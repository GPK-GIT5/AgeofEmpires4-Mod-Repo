---------------------------------------------------------------------------------------------------
-- CBA Debug — Coverage Test (10 Batches)
-- Invokes gameplay functions via pcall to verify they exist and don't crash.
-- Console: Debug_CoverageTest()    (~40s)
--          Debug_CoverageBatch(n)  (individual batch 1-10)
---------------------------------------------------------------------------------------------------

_cba_coverage = {
	results = {},
	batch_results = {},
	untested = {},
	batch_delay = 4,
}

function _Cov_RunTest(name, test_fn)
	local ok, result_or_err = pcall(function()
		local p, d = test_fn()
		return {pass = p, detail = d or ""}
	end)
	if not ok then
		table.insert(_cba_coverage.results, {name = name, pass = false, detail = "CRASH: " .. tostring(result_or_err)})
		print(string.format("    [COV] %s — CRASH: %s", name, tostring(result_or_err)))
	else
		local r = result_or_err
		table.insert(_cba_coverage.results, {name = name, pass = r.pass, detail = r.detail})
		print(string.format("    [COV] %s — %s: %s", name, r.pass and "PASS" or "FAIL", r.detail))
	end
end

function _Cov_BatchHeader(num, name)
	print("")
	print(string.format("  ---- COVERAGE BATCH %d: %s ----", num, string.upper(name)))
end

---------------------------------------------------------------------------------------------------
-- Batch 1: Engine API
---------------------------------------------------------------------------------------------------

function _Cov_Batch1_EngineAPI()
	_Cov_BatchHeader(1, "Engine API")

	_Cov_RunTest("1.1 World_GetPlayerCount", function()
		local ok, c = pcall(World_GetPlayerCount)
		if not ok then return false, "call failed" end
		return true, c .. " players"
	end)

	_Cov_RunTest("1.2 Game_GetLocalPlayer", function()
		local ok, lp = pcall(Game_GetLocalPlayer)
		return ok, ok and "resolved" or "failed"
	end)

	_Cov_RunTest("1.3 World_GetGameTime", function()
		local ok, t = pcall(World_GetGameTime)
		if not ok then return false, "call failed" end
		return true, string.format("%.1fs", t)
	end)
end

---------------------------------------------------------------------------------------------------
-- Batch 2: Blueprint Resolution
---------------------------------------------------------------------------------------------------

function _Cov_Batch2_BlueprintResolution()
	_Cov_BatchHeader(2, "Blueprint Resolution")

	_Cov_RunTest("2.1 BP_GetEntityBlueprint basic", function()
		local ok, bp = pcall(BP_GetEntityBlueprint, "building_house_abb")
		return ok and bp ~= nil, ok and "resolved" or "failed"
	end)

	_Cov_RunTest("2.2 BP_GetSquadBlueprint basic", function()
		local ok, bp = pcall(BP_GetSquadBlueprint, "unit_spearman_1_abb")
		return ok and bp ~= nil, ok and "resolved" or "failed"
	end)

	_Cov_RunTest("2.3 AGS_ENTITY_TABLE lookup", function()
		if AGS_ENTITY_TABLE == nil then return false, "nil" end
		local eng = AGS_ENTITY_TABLE["english"]
		if eng == nil then return false, "english entry nil" end
		return true, "english.castle=" .. tostring(eng.castle)
	end)
end

---------------------------------------------------------------------------------------------------
-- Batch 3: Economy Functions
---------------------------------------------------------------------------------------------------

function _Cov_Batch3_Economy()
	_Cov_BatchHeader(3, "Economy")

	_Cov_RunTest("3.1 Player_GetResource", function()
		local p = PLAYERS[1]
		if p == nil then return false, "no players" end
		local ok, food = pcall(Player_GetResource, p.id, RT_Food)
		return ok, ok and ("food=" .. tostring(food)) or "failed"
	end)

	_Cov_RunTest("3.2 Auto-resource function", function()
		local exists = type(AGS_AutoResources) == "function"
		return exists, exists and "found" or "missing"
	end)
end

---------------------------------------------------------------------------------------------------
-- Batch 4: Team & Player
---------------------------------------------------------------------------------------------------

function _Cov_Batch4_TeamPlayer()
	_Cov_BatchHeader(4, "Team & Player")

	_Cov_RunTest("4.1 Player_GetRaceName", function()
		local p = PLAYERS[1]
		if p == nil then return false, "no players" end
		local ok, civ = pcall(Player_GetRaceName, p.id)
		return ok, ok and civ or "failed"
	end)

	_Cov_RunTest("4.2 Core_IsPlayerEliminated", function()
		local p = PLAYERS[1]
		if p == nil then return false, "no players" end
		local ok, elim = pcall(Core_IsPlayerEliminated, p.id)
		return ok, ok and tostring(elim) or "failed"
	end)

	_Cov_RunTest("4.3 Player_ObserveRelationship", function()
		if #PLAYERS < 2 then return true, "< 2 players, skip" end
		local ok, rel = pcall(Player_ObserveRelationship, PLAYERS[1].id, PLAYERS[2].id)
		return ok, ok and tostring(rel) or "failed"
	end)
end

---------------------------------------------------------------------------------------------------
-- Batch 5: Options System
---------------------------------------------------------------------------------------------------

function _Cov_Batch5_Options()
	_Cov_BatchHeader(5, "Options")

	_Cov_RunTest("5.1 CBA_Options functions exist", function()
		local fns = {
			"CBA_Options_BuildingLimit_SetupObjective",
			"CBA_Options_BuildingLimit_ConstructionStart",
			"CBA_Options_SiegeLimit_Disable",
		}
		local found = 0
		for _, fn in ipairs(fns) do
			if type(_G[fn]) == "function" then found = found + 1 end
		end
		return found == #fns, found .. "/" .. #fns .. " found"
	end)

	_Cov_RunTest("5.2 _buildingLimit module", function()
		return _buildingLimit ~= nil, type(_buildingLimit)
	end)
end

---------------------------------------------------------------------------------------------------
-- Batch 6: Rewards System
---------------------------------------------------------------------------------------------------

function _Cov_Batch6_Rewards()
	_Cov_BatchHeader(6, "Rewards")

	_Cov_RunTest("6.1 CBA_Rewards_nextRequirement callable", function()
		if type(CBA_Rewards_nextRequirement) ~= "function" then return false, "not a function" end
		local p = PLAYERS[1]
		if p == nil then return false, "no players" end
		local ok, req = pcall(CBA_Rewards_nextRequirement, p)
		return ok, ok and ("next=" .. tostring(req)) or "call failed"
	end)

	_Cov_RunTest("6.2 Reward tables per civ type", function()
		if _CBA == nil or _CBA.rewards == nil then return false, "no rewards" end
		local keys = {}
		for k in pairs(_CBA.rewards) do table.insert(keys, k) end
		return #keys > 0, #keys .. " reward groups"
	end)
end

---------------------------------------------------------------------------------------------------
-- Batch 7: Objectives System
---------------------------------------------------------------------------------------------------

function _Cov_Batch7_Objectives()
	_Cov_BatchHeader(7, "Objectives")

	_Cov_RunTest("7.1 _mod.objective exists", function()
		return _mod.objective ~= nil, type(_mod.objective)
	end)

	_Cov_RunTest("7.2 Objective counter state", function()
		return true, string.format("met=%s req=%s",
			tostring(_mod.objective_meet), tostring(_mod.objective_requirement))
	end)
end

---------------------------------------------------------------------------------------------------
-- Batch 8: Win Conditions
---------------------------------------------------------------------------------------------------

function _Cov_Batch8_WinConditions()
	_Cov_BatchHeader(8, "Win Conditions")

	_Cov_RunTest("8.1 Annihilation functions", function()
		local fns = {"Annihilation_CheckAnnihilationCondition", "Annihilation_CheckVictory"}
		local found = 0
		for _, fn in ipairs(fns) do
			if type(_G[fn]) == "function" then found = found + 1 end
		end
		return found == #fns, found .. "/" .. #fns
	end)

	_Cov_RunTest("8.2 Religious functions", function()
		local exists = type(Religious_Update) == "function"
		return exists, exists and "found" or "missing"
	end)

	_Cov_RunTest("8.3 Wonder functions", function()
		local exists = type(Wonder_Update) == "function"
		return exists, exists and "found" or "missing"
	end)
end

---------------------------------------------------------------------------------------------------
-- Batch 9: Auto Systems
---------------------------------------------------------------------------------------------------

function _Cov_Batch9_AutoSystems()
	_Cov_BatchHeader(9, "Auto Systems")

	_Cov_RunTest("9.1 Auto-population function", function()
		local exists = type(AGS_IncreasePopulation) == "function"
		return exists, exists and "found" or "missing"
	end)

	_Cov_RunTest("9.2 Auto-age functions", function()
		local fns = {"CBA_Auto_Age", "CBA_Auto_Age_1", "CBA_Auto_Age_2", "CBA_Auto_Age_3"}
		local found = 0
		for _, fn in ipairs(fns) do
			if type(_G[fn]) == "function" then found = found + 1 end
		end
		return found == #fns, found .. "/" .. #fns
	end)
end

---------------------------------------------------------------------------------------------------
-- Batch 10: Debug Self-Test
---------------------------------------------------------------------------------------------------

function _Cov_Batch10_DebugSelfTest()
	_Cov_BatchHeader(10, "Debug Self-Test")

	_Cov_RunTest("10.1 _cba_debug table", function()
		return _cba_debug ~= nil and _cba_debug.enabled, "enabled=" .. tostring(_cba_debug.enabled)
	end)

	_Cov_RunTest("10.2 Debug entry points", function()
		local fns = {"Debug_FullValidation", "Debug_StressTest", "Debug_RunSmokeTests", "Debug_SetBaseline"}
		local found = 0
		for _, fn in ipairs(fns) do
			if type(_G[fn]) == "function" then found = found + 1 end
		end
		return found == #fns, found .. "/" .. #fns
	end)

	_Cov_RunTest("10.3 DebugLog function", function()
		local ok, _ = pcall(DebugLog, "selftest", "coverage probe")
		return ok, "DebugLog callable"
	end)
end

---------------------------------------------------------------------------------------------------
-- Coverage Final Report
---------------------------------------------------------------------------------------------------

function _Cov_FinalReport()
	print("")
	print("  ======== COVERAGE TEST COMPLETE ========")
	local total = #_cba_coverage.results
	local fails = 0
	for _, r in ipairs(_cba_coverage.results) do
		if not r.pass then fails = fails + 1 end
	end
	print(string.format("  TOTAL: %d/%d passed", total - fails, total))
	if fails > 0 then
		print("  FAILURES:")
		for _, r in ipairs(_cba_coverage.results) do
			if not r.pass then
				print(string.format("    [FAIL] %s — %s", r.name, r.detail))
			end
		end
	end
end

---------------------------------------------------------------------------------------------------
-- Public Entry Points
---------------------------------------------------------------------------------------------------

function Debug_CoverageTest()
	_cba_coverage.results = {}
	_cba_coverage.batch_results = {}
	_cba_coverage.untested = {}
	_cba_debug.enabled = true

	print("")
	print("============================================")
	print("  CBA DEBUG — COVERAGE TEST (10 batches, ~40s)")
	print("============================================")

	_Cov_Batch1_EngineAPI()
	Rule_AddOneShot(_Cov_Batch2_BlueprintResolution, _cba_coverage.batch_delay)
	Rule_AddOneShot(_Cov_Batch3_Economy, _cba_coverage.batch_delay * 2)
	Rule_AddOneShot(_Cov_Batch4_TeamPlayer, _cba_coverage.batch_delay * 3)
	Rule_AddOneShot(_Cov_Batch5_Options, _cba_coverage.batch_delay * 4)
	Rule_AddOneShot(_Cov_Batch6_Rewards, _cba_coverage.batch_delay * 5)
	Rule_AddOneShot(_Cov_Batch7_Objectives, _cba_coverage.batch_delay * 6)
	Rule_AddOneShot(_Cov_Batch8_WinConditions, _cba_coverage.batch_delay * 7)
	Rule_AddOneShot(_Cov_Batch9_AutoSystems, _cba_coverage.batch_delay * 8)
	Rule_AddOneShot(_Cov_Batch10_DebugSelfTest, _cba_coverage.batch_delay * 9)
	Rule_AddOneShot(_Cov_FinalReport, _cba_coverage.batch_delay * 10)
end

function Debug_CoverageBatch(n)
	_cba_debug.enabled = true
	local batches = {
		_Cov_Batch1_EngineAPI,
		_Cov_Batch2_BlueprintResolution,
		_Cov_Batch3_Economy,
		_Cov_Batch4_TeamPlayer,
		_Cov_Batch5_Options,
		_Cov_Batch6_Rewards,
		_Cov_Batch7_Objectives,
		_Cov_Batch8_WinConditions,
		_Cov_Batch9_AutoSystems,
		_Cov_Batch10_DebugSelfTest,
	}
	if n < 1 or n > #batches then
		print("[CBA_DEBUG] Batch must be 1-10")
		return
	end
	_cba_coverage.results = {}
	batches[n]()
end
