---------------------------------------------------------------------------------------------------
-- CBA Debug — Stress Test (8 Stages)
-- Exercises all systems across all 16+ civs with pcall safety.
-- Console: Debug_StressTest()      (~25s)
--          Debug_StressStage(n)    (individual stage 1-8)
---------------------------------------------------------------------------------------------------

STRESS_ALL_CIVS = {
	"english", "chinese", "french", "hre", "mongol", "rus",
	"sultanate", "abbasid", "malian", "ottoman",
	"japanese", "byzantine",
	"chinese_ha_01", "abbasid_ha_01", "french_ha_01", "hre_ha_01",
}

_cba_stress = {
	results = {},
	stage_results = {},
	stage_delay = 3,
}

---------------------------------------------------------------------------------------------------
-- Stress Test Runner
---------------------------------------------------------------------------------------------------

function _Stress_RunTest(name, test_fn)
	local ok, result_or_err = pcall(function()
		local p, d = test_fn()
		return {pass = p, detail = d or ""}
	end)
	if not ok then
		table.insert(_cba_stress.results, {name = name, pass = false, detail = "CRASH: " .. tostring(result_or_err)})
		print(string.format("    [STRESS] %s — CRASH: %s", name, tostring(result_or_err)))
	else
		local r = result_or_err
		table.insert(_cba_stress.results, {name = name, pass = r.pass, detail = r.detail})
		print(string.format("    [STRESS] %s — %s: %s", name, r.pass and "PASS" or "FAIL", r.detail))
	end
end

function _Stress_StageHeader(num, name)
	print("")
	print(string.format("  ---- STRESS STAGE %d: %s ----", num, string.upper(name)))
end

---------------------------------------------------------------------------------------------------
-- Stage 1: Core System Tables
---------------------------------------------------------------------------------------------------

function _Stress_Stage1_CoreSystem()
	_Stress_StageHeader(1, "Core System")

	_Stress_RunTest("1.1 PLAYERS count", function()
		return #PLAYERS > 0, #PLAYERS .. " players"
	end)

	_Stress_RunTest("1.2 _mod module registration", function()
		return _mod ~= nil and _mod.module == "Mod", tostring(_mod and _mod.module)
	end)

	_Stress_RunTest("1.3 _CBA table", function()
		return _CBA ~= nil, type(_CBA)
	end)

	_Stress_RunTest("1.4 AGS_GLOBAL_SETTINGS", function()
		return AGS_GLOBAL_SETTINGS ~= nil, type(AGS_GLOBAL_SETTINGS)
	end)
end

---------------------------------------------------------------------------------------------------
-- Stage 2: Blueprint Resolution
---------------------------------------------------------------------------------------------------

function _Stress_Stage2_Blueprints()
	_Stress_StageHeader(2, "Blueprints")

	_Stress_RunTest("2.1 Keep BP resolution", function()
		local resolved = 0
		local failed = {}
		for civ, data in pairs(AGS_ENTITY_TABLE) do
			if civ ~= "neutral" and data.castle and data.castle ~= false then
				local ok, ebp = pcall(BP_GetEntityBlueprint, data.castle)
				if ok and ebp then
					resolved = resolved + 1
				else
					table.insert(failed, civ)
				end
			end
		end
		if #failed > 0 then return false, "unresolved: " .. table.concat(failed, ", ") end
		return true, resolved .. " resolved"
	end)

	_Stress_RunTest("2.2 TC BP resolution", function()
		local resolved = 0
		local failed = {}
		for civ, data in pairs(AGS_ENTITY_TABLE) do
			if civ ~= "neutral" and data.town_center then
				local ok, ebp = pcall(BP_GetEntityBlueprint, data.town_center)
				if ok and ebp then
					resolved = resolved + 1
				else
					table.insert(failed, civ)
				end
			end
		end
		if #failed > 0 then return false, "unresolved: " .. table.concat(failed, ", ") end
		return true, resolved .. " resolved"
	end)

	_Stress_RunTest("2.3 Villager BP resolution", function()
		local resolved = 0
		local failed = {}
		for civ, data in pairs(AGS_ENTITY_TABLE) do
			if civ ~= "neutral" and data.villager then
				local ok, sbp = pcall(BP_GetSquadBlueprint, data.villager)
				if ok and sbp then
					resolved = resolved + 1
				else
					table.insert(failed, civ)
				end
			end
		end
		if #failed > 0 then return false, "unresolved: " .. table.concat(failed, ", ") end
		return true, resolved .. " resolved"
	end)
end

---------------------------------------------------------------------------------------------------
-- Stage 3: Rewards System
---------------------------------------------------------------------------------------------------

function _Stress_Stage3_Rewards()
	_Stress_StageHeader(3, "Rewards")

	_Stress_RunTest("3.1 Reward table exists", function()
		if _CBA == nil or _CBA.rewards == nil then return false, "_CBA.rewards nil" end
		return true, "present"
	end)

	_Stress_RunTest("3.2 Reward entry count", function()
		if _CBA == nil or _CBA.rewards == nil then return false, "no rewards" end
		local count = 0
		for _ in pairs(_CBA.rewards) do count = count + 1 end
		return count > 0, count .. " reward sets"
	end)

	_Stress_RunTest("3.3 CBA_Rewards functions exist", function()
		local fns = {"CBA_Rewards_OnEntityKilled", "CBA_Rewards_SpawnUnits", "CBA_Rewards_nextRequirement"}
		local missing = {}
		for _, fn in ipairs(fns) do
			if type(_G[fn]) ~= "function" then
				table.insert(missing, fn)
			end
		end
		if #missing > 0 then return false, "missing: " .. table.concat(missing, ", ") end
		return true, #fns .. " functions found"
	end)
end

---------------------------------------------------------------------------------------------------
-- Stage 4: Economy System
---------------------------------------------------------------------------------------------------

function _Stress_Stage4_Economy()
	_Stress_StageHeader(4, "Economy")

	_Stress_RunTest("4.1 Resource types accessible", function()
		local ok, _ = pcall(function()
			return RT_Food and RT_Wood and RT_Gold and RT_Stone
		end)
		return ok, "all 4 resource types"
	end)

	_Stress_RunTest("4.2 Player resources valid", function()
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			local ok, food = pcall(Player_GetResource, player.id, RT_Food)
			if not ok then table.insert(issues, "P" .. i .. " food") end
		end
		if #issues > 0 then return false, table.concat(issues, ", ") end
		return true, #PLAYERS .. " players OK"
	end)
end

---------------------------------------------------------------------------------------------------
-- Stage 5: Population & Age
---------------------------------------------------------------------------------------------------

function _Stress_Stage5_PopAge()
	_Stress_StageHeader(5, "Population & Age")

	_Stress_RunTest("5.1 Pop cap per player", function()
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			local ok, cap = pcall(Player_GetCurrentPopulationCap, player.id, CT_Personnel)
			if not ok then table.insert(issues, "P" .. i) end
		end
		if #issues > 0 then return false, "cap read fail: " .. table.concat(issues, ", ") end
		return true, #PLAYERS .. " players OK"
	end)

	_Stress_RunTest("5.2 Current age per player", function()
		local ages = {}
		for i, player in ipairs(PLAYERS) do
			local ok, age = pcall(Player_GetCurrentAge, player.id)
			table.insert(ages, ok and tostring(age) or "ERR")
		end
		return true, "ages: " .. table.concat(ages, ",")
	end)
end

---------------------------------------------------------------------------------------------------
-- Stage 6: Win Conditions
---------------------------------------------------------------------------------------------------

function _Stress_Stage6_WinConditions()
	_Stress_StageHeader(6, "Win Conditions")

	_Stress_RunTest("6.1 Annihilation module", function()
		return _annihilation ~= nil, type(_annihilation)
	end)

	_Stress_RunTest("6.2 Religious module", function()
		return _religious ~= nil, type(_religious)
	end)

	_Stress_RunTest("6.3 Wonder module", function()
		return _wonder ~= nil, type(_wonder)
	end)

	_Stress_RunTest("6.4 Surrender module", function()
		local ok = type(Surrender_CheckVictory) == "function"
		return ok, ok and "function found" or "missing"
	end)
end

---------------------------------------------------------------------------------------------------
-- Stage 7: Restrictions (Building/Siege)
---------------------------------------------------------------------------------------------------

function _Stress_Stage7_Restrictions()
	_Stress_StageHeader(7, "Restrictions")

	_Stress_RunTest("7.1 CBA_Options module functions", function()
		local fns = {
			"CBA_Options_BuildingLimit_ConstructionStart",
			"CBA_Options_BuildingLimit_OnEntityKilled",
			"CBA_Options_SiegeLimit_Disable",
		}
		local missing = {}
		for _, fn in ipairs(fns) do
			if type(_G[fn]) ~= "function" then table.insert(missing, fn) end
		end
		if #missing > 0 then return false, "missing: " .. table.concat(missing, ", ") end
		return true, #fns .. " functions found"
	end)

	_Stress_RunTest("7.2 Building limit counters non-negative", function()
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			local bld = player.obj_buildingLimit_count
			if type(bld) == "number" and bld < 0 then
				table.insert(issues, string.format("P%d=%d", i, bld))
			end
		end
		if #issues > 0 then return false, "negative: " .. table.concat(issues, ", ") end
		return true, "all non-negative"
	end)
end

---------------------------------------------------------------------------------------------------
-- Stage 8: Player State
---------------------------------------------------------------------------------------------------

function _Stress_Stage8_PlayerState()
	_Stress_StageHeader(8, "Player State")

	_Stress_RunTest("8.1 Player team assignments", function()
		local teams = {}
		for i, player in ipairs(PLAYERS) do
			local t = player.team or 0
			teams[t] = (teams[t] or 0) + 1
		end
		local parts = {}
		for t, c in pairs(teams) do table.insert(parts, "T" .. t .. "=" .. c) end
		return true, table.concat(parts, " ")
	end)

	_Stress_RunTest("8.2 Player eliminated state", function()
		local active = 0
		for i, player in ipairs(PLAYERS) do
			local ok, elim = pcall(Core_IsPlayerEliminated, player.id)
			if ok and not elim then active = active + 1 end
		end
		return true, active .. "/" .. #PLAYERS .. " active"
	end)

	_Stress_RunTest("8.3 No orphaned entities", function()
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			if player.keep and player.keep.entity then
				local ok, owner = pcall(Entity_GetPlayerOwner, player.keep.entity)
				if ok and owner ~= player.id then
					table.insert(issues, "P" .. i .. " keep owned by other")
				end
			end
		end
		if #issues > 0 then return false, table.concat(issues, ", ") end
		return true, "all keeps owned correctly"
	end)
end

---------------------------------------------------------------------------------------------------
-- Stress Final Report
---------------------------------------------------------------------------------------------------

function _Stress_FinalReport()
	print("")
	print("  ======== STRESS TEST COMPLETE ========")
	local total = #_cba_stress.results
	local fails = 0
	for _, r in ipairs(_cba_stress.results) do
		if not r.pass then fails = fails + 1 end
	end
	print(string.format("  TOTAL: %d/%d passed", total - fails, total))
	if fails > 0 then
		print("  FAILURES:")
		for _, r in ipairs(_cba_stress.results) do
			if not r.pass then
				print(string.format("    [FAIL] %s — %s", r.name, r.detail))
			end
		end
	end
end

---------------------------------------------------------------------------------------------------
-- Public Entry Points
---------------------------------------------------------------------------------------------------

function Debug_StressTest()
	_cba_stress.results = {}
	_cba_stress.stage_results = {}
	_cba_debug.enabled = true

	print("")
	print("============================================")
	print("  CBA DEBUG — STRESS TEST (8 stages, ~25s)")
	print("============================================")

	_Stress_Stage1_CoreSystem()
	Rule_AddOneShot(_Stress_Stage2_Blueprints, _cba_stress.stage_delay)
	Rule_AddOneShot(_Stress_Stage3_Rewards, _cba_stress.stage_delay * 2)
	Rule_AddOneShot(_Stress_Stage4_Economy, _cba_stress.stage_delay * 3)
	Rule_AddOneShot(_Stress_Stage5_PopAge, _cba_stress.stage_delay * 4)
	Rule_AddOneShot(_Stress_Stage6_WinConditions, _cba_stress.stage_delay * 5)
	Rule_AddOneShot(_Stress_Stage7_Restrictions, _cba_stress.stage_delay * 6)
	Rule_AddOneShot(_Stress_Stage8_PlayerState, _cba_stress.stage_delay * 7)
	Rule_AddOneShot(_Stress_FinalReport, _cba_stress.stage_delay * 8)
end

function Debug_StressStage(n)
	_cba_debug.enabled = true
	local stages = {
		_Stress_Stage1_CoreSystem,
		_Stress_Stage2_Blueprints,
		_Stress_Stage3_Rewards,
		_Stress_Stage4_Economy,
		_Stress_Stage5_PopAge,
		_Stress_Stage6_WinConditions,
		_Stress_Stage7_Restrictions,
		_Stress_Stage8_PlayerState,
	}
	if n < 1 or n > #stages then
		print("[CBA_DEBUG] Stage must be 1-8")
		return
	end
	_cba_stress.results = {}
	stages[n]()
end
