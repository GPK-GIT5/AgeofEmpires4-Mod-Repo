---------------------------------------------------------------------------------------------------
-- Authors:
-- Relic
-- Woprock
--
-- Description:
-- Alters all gathering rates.
---------------------------------------------------------------------------------------------------

AGS_GATHER_RATES_MODULE = "AGS_GatherRates"
AGS_GATHER_RATES_MODIFIERS = { }

---------------------------------------------------------------------------------------------------
-- Delegates:
---------------------------------------------------------------------------------------------------

Core_RegisterModule(AGS_GATHER_RATES_MODULE)	

function AGS_GatherRates_UpdateModuleSettings()
	AGS_Print("AGS_GatherRates_UpdateModuleSettings")
	if AGS_GLOBAL_SETTINGS.gatherRates == 1.00 then
		Core_UnregisterModule(AGS_gather_RATES_MODULE)
	end
end

function AGS_GatherRates_PresetFinalize()	
	AGS_Print("AGS_GatherRates_PresetFinalize")
	AGS_GatherRates_ApplyBonus(BP_GetEntityBlueprintsWithType(AGS_BP_BUILDING))	
	AGS_GatherRates_ApplyBonus(BP_GetEntityBlueprintsWithType(AGS_BP_UNIT_CLASS))	
end

---------------------------------------------------------------------------------------------------
-- Functions:
---------------------------------------------------------------------------------------------------

function AGS_GatherRates_ApplyBonus(bps)
	for _, ebp in pairs(bps) do 
		if AGS_GATHER_RATES_MODIFIERS[ebp.PropertyBagGroupID] == nil then
			AGS_GATHER_RATES_MODIFIERS[ebp.PropertyBagGroupID] = true
			for _, player in pairs(PLAYERS) do	
				AGS_GatherRates_ApplyModifier(player.id, ebp, "resource_entity_harvest_rate_food", AGS_GLOBAL_SETTINGS.gatherRates)
				AGS_GatherRates_ApplyModifier(player.id, ebp, "resource_entity_harvest_rate_wood", AGS_GLOBAL_SETTINGS.gatherRates)
				AGS_GatherRates_ApplyModifier(player.id, ebp, "resource_entity_harvest_rate_gold", AGS_GLOBAL_SETTINGS.gatherRates)
				AGS_GatherRates_ApplyModifier(player.id, ebp, "resource_entity_harvest_rate_stone", AGS_GLOBAL_SETTINGS.gatherRates)
				
			end
		end
	end
end
-- Apply function.
function AGS_GatherRates_ApplyModifier(player_id, modifier_ebp, modifier_type, modifier_value)
	Modifier_ApplyToPlayer(Modifier_Create(MAT_EntityType, modifier_type, MUT_Multiplication, false, modifier_value, modifier_ebp), player_id, 0.0)
end	