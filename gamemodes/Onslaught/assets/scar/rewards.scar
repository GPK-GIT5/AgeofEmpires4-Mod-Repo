Core_RegisterModule(CBA_REWARDS_CBAULE)	

function CBA_Rewards_UpdateModuleSettings()
	if AGS_GLOBAL_SETTINGS.CBA_Rewards == "disabled" then
		Core_UnregisterModule(CBA_REWARDS_CBAULE)
	end
end

