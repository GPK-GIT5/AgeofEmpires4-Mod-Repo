				for id, upgrade_bp in pairs(REWARD_UPGRADE_ENG) do
					Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint(upgrade_bp), ITEM_REMOVED)	
				end
			end
			if player_civ == "chinese" then
				for id, upgrade_bp in pairs(REWARD_UPGRADE_CHI) do
					Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint(upgrade_bp), ITEM_REMOVED)	
				end
			end
			if player_civ == "french" then
				for id, upgrade_bp in pairs(REWARD_UPGRADE_FRE) do
					Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint(upgrade_bp), ITEM_REMOVED)	
				end
			end
			if player_civ == "hre" then
				for id, upgrade_bp in pairs(REWARD_UPGRADE_HRE) do
					Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint(upgrade_bp), ITEM_REMOVED)	
				end
			end
			if player_civ == "mongol" then
				for id, upgrade_bp in pairs(REWARD_UPGRADE_MON) do
					Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint(upgrade_bp), ITEM_REMOVED)	
				end
			end
			if player_civ == "rus" then
				for id, upgrade_bp in pairs(REWARD_UPGRADE_RUS) do
					Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint(upgrade_bp), ITEM_REMOVED)	
				end
			end
			if player_civ == "sultante" then
