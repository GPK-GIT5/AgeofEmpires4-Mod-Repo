---------------------------------------------------------------------------------------------------
-- Tier index helper: returns the 3 commandery entries for a given tier name.
---------------------------------------------------------------------------------------------------

function BoonSelection_GetTemplarChoicesForTier(tier_name)
	local offset = 0
	if tier_name == "feudal" then
		offset = 0
	elseif tier_name == "castle" then
		offset = 3
	elseif tier_name == "imperial" then
		offset = 6
	else
		return nil
	end

	local choices = {}
	for i = 1, 3 do
		local entry = _BOON_TEMPLAR_COMMANDERIES[offset + i]
		if entry ~= nil then
			table.insert(choices, {
				index = i,
				upgrade = entry.upgrade,
				title = entry.title,
				unit = entry.unit,
				desc = entry.desc,
				icon = entry.icon,
			})
		end
	end

	if #choices == 0 then
		return nil
	end
	return choices
end

---------------------------------------------------------------------------------------------------
-- Tier title helper: returns display title for the selection prompt.
---------------------------------------------------------------------------------------------------

function BoonSelection_GetTemplarTierTitle(tier_name)
	if tier_name == "feudal" then
		return "Choose Feudal Age Commandery"
	elseif tier_name == "castle" then
		return "Choose Castle Age Commandery"
	elseif tier_name == "imperial" then
		return "Choose Imperial Age Commandery"
	end
	return "Choose Commandery"
end

function BoonSelection_GetTemplarTierSubtitle(tier_name)
	if tier_name == "feudal" then
		return "Select a Commandery to advance to the Feudal Age"
	elseif tier_name == "castle" then
		return "Select a Commandery to advance to the Castle Age"
	elseif tier_name == "imperial" then
		return "Select a Commandery to advance to the Imperial Age"
	end
	return "Select a Commandery to advance"
end

---------------------------------------------------------------------------------------------------
-- Abbasid Wing Data (base abbasid)
-- 4 wings per tier (Culture, Economy, Military, Trade).
-- Tier key "feudal" = dark-age wings (chosen when aging to Feudal), etc.
---------------------------------------------------------------------------------------------------

_BOON_ABBASID_WINGS = {
	feudal = {
		{ upgrade = "upgrade_add_culture_wing",  title = "Culture Wing",  desc = "Improves technology research speed and healing rates." },
		{ upgrade = "upgrade_add_economy_wing",  title = "Economic Wing", desc = "Boosts villager gathering rates and construction speed." },
		{ upgrade = "upgrade_add_military_wing", title = "Military Wing", desc = "Enhances military production speed and unit stats." },
		{ upgrade = "upgrade_add_trade_wing",    title = "Trade Wing",    desc = "Improves trade ship speed and market exchange rates." },
	},
	castle = {
		{ upgrade = "upgrade_add_culture_wing_feudal",  title = "Culture Wing",  desc = "Further improves research and healing capabilities." },
		{ upgrade = "upgrade_add_economy_wing_feudal",  title = "Economic Wing", desc = "Further boosts gathering and construction speed." },
		{ upgrade = "upgrade_add_military_wing_feudal", title = "Military Wing", desc = "Further enhances military production and stats." },
		{ upgrade = "upgrade_add_trade_wing_feudal",    title = "Trade Wing",    desc = "Further improves trade income and market rates." },
	},
	imperial = {
		{ upgrade = "upgrade_add_culture_wing_castle",  title = "Culture Wing",  desc = "Maximum culture bonuses for research and healing." },
		{ upgrade = "upgrade_add_economy_wing_castle",  title = "Economic Wing", desc = "Maximum economy bonuses for gathering and building." },
		{ upgrade = "upgrade_add_military_wing_castle", title = "Military Wing", desc = "Maximum military bonuses for production and combat." },
		{ upgrade = "upgrade_add_trade_wing_castle",    title = "Trade Wing",    desc = "Maximum trade bonuses for income and exchange." },
	},
}

function BoonSelection_GetAbbasidChoicesForTier(tier_name, chosen_families)
	local tier_data = _BOON_ABBASID_WINGS[tier_name]
	if tier_data == nil then return nil end

	local choices = {}
	for i, entry in ipairs(tier_data) do
		local dominated = false
		if chosen_families ~= nil then
			local family = BoonSelection_GetWingFamily(entry.upgrade)
			if family ~= nil and chosen_families[family] then
				dominated = true
			end
		end
		if not dominated then
			table.insert(choices, {
				index = #choices + 1,
				upgrade = entry.upgrade,
				title = entry.title,
				unit = "House of Wisdom",
				desc = entry.desc,
				icon = BoonSelection_ResolveUpgradeIcon(entry.upgrade),
			})
		end
	end
	return (#choices > 0) and choices or nil
end

function BoonSelection_GetAbbasidTierTitle(tier_name)
	if tier_name == "feudal" then
		return "Choose Feudal Age Wing"
	elseif tier_name == "castle" then
		return "Choose Castle Age Wing"
	elseif tier_name == "imperial" then
		return "Choose Imperial Age Wing"
	end
	return "Choose Wing"
end

function BoonSelection_GetAbbasidTierSubtitle(tier_name)
	if tier_name == "feudal" then
		return "Select a House of Wisdom wing to advance to the Feudal Age"
	elseif tier_name == "castle" then
		return "Select a House of Wisdom wing to advance to the Castle Age"
	elseif tier_name == "imperial" then
		return "Select a House of Wisdom wing to advance to the Imperial Age"
	end
	return "Select a House of Wisdom wing"
end

