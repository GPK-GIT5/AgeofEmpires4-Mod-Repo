---------------------------------------------------------------------------------------------------
-- Boon Selection UI — Choice Data Definitions
-- Maps upgrade blueprints to display info (title, description, icon, unit name).
-- Extensible: add new civs or boon sets by registering data tables.
---------------------------------------------------------------------------------------------------

---------------------------------------------------------------------------------------------------
-- Runtime icon resolution helper
-- Uses BP_GetUpgradeUIInfo to fetch the engine icon path for an upgrade blueprint.
-- Returns a pack:// XAML-usable string, or "" on failure.
---------------------------------------------------------------------------------------------------

function BoonSelection_ResolveUpgradeIcon(upg_name)
	if upg_name == nil or upg_name == "" then return "" end
	local ok_bp, ubp = pcall(BP_GetUpgradeBlueprint, upg_name)
	if not ok_bp or ubp == nil then return "" end
	local ok_ui, uiinfo = pcall(BP_GetUpgradeUIInfo, ubp)
	if not ok_ui or uiinfo == nil or uiinfo.iconName == nil then return "" end
	return string.format("pack://application:,,,/WPFGUI;component/%s.png", string.gsub(uiinfo.iconName, "\\", "/"))
end

---------------------------------------------------------------------------------------------------
-- Wing family utilities
-- Used by Abbasid/Ayyubid to enforce one-pick-per-family uniqueness across tier choices.
---------------------------------------------------------------------------------------------------

_BOON_WING_FAMILIES = { "culture", "economy", "military", "trade" }

-- Returns the wing family name ("culture", "economy", "military", "trade") from an upgrade BP name.
function BoonSelection_GetWingFamily(upgrade_name)
	if upgrade_name == nil or upgrade_name == "" then return nil end
	if string.find(upgrade_name, "culture_wing") then return "culture" end
	if string.find(upgrade_name, "economy_wing") then return "economy" end
	if string.find(upgrade_name, "military_wing") then return "military" end
	if string.find(upgrade_name, "trade_wing") then return "trade" end
	return nil
end

-- Returns a set { family = true } of wing families already completed by a player,
-- checking all tier upgrades in _AUTOAGE_SPECIAL_UPGRADES.
function BoonSelection_GetChosenWingFamilies(player_id, civ_name)
	local chosen = {}
	if player_id == nil or civ_name == nil then return chosen end
	local civ_cfg = _AUTOAGE_SPECIAL_UPGRADES[civ_name]
	if civ_cfg == nil then return chosen end

	for _, tier_name in ipairs({"feudal", "castle", "imperial"}) do
		local tier_upgrades = civ_cfg[tier_name]
		if tier_upgrades ~= nil then
			for _, upg_name in ipairs(tier_upgrades) do
				local ok_bp, ubp = pcall(BP_GetUpgradeBlueprint, upg_name)
				if ok_bp and ubp ~= nil and Player_HasUpgrade(player_id, ubp) then
					local family = BoonSelection_GetWingFamily(upg_name)
					if family ~= nil then
						chosen[family] = true
					end
				end
			end
		end
	end

	return chosen
end

