---------------------------------------------------------------------------------------------------
-- Unified dispatcher — returns (choices, title, subtitle) for any supported civ.
---------------------------------------------------------------------------------------------------

function BoonSelection_GetChoicesForCiv(civ_name, tier_name, player_id)
	if civ_name == "templar" then
		return BoonSelection_GetTemplarChoicesForTier(tier_name),
			BoonSelection_GetTemplarTierTitle(tier_name),
			BoonSelection_GetTemplarTierSubtitle(tier_name)
	elseif civ_name == "abbasid" then
		local chosen = (player_id ~= nil) and BoonSelection_GetChosenWingFamilies(player_id, civ_name) or nil
		return BoonSelection_GetAbbasidChoicesForTier(tier_name, chosen),
			BoonSelection_GetAbbasidTierTitle(tier_name),
			BoonSelection_GetAbbasidTierSubtitle(tier_name)
	elseif civ_name == "abbasid_ha_01" then
		local chosen = (player_id ~= nil) and BoonSelection_GetChosenWingFamilies(player_id, civ_name) or nil
		return BoonSelection_GetAyyubidChoicesForTier(tier_name, chosen),
			BoonSelection_GetAyyubidTierTitle(tier_name),
			BoonSelection_GetAyyubidTierSubtitle(tier_name)
	elseif civ_name == "mongol_ha_gol" then
		return BoonSelection_GetGoldenHordeChoicesForTier(tier_name),
			BoonSelection_GetGoldenHordeTierTitle(tier_name),
			BoonSelection_GetGoldenHordeTierSubtitle(tier_name)
	end
	return nil, nil, nil
end
