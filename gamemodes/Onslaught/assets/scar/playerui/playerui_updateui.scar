	food = RT_Food,
	wood = RT_Wood,
	gold = RT_Gold,
	stone = RT_Stone,
}

function PlayerUI_AdaptIconPathForXaml(iconPath)
	return string.format("pack://application:,,,/WPFGUI;component/%s.png", string.gsub(iconPath, "\\", "/"))
end

