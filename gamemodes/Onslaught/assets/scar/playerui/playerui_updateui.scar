-----------------------------------------------------------------------
-- PlayerUI: Update UI Data Context
-- Maps tracked game data into the UI data context for XAML binding.
-- All human players have data slots. Data depth is tiered:
--   Local player  -> full (resources, pop, units, relics, civ specifics)
--   Allies        -> summary (pop total, military count, age-up)
--   Enemies       -> minimal (name, color, age, eliminated status only)
-- Reference: observerui/observeruiupdateui.scar
-----------------------------------------------------------------------

_PlayerUI_DataContext = PlayerUiDataContext

_PLAYERUI_ELIM_TRANSFER_SUPPRESS_WARN_SEC = 15.0

-- State tracking for elimination animation trigger (per-player, one-time)
_PlayerUI_EliminationAnimTriggered = {}   -- keyed by playerIndex, true once animation triggered

function PlayerUI_ResetEliminationPresentationState()
	_PlayerUI_EliminationAnimTriggered = {}
	local mappings = PlayerUIDataContextMappings
	if mappings == nil or mappings.PlayersByIndex == nil then
		return
	end
	for i = 1, #mappings.PlayersByIndex do
		local data = mappings.PlayersByIndex[i]
		if data ~= nil then
			data._elimPresentationKeyApplied = nil
			data._elimPresentationPlayerID = nil
			data._elimSteadyVisualKeyApplied = nil
			data._elimPresentationRevealed = false
			data._elimPresentationReady = false
			data._elimTransferSuppressed = false
			data._elimTransferSuppressedSince = nil
			data._elimTransferSuppressedWarnedAt = nil
			data.showEliminationPresentation = false
			data.eliminationLabel = ""
			data.eliminationLabelColor = "#FFDD3333"
			data.showElimIconEliminated = false
			data.showElimIconSurrender = false
			data.showElimIconDisconnect = false
			data.elimRevealOpacity = 1.0
			data.elimGlowOpacity = 0.0
			data.elimGlowColor = "#FFDD3333"
			data.hideAliveStats = false
			data.elimScoreForeground = "#FF888888"
			data.elimRevealMargin = "0,0,0,0"
			data._elimRevealCompleted = false
			data.elimStatusForeground = "#FF888888"
			data._elimStatusTargetColor = nil
			-- Fill-alpha strings (safe alternatives to Opacity bindings)
			data.elimStrikethroughFill = "#00FFFFFF"
			data.elimOverlayNameFill = "#00111111"
			data.elimOverlayStatsFill = "#00111111"
			data.elimGlowFill = "#00DD3333"
		end
	end
end

function _PlayerUI_GetEliminationPresentationKey(isEliminated, showEliminationPresentation, eliminationReason)
	if not isEliminated then
		return "alive"
	end
	if not showEliminationPresentation then
		return "hidden"
	end
	if eliminationReason == "surrender" then
		return "surrender"
	end
	if eliminationReason == "disconnect" then
		return "disconnect"
	end
	return "eliminated"
end

function _PlayerUI_ApplyEliminationPresentationIfChanged(data, presentationKey)
	if data._elimPresentationKeyApplied == presentationKey then
		return
	end

	data._elimPresentationKeyApplied = presentationKey

	-- Track whether this is the first reveal (for Phase 1 reveal animation)
	local wasPreviouslyRevealed = data._elimPresentationRevealed

	if presentationKey == "surrender" then
		data.showEliminationPresentation = true
		data.eliminationLabel = "Surrendered"
		data.eliminationLabelColor = "#FFDDAA22"
		data.showElimIconEliminated = false
		data.showElimIconSurrender = true
		data.showElimIconDisconnect = false
		data.showEliminationStrikethrough = true
		data._elimPresentationRevealed = true
		data._elimStatusTargetColor = "#FFDDAA22"
		-- Phase 1 reveal: start at zero opacity so fade-in animates
		if not wasPreviouslyRevealed and PlayerUI_Animate_EliminationReveal ~= nil then
			data.elimRevealOpacity = 0.0
			-- Phase 3A: alive grids visible during crossfade; score starts white; margin offset
			data.hideAliveStats = false
			data.elimScoreForeground = _PLAYERUI_ELIM_SCORE_COLOR_ALIVE
			data.elimRevealMargin = "0," .. tostring(_PLAYERUI_ELIM_MARGIN_SLIDE_PX) .. ",0,0"
			data.elimStatusForeground = _PLAYERUI_ELIM_STATUS_COLOR_START
		else
			data.hideAliveStats = true
			data.elimScoreForeground = _PLAYERUI_ELIM_SCORE_COLOR_FINAL
			data.elimRevealMargin = "0,0,0,0"
			data.elimStatusForeground = "#FFDDAA22"
		end
	elseif presentationKey == "disconnect" then
		data.showEliminationPresentation = true
		data.eliminationLabel = "Disconnected"
		data.eliminationLabelColor = "#FF6699BB"
		data.showElimIconEliminated = false
		data.showElimIconSurrender = false
		data.showElimIconDisconnect = true
		data.showEliminationStrikethrough = true
		data._elimPresentationRevealed = true
		data._elimStatusTargetColor = "#FF6699BB"
		if not wasPreviouslyRevealed and PlayerUI_Animate_EliminationReveal ~= nil then
			data.elimRevealOpacity = 0.0
			data.hideAliveStats = false
			data.elimScoreForeground = _PLAYERUI_ELIM_SCORE_COLOR_ALIVE
			data.elimRevealMargin = "0," .. tostring(_PLAYERUI_ELIM_MARGIN_SLIDE_PX) .. ",0,0"
			data.elimStatusForeground = _PLAYERUI_ELIM_STATUS_COLOR_START
		else
			data.hideAliveStats = true
			data.elimScoreForeground = _PLAYERUI_ELIM_SCORE_COLOR_FINAL
			data.elimRevealMargin = "0,0,0,0"
			data.elimStatusForeground = "#FF6699BB"
		end
	elseif presentationKey == "eliminated" then
		data.showEliminationPresentation = true
		data.eliminationLabel = "Eliminated"
		data.eliminationLabelColor = "#FFDD3333"
		data.showElimIconEliminated = true
		data.showElimIconSurrender = false
		data.showElimIconDisconnect = false
		data.showEliminationStrikethrough = true
		data._elimPresentationRevealed = true
		data._elimStatusTargetColor = "#FFDD3333"
		if not wasPreviouslyRevealed and PlayerUI_Animate_EliminationReveal ~= nil then
			data.elimRevealOpacity = 0.0
			data.hideAliveStats = false
			data.elimScoreForeground = _PLAYERUI_ELIM_SCORE_COLOR_ALIVE
			data.elimRevealMargin = "0," .. tostring(_PLAYERUI_ELIM_MARGIN_SLIDE_PX) .. ",0,0"
			data.elimStatusForeground = _PLAYERUI_ELIM_STATUS_COLOR_START
		else
			data.hideAliveStats = true
			data.elimScoreForeground = _PLAYERUI_ELIM_SCORE_COLOR_FINAL
			data.elimRevealMargin = "0,0,0,0"
			data.elimStatusForeground = "#FFDD3333"
		end
	else
		data.showEliminationPresentation = false
		data.eliminationLabel = ""
		data.eliminationLabelColor = "#FFDD3333"
		data.showElimIconEliminated = false
		data.showElimIconSurrender = false
		data.showElimIconDisconnect = false
		data.showEliminationStrikethrough = false
		data._elimPresentationRevealed = false
		data.elimRevealOpacity = 1.0
		data.elimGlowOpacity = 0.0
		data.hideAliveStats = false
		data.elimScoreForeground = _PLAYERUI_ELIM_SCORE_COLOR_FINAL
		data.elimRevealMargin = "0,0,0,0"
		data._elimRevealCompleted = false
		data.elimStatusForeground = _PLAYERUI_ELIM_STATUS_COLOR_START
		data._elimStatusTargetColor = nil
	end
	-- Recompute Fill-alpha strings from current opacity values
	_PlayerUI_UpdateElimFills(data)
end

-----------------------------------------------------------------------
-- Compute elimination Fill-alpha strings from numeric opacity fields.
-- XAML safety: Opacity bindings on elements inside ItemsControl crash
-- D3D on Collapsed→Visible toggle.  Instead, encode opacity into Fill
-- colour alpha channels (#AARRGGBB) and bind Fill only.
-- Call this after writing elimRevealOpacity / elimGlowOpacity / elimGlowColor.
-----------------------------------------------------------------------
function _PlayerUI_UpdateElimFills(data)
	local revealOp = data.elimRevealOpacity or 0
	local glowOp = data.elimGlowOpacity or 0
	local glowColor = data.elimGlowColor or "#FFDD3333"
	local playerColor = data.color or "#FFFFFFFF"
	-- Strikethrough: player color + reveal opacity
	data.elimStrikethroughFill = _PlayerUI_FillWithOpacity(
		(#playerColor == 7) and ("#FF" .. string.sub(playerColor, 2)) or playerColor, revealOp)
	-- Name overlay: #CC111111 base + reveal opacity
	data.elimOverlayNameFill = _PlayerUI_FillWithOpacity("#CC111111", revealOp)
	-- Stats overlay: #99111111 base + reveal opacity
	data.elimOverlayStatsFill = _PlayerUI_FillWithOpacity("#99111111", revealOp)
	-- Glow: glowColor + glow opacity (shared by name and stats rows)
	data.elimGlowFill = _PlayerUI_GlowFillWithOpacity(glowColor, glowOp)
end

function _PlayerUI_GetEliminationSteadyVisualKey(isEliminated, dimEnabled)
	if isEliminated then
		if dimEnabled then
			return "elim_dim"
		end
		return "elim_nodim"
	end
	return "alive"
end

function _PlayerUI_ApplyEliminationSteadyVisualIfChanged(data, steadyVisualKey)
	if data._elimSteadyVisualKeyApplied == steadyVisualKey then
		return
	end

	data._elimSteadyVisualKeyApplied = steadyVisualKey
	local setIfChanged = _PlayerUI_SetIfChanged
	if setIfChanged == nil then
		setIfChanged = function(t, k, v)
			if t[k] ~= v then
				t[k] = v
			end
		end
	end

	if steadyVisualKey == "elim_dim" then
		setIfChanged(data, "rowOpacity", _PLAYERUI_ELIM_ANIM_FADE_TARGET)
		data.rowDimFill = _PlayerUI_RowDimFill(_PLAYERUI_ELIM_ANIM_FADE_TARGET)
		setIfChanged(data, "eliminationScaleFactor", 1.0)
		setIfChanged(data, "eliminationAnimActive", false)
		setIfChanged(data, "eliminationAnimElapsed", 0.0)
	elseif steadyVisualKey == "elim_nodim" then
		setIfChanged(data, "rowOpacity", 1.0)
		data.rowDimFill = _PlayerUI_RowDimFill(1.0)
		setIfChanged(data, "eliminationScaleFactor", 1.0)
		setIfChanged(data, "eliminationAnimActive", false)
		setIfChanged(data, "eliminationAnimElapsed", 0.0)
	else
		setIfChanged(data, "rowOpacity", 1.0)
		data.rowDimFill = _PlayerUI_RowDimFill(1.0)
		setIfChanged(data, "eliminationScaleFactor", 1.0)
		setIfChanged(data, "eliminationAnimActive", false)
		setIfChanged(data, "eliminationAnimElapsed", 0.0)
	end
end

function PlayerUI_Debug_PrintEliminationSnapshot(index)
	local allPlayers = _PlayerUI_AllPlayers
	if allPlayers == nil then
		print("[PLAYERUI_ELIM] snapshot unavailable: no players")
		return
	end
	local playerEntry = allPlayers[index]
	local data = PlayerUIDataContextMappings.PlayersByIndex[index]
	if playerEntry == nil or data == nil then
		print("[PLAYERUI_ELIM] snapshot unavailable for index=" .. tostring(index))
		return
	end
	local animActive = _PlayerUI_IsEliminationAnimationActive(index)
	local animProgress = 0.0
	if PlayerUI_Animate_GetEliminationLastProgress ~= nil then
		animProgress = PlayerUI_Animate_GetEliminationLastProgress(index)
	end
	print("[PLAYERUI_ELIM] idx=" .. tostring(index)
		.. " pid=" .. tostring(playerEntry.id.PlayerID)
		.. " eliminated=" .. tostring(playerEntry.isEliminated)
		.. " shown=" .. tostring(data.showEliminationPresentation)
		.. " revealed=" .. tostring(data._elimPresentationRevealed)
		.. " animActive=" .. tostring(animActive)
		.. " progress=" .. tostring(animProgress)
		.. " opacity=" .. tostring(data.rowOpacity)
		.. " scale=" .. tostring(data.eliminationScaleFactor)
		.. " elapsed=" .. tostring(data.eliminationAnimElapsed)
		.. " strike=" .. tostring(data.showEliminationStrikethrough)
		.. " fence=" .. tostring(data._elimCompletionFenceCycles)
		.. " seeded=" .. tostring(data._elimFirstFrameSeeded)
		.. " reason=" .. tostring(data.eliminationReason))
end

local function _PlayerUI_Debug_GetAnimEntryValue(key, field, fallback)
	local entry = _PlayerUI_Anim and _PlayerUI_Anim[key]
	if entry == nil then
		return fallback
	end
	local value = entry[field]
	if value == nil then
		return fallback
	end
	return value
end

local function _PlayerUI_Debug_GetDecayValue(key)
	local entry = _PlayerUI_AnimDecay and _PlayerUI_AnimDecay[key]
	if entry == nil then
		return 0
	end
	return entry.value or 0
end

function PlayerUI_Debug_PrintFullSnapshot(index)
	local allPlayers = _PlayerUI_AllPlayers
	if allPlayers == nil then
		print("[PLAYERUI_SNAPSHOT] unavailable: no players")
		return
	end

	local playerEntry = allPlayers[index]
	local data = PlayerUIDataContextMappings.PlayersByIndex[index]
	if playerEntry == nil or data == nil then
		print("[PLAYERUI_SNAPSHOT] unavailable for index=" .. tostring(index))
		return
	end

	local pIdx = World_GetPlayerIndex(playerEntry.id)
	local animProgress = 0.0
	if PlayerUI_Animate_GetEliminationLastProgress ~= nil then
		animProgress = PlayerUI_Animate_GetEliminationLastProgress(index)
	end

	local teamKey = data.IsRightSide and "teamRight" or "teamLeft"
	local rankPos = tonumber(data.rankPosition) or 0
	local rankEntry = nil
	if _PlayerUI_RankState ~= nil and _PlayerUI_RankState[teamKey] ~= nil and rankPos >= 1 then
		rankEntry = _PlayerUI_RankState[teamKey][rankPos]
	end

	local killKey = "kill_" .. tostring(index)
	local rewardKey = "reward_bar_" .. tostring(index)
	local workerKey = "workerPop_" .. tostring(pIdx)
	local militaryKey = "militaryPop_" .. tostring(pIdx)
	local rankTranslateKey = "rank_translateY_" .. teamKey .. "_" .. tostring(rankPos)
	local rankScaleKey = "rank_scale_" .. teamKey .. "_" .. tostring(rankPos)
	local rankHighlightKey = "rank_highlight_" .. teamKey .. "_" .. tostring(rankPos)

	local scorePulse = _PlayerUI_ScorePulse and _PlayerUI_ScorePulse[index]
	local scorePulseValue = scorePulse and scorePulse.value or 0

	print("[PLAYERUI_SNAPSHOT] idx=" .. tostring(index)
		.. " pid=" .. tostring(playerEntry.id.PlayerID)
		.. " team=" .. tostring(teamKey)
		.. " rankPos=" .. tostring(rankPos)
		.. " eliminated=" .. tostring(playerEntry.isEliminated)
		.. " reason=" .. tostring(data.eliminationReason)
		.. " shown=" .. tostring(data.showEliminationPresentation)
		.. " revealed=" .. tostring(data._elimPresentationRevealed)
		.. " transferSuppressed=" .. tostring(data._elimTransferSuppressed)
		.. " animActive=" .. tostring(_PlayerUI_IsEliminationAnimationActive(index))
		.. " progress=" .. tostring(animProgress)
		.. " opacity=" .. tostring(data.rowOpacity)
		.. " scale=" .. tostring(data.eliminationScaleFactor)
		.. " elapsed=" .. tostring(data.eliminationAnimElapsed)
		.. " fence=" .. tostring(data._elimCompletionFenceCycles)
		.. " seeded=" .. tostring(data._elimFirstFrameSeeded))

	print("[PLAYERUI_SNAPSHOT] anim kill(d=" .. tostring(_PlayerUI_Debug_GetAnimEntryValue(killKey, "display", 0))
		.. " t=" .. tostring(_PlayerUI_Debug_GetAnimEntryValue(killKey, "target", 0))
		.. " moving=" .. tostring(PlayerUI_Animate_IsTransitioning and PlayerUI_Animate_IsTransitioning(killKey))
		.. ") reward(d=" .. tostring(_PlayerUI_Debug_GetAnimEntryValue(rewardKey, "display", 0))
		.. " t=" .. tostring(_PlayerUI_Debug_GetAnimEntryValue(rewardKey, "target", 0))
		.. ") worker(d=" .. tostring(_PlayerUI_Debug_GetAnimEntryValue(workerKey, "display", 0))
		.. " t=" .. tostring(_PlayerUI_Debug_GetAnimEntryValue(workerKey, "target", 0))
		.. ") military(d=" .. tostring(_PlayerUI_Debug_GetAnimEntryValue(militaryKey, "display", 0))
		.. " t=" .. tostring(_PlayerUI_Debug_GetAnimEntryValue(militaryKey, "target", 0))
		.. ")")

	print("[PLAYERUI_SNAPSHOT] ranking lock=" .. tostring(_PlayerUI_RankTransitionLock)
		.. " pending=" .. tostring(_PlayerUI_RankPendingReorder)
		.. " rankScaleDecay=" .. tostring(_PlayerUI_Debug_GetDecayValue(rankScaleKey))
		.. " rankHighlightDecay=" .. tostring(_PlayerUI_Debug_GetDecayValue(rankHighlightKey))
		.. " rankTranslate=" .. tostring(PlayerUI_Animate_GetPosition and PlayerUI_Animate_GetPosition(rankTranslateKey))
		.. " pulse=" .. tostring(scorePulseValue)
		.. " rankEntryTop=" .. tostring(rankEntry and rankEntry.isTopPlayer)
		.. " rankEntryContested=" .. tostring(rankEntry and rankEntry.isContested)
		.. " rankEntryChange=" .. tostring(rankEntry and rankEntry.rankChangeType))
end

function _PlayerUI_IsEliminationAnimationActive(index)
	if PlayerUI_Animate_IsEliminationTransitionActive ~= nil then
		return PlayerUI_Animate_IsEliminationTransitionActive(index)
	end
	return false
end

function PlayerUI_UpdateEliminationPresentationForIndex(index, playersEntryOverride)
	local allPlayers = _PlayerUI_AllPlayers
	if allPlayers == nil then
		return
	end

	local playerEntry = allPlayers[index]
	local data = PlayerUIDataContextMappings.PlayersByIndex[index]
	if playerEntry == nil or data == nil then
		return
	end

	local playersEntry = playersEntryOverride
	if playersEntry == nil then
		playersEntry = PLAYERS[World_GetPlayerIndex(playerEntry.id)]
	end

	local showEliminationPresentation = false
	local transferSuppressed = false
	local transferActive = (_leaver_transfer_state ~= nil)
	if playerEntry.isEliminated then
		-- Once presentation has been revealed (reached steady visual), don't suppress
		-- during subsequent leaver transfers on other players. Only suppress while
		-- animation is still active (pre-reveal) or if this is the first reveal.
		if data._elimPresentationRevealed then
			showEliminationPresentation = true
		else
			-- Gate first reveal: only open after fence/defer settle (Phase 4.1)
			if data._elimPresentationReady == true then
				transferSuppressed = transferActive
				showEliminationPresentation = not transferSuppressed and not _PlayerUI_IsEliminationAnimationActive(index)
			else
				showEliminationPresentation = false
				transferSuppressed = transferActive
			end
		end
	end

	-- Phase B hardening: track suppression duration so stuck transfer-state coupling
	-- is visible in logs and can be audited via debugger.
	local now = World_GetGameTime()
	if transferSuppressed then
		if data._elimTransferSuppressedSince == nil then
			data._elimTransferSuppressedSince = now
		end
		local suppressedFor = now - data._elimTransferSuppressedSince
		if suppressedFor >= _PLAYERUI_ELIM_TRANSFER_SUPPRESS_WARN_SEC and _PLAYERUI_ELIM_ANIM_DEBUG then
			local lastWarn = data._elimTransferSuppressedWarnedAt or 0
			if (now - lastWarn) >= _PLAYERUI_ELIM_TRANSFER_SUPPRESS_WARN_SEC then
				print("[PLAYERUI_ELIM_SUPPRESS_WARN] idx=" .. tostring(index)
					.. " suppressedFor=" .. string.format("%.1fs", suppressedFor)
					.. " transferActive=" .. tostring(transferActive)
					.. " ready=" .. tostring(data._elimPresentationReady)
					.. " revealed=" .. tostring(data._elimPresentationRevealed)
					.. " animActive=" .. tostring(_PlayerUI_IsEliminationAnimationActive(index)))
				data._elimTransferSuppressedWarnedAt = now
			end
		end
	else
		data._elimTransferSuppressedSince = nil
		data._elimTransferSuppressedWarnedAt = nil
	end

	if _PLAYERUI_ELIM_ANIM_DEBUG and data._elimTransferSuppressed ~= transferSuppressed then
		print("[PLAYERUI_ELIM_LIFECYCLE] idx=" .. tostring(index)
			.. " transferSuppressed=" .. tostring(transferSuppressed)
			.. " transferActive=" .. tostring(transferActive)
			.. " revealed=" .. tostring(data._elimPresentationRevealed)
			.. " shown=" .. tostring(showEliminationPresentation)
			.. " animActive=" .. tostring(_PlayerUI_IsEliminationAnimationActive(index)))
	end
	data._elimTransferSuppressed = transferSuppressed

	local eliminationReason = "alive"
	if playersEntry ~= nil and playersEntry.eliminationReason ~= nil then
		eliminationReason = playersEntry.eliminationReason
	elseif playerEntry.isEliminated then
		eliminationReason = "eliminated"
	end

	-- Note: classification (eliminated / disconnect / surrender) is owned at the
	-- source -- _Onslaught_SetEliminationReason in cba.scar handles MP
	-- WR_ELIMINATION (with the starter-Keep-alive disconnect probe at the
	-- moment of defeat), Surrender_OnPlayerDefeated handles WR_SURRENDER, and
	-- Annihilation_OnPlayerDefeated stamps WR_ANNIHILATION explicitly.  We
	-- intentionally do NOT re-probe Entity_IsValid(keep) here every frame:
	-- killed keeps remain "valid" for several seconds during their death/ruin
	-- animation, which would cause genuine eliminations to flicker into the
	-- "disconnect" presentation.

	data.eliminationReason = eliminationReason
	local presentationKey = _PlayerUI_GetEliminationPresentationKey(playerEntry.isEliminated, showEliminationPresentation, eliminationReason)
	_PlayerUI_ApplyEliminationPresentationIfChanged(data, presentationKey)
end

