			"upgrade_ranged_armor_i_improved_mon",
			"upgrade_ranged_armor_ii_improved_mon",
			"upgrade_ranged_armor_iii_improved_mon",
			"upgrade_ranged_damage_i_improved_mon",
			"upgrade_ranged_damage_ii_improved_mon",
			"upgrade_ranged_damage_iii_improved_mon",
			"upgrade_melee_armor_i_improved_mon",
			"upgrade_melee_armor_ii_improved_mon",
			"upgrade_melee_armor_iii_improved_mon",
			"upgrade_melee_damage_i_improved_mon",
			"upgrade_melee_damage_ii_improved_mon",
