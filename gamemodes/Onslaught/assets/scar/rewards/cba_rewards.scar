---------------------------------------------------------------------------------------------------
-- CBA Rewards Engine
-- Module registration, spawner, objective UI, kill tracking, reward application
-- Kill point values: rewards/cba_kill_scoring.scar
-- Onslaught reward trees: rewards/cba_rewards_onslaught.scar
-- Arena reward trees: rewards/cba_rewards_arena.scar
---------------------------------------------------------------------------------------------------

import("rewards/cba_kill_scoring.scar")
import("rewards/cba_rewards_onslaught.scar")
import("rewards/cba_rewards_arena.scar")

CBA_REWARDS_CBAULE = "CBA_Rewards"
_CBA = {
	module = "CBA",
	group_counter = 0, 
	rewards = {},
	center,
	-- Objective: Eliminate for Rewards
	obj_kill_title = "DO NOT USE",
	-- Objective: Eliminate for Villagers 
}

-- Queued reward spawns when population is near cap (keyed by player index)
_reward_queue = {}

-- Kill-objective UI coalescing: defer Obj_Set* counter/progress to reduce per-kill UI spam
_rewards_kill_ui_pending = false

---------------------------------------------------------------------------------------------------
-- Delegates:
---------------------------------------------------------------------------------------------------

Core_RegisterModule(CBA_REWARDS_CBAULE)	

function CBA_Rewards_UpdateModuleSettings()
	if AGS_GLOBAL_SETTINGS.CBA_Rewards == "disabled" then
		Core_UnregisterModule(CBA_REWARDS_CBAULE)
	else
		-- Onslaught uses reward score (killed_number) as authoritative value.
		-- Disable stock Score module to prevent competing economy-derived writes
		-- to player.score and total_score that cause visible jump/reset behavior
		-- between Onslaught's 2-second sync intervals.
		Core_UnregisterModule("Score")
	end
end

function CBA_Rewards_PresetFinalize()
	
	if AGS_GLOBAL_SETTINGS.CBA_Rewards == "onslaught" then
		cba_spawner_interval = 300
		CBA_Rewards_List_Onslaught()
		
		-- Rewards List - Selected Upgrade Blueprints 
		local REWARD_UPGRADE_ALL = {
			AGS_UP_A_MELEE_I, -- Attack / Damage
			AGS_UP_D_MELEE_I, -- Defense/ Armor
			AGS_UP_A_MELEE_II,
