			end
			if branch_civ == "french" then
				for id, upgrade_bp in pairs(REWARD_UPGRADE_FRE) do
					Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint(upgrade_bp), ITEM_REMOVED)	
				end
			end
			if branch_civ == "hre" then
				for id, upgrade_bp in pairs(REWARD_UPGRADE_HRE) do
					Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint(upgrade_bp), ITEM_REMOVED)	
				end
			end
			if branch_civ == "mongol" then
				for id, upgrade_bp in pairs(REWARD_UPGRADE_MON) do
					Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint(upgrade_bp), ITEM_REMOVED)	
				end
			end
			if branch_civ == "rus" then
				for id, upgrade_bp in pairs(REWARD_UPGRADE_RUS) do
					Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint(upgrade_bp), ITEM_REMOVED)	
				end
			end
			if branch_civ == "sultanate" then
				for id, upgrade_bp in pairs(REWARD_UPGRADE_SUL) do
					Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint(upgrade_bp), ITEM_REMOVED)	
				end
			end
			if branch_civ == "abbasid" then
				for id, upgrade_bp in pairs(REWARD_UPGRADE_ABB) do
					Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint(upgrade_bp), ITEM_REMOVED)	
				end
			end
			if branch_civ == "malian" then
				for id, upgrade_bp in pairs(REWARD_UPGRADE_MAL) do
					Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint(upgrade_bp), ITEM_REMOVED)	
				end
