function Nomad_PresetFinalize()
	
	--[[Check starting units option
	if options.starting_conditions.start_units_enabled then
		-- GLOBAL EVENT run Nomad_OnConstructionComplete() when a building is constructed. 
		-- Rule_AddGlobalEvent(Nomad_OnConstructionComplete, GE_ConstructionComplete)
	end]]
	Nomad_DestroySpawns()
	Nomad_SetupSpawns()
	-- ONE SHOT RULES: Delay to avoid DestroySpawns function
	-- Rule_AddOneShot(Nomad_SetupSpawns, 0.125)
	-- GLOBAL EVENT RULES: 	
	 Rule_AddGlobalEvent(Nomad_OnConstructionComplete, GE_ConstructionComplete)
	
end

function Nomad_Start()
	print("[NOMAD_DISABLED] Nomad_Start() is not used by Onslaught main mode and has been intentionally disabled.")
	return
end



---------------------------------------------------------------------------------------------------
-- Functions:
---------------------------------------------------------------------------------------------------
-- Disable limit from Onslaught_Tuning for villagers
function Nomad_UnlockVillagers()
	-- Disable entities/squads
	for i, player in ipairs(PLAYERS) do
		AGS_SetSquadProductionAvailabilitySafe(player.id, AGS_GetCivilizationUnit(player.raceName, AGS_BP_VILLAGER), ITEM_UNLOCKED, "Nomad_UnlockVillagers/villager/" .. tostring(player.raceName))
	end
end
-- Used to spawn sarting units upon players capital tc completion
function Nomad_OnConstructionComplete(context)
	
	local builder = Core_GetPlayersTableEntry(context.player) -- player who constructed the building	
	
	-- Keep-as-Capital: players won't build a capital TC; skip scout-spawn trigger.
	if _mod.keep_as_capital then return end
	
	-- check if building is capital TC
	if Entity_IsEBPOfType(context.pbg, "town_center_capital") and not _tcSpawned[builder.id] then
		_tcSpawned[builder.id] = true
							
		local player_civ = Player_GetRaceName(builder.id)
		
		-- Get Unit BPs
		local sbp_scout = AGS_GetCivilizationUnit(player_civ, AGS_BP_SCOUT)
		local sbp_ger = BP_GetSquadBlueprint("building_house_moving_mon")
		local sbp_prelate = BP_GetSquadBlueprint("unit_monk_1_hre")
		
		
		--Spawn Starting Units
		local sg_tcunits = SGroup_CreateIfNotFound("sg_tcunits" .. tostring(builder.id))
		if player_civ == "hre" then
			--Spawn prelate and scout
			UnitEntry_DeploySquads(builder.id, sg_tcunits, {{sbp = sbp_prelate, numSquads = 1 }, {sbp = sbp_scout, numSquads = 1 }}, Entity_GetPosition(context.entity))
		elseif player_civ == "mongol" then
			--Spawn prelate and scout
			UnitEntry_DeploySquads(builder.id, sg_tcunits, {{sbp = sbp_ger, numSquads = 1 }, {sbp = sbp_scout, numSquads = 1 }}, Entity_GetPosition(context.entity))
		else
			--Spawn scout only
			UnitEntry_DeploySquads(builder.id, sg_tcunits, {{sbp = sbp_scout, numSquads = 1 }}, Entity_GetPosition(context.entity))
		end
	end
end
-- Removing prefab start.
function Nomad_DestroySpawns()
	-- Remove player's initial buildings
	for _, player in ipairs(PLAYERS) do
		if _mod.keep_as_capital and player.keep ~= nil and player.keep.entity ~= nil then
			-- Keep-as-Capital: preserve the Starter Keep; destroy everything else.
			local eg_all = Player_GetEntities(player.id)
			local keep_eid = player.keep.entity
			EGroup_Filter(eg_all, "castle", FILTER_REMOVE)  -- remove keeps from kill list
			EGroup_DestroyAllEntities(eg_all)
			SGroup_DestroyAllSquads(Player_GetSquads(player.id))
		else
			EGroup_DestroyAllEntities(Player_GetEntities(player.id))
			SGroup_DestroyAllSquads(Player_GetSquads(player.id))
		end
	end
end
-- Nomad spawner
function Nomad_SetupSpawns()
	for i, player in ipairs(PLAYERS) do
		
		local player_civ = Player_GetRaceName(player.id)
		
		--[[ HRE either gets 100 gold or a prelate
		if (player_civ == "hre" and not options.starting_conditions.start_units_enabled) then
			Player_GiftResource(player.id, RT_Gold, 100)
		end]]
		
		-- Get Villager BP based on civ
		local sbp_villager = AGS_GetCivilizationUnit(player_civ, AGS_BP_VILLAGER)
		
		-- Get spawn dimensions
		local trueRadius = Nomad_intMax(World_GetWidth(), World_GetLength())/2
		local radius = trueRadius*1.08 -- 1.08 to try and tune villager spawn out from the middle of the map
		local map_center = World_Pos(0, 0, 0)
		
		-- Generate random location and spawn vils 
		local i = 0
		while i < _num_vils do
			-- Generate random spawn location
			
			local edgeOffset = 0.8

			local randx = World_GetRand(0-radius, radius)
			if randx > trueRadius * edgeOffset or randx < -trueRadius * edgeOffset then
				randx = randx * edgeOffset --offset from edge of map to try reduce vils trapped in trees
			end
			local randz = World_GetRand(0-radius, radius)
			if randz > trueRadius * edgeOffset or randz < -trueRadius * edgeOffset then
				randz = randz * edgeOffset
			end
			local height = World_GetHeightAt(randx, randz)
			local spawn_pos = World_Pos(randx, height, randz)
			
			-- Create villager squad and spawn at random location
			local sg_villager = SGroup_CreateIfNotFound("sg_villager" .. i .. tostring(player.id))
			UnitEntry_DeploySquads(player.id, sg_villager, {{sbp = sbp_villager, numSquads = 1 }}, spawn_pos)
			
			--Set a ping to show the player where the villager spawned
			if player.isLocal then
				UI_CreateMinimapBlip(sg_villager, 9, "general")
			end
			
			i = i + 1
		end
		
	end
	
end
--takes two int values and returns the greatest of the two
function Nomad_intMax(x, y)
	if x > y then
		return x 
	end
	return y
end

