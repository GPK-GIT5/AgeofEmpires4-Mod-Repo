---------------------------------------------------------------------------------------------------
--[[ Called during load as part of the game setup sequence
function Nomad_OnGameSetup()
	
	
	Setup_GetWinConditionOptions(options)
	
	if options.win_conditions.landmarks == true then
		import("winconditions/conquest.scar")
	end
	if options.win_conditions.sacred == true then
		import("winconditions/religious.scar")
	end
	if options.win_conditions.wonder == true then
		import("winconditions/wonder.scar")
	end 

end
]]

Core_RegisterModule("Nomad")


