-- Internal Variables
_num_vils = 3 -- number of vils to be spawned at the start of the game
_timer_one = 180 -- Duration of treaty timer option one
_timer_two = 300 -- Duration of treaty timer option two
_tcSpawned = {} -- Holds bools for if player has built a TC
options = {}

---------------------------------------------------------------------------------------------------
