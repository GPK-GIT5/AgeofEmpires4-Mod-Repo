---------------------------------------------------------------------------------------------------
-- CBA Debug — Leaver Conversion System Tests
-- Full-system validation for the 8-phase leaver conversion pipeline.
--
-- Console commands (run in order, ≤5 commands for full validation):
--   Debug_LeaverConversion_Inspect()        — Read-only: dump reverse map, per-player state, gaps
--   Debug_LeaverConversion_Full()           — Stages 1-6: snapshot → disconnect → validate
--   Debug_FullValidation_All(player_idx)    — One-command full pass: leaver + matrix + house guard
--   Debug_LeaverMilTest()                   — Military test: exercises suffix-swap & class-fallback paths
--   Debug_LeaverMilProof_OneShot()          — Single-command deterministic MIL proof + immediate full validation
--   Debug_FullSystemValidation(player_idx)  — One-pass: leaver + limits + siege + timing + resources
--   Debug_LeaverConversion_Stress(n)        — Disconnect N players sequentially, validate after each
--   Debug_LeaverConversion_Visual(src, dst) — Spawn test assets for src, convert to dst civ visually
--   Debug_LeaverConversion_MilResolve(src, dst) — Print suffix swap resolution for all known unit patterns
--   Debug_LeaverCrossCivMatrix()                 — Directed all-player pair matrix (mil + bldg), global cross-civ coverage
--   Debug_LeaverCrossCivMatrix("verbose")         — Same with per-pair detail
--
-- Coverage audit commands:
--   Debug_LeaverCoverage_AllCivPairs()          — All-civ building coverage with quality tiers
--   Debug_LeaverCoverage_AllCivPairs("summary") — One-line-per-pair summary
--   Debug_LeaverCoverage_Civ("byzantine")       — Single sender civ vs all receivers
--
-- Performance commands:
--   Debug_LeaverPerformance()               — Print per-phase timing from last completed transfer
--   Debug_LeaverPerformance_6Player(n)      — Cascade n disconnects with per-transfer timing
--   Debug_LeaverPipelineStatus()            — Print current pipeline state and rule pause status
--
-- Branch: onslaught-v3.4
---------------------------------------------------------------------------------------------------

_LEAVER_DEBUG_FULL_PENDING = nil
_LEAVER_DEBUG_FULL_RUN_COUNTER = 0
_LEAVER_DEBUG_MIL_COVERAGE_RUN_COUNTER = 0
_LEAVER_MIL_TEST_PENDING = nil
_LEAVER_DEBUG_MILTEST_RUN_COUNTER = 0
_LEAVER_MIL_TEST_CLASS_PROOF_STREAK = 0
_LEAVER_MIL_ONESHOT_PENDING = nil
_LEAVER_MIL_ONESHOT_RUN_COUNTER = 0

function _LeaverDebug_FullFinalize()
	local ctx = _LEAVER_DEBUG_FULL_PENDING
	if ctx == nil then return end

	if _leaver_transfer_state ~= nil then
		Rule_AddOneShot(_LeaverDebug_FullFinalize, 0)
		return
	end

	ctx.stage_issues["4_PostDisconnect"] = _LeaverDebug_Stage4_Validate(ctx.pre_snapshot, ctx.disconnected_idx)
	ctx.stage_issues["5_BlueprintAudit"] = _LeaverDebug_Stage5_BlueprintAudit()
	local total = _LeaverDebug_Stage6_Summary(ctx.stage_issues)

	if ctx.full_validation_all then
		print("")
		print("=== STAGE 6b: CROSS-CIV MATRIX (MIL + BLDG) ===")
		local matrix_issues = 0
		local ok_matrix, matrix_result = pcall(Debug_LeaverCrossCivMatrix, ctx.matrix_mode)
		if ok_matrix then
			matrix_issues = matrix_result or 0
			ctx.stage_issues["6b_CrossCivMatrixAll"] = matrix_issues
		else
			print(string.format("  [FAIL] Cross-civ matrix crashed: %s", tostring(matrix_result)))
			matrix_issues = 1
			ctx.stage_issues["6b_CrossCivMatrixAll"] = matrix_issues
		end

		print("")
		print("=== STAGE 6c: HOUSE GUARD VERIFICATION ===")
		local house_guard_issues = 0
		if type(Debug_AutoPopHouseGuard) == "function" then
			if _mod ~= nil and _mod.pop_cap_incease_on_interval ~= nil and _mod.pop_cap_incease_on_interval ~= 0 then
				local ok_hg, hg_result = pcall(Debug_AutoPopHouseGuard)
				if ok_hg then
					house_guard_issues = hg_result or 0
				else
					print(string.format("  [FAIL] House guard inspector crashed: %s", tostring(hg_result)))
					house_guard_issues = 1
				end
			else
				print("  [SKIP] Auto-pop inactive in this match; house guard runtime path not active")
			end
		else
			print("  [FAIL] Debug_AutoPopHouseGuard is unavailable")
			house_guard_issues = 1
		end
		ctx.stage_issues["6c_HouseGuard"] = house_guard_issues

		total = total + matrix_issues + house_guard_issues
	end

	local elapsed = 0
	if ctx.start_time ~= nil then
		elapsed = World_GetGameTime() - ctx.start_time
	end

	local run_id = ctx.run_id or 0
	local result = (total == 0) and "PASS" or "FAIL"
	print(string.format("[LEAVER_DEBUG][FULL][RUN %d] COMPLETE result=%s total_issues=%d elapsed=%.2fs", run_id, result, total, elapsed))

	local oneshot = _LEAVER_MIL_ONESHOT_PENDING
	if oneshot ~= nil and oneshot.phase == "full_wait" and oneshot.full_run_id == run_id then
		oneshot.full_result = result
		oneshot.full_total_issues = total
		local combined = (oneshot.sfx_result == "PASS" and oneshot.class_result == "PASS" and oneshot.full_result == "PASS") and "PASS" or "FAIL"
		print(string.format("[LEAVER_DEBUG][ONE_SHOT][RUN %d] COMPLETE result=%s SFX=%s CLASS=%s FULL=%s reason=%s",
			oneshot.run_id or 0,
			combined,
			oneshot.sfx_result or "FAIL",
			oneshot.class_result or "FAIL",
			oneshot.full_result or "FAIL",
			oneshot.reason or (combined == "PASS" and "success" or "phase_failure")))
		_LEAVER_MIL_ONESHOT_PENDING = nil
	end

	_LEAVER_DEBUG_FULL_PENDING = nil
end

function _LeaverMilTest_Finalize()
	local ctx = _LEAVER_MIL_TEST_PENDING
	if ctx == nil then return end

	if _leaver_transfer_state ~= nil then
		Rule_AddOneShot(_LeaverMilTest_Finalize, 0)
		return
	end

	local elapsed = 0
	if ctx.start_time ~= nil then
		elapsed = World_GetGameTime() - ctx.start_time
	end

	-- Restore debug flags to their previous state
	local old_bypass = ctx.saved_bypass_gates
	local old_cap_bypass = ctx.saved_cap_bypass
	local old_verbose = ctx.saved_verbose
	if old_bypass ~= nil then _LEAVER_DEBUG_BYPASS_GATES = old_bypass end
	if old_cap_bypass ~= nil then _LEAVER_DEBUG_BYPASS_CAPABILITY_GATES = old_cap_bypass end
	if old_verbose ~= nil then _LEAVER_DEBUG_VERBOSE = old_verbose end

	-- Read final stats
	local last_stats = _leaver_last_transfer_stats or {}
	local mil_direct = last_stats.mil_direct or 0
	local mil_tier_bump = last_stats.mil_tier_bump or 0
	local mil_receiver_class = last_stats.mil_receiver_class or 0
	local mil_civ_unique_archetype = last_stats.mil_civ_unique_archetype or 0
	local mil_generic_archetype = last_stats.mil_generic_archetype or 0
	local total_created = mil_direct + mil_tier_bump + mil_receiver_class + mil_civ_unique_archetype + mil_generic_archetype

	local sfx_spawned = ctx.sfx_spawned or 0
	local remap_spawned = ctx.remap_spawned or 0
	local remap_attempted = ctx.remap_attempted or 0
	local remap_resolved = ctx.remap_resolved or 0
	local sfx_ok = (sfx_spawned > 0) and ((mil_direct + mil_tier_bump) > 0)
	local class_ok = (remap_spawned > 0) and (mil_receiver_class > 0)

	if class_ok then
		_LEAVER_MIL_TEST_CLASS_PROOF_STREAK = (_LEAVER_MIL_TEST_CLASS_PROOF_STREAK or 0) + 1
	else
		_LEAVER_MIL_TEST_CLASS_PROOF_STREAK = 0
	end

	local reason = "success"
	if not sfx_ok and sfx_spawned <= 0 then
		reason = "no_suffix_spawns"
	elseif not sfx_ok then
		reason = "no_suffix_conversions"
	elseif not class_ok and remap_attempted <= 0 then
		reason = "no_class_attempts"
	elseif not class_ok and remap_resolved <= 0 then
		reason = "no_class_targets_resolved"
	elseif not class_ok and remap_spawned <= 0 then
		reason = "no_class_spawns"
	elseif not class_ok then
		reason = "no_class_conversions"
	end

	local run_id = ctx.run_id or 0
	local result = (sfx_ok and class_ok) and "PASS" or "FAIL"
	print(string.format("[LEAVER_DEBUG][MIL_TEST][RUN %d] SFX_VALIDATE result=%s sfx_spawned=%d direct=%d bump=%d",
		run_id, sfx_ok and "PASS" or "FAIL", sfx_spawned, mil_direct, mil_tier_bump))
	print(string.format("[LEAVER_DEBUG][MIL_TEST][RUN %d] CLASS_VALIDATE result=%s remap_attempted=%d resolved=%d remap_spawned=%d class=%d streak=%d",
		run_id, class_ok and "PASS" or "FAIL", remap_attempted, remap_resolved, remap_spawned, mil_receiver_class, _LEAVER_MIL_TEST_CLASS_PROOF_STREAK or 0))
	print(string.format("[LEAVER_DEBUG][MIL_TEST][RUN %d] COMPLETE result=%s reason=%s created=%d (direct=%d+bump=%d+class=%d+unique=%d+generic=%d) elapsed=%.2fs",
		run_id, result, reason, total_created, mil_direct, mil_tier_bump, mil_receiver_class, mil_civ_unique_archetype, mil_generic_archetype, elapsed))

	local oneshot = _LEAVER_MIL_ONESHOT_PENDING
	if oneshot ~= nil and oneshot.phase == "mil_wait" and oneshot.mil_run_id == run_id then
		oneshot.sfx_result = sfx_ok and "PASS" or "FAIL"
		oneshot.class_result = class_ok and "PASS" or "FAIL"
		oneshot.reason = reason
		local full_target = _LeaverMilTest_SelectFullValidationTarget(ctx.src_idx)
		if full_target == nil then
			print(string.format("[LEAVER_DEBUG][ONE_SHOT][RUN %d] COMPLETE result=FAIL SFX=%s CLASS=%s FULL=FAIL reason=no_full_validation_target",
				oneshot.run_id or 0,
				oneshot.sfx_result,
				oneshot.class_result))
			_LEAVER_MIL_ONESHOT_PENDING = nil
		else
			oneshot.phase = "full_wait"
			oneshot.full_run_id = (_LEAVER_DEBUG_FULL_RUN_COUNTER or 0) + 1
			print(string.format("[LEAVER_DEBUG][ONE_SHOT][RUN %d] DEFERRED phase=full_validation target=%d full_run=%d",
				oneshot.run_id or 0, full_target, oneshot.full_run_id))
			Debug_LeaverConversion_Full(full_target)
		end
	end

	_LEAVER_MIL_TEST_PENDING = nil
end

function _LeaverMilTest_GetActualRecipientIndex(src_idx)
	local src_player = PLAYERS[src_idx]
	if src_player == nil then return nil, "invalid_source" end
	local recipient = Mod_FindBestAlly(src_player.id)
	if recipient == nil then return nil, "no_runtime_recipient" end
	for idx, p in ipairs(PLAYERS) do
		if p ~= nil and p.id == recipient.id then
			return idx, "ok"
		end
	end
	return nil, "recipient_index_not_found"
end

function _LeaverMilTest_IsAlivePlayerIndex(player_idx)
	local player = PLAYERS[player_idx]
	if player == nil then return false end
	local ok, eliminated = pcall(Core_IsPlayerEliminated, player.id)
	return ok and not eliminated
end

function _LeaverMilTest_GetCivSuffix(civ_name)
	local prefix = AGS_CIV_PREFIXES[civ_name]
	if prefix == nil then return nil end
	if string.sub(prefix, -1) == "_" then
		return string.sub(prefix, 1, -2)
	end
	return prefix
end

function _LeaverMilTest_GetRoleSourceCandidates(role_key, src_suffix)
	if role_key == nil or src_suffix == nil then return {} end
	local tiers = { 2, 3, 1, 4 }
	if role_key == "unit_monk_" then
		tiers = { 2, 1, 3, 4 }
	elseif role_key == "unit_culverin_" or role_key == "unit_bombard_" or role_key == "unit_ribauldequin_"
		or role_key == "unit_trebuchet_" or role_key == "unit_springald_" or role_key == "unit_mangonel_"
		or role_key == "unit_ram_" or role_key == "unit_siege_tower_" then
		tiers = { 3, 4, 2, 1 }
	end

	local names = {}
	for _, tier in ipairs(tiers) do
		table.insert(names, string.format("%s%d_%s", role_key, tier, src_suffix))
	end
	return names
end

function _LeaverMilTest_FindReceiverClassCandidate(role_key, src_civ, dst_civ)
	local src_suffix = _LeaverMilTest_GetCivSuffix(src_civ)
	if src_suffix == nil then
		return nil, nil, "missing_src_suffix"
	end

	local candidate_names = _LeaverMilTest_GetRoleSourceCandidates(role_key, src_suffix)
	for _, candidate in ipairs(candidate_names) do
		local ok_bp, source_sbp = pcall(BP_GetSquadBlueprint, candidate)
		if ok_bp and source_sbp ~= nil then
			local route = _ResolveMilitaryRoute(candidate, src_civ, dst_civ)
			if route ~= nil and route.route == "receiver_class" and route.to_sbp ~= nil then
				return candidate, source_sbp, route
			end
		end
	end

	return nil, nil, "no_receiver_class_candidate"
end

function _LeaverMilTest_SelectAutoPair()
	local alive = {}
	for i, player in ipairs(PLAYERS) do
		if _LeaverMilTest_IsAlivePlayerIndex(i) and not (player.isLocal == true) then
			table.insert(alive, i)
		end
	end
	if #alive < 2 then return nil, nil, "no_valid_pairs" end

	local has_runtime_recipient = false
	local has_class_map_coverage = false
	for _, src_idx in ipairs(alive) do
		local dst_idx = _LeaverMilTest_GetActualRecipientIndex(src_idx)
		if dst_idx ~= nil and src_idx ~= dst_idx and _LeaverMilTest_IsAlivePlayerIndex(dst_idx) then
			has_runtime_recipient = true
			local src_civ = Player_GetRaceName(PLAYERS[src_idx].id)
			local dst_civ = Player_GetRaceName(PLAYERS[dst_idx].id)
			local receiver_map = _LEAVER_RECEIVER_CLASS_MAP and _LEAVER_RECEIVER_CLASS_MAP[dst_civ]
			if receiver_map ~= nil then
				has_class_map_coverage = true
				for role_key, rule in pairs(receiver_map) do
					if type(rule) == "table" and rule.policy ~= "destroy" then
						local candidate_name = _LeaverMilTest_FindReceiverClassCandidate(role_key, src_civ, dst_civ)
						if candidate_name ~= nil then
							return src_idx, dst_idx, "bound_actual_recipient"
						end
					end
				end
			end
		end
	end

	if not has_runtime_recipient then return nil, nil, "no_valid_pairs" end
	if not has_class_map_coverage then return nil, nil, "no_class_map_coverage" end
	return nil, nil, "no_receiver_class_candidates"
end

function _LeaverMilTest_SelectFullValidationTarget(excluded_idx)
	for i, player in ipairs(PLAYERS) do
		if player ~= nil and i ~= excluded_idx and not (player.isLocal == true) and _LeaverMilTest_IsAlivePlayerIndex(i) then
			return i
		end
	end
	for i, player in ipairs(PLAYERS) do
		if player ~= nil and i ~= excluded_idx and _LeaverMilTest_IsAlivePlayerIndex(i) then
			return i
		end
	end
	return nil
end

---------------------------------------------------------------------------------------------------
-- Stage 1: Pre-Snapshot (read-only baseline)
---------------------------------------------------------------------------------------------------
function _LeaverDebug_Stage1_Snapshot()
	print("")
	print("=== STAGE 1: PRE-DISCONNECT SNAPSHOT ===")
	local snapshot = {}
	for i, player in ipairs(PLAYERS) do
		local ok, elim = pcall(Core_IsPlayerEliminated, player.id)
		if ok and not elim then
			local eg = Player_GetEntities(player.id)
			local sg = Player_GetSquads(player.id)
			local pop = Player_GetCurrentPopulation(player.id, CT_Personnel)
			local cap = Player_GetCurrentPopulationCap(player.id, CT_Personnel)
			local civ = Player_GetRaceName(player.id)
			local bld = player.obj_buildingLimit_count or 0
			local ws = player.obj_buildingLimit_workshop_count or 0
			local op = player.obj_buildingLimit_outpost_count or 0
			local siege = player.siegeLimit_count or 0
			local absorb = player._leaver_absorb_count or 0

			-- Count eco vs military squads
			local eco_count, mil_count = 0, 0
			local sc = SGroup_Count(sg)
			for idx = 1, sc do
				local squad = SGroup_GetSquadAt(sg, idx)
				if squad ~= nil then
					if Squad_IsOfType(squad, "scar_villager") or Squad_IsOfType(squad, "scar_monk")
						or Squad_IsOfType(squad, "scar_trader") or Squad_IsOfType(squad, "scar_fishing")
						or Squad_IsOfType(squad, "scar_scout") or Squad_IsOfType(squad, "king") then
						eco_count = eco_count + 1
					else
						mil_count = mil_count + 1
					end
				end
			end

			-- Count buildings by class
			local bld_classes = { production = 0, workshop = 0, outpost = 0, landmark = 0, other = 0 }
			local ec = EGroup_Count(eg)
			for idx = 1, ec do
				local ent = EGroup_GetEntityAt(eg, idx)
				if ent ~= nil then
					local cls = _Transfer_ClassifyBuilding(ent, civ)
					bld_classes[cls] = (bld_classes[cls] or 0) + 1
				end
			end

			-- Resources
			local food = Player_GetResource(player.id, RT_Food)
			local wood = Player_GetResource(player.id, RT_Wood)
			local gold = Player_GetResource(player.id, RT_Gold)
			local stone = Player_GetResource(player.id, RT_Stone)

			snapshot[i] = {
				civ = civ, pop = pop, cap = cap,
				entities = ec, squads = sc,
				eco = eco_count, mil = mil_count,
				bld = bld, ws = ws, op = op, siege = siege, absorb = absorb,
				bld_classes = bld_classes,
				food = food, wood = wood, gold = gold, stone = stone,
			}
			print(string.format(
				"  P%d [%s] pop=%d/%d ent=%d sq=%d(eco=%d mil=%d) bld=%d ws=%d op=%d siege=%d absorb=%d",
				i, civ, pop, cap, ec, sc, eco_count, mil_count, bld, ws, op, siege, absorb
			))
			print(string.format(
				"    buildings: prod=%d ws=%d op=%d lm=%d other=%d | res: F=%d W=%d G=%d S=%d",
				bld_classes.production, bld_classes.workshop, bld_classes.outpost, bld_classes.landmark, bld_classes.other,
				math.floor(food), math.floor(wood), math.floor(gold), math.floor(stone)
			))
		else
			print(string.format("  P%d [eliminated]", i))
			snapshot[i] = nil
		end
	end
	return snapshot
end

---------------------------------------------------------------------------------------------------
-- Stage 2: Reverse Map Validation (read-only)
---------------------------------------------------------------------------------------------------
function _LeaverDebug_Stage2_ReverseMap()
	print("")
	print("=== STAGE 2: REVERSE BLUEPRINT MAP VALIDATION ===")
	local issues = 0

	if type(_BLUEPRINT_REVERSE_MAP) ~= "table" then
		print("  [FAIL] _BLUEPRINT_REVERSE_MAP is nil or not a table")
		return 1
	end

	local count = 0
	for _ in pairs(_BLUEPRINT_REVERSE_MAP) do count = count + 1 end
	print(string.format("  Map size: %d entries", count))

	if count == 0 then
		print("  [FAIL] Map is empty — _BuildBlueprintReverseMap() may not have run")
		return 1
	end

	-- Spot-check known entries
	local spot_checks = {
		{ "building_unit_infantry_control_eng", "barracks" },
		{ "building_defense_keep_eng", "castle" },
		{ "unit_villager_1_eng", "villager" },
		{ "building_unit_cavalry_control_eng", "stable" },
	}
	for _, check in ipairs(spot_checks) do
		local attrib, expected_key = check[1], check[2]
		local actual = _BLUEPRINT_REVERSE_MAP[attrib]
		if actual == expected_key then
			print(string.format("  [OK] '%s' → '%s'", attrib, actual))
		elseif actual == nil then
			print(string.format("  [WARN] '%s' → nil (expected '%s')", attrib, expected_key))
			issues = issues + 1
		else
			print(string.format("  [WARN] '%s' → '%s' (expected '%s')", attrib, actual, expected_key))
			issues = issues + 1
		end
	end

	-- Check that all alive player's buildings can be reverse-mapped
	local unmapped_bps = {}
	for i, player in ipairs(PLAYERS) do
		local ok, elim = pcall(Core_IsPlayerEliminated, player.id)
		if ok and not elim then
			local eg = Player_GetEntities(player.id)
			local ec = EGroup_Count(eg)
			for idx = 1, ec do
				local ent = EGroup_GetEntityAt(eg, idx)
				if ent ~= nil then
					local bp = Entity_GetBlueprint(ent)
					local bp_name = BP_GetName(bp)
					local ags_key = _BLUEPRINT_REVERSE_MAP[bp_name]
					if ags_key == nil and not Entity_IsOfType(ent, "landmark") and not Entity_IsOfType(ent, "wonder") then
						unmapped_bps[bp_name] = (unmapped_bps[bp_name] or 0) + 1
					end
				end
			end
		end
	end

	local unmapped_count = 0
	for bp, ct in pairs(unmapped_bps) do
		print(string.format("  [INFO] Unmapped BP: '%s' (×%d) — defense structures transfer, unmapped others killed", bp, ct))
		unmapped_count = unmapped_count + 1
	end
	if unmapped_count > 0 then
		print(string.format("  [INFO] %d unique blueprints have no AGS mapping (defense structures transfer, others killed)", unmapped_count))
	end

	return issues
end

---------------------------------------------------------------------------------------------------
-- Stage 3: Execute Disconnect (DESTRUCTIVE)
---------------------------------------------------------------------------------------------------
function _LeaverDebug_Stage3_Disconnect(player_idx)
	print("")
	print(string.format("=== STAGE 3: DISCONNECTING PLAYER %d ===", player_idx))

	local player = PLAYERS[player_idx]
	if player == nil then
		print(string.format("  [FAIL] PLAYERS[%d] is nil", player_idx))
		return false
	end
	if Core_IsPlayerEliminated(player.id) then
		print(string.format("  [FAIL] Player %d already eliminated", player_idx))
		return false
	end

	-- Find who will receive
	local recipient = Mod_FindBestAlly(player.id)
	if recipient then
		local rcv_idx = "?"
		for i, p in ipairs(PLAYERS) do
			if p.id == recipient.id then rcv_idx = i break end
		end
		print(string.format("  Expected recipient: P%s [%s] (pop=%d, absorb=%d)",
			rcv_idx, Player_GetRaceName(recipient.id),
			Player_GetCurrentPopulation(recipient.id, CT_Personnel),
			recipient._leaver_absorb_count or 0))
	else
		print("  [WARN] No ally found — all assets will be killed")
	end

	-- Mirror the real AGS_Elimination_OnPlayerAITakeover path: set reason first
	-- so that _Onslaught_SetEliminationReason(WR_ELIMINATION) does not overwrite it.
	player.eliminationReason = "disconnect"
	Core_SetPlayerDefeated(player.id, Annihilation_LoserPresentation, WR_ELIMINATION)
	print("  Disconnect triggered via Core_SetPlayerDefeated")
	return true
end

---------------------------------------------------------------------------------------------------
-- Stage 4: Post-Disconnect Validation (read-only)
---------------------------------------------------------------------------------------------------
function _LeaverDebug_Stage4_Validate(pre_snapshot, disconnected_idx)
	print("")
	print("=== STAGE 4: POST-DISCONNECT VALIDATION ===")
	local issues = 0

	-- Check disconnected player has no entities
	local victim = PLAYERS[disconnected_idx]
	if victim ~= nil then
		local eg = Player_GetEntities(victim.id)
		local sg = Player_GetSquads(victim.id)
		local e_count = EGroup_Count(eg)
		local s_count = SGroup_Count(sg)
		if e_count > 0 then
			print(string.format("  [FAIL] Victim P%d still has %d entities (orphaned)", disconnected_idx, e_count))
			issues = issues + 1
		else
			print(string.format("  [OK] Victim P%d has 0 entities", disconnected_idx))
		end
		if s_count > 0 then
			print(string.format("  [FAIL] Victim P%d still has %d squads (orphaned)", disconnected_idx, s_count))
			issues = issues + 1
		else
			print(string.format("  [OK] Victim P%d has 0 squads", disconnected_idx))
		end
	end

	-- Check all surviving allies
	for i, player in ipairs(PLAYERS) do
		local ok, elim = pcall(Core_IsPlayerEliminated, player.id)
		if ok and not elim then
			local eg = Player_GetEntities(player.id)
			local sg = Player_GetSquads(player.id)
			local pop = Player_GetCurrentPopulation(player.id, CT_Personnel)
			local cap = Player_GetCurrentPopulationCap(player.id, CT_Personnel)
			local bld = player.obj_buildingLimit_count or 0
			local ws = player.obj_buildingLimit_workshop_count or 0
			local siege = player.siegeLimit_count or 0
			local absorb = player._leaver_absorb_count or 0
			local pre = pre_snapshot[i]

			print(string.format("  P%d [%s] pop=%d/%d ent=%d sq=%d bld=%d ws=%d siege=%d absorb=%d",
				i, Player_GetRaceName(player.id), pop, cap,
				EGroup_Count(eg), SGroup_Count(sg), bld, ws, siege, absorb))

			-- Check for negative counters
			if bld < 0 then
				print(string.format("    [FAIL] Negative building count: %d", bld))
				issues = issues + 1
			end
			if siege < 0 then
				print(string.format("    [FAIL] Negative siege count: %d", siege))
				issues = issues + 1
			end

			-- Check building limit not exceeded
			local limit = CBA_Options_GetPlayerProdLimit(player)
			if limit > 0 and bld > limit then
				print(string.format("    [FAIL] Building count %d exceeds limit %d", bld, limit))
				issues = issues + 1
			end

			-- Check pop not over cap
			if pop > cap then
				print(string.format("    [WARN] Pop %d exceeds cap %d (enforcement may be delayed)", pop, cap))
				issues = issues + 1
			end

			-- Absorption can change cap by different amounts depending on runtime population rules.
			-- Treat any non-decreasing cap as healthy and only warn if absorption lowers it.
			if pre ~= nil and absorb > (pre.absorb or 0) then
				local delta = cap - pre.cap
				if delta > 0 then
					print(string.format("    [OK] Pop cap adjusted from %d to %d (+%d)", pre.cap, cap, delta))
				elseif delta == 0 then
					print(string.format("    [INFO] Pop cap unchanged at %d after absorption", cap))
				else
					print(string.format("    [WARN] Pop cap dropped from %d to %d after absorption", pre.cap, cap))
				end
			end

			-- Check starter keep ref still valid for English
			local branch = AGS_CIV_FACTION_MAP[Player_GetRaceName(player.id)] or Player_GetRaceName(player.id)
			if branch == "english" and player.obj_buildingLimit_english_start_keep_id ~= nil then
				local keep = player.obj_buildingLimit_english_start_keep_id
				if Entity_IsAlive(keep) then
					print(string.format("    [OK] Starter keep ref valid (alive)"))
				else
					print(string.format("    [FAIL] Starter keep ref is STALE (entity dead)"))
					issues = issues + 1
				end
			end
		end
	end

	return issues
end

---------------------------------------------------------------------------------------------------
-- Stage 5: Cross-Civ Blueprint Audit (read-only)
-- Checks foreign-civ BP ownership AND prerequisite violations (age + capability).
---------------------------------------------------------------------------------------------------
function _LeaverDebug_Stage5_BlueprintAudit()
	print("")
	print("=== STAGE 5: CROSS-CIV BLUEPRINT AUDIT ===")
	local issues = 0

	-- For each alive player, check that every building they own resolves to their civ
	for i, player in ipairs(PLAYERS) do
		local ok, elim = pcall(Core_IsPlayerEliminated, player.id)
		if ok and not elim then
			local civ = Player_GetRaceName(player.id)
			local rcv_age = Player_GetCurrentAge(player.id)
			local eg = Player_GetEntities(player.id)
			local ec = EGroup_Count(eg)
			local foreign_bps = {}
			local age_violations = {}
			local cap_violations = {}
			for idx = 1, ec do
				local ent = EGroup_GetEntityAt(eg, idx)
				if ent ~= nil then
					local bp = Entity_GetBlueprint(ent)
					local bp_name = BP_GetName(bp)
					-- Skip transferred infrastructure (walls, gates, towers, palisades, keeps)
					if not string.find(bp_name, "defense_wall") and not string.find(bp_name, "defense_tower")
						and not string.find(bp_name, "palisade") and not string.find(bp_name, "defense_keep") then
						local ags_key = _BLUEPRINT_REVERSE_MAP[bp_name]
						if ags_key ~= nil then
							-- Check if this attribName belongs to the player's civ
							local expected_bp = AGS_GetCivilizationEntity(civ, ags_key)
							if expected_bp ~= nil and BP_GetName(expected_bp) ~= bp_name then
								foreign_bps[bp_name] = (foreign_bps[bp_name] or 0) + 1
							end
							-- Check age requirement violation
							if _LEAVER_AGE_REQUIREMENTS ~= nil and _LEAVER_AGE_REQUIREMENTS[ags_key] ~= nil then
								local req_age = _LEAVER_AGE_REQUIREMENTS[ags_key]
								if rcv_age < req_age then
									age_violations[bp_name] = { required = req_age, actual = rcv_age, ags_key = ags_key }
								end
							end
							-- Check capability requirement violation
							if _LEAVER_CAPABILITY_REQUIREMENTS ~= nil and _LEAVER_CAPABILITY_REQUIREMENTS[ags_key] ~= nil then
								local req = _LEAVER_CAPABILITY_REQUIREMENTS[ags_key]
								local has_upgrade = false
								if type(_Leaver_PlayerHasUpgradeCached) == "function" then
									has_upgrade = _Leaver_PlayerHasUpgradeCached(player.id, req.upgrade_key)
								end
								if not has_upgrade then
									cap_violations[bp_name] = { upgrade = req.upgrade_key, description = req.description, ags_key = ags_key }
								end
							end
						end
					end
				end
			end
			local foreign_count = 0
			for bp, ct in pairs(foreign_bps) do
				print(string.format("  [WARN] P%d [%s] owns foreign BP '%s' (×%d)", i, civ, bp, ct))
				foreign_count = foreign_count + ct
				issues = issues + 1
			end
			for bp, v in pairs(age_violations) do
				print(string.format("  [AGE_REQUIREMENT_VIOLATION] P%d [%s] owns '%s' (ags=%s) requiring age %d, player at age %d",
					i, civ, bp, v.ags_key, v.required, v.actual))
				issues = issues + 1
			end
			for bp, v in pairs(cap_violations) do
				print(string.format("  [CAPABILITY_REQUIREMENT_VIOLATION] P%d [%s] owns '%s' (ags=%s) requiring %s (%s) — not researched",
					i, civ, bp, v.ags_key, v.description, v.upgrade))
				issues = issues + 1
			end
			if foreign_count == 0 and next(age_violations) == nil and next(cap_violations) == nil then
				print(string.format("  [OK] P%d [%s] — all %d buildings match civ, no prerequisite violations", i, civ, ec))
			end
		end
	end

	return issues
end

---------------------------------------------------------------------------------------------------
-- Stage 6: Summary Report (with gate taxonomy and mismatch detection)
---------------------------------------------------------------------------------------------------
function _LeaverDebug_Stage6_Summary(stage_issues)
	print("")
	print("=== STAGE 6: SUMMARY REPORT ===")
	local total = 0
	for stage, count in pairs(stage_issues) do
		if count > 0 then
			print(string.format("  Stage %s: %d issue(s)", stage, count))
		end
		total = total + count
	end

	-- Gate decision taxonomy from last transfer stats
	print("")
	print("  --- GATE DECISION TAXONOMY ---")
	local lst = _leaver_last_transfer_stats
	if lst ~= nil then
		local age_blocked = lst.mil_destroy_age_blocked or 0
		local cap_blocked = lst.mil_destroy_cap_blocked or 0
		local age_bypass_count = 0
		local cap_bypass_count = 0
		-- Count bypass entries from audit log snapshot (if still available)
		if type(_LEAVER_AUDIT_LOG) == "table" then
			for _, entry in ipairs(_LEAVER_AUDIT_LOG) do
				if entry.decision == "AGE_BYPASS" then age_bypass_count = age_bypass_count + 1 end
				if entry.decision == "CAP_BYPASS" then cap_bypass_count = cap_bypass_count + 1 end
			end
		end
		print(string.format("  Age gates:  blocked=%d bypassed=%d", age_blocked, age_bypass_count))
		print(string.format("  Cap gates:  blocked=%d bypassed=%d", cap_blocked, cap_bypass_count))
		print(string.format("  Bypass flags: age=%s cap=%s",
			tostring(_LEAVER_DEBUG_BYPASS_GATES), tostring(_LEAVER_DEBUG_BYPASS_CAPABILITY_GATES)))

		-- Mismatch detection: route counters vs destroy counters
		local routes_total = (lst.mil_direct or 0) + (lst.mil_tier_bump or 0)
			+ (lst.mil_civ_unique_archetype or 0) + (lst.mil_receiver_class or 0)
			+ (lst.mil_generic_archetype or 0)
		local destroy_total = (lst.mil_destroy_policy or 0) + age_blocked + cap_blocked
			+ (lst.mil_destroy_create_fail or 0) + (lst.mil_destroy_no_mapping or 0)
			+ (lst.mil_destroy_ratio_skip or 0)
			+ (lst.mil_destroy_pop_capped or 0)
		local same_xfer = (lst.mil_same_bp or 0) + (lst.mil_transfer_only or 0)
		local eco_accounted = (lst.eco_transferred or 0) + (lst.eco_killed or 0)
		local dead_accounted = lst.skipped_dead or 0
		local accounted = routes_total + destroy_total + same_xfer + eco_accounted + dead_accounted
		local expected = lst.squad_total or 0
		if expected > 0 and accounted ~= expected then
			print(string.format("  [MISMATCH] Squad total=%d but accounted=%d (routes=%d destroy=%d same/xfer=%d eco=%d dead=%d) — %d unaccounted",
				expected, accounted, routes_total, destroy_total, same_xfer, eco_accounted, dead_accounted, expected - accounted))
			total = total + 1
		elseif expected > 0 then
			print(string.format("  [OK] All %d squads accounted (routes=%d destroy=%d same/xfer=%d eco=%d dead=%d)",
				expected, routes_total, destroy_total, same_xfer, eco_accounted, dead_accounted))
		end

		-- Terminal handled-decision reconciliation
		print("")
		print("  --- TERMINAL HANDLED-DECISION RECONCILIATION ---")
		local eco_total = (lst.eco_transferred or 0) + (lst.eco_killed or 0)
		local mil_converted = routes_total + (lst.mil_same_bp or 0)
		local mil_destroyed_all = destroy_total
		local handled_total = eco_total + mil_converted + mil_destroyed_all + (lst.mil_transfer_only or 0)
		local skipped_dead = lst.skipped_dead or 0
		local silent_skip = lst.mil_silent_skip or 0
		local eligible_total = expected - skipped_dead

		print(string.format("  eligible_total=%d  handled_total=%d  skipped_dead=%d  silent_skip=%d",
			eligible_total, handled_total, skipped_dead, silent_skip))
		print(string.format("  eco=%d (xfer=%d kill=%d)  mil_conv=%d (routes=%d same=%d)  mil_dest=%d  mil_xfer=%d",
			eco_total, lst.eco_transferred or 0, lst.eco_killed or 0,
			mil_converted, routes_total, lst.mil_same_bp or 0,
			mil_destroyed_all, lst.mil_transfer_only or 0))

		if silent_skip > 0 then
			print(string.format("  [FAIL] silent_skip=%d — unhandled squads detected in pipeline", silent_skip))
			total = total + 1
		else
			print("  [OK] silent_skip=0")
		end
		if eligible_total > 0 and handled_total ~= eligible_total then
			print(string.format("  [FAIL] handled_total=%d != eligible_total=%d — %d unaccounted",
				handled_total, eligible_total, eligible_total - handled_total))
			total = total + 1
		elseif eligible_total > 0 then
			print(string.format("  [OK] eligible_total == handled_total == %d", eligible_total))
		end

		-- Terminal bucket exhaustiveness:
		-- handled_total must equal sum of (converted + transferred + killed + blocked + bypassed)
		local bucket_converted = routes_total
		local bucket_transferred = (lst.mil_same_bp or 0) + (lst.mil_transfer_only or 0) + (lst.eco_transferred or 0)
		local bucket_killed = (lst.mil_destroy_policy or 0) + (lst.mil_destroy_create_fail or 0)
			+ (lst.mil_destroy_no_mapping or 0) + (lst.mil_destroy_ratio_skip or 0)
			+ (lst.mil_destroy_pop_capped or 0) + (lst.eco_killed or 0)
		local bucket_blocked = age_blocked + cap_blocked
		local bucket_bypassed = (lst.mil_bypass_age_spawner_exempt or 0)
		local bucket_sum = bucket_converted + bucket_transferred + bucket_killed + bucket_blocked
		-- Note: bypassed units continue to a terminal decision, so bypass is NOT a terminal bucket.
		-- Bypass count is informational only (spawner-exempt units still get converted or destroyed).
		if eligible_total > 0 and bucket_sum ~= eligible_total then
			print(string.format("  [FAIL] bucket_sum=%d != eligible_total=%d (conv=%d xfer=%d kill=%d block=%d)",
				bucket_sum, eligible_total, bucket_converted, bucket_transferred, bucket_killed, bucket_blocked))
			total = total + 1
		elseif eligible_total > 0 then
			print(string.format("  [OK] bucket_sum == eligible_total == %d (conv=%d xfer=%d kill=%d block=%d exempt_bypass=%d)",
				eligible_total, bucket_converted, bucket_transferred, bucket_killed, bucket_blocked, bucket_bypassed))
		end

		-- Building handled-decision reconciliation
		print("")
		print("  --- BUILDING HANDLED-DECISION RECONCILIATION ---")
		local bldg_conv = lst.bldg_converted or 0
		local bldg_xfer = lst.bldg_transferred or 0
		local bldg_kill = lst.bldg_killed or 0
		local bldg_dead = lst.bldg_skipped_dead or 0
		local bldg_silent = lst.bldg_silent_skip or 0
		local bldg_total = lst.entity_total or 0
		local bldg_eligible = bldg_total - bldg_dead
		local bldg_handled = bldg_conv + bldg_xfer + bldg_kill
		print(string.format("  entity_total=%d eligible=%d handled=%d dead=%d silent_skip=%d pop_house=%d pop_tc=%d",
			bldg_total, bldg_eligible, bldg_handled, bldg_dead, bldg_silent, lst.bldg_killed_autopop_house or 0, lst.bldg_killed_autopop_tc or 0))
		print(string.format("  conv=%d xfer=%d kill=%d quality[e=%d p=%d l=%d]",
			bldg_conv, bldg_xfer, bldg_kill,
			lst.bldg_q_exact or 0, lst.bldg_q_parent or 0, lst.bldg_q_lossy or 0))

		if bldg_silent > 0 then
			print(string.format("  [FAIL] bldg_silent_skip=%d — unhandled building path(s)", bldg_silent))
			total = total + 1
		else
			print("  [OK] bldg_silent_skip=0")
		end
		if bldg_handled ~= bldg_eligible then
			print(string.format("  [FAIL] bldg_handled=%d != bldg_eligible=%d", bldg_handled, bldg_eligible))
			total = total + 1
		else
			print(string.format("  [OK] bldg_handled == bldg_eligible == %d", bldg_eligible))
		end
	else
		print("  No transfer stats available — run a disconnect first.")
	end

	print("")
	if total == 0 then
		print("  *** ALL STAGES PASSED — LEAVER CONVERSION SYSTEM OK ***")
	else
		print(string.format("  *** %d TOTAL ISSUE(S) DETECTED ***", total))
	end

	-- Gap analysis
	print("")
	print("  --- GAP ANALYSIS ---")
	local gaps = {}

	-- Check if reverse map exists
	if type(_BLUEPRINT_REVERSE_MAP) ~= "table" or next(_BLUEPRINT_REVERSE_MAP) == nil then
		table.insert(gaps, "Reverse blueprint map empty — _BuildBlueprintReverseMap() failed or didn't run")
	end

	-- Check if any alive player has absorb > 0 (means transfer happened)
	local any_absorb = false
	for _, p in ipairs(PLAYERS) do
		if (p._leaver_absorb_count or 0) > 0 then any_absorb = true break end
	end
	if not any_absorb then
		table.insert(gaps, "No player has _leaver_absorb_count > 0 — pipeline may not have executed")
	end

	-- Check EnforcePostTransfer availability
	if type(CBA_Options_EnforcePostTransfer) ~= "function" then
		table.insert(gaps, "CBA_Options_EnforcePostTransfer not found — post-transfer enforcement missing")
	end

	-- Check AGS_GetCivilizationEntity availability
	if type(AGS_GetCivilizationEntity) ~= "function" then
		table.insert(gaps, "AGS_GetCivilizationEntity not found — building conversion will fail")
	end

	-- Check AGS_GetCivilizationUnit availability
	if type(AGS_GetCivilizationUnit) ~= "function" then
		table.insert(gaps, "AGS_GetCivilizationUnit not found — eco squad conversion will fail")
	end

	-- Check capability gate function
	if type(_Leaver_MeetsCapabilityRequirement) ~= "function" then
		table.insert(gaps, "_Leaver_MeetsCapabilityRequirement not found — capability gating missing")
	end

	if #gaps == 0 then
		print("  No gaps detected.")
	else
		for _, gap in ipairs(gaps) do
			print(string.format("  [GAP] %s", gap))
		end
	end

	-- Recommendations
	print("")
	print("  --- NEXT STEPS ---")
	if total > 0 then
		print("  1. Fix issues above, then re-run Debug_LeaverConversion_Full()")
		print("  2. Test cross-civ: start 4v4 with mixed civs, disconnect different civs")
		print("  3. Verify Mongol packed buildings, English starter keeps, landmarks")
	else
		print("  1. Run Debug_LeaverConversion_Stress(2) to test multi-disconnect")
		print("  2. Manual test: disconnect Chinese→English receiver, check barracks conversion")
		print("  3. Manual test: verify garrisoned units ejected (archers in keep)")
		print("  4. Manual test: verify farm buildings functional after conversion")
	end

	return total
end

---------------------------------------------------------------------------------------------------
-- COMMAND 1: Full Validation (Stages 1-6)
-- Usage: Debug_LeaverConversion_Full()  or  Debug_LeaverConversion_Full(2)
---------------------------------------------------------------------------------------------------
function Debug_LeaverConversion_Full(disconnect_player_idx, opt_mode)
	print("")
	print("============================================")
	print("  CBA DEBUG — LEAVER CONVERSION: FULL TEST")
	print("  Branch: onslaught-v3.4")
	print("============================================")

	-- Default: disconnect player 2 (typically first enemy or ally depending on setup)
	disconnect_player_idx = disconnect_player_idx or 2
	local full_validation_all = (opt_mode == "full_validation_all" or opt_mode == "full_validation_all_verbose")
	local matrix_mode = (opt_mode == "full_validation_all_verbose") and "verbose" or nil

	-- Validate player index
	if PLAYERS[disconnect_player_idx] == nil then
		print(string.format("[ERROR] PLAYERS[%d] is nil — valid range is 1-%d", disconnect_player_idx, #PLAYERS))
		return
	end
	if Core_IsPlayerEliminated(PLAYERS[disconnect_player_idx].id) then
		print(string.format("[ERROR] Player %d already eliminated — pick another", disconnect_player_idx))
		return
	end

	_LEAVER_DEBUG_FULL_RUN_COUNTER = _LEAVER_DEBUG_FULL_RUN_COUNTER + 1
	local run_id = _LEAVER_DEBUG_FULL_RUN_COUNTER
	local start_time = World_GetGameTime()
	print(string.format("[LEAVER_DEBUG][FULL][RUN %d] START disconnect_player_idx=%d", run_id, disconnect_player_idx))

	local stage_issues = {}

	-- Stage 1: Baseline snapshot
	local pre_snapshot = _LeaverDebug_Stage1_Snapshot()

	-- Stage 2: Reverse map
	stage_issues["2_ReverseMap"] = _LeaverDebug_Stage2_ReverseMap()

	-- Stage 3: Execute disconnect
	local ok = _LeaverDebug_Stage3_Disconnect(disconnect_player_idx)
	if not ok then
		print("[ABORT] Disconnect failed — cannot continue validation")
		return
	end

	-- Defer validation until the optimized multi-frame transfer pipeline fully completes.
	_LEAVER_DEBUG_FULL_PENDING = {
		pre_snapshot = pre_snapshot,
		disconnected_idx = disconnect_player_idx,
		stage_issues = stage_issues,
		run_id = run_id,
		start_time = start_time,
		full_validation_all = full_validation_all,
		matrix_mode = matrix_mode,
	}
	print("  Waiting for deferred conversion batches to complete before Stage 4-6...")
	Rule_AddOneShot(_LeaverDebug_FullFinalize, 0)
	print(string.format("[LEAVER_DEBUG][FULL][RUN %d] DEFERRED waiting_for_pipeline=true", run_id))
end

---------------------------------------------------------------------------------------------------
-- Military Test Mode: Exercises suffix-swap and class-fallback resolution paths by
-- spawning military units without age constraints and observing route selection.
-- Usage: Debug_LeaverMilTest()                — auto-select civs, default verbosity
--        Debug_LeaverMilTest(src_idx, dst_idx) — manual player indices
--        Debug_LeaverMilTest(src_idx, dst_idx, verbose) — with verbose logging
---------------------------------------------------------------------------------------------------
function Debug_LeaverMilTest(src_idx, dst_idx, verbose)
	print("")
	print("============================================")
	print("  CBA DEBUG — LEAVER MILITARY TEST MODE")
	print("============================================")

	-- Auto-select: prefer alive non-local pair with class-map support and receiver_class route availability.
	if src_idx == nil or dst_idx == nil then
		local auto_reason = nil
		src_idx, dst_idx, auto_reason = _LeaverMilTest_SelectAutoPair()
		if src_idx == nil or dst_idx == nil then
			print(string.format("[LEAVER_DEBUG][MIL_TEST] FAIL reason=%s", tostring(auto_reason)))
			return false, tostring(auto_reason)
		end
		print(string.format("[LEAVER_DEBUG][MIL_TEST] AUTO_SELECT src=%d dst=%d reason=%s", src_idx, dst_idx, tostring(auto_reason)))
	end

	-- Validate indices
	if PLAYERS[src_idx] == nil or PLAYERS[dst_idx] == nil then
		print(string.format("[ERROR] Invalid indices src=%d dst=%d (valid range: 1-%d)", src_idx, dst_idx, #PLAYERS))
		return false, "invalid_indices"
	end
	if src_idx == dst_idx then
		print("[ERROR] Source and destination must be different players")
		return false, "same_source_destination"
	end
	local ok_src, elim_src = pcall(Core_IsPlayerEliminated, PLAYERS[src_idx].id)
	local ok_dst, elim_dst = pcall(Core_IsPlayerEliminated, PLAYERS[dst_idx].id)
	if (not ok_src or elim_src) or (not ok_dst or elim_dst) then
		print(string.format("[ERROR] Both players must be alive (src_elim=%s dst_elim=%s)", tostring(elim_src), tostring(elim_dst)))
		return false, "players_not_alive"
	end

	local actual_dst_idx, actual_reason = _LeaverMilTest_GetActualRecipientIndex(src_idx)
	if actual_dst_idx == nil then
		print(string.format("[LEAVER_DEBUG][MIL_TEST] FAIL reason=%s src=%d", tostring(actual_reason), src_idx))
		return false, tostring(actual_reason)
	end
	if dst_idx ~= actual_dst_idx then
		print(string.format("[LEAVER_DEBUG][MIL_TEST] FAIL reason=recipient_mismatch requested_dst=%d actual_dst=%d", dst_idx, actual_dst_idx))
		return false, "recipient_mismatch"
	end
	dst_idx = actual_dst_idx

	verbose = verbose or false
	_LEAVER_DEBUG_MILTEST_RUN_COUNTER = _LEAVER_DEBUG_MILTEST_RUN_COUNTER + 1
	local run_id = _LEAVER_DEBUG_MILTEST_RUN_COUNTER
	local start_time = World_GetGameTime()

	local src_civ = Player_GetRaceName(PLAYERS[src_idx].id)
	local dst_civ = Player_GetRaceName(PLAYERS[dst_idx].id)
	local src_suffix = _LeaverMilTest_GetCivSuffix(src_civ)
	print(string.format("[LEAVER_DEBUG][MIL_TEST][RUN %d] START src=%d(%s) dst=%d(%s) verbose=%s",
		run_id, src_idx, src_civ, dst_idx, dst_civ, tostring(verbose)))
	if src_suffix == nil then
		print(string.format("[ERROR] Missing source civ suffix for %s", tostring(src_civ)))
		return false, "missing_source_suffix"
	end

	-- Save current debug flags so we can restore them after the test
	local saved_bypass_gates = _LEAVER_DEBUG_BYPASS_GATES
	local saved_cap_bypass = _LEAVER_DEBUG_BYPASS_CAPABILITY_GATES
	local saved_verbose = _LEAVER_DEBUG_VERBOSE

	-- Enable bypass so units aren't age/cap-gated, and enable verbose if requested
	_LEAVER_DEBUG_BYPASS_GATES = true
	_LEAVER_DEBUG_BYPASS_CAPABILITY_GATES = true
	_LEAVER_DEBUG_VERBOSE = verbose

	-- Spawn suffix-swap test units (gap-safe approach)
	local sfx_count = 0
	local sfx_attempted = 0
	local sg_sfx = SGroup_CreateIfNotFound("sg_leaver_mil_test_sfx")
	SGroup_Clear(sg_sfx)
	local src_player = PLAYERS[src_idx]
	local spawn_pos = Player_GetStartingPosition(src_player.id) or Position_New(50, 50, 0)

	local sfx_bps = {
		string.format("unit_spearman_2_%s", src_suffix),
		string.format("unit_archer_2_%s", src_suffix),
		string.format("unit_horseman_2_%s", src_suffix),
		string.format("unit_manatarms_3_%s", src_suffix),
	}
	for _, bp_name in ipairs(sfx_bps) do
		sfx_attempted = sfx_attempted + 1
		local ok_bp, sfx_bp = pcall(BP_GetSquadBlueprint, bp_name)
		if ok_bp and sfx_bp ~= nil then
			local before_count = SGroup_Count(sg_sfx)
			local ok_create, err_create = pcall(Util_CreateSquads, src_player.id, sg_sfx, sfx_bp, spawn_pos, nil, 1)
			local after_count = SGroup_Count(sg_sfx)
			if ok_create and after_count > before_count then
				sfx_count = sfx_count + 1
				if verbose then print(string.format("[LEAVER_DEBUG_MILTEST] SFX spawn: %s ✓", bp_name)) end
			else
				print(string.format("[LEAVER_DEBUG_MILTEST] SFX_FAIL bp=%s create_ok=%s err=%s", bp_name, tostring(ok_create), tostring(err_create)))
			end
		else
			if verbose then print(string.format("[LEAVER_DEBUG_MILTEST] SFX_SKIP missing_bp=%s", bp_name)) end
		end
	end
	print(string.format("[LEAVER_DEBUG][MIL_TEST][RUN %d] SFX_SPAWNED units=%d attempted=%d", run_id, sfx_count, sfx_attempted))

	-- Spawn remap test units using receiver-aware standard-role candidates that resolve to receiver_class.
	local remap_count = 0
	local remap_attempted = 0
	local remap_resolved = 0
	local sg_remap = SGroup_CreateIfNotFound("sg_leaver_mil_test_remap")
	SGroup_Clear(sg_remap)
	local receiver_map = _LEAVER_RECEIVER_CLASS_MAP and _LEAVER_RECEIVER_CLASS_MAP[dst_civ]
	if receiver_map == nil then
		print(string.format("[LEAVER_DEBUG][MIL_TEST][RUN %d] FAIL reason=no_class_map_coverage dst_civ=%s", run_id, tostring(dst_civ)))
		_LEAVER_DEBUG_BYPASS_GATES = saved_bypass_gates
		_LEAVER_DEBUG_BYPASS_CAPABILITY_GATES = saved_cap_bypass
		_LEAVER_DEBUG_VERBOSE = saved_verbose
		return false, "no_class_map_coverage"
	end
	local role_priority = {
		"unit_manatarms_",
		"unit_crossbowman_",
		"unit_archer_",
		"unit_knight_",
		"unit_horseman_",
		"unit_spearman_",
		"unit_monk_",
		"unit_culverin_",
		"unit_ribauldequin_",
		"unit_trebuchet_",
		"unit_bombard_",
	}

	for _, role_key in ipairs(role_priority) do
		local rule = receiver_map[role_key]
		if type(rule) == "table" then
			remap_attempted = remap_attempted + 1
			if rule.policy == "destroy" then
				print(string.format("[LEAVER_DEBUG_MILTEST] REMAP_SKIP role=%s reason=policy_destroy", role_key))
			else
				local src_bp_name, remap_bp, route_or_reason = _LeaverMilTest_FindReceiverClassCandidate(role_key, src_civ, dst_civ)
				if src_bp_name == nil or remap_bp == nil then
					print(string.format("[LEAVER_DEBUG_MILTEST] REMAP_FAIL role=%s reason=%s", role_key, tostring(route_or_reason)))
				else
					local target_name = "?"
					if type(route_or_reason) == "table" and route_or_reason.to_sbp ~= nil then
						target_name = BP_GetName(route_or_reason.to_sbp)
					end
					remap_resolved = remap_resolved + 1
					local before_count = SGroup_Count(sg_remap)
					local ok_create, err_create = pcall(Util_CreateSquads, src_player.id, sg_remap, remap_bp, spawn_pos, nil, 1)
					local after_count = SGroup_Count(sg_remap)
					if ok_create and after_count > before_count then
						remap_count = remap_count + 1
						print(string.format("[LEAVER_DEBUG_MILTEST] REMAP_OK role=%s src=%s target=%s", role_key, src_bp_name, target_name))
					else
						print(string.format("[LEAVER_DEBUG_MILTEST] REMAP_FAIL role=%s src=%s target=%s reason=create_failed err=%s", role_key, src_bp_name, target_name, tostring(err_create)))
					end
				end
			end
			if remap_count >= 3 then break end
		end
	end
	print(string.format("[LEAVER_DEBUG][MIL_TEST][RUN %d] REMAP_SPAWNED units=%d attempted=%d resolved=%d", run_id, remap_count, remap_attempted, remap_resolved))
	if remap_attempted <= 0 then
		print(string.format("[LEAVER_DEBUG][MIL_TEST][RUN %d] FAIL reason=no_class_map_coverage", run_id))
		_LEAVER_DEBUG_BYPASS_GATES = saved_bypass_gates
		_LEAVER_DEBUG_BYPASS_CAPABILITY_GATES = saved_cap_bypass
		_LEAVER_DEBUG_VERBOSE = saved_verbose
		return false, "no_class_map_coverage"
	end

	if sfx_count == 0 and remap_count == 0 then
		print("[ERROR] Failed to spawn any test units — aborting test")
		_LEAVER_DEBUG_BYPASS_GATES = saved_bypass_gates
		_LEAVER_DEBUG_BYPASS_CAPABILITY_GATES = saved_cap_bypass
		_LEAVER_DEBUG_VERBOSE = saved_verbose
		return false, "no_spawnable_units"
	end

	-- Trigger leaver pipeline by disconnecting source player
	local src_player = PLAYERS[src_idx]
	src_player.eliminationReason = "disconnect"
	print(string.format("[LEAVER_DEBUG][MIL_TEST][RUN %d] Disconnecting player %d to trigger leaver pipeline", run_id, src_idx))

	local ok_disconnect = pcall(Core_SetPlayerDefeated, src_player.id, Annihilation_LoserPresentation, WR_ELIMINATION)
	if not ok_disconnect then
		print("[ERROR] Failed to disconnect player — aborting test")
		_LEAVER_DEBUG_BYPASS_GATES = saved_bypass_gates
		_LEAVER_DEBUG_BYPASS_CAPABILITY_GATES = saved_cap_bypass
		_LEAVER_DEBUG_VERBOSE = saved_verbose
		return false, "disconnect_failed"
	end

	-- Store context for finalize function (will poll and complete)
	_LEAVER_MIL_TEST_PENDING = {
		src_idx = src_idx,
		dst_idx = dst_idx,
		run_id = run_id,
		start_time = start_time,
		saved_bypass_gates = saved_bypass_gates,
		saved_cap_bypass = saved_cap_bypass,
		saved_verbose = saved_verbose,
		sfx_spawned = sfx_count,
		remap_spawned = remap_count,
		remap_attempted = remap_attempted,
		remap_resolved = remap_resolved,
	}

	print("  Waiting for deferred conversion batches to complete...")
	Rule_AddOneShot(_LeaverMilTest_Finalize, 0)
	print(string.format("[LEAVER_DEBUG][MIL_TEST][RUN %d] DEFERRED waiting_for_pipeline=true", run_id))
	return true, "started"
end

---------------------------------------------------------------------------------------------------
-- Single-command deterministic MIL proof runner
-- Usage: Debug_LeaverMilProof_OneShot()
---------------------------------------------------------------------------------------------------
function Debug_LeaverMilProof_OneShot(verbose)
	print("")
	print("============================================")
	print("  CBA DEBUG — LEAVER ONE-SHOT PROOF")
	print("============================================")

	if _LEAVER_MIL_ONESHOT_PENDING ~= nil then
		print("[LEAVER_DEBUG][ONE_SHOT] FAIL reason=already_running")
		return
	end

	verbose = verbose or false
	local src_idx, dst_idx, select_reason = _LeaverMilTest_SelectAutoPair()
	_LEAVER_MIL_ONESHOT_RUN_COUNTER = _LEAVER_MIL_ONESHOT_RUN_COUNTER + 1
	local one_run = _LEAVER_MIL_ONESHOT_RUN_COUNTER
	if src_idx == nil or dst_idx == nil then
		print(string.format("[LEAVER_DEBUG][ONE_SHOT][RUN %d] COMPLETE result=FAIL SFX=FAIL CLASS=FAIL FULL=FAIL reason=%s", one_run, tostring(select_reason)))
		return
	end

	local expected_recipient = _LeaverMilTest_GetActualRecipientIndex(src_idx)
	if expected_recipient == nil then
		print(string.format("[LEAVER_DEBUG][ONE_SHOT][RUN %d] COMPLETE result=FAIL SFX=FAIL CLASS=FAIL FULL=FAIL reason=no_runtime_recipient", one_run))
		return
	end
	if expected_recipient ~= dst_idx then
		print(string.format("[LEAVER_DEBUG][ONE_SHOT][RUN %d] COMPLETE result=FAIL SFX=FAIL CLASS=FAIL FULL=FAIL reason=recipient_mismatch", one_run))
		return
	end

	local dst_civ = Player_GetRaceName(PLAYERS[dst_idx].id)
	if _LEAVER_RECEIVER_CLASS_MAP == nil or _LEAVER_RECEIVER_CLASS_MAP[dst_civ] == nil then
		print(string.format("[LEAVER_DEBUG][ONE_SHOT][RUN %d] COMPLETE result=FAIL SFX=FAIL CLASS=FAIL FULL=FAIL reason=no_class_map_coverage", one_run))
		return
	end

	local planned_mil_run = (_LEAVER_DEBUG_MILTEST_RUN_COUNTER or 0) + 1
	_LEAVER_MIL_ONESHOT_PENDING = {
		run_id = one_run,
		phase = "mil_wait",
		src_idx = src_idx,
		dst_idx = dst_idx,
		mil_run_id = planned_mil_run,
		sfx_result = "FAIL",
		class_result = "FAIL",
		full_result = "FAIL",
		reason = "pending",
	}
	print(string.format("[LEAVER_DEBUG][ONE_SHOT][RUN %d] START src=%d dst=%d reason=%s", one_run, src_idx, dst_idx, tostring(select_reason)))
	local ok_start, start_reason = Debug_LeaverMilTest(src_idx, dst_idx, verbose)
	if not ok_start then
		_LEAVER_MIL_ONESHOT_PENDING = nil
		print(string.format("[LEAVER_DEBUG][ONE_SHOT][RUN %d] COMPLETE result=FAIL SFX=FAIL CLASS=FAIL FULL=FAIL reason=%s", one_run, tostring(start_reason)))
		return
	end
	print(string.format("[LEAVER_DEBUG][ONE_SHOT][RUN %d] DEFERRED phase=mil_proof mil_run=%d", one_run, planned_mil_run))
end

---------------------------------------------------------------------------------------------------
-- COMMAND 2: Inspect (read-only, no game state changes)
-- Usage: Debug_LeaverConversion_Inspect()
---------------------------------------------------------------------------------------------------
function Debug_LeaverConversion_Inspect()
	print("")
	print("============================================")
	print("  CBA DEBUG — LEAVER CONVERSION: INSPECT")
	print("============================================")

	local stage_issues = {}

	-- Stage 1: Current state
	_LeaverDebug_Stage1_Snapshot()

	-- Stage 2: Reverse map
	stage_issues["2_ReverseMap"] = _LeaverDebug_Stage2_ReverseMap()

	-- Stage 5: Blueprint audit (check for foreign BPs already present)
	stage_issues["5_BlueprintAudit"] = _LeaverDebug_Stage5_BlueprintAudit()

	-- Show system readiness
	print("")
	print("=== SYSTEM READINESS ===")
	local ready = true

	if type(_BLUEPRINT_REVERSE_MAP) ~= "table" or next(_BLUEPRINT_REVERSE_MAP) == nil then
		print("  [FAIL] _BLUEPRINT_REVERSE_MAP not initialized")
		ready = false
	else
		local count = 0
		for _ in pairs(_BLUEPRINT_REVERSE_MAP) do count = count + 1 end
		print(string.format("  [OK] _BLUEPRINT_REVERSE_MAP: %d entries", count))
	end

	if type(Mod_EliminatePlayerUnits) == "function" then
		print("  [OK] Mod_EliminatePlayerUnits available")
	else
		print("  [FAIL] Mod_EliminatePlayerUnits not found")
		ready = false
	end

	if type(_Convert_Building) == "function" then
		print("  [OK] _Convert_Building available")
	else
		print("  [FAIL] _Convert_Building not found")
		ready = false
	end

	if type(_Convert_EcoSquad) == "function" then
		print("  [OK] _Convert_EcoSquad available")
	else
		print("  [FAIL] _Convert_EcoSquad not found")
		ready = false
	end

	if type(CBA_Options_EnforcePostTransfer) == "function" then
		print("  [OK] CBA_Options_EnforcePostTransfer available")
	else
		print("  [FAIL] CBA_Options_EnforcePostTransfer not found")
		ready = false
	end

	if type(AGS_GetCivilizationEntity) == "function" then
		print("  [OK] AGS_GetCivilizationEntity available")
	else
		print("  [FAIL] AGS_GetCivilizationEntity not found")
		ready = false
	end

	-- Absorb count state
	print("")
	print("  Absorb counts:")
	for i, player in ipairs(PLAYERS) do
		print(string.format("    P%d: %d", i, player._leaver_absorb_count or 0))
	end

	print("")
	if ready then
		print("  *** SYSTEM READY — run Debug_LeaverConversion_Full() to test ***")
	else
		print("  *** SYSTEM NOT READY — fix issues above first ***")
	end
end

---------------------------------------------------------------------------------------------------
-- COMMAND 3: Stress Test (multi-disconnect)
-- Usage: Debug_LeaverConversion_Stress(2)  — disconnects 2 players sequentially
---------------------------------------------------------------------------------------------------
function Debug_LeaverConversion_Stress(num_disconnects)
	print("")
	print("============================================")
	print("  CBA DEBUG — LEAVER CONVERSION: STRESS TEST")
	print("============================================")

	num_disconnects = num_disconnects or 1

	-- Find alive players to disconnect (pick from highest index first to avoid self-disconnect)
	local targets = {}
	for i = #PLAYERS, 1, -1 do
		if not Core_IsPlayerEliminated(PLAYERS[i].id) then
			-- Don't disconnect local player
			if PLAYERS[i].id ~= Game_GetLocalPlayer() then
				table.insert(targets, i)
			end
		end
	end

	if #targets < num_disconnects then
		print(string.format("[ERROR] Only %d non-local alive players, can't disconnect %d", #targets, num_disconnects))
		return
	end

	local total_issues = 0
	for d = 1, num_disconnects do
		local target_idx = targets[d]
		print("")
		print(string.format("--- DISCONNECT %d/%d: Player %d ---", d, num_disconnects, target_idx))

		local pre_snapshot = _LeaverDebug_Stage1_Snapshot()
		local ok = _LeaverDebug_Stage3_Disconnect(target_idx)
		if ok then
			local issues = _LeaverDebug_Stage4_Validate(pre_snapshot, target_idx)
			total_issues = total_issues + issues
		else
			print("  [FAIL] Disconnect failed")
			total_issues = total_issues + 1
		end
	end

	-- Final audit
	local bp_issues = _LeaverDebug_Stage5_BlueprintAudit()
	total_issues = total_issues + bp_issues

	print("")
	print("=== STRESS TEST COMPLETE ===")
	if total_issues == 0 then
		print(string.format("  *** %d disconnects — ALL CLEAR ***", num_disconnects))
	else
		print(string.format("  *** %d disconnects — %d issue(s) found ***", num_disconnects, total_issues))
	end

	-- Final state dump
	_LeaverDebug_Stage1_Snapshot()
end

---------------------------------------------------------------------------------------------------
-- COMMAND 4: Visual Conversion Test (non-destructive spawn + convert)
-- Spawns buildings and military units near src player's base, then converts them
-- to dst player's civ equivalents. Lets you visually confirm heading, position,
-- blueprint correctness without triggering a full disconnect.
-- Usage: Debug_LeaverConversion_Visual()      — P2→P1
--        Debug_LeaverConversion_Visual(3, 1)  — P3→P1
--        Debug_LeaverConversion_Visual("mongol_ha_gol", "french") — by civ name
---------------------------------------------------------------------------------------------------

-- Test building keys (available in most civs via AGS_ENTITY_TABLE)
-- Organized by category for structured visual verification
_VISUAL_TEST_BUILDINGS_MILITARY = { "barracks", "archery_range", "stable", "siege_workshop" }
_VISUAL_TEST_BUILDINGS_ECONOMY = { "house", "market", "blacksmith", "scar_dock" }
_VISUAL_TEST_BUILDINGS_ADVANCED = { "monastery", "castle" }
_VISUAL_TEST_BUILDINGS_WALLS = { "stone_wall", "palisade_wall", "palisade_gate" }
_VISUAL_TEST_BUILDINGS_LANDMARKS = { "town_center" }
-- Excluded from test: Entity_Kill on these cases triggers deferred engine callbacks and
-- can crash the game after the test completes.
--   wonder_imperial_age: Wonder_OnWonderKilled win-condition path.
--   university / arsenal: age-gated or missing on some civs, so _Convert_Building kills them.

-- Cleanup globals: track entities and squads spawned by the visual test so
-- Debug_LeaverConversion_VisualCleanup() can safely remove them afterward.
_VISUAL_TEST_CLEANUP_EIDS = {}
_VISUAL_TEST_CLEANUP_SQS = {}
_VISUAL_TEST_DEFERRED_CLEANUP = nil
_VISUAL_TEST_CLEANUP_TRACE = true

-- Test military unit patterns (tier_suffix, to be prefixed with unit_<type>_)
-- Covers all standard unit categories; civ-unique units that don't match
-- a suffix swap are handled by _ResolveFallbackSquadBP.
_VISUAL_TEST_UNITS = {
	-- Infantry
	{ name = "spearman",      tier = "1" },
	{ name = "spearman",      tier = "2" },
	{ name = "spearman",      tier = "3" },
	{ name = "manatarms",     tier = "2" },
	{ name = "manatarms",     tier = "3" },
	{ name = "manatarms",     tier = "4" },
	{ name = "landsknecht",   tier = "3" },
	-- Ranged
	{ name = "archer",        tier = "2" },
	{ name = "archer",        tier = "3" },
	{ name = "archer",        tier = "4" },
	{ name = "crossbowman",   tier = "3" },
	{ name = "crossbowman",   tier = "4" },
	{ name = "handcannoneer", tier = "4" },
	-- Cavalry
	{ name = "horseman",      tier = "2" },
	{ name = "horseman",      tier = "3" },
	{ name = "horseman",      tier = "4" },
	{ name = "knight",        tier = "2" },
	{ name = "knight",        tier = "3" },
	{ name = "knight",        tier = "4" },
	-- Siege
	{ name = "springald",     tier = "3" },
	{ name = "mangonel",      tier = "3" },
	{ name = "bombard",       tier = "4" },
	{ name = "trebuchet",     tier = "4_cw" },
	{ name = "culverin",      tier = "4" },
	{ name = "ribauldequin",  tier = "4" },
	-- Support / Other
	{ name = "ram",           tier = "3" },
	{ name = "siege_tower",   tier = "3" },
	{ name = "monk",          tier = "3" },
	{ name = "villager",      tier = "1" },
	{ name = "scout",         tier = "1" },
}

-- Phase state for the visual test.  Set by Debug_LeaverConversion_Visual,
-- consumed by _VisualTest_NextPhase which is scheduled via Rule_AddOneShot.
-- Phasing spreads entity creation across frames so deferred engine callbacks
-- (Conquest_PostConstructionComplete at +0.25 s, etc.) resolve before the next
-- batch of entities is spawned, preventing cumulative D3D/GPU crashes.
_VISUAL_TEST_STATE = nil
_VISUAL_TEST_CIV_OVERRIDE = nil

-- Clamp a position to playable world bounds and snap Y to terrain height.
local function _VisualTest_SafeWorldPos(raw_x, raw_z)
	local world_w = World_GetWidth()
	if world_w == nil or world_w <= 0 then
		return World_Pos(raw_x, World_GetHeightAt(raw_x, raw_z), raw_z)
	end
	local half = world_w * 0.5
	local margin = 30
	local min_v = -half + margin
	local max_v = half - margin
	local x = math.max(min_v, math.min(max_v, raw_x))
	local z = math.max(min_v, math.min(max_v, raw_z))
	return World_Pos(x, World_GetHeightAt(x, z), z)
end

-- Clamp grid base so the full [cols x rows] building layout fits in playable bounds.
local function _VisualTest_SafeGridBase(raw_x, raw_z, cols, spacing_x, total_slots, spacing_z)
	local world_w = World_GetWidth()
	if world_w == nil or world_w <= 0 then
		return _VisualTest_SafeWorldPos(raw_x, raw_z)
	end
	local half = world_w * 0.5
	local margin = 30
	local min_v = -half + margin
	local max_v = half - margin
	local max_col = math.max(0, cols - 1)
	local rows = math.max(1, math.ceil(total_slots / cols))
	local max_row = math.max(0, rows - 1)
	local max_x = max_v - (max_col * spacing_x)
	local max_z = max_v - (max_row * spacing_z)
	local base_x = math.max(min_v, math.min(max_x, raw_x))
	local base_z = math.max(min_v, math.min(max_z, raw_z))
	return _VisualTest_SafeWorldPos(base_x, base_z)
end

-- Internal: process one building-key group using _VISUAL_TEST_STATE.
function _VisualTest_BuildingGroup(category_name, keys)
	local st = _VISUAL_TEST_STATE
	if st == nil then return end
	print("")
	print(string.format("--- %s ---", category_name))
	local ok_count = 0
	local fail_count = 0
	for _, key in ipairs(keys) do
		local col = math.fmod(st.bldg_col, st.bldg_cols)
		local row = math.floor(st.bldg_col / st.bldg_cols)
		local raw_x = st.spawn_base.x + (col * st.bldg_spacing_x)
		local raw_z = st.spawn_base.z + (row * st.bldg_spacing_z)
		local offset_pos = _VisualTest_SafeWorldPos(raw_x, raw_z)
		st.bldg_col = st.bldg_col + 1
		local resolve_ok, src_ebp = pcall(AGS_GetCivilizationEntity, st.src_civ, key)
		if not resolve_ok or src_ebp == nil then
			print(string.format("  [SKIP] %s — no BP for %s", key, st.src_civ))
		else
			local facing = World_Pos(offset_pos.x + 5, offset_pos.y, offset_pos.z)
			-- Age gate: scaffold entity for source side (debug bypass expected)
			_Leaver_MeetsAgeRequirement(BP_GetName(src_ebp), key, st.src.id, "debug_bldg_scaffold")
			local ok_c, eid = pcall(Entity_CreateFacing, src_ebp, st.src.id, offset_pos, facing, true)
			if ok_c and eid ~= nil then
				pcall(Entity_Spawn, eid)
				table.insert(_VISUAL_TEST_CLEANUP_EIDS, eid)
				pcall(Entity_ForceConstruct, eid)
				local conv_ok, result = pcall(_Convert_Building, eid, st.dst, st.dst_civ, st.src_civ, {}, st.src.id)
				if conv_ok then
					local tag = (result == "converted" or result == "transferred") and "OK" or result
					print(string.format("  [%s] %s (%s) → %s", tag, key, BP_GetName(src_ebp), result))
					if result == "converted" or result == "transferred" then ok_count = ok_count + 1 else fail_count = fail_count + 1 end
				else
					print(string.format("  [FAIL] %s — _Convert_Building threw: %s", key, tostring(result)))
					fail_count = fail_count + 1
				end
			else
				print(string.format("  [FAIL] %s — Entity_CreateFacing failed: %s", key, tostring(eid)))
				fail_count = fail_count + 1
			end
		end
	end
	st.total_bldg_ok = st.total_bldg_ok + ok_count
	st.total_bldg_fail = st.total_bldg_fail + fail_count
end

-- Internal: deferred cleanup called via Rule_AddOneShot after phase 4 summary.
-- Processes entities and squads in small batches to avoid GPU stalls.
-- All destruction calls are guarded with alive-checks and pcall for safety.
function _VisualTest_DeferredCleanup()
	-- Move cleanup queues into a deferred state and process in small batches.
	_VISUAL_TEST_DEFERRED_CLEANUP = {
		eids = _VISUAL_TEST_CLEANUP_EIDS,
		squads = _VISUAL_TEST_CLEANUP_SQS,
		eid_i = 1,
		sq_i = 1,
		total_e = #_VISUAL_TEST_CLEANUP_EIDS,
		total_s = #_VISUAL_TEST_CLEANUP_SQS,
		removed_e = 0,
		invalid_e = 0,
		removed_s = 0,
		invalid_s = 0,
		tick = 0,
	}
	if _VISUAL_TEST_CLEANUP_TRACE then
		print(string.format("[VISUAL_CLEANUP] Begin deferred cleanup: entities=%d squads=%d",
			_VISUAL_TEST_DEFERRED_CLEANUP.total_e,
			_VISUAL_TEST_DEFERRED_CLEANUP.total_s))
	end
	_VISUAL_TEST_CLEANUP_EIDS = {}
	_VISUAL_TEST_CLEANUP_SQS = {}
	Rule_AddOneShot(_VisualTest_DeferredCleanupStep, 0.05)
end

function _VisualTest_DeferredCleanupStep()
	local st = _VISUAL_TEST_DEFERRED_CLEANUP
	if st == nil then return end
	st.tick = st.tick + 1

	local max_entities_per_tick = 8
	local max_squads_per_tick = 2

	for _ = 1, max_entities_per_tick do
		if st.eid_i > st.total_e then break end
		local eid = st.eids[st.eid_i]
		if eid ~= nil and Entity_IsAlive(eid) then
			pcall(Entity_Destroy, eid)
			st.removed_e = st.removed_e + 1
		else
			st.invalid_e = st.invalid_e + 1
		end
		st.eid_i = st.eid_i + 1
	end

	for _ = 1, max_squads_per_tick do
		if st.sq_i > st.total_s then break end
		local sq = st.squads[st.sq_i]
		if sq ~= nil and Squad_IsAlive(sq) then
			pcall(Squad_Destroy, sq)
			st.removed_s = st.removed_s + 1
		else
			st.invalid_s = st.invalid_s + 1
		end
		st.sq_i = st.sq_i + 1
	end

	if _VISUAL_TEST_CLEANUP_TRACE and (st.tick % 5 == 0 or (st.eid_i > st.total_e and st.sq_i > st.total_s)) then
		print(string.format("[VISUAL_CLEANUP] tick=%d progress e=%d/%d s=%d/%d",
			st.tick,
			math.max(0, st.eid_i - 1), st.total_e,
			math.max(0, st.sq_i - 1), st.total_s))
	end

	if st.eid_i <= st.total_e or st.sq_i <= st.total_s then
		Rule_AddOneShot(_VisualTest_DeferredCleanupStep, 0.05)
		return
	end

	print(string.format("[VISUAL_CLEANUP] Auto-removed %d/%d entities (invalid=%d), %d/%d squads (invalid=%d).",
		st.removed_e, st.total_e, st.invalid_e,
		st.removed_s, st.total_s, st.invalid_s))
	_VISUAL_TEST_DEFERRED_CLEANUP = nil
end


-- Internal: process military unit conversion in small batches across ticks.
-- Includes a watchdog: if no progress for 5 s, auto-skip to next phase.
function _VisualTest_ProcessUnitBatch()
	local st = _VISUAL_TEST_STATE
	if st == nil then return end
	if st.phase ~= 4 then return end

	-- Watchdog: detect stuck batch processing
	local now = World_GetGameTime()
	if st._watchdog_last_progress == nil then
		st._watchdog_last_progress = now
	end
	if (now - st._watchdog_last_progress) > 5 then
		print("  [TIMEOUT] Unit batch stalled for 5s — skipping to next phase.")
		Rule_AddOneShot(_VisualTest_NextPhase, 0.1)
		return
	end

	local src_prefix = AGS_CIV_PREFIXES[st.src_civ]
	if src_prefix == nil then
		print(string.format("  [ERROR] No AGS_CIV_PREFIXES entry for %s", st.src_civ))
		_VISUAL_TEST_STATE = nil
		_VISUAL_TEST_CIV_OVERRIDE = nil
		return
	end

	local src_suffix = string.sub(src_prefix, 1, -2)
	local unit_idx = st.unit_idx or 1
	local unit_batch_size = st.unit_batch_size or 2
	local last_idx = math.min(#_VISUAL_TEST_UNITS, unit_idx + unit_batch_size - 1)

	for i = unit_idx, last_idx do
		st._watchdog_last_progress = World_GetGameTime()
		local unit = _VISUAL_TEST_UNITS[i]
		local sbp_name = string.format("unit_%s_%s_%s", unit.name, unit.tier, src_suffix)
		local ok_bp, sbp = pcall(BP_GetSquadBlueprint, sbp_name)
		if not ok_bp or sbp == nil then
			print(string.format("  [SKIP] %s — BP not found for %s", sbp_name, st.src_civ))
		else
			local unit_pos = _VisualTest_SafeWorldPos(st.spawn_base.x + (i - 1) * 5, st.spawn_base.z + 25)
			-- Age gate: logs [AGE-BYPASS] (debug bypass enabled at test init)
			_Leaver_MeetsAgeRequirement(sbp_name, nil, st.src.id, "debug_src_spawn")
			local sg_test = SGroup_CreateIfNotFound("sg_debug_visual_test")
			SGroup_Clear(sg_test)
			local ok_sp, sp_err = pcall(Util_CreateSquads, st.src.id, sg_test, sbp, unit_pos, nil, 1)
			if ok_sp and SGroup_Count(sg_test) > 0 then
				local squad = SGroup_GetSquadAt(sg_test, 1)
				local to_sbp = _ResolveMilitarySquadBP(sbp_name, st.src_civ, st.dst_civ)
				if to_sbp ~= nil then
					local to_name = BP_GetName(to_sbp)
					if to_name == sbp_name then
						pcall(Squad_SetPlayerOwner, squad, st.dst.id)
						table.insert(_VISUAL_TEST_CLEANUP_SQS, squad)
						print(string.format("  [OK] %s → same BP (transferred)", sbp_name))
						st.mil_ok = st.mil_ok + 1
					else
						-- Age gate: logs [AGE-BYPASS] (debug bypass enabled at test init)
						_Leaver_MeetsAgeRequirement(to_name, nil, st.dst.id, "debug_dst_convert")
						local sg_new = SGroup_CreateIfNotFound("sg_debug_visual_new")
						SGroup_Clear(sg_new)
						local ok_cn, cn_err = pcall(Util_CreateSquads, st.dst.id, sg_new, to_sbp, unit_pos, nil, 1)
						if ok_cn and SGroup_Count(sg_new) > 0 then
							table.insert(_VISUAL_TEST_CLEANUP_SQS, SGroup_GetSquadAt(sg_new, 1))
							Squad_Destroy(squad)
							print(string.format("  [OK] %s → %s (converted)", sbp_name, to_name))
							st.mil_ok = st.mil_ok + 1
						else
							print(string.format("  [FAIL] %s → %s (create failed: %s)", sbp_name, to_name, tostring(cn_err)))
							pcall(Squad_SetPlayerOwner, squad, st.dst.id)
							table.insert(_VISUAL_TEST_CLEANUP_SQS, squad)
							st.mil_ok = st.mil_ok + 1
						end
					end
				else
					pcall(Squad_Kill, squad)
					print(string.format("  [KILL] %s — no receiver equivalent", sbp_name))
					st.mil_fail = st.mil_fail + 1
				end
			else
				print(string.format("  [FAIL] %s — spawn failed: %s", sbp_name, tostring(sp_err)))
				st.mil_fail = st.mil_fail + 1
			end
		end
	end

	st.unit_idx = last_idx + 1
	if st.unit_idx <= #_VISUAL_TEST_UNITS then
		Rule_AddOneShot(_VisualTest_ProcessUnitBatch, st.unit_batch_delay or 0.2)
		return
	end

	print(string.format("  Military: %d converted, %d killed/failed", st.mil_ok, st.mil_fail))
	-- Restore bypass flags
	_LEAVER_DEBUG_BYPASS_GATES = _VISUAL_TEST_SAVED_BYPASS or false
	_LEAVER_DEBUG_BYPASS_CAPABILITY_GATES = _VISUAL_TEST_SAVED_CAP_BYPASS or false
	print(string.format("  Bypass flags restored: age=%s cap=%s",
		tostring(_LEAVER_DEBUG_BYPASS_GATES), tostring(_LEAVER_DEBUG_BYPASS_CAPABILITY_GATES)))
	Rule_AddOneShot(_VisualTest_NextPhase, 1)
end

-- Internal: phase dispatcher called by Rule_AddOneShot.
--   Phase 1: military-production buildings (4 entities)
--   Phase 2: economy + advanced buildings (6 entities)
--   Phase 3: walls + landmarks (4 entities) + buildings summary
--   Phase 4: military units
--   Phase 5: final summary
function _VisualTest_NextPhase()
	local st = _VISUAL_TEST_STATE
	if st == nil then return end
	st.phase = st.phase + 1

	-- Skip phases not relevant to the current mode
	local mode = st.mode or "all"
	if mode == "u" and st.phase < 4 then
		st.phase = 4
	elseif mode == "b" and st.phase == 4 then
		st.phase = 5
	end

	if st.phase == 1 then
		print("")
		print("=== BUILDING CONVERSION TEST ===")
		_VisualTest_BuildingGroup("MILITARY PRODUCTION", _VISUAL_TEST_BUILDINGS_MILITARY)
		Rule_AddOneShot(_VisualTest_NextPhase, 1.5)

	elseif st.phase == 2 then
		_VisualTest_BuildingGroup("ECONOMY / SUPPORT", _VISUAL_TEST_BUILDINGS_ECONOMY)
		_VisualTest_BuildingGroup("ADVANCED (AGE 3-4)", _VISUAL_TEST_BUILDINGS_ADVANCED)
		Rule_AddOneShot(_VisualTest_NextPhase, 1.5)

	elseif st.phase == 3 then
		_VisualTest_BuildingGroup("WALLS / GATES", _VISUAL_TEST_BUILDINGS_WALLS)
		_VisualTest_BuildingGroup("LANDMARKS / TC", _VISUAL_TEST_BUILDINGS_LANDMARKS)
		print("")
		print(string.format("  Buildings total: %d ok, %d failed/killed", st.total_bldg_ok, st.total_bldg_fail))
		-- Extra gap before unit phase reduces mixed-load pressure in full mode.
		Rule_AddOneShot(_VisualTest_NextPhase, 2.5)

	elseif st.phase == 4 then
		print("")
		print("=== MILITARY UNIT CONVERSION TEST ===")
		st.unit_idx = 1
		st.unit_batch_size = 1
		st.unit_batch_delay = 0.25
		_VisualTest_ProcessUnitBatch()

	elseif st.phase == 5 then
		print("")
		print("=== VISUAL TEST SUMMARY ===")
		local total_ok = st.total_bldg_ok + st.mil_ok
		local total_fail = st.total_bldg_fail + st.mil_fail
		print(string.format("  Total: %d ok, %d failed  (%d buildings + %d units tested)", total_ok, total_fail, st.total_bldg_ok + st.total_bldg_fail, st.mil_ok + st.mil_fail))
		print(string.format("  Buildings owned by P%d [%s] should match %s blueprints.", st.dst_idx, st.dst_civ, st.dst_civ))
		print("  CHECK: building rotation matches original facing (east)")
		print("  CHECK: walls/gates transferred (foreign BP acceptable)")
		print("  CHECK: no precache red-box overlay on converted buildings")
		print("")
		print(string.format("  %d entities, %d squads tracked — auto-cleanup in 0.5s.",
			#_VISUAL_TEST_CLEANUP_EIDS, #_VISUAL_TEST_CLEANUP_SQS))
		_VISUAL_TEST_STATE = nil
		_VISUAL_TEST_CIV_OVERRIDE = nil
		-- Schedule deferred cleanup to let pending callbacks drain first
		Rule_AddOneShot(_VisualTest_DeferredCleanup, 0.5)
	end
end

---------------------------------------------------------------------------------------------------
-- COMMAND: Surrogate Visual Test — spawns entities using arbitrary civ names, converting via
-- _Convert_Building with civ override. Works in ANY match with ≥2 alive players; the first
-- two alive players are auto-selected as surrogates (their actual civs are irrelevant).
-- Usage (console): Debug_LeaverConversion_VisualByCiv("malian", "japanese", "b")
---------------------------------------------------------------------------------------------------
function Debug_LeaverConversion_VisualByCiv(src_civ, dst_civ, mode)
	if _VISUAL_TEST_STATE ~= nil then
		print("[ERROR] Visual test is already running. Wait for it to complete.")
		return
	end

	if src_civ == nil or dst_civ == nil then
		print("[ERROR] Usage: Debug_LeaverConversion_VisualByCiv(\"malian\", \"japanese\", \"b\")")
		return
	end

	-- Validate civ names against AGS_ENTITY_TABLE
	if AGS_ENTITY_TABLE[src_civ] == nil then
		print(string.format("[ERROR] Unknown source civ '%s' — not in AGS_ENTITY_TABLE", src_civ))
		return
	end
	if AGS_ENTITY_TABLE[dst_civ] == nil then
		print(string.format("[ERROR] Unknown receiver civ '%s' — not in AGS_ENTITY_TABLE", dst_civ))
		return
	end

	mode = mode or "all"
	if mode ~= "all" and mode ~= "b" and mode ~= "u" then
		print("[ERROR] Invalid mode '" .. tostring(mode) .. "'. Use 'b' (buildings), 'u' (units), or nil (all).")
		return
	end

	-- Auto-select first two alive players as surrogates
	local surrogate_src = nil
	local surrogate_dst = nil
	local surrogate_src_idx = nil
	local surrogate_dst_idx = nil
	for i, player in ipairs(PLAYERS) do
		local ok, elim = pcall(Core_IsPlayerEliminated, player.id)
		if ok and not elim then
			if surrogate_src == nil then
				surrogate_src = player
				surrogate_src_idx = i
			elseif surrogate_dst == nil then
				surrogate_dst = player
				surrogate_dst_idx = i
				break
			end
		end
	end
	if surrogate_src == nil or surrogate_dst == nil then
		print("[ERROR] Need ≥2 alive players as surrogates")
		return
	end

	print("")
	print("============================================")
	print("  CBA DEBUG — SURROGATE VISUAL CONVERSION")
	print("============================================")
	local mode_label = ({all="all", b="buildings-only", u="units-only"})[mode]
	print(string.format("  Source civ: %s   Receiver civ: %s   Mode: %s", src_civ, dst_civ, mode_label))
	print(string.format("  Surrogates: P%d [%s] as src owner, P%d [%s] as dst owner",
		surrogate_src_idx, Player_GetRaceName(surrogate_src.id),
		surrogate_dst_idx, Player_GetRaceName(surrogate_dst.id)))
	print("  [CIV_OVERRIDE] _Convert_Building will use parameter civs, not player civs")
	print("  (phased — results will appear over ~5 seconds)")

	-- Find spawn area near surrogate source's first entity
	local eg = Player_GetEntities(surrogate_src.id)
	if EGroup_Count(eg) == 0 then
		print("[ERROR] Surrogate source player has no entities to anchor spawn location")
		return
	end
	local anchor = Entity_GetPosition(EGroup_GetEntityAt(eg, 1))
	local bldg_cols = 4
	local bldg_spacing_x = 12
	local bldg_spacing_z = 14
	local total_bldg_slots = #_VISUAL_TEST_BUILDINGS_MILITARY + #_VISUAL_TEST_BUILDINGS_ECONOMY
		+ #_VISUAL_TEST_BUILDINGS_ADVANCED + #_VISUAL_TEST_BUILDINGS_WALLS + #_VISUAL_TEST_BUILDINGS_LANDMARKS
	local spawn_base = _VisualTest_SafeGridBase(anchor.x + 20, anchor.z + 20,
		bldg_cols, bldg_spacing_x, total_bldg_slots, bldg_spacing_z)

	-- Reset cleanup tracking
	_VISUAL_TEST_CLEANUP_EIDS = {}
	_VISUAL_TEST_CLEANUP_SQS = {}

	-- Enable civ override BEFORE initializing state
	_VISUAL_TEST_CIV_OVERRIDE = true

	-- Enable debug bypass so visual test creations log [AGE-BYPASS]/[CAP-BYPASS] instead of blocking
	_VISUAL_TEST_SAVED_BYPASS = _LEAVER_DEBUG_BYPASS_GATES
	_VISUAL_TEST_SAVED_CAP_BYPASS = _LEAVER_DEBUG_BYPASS_CAPABILITY_GATES
	_LEAVER_DEBUG_BYPASS_GATES = true
	_LEAVER_DEBUG_BYPASS_CAPABILITY_GATES = true

	_VISUAL_TEST_STATE = {
		src = surrogate_src,
		dst = surrogate_dst,
		src_civ = src_civ,
		dst_civ = dst_civ,
		src_idx = surrogate_src_idx,
		dst_idx = surrogate_dst_idx,
		spawn_base = spawn_base,
		bldg_col = 0,
		bldg_cols = bldg_cols,
		bldg_spacing_x = bldg_spacing_x,
		bldg_spacing_z = bldg_spacing_z,
		total_bldg_ok = 0,
		total_bldg_fail = 0,
		mil_ok = 0,
		mil_fail = 0,
		phase = 0,
		mode = mode,
	}

	-- Kick off phased execution
	_VisualTest_NextPhase()
end

function Debug_LeaverConversion_Visual(src_idx, dst_idx, mode)
	if _VISUAL_TEST_STATE ~= nil then
		print("[ERROR] Visual test is already running. Wait for it to complete.")
		return
	end

	-- mode: nil/"all" = full test, "b" = buildings only, "u" = units only
	mode = mode or "all"
	if mode ~= "all" and mode ~= "b" and mode ~= "u" then
		print("[ERROR] Invalid mode '" .. tostring(mode) .. "'. Use 'b' (buildings), 'u' (units), or nil (all).")
		return
	end

	print("")
	print("============================================")
	print("  CBA DEBUG — VISUAL CONVERSION TEST")
	print("============================================")

	local function _ResolveVisualPlayerSelector(selector, default_idx, role)
		if selector == nil then selector = default_idx end

		if type(selector) == "number" then
			local idx = selector
			local player = PLAYERS[idx]
			if player == nil then
				return nil, nil, string.format("[ERROR] Invalid %s player index: %s (valid 1-%d)", role, tostring(selector), #PLAYERS)
			end
			return idx, player, nil
		end

		if type(selector) == "string" then
			local wanted = string.lower(selector)
			for idx, player in ipairs(PLAYERS) do
				if not Core_IsPlayerEliminated(player.id) then
					local civ = Player_GetRaceName(player.id)
					if civ ~= nil and string.lower(civ) == wanted then
						return idx, player, nil
					end
				end
			end
			return nil, nil, string.format("[ERROR] No alive player found for %s civ '%s'", role, tostring(selector))
		end

		return nil, nil, string.format("[ERROR] Invalid %s selector type '%s' (use player index or civ string)", role, type(selector))
	end

	local src_err, dst_err
	src_idx, src, src_err = _ResolveVisualPlayerSelector(src_idx, 2, "source")
	dst_idx, dst, dst_err = _ResolveVisualPlayerSelector(dst_idx, 1, "receiver")
	if src_err ~= nil then
		print(src_err)
		return
	end
	if dst_err ~= nil then
		print(dst_err)
		return
	end
	if Core_IsPlayerEliminated(src.id) or Core_IsPlayerEliminated(dst.id) then
		print("[ERROR] Both players must be alive")
		return
	end

	local src_civ = Player_GetRaceName(src.id)
	local dst_civ = Player_GetRaceName(dst.id)
	local mode_label = ({all="all", b="buildings-only", u="units-only"})[mode]
	print(string.format("  Source: P%d [%s]   Receiver: P%d [%s]   Mode: %s", src_idx, src_civ, dst_idx, dst_civ, mode_label))
	print("  (phased — results will appear over ~5 seconds)")

	-- Find a spawn area near src player's first entity
	local eg = Player_GetEntities(src.id)
	if EGroup_Count(eg) == 0 then
		print("[ERROR] Source player has no entities to anchor spawn location")
		return
	end
	local anchor = Entity_GetPosition(EGroup_GetEntityAt(eg, 1))
	local bldg_cols = 4
	local bldg_spacing_x = 12
	local bldg_spacing_z = 14
	local total_bldg_slots = #_VISUAL_TEST_BUILDINGS_MILITARY + #_VISUAL_TEST_BUILDINGS_ECONOMY
		+ #_VISUAL_TEST_BUILDINGS_ADVANCED + #_VISUAL_TEST_BUILDINGS_WALLS + #_VISUAL_TEST_BUILDINGS_LANDMARKS
	local spawn_base = _VisualTest_SafeGridBase(anchor.x + 20, anchor.z + 20,
		bldg_cols, bldg_spacing_x, total_bldg_slots, bldg_spacing_z)

	-- Reset cleanup tracking
	_VISUAL_TEST_CLEANUP_EIDS = {}
	_VISUAL_TEST_CLEANUP_SQS = {}

	-- Initialize phase state
	-- Enable debug bypass so visual test creations log [AGE-BYPASS]/[CAP-BYPASS] instead of blocking
	_VISUAL_TEST_SAVED_BYPASS = _LEAVER_DEBUG_BYPASS_GATES
	_VISUAL_TEST_SAVED_CAP_BYPASS = _LEAVER_DEBUG_BYPASS_CAPABILITY_GATES
	_LEAVER_DEBUG_BYPASS_GATES = true
	_LEAVER_DEBUG_BYPASS_CAPABILITY_GATES = true

	_VISUAL_TEST_STATE = {
		src = src,
		dst = dst,
		src_civ = src_civ,
		dst_civ = dst_civ,
		src_idx = src_idx,
		dst_idx = dst_idx,
		spawn_base = spawn_base,
		bldg_col = 0,
		bldg_cols = bldg_cols,
		bldg_spacing_x = bldg_spacing_x,
		bldg_spacing_z = bldg_spacing_z,
		total_bldg_ok = 0,
		total_bldg_fail = 0,
		mil_ok = 0,
		mil_fail = 0,
		phase = 0,
		mode = mode,
	}

	-- Kick off phased execution
	_VisualTest_NextPhase()
end

-- Visual test cleanup: safely drains all tracked entities/squads using the
-- same deferred batched path as auto-cleanup.
-- Usage (console): Debug_LeaverConversion_VisualCleanup()
---------------------------------------------------------------------------------------------------
function Debug_LeaverConversion_VisualCleanup()
	if _VISUAL_TEST_DEFERRED_CLEANUP ~= nil then
		print("[VISUAL_CLEANUP] Deferred cleanup already in progress.")
		return
	end

	-- Abort any in-flight visual run; pending batch callbacks will no-op once state is nil.
	_VISUAL_TEST_STATE = nil
	_VISUAL_TEST_CIV_OVERRIDE = nil
	-- Restore bypass flags if test was interrupted
	_LEAVER_DEBUG_BYPASS_GATES = _VISUAL_TEST_SAVED_BYPASS or false
	_LEAVER_DEBUG_BYPASS_CAPABILITY_GATES = _VISUAL_TEST_SAVED_CAP_BYPASS or false

	local n_e = #_VISUAL_TEST_CLEANUP_EIDS
	local n_s = #_VISUAL_TEST_CLEANUP_SQS
	if n_e == 0 and n_s == 0 then
		print("[VISUAL_CLEANUP] Nothing to clean.")
		return
	end

	print(string.format("[VISUAL_CLEANUP] Scheduling deferred cleanup for %d entities, %d squads.", n_e, n_s))
	_VisualTest_DeferredCleanup()
end

-- Helper: simulates gate checks for a BP name without modifying audit log.
-- Returns age_tag, cap_tag, exempt strings for annotation (e.g., "AGE-OK", "CAP-BLOCK", "EXEMPT").
function _LeaverDebug_SimulateGates(bp_name, ags_key, player_id)
	local age_tag = "AGE-N/A"
	local cap_tag = "CAP-N/A"
	local exempt = false

	-- Age gate simulation
	if type(_Leaver_MeetsAgeRequirement) == "function" then
		-- Temporarily suppress audit log writes by snapshotting size
		local log_size = #_LEAVER_AUDIT_LOG
		local result = _Leaver_MeetsAgeRequirement(bp_name, ags_key, player_id, "debug_sim")
		-- Remove entries we just added (non-destructive simulation)
		while #_LEAVER_AUDIT_LOG > log_size do
			table.remove(_LEAVER_AUDIT_LOG)
		end
		if result == "ok" then age_tag = "AGE-OK"
		elseif result == "blocked" then
			-- Check spawner-exempt bypass (mirrors live pipeline logic)
			if type(_Leaver_IsSpawnerExemptBP) == "function" and _Leaver_IsSpawnerExemptBP(bp_name) then
				age_tag = "AGE-EXEMPT"
				exempt = true
			else
				age_tag = "AGE-BLOCK"
			end
		elseif result == "bypassed" then age_tag = "AGE-BYPASS"
		end
	end

	-- Capability gate simulation
	if type(_Leaver_MeetsCapabilityRequirement) == "function" then
		local log_size = #_LEAVER_AUDIT_LOG
		local result = _Leaver_MeetsCapabilityRequirement(bp_name, ags_key, player_id, "debug_sim")
		while #_LEAVER_AUDIT_LOG > log_size do
			table.remove(_LEAVER_AUDIT_LOG)
		end
		if result == "ok" then cap_tag = "CAP-OK"
		elseif result == "blocked" then cap_tag = "CAP-BLOCK"
		elseif result == "bypassed" then cap_tag = "CAP-BYPASS"
		end
	end

	return age_tag, cap_tag, exempt
end

---------------------------------------------------------------------------------------------------
-- COMMAND 5: Military Suffix Resolution Test (read-only, no spawning)
-- Prints the suffix swap result for common unit patterns across all civs,
-- annotated with gate outcomes (AGE-OK/BLOCK, CAP-OK/BLOCK) per candidate.
-- Usage: Debug_LeaverConversion_MilResolve(src_idx, dst_idx)
---------------------------------------------------------------------------------------------------
function Debug_LeaverConversion_MilResolve(src_idx, dst_idx)
	print("")
	print("============================================")
	print("  CBA DEBUG — MILITARY SUFFIX RESOLUTION")
	print("============================================")

	src_idx = src_idx or 2
	dst_idx = dst_idx or 1

	local src = PLAYERS[src_idx]
	local dst = PLAYERS[dst_idx]
	if src == nil or dst == nil then
		print(string.format("[ERROR] Invalid player indices: src=%d, dst=%d", src_idx, dst_idx))
		return
	end

	local src_civ = Player_GetRaceName(src.id)
	local dst_civ = Player_GetRaceName(dst.id)
	local dst_age = Player_GetCurrentAge(dst.id)
	print(string.format("  Source: %s → Receiver: %s (age %d)", src_civ, dst_civ, dst_age))

	local src_prefix = AGS_CIV_PREFIXES[src_civ]
	if src_prefix == nil then
		print(string.format("  [ERROR] No prefix for %s", src_civ))
		return
	end
	local src_suffix = string.sub(src_prefix, 1, -2)

	local test_patterns = {
		"unit_spearman_1_", "unit_spearman_2_", "unit_spearman_3_", "unit_spearman_4_",
		"unit_archer_2_", "unit_archer_3_", "unit_archer_4_",
		"unit_horseman_2_", "unit_horseman_3_",
		"unit_knight_2_", "unit_knight_3_", "unit_knight_4_",
		"unit_manatarms_1_", "unit_manatarms_2_", "unit_manatarms_3_", "unit_manatarms_4_",
		"unit_crossbowman_3_", "unit_crossbowman_4_",
		"unit_handcannoneer_4_",
		"unit_ram_3_", "unit_springald_3_", "unit_mangonel_3_",
		"unit_bombard_4_", "unit_trebuchet_4_cw_", "unit_culverin_4_",
		"unit_ribauldequin_4_", "unit_cannon_4_",
		-- Civ-unique patterns (test fallback resolution)
		"unit_gbeto_2_", "unit_gbeto_3_", "unit_gbeto_4_",
		"unit_javelin_3_", "unit_javelin_4_",
		"unit_musofadi_3_",
	}

	local resolved = 0
	local unresolved = 0
	local gate_blocked = 0
	print("")
	for _, pattern in ipairs(test_patterns) do
		local sbp_name = pattern .. src_suffix
		local ok, src_bp = pcall(BP_GetSquadBlueprint, sbp_name)
		if ok and src_bp ~= nil then
			local route = _ResolveMilitaryRoute(sbp_name, src_civ, dst_civ)
			local target_name = route.bp_name or sbp_name
			local age_tag, cap_tag = _LeaverDebug_SimulateGates(target_name, nil, dst.id)
			local gate_suffix = string.format("[%s %s]", age_tag, cap_tag)

			-- Determine handled class (terminal decision bucket)
			local handled_class = "unknown"
			if route.route == "same_bp" then
				handled_class = "transferred"
				print(string.format("  [OK] %s → same_bp %s {%s}", sbp_name, gate_suffix, handled_class))
				resolved = resolved + 1
			elseif route.route == "destroy_policy" then
				handled_class = "killed"
				print(string.format("  [DESTROY] %s → destroy_policy {%s}", sbp_name, handled_class))
				resolved = resolved + 1
			elseif route.route == "destroy_no_mapping" then
				handled_class = "killed"
				print(string.format("  [--] %s → nil (no receiver equivalent) {%s}", sbp_name, handled_class))
				unresolved = unresolved + 1
			elseif route.to_sbp ~= nil then
				local blocked = (age_tag == "AGE-BLOCK" or cap_tag == "CAP-BLOCK")
				if blocked then
					handled_class = "blocked"
				else
					handled_class = "converted"
				end
				local marker = blocked and "GATED" or "OK"
				print(string.format("  [%s] %s → %s (%s, ratio=%.0f%%) %s {%s}",
					marker, sbp_name, route.bp_name, route.route, (route.ratio or 1) * 100, gate_suffix, handled_class))
				resolved = resolved + 1
				if blocked then gate_blocked = gate_blocked + 1 end
			end
		end
	end

	-- Also check the actual squads alive for src player
	print("")
	print("=== LIVE SQUAD RESOLUTION ===")
	local sg = Player_GetSquads(src.id)
	local sc = SGroup_Count(sg)
	local live_resolved = 0
	local live_unresolved = 0
	local live_gate_blocked = 0
	for idx = 1, sc do
		local squad = SGroup_GetSquadAt(sg, idx)
		if squad ~= nil and Squad_IsAlive(squad) then
			local sbp = Squad_GetBlueprint(squad)
			local sbp_name = BP_GetName(sbp)
			local route = _ResolveMilitaryRoute(sbp_name, src_civ, dst_civ)
			local target_name = route.bp_name or sbp_name
			local age_tag, cap_tag = _LeaverDebug_SimulateGates(target_name, nil, dst.id)
			local gate_suffix = string.format("[%s %s]", age_tag, cap_tag)

			local handled_class = "unknown"
			if route.route == "same_bp" then
				handled_class = "transferred"
				print(string.format("  [OK] %s → same_bp %s {%s}", sbp_name, gate_suffix, handled_class))
				live_resolved = live_resolved + 1
			elseif route.route == "destroy_policy" or route.route == "destroy_no_mapping" then
				handled_class = "killed"
				print(string.format("  [--] %s → %s {%s}", sbp_name, route.route, handled_class))
				live_unresolved = live_unresolved + 1
			elseif route.to_sbp ~= nil then
				local blocked = (age_tag == "AGE-BLOCK" or cap_tag == "CAP-BLOCK")
				if blocked then
					handled_class = "blocked"
				else
					handled_class = "converted"
				end
				local marker = blocked and "GATED" or "OK"
				print(string.format("  [%s] %s → %s (%s) %s {%s}", marker, sbp_name, route.bp_name, route.route, gate_suffix, handled_class))
				live_resolved = live_resolved + 1
				if blocked then live_gate_blocked = live_gate_blocked + 1 end
			end
		end
	end

	print("")
	print(string.format("  Pattern test: %d resolved, %d unresolved, %d gate-blocked", resolved, unresolved, gate_blocked))
	print(string.format("  Live squads:  %d resolved, %d unresolved, %d gate-blocked", live_resolved, live_unresolved, live_gate_blocked))
end

---------------------------------------------------------------------------------------------------
-- COMMAND: Cross-Civ Matrix Validation (read-only, no spawning)
-- For each alive source player -> each alive receiver player (directed pairs), resolve
-- military and building candidates and verify every candidate produces an explicit
-- terminal outcome.
-- This is the complete all-player global cross-civ route check in one command.
-- Usage: Debug_LeaverCrossCivMatrix()
--        Debug_LeaverCrossCivMatrix("verbose")
---------------------------------------------------------------------------------------------------
function Debug_LeaverCrossCivMatrix(opt_mode)
	print("")
	print("==============================================")
	print("  CBA DEBUG — CROSS-PLAYER MATRIX (MIL + BLDG)")
	print("==============================================")

	local verbose = (opt_mode == "verbose")
	if type(_LEAVER_AUDIT_LOG) ~= "table" then
		_LEAVER_AUDIT_LOG = {}
	end

	local alive_players = {}
	local loaded_civ_set = {}
	local loaded_civs = {}
	for i, player in ipairs(PLAYERS) do
		local ok, elim = pcall(Core_IsPlayerEliminated, player.id)
		if ok and not elim then
			local civ = Player_GetRaceName(player.id)
			table.insert(alive_players, {
				slot = i,
				id = player.id,
				civ = civ,
			})
			if loaded_civ_set[civ] ~= true then
				loaded_civ_set[civ] = true
				table.insert(loaded_civs, civ)
			end
		end
	end
	table.sort(loaded_civs)

	if #alive_players < 2 then
		print("  [SKIP] Need at least 2 alive players for cross-player matrix")
		return 0
	end

	local expected_cross_routes = #loaded_civs * (#loaded_civs - 1)
	local seen_cross_routes = {}

	print(string.format("  Alive players: %d", #alive_players))
	print(string.format("  Loaded civs: %d (%s)", #loaded_civs, table.concat(loaded_civs, ", ")))

	local mil_issues = 0
	local mil_pair_count = 0
	local mil_cross_civ_pairs = 0
	local mil_same_civ_pairs = 0

	for _, src_info in ipairs(alive_players) do
		local src_civ = src_info.civ
		local src_prefix = AGS_CIV_PREFIXES[src_civ]

		for _, rcv_info in ipairs(alive_players) do
			if src_info.id ~= rcv_info.id then
				local rcv_civ = rcv_info.civ
				mil_pair_count = mil_pair_count + 1
				if src_civ ~= rcv_civ then
					mil_cross_civ_pairs = mil_cross_civ_pairs + 1
					seen_cross_routes[src_civ .. "->" .. rcv_civ] = true
				else
					mil_same_civ_pairs = mil_same_civ_pairs + 1
				end

				if src_prefix == nil then
					mil_issues = mil_issues + 1
					print(string.format("  [FAIL] P%d(%s)->P%d(%s): source civ missing AGS_CIV_PREFIXES entry",
						src_info.slot, src_civ, rcv_info.slot, rcv_civ))
					goto continue_rcv
				end
				local src_suffix = string.sub(src_prefix, 1, -2)

			local pair_total = 0
			local pair_resolved = 0
			local pair_destroyed = 0
			local pair_gate_blocked = 0
			local pair_unhandled = 0
			local unhandled_bps = {}

			for _, pattern in ipairs(_MIL_COVERAGE_PATTERNS) do
				local sbp_name = pattern .. src_suffix
				local ok_bp, src_bp = pcall(BP_GetSquadBlueprint, sbp_name)
				if ok_bp and src_bp ~= nil then
					pair_total = pair_total + 1
					local route = _ResolveMilitaryRoute(sbp_name, src_civ, rcv_civ)

					if route.route == "same_bp" then
						pair_resolved = pair_resolved + 1
					elseif route.route == "destroy_policy" then
						pair_destroyed = pair_destroyed + 1
					elseif route.route == "destroy_no_mapping" then
						pair_destroyed = pair_destroyed + 1
					elseif route.to_sbp ~= nil then
						-- Check gates (SimulateGates returns AGE-EXEMPT for spawner-exempt BPs)
						local target_name = route.bp_name or sbp_name
						local age_tag, cap_tag, exempt = _LeaverDebug_SimulateGates(target_name, nil, rcv_info.id)
						if (age_tag == "AGE-BLOCK" or cap_tag == "CAP-BLOCK") and not exempt then
							pair_gate_blocked = pair_gate_blocked + 1
						end
						pair_resolved = pair_resolved + 1
					else
						-- No terminal decision: unhandled candidate
						pair_unhandled = pair_unhandled + 1
						table.insert(unhandled_bps, sbp_name)
					end
				end
			end

			local pair_handled = pair_resolved + pair_destroyed
			local pair_marker = (pair_unhandled > 0) and "FAIL" or "OK"
			if pair_unhandled > 0 then
				mil_issues = mil_issues + pair_unhandled
			end

			if verbose or pair_unhandled > 0 then
				print(string.format("  [%s] P%d(%s)->P%d(%s): total=%d handled=%d (resolved=%d destroyed=%d gate_blocked=%d) unhandled=%d",
					pair_marker, src_info.slot, src_civ, rcv_info.slot, rcv_civ, pair_total, pair_handled,
					pair_resolved, pair_destroyed, pair_gate_blocked, pair_unhandled))
				if pair_unhandled > 0 then
					for _, bp in ipairs(unhandled_bps) do
						print(string.format("    [UNHANDLED] %s", bp))
					end
				end
			end

			end
			::continue_rcv::
		end
	end

	print("")
	print(string.format("  MIL player pairs checked: %d (cross-civ=%d same-civ=%d)", mil_pair_count, mil_cross_civ_pairs, mil_same_civ_pairs))
	local seen_cross_count = 0
	for _ in pairs(seen_cross_routes) do seen_cross_count = seen_cross_count + 1 end
	print(string.format("  MIL unique cross-civ routes covered: %d/%d", seen_cross_count, expected_cross_routes))
	if mil_issues == 0 then
		print(string.format("  *** MIL MATRIX PASS: %d pairs, 0 unhandled candidates ***", mil_pair_count))
	else
		print(string.format("  *** MIL MATRIX FAIL: %d pairs, %d unhandled candidates ***", mil_pair_count, mil_issues))
	end

	print("")
	print("----------------------------------------------")
	print("  BUILDING MATRIX")
	print("----------------------------------------------")

	local bldg_issues = 0
	local bldg_pair_count = 0
	local bldg_cross_civ_pairs = 0
	local bldg_same_civ_pairs = 0

	for _, src_info in ipairs(alive_players) do
		local src_civ = src_info.civ
		local src_table = AGS_ENTITY_TABLE[src_civ]
		if src_table == nil and AGS_CIV_PARENT_MAP[src_civ] ~= nil then
			src_table = AGS_ENTITY_TABLE[AGS_CIV_PARENT_MAP[src_civ]]
		end

		for _, rcv_info in ipairs(alive_players) do
			if src_info.id ~= rcv_info.id then
				local rcv_civ = rcv_info.civ
				bldg_pair_count = bldg_pair_count + 1
				if src_civ ~= rcv_civ then
					bldg_cross_civ_pairs = bldg_cross_civ_pairs + 1
				else
					bldg_same_civ_pairs = bldg_same_civ_pairs + 1
				end

				if src_table == nil then
					bldg_issues = bldg_issues + 1
					print(string.format("  [FAIL] P%d(%s)->P%d(%s): source civ has no AGS entity table",
						src_info.slot, src_civ, rcv_info.slot, rcv_civ))
					goto continue_rcv_bldg
				end

			local pair_total = 0
			local pair_converted = 0
			local pair_blocked = 0
			local pair_killed = 0
			local pair_unhandled = 0
			local pair_tc_house = 0
			local unhandled_keys = {}

			for ags_key, attrib in pairs(src_table) do
				if type(attrib) ~= "string" or string.sub(attrib, 1, 9) ~= "building_" then
					goto continue_key
				end
				pair_total = pair_total + 1
				if ags_key == AGS_BP_TC or ags_key == AGS_BP_HOUSE then
					pair_tc_house = pair_tc_house + 1
				end

				local resolved_key = ags_key
				local resolve_ok, to_bp = pcall(AGS_GetCivilizationEntity, rcv_civ, ags_key)
				if (not resolve_ok or to_bp == nil) and AGS_CIV_PARENT_MAP[rcv_civ] ~= nil
					and not AGS_CivTableHasExplicitFalse(rcv_civ, ags_key) then
					resolve_ok, to_bp = pcall(AGS_GetCivilizationEntity, AGS_CIV_PARENT_MAP[rcv_civ], ags_key)
				end
				if (not resolve_ok or to_bp == nil) and AGS_BUILDING_FALLBACK_MAP ~= nil then
					local fb_key = AGS_BUILDING_FALLBACK_MAP[ags_key]
					if fb_key ~= nil then
						resolved_key = fb_key
						resolve_ok, to_bp = pcall(AGS_GetCivilizationEntity, rcv_civ, fb_key)
						if (not resolve_ok or to_bp == nil) and AGS_CIV_PARENT_MAP[rcv_civ] ~= nil
							and not AGS_CivTableHasExplicitFalse(rcv_civ, fb_key) then
							resolve_ok, to_bp = pcall(AGS_GetCivilizationEntity, AGS_CIV_PARENT_MAP[rcv_civ], fb_key)
						end
					end
				end

				if not resolve_ok or to_bp == nil then
					pair_killed = pair_killed + 1
					goto continue_key
				end

				local _is_pop_ags = (ags_key == AGS_BP_HOUSE or ags_key == AGS_BP_TC
					or ags_key == AGS_BP_TC_CAPITAL or ags_key == AGS_BP_TC_LANDMARK)
				local _is_pop_resolved = (resolved_key == AGS_BP_HOUSE or resolved_key == AGS_BP_TC
					or resolved_key == AGS_BP_TC_CAPITAL or resolved_key == AGS_BP_TC_LANDMARK)
				if _mod ~= nil and _mod.pop_cap_incease_on_interval ~= nil
					and _mod.pop_cap_incease_on_interval ~= 0 and (_is_pop_ags or _is_pop_resolved) then
					pair_blocked = pair_blocked + 1
					goto continue_key
				end

				local bp_name = BP_GetName(to_bp)
				local age_tag, cap_tag = _LeaverDebug_SimulateGates(bp_name, resolved_key, rcv_info.id)
				if age_tag == "AGE-BLOCK" or cap_tag == "CAP-BLOCK" then
					pair_blocked = pair_blocked + 1
				elseif bp_name ~= nil then
					pair_converted = pair_converted + 1
				else
					pair_unhandled = pair_unhandled + 1
					table.insert(unhandled_keys, tostring(ags_key))
				end

				::continue_key::
			end

			local pair_handled = pair_converted + pair_blocked + pair_killed
			if pair_handled ~= pair_total then
				pair_unhandled = pair_unhandled + (pair_total - pair_handled)
			end
			if pair_unhandled > 0 then
				bldg_issues = bldg_issues + pair_unhandled
			end

			if verbose or pair_unhandled > 0 then
				local marker = (pair_unhandled > 0) and "FAIL" or "OK"
				print(string.format("  [%s] P%d(%s)->P%d(%s): total=%d handled=%d (conv/xfer=%d blocked=%d killed=%d tc_house=%d) unhandled=%d",
					marker, src_info.slot, src_civ, rcv_info.slot, rcv_civ, pair_total, pair_handled,
					pair_converted, pair_blocked, pair_killed, pair_tc_house, pair_unhandled))
				if pair_unhandled > 0 then
					for _, key in ipairs(unhandled_keys) do
						print(string.format("    [UNHANDLED] key=%s", key))
					end
				end
			end

			end
			::continue_rcv_bldg::
	end
	end

	print("")
	print(string.format("  BLDG player pairs checked: %d (cross-civ=%d same-civ=%d)", bldg_pair_count, bldg_cross_civ_pairs, bldg_same_civ_pairs))
	if bldg_issues == 0 then
		print(string.format("  *** BLDG MATRIX PASS: %d pairs, 0 unhandled candidates ***", bldg_pair_count))
	else
		print(string.format("  *** BLDG MATRIX FAIL: %d pairs, %d unhandled candidates ***", bldg_pair_count, bldg_issues))
	end

	local total_issues = mil_issues + bldg_issues
	print("")
	if total_issues == 0 then
		print("  *** CROSS-CIV MATRIX OVERALL PASS ***")
	else
		print(string.format("  *** CROSS-CIV MATRIX OVERALL FAIL: %d issue(s) ***", total_issues))
	end

	return total_issues
end

---------------------------------------------------------------------------------------------------
-- Comprehensive military unit BP prefix list for coverage audits.
-- Each pattern is appended with the civ suffix to form a full SBP name.
-- Patterns that don't exist for a given src civ are silently skipped.
---------------------------------------------------------------------------------------------------
_MIL_COVERAGE_PATTERNS = {
	-- Standard archetypes (suffix-swappable across most civs)
	"unit_spearman_1_", "unit_spearman_2_", "unit_spearman_3_", "unit_spearman_4_",
	"unit_archer_2_", "unit_archer_3_", "unit_archer_4_",
	"unit_horseman_2_", "unit_horseman_3_", "unit_horseman_4_",
	"unit_knight_2_", "unit_knight_3_", "unit_knight_4_",
	"unit_manatarms_2_", "unit_manatarms_3_", "unit_manatarms_4_",
	"unit_crossbowman_3_", "unit_crossbowman_4_",
	"unit_handcannoneer_4_",
	"unit_landsknecht_3_",
	"unit_springald_3_", "unit_mangonel_3_", "unit_bombard_4_",
	"unit_trebuchet_4_cw_", "unit_culverin_4_", "unit_ribauldequin_4_",
	"unit_ram_3_", "unit_siege_tower_3_",
	"unit_monk_3_", "unit_villager_1_", "unit_scout_1_",
	-- Malian unique
	"unit_gbeto_2_", "unit_gbeto_3_", "unit_gbeto_4_",
	"unit_javelin_3_", "unit_javelin_4_",
	"unit_musofadi_3_",
	"unit_donso_2_", "unit_donso_3_",
	-- English unique
	"unit_longbowman_2_", "unit_longbowman_3_", "unit_longbowman_4_",
	-- Chinese unique
	"unit_palace_guard_3_", "unit_palace_guard_4_",
	"unit_fire_lancer_4_",
	"unit_zhuge_nu_2_", "unit_zhuge_nu_3_",
	"unit_nest_of_bees_4_",
	"unit_grenadier_4_",
	-- Mongol unique
	"unit_mangudai_3_", "unit_mangudai_4_",
	"unit_keshik_2_", "unit_keshik_3_",
	"unit_khan_1_",
	-- Rus unique
	"unit_streltsy_4_",
	"unit_horse_archer_3_", "unit_horse_archer_4_",
	"unit_warrior_monk_3_",
	-- Ottoman unique
	"unit_janissary_3_", "unit_janissary_4_",
	"unit_sipahi_3_", "unit_sipahi_4_",
	"unit_great_bombard_4_",
	"unit_mehter_3_",
	-- Abbasid unique
	"unit_camel_archer_3_", "unit_camel_archer_4_",
	"unit_camel_rider_3_", "unit_camel_rider_4_",
	-- Sultanate unique
	"unit_war_elephant_4_",
	"unit_tower_elephant_4_",
	"unit_ghulam_3_", "unit_ghulam_4_",
	-- Byzantine unique
	"unit_cataphract_3_", "unit_cataphract_4_",
	"unit_limitanei_2_", "unit_limitanei_3_",
	"unit_varangian_guard_4_",
	-- Japanese unique
	"unit_samurai_3_", "unit_samurai_4_",
	"unit_onna_musha_3_",
	"unit_mounted_samurai_3_",
	"unit_ozutsu_4_",
	-- Heroes (should be policy=destroy)
	"unit_jeanne_1_", "unit_jeanne_2_", "unit_jeanne_3_", "unit_jeanne_4_",
	"unit_abbey_king_2_",
	"unit_wynguard_ranger_4_", "unit_wynguard_footman_4_",
}

---------------------------------------------------------------------------------------------------
-- COMMAND: Military Coverage Pair — per-unit suffix-swap + policy audit for one src→rcv pair.
-- Works in ANY match (reads AGS_CIV_PREFIXES + _LEAVER_CIV_UNIQUE_FALLBACK + BP engine).
-- Usage (console): Debug_LeaverMilCoverage_Pair("malian", "japanese")
---------------------------------------------------------------------------------------------------
function Debug_LeaverMilCoverage_Pair(src_civ, rcv_civ)
	if src_civ == nil or rcv_civ == nil then
		print("[ERROR] Usage: Debug_LeaverMilCoverage_Pair(\"malian\", \"japanese\")")
		return
	end

	local src_prefix = AGS_CIV_PREFIXES[src_civ]
	local rcv_prefix = AGS_CIV_PREFIXES[rcv_civ]
	if src_prefix == nil then
		print(string.format("[ERROR] Unknown source civ '%s' — not in AGS_CIV_PREFIXES", src_civ))
		return
	end
	if rcv_prefix == nil then
		print(string.format("[ERROR] Unknown receiver civ '%s' — not in AGS_CIV_PREFIXES", rcv_civ))
		return
	end

	print("")
	print("==============================================")
	print(string.format("  CBA DEBUG — MIL COVERAGE: %s → %s", src_civ, rcv_civ))
	print("==============================================")

	local src_suffix = string.sub(src_prefix, 1, -2)
	local totals = { swap = 0, archetype = 0, destroy = 0, remap = 0, destroy_final = 0, skip = 0 }

	for _, pattern in ipairs(_MIL_COVERAGE_PATTERNS) do
		local sbp_name = pattern .. src_suffix
		local ok_bp, sbp = pcall(BP_GetSquadBlueprint, sbp_name)
		if not ok_bp or sbp == nil then
			totals.skip = totals.skip + 1
		else
			-- Tier 1: direct suffix swap
			local to_sbp = _ResolveMilitarySquadBP(sbp_name, src_civ, rcv_civ)
			if to_sbp ~= nil then
				print(string.format("  [OK]        %-36s → %s", sbp_name, BP_GetName(to_sbp)))
				totals.swap = totals.swap + 1
			else
				-- Tier 2: civ-unique policy
				local policy = _Leaver_GetCivUniquePolicy(sbp_name)
				if policy == "archetype" then
					local fb_sbp, fb_ratio = _ResolveFallbackSquadBP(sbp_name, rcv_civ)
					if fb_sbp ~= nil then
						print(string.format("  [ARCHETYPE] %-36s → %s (ratio=%.0f%%)", sbp_name, BP_GetName(fb_sbp), (fb_ratio or 1) * 100))
					else
						print(string.format("  [ARCHETYPE] %-36s → target BP missing for %s", sbp_name, rcv_civ))
					end
					totals.archetype = totals.archetype + 1
				elseif policy == "destroy" then
					print(string.format("  [DESTROY]   %-36s — killed on transfer", sbp_name))
					totals.destroy = totals.destroy + 1
				else
					-- Tier 3: receiver-side class fallback
					local rcv_bp, rcv_ratio, rcv_policy = _ResolveReceiverClassFallback(sbp_name, rcv_civ)
					if rcv_bp ~= nil then
						print(string.format("  [REMAP]     %-36s → %s (ratio=%.0f%%)", sbp_name, BP_GetName(rcv_bp), (rcv_ratio or 1) * 100))
						totals.remap = totals.remap + 1
					elseif rcv_policy == "destroy" then
						print(string.format("  [DESTROY]   %-36s — receiver policy destroy", sbp_name))
						totals.destroy = totals.destroy + 1
					else
						print(string.format("  [DESTROY-FINAL] %-36s — no conversion path", sbp_name))
						totals.destroy_final = totals.destroy_final + 1
					end
				end
			end
		end
	end

	local tested = totals.swap + totals.archetype + totals.destroy + totals.remap + totals.destroy_final
	print("")
	print("=== PAIR TOTALS ===")
	print(string.format("  Tested: %d (skipped %d patterns not in %s)", tested, totals.skip, src_civ))
	print(string.format("  suffix-swap=%d  archetype=%d  destroy=%d  remap=%d  destroy-final=%d",
		totals.swap, totals.archetype, totals.destroy, totals.remap, totals.destroy_final))
	if totals.destroy_final > 0 then
		print(string.format("  FAIL: %d units have no conversion path (must map or add override)", totals.destroy_final))
	else
		print("  PASS: all units resolved via suffix-swap, policy, archetype, or class-remap")
	end
end

---------------------------------------------------------------------------------------------------
-- COMMAND: Military Coverage All Pairs — exhaustive civ×civ audit.
-- Reports per-pair summary and global totals. opt_mode="detail" prints per-unit lines.
-- Usage (console): Debug_LeaverMilCoverage_AllPairs()
-- Usage (detail):  Debug_LeaverMilCoverage_AllPairs("detail")
---------------------------------------------------------------------------------------------------
function Debug_LeaverMilCoverage_AllPairs(opt_mode)
	print("")
	print("==============================================")
	print("  CBA DEBUG — ALL-CIV MILITARY COVERAGE AUDIT")
	print("==============================================")

	local show_detail = (opt_mode == "detail")
	_LEAVER_DEBUG_MIL_COVERAGE_RUN_COUNTER = _LEAVER_DEBUG_MIL_COVERAGE_RUN_COUNTER + 1
	local run_id = _LEAVER_DEBUG_MIL_COVERAGE_RUN_COUNTER
	local mode = opt_mode or "default"
	print(string.format("[LEAVER_DEBUG][MIL_COVERAGE][RUN %d] START mode=%s", run_id, mode))

	local civs = {}
	for civ_name, _ in pairs(AGS_CIV_PREFIXES) do
		table.insert(civs, civ_name)
	end
	table.sort(civs)

	local global = { swap = 0, archetype = 0, destroy = 0, remap = 0, destroy_final = 0, total = 0, pairs = 0 }
	local worst_pairs = {}

	for _, src_civ in ipairs(civs) do
		local src_prefix = AGS_CIV_PREFIXES[src_civ]
		local src_suffix = string.sub(src_prefix, 1, -2)

		for _, rcv_civ in ipairs(civs) do
			if src_civ == rcv_civ then goto continue_rcv end

			local pair = { swap = 0, archetype = 0, destroy = 0, remap = 0, destroy_final = 0 }
			local destroy_final_names = {}

			for _, pattern in ipairs(_MIL_COVERAGE_PATTERNS) do
				local sbp_name = pattern .. src_suffix
				local ok_bp, sbp = pcall(BP_GetSquadBlueprint, sbp_name)
				if ok_bp and sbp ~= nil then
					local to_sbp = _ResolveMilitarySquadBP(sbp_name, src_civ, rcv_civ)
					if to_sbp ~= nil then
						pair.swap = pair.swap + 1
						if show_detail then
							print(string.format("  %s→%s [OK]        %s → %s", src_civ, rcv_civ, sbp_name, BP_GetName(to_sbp)))
						end
					else
						local policy = _Leaver_GetCivUniquePolicy(sbp_name)
						if policy == "archetype" then
							pair.archetype = pair.archetype + 1
							if show_detail then
								local fb_sbp, fb_ratio = _ResolveFallbackSquadBP(sbp_name, rcv_civ)
								local fb_label = fb_sbp ~= nil and BP_GetName(fb_sbp) or "target-miss"
								print(string.format("  %s→%s [ARCHETYPE] %s → %s", src_civ, rcv_civ, sbp_name, fb_label))
							end
						elseif policy == "destroy" then
							pair.destroy = pair.destroy + 1
							if show_detail then
								print(string.format("  %s→%s [DESTROY]   %s", src_civ, rcv_civ, sbp_name))
							end
						else
							-- Try class fallback
							local rcv_bp, rcv_ratio, rcv_policy = _ResolveReceiverClassFallback(sbp_name, rcv_civ)
							if rcv_bp ~= nil then
								pair.remap = pair.remap + 1
								if show_detail then
									print(string.format("  %s→%s [REMAP]     %s → %s", src_civ, rcv_civ, sbp_name, BP_GetName(rcv_bp)))
								end
							elseif rcv_policy == "destroy" then
								pair.destroy = pair.destroy + 1
								if show_detail then
									print(string.format("  %s→%s [DESTROY]   %s (receiver policy)", src_civ, rcv_civ, sbp_name))
								end
							else
								pair.destroy_final = pair.destroy_final + 1
								table.insert(destroy_final_names, sbp_name)
								if show_detail then
									print(string.format("  %s→%s [DESTROY-FINAL] %s", src_civ, rcv_civ, sbp_name))
								end
							end
						end
					end
				end
			end

			local pair_total = pair.swap + pair.archetype + pair.destroy + pair.remap + pair.destroy_final
			global.swap = global.swap + pair.swap
			global.archetype = global.archetype + pair.archetype
			global.destroy = global.destroy + pair.destroy
			global.remap = global.remap + pair.remap
			global.destroy_final = global.destroy_final + pair.destroy_final
			global.total = global.total + pair_total
			global.pairs = global.pairs + 1

			if pair.destroy_final > 0 then
				table.insert(worst_pairs, {
					src = src_civ, rcv = rcv_civ,
					destroy_final = pair.destroy_final,
					names = destroy_final_names,
				})
				if not show_detail then
					print(string.format("  %s→%-20s swap=%d arch=%d dest=%d remap=%d destroy-final=%d [%s]",
						src_civ, rcv_civ,
						pair.swap, pair.archetype, pair.destroy, pair.remap, pair.destroy_final,
						table.concat(destroy_final_names, ", ")))
				end
			end

			::continue_rcv::
		end
	end

	table.sort(worst_pairs, function(a, b) return a.destroy_final > b.destroy_final end)

	print("")
	print("=== GLOBAL TOTALS ===")
	print(string.format("  Pairs tested: %d (%d civs)", global.pairs, #civs))
	print(string.format("  Total unit lookups: %d", global.total))
	print(string.format("  suffix-swap: %d (%.1f%%)", global.swap, global.total > 0 and (global.swap / global.total * 100) or 0))
	print(string.format("  archetype:   %d (%.1f%%)", global.archetype, global.total > 0 and (global.archetype / global.total * 100) or 0))
	print(string.format("  destroy:     %d (%.1f%%)", global.destroy, global.total > 0 and (global.destroy / global.total * 100) or 0))
	print(string.format("  remap:       %d (%.1f%%)", global.remap, global.total > 0 and (global.remap / global.total * 100) or 0))
	print(string.format("  destroy-final: %d (%.1f%%)", global.destroy_final, global.total > 0 and (global.destroy_final / global.total * 100) or 0))

	if #worst_pairs > 0 then
		print("")
		print("=== WORST PAIRS (top 10) ===")
		for i = 1, math.min(10, #worst_pairs) do
			local p = worst_pairs[i]
			print(string.format("  #%d %s→%s: %d destroy-final [%s]",
				i, p.src, p.rcv, p.destroy_final,
				table.concat(p.names, ", ")))
		end
	end

	if global.destroy_final == 0 then
		print("")
		print("  PASS: all military units across all pairs resolved via suffix-swap or explicit policy")
	else
		print("")
		print(string.format("  FAIL: %d destroy-final unit outcomes across %d pairs — add receiver-class remaps or explicit destroy policy", global.destroy_final, #worst_pairs))
	end

	print(string.format("=== AUDIT COMPLETE: %d civs, %d pairs ===", #civs, global.pairs))
	local result = (global.destroy_final == 0) and "PASS" or "FAIL"
	print(string.format("[LEAVER_DEBUG][MIL_COVERAGE][RUN %d] COMPLETE result=%s destroy_final=%d pairs=%d", run_id, result, global.destroy_final, global.pairs))
end

---------------------------------------------------------------------------------------------------
-- Legacy commands (backward-compatible wrappers)
---------------------------------------------------------------------------------------------------

function Debug_ForceDisconnect(player_idx)
	if player_idx == nil then
		print("[DEBUG_LEAVER] Usage: Debug_ForceDisconnect(player_index)")
		return
	end
	_LeaverDebug_Stage3_Disconnect(player_idx)
end

function Debug_LeaverValidation()
	print("")
	print("============================================")
	print("  CBA DEBUG — LEAVER VALIDATION (LEGACY)")
	print("============================================")

	local issues = 0

	-- Check all eliminated players for orphaned entities
	for i, player in ipairs(PLAYERS) do
		local ok, elim = pcall(Core_IsPlayerEliminated, player.id)
		if ok and elim then
			local eg = Player_GetEntities(player.id)
			local count = EGroup_Count(eg)
			if count > 0 then
				print(string.format("  [WARN] Eliminated Player %d still has %d entities", i, count))
				issues = issues + 1
			else
				print(string.format("  [OK] Eliminated Player %d has 0 entities", i))
			end
		end
	end

	-- Check building-limit consistency for alive players
	for i, player in ipairs(PLAYERS) do
		local ok, elim = pcall(Core_IsPlayerEliminated, player.id)
		if ok and not elim then
			local counted = player.obj_buildingLimit_count or 0
			if counted < 0 then
				print(string.format("  [WARN] Player %d has negative building count: %d", i, counted))
				issues = issues + 1
			end
			local siege = player.siegeLimit_count or 0
			if siege < 0 then
				print(string.format("  [WARN] Player %d has negative siege count: %d", i, siege))
				issues = issues + 1
			end
		end
	end

	print("")
	if issues == 0 then
		print("  LEAVER VALIDATION: ALL CLEAR")
	else
		print(string.format("  LEAVER VALIDATION: %d issue(s) found", issues))
	end
end

function Debug_TransferValidation(src_idx, dst_idx)
	if src_idx == nil or dst_idx == nil then
		print("[DEBUG_LEAVER] Usage: Debug_TransferValidation(src_index, dst_index)")
		return
	end

	local src = PLAYERS[src_idx]
	local dst = PLAYERS[dst_idx]
	if src == nil or dst == nil then
		print("[DEBUG_LEAVER] Invalid player indices")
		return
	end

	print(string.format("[DEBUG_LEAVER] Transfer validation: Player %d -> Player %d", src_idx, dst_idx))
	local ok_rel, rel = pcall(Player_ObserveRelationship, src.id, dst.id)
	print(string.format("  Same team: %s", tostring(ok_rel and rel == R_ALLY)))

	local ok_elim, src_eliminated = pcall(Core_IsPlayerEliminated, src.id)
	print(string.format("  Source eliminated: %s", tostring(ok_elim and src_eliminated)))

	local dst_bl = dst.obj_buildingLimit_count or 0
	local max_bl = CBA_Options_GetPlayerProdLimit(dst)
	print(string.format("  Dest building count: %d/%d", dst_bl, max_bl))
	print(string.format("  Dest siege count: %d/%d", dst.siegeLimit_count or 0, AGS_GLOBAL_SETTINGS.MaximumMedicPopulation or 0))
	print(string.format("  Source entities: %d", EGroup_Count(Player_GetEntities(src.id))))
	print(string.format("  Dest entities: %d", EGroup_Count(Player_GetEntities(dst.id))))
end

function Debug_ForceAnnihilation(player_idx)
	if player_idx == nil then
		print("[DEBUG_LEAVER] Usage: Debug_ForceAnnihilation(player_index)")
		return
	end
	local player = PLAYERS[player_idx]
	if player == nil then
		print(string.format("[DEBUG_LEAVER] PLAYERS[%d] is nil", player_idx))
		return
	end
	if Core_IsPlayerEliminated(player.id) then
		print(string.format("[DEBUG_LEAVER] Player %d already eliminated", player_idx))
		return
	end
	print(string.format("[DEBUG_LEAVER] Forcing annihilation for Player %d", player_idx))
	local eg = Player_GetEntities(player.id)
	print(string.format("  Killing %d entities...", EGroup_Count(eg)))
	EGroup_DestroyAllEntities(eg)
	local sg = Player_GetSquads(player.id)
	print(string.format("  Killing %d squads...", SGroup_Count(sg)))
	SGroup_DestroyAllSquads(sg)
	print("  Annihilation complete.")
end

function Debug_GetLeaverBalanceState()
	print("")
	print("[DEBUG_LEAVER] Post-Leaver Balance State:")
	local alive_players = 0
	local alive_teams = {}
	for i, player in ipairs(PLAYERS) do
		local ok, elim = pcall(Core_IsPlayerEliminated, player.id)
		if ok and not elim then
			alive_players = alive_players + 1
			local ok2, team = pcall(Player_GetTeam, player.id)
			if ok2 then
				alive_teams[team] = (alive_teams[team] or 0) + 1
			end
		end
	end
	print(string.format("  Alive players: %d / %d", alive_players, #PLAYERS))
	for team, count in pairs(alive_teams) do
		print(string.format("  Team %d: %d alive", team, count))
	end
end

---------------------------------------------------------------------------------------------------
-- Best-Ally Candidate Dump
-- Shows which player would be chosen by Mod_FindBestAlly for each alive non-eliminated player,
-- including Human/AI label and ranking values, to verify human-priority selection.
-- Console: Debug_GetBestAllyInfo()
---------------------------------------------------------------------------------------------------

function Debug_GetBestAllyInfo()
	print("")
	print("[DEBUG_LEAVER] Best-Ally Candidate Dump:")
	print("  (Ranking: Human > AI, then lowest pop, then lowest absorb)")
	print("")
	for i, player in ipairs(PLAYERS) do
		local ok_e, elim = pcall(Core_IsPlayerEliminated, player.id)
		if ok_e and elim then goto continue_outer end
		print(string.format("  --- If P%d (%s) were to leave: ---", i, _Debug_GetPlayerCiv and _Debug_GetPlayerCiv(player) or tostring(i)))
		local candidates = {}
		for j, ally in ipairs(PLAYERS) do
			if ally.id ~= player.id and not Core_IsPlayerEliminated(ally.id)
				and Player_ObserveRelationship(ally.id, player.id) == R_ALLY then
				local ok_h, is_human = pcall(Player_IsHuman, ally.id)
				if not ok_h then is_human = false end
				local ok_p, pop = pcall(Player_GetCurrentPopulation, ally.id, CT_Personnel)
				if not ok_p then pop = -1 end
				local absorb = ally._leaver_absorb_count or 0
				local civ = _Debug_GetPlayerCiv and _Debug_GetPlayerCiv(ally) or tostring(j)
				table.insert(candidates, { idx=j, civ=civ, is_human=is_human, pop=pop, absorb=absorb })
			end
		end
		-- Sort: human first, then pop, then absorb
		table.sort(candidates, function(a, b)
			if a.is_human ~= b.is_human then return a.is_human end
			if a.pop ~= b.pop then return a.pop < b.pop end
			return a.absorb < b.absorb
		end)
		if #candidates == 0 then
			print("    (no eligible allies)")
		else
			for rank, c in ipairs(candidates) do
				local type_label = c.is_human and "Human" or "AI   "
				local selected = (rank == 1) and " <-- SELECTED" or ""
				print(string.format("    [%d] P%d (%s) %s  pop=%d  absorb=%d%s",
					rank, c.idx, c.civ, type_label, c.pop, c.absorb, selected))
			end
		end
		print("")
		::continue_outer::
	end
end

---------------------------------------------------------------------------------------------------
-- Full System Validation — One-shot console command
-- Runs leaver conversion + all subsystem checks in a single pass.
-- Console: Debug_FullSystemValidation(player_idx)
---------------------------------------------------------------------------------------------------

_LEAVER_DEBUG_FULLSYS_PENDING = nil

function _LeaverDebug_FullSystemValidateLimitsUI()
	print("")
	print("=== STAGE 8: LIMITS UI CONSISTENCY ===")

	if AGS_LIMITS_UI_CONTEXT == nil then
		print("  [SKIP] Limits UI context is nil — skipping UI validation")
		return -1
	end
	if not AGS_LIMITS_UI_CONTEXT.is_ui_created or AGS_LIMITS_UI_CONTEXT.data_context == nil then
		print("  [SKIP] Limits UI not created for this client — skipping UI validation")
		return -1
	end

	local ok_idx, player_idx = pcall(World_GetPlayerIndex, AGS_GET_LOCAL_PLAYER)
	if not ok_idx or player_idx == nil or PLAYERS[player_idx] == nil then
		print("  [SKIP] Local player could not be resolved — skipping UI validation")
		return -1
	end

	local player = PLAYERS[player_idx]
	local ok_elim, elim = pcall(Core_IsPlayerEliminated, player.id)
	if ok_elim and elim then
		print(string.format("  [SKIP] Local player P%d eliminated — skipping UI validation", player_idx))
		return -1
	end

	pcall(AGS_LimitsUI_Update)

	local issues = 0
	local dc = AGS_LIMITS_UI_CONTEXT.data_context
	print(string.format("  Local player: P%d [%s]", player_idx, Player_GetRaceName(player.id)))

	for _, def in ipairs(AGS_LIMITS_UI_ROW_DEFS) do
		local prefix = def.prefix
		local ok_active, active = pcall(def.is_active)
		local expected_visible = ok_active and active or false
		local actual_visible = dc[prefix .. "_visible"] == true

		if actual_visible ~= expected_visible then
			print(string.format("  [FAIL] UI row '%s' visible=%s expected=%s",
				def.key, tostring(actual_visible), tostring(expected_visible)))
			issues = issues + 1
		elseif expected_visible then
			local expected_cur = def.get_current(player) or 0
			local expected_max = def.get_max(player) or 0
			local expected_counter = tostring(expected_cur) .. " / " .. tostring(expected_max)
			local actual_counter = tostring(dc[prefix .. "_counter"] or "")
			if actual_counter ~= expected_counter then
				print(string.format("  [FAIL] UI row '%s' counter='%s' expected='%s'",
					def.key, actual_counter, expected_counter))
				issues = issues + 1
			else
				print(string.format("  [OK] UI row '%s' = %s", def.key, expected_counter))
			end
		else
			print(string.format("  [OK] UI row '%s' hidden", def.key))
		end
	end

	return issues
	end

---------------------------------------------------------------------------------------------------
-- Stage 4b: Wall Ownership Audit (post-transfer)
-- Verifies no defense structures remain world-owned or victim-owned after transfer.
---------------------------------------------------------------------------------------------------
function _LeaverDebug_Stage4b_WallOwnershipAudit(victim_id)
	print("")
	print("=== STAGE 4b: WALL OWNERSHIP AUDIT ===")
	local issues = 0

	-- Scan all alive, non-eliminated players for defense entities they received
	local recipient_walls = 0
	for i, player in ipairs(PLAYERS) do
		local ok, elim = pcall(Core_IsPlayerEliminated, player.id)
		if ok and not elim then
			local eg = Player_GetEntities(player.id)
			local ec = EGroup_Count(eg)
			for idx = 1, ec do
				local ent = EGroup_GetEntityAt(eg, idx)
				if ent ~= nil then
					local bp_ok, bp = pcall(Entity_GetBlueprint, ent)
					if bp_ok and bp ~= nil then
						local name_ok, bp_name = pcall(BP_GetName, bp)
						if name_ok and bp_name ~= nil then
							if string.find(bp_name, "defense_wall") or string.find(bp_name, "palisade")
								or string.find(bp_name, "defense_tower") or string.find(bp_name, "defense_keep") then
								recipient_walls = recipient_walls + 1
							end
						end
					end
				end
			end
		end
	end
	print(string.format("  Defense structures on alive players: %d", recipient_walls))

	-- Check that the victim has no remaining defense entities
	if victim_id ~= nil then
		local victim_eg = Player_GetEntities(victim_id)
		local victim_ec = EGroup_Count(victim_eg)
		local victim_walls = 0
		for idx = 1, victim_ec do
			local ent = EGroup_GetEntityAt(victim_eg, idx)
			if ent ~= nil then
				local bp_ok, bp = pcall(Entity_GetBlueprint, ent)
				if bp_ok and bp ~= nil then
					local name_ok, bp_name = pcall(BP_GetName, bp)
					if name_ok and bp_name ~= nil then
						if string.find(bp_name, "defense_wall") or string.find(bp_name, "palisade")
							or string.find(bp_name, "defense_tower") or string.find(bp_name, "defense_keep") then
							victim_walls = victim_walls + 1
						end
					end
				end
			end
		end
		if victim_walls > 0 then
			print(string.format("  [FAIL] Victim still owns %d defense structure(s) — transfer failed", victim_walls))
			issues = issues + victim_walls
		else
			print("  [OK] Victim has 0 defense structures")
		end
	end

	print(string.format("  [OK] Wall ownership audit complete (%d total on alive players)", recipient_walls))
	return issues
end

function _LeaverDebug_FullSystemFinalize()
	local ctx = _LEAVER_DEBUG_FULLSYS_PENDING
	if ctx == nil then return end

	-- Wait for deferred pipeline to finish
	if _leaver_transfer_state ~= nil then
		Rule_AddOneShot(_LeaverDebug_FullSystemFinalize, 0)
		return
	end

	-- Game-over guard: if all non-victim players are eliminated, validation context is invalid.
	local alive_count = 0
	for i, player in ipairs(PLAYERS) do
		if i ~= ctx.disconnected_idx then
			local ok, elim = pcall(Core_IsPlayerEliminated, player.id)
			if ok and not elim then
				alive_count = alive_count + 1
			end
		end
	end
	local game_over_invalidated = (alive_count == 0)
	if game_over_invalidated then
		print("")
		print("[WARNING] Game-over detected — all non-victim players are eliminated.")
		print("          Validation context is INVALIDATED. All remaining stages will be marked SKIP.")
		print("          Re-run targeting an AI player (not the local human) to get valid results.")
		ctx.stage_issues["4_PostDisconnect"] = -1
		ctx.stage_issues["4b_WallOwnership"] = -1
		ctx.stage_issues["5_BlueprintAudit"] = -1
		ctx.stage_issues["7_TransferStats"] = -1
		ctx.stage_issues["8_LimitsUI"] = -1
		ctx.stage_issues["9_SiegeCrossVal"] = -1
		ctx.stage_issues["9b_HouseGuard"] = -1

		-- Jump directly to summary
		local elapsed = 0
		local ok_gt, gt = pcall(World_GetGameTime)
		if ok_gt and gt and ctx.start_time then elapsed = gt - ctx.start_time end

		print("")
		print("=== STAGE 10: FULL SYSTEM SUMMARY ===")
		print(string.format("  Total elapsed (including deferred wait): %.2fs", elapsed))
		local subsystems = { "2_ReverseMap", "4_PostDisconnect", "4b_WallOwnership", "5_BlueprintAudit", "7_TransferStats", "8_LimitsUI", "9_SiegeCrossVal", "9b_HouseGuard" }
		for _, key in ipairs(subsystems) do
			local count = ctx.stage_issues[key] or 0
			if count == -1 then
				print(string.format("  [SKIP] %s: invalidated by game-over", key))
			else
				local status = count == 0 and "PASS" or "FAIL"
				print(string.format("  [%s] %s: %d issue(s)", status, key, count))
			end
		end
		print("")
		print("  >>> FULL SYSTEM VALIDATION: INVALIDATED (game-over) <<<")
		_LEAVER_DEBUG_FULLSYS_PENDING = nil
		return
	end

	-- Compute elapsed time
	local elapsed = 0
	local ok_gt, gt = pcall(World_GetGameTime)
	if ok_gt and gt and ctx.start_time then
		elapsed = gt - ctx.start_time
	end

	print("")
	print("=== FULL SYSTEM VALIDATION: POST-TRANSFER ===")

	-- Stage 4: Post-disconnect validation (existing)
	ctx.stage_issues["4_PostDisconnect"] = _LeaverDebug_Stage4_Validate(ctx.pre_snapshot, ctx.disconnected_idx)

	-- Stage 4b: Wall ownership audit
	local victim_player = PLAYERS[ctx.disconnected_idx]
	local victim_id_for_audit = victim_player ~= nil and victim_player.id or nil
	ctx.stage_issues["4b_WallOwnership"] = _LeaverDebug_Stage4b_WallOwnershipAudit(victim_id_for_audit)

	-- Stage 5: Blueprint audit (existing)
	ctx.stage_issues["5_BlueprintAudit"] = _LeaverDebug_Stage5_BlueprintAudit()

	-- Stage 7: Transfer Stats + Timing
	local stage7_issues = 0
	print("")
	print("=== STAGE 7: TRANSFER STATS + TIMING ===")
	if _leaver_last_transfer_stats ~= nil then
		local ts = _leaver_last_transfer_stats
		print(string.format("  Pipeline: %s → %s  |  elapsed=%.2fs  |  %d ent + %d sq",
			tostring(ts.src_civ), tostring(ts.rcv_civ), ts.elapsed or 0, ts.entity_total or 0, ts.squad_total or 0))
		print(string.format("  Buildings: conv=%d xfer=%d kill=%d dead=%d silent=%d pop_house=%d pop_tc=%d  |  Eco: xfer=%d kill=%d  |  Mil: conv=%d kill=%d fb=%d fb_skip=%d",
			ts.bldg_converted or 0, ts.bldg_transferred or 0, ts.bldg_killed or 0,
			ts.bldg_skipped_dead or 0, ts.bldg_silent_skip or 0, ts.bldg_killed_autopop_house or 0, ts.bldg_killed_autopop_tc or 0,
			ts.eco_transferred or 0, ts.eco_killed or 0, ts.mil_converted or 0, ts.mil_killed or 0,
			ts.mil_fallback or 0, ts.mil_fallback_skipped or 0))
		print(string.format("  Recipient pop bonus: +%d (disabled path expected 0; team-wide bonus handled separately)", ts.pop_bonus or 0))
		if (ts.elapsed or 0) > 5 then
			print(string.format("  [WARN] Pipeline took >5s (%.2fs) — may need batch size increase", ts.elapsed))
			stage7_issues = stage7_issues + 1
		else
			print(string.format("  [OK] Pipeline time %.2fs", ts.elapsed or 0))
		end
	else
		print("  [WARN] No transfer stats available (_leaver_last_transfer_stats is nil)")
		stage7_issues = stage7_issues + 1
	end

	-- Resource deltas
	print("")
	print("  --- Resource Deltas ---")
	for i, player in ipairs(PLAYERS) do
		local ok, elim = pcall(Core_IsPlayerEliminated, player.id)
		if ok and not elim and ctx.pre_snapshot[i] ~= nil then
			local pre = ctx.pre_snapshot[i]
			local food = Player_GetResource(player.id, RT_Food)
			local wood = Player_GetResource(player.id, RT_Wood)
			local gold = Player_GetResource(player.id, RT_Gold)
			local stone = Player_GetResource(player.id, RT_Stone)
			local df = math.floor(food - (pre.food or 0))
			local dw = math.floor(wood - (pre.wood or 0))
			local dg = math.floor(gold - (pre.gold or 0))
			local ds = math.floor(stone - (pre.stone or 0))
			if df ~= 0 or dw ~= 0 or dg ~= 0 or ds ~= 0 then
				print(string.format("  P%d [%s] res delta: F%+d W%+d G%+d S%+d", i, pre.civ, df, dw, dg, ds))
			end
		end
	end

	-- Limit cap deltas
	print("")
	print("  --- Limit Cap Deltas ---")
	for i, player in ipairs(PLAYERS) do
		local ok, elim = pcall(Core_IsPlayerEliminated, player.id)
		if ok and not elim and ctx.pre_snapshot[i] ~= nil then
			local pre = ctx.pre_snapshot[i]
			local prod_lim = CBA_Options_GetPlayerProdLimit(player)
			local ws_lim = CBA_Options_GetPlayerWorkshopLimit(player)
			local op_lim = CBA_Options_GetPlayerOutpostLimit(player)
			local siege_lim = CBA_Options_GetPlayerSiegeLimit(player)
			local ram_lim = CBA_Options_GetPlayerRamLimit(player)
			local st_lim = CBA_Options_GetPlayerSiegeTowerLimit(player)
			local cap = Player_GetCurrentPopulationCap(player.id, CT_Personnel)

			local pop_delta = cap - (pre.cap or 0)
			print(string.format("  P%d [%s] pop_cap=%d(%+d) prod=%d ws=%d op=%d siege=%d ram=%d st=%d",
				i, pre.civ, cap, pop_delta, prod_lim, ws_lim, op_lim, siege_lim, ram_lim, st_lim))
		end
	end

	ctx.stage_issues["7_TransferStats"] = stage7_issues

	ctx.stage_issues["8_LimitsUI"] = _LeaverDebug_FullSystemValidateLimitsUI()

	-- Stage 9: Siege Limit Cross-Validation (calls existing inspector function)
	local stage9_issues = 0
	print("")
	print("=== STAGE 9: SIEGE LIMIT CROSS-VALIDATION ===")
	local ok_siege, siege_result = pcall(Debug_SiegeLimitCrossValidation)
	if ok_siege then
		print("  [OK] Siege cross-validation completed")
	else
		print(string.format("  [FAIL] Siege cross-validation error: %s", tostring(siege_result)))
		stage9_issues = stage9_issues + 1
	end
	ctx.stage_issues["9_SiegeCrossVal"] = stage9_issues

	-- Stage 9b: Auto-Pop House Guard (only when auto-pop is active)
	if _mod ~= nil and _mod.pop_cap_incease_on_interval ~= nil and _mod.pop_cap_incease_on_interval ~= 0 then
		print("")
		print("=== STAGE 9b: AUTO-POP HOUSE GUARD ===")
		local ok_hg, hg_result = pcall(Debug_AutoPopHouseGuard)
		if ok_hg then
			ctx.stage_issues["9b_HouseGuard"] = hg_result or 0
		else
			print(string.format("  [FAIL] House guard inspector error: %s", tostring(hg_result)))
			ctx.stage_issues["9b_HouseGuard"] = 1
		end
	else
		print("")
		print("=== STAGE 9b: AUTO-POP HOUSE GUARD (SKIPPED — auto-pop inactive) ===")
		ctx.stage_issues["9b_HouseGuard"] = -1
	end

	-- Stage 10: Per-Subsystem Summary
	print("")
	print("=== STAGE 10: FULL SYSTEM SUMMARY ===")
	print(string.format("  Total elapsed (including deferred wait): %.2fs", elapsed))
	local grand_total = 0
	local skipped_count = 0
	local subsystems = { "2_ReverseMap", "4_PostDisconnect", "4b_WallOwnership", "5_BlueprintAudit", "7_TransferStats", "8_LimitsUI", "9_SiegeCrossVal", "9b_HouseGuard" }
	for _, key in ipairs(subsystems) do
		local count = ctx.stage_issues[key] or 0
		if count == -1 then
			print(string.format("  [SKIP] %s: skipped", key))
			skipped_count = skipped_count + 1
		else
			grand_total = grand_total + count
			local status = count == 0 and "PASS" or "FAIL"
			print(string.format("  [%s] %s: %d issue(s)", status, key, count))
		end
	end
	print("")
	if grand_total == 0 and skipped_count == 0 then
		print("  >>> FULL SYSTEM VALIDATION: ALL CLEAR <<<")
	elseif grand_total == 0 and skipped_count > 0 then
		print(string.format("  >>> FULL SYSTEM VALIDATION: ALL CLEAR (%d stage(s) skipped) <<<", skipped_count))
	else
		print(string.format("  >>> FULL SYSTEM VALIDATION: %d TOTAL ISSUE(S) (%d skipped) <<<", grand_total, skipped_count))
	end

	_LEAVER_DEBUG_FULLSYS_PENDING = nil
end

---------------------------------------------------------------------------------------------------
-- Debug_FullSystemValidation(player_idx)
-- Single console command for complete runtime validation across all subsystems.
-- Runs: snapshot → reverse map → disconnect → deferred wait → post-validate → blueprint audit
	--       → transfer stats/timing → resource/pop/limit deltas → UI check → siege cross-val → summary
---------------------------------------------------------------------------------------------------
function Debug_FullSystemValidation(player_idx)
	print("")
	print("============================================================")
	print("  CBA DEBUG — FULL SYSTEM VALIDATION")
	print("  Branch: onslaught-v3.4")
	print("============================================================")

	player_idx = player_idx or 2

	if PLAYERS[player_idx] == nil then
		print(string.format("[ERROR] PLAYERS[%d] is nil — valid range is 1-%d", player_idx, #PLAYERS))
		return
	end
	if Core_IsPlayerEliminated(PLAYERS[player_idx].id) then
		print(string.format("[ERROR] Player %d already eliminated — pick another", player_idx))
		return
	end
	-- Reject local human player as victim: Core_SetPlayerDefeated on the local player triggers
	-- Core_WinnerlessGameOver, eliminating ALL players and invalidating all subsequent validation.
	if PLAYERS[player_idx].id == localPlayer.id then
		print("[ERROR] Cannot validate local player — game-over will invalidate all results.")
		print("        Use an AI player index instead (e.g., Debug_FullSystemValidation(3))")
		return
	end

	-- Capture timing start
	local ok_gt, gt = pcall(World_GetGameTime)
	local start_time = (ok_gt and gt) or 0

	local stage_issues = {}

	-- Stage 1: Baseline snapshot (includes limits, resources, pop caps)
	local pre_snapshot = _LeaverDebug_Stage1_Snapshot()

	-- Augment snapshot with limit caps for delta tracking
	for i, player in ipairs(PLAYERS) do
		if pre_snapshot[i] ~= nil then
			pre_snapshot[i].prod_lim = CBA_Options_GetPlayerProdLimit(player)
			pre_snapshot[i].ws_lim = CBA_Options_GetPlayerWorkshopLimit(player)
			pre_snapshot[i].op_lim = CBA_Options_GetPlayerOutpostLimit(player)
			pre_snapshot[i].siege_lim = CBA_Options_GetPlayerSiegeLimit(player)
			pre_snapshot[i].ram_lim = CBA_Options_GetPlayerRamLimit(player)
			pre_snapshot[i].st_lim = CBA_Options_GetPlayerSiegeTowerLimit(player)
		end
	end

	-- Stage 2: Reverse map validation
	stage_issues["2_ReverseMap"] = _LeaverDebug_Stage2_ReverseMap()

	-- Stage 3: Execute disconnect
	local ok = _LeaverDebug_Stage3_Disconnect(player_idx)
	if not ok then
		print("[ABORT] Disconnect failed — cannot continue validation")
		return
	end

	-- Defer remaining validation until deferred pipeline completes
	_LEAVER_DEBUG_FULLSYS_PENDING = {
		pre_snapshot = pre_snapshot,
		disconnected_idx = player_idx,
		stage_issues = stage_issues,
		start_time = start_time,
	}
	print("  Waiting for deferred conversion pipeline to complete...")
	Rule_AddOneShot(_LeaverDebug_FullSystemFinalize, 0)
end

---------------------------------------------------------------------------------------------------
-- Debug_FullValidation_All(player_idx, mode)
-- Single-command orchestrated pass:
--   1) Leaver conversion full test (Stages 1-6, now including building reconciliation)
--   2) Cross-civ matrix (military + building)
--   3) House-guard verification
-- Usage:
--   Debug_FullValidation_All()
--   Debug_FullValidation_All(2)
--   Debug_FullValidation_All(2, "verbose")
---------------------------------------------------------------------------------------------------
function Debug_FullValidation_All(player_idx, mode)
	player_idx = player_idx or 2
	local opt_mode = "full_validation_all"
	if mode == "verbose" then
		opt_mode = "full_validation_all_verbose"
	end
	print("")
	print("============================================================")
	print("  CBA DEBUG — FULL VALIDATION ALL")
	print("  Includes: leaver full + matrix (mil+bldg) + house guard")
	print("============================================================")
	Debug_LeaverConversion_Full(player_idx, opt_mode)
end

---------------------------------------------------------------------------------------------------
-- PERFORMANCE DEBUG: Per-transfer timing report
-- Prints the phase_timings and annihilation cascade count from the last completed transfer.
-- Usage: Debug_LeaverPerformance()
---------------------------------------------------------------------------------------------------
function Debug_LeaverPerformance()
	print("")
	print("============================================================")
	print("  CBA DEBUG — LEAVER PERFORMANCE REPORT")
	print("============================================================")
	local s = _leaver_last_transfer_stats
	if s == nil then
		print("  [INFO] No completed transfer stats available. Run a disconnect first.")
		return
	end
	print(string.format("  Transfer: %s → %s", tostring(s.src_civ), tostring(s.rcv_civ)))
	print(string.format("  Totals: %d entities + %d squads", s.entity_total or 0, s.squad_total or 0))
	print(string.format("  Elapsed: %.3fs", s.elapsed or 0))
	local pt = s.phase_timings or {}
	-- Compute individual phase durations from absolute timestamps
	if pt.phase3_end and pt.phase45_end and pt.phase7_end then
		-- phase3 = phase3_end - start_time (not stored directly in stats, use total - others)
		local p45_dur = pt.phase45_end - pt.phase3_end
		local p7_dur = pt.phase7_end - pt.phase45_end
		local p3_dur = s.elapsed - p45_dur - p7_dur
		print(string.format("  Phase 3 (buildings):  %.3fs", p3_dur))
		print(string.format("  Phase 4+5 (squads):   %.3fs", p45_dur))
		print(string.format("  Phase 7 (enforcement): %.3fs", p7_dur))
	else
		print("  [WARN] Phase timings not available (transfer may predate instrumentation)")
	end
	print(string.format("  Annihilation cascade checks: %d", s.annihilation_cascade or -1))
	print(string.format("  Results: bldg[conv=%d xfer=%d kill=%d] eco[xfer=%d kill=%d] mil[conv=%d kill=%d]",
		s.bldg_converted or 0, s.bldg_transferred or 0, s.bldg_killed or 0,
		s.eco_transferred or 0, s.eco_killed or 0,
		s.mil_converted or 0, s.mil_killed or 0))
	print(string.format("  Rules paused during transfer: %s", tostring(_LEAVER_RULES_PAUSED ~= nil)))
end

---------------------------------------------------------------------------------------------------
-- PERFORMANCE DEBUG: 6-Player Cascade Test
-- Disconnects up to 6 AI players sequentially, collecting per-transfer timing after each.
-- Each transfer is fully deferred — waits for pipeline completion before starting next.
-- Usage: Debug_LeaverPerformance_6Player()
--        Debug_LeaverPerformance_6Player(4)  — disconnect only 4 players
---------------------------------------------------------------------------------------------------
_LEAVER_PERF_CASCADE = nil

function _LeaverPerf_CascadeNext()
	local ctx = _LEAVER_PERF_CASCADE
	if ctx == nil then return end

	-- Wait for any active pipeline to finish
	if _leaver_transfer_state ~= nil then
		Rule_AddOneShot(_LeaverPerf_CascadeNext, 0)
		return
	end

	-- Collect stats from the last completed transfer (if any)
	if ctx.current_disconnect > 0 and _leaver_last_transfer_stats ~= nil then
		local s = _leaver_last_transfer_stats
		table.insert(ctx.results, {
			player_idx = ctx.targets[ctx.current_disconnect],
			elapsed = s.elapsed or 0,
			phase_timings = s.phase_timings or {},
			entity_total = s.entity_total or 0,
			squad_total = s.squad_total or 0,
			annihilation_cascade = s.annihilation_cascade or 0,
		})
		print(string.format("  [%d/%d] P%d completed in %.3fs (%d ent + %d sq, cascade=%d)",
			ctx.current_disconnect, ctx.total,
			ctx.targets[ctx.current_disconnect],
			s.elapsed or 0, s.entity_total or 0, s.squad_total or 0, s.annihilation_cascade or 0))
	end

	-- Start next disconnect
	ctx.current_disconnect = ctx.current_disconnect + 1
	if ctx.current_disconnect > ctx.total then
		-- All done — print summary
		_LeaverPerf_CascadeSummary()
		return
	end

	local target_idx = ctx.targets[ctx.current_disconnect]
	local player = PLAYERS[target_idx]
	if player == nil or Core_IsPlayerEliminated(player.id) then
		print(string.format("  [SKIP] P%d already eliminated", target_idx))
		Rule_AddOneShot(_LeaverPerf_CascadeNext, 0)
		return
	end

	print(string.format("  --- Disconnecting P%d (%s) [%d/%d] ---",
		target_idx, Player_GetRaceName(player.id), ctx.current_disconnect, ctx.total))
	Core_SetPlayerDefeated(player.id, nil, WR_ELIMINATION)
	Rule_AddOneShot(_LeaverPerf_CascadeNext, 0)
end

function _LeaverPerf_CascadeSummary()
	local ctx = _LEAVER_PERF_CASCADE
	if ctx == nil then return end

	print("")
	print("=== PERFORMANCE CASCADE SUMMARY ===")
	local total_elapsed = 0
	local total_ents = 0
	local total_squads = 0
	local total_cascade = 0
	for i, r in ipairs(ctx.results) do
		total_elapsed = total_elapsed + r.elapsed
		total_ents = total_ents + r.entity_total
		total_squads = total_squads + r.squad_total
		total_cascade = total_cascade + r.annihilation_cascade
		local pt = r.phase_timings
		local p3, p45, p7 = -1, -1, -1
		if pt.phase3_end and pt.phase45_end and pt.phase7_end then
			p45 = pt.phase45_end - pt.phase3_end
			p7 = pt.phase7_end - pt.phase45_end
			p3 = r.elapsed - p45 - p7
		end
		print(string.format("  P%d: %.3fs total (P3=%.3f P4+5=%.3f P7=%.3f) %d ent + %d sq, cascade=%d",
			r.player_idx, r.elapsed, p3, p45, p7, r.entity_total, r.squad_total, r.annihilation_cascade))
	end
	print(string.format("  TOTAL: %.3fs elapsed, %d entities, %d squads, %d annihilation checks",
		total_elapsed, total_ents, total_squads, total_cascade))
	if #ctx.results > 0 then
		print(string.format("  AVG:   %.3fs per transfer", total_elapsed / #ctx.results))
	end
	_LEAVER_PERF_CASCADE = nil
end

function Debug_LeaverPerformance_6Player(count)
	print("")
	print("============================================================")
	print("  CBA DEBUG — LEAVER PERFORMANCE: CASCADE TEST")
	print("============================================================")

	count = count or 6
	local local_id = Game_GetLocalPlayer()

	-- Find alive AI targets (highest index first)
	local targets = {}
	for i = #PLAYERS, 1, -1 do
		if not Core_IsPlayerEliminated(PLAYERS[i].id) and PLAYERS[i].id ~= local_id then
			table.insert(targets, i)
		end
	end

	if #targets < count then
		print(string.format("[WARN] Only %d non-local alive players, reducing to %d", #targets, #targets))
		count = #targets
	end
	if count == 0 then
		print("[ERROR] No alive AI players to disconnect")
		return
	end

	-- Trim to requested count
	while #targets > count do table.remove(targets) end

	print(string.format("  Cascading %d disconnects: %s", count, table.concat(targets, ", ")))
	print(string.format("  Annihilation cascade counter at start: %d", _LEAVER_PERF_ANNIHILATION_CHECKS or 0))

	_LEAVER_PERF_CASCADE = {
		targets = targets,
		total = count,
		current_disconnect = 0,
		results = {},
	}
	_LeaverPerf_CascadeNext()
end

---------------------------------------------------------------------------------------------------
-- PERFORMANCE DEBUG: Leaver Pipeline Status
-- Prints current pipeline state and rule pause status.
-- Usage: Debug_LeaverPipelineStatus()
---------------------------------------------------------------------------------------------------
function Debug_LeaverPipelineStatus()
	print("")
	print("=== LEAVER PIPELINE STATUS ===")
	if _leaver_transfer_state ~= nil then
		local st = _leaver_transfer_state
		print(string.format("  ACTIVE: phase=%s victim=%s→%s | bldg_idx=%d sq_idx=%d enforce_idx=%d",
			tostring(st.phase), tostring(st.src_civ), tostring(st.rcv_civ),
			st.bldg_idx or -1, st.squad_idx or -1, st.enforce_idx or -1))
		if st.enforce_subphase then
			print(string.format("  Enforce sub-phase: %d/3", st.enforce_subphase))
		end
	else
		print("  IDLE: no active transfer")
	end
	print(string.format("  Rules paused: %s", tostring(_LEAVER_RULES_PAUSED or false)))
	print(string.format("  Annihilation cascade counter: %d", _LEAVER_PERF_ANNIHILATION_CHECKS or 0))
	if _leaver_last_transfer_stats ~= nil then
		local s = _leaver_last_transfer_stats
		print(string.format("  Last transfer: %s→%s elapsed=%.3fs ent=%d sq=%d cascade=%d",
			tostring(s.src_civ), tostring(s.rcv_civ), s.elapsed or 0,
			s.entity_total or 0, s.squad_total or 0, s.annihilation_cascade or 0))
	end
end

---------------------------------------------------------------------------------------------------
-- COMMAND: All-Civ Building Coverage Audit (read-only, no spawning)
-- Iterates every sender→receiver civ pair and dry-runs building key resolution.
-- Reports coverage quality per pair: exact, parent fallback, lossy fallback, unresolved.
--
-- Usage:
--   Debug_LeaverCoverage_AllCivPairs()          — audit all pairs, buildings only
--   Debug_LeaverCoverage_AllCivPairs("summary") — one-line-per-pair summary
--   Debug_LeaverCoverage_Civ("byzantine")       — single sender civ vs all receivers
---------------------------------------------------------------------------------------------------

function Debug_LeaverCoverage_AllCivPairs(opt_mode)
	print("")
	print("==============================================")
	print("  CBA DEBUG — ALL-CIV BUILDING COVERAGE AUDIT")
	print("==============================================")

	if _BLUEPRINT_REVERSE_MAP == nil or next(_BLUEPRINT_REVERSE_MAP) == nil then
		print("  [FAIL] _BLUEPRINT_REVERSE_MAP is empty — run after match start")
		return
	end

	local summary_only = (opt_mode == "summary")
	local civs = {}
	for civ_name, tbl in pairs(AGS_ENTITY_TABLE) do
		if civ_name ~= "neutral" and type(tbl) == "table" then
			table.insert(civs, civ_name)
		end
	end
	table.sort(civs)

	local global_totals = {exact = 0, parent = 0, lossy = 0, unresolved = 0, total = 0}
	local worst_pairs = {}

	for _, src_civ in ipairs(civs) do
		local src_table = AGS_ENTITY_TABLE[src_civ]
		if src_table == nil then goto continue_src end

		for _, rcv_civ in ipairs(civs) do
			if src_civ == rcv_civ then goto continue_rcv end

			local pair_totals = {exact = 0, parent = 0, lossy = 0, unresolved = 0}
			local unresolved_keys = {}

			for ags_key, attrib in pairs(src_table) do
				if type(attrib) ~= "string" then goto continue_key end
				-- Skip non-building entries (units, resources)
				if string.sub(attrib, 1, 9) ~= "building_" then goto continue_key end

				-- Tier 1: direct receiver table lookup
				local quality = nil
				local rcv_bp = _LeaverCoverage_TryResolve(rcv_civ, ags_key)
				if rcv_bp ~= nil then
					quality = "exact"
				end

				-- Tier 2: parent civ fallback (guarded: false = authoritative)
				if quality == nil and AGS_CIV_PARENT_MAP[rcv_civ] ~= nil
					and not AGS_CivTableHasExplicitFalse(rcv_civ, ags_key) then
					rcv_bp = _LeaverCoverage_TryResolve(AGS_CIV_PARENT_MAP[rcv_civ], ags_key)
					if rcv_bp ~= nil then
						quality = "parent"
					end
				end

				-- Tier 3: AGS_BUILDING_FALLBACK_MAP
				if quality == nil and AGS_BUILDING_FALLBACK_MAP ~= nil then
					local fb_key = AGS_BUILDING_FALLBACK_MAP[ags_key]
					if fb_key ~= nil then
						rcv_bp = _LeaverCoverage_TryResolve(rcv_civ, fb_key)
						if rcv_bp == nil and AGS_CIV_PARENT_MAP[rcv_civ] ~= nil
							and not AGS_CivTableHasExplicitFalse(rcv_civ, fb_key) then
							rcv_bp = _LeaverCoverage_TryResolve(AGS_CIV_PARENT_MAP[rcv_civ], fb_key)
						end
						if rcv_bp ~= nil then
							quality = "lossy"
						end
					end
				end

				if quality == nil then
					quality = "unresolved"
					table.insert(unresolved_keys, ags_key)
				end
				pair_totals[quality] = pair_totals[quality] + 1
				global_totals[quality] = global_totals[quality] + 1
				global_totals.total = global_totals.total + 1

				::continue_key::
			end

			if not summary_only and #unresolved_keys > 0 then
				print(string.format("  %s→%s: exact=%d parent=%d lossy=%d UNRESOLVED=%d [%s]",
					src_civ, rcv_civ,
					pair_totals.exact, pair_totals.parent, pair_totals.lossy, pair_totals.unresolved,
					table.concat(unresolved_keys, ", ")))
			elseif summary_only then
				local total = pair_totals.exact + pair_totals.parent + pair_totals.lossy + pair_totals.unresolved
				if total > 0 then
					print(string.format("  %s→%s: %d/%d resolved (e=%d p=%d l=%d u=%d)",
						src_civ, rcv_civ, total - pair_totals.unresolved, total,
						pair_totals.exact, pair_totals.parent, pair_totals.lossy, pair_totals.unresolved))
				end
			end

			if pair_totals.unresolved > 0 then
				table.insert(worst_pairs, {
					src = src_civ, rcv = rcv_civ,
					unresolved = pair_totals.unresolved,
					keys = unresolved_keys,
				})
			end

			::continue_rcv::
		end

		::continue_src::
	end

	-- Sort worst pairs by unresolved count descending
	table.sort(worst_pairs, function(a, b) return a.unresolved > b.unresolved end)

	print("")
	print("=== GLOBAL TOTALS ===")
	print(string.format("  Total building lookups: %d", global_totals.total))
	print(string.format("  Exact:      %d (%.1f%%)", global_totals.exact, global_totals.total > 0 and (global_totals.exact / global_totals.total * 100) or 0))
	print(string.format("  Parent:     %d (%.1f%%)", global_totals.parent, global_totals.total > 0 and (global_totals.parent / global_totals.total * 100) or 0))
	print(string.format("  Lossy:      %d (%.1f%%)", global_totals.lossy, global_totals.total > 0 and (global_totals.lossy / global_totals.total * 100) or 0))
	print(string.format("  Unresolved: %d (%.1f%%)", global_totals.unresolved, global_totals.total > 0 and (global_totals.unresolved / global_totals.total * 100) or 0))

	if #worst_pairs > 0 then
		print("")
		print("=== WORST PAIRS (top 10) ===")
		for i = 1, math.min(10, #worst_pairs) do
			local p = worst_pairs[i]
			print(string.format("  #%d %s→%s: %d unresolved [%s]",
				i, p.src, p.rcv, p.unresolved,
				table.concat(p.keys, ", ")))
		end
	end

	print("")
	print(string.format("=== AUDIT COMPLETE: %d civs, %d pairs checked ===", #civs, #civs * (#civs - 1)))
end

-- Single-civ variant: audit one sender civ against all receivers.
function Debug_LeaverCoverage_Civ(src_civ_name)
	if src_civ_name == nil then
		print("[ERROR] Usage: Debug_LeaverCoverage_Civ(\"byzantine\")")
		return
	end

	print("")
	print(string.format("=== BUILDING COVERAGE: %s → all receivers ===", src_civ_name))

	local src_table = AGS_ENTITY_TABLE[src_civ_name]
	if src_table == nil then
		print(string.format("  [ERROR] No AGS_ENTITY_TABLE entry for '%s'", src_civ_name))
		return
	end

	if _BLUEPRINT_REVERSE_MAP == nil or next(_BLUEPRINT_REVERSE_MAP) == nil then
		print("  [FAIL] _BLUEPRINT_REVERSE_MAP is empty — run after match start")
		return
	end

	-- Collect building keys from source table
	local bldg_keys = {}
	for ags_key, attrib in pairs(src_table) do
		if type(attrib) == "string" and string.sub(attrib, 1, 9) == "building_" then
			table.insert(bldg_keys, ags_key)
		end
	end
	table.sort(bldg_keys)

	print(string.format("  Source has %d building keys", #bldg_keys))
	print("")

	for rcv_civ, _ in pairs(AGS_ENTITY_TABLE) do
		if rcv_civ == "neutral" or rcv_civ == src_civ_name then goto continue_rcv2 end

		local exact, parent, lossy, unresolved = 0, 0, 0, 0
		local unresolved_list = {}

		for _, ags_key in ipairs(bldg_keys) do
			local quality = nil
			local rcv_bp = _LeaverCoverage_TryResolve(rcv_civ, ags_key)
			if rcv_bp ~= nil then quality = "exact" end

			if quality == nil and AGS_CIV_PARENT_MAP[rcv_civ] ~= nil
				and not AGS_CivTableHasExplicitFalse(rcv_civ, ags_key) then
				rcv_bp = _LeaverCoverage_TryResolve(AGS_CIV_PARENT_MAP[rcv_civ], ags_key)
				if rcv_bp ~= nil then quality = "parent" end
			end

			if quality == nil and AGS_BUILDING_FALLBACK_MAP ~= nil then
				local fb_key = AGS_BUILDING_FALLBACK_MAP[ags_key]
				if fb_key ~= nil then
					rcv_bp = _LeaverCoverage_TryResolve(rcv_civ, fb_key)
					if rcv_bp == nil and AGS_CIV_PARENT_MAP[rcv_civ] ~= nil
						and not AGS_CivTableHasExplicitFalse(rcv_civ, fb_key) then
						rcv_bp = _LeaverCoverage_TryResolve(AGS_CIV_PARENT_MAP[rcv_civ], fb_key)
					end
					if rcv_bp ~= nil then quality = "lossy" end
				end
			end

			if quality == nil then
				unresolved = unresolved + 1
				table.insert(unresolved_list, ags_key)
			elseif quality == "exact" then exact = exact + 1
			elseif quality == "parent" then parent = parent + 1
			elseif quality == "lossy" then lossy = lossy + 1
			end
		end

		local total = exact + parent + lossy + unresolved
		print(string.format("  →%-20s %d/%d resolved (e=%d p=%d l=%d u=%d)%s",
			rcv_civ, total - unresolved, total,
			exact, parent, lossy, unresolved,
			#unresolved_list > 0 and (" [" .. table.concat(unresolved_list, ", ") .. "]") or ""))

		::continue_rcv2::
	end
end

---------------------------------------------------------------------------------------------------
-- COMMAND: Coverage Pair — detailed building-key resolution for one src→rcv civ pair.
-- Works in ANY match (reads AGS_ENTITY_TABLE + _BLUEPRINT_REVERSE_MAP only).
-- Usage (console): Debug_LeaverCoverage_Pair("malian", "japanese")
---------------------------------------------------------------------------------------------------
function Debug_LeaverCoverage_Pair(src_civ, rcv_civ)
	if src_civ == nil or rcv_civ == nil then
		print("[ERROR] Usage: Debug_LeaverCoverage_Pair(\"malian\", \"japanese\")")
		return
	end

	print("")
	print("==============================================")
	print(string.format("  CBA DEBUG — COVERAGE PAIR: %s → %s", src_civ, rcv_civ))
	print("==============================================")

	local src_table = AGS_ENTITY_TABLE[src_civ]
	if src_table == nil then
		print(string.format("  [ERROR] No AGS_ENTITY_TABLE entry for '%s'", src_civ))
		return
	end
	if AGS_ENTITY_TABLE[rcv_civ] == nil then
		print(string.format("  [ERROR] No AGS_ENTITY_TABLE entry for '%s'", rcv_civ))
		return
	end

	if _BLUEPRINT_REVERSE_MAP == nil or next(_BLUEPRINT_REVERSE_MAP) == nil then
		print("  [FAIL] _BLUEPRINT_REVERSE_MAP is empty — run after match start")
		return
	end

	-- Collect and sort building keys from source table
	local bldg_keys = {}
	for ags_key, attrib in pairs(src_table) do
		if type(attrib) == "string" and string.sub(attrib, 1, 9) == "building_" then
			table.insert(bldg_keys, ags_key)
		end
	end
	table.sort(bldg_keys)

	local totals = { exact = 0, parent = 0, lossy = 0, unresolved = 0 }
	local unresolved_keys = {}

	for _, ags_key in ipairs(bldg_keys) do
		local quality = nil
		local resolved_attrib = nil
		local tier_label = nil

		-- Tier 1: direct receiver table lookup
		resolved_attrib = _LeaverCoverage_TryResolve(rcv_civ, ags_key)
		if resolved_attrib ~= nil then
			quality = "exact"
			tier_label = "exact"
		end

		-- Tier 2: parent civ fallback (guarded: false = authoritative)
		if quality == nil and AGS_CIV_PARENT_MAP[rcv_civ] ~= nil
			and not AGS_CivTableHasExplicitFalse(rcv_civ, ags_key) then
			resolved_attrib = _LeaverCoverage_TryResolve(AGS_CIV_PARENT_MAP[rcv_civ], ags_key)
			if resolved_attrib ~= nil then
				quality = "parent"
				tier_label = "parent→" .. AGS_CIV_PARENT_MAP[rcv_civ]
			end
		end

		-- Tier 3: AGS_BUILDING_FALLBACK_MAP
		if quality == nil and AGS_BUILDING_FALLBACK_MAP ~= nil then
			local fb_key = AGS_BUILDING_FALLBACK_MAP[ags_key]
			if fb_key ~= nil then
				resolved_attrib = _LeaverCoverage_TryResolve(rcv_civ, fb_key)
				if resolved_attrib == nil and AGS_CIV_PARENT_MAP[rcv_civ] ~= nil
					and not AGS_CivTableHasExplicitFalse(rcv_civ, fb_key) then
					resolved_attrib = _LeaverCoverage_TryResolve(AGS_CIV_PARENT_MAP[rcv_civ], fb_key)
				end
				if resolved_attrib ~= nil then
					quality = "lossy"
					tier_label = "lossy→" .. fb_key
				end
			end
		end

		if quality == nil then
			quality = "unresolved"
			tier_label = "UNRESOLVED"
			table.insert(unresolved_keys, ags_key)
		end
		totals[quality] = totals[quality] + 1

		local src_attrib = src_table[ags_key]
		print(string.format("  %-24s [%s] %s → %s",
			ags_key, tier_label, tostring(src_attrib),
			resolved_attrib ~= nil and tostring(resolved_attrib) or "—"))
	end

	local total = totals.exact + totals.parent + totals.lossy + totals.unresolved
	print("")
	print("=== PAIR TOTALS ===")
	print(string.format("  Keys: %d | exact=%d parent=%d lossy=%d unresolved=%d",
		total, totals.exact, totals.parent, totals.lossy, totals.unresolved))
	if #unresolved_keys > 0 then
		print(string.format("  Unresolved: [%s]", table.concat(unresolved_keys, ", ")))
	end
	print(string.format("  Coverage: %.1f%%", total > 0 and ((total - totals.unresolved) / total * 100) or 0))
end

-- Helper: try to resolve an AGS key for a civ via AGS_ENTITY_TABLE lookup only (no pcall BP load).
-- Returns the attribName string if the civ table has a truthy value, nil otherwise.
function _LeaverCoverage_TryResolve(civ_name, ags_key)
	local tbl = AGS_ENTITY_TABLE[civ_name]
	if tbl == nil then return nil end
	local val = tbl[ags_key]
	if val == nil or val == false then return nil end
	return val
end

---------------------------------------------------------------------------------------------------
-- Forced-Precache BP Resolution Batch Test
-- Tests every forced-precache entry in _LEAVER_PRECACHE_ALWAYS_REQUIRED_BP plus
-- the 6 DLC/variant MaA/Knight civs (sul, abb, ott, abb_ha_01, fre_ha_01, chi_ha_01)
-- as both source and receiver against all 22 civs. Validates BP existence and route resolution.
-- Usage: Debug_LeaverResolve_ForcedBP()
---------------------------------------------------------------------------------------------------

function Debug_LeaverResolve_ForcedBP()
	print("")
	print("============================================================")
	print("  CBA DEBUG — FORCED-PRECACHE BP RESOLUTION BATCH TEST")
	print("============================================================")

	-- Phase 1: Validate every forced-precache entry actually resolves to a valid BP
	print("")
	print("--- Phase 1: BP Existence Validation ---")
	local bp_valid = 0
	local bp_phantom = 0
	local phantom_list = {}
	if _LEAVER_PRECACHE_ALWAYS_REQUIRED_BP == nil then
		print("  [FAIL] _LEAVER_PRECACHE_ALWAYS_REQUIRED_BP is nil")
		return
	end
	local forced_bps = {}
	for bp_name, _ in pairs(_LEAVER_PRECACHE_ALWAYS_REQUIRED_BP) do
		table.insert(forced_bps, bp_name)
	end
	table.sort(forced_bps)
	for _, bp_name in ipairs(forced_bps) do
		local ok, sbp = pcall(BP_GetSquadBlueprint, bp_name)
		if ok and sbp ~= nil then
			bp_valid = bp_valid + 1
			print(string.format("  [OK]      %s", bp_name))
		else
			bp_phantom = bp_phantom + 1
			table.insert(phantom_list, bp_name)
			print(string.format("  [PHANTOM] %s — BP does not exist!", bp_name))
		end
	end
	print(string.format("  Summary: %d valid, %d phantom out of %d entries", bp_valid, bp_phantom, #forced_bps))

	-- Phase 2: Route resolution for 6 DLC/variant civs as receiver vs all 22 civs
	print("")
	print("--- Phase 2: DLC/Variant Civ Route Resolution ---")
	local target_civs = {"sultanate", "abbasid", "ottoman", "abbasid_ha_01", "french_ha_01", "chinese_ha_01"}
	local test_archetypes = {"unit_manatarms_3_", "unit_knight_4_"}

	local total_pairs = 0
	local total_resolved = 0
	local total_destroy = 0
	local total_errors = 0
	local fail_list = {}

	for _, target_civ in ipairs(target_civs) do
		print(string.format("\n  === %s as RECEIVER ===", target_civ))
		for src_civ, src_prefix in pairs(AGS_CIV_PREFIXES) do
			if src_civ ~= target_civ then
				local src_suffix = string.sub(src_prefix, 1, -2)
				for _, archetype in ipairs(test_archetypes) do
					local src_bp = archetype .. src_suffix
					total_pairs = total_pairs + 1
					local ok, route = pcall(_ResolveMilitaryRoute, src_bp, src_civ, target_civ)
					if ok and route then
						if route.route == "destroy_no_mapping" then
							total_destroy = total_destroy + 1
							table.insert(fail_list, {src = src_bp, src_civ = src_civ, rcv = target_civ, route = route.route})
							print(string.format("    [FAIL] %s (%s) → %s | %s", src_bp, src_civ, target_civ, route.route))
						else
							total_resolved = total_resolved + 1
							if _LEAVER_DEBUG_VERBOSE then
								print(string.format("    [OK]   %s (%s) → %s | %s → %s", src_bp, src_civ, target_civ, route.route, route.bp_name or "same"))
							end
						end
					else
						total_errors = total_errors + 1
						print(string.format("    [ERR]  %s (%s) → %s | error: %s", src_bp, src_civ, target_civ, tostring(route)))
					end
				end
			end
		end
	end

	-- Phase 3: Same 6 civs as SOURCE vs all 22 receivers
	print("")
	print("--- Phase 3: DLC/Variant Civs as SOURCE ---")
	for _, target_civ in ipairs(target_civs) do
		local mil_suffix = _Leaver_GetMilitarySuffix(target_civ)
		if mil_suffix == nil then
			print(string.format("  [SKIP] %s — no military suffix", target_civ))
		else
			print(string.format("\n  === %s as SOURCE (suffix=%s) ===", target_civ, mil_suffix))
			for rcv_civ, _ in pairs(AGS_CIV_PREFIXES) do
				if rcv_civ ~= target_civ then
					for _, archetype in ipairs(test_archetypes) do
						local src_bp = archetype .. mil_suffix
						total_pairs = total_pairs + 1
						local ok, route = pcall(_ResolveMilitaryRoute, src_bp, target_civ, rcv_civ)
						if ok and route then
							if route.route == "destroy_no_mapping" then
								total_destroy = total_destroy + 1
								table.insert(fail_list, {src = src_bp, src_civ = target_civ, rcv = rcv_civ, route = route.route})
								print(string.format("    [FAIL] %s (%s) → %s | %s", src_bp, target_civ, rcv_civ, route.route))
							else
								total_resolved = total_resolved + 1
							end
						else
							total_errors = total_errors + 1
							print(string.format("    [ERR]  %s (%s) → %s | error: %s", src_bp, target_civ, rcv_civ, tostring(route)))
						end
					end
				end
			end
		end
	end

	-- Summary
	print("")
	print("============================================================")
	print("  FORCED-PRECACHE BP — SUMMARY")
	print("============================================================")
	print(string.format("  Forced-precache BPs: %d valid, %d phantom", bp_valid, bp_phantom))
	print(string.format("  Route pairs tested:  %d", total_pairs))
	print(string.format("  Resolved:            %d", total_resolved))
	print(string.format("  Destroy (no map):    %d", total_destroy))
	print(string.format("  Errors:              %d", total_errors))
	if #phantom_list > 0 then
		print("")
		print("  PHANTOM BPs (remove from forced-precache table):")
		for _, bp in ipairs(phantom_list) do
			print(string.format("    %s", bp))
		end
	end
	if #fail_list > 0 and #fail_list <= 20 then
		print("")
		print("  DESTROY-NO-MAPPING pairs:")
		for _, f in ipairs(fail_list) do
			print(string.format("    %s (%s) → %s", f.src, f.src_civ, f.rcv))
		end
	elseif #fail_list > 20 then
		print(string.format("\n  DESTROY-NO-MAPPING: %d pairs (too many to list — check verbose output)", #fail_list))
	end
	if bp_phantom == 0 and total_destroy == 0 and total_errors == 0 then
		print("\n  >>> ALL CLEAR — No phantom BPs, no unresolved routes <<<")
	end
end

---------------------------------------------------------------------------------------------------
-- Weapon Path Classifier (helper)
-- Analyzes weapon blueprint name to determine if path is civ-specific or shared across civs.
-- Returns: "civ_specific" or "common"
-- Examples:
--   weapon_manatarms_3_abb → "civ_specific" (races/abbasid/ path)
--   weapon_manatarms_3 → "common" (races/common/ path)
--   weapon_knight_4 → "common"
--   weapon_manatarms_3_lan → "civ_specific"
---------------------------------------------------------------------------------------------------
local function _ClassifyWeaponPath(weapon_bp_name)
	if weapon_bp_name == nil or weapon_bp_name == "" then return "unknown" end
	
	-- Civ indicators: known suffixes that indicate race-specific path
	-- (corresponds to races/ subdirectories in AoE4 asset tree)
	local civ_suffixes = {
		["_abb"] = true,
		["_byz"] = true,
		["_chi"] = true,
		["_eng"] = true,
		["_fre"] = true,
		["_hre"] = true,
		["_jpn"] = true,
		["_mal"] = true,
		["_mon"] = true,
		["_ott"] = true,
		["_rus"] = true,
		["_sul"] = true,
		["_tem"] = true,
		["_lan"] = true,
		-- HA/variant suffixes
		["_abb_ha_01"] = true,
		["_byz_ha_mac"] = true,
		["_chi_ha_01"] = true,
		["_fre_ha_01"] = true,
		["_hre_ha_01"] = true,
		["_jpn_ha_sen"] = true,
		["_mon_ha_gol"] = true,
		["_sul_ha_tug"] = true,
	}
	
	-- Check for HA variants first (longer suffixes)
	for suffix, _ in pairs(civ_suffixes) do
		if string.sub(suffix, 1, 1) == "_" and string.len(suffix) > 4 then
			if string.sub(weapon_bp_name, -string.len(suffix)) == suffix then
				return "civ_specific"
			end
		end
	end
	
	-- Check single civ suffixes
	for suffix, _ in pairs(civ_suffixes) do
		if string.sub(suffix, 1, 1) == "_" and string.len(suffix) <= 4 then
			if string.sub(weapon_bp_name, -string.len(suffix)) == suffix then
				return "civ_specific"
			end
		end
	end
	
	return "common"
end

---------------------------------------------------------------------------------------------------
-- Weapon-Audit Debug Commands
-- Spawns one squad per forced-precache BP, inspects live entities' weapon
-- hardpoints via Entity_GetWeaponHardpointCount / Entity_GetWeaponBlueprint.
-- Catches cases where squad BP exists and route resolves, but weapon sub-resources
-- fail at engine level.
-- Depends on: _LEAVER_PRECACHE_ALWAYS_REQUIRED_BP, PLAYERS, BP_GetSquadBlueprint,
--   Util_CreateSquads, Squad_GetFirstEntity, Entity_GetWeaponHardpointCount,
--   Entity_GetWeaponBlueprint, SGroup_DestroyAllSquads
---------------------------------------------------------------------------------------------------

function Debug_LeaverWeaponAudit()
	print("")
	print("============================================================")
	print("  CBA DEBUG — WEAPON-AUDIT: FORCED-PRECACHE BP HARDPOINTS")
	print("============================================================")

	if _LEAVER_PRECACHE_ALWAYS_REQUIRED_BP == nil then
		print("  [FAIL] _LEAVER_PRECACHE_ALWAYS_REQUIRED_BP is nil")
		return
	end
	if PLAYERS == nil or #PLAYERS < 2 then
		print("  [FAIL] PLAYERS table missing or insufficient")
		return
	end

	-- Use player 2 (AI) as spawn owner to avoid polluting human player state
	local owner = PLAYERS[2]
	local spawn_pos = Player_GetStartingPosition(owner.id) or Position_New(50, 50, 0)
	local sg_audit = SGroup_CreateIfNotFound("sg_weapon_audit")
	SGroup_Clear(sg_audit)

	-- Collect and sort forced BPs
	local forced_bps = {}
	for bp_name, _ in pairs(_LEAVER_PRECACHE_ALWAYS_REQUIRED_BP) do
		table.insert(forced_bps, bp_name)
	end
	table.sort(forced_bps)

	-- Per-civ buckets for grouped output
	local civ_results = {}
	local totals = { weapon_ok = 0, weapon_missing = 0, weapon_query_error = 0, spawn_error = 0, bp_phantom = 0, total = 0 }

	-- Abbasid-focused summary list
	local abb_results = {}

	for _, bp_name in ipairs(forced_bps) do
		totals.total = totals.total + 1

		-- Derive short civ suffix from BP name for grouping (last segment after final _)
		local civ_tag = string.match(bp_name, "_([^_]+)$") or "unknown"
		-- Handle HA suffixes like _abb_ha_01 → abb_ha_01
		local ha_tag = string.match(bp_name, "_(%w+_ha_%d+)$")
		if ha_tag then civ_tag = ha_tag end
		if civ_results[civ_tag] == nil then civ_results[civ_tag] = {} end

		local ok_bp, sbp = pcall(BP_GetSquadBlueprint, bp_name)
		if not ok_bp or sbp == nil then
			totals.bp_phantom = totals.bp_phantom + 1
			local entry = { bp = bp_name, status = "BP_PHANTOM" }
			table.insert(civ_results[civ_tag], entry)
			if string.find(bp_name, "abb", 1, true) then table.insert(abb_results, entry) end
			print(string.format("  [PHANTOM]  %s — squad BP does not exist", bp_name))
		else
			-- Spawn one squad
			SGroup_Clear(sg_audit)
			local ok_spawn, spawn_err = pcall(Util_CreateSquads, owner.id, sg_audit, sbp, spawn_pos, nil, 1)
			if not ok_spawn or SGroup_Count(sg_audit) == 0 then
				totals.spawn_error = totals.spawn_error + 1
				local entry = { bp = bp_name, status = "SPAWN_ERROR", detail = tostring(spawn_err) }
				table.insert(civ_results[civ_tag], entry)
				if string.find(bp_name, "abb", 1, true) then table.insert(abb_results, entry) end
				print(string.format("  [SPAWN_ERR] %s — %s", bp_name, tostring(spawn_err)))
			else
				-- Inspect first entity member in spawned squad
				local squad = SGroup_GetSquadAt(sg_audit, 1)
				local ent = Squad_GetFirstEntity(squad)
				if ent == nil then
					totals.weapon_query_error = totals.weapon_query_error + 1
					local entry = { bp = bp_name, status = "NO_ENTITY", detail = "Squad_GetFirstEntity returned nil" }
					table.insert(civ_results[civ_tag], entry)
					if string.find(bp_name, "abb", 1, true) then table.insert(abb_results, entry) end
					print(string.format("  [NO_ENTITY] %s — Squad has no entity members", bp_name))
					pcall(SGroup_DestroyAllSquads, sg_audit)
				else
				local ok_hpc, hp_count = pcall(Entity_GetWeaponHardpointCount, ent)
				if not ok_hpc then
					totals.weapon_query_error = totals.weapon_query_error + 1
					local entry = { bp = bp_name, status = "QUERY_ERROR", detail = tostring(hp_count) }
					table.insert(civ_results[civ_tag], entry)
					if string.find(bp_name, "abb", 1, true) then table.insert(abb_results, entry) end
					print(string.format("  [QUERY_ERR] %s — Entity_GetWeaponHardpointCount failed: %s", bp_name, tostring(hp_count)))
				else
					local all_ok = true
					local hp_details = {}
					local weapon_classifications = {}
					for hp_idx = 0, hp_count - 1 do
						local ok_wp, wbp = pcall(Entity_GetWeaponBlueprint, ent, hp_idx)
						if ok_wp and wbp ~= nil then
							local ok_name, wp_name = pcall(BP_GetName, wbp)
							table.insert(hp_details, string.format("hp%d=%s", hp_idx, ok_name and wp_name or "name_err"))
							if ok_name and wp_name then
								table.insert(weapon_classifications, _ClassifyWeaponPath(wp_name))
							end
						else
							all_ok = false
							table.insert(hp_details, string.format("hp%d=MISSING(%s)", hp_idx, tostring(wbp)))
						end
					end

					local hp_str = hp_count > 0 and table.concat(hp_details, ", ") or "no_hardpoints"
					local weapon_path_info = #weapon_classifications > 0 and table.concat(weapon_classifications, ",") or ""
					if all_ok and hp_count > 0 then
						totals.weapon_ok = totals.weapon_ok + 1
						local entry = { bp = bp_name, status = "OK", hardpoints = hp_count, detail = hp_str, weapon_path = weapon_path_info }
						table.insert(civ_results[civ_tag], entry)
						if string.find(bp_name, "abb", 1, true) then table.insert(abb_results, entry) end
						print(string.format("  [OK]       %s — %d hardpoints: %s | weapons: %s", bp_name, hp_count, hp_str, weapon_path_info))
					elseif hp_count == 0 then
						-- Zero hardpoints is unusual for military units but not necessarily an error
						totals.weapon_query_error = totals.weapon_query_error + 1
						local entry = { bp = bp_name, status = "NO_HARDPOINTS", hardpoints = 0 }
						table.insert(civ_results[civ_tag], entry)
						if string.find(bp_name, "abb", 1, true) then table.insert(abb_results, entry) end
						print(string.format("  [WARN]     %s — 0 hardpoints (unusual for military)", bp_name))
					else
						totals.weapon_missing = totals.weapon_missing + 1
						local entry = { bp = bp_name, status = "WEAPON_MISSING", hardpoints = hp_count, detail = hp_str }
						table.insert(civ_results[civ_tag], entry)
						if string.find(bp_name, "abb", 1, true) then table.insert(abb_results, entry) end
						print(string.format("  [MISSING]  %s — %d hardpoints: %s", bp_name, hp_count, hp_str))
					end
				end

				-- Cleanup spawned squad
				pcall(SGroup_DestroyAllSquads, sg_audit)
			end -- ent ~= nil
			end
		end
	end

	-- Abbasid-focused summary
	print("")
	print("=== ABBASID FOCUS ===")
	if #abb_results == 0 then
		print("  (no Abbasid entries in forced-precache table)")
	else
		for _, r in ipairs(abb_results) do
			print(string.format("  [%s] %s%s", r.status, r.bp, r.detail and (" — " .. r.detail) or ""))
		end
	end

	-- Weapon path classification summary
	print("")
	print("=== WEAPON PATH CLASSIFICATION ===")
	local civ_specific_count = 0
	local common_count = 0
	for _, entries in pairs(civ_results) do
		for _, entry in ipairs(entries) do
			if entry.status == "OK" and entry.weapon_path then
				for path in string.gmatch(entry.weapon_path, "[^,]+") do
					if string.find(path, "civ_specific", 1, true) then
						civ_specific_count = civ_specific_count + 1
					elseif string.find(path, "common", 1, true) then
						common_count = common_count + 1
					end
				end
			end
		end
	end
	print(string.format("  Civ-specific weapons: %d (race-specific asset paths requiring per-civ precache)", civ_specific_count))
	print(string.format("  Common weapons:       %d (shared races/common path)", common_count))

	-- Summary
	print("")
	print("============================================================")
	print("  WEAPON-AUDIT — SUMMARY")
	print("============================================================")
	print(string.format("  Total forced BPs:     %d", totals.total))
	print(string.format("  Weapon OK:            %d", totals.weapon_ok))
	print(string.format("  Weapon missing:       %d", totals.weapon_missing))
	print(string.format("  Query error:          %d", totals.weapon_query_error))
	print(string.format("  Spawn error:          %d", totals.spawn_error))
	print(string.format("  BP phantom:           %d", totals.bp_phantom))
	if totals.weapon_missing == 0 and totals.spawn_error == 0 and totals.bp_phantom == 0 then
		print("\n  >>> WEAPON-AUDIT CLEAR — All forced-precache BPs have valid weapon hardpoints <<<")
	else
		print(string.format("\n  >>> WEAPON-AUDIT ISSUES — %d weapon_missing, %d spawn_error, %d phantom <<<",
			totals.weapon_missing, totals.spawn_error, totals.bp_phantom))
	end

	-- Store results for validation test consumption
	_WEAPON_AUDIT_RESULTS = totals
end

---------------------------------------------------------------------------------------------------
-- Transfer Inspector
-- Spawns a source unit, resolves the military route to a target receiver civ,
-- spawns the resolved target squad, and inspects weapon hardpoints on the live
-- entity. Closes the gap between theoretical route resolution and actual
-- spawned-entity weapon state.
-- Usage: Debug_LeaverTransferInspector("abbasid", "english")
--   or:  Debug_LeaverTransferInspector()  -- defaults to Abbasid receiver
---------------------------------------------------------------------------------------------------

function Debug_LeaverTransferInspector(rcv_civ, src_civ)
	rcv_civ = rcv_civ or "abbasid"
	src_civ = src_civ or "english"

	print("")
	print("============================================================")
	print(string.format("  CBA DEBUG — TRANSFER INSPECTOR: %s → %s", src_civ, rcv_civ))
	print("============================================================")

	if AGS_CIV_PREFIXES == nil then
		print("  [FAIL] AGS_CIV_PREFIXES not loaded")
		return
	end
	if AGS_CIV_PREFIXES[src_civ] == nil then
		print(string.format("  [FAIL] Unknown source civ: %s", src_civ))
		return
	end
	if AGS_CIV_PREFIXES[rcv_civ] == nil then
		print(string.format("  [FAIL] Unknown receiver civ: %s", rcv_civ))
		return
	end
	if PLAYERS == nil or #PLAYERS < 2 then
		print("  [FAIL] PLAYERS table missing or insufficient")
		return
	end

	local src_suffix = _Leaver_GetMilitarySuffix(src_civ)
	if src_suffix == nil then
		print(string.format("  [FAIL] No military suffix for %s", src_civ))
		return
	end

	local owner = PLAYERS[2]
	local spawn_pos = Player_GetStartingPosition(owner.id) or Position_New(50, 50, 0)
	local sg_xfer = SGroup_CreateIfNotFound("sg_xfer_inspector")

	-- Test archetypes that cover the forced-precache set
	local test_bps = {
		string.format("unit_manatarms_3_%s", src_suffix),
		string.format("unit_knight_4_%s", src_suffix),
		string.format("unit_spearman_2_%s", src_suffix),
		string.format("unit_archer_2_%s", src_suffix),
	}

	for _, src_bp_name in ipairs(test_bps) do
		print(string.format("\n  --- Source: %s ---", src_bp_name))

		-- Phase 1: Route resolution
		local ok_route, route = pcall(_ResolveMilitaryRoute, src_bp_name, src_civ, rcv_civ)
		if not ok_route or route == nil then
			print(string.format("    [ERR] Route resolution failed: %s", tostring(route)))
		elseif route.route == "destroy_no_mapping" or route.route == "destroy_policy" then
			print(string.format("    [DESTROY] Route=%s — no target BP to inspect", route.route))
		else
			print(string.format("    Route:     %s", route.route))
			print(string.format("    Target BP: %s", route.bp_name or "nil"))
			print(string.format("    Ratio:     %.2f", route.ratio or 1.0))

			-- Phase 2: Spawn resolved target and inspect weapons
			if route.to_sbp ~= nil then
				SGroup_Clear(sg_xfer)
				local ok_spawn, spawn_err = pcall(Util_CreateSquads, owner.id, sg_xfer, route.to_sbp, spawn_pos, nil, 1)
				if not ok_spawn or SGroup_Count(sg_xfer) == 0 then
					print(string.format("    [SPAWN_ERR] Could not spawn target: %s", tostring(spawn_err)))
				else
					local squad = SGroup_GetSquadAt(sg_xfer, 1)
					local ent = Squad_GetFirstEntity(squad)

					if ent == nil then
						print("    [NO_ENTITY] Squad has no entity members")
					else
						-- Weapon hardpoint inspection
						local ok_hpc, hp_count = pcall(Entity_GetWeaponHardpointCount, ent)
						if not ok_hpc then
							print(string.format("    [QUERY_ERR] Entity_GetWeaponHardpointCount: %s", tostring(hp_count)))
						else
							print(string.format("    Hardpoints: %d", hp_count))
							for hp_idx = 0, hp_count - 1 do
								local ok_wp, wbp = pcall(Entity_GetWeaponBlueprint, ent, hp_idx)
								if ok_wp and wbp ~= nil then
									local ok_name, wp_name = pcall(BP_GetName, wbp)
									print(string.format("      hp[%d] = %s", hp_idx, ok_name and wp_name or "name_err"))
								else
									print(string.format("      hp[%d] = MISSING (%s)", hp_idx, tostring(wbp)))
								end
							end
						end
					end

					-- Cleanup
					pcall(SGroup_DestroyAllSquads, sg_xfer)
				end
			else
				print("    [SKIP] Route resolved but to_sbp is nil")
			end
		end
	end

	print("")
	print("============================================================")
	print(string.format("  TRANSFER INSPECTOR COMPLETE: %s → %s", src_civ, rcv_civ))
	print("============================================================")
end

---------------------------------------------------------------------------------------------------
-- Receiver-Class Weapon Audit
-- Extends the forced-BP weapon audit to also test receiver-class remap targets
-- from _LEAVER_RECEIVER_CLASS_MAP. Spawns each resolved target BP for each
-- receiver civ and validates weapon hardpoints — catches the case where route
-- resolution succeeds but the target's weapon sub-resources are not loaded.
-- Usage: Debug_LeaverWeaponAudit_ReceiverClass()
--   or:  Debug_LeaverWeaponAudit_ReceiverClass("lancaster")
---------------------------------------------------------------------------------------------------

function Debug_LeaverWeaponAudit_ReceiverClass(filter_civ)
	print("")
	print("============================================================")
	print("  CBA DEBUG — WEAPON-AUDIT: RECEIVER-CLASS REMAP TARGETS")
	print("============================================================")

	if _LEAVER_RECEIVER_CLASS_MAP == nil then
		print("  [FAIL] _LEAVER_RECEIVER_CLASS_MAP is nil")
		return
	end
	if PLAYERS == nil or #PLAYERS < 2 then
		print("  [FAIL] PLAYERS table missing or insufficient")
		return
	end

	local owner = PLAYERS[2]
	local spawn_pos = Player_GetStartingPosition(owner.id) or Position_New(50, 50, 0)
	local sg_rcv_audit = SGroup_CreateIfNotFound("sg_rcv_weapon_audit")
	SGroup_Clear(sg_rcv_audit)

	local totals = { ok = 0, missing = 0, query_error = 0, spawn_error = 0, bp_phantom = 0, destroy_policy = 0, total = 0 }
	local civ_summaries = {}

	-- Sorted civ iteration for deterministic output
	local civ_keys = {}
	for civ, _ in pairs(_LEAVER_RECEIVER_CLASS_MAP) do
		if filter_civ == nil or civ == filter_civ then
			table.insert(civ_keys, civ)
		end
	end
	table.sort(civ_keys)

	for _, rcv_civ in ipairs(civ_keys) do
		local remap = _LEAVER_RECEIVER_CLASS_MAP[rcv_civ]
		local rcv_suffix = _Leaver_GetMilitarySuffix(rcv_civ)
		if rcv_suffix == nil then
			print(string.format("  [SKIP] %s — no military suffix", rcv_civ))
		else
			local civ_ok, civ_fail = 0, 0
			-- Sorted prefix iteration
			local prefixes = {}
			for prefix, _ in pairs(remap) do table.insert(prefixes, prefix) end
			table.sort(prefixes)

			print(string.format("\n  --- %s (suffix=%s) ---", rcv_civ, rcv_suffix))
			for _, prefix in ipairs(prefixes) do
				local entry = remap[prefix]
				totals.total = totals.total + 1
				if entry.policy == "destroy" then
					totals.destroy_policy = totals.destroy_policy + 1
					print(string.format("    [DESTROY] %s → destroy policy", prefix))
				else
					-- Resolve the target BP name
					local target_bp_name
					if entry.full_name then
						target_bp_name = entry.target
					else
						target_bp_name = entry.target .. (entry.default_tier or 3) .. "_" .. rcv_suffix
					end

					local ok_bp, sbp = pcall(BP_GetSquadBlueprint, target_bp_name)
					if not ok_bp or sbp == nil then
						totals.bp_phantom = totals.bp_phantom + 1
						civ_fail = civ_fail + 1
						print(string.format("    [PHANTOM] %s → %s — BP does not exist", prefix, target_bp_name))
					else
						SGroup_Clear(sg_rcv_audit)
						local ok_spawn, spawn_err = pcall(Util_CreateSquads, owner.id, sg_rcv_audit, sbp, spawn_pos, nil, 1)
						if not ok_spawn or SGroup_Count(sg_rcv_audit) == 0 then
							totals.spawn_error = totals.spawn_error + 1
							civ_fail = civ_fail + 1
							print(string.format("    [SPAWN_ERR] %s → %s — %s", prefix, target_bp_name, tostring(spawn_err)))
						else
							local squad = SGroup_GetSquadAt(sg_rcv_audit, 1)
							local ent = Squad_GetFirstEntity(squad)
							if ent == nil then
								totals.query_error = totals.query_error + 1
								civ_fail = civ_fail + 1
								print(string.format("    [NO_ENTITY] %s → %s", prefix, target_bp_name))
							else
								local ok_hpc, hp_count = pcall(Entity_GetWeaponHardpointCount, ent)
								if not ok_hpc then
									totals.query_error = totals.query_error + 1
									civ_fail = civ_fail + 1
									print(string.format("    [QUERY_ERR] %s → %s — %s", prefix, target_bp_name, tostring(hp_count)))
								else
									local all_ok = true
									local hp_details = {}
									for hp_idx = 0, hp_count - 1 do
										local ok_wp, wbp = pcall(Entity_GetWeaponBlueprint, ent, hp_idx)
										if ok_wp and wbp ~= nil then
											local ok_name, wp_name = pcall(BP_GetName, wbp)
											table.insert(hp_details, string.format("hp%d=%s", hp_idx, ok_name and wp_name or "name_err"))
										else
											all_ok = false
											table.insert(hp_details, string.format("hp%d=MISSING", hp_idx))
										end
									end
									local hp_str = hp_count > 0 and table.concat(hp_details, ", ") or "no_hardpoints"
									if all_ok and hp_count > 0 then
										totals.ok = totals.ok + 1
										civ_ok = civ_ok + 1
										print(string.format("    [OK]       %s → %s — %d hp: %s", prefix, target_bp_name, hp_count, hp_str))
									elseif hp_count == 0 then
										totals.query_error = totals.query_error + 1
										civ_fail = civ_fail + 1
										print(string.format("    [WARN]     %s → %s — 0 hardpoints", prefix, target_bp_name))
									else
										totals.missing = totals.missing + 1
										civ_fail = civ_fail + 1
										print(string.format("    [MISSING]  %s → %s — %d hp: %s", prefix, target_bp_name, hp_count, hp_str))
									end
								end
							end
							pcall(SGroup_DestroyAllSquads, sg_rcv_audit)
						end
					end
				end
			end
			civ_summaries[rcv_civ] = { ok = civ_ok, fail = civ_fail }
		end
	end

	-- Summary
	print("")
	print("============================================================")
	print("  RECEIVER-CLASS WEAPON-AUDIT — SUMMARY")
	print("============================================================")
	print(string.format("  Total entries tested: %d", totals.total))
	print(string.format("  Weapon OK:           %d", totals.ok))
	print(string.format("  Weapon missing:      %d", totals.missing))
	print(string.format("  Query error:         %d", totals.query_error))
	print(string.format("  Spawn error:         %d", totals.spawn_error))
	print(string.format("  BP phantom:          %d", totals.bp_phantom))
	print(string.format("  Destroy-policy:      %d (skipped)", totals.destroy_policy))
	if totals.missing == 0 and totals.spawn_error == 0 and totals.bp_phantom == 0 then
		print("\n  >>> RECEIVER-CLASS WEAPON-AUDIT CLEAR <<<")
	else
		print(string.format("\n  >>> RECEIVER-CLASS ISSUES — %d missing, %d spawn_error, %d phantom <<<",
			totals.missing, totals.spawn_error, totals.bp_phantom))
	end
end

---------------------------------------------------------------------------------------------------
-- Forced-Coverage Cross-Reference
-- Compares all reward-table unit_upgrade BPs against _LEAVER_PRECACHE_ALWAYS_REQUIRED_BP
-- and flags any reward BPs not present in the forced-precache table.
-- Usage: Debug_PrecacheManifest_ForcedCoverage()
---------------------------------------------------------------------------------------------------

function Debug_PrecacheManifest_ForcedCoverage()
	print("")
	print("============================================================")
	print("  CBA DEBUG — FORCED-PRECACHE COVERAGE CROSS-REFERENCE")
	print("============================================================")

	if _CBA == nil or _CBA.rewards == nil then
		print("  [FAIL] _CBA.rewards not loaded")
		return
	end
	if _LEAVER_PRECACHE_ALWAYS_REQUIRED_BP == nil then
		print("  [FAIL] _LEAVER_PRECACHE_ALWAYS_REQUIRED_BP is nil")
		return
	end

	local reward_bps = {}  -- [bp_name] = { civs }
	local total_reward_entries = 0
	for civ, rewards in pairs(_CBA.rewards) do
		if type(rewards) == "table" then
			for threshold, reward in pairs(rewards) do
				if type(threshold) == "number" then
					for _, field in ipairs({"unit_upgrade", "unit"}) do
						if reward[field] ~= nil then
							local ok, name = pcall(BP_GetName, reward[field])
							if ok and name then
								total_reward_entries = total_reward_entries + 1
								reward_bps[name] = reward_bps[name] or {}
								reward_bps[name][civ] = true
							end
						end
					end
				end
			end
		end
	end

	-- Check each reward BP against forced table
	local missing = {}
	local covered = 0
	local bp_names = {}
	for name, _ in pairs(reward_bps) do table.insert(bp_names, name) end
	table.sort(bp_names)

	for _, bp_name in ipairs(bp_names) do
		if _LEAVER_PRECACHE_ALWAYS_REQUIRED_BP[bp_name] then
			covered = covered + 1
		else
			-- Check if it's an age-1 unit (excluded by policy)
			local req_age = _Leaver_GetRequiredAgeForBP(bp_name)
			if req_age ~= nil and req_age <= 1 then
				-- Age-1 units are intentionally excluded from forced table
			else
				table.insert(missing, bp_name)
			end
		end
	end

	print(string.format("  Unique reward unit BPs:  %d", #bp_names))
	print(string.format("  Covered by forced table: %d", covered))
	print(string.format("  Missing from forced:     %d", #missing))
	print("")

	if #missing > 0 then
		print("  === MISSING REWARD BPs (not in forced-precache) ===")
		for _, bp_name in ipairs(missing) do
			local civ_list = {}
			for civ, _ in pairs(reward_bps[bp_name]) do table.insert(civ_list, civ) end
			table.sort(civ_list)
			print(string.format("    [MISSING] %s (civs: %s)", bp_name, table.concat(civ_list, ", ")))
		end
		print("")
		print("  >>> FORCED-COVERAGE INCOMPLETE — add missing BPs to _LEAVER_PRECACHE_ALWAYS_REQUIRED_BP <<<")
	else
		print("  >>> FORCED-COVERAGE COMPLETE — all reward unit BPs (age>1) are in forced-precache table <<<")
	end

	-- Also check reverse: forced BPs with no reward source
	local forced_count = 0
	local orphaned = {}
	for bp_name, _ in pairs(_LEAVER_PRECACHE_ALWAYS_REQUIRED_BP) do
		forced_count = forced_count + 1
		if reward_bps[bp_name] == nil then
			table.insert(orphaned, bp_name)
		end
	end
	table.sort(orphaned)

	print("")
	print(string.format("  Forced-precache entries: %d", forced_count))
	print(string.format("  Orphaned (no reward):   %d", #orphaned))
	if #orphaned > 0 then
		print("  === ORPHANED FORCED BPs (no reward source — may be receiver-class targets) ===")
		for _, bp_name in ipairs(orphaned) do
			print(string.format("    [INFO] %s", bp_name))
		end
	end
end

---------------------------------------------------------------------------------------------------
-- Transfer Inspector: All-Pairs Mode
-- Runs Debug_LeaverTransferInspector for every civ that has a receiver-class
-- remap entry, paired against a standard source civ (default: english).
-- Produces a per-civ weapon status summary at the end.
-- Usage: Debug_LeaverTransferInspector_AllPairs()
--   or:  Debug_LeaverTransferInspector_AllPairs("french")  -- custom source civ
---------------------------------------------------------------------------------------------------

function Debug_LeaverTransferInspector_AllPairs(src_civ)
	src_civ = src_civ or "english"

	print("")
	print("============================================================")
	print(string.format("  CBA DEBUG — TRANSFER INSPECTOR ALL-PAIRS (source: %s)", src_civ))
	print("============================================================")

	if _LEAVER_RECEIVER_CLASS_MAP == nil then
		print("  [FAIL] _LEAVER_RECEIVER_CLASS_MAP is nil")
		return
	end

	local rcv_civs = {}
	for civ, _ in pairs(_LEAVER_RECEIVER_CLASS_MAP) do
		table.insert(rcv_civs, civ)
	end
	table.sort(rcv_civs)

	for _, rcv_civ in ipairs(rcv_civs) do
		if rcv_civ ~= src_civ then
			Debug_LeaverTransferInspector(rcv_civ, src_civ)
		end
	end

	print("")
	print("============================================================")
	print(string.format("  TRANSFER INSPECTOR ALL-PAIRS COMPLETE (%d receiver civs tested)", #rcv_civs))
	print("============================================================")
end

---------------------------------------------------------------------------------------------------
-- Precache Manifest Inspection
-- Console commands to inspect the init-time precache manifest built by
-- _Leaver_BuildPrecacheManifest() — shows confirmed targets, unresolved gaps,
-- and runtime guard hit/miss counters.
---------------------------------------------------------------------------------------------------

function Debug_PrecacheManifest_Summary()
	print("")
	print("=== PRECACHE MANIFEST — SUMMARY ===")
	if _PRECACHE_MANIFEST == nil then
		print("  [FAIL] _PRECACHE_MANIFEST not initialized — run a match first")
		return
	end
	local M = _PRECACHE_MANIFEST
	local forced_count = 0
	if _LEAVER_PRECACHE_ALWAYS_REQUIRED_BP then
		for _ in pairs(_LEAVER_PRECACHE_ALWAYS_REQUIRED_BP) do
			forced_count = forced_count + 1
		end
	end
	print(string.format("  Routes discovered: %d", M.total_routes or 0))
	print(string.format("  Confirmed targets: %d confirmed, %d unique target BPs", M.total_confirmed or 0, M.total_unique_targets or 0))
	print(string.format("  Unresolved gaps:   %d", M.total_gaps or 0))
	print(string.format("  Destroy-policy:    %d", M.total_destroy or 0))
	print(string.format("  Forced category:   %d always-precache BPs", forced_count))
	print(string.format("  Age-1 excluded:    %d sources, %d targets", M.excluded_age1_sources or 0, M.excluded_age1_targets or 0))
	print(string.format("  Init timing:       %.3fs (precache %.3fs)", M.init_elapsed or 0, M.precache_elapsed or 0))
	print(string.format("  Unit precache ops: %d (%d failed)", M.total_precached or 0, M.total_precache_failed or 0))
	print(string.format("  Warmup spawned:    %d (%d failed)", M.total_entity_precached or 0, M.total_entity_precache_failed or 0))
	print(string.format("  Precache skipped:  age1=%d | age_met=%d", M.skipped_precache_age1 or 0, M.skipped_precache_age_met or 0))
	print("")
	print("  --- Runtime Guard ---")
	print(string.format("  Required checks: %d | Hits: %d | Misses: %d",
		M.runtime_checks or 0, M.runtime_hits or 0, M.runtime_misses or 0))
	print(string.format("  Runtime skipped: age1=%d | age_met=%d",
		M.runtime_skipped_age1 or 0, M.runtime_skipped_age_met or 0))
	if M.runtime_context ~= nil then
		local ctx_keys = {}
		for ctx, counts in pairs(M.runtime_context) do
			if counts ~= nil and (counts.checks or 0) > 0 then
				table.insert(ctx_keys, ctx)
			end
		end
		table.sort(ctx_keys)
		if #ctx_keys > 0 then
			print("  Runtime by context:")
			for _, ctx in ipairs(ctx_keys) do
				local counts = M.runtime_context[ctx] or {}
				print(string.format("    %s: checks=%d hits=%d misses=%d",
					tostring(ctx), counts.checks or 0, counts.hits or 0, counts.misses or 0))
			end
		end
	end
	if (M.runtime_checks or 0) == 0 then
		print("  [WARN] Runtime guard has 0 checks in this match (init-time manifest only)")
	end
	if (M.total_gaps or 0) > 0 then
		print("")
		print("  [WARNING] Gaps found — use Debug_PrecacheManifest_Gaps() for details")
	else
		print("")
		print("  [OK] All conversion routes confirmed safe")
	end
end

function Debug_PrecacheManifest_Gaps()
	print("")
	print("=== PRECACHE MANIFEST — UNRESOLVED GAPS ===")
	if _PRECACHE_MANIFEST == nil then
		print("  [FAIL] _PRECACHE_MANIFEST not initialized")
		return
	end
	local M = _PRECACHE_MANIFEST
	if M.gaps == nil or #M.gaps == 0 then
		print("  [OK] No gaps — all conversion targets verified")
		return
	end
	print(string.format("  Total gaps: %d", M.total_gaps or 0))
	print("")
	local by_bp = {}
	for _, gap in ipairs(M.gaps) do
		if by_bp[gap.src_bp] == nil then
			by_bp[gap.src_bp] = {}
		end
		table.insert(by_bp[gap.src_bp], gap)
	end
	for src_bp, routes in pairs(by_bp) do
		print(string.format("  [GAP] %s x%d unresolved routes", src_bp, #routes))
		for i, gap in ipairs(routes) do
			if i <= 5 then
				print(string.format("        %s -> %s (route=%s)", gap.src_civ, gap.rcv_civ, gap.route or "nil"))
			end
		end
		if #routes > 5 then
			print(string.format("        ... and %d more", #routes - 5))
		end
	end
	print("")
	print("  Recommendation: add receiver-class maps or explicit archetype policies")
end

function Debug_PrecacheManifest_Confirmed()
	print("")
	print("=== PRECACHE MANIFEST — CONFIRMED SAFE TARGETS ===")
	if _PRECACHE_MANIFEST == nil then
		print("  [FAIL] _PRECACHE_MANIFEST not initialized")
		return
	end
	local M = _PRECACHE_MANIFEST
	if M.confirmed == nil or next(M.confirmed) == nil then
		print("  [INFO] No confirmed targets recorded")
		return
	end
	local targets = {}
	for bp_name, _ in pairs(M.confirmed) do
		table.insert(targets, bp_name)
	end
	table.sort(targets)
	print(string.format("  Total confirmed: %d unique target BPs", #targets))
	print("")
	for _, bp_name in ipairs(targets) do
		print(string.format("    %s", bp_name))
	end
end

function Debug_PrecacheManifest_Report()
	print("")
	print("============================================================")
	print("  PRECACHE MANIFEST — FULL COVERAGE REPORT")
	print("============================================================")
	if _PRECACHE_MANIFEST == nil then
		print("  [FAIL] _PRECACHE_MANIFEST not initialized")
		return
	end
	local M = _PRECACHE_MANIFEST
	local total_routes = M.total_routes or 0
	local confirmed = M.total_confirmed or 0
	local gaps = M.total_gaps or 0
	local destroy = M.total_destroy or 0
	local accounted = confirmed + gaps + destroy
	local forced_count = 0
	if _LEAVER_PRECACHE_ALWAYS_REQUIRED_BP then
		for _ in pairs(_LEAVER_PRECACHE_ALWAYS_REQUIRED_BP) do
			forced_count = forced_count + 1
		end
	end
	print(string.format("  Init time:      %.3fs", M.init_elapsed or 0))
	print(string.format("  Precache time:  %.3fs", M.precache_elapsed or 0))
	print(string.format("  Precache ops:   %d (%d failed)", M.total_precached or 0, M.total_precache_failed or 0))
	print(string.format("  Warmup spawned: %d (%d failed)", M.total_entity_precached or 0, M.total_entity_precache_failed or 0))
	print(string.format("  Precache skipped: age1=%d | age_met=%d", M.skipped_precache_age1 or 0, M.skipped_precache_age_met or 0))
	print(string.format("  Forced category: %d always-precache BPs", forced_count))
	print(string.format("  Source BPs:     %d", M.total_src_bps or 0))
	print(string.format("  Age-1 excluded: %d sources, %d targets", M.excluded_age1_sources or 0, M.excluded_age1_targets or 0))
	print(string.format("  Total routes:   %d", total_routes))
	print("")
	print("=== ROUTE BREAKDOWN ===")
	print(string.format("  Confirmed safe:   %d (%.1f%%)", confirmed, total_routes > 0 and (confirmed / total_routes * 100) or 0))
	print(string.format("  Destroy-policy:   %d (%.1f%%)", destroy, total_routes > 0 and (destroy / total_routes * 100) or 0))
	print(string.format("  Unresolved gaps:  %d (%.1f%%)", gaps, total_routes > 0 and (gaps / total_routes * 100) or 0))
	print(string.format("  Accounted:        %d/%d", accounted, total_routes))
	print("")
	print("=== RUNTIME GUARD ===")
	print(string.format("  Required checks: %d | Hits: %d | Misses: %d",
		M.runtime_checks or 0, M.runtime_hits or 0, M.runtime_misses or 0))
	print(string.format("  Runtime skipped: age1=%d | age_met=%d",
		M.runtime_skipped_age1 or 0, M.runtime_skipped_age_met or 0))
	if M.runtime_context ~= nil then
		local ctx_keys = {}
		for ctx, counts in pairs(M.runtime_context) do
			if counts ~= nil and (counts.checks or 0) > 0 then
				table.insert(ctx_keys, ctx)
			end
		end
		table.sort(ctx_keys)
		if #ctx_keys > 0 then
			print("  Runtime by context:")
			for _, ctx in ipairs(ctx_keys) do
				local counts = M.runtime_context[ctx] or {}
				print(string.format("    %s: checks=%d hits=%d misses=%d",
					tostring(ctx), counts.checks or 0, counts.hits or 0, counts.misses or 0))
			end
		end
	end
	if (M.runtime_checks or 0) == 0 then
		print("  [WARN] Runtime guard has 0 checks in this match (init-time manifest only)")
	end
	print("")
	print("=== CIV COVERAGE ===")
	local present = {}
	for _, player in ipairs(PLAYERS) do
		if player ~= nil and player.id ~= nil and not Core_IsPlayerEliminated(player.id) then
			local civ = Player_GetRaceName(player.id)
			if civ ~= nil then
				present[civ] = true
			end
		end
	end
	local present_list = {}
	for civ, _ in pairs(present) do table.insert(present_list, civ) end
	table.sort(present_list)
	print(string.format("  Present civs: %s", (#present_list > 0) and table.concat(present_list, ", ") or "none"))
	if _LEAVER_PRECACHE_TARGET_CIVS ~= nil then
		local missing_targets = {}
		for civ, enabled in pairs(_LEAVER_PRECACHE_TARGET_CIVS) do
			if enabled and not present[civ] then
				table.insert(missing_targets, civ)
			end
		end
		table.sort(missing_targets)
		if #missing_targets > 0 then
			print(string.format("  [WARN] Missing target civs for known issue validation: %s", table.concat(missing_targets, ", ")))
		else
			print("  [OK] All target civs for known issue validation are present")
		end
	end
	print("")
	if gaps == 0 then
		print("  >>> MANIFEST COMPLETE — All spawned unit conversions verified safe <<<")
	else
		print(string.format("  >>> MANIFEST INCOMPLETE — %d gaps <<<", gaps))
		print("  Run Debug_PrecacheManifest_Gaps() for details")
	end

	-- Optional weapon-audit section (populated by Debug_LeaverWeaponAudit)
	if _WEAPON_AUDIT_RESULTS ~= nil then
		local W = _WEAPON_AUDIT_RESULTS
		print("")
		print("=== WEAPON-AUDIT (from last Debug_LeaverWeaponAudit run) ===")
		print(string.format("  Weapon OK:       %d / %d", W.weapon_ok or 0, W.total or 0))
		print(string.format("  Weapon missing:  %d", W.weapon_missing or 0))
		print(string.format("  Query errors:    %d", W.weapon_query_error or 0))
		print(string.format("  Spawn errors:    %d", W.spawn_error or 0))
		print(string.format("  BP phantoms:     %d", W.bp_phantom or 0))
		if (W.weapon_missing or 0) == 0 and (W.spawn_error or 0) == 0 and (W.bp_phantom or 0) == 0 then
			print("  >>> WEAPON LAYER CLEAR <<<")
		else
			print("  >>> WEAPON LAYER HAS ISSUES — run Debug_LeaverWeaponAudit() for details <<<")
		end
	else
		print("")
		print("  [INFO] Weapon-audit not yet run — use Debug_LeaverWeaponAudit() for sub-resource inspection")
	end
end

---------------------------------------------------------------------------------------------------
-- COMMAND 6: Spawner-Exempt Age-Bypass Proof
-- Validates the static BP-name prefix table that exempts spawner-utilized unit types
-- from age blocking. No squad spawning needed — purely static analysis.
--
-- Tests:
--   1. Positive: all 3 exempt prefixes match expected BP names
--   2. Negative: non-exempt BPs (trebuchet, bombard) are NOT exempt
--   3. Reward tree: resolves all reward-tree BPs across all civs and confirms
--      resolved targets match the exempt list
--   4. Live route: for a src→dst player pair, resolves real routes and confirms
--      spawner-exempt targets get AGE-EXEMPT instead of AGE-BLOCK
--
-- Usage: Debug_LeaverSpawnerExemptProof()                  -- auto-select alive pair
--        Debug_LeaverSpawnerExemptProof(src_idx, dst_idx)  -- specify by PLAYERS index
---------------------------------------------------------------------------------------------------
function Debug_LeaverSpawnerExemptProof(src_idx, dst_idx)
	print("")
	print("============================================================")
	print("  CBA DEBUG — SPAWNER-EXEMPT AGE-BYPASS PROOF")
	print("============================================================")

	local pass_count = 0
	local fail_count = 0

	-- Guard: prerequisite globals
	if type(_Leaver_IsSpawnerExemptBP) ~= "function" then
		print("[FAIL] _Leaver_IsSpawnerExemptBP not available")
		return false, "missing_fn"
	end
	if _LEAVER_SPAWNER_EXEMPT_PREFIXES == nil then
		print("[FAIL] _LEAVER_SPAWNER_EXEMPT_PREFIXES table not defined")
		return false, "missing_table"
	end
	if type(_ResolveMilitaryRoute) ~= "function" then
		print("[FAIL] _ResolveMilitaryRoute not available")
		return false, "missing_fn"
	end
	if type(_Leaver_MeetsAgeRequirement) ~= "function" then
		print("[FAIL] _Leaver_MeetsAgeRequirement not available")
		return false, "missing_fn"
	end

	-- === TEST 1: Positive — exempt prefixes match expected BPs ===
	print("")
	print("--- TEST 1: Positive prefix matching ---")
	local positive_cases = {
		"unit_manatarms_3_eng", "unit_manatarms_3_mon", "unit_manatarms_3_mal",
		"unit_knight_4_eng", "unit_knight_4_fra", "unit_knight_4_hre",
		"unit_horseman_4_mal", "unit_horseman_4_eng",
	}
	for _, bp in ipairs(positive_cases) do
		local result = _Leaver_IsSpawnerExemptBP(bp)
		if result then
			print(string.format("  [PASS] %s → exempt=true", bp))
			pass_count = pass_count + 1
		else
			print(string.format("  [FAIL] %s → exempt=false (expected true)", bp))
			fail_count = fail_count + 1
		end
	end

	-- === TEST 2: Negative — non-exempt BPs are NOT exempt ===
	print("")
	print("--- TEST 2: Negative cases ---")
	local negative_cases = {
		"unit_trebuchet_4_eng", "unit_bombard_4_fra", "unit_archer_2_eng",
		"unit_crossbowman_3_eng", "unit_spearman_1_eng", "unit_horseman_3_eng",
		"unit_knight_3_eng", "unit_manatarms_2_eng", "unit_manatarms_4_eng",
	}
	for _, bp in ipairs(negative_cases) do
		local result = _Leaver_IsSpawnerExemptBP(bp)
		if not result then
			print(string.format("  [PASS] %s → exempt=false", bp))
			pass_count = pass_count + 1
		else
			print(string.format("  [FAIL] %s → exempt=true (expected false)", bp))
			fail_count = fail_count + 1
		end
	end

	-- Edge cases
	local edge_nil = _Leaver_IsSpawnerExemptBP(nil)
	local edge_empty = _Leaver_IsSpawnerExemptBP("")
	if not edge_nil and not edge_empty then
		print("  [PASS] nil/empty → exempt=false")
		pass_count = pass_count + 1
	else
		print(string.format("  [FAIL] edge: nil=%s empty=%s", tostring(edge_nil), tostring(edge_empty)))
		fail_count = fail_count + 1
	end

	-- === TEST 3: Reward tree target coverage ===
	print("")
	print("--- TEST 3: Reward tree target coverage ---")
	if _CBA_REWARDS_ONSLAUGHT ~= nil and type(_CBA_REWARDS_ONSLAUGHT) == "table" then
		local reward_exempt = 0
		local reward_non_exempt = 0
		local reward_checked = 0
		-- Collect all BPs from all civ reward trees
		for civ_key, civ_data in pairs(_CBA_REWARDS_ONSLAUGHT) do
			if type(civ_data) == "table" then
				for _, entry in ipairs(civ_data) do
					if type(entry) == "table" and entry.unit ~= nil then
						local bp_name = nil
						if type(entry.unit) == "string" then
							bp_name = entry.unit
						else
							local ok_name, name = pcall(BP_GetName, entry.unit)
							if ok_name then bp_name = name end
						end
						if bp_name ~= nil then
							reward_checked = reward_checked + 1
							if _Leaver_IsSpawnerExemptBP(bp_name) then
								reward_exempt = reward_exempt + 1
							else
								reward_non_exempt = reward_non_exempt + 1
							end
						end
					end
				end
			end
		end
		print(string.format("  Checked %d reward-tree BPs: %d exempt, %d non-exempt",
			reward_checked, reward_exempt, reward_non_exempt))
		if reward_exempt > 0 then
			print(string.format("  [PASS] %d reward BPs directly match exempt prefixes", reward_exempt))
			pass_count = pass_count + 1
		else
			print("  [INFO] No direct prefix matches in reward tree — expected if civs use unique names")
			-- Not a failure: unique names resolve via archetype fallback to exempt targets
		end
	else
		print("  [SKIP] _CBA_REWARDS_ONSLAUGHT not loaded — cannot check reward tree")
	end

	-- === TEST 4: Live route resolution with age gate ===
	print("")
	print("--- TEST 4: Live route resolution ---")
	if PLAYERS == nil then
		print("  [SKIP] PLAYERS not available")
	else
		local src_player, dst_player
		if src_idx ~= nil and dst_idx ~= nil then
			src_player = PLAYERS[src_idx]
			dst_player = PLAYERS[dst_idx]
		else
			for _, p in ipairs(PLAYERS) do
				if not p.isLocal and not Core_IsPlayerEliminated(p.id) then
					if src_player == nil then src_player = p
					elseif dst_player == nil and p ~= src_player then dst_player = p end
				end
			end
		end

		if src_player ~= nil and dst_player ~= nil then
			local src_civ = Player_GetRaceName(src_player.id)
			local dst_civ = Player_GetRaceName(dst_player.id)
			local dst_age = Player_GetCurrentAge(dst_player.id)
			print(string.format("  src=%s  dst=%s (age=%d)", src_civ, dst_civ, dst_age))

			-- Save and disable bypass flags
			local saved_bypass = _LEAVER_DEBUG_BYPASS_GATES
			local saved_cap = _LEAVER_DEBUG_BYPASS_CAPABILITY_GATES
			_LEAVER_DEBUG_BYPASS_GATES = false
			_LEAVER_DEBUG_BYPASS_CAPABILITY_GATES = false

			-- Test exempt archetypes
			local exempt_probes = {
				"unit_manatarms_3_", "unit_knight_4_", "unit_horseman_4_",
			}
			local src_suffix = (type(_Leaver_GetMilitarySuffix) == "function") and _Leaver_GetMilitarySuffix(src_civ) or src_civ
			local exempt_tested = 0
			local exempt_pass = 0
			for _, prefix in ipairs(exempt_probes) do
				local probe_bp = prefix .. src_suffix
				local ok_route, route = pcall(_ResolveMilitaryRoute, probe_bp, src_civ, dst_civ)
				if ok_route and route ~= nil and route.to_sbp ~= nil then
					local target_bp = route.bp_name
					local is_exempt = _Leaver_IsSpawnerExemptBP(target_bp)
					local log_snap = #_LEAVER_AUDIT_LOG
					local age_result = _Leaver_MeetsAgeRequirement(target_bp, nil, dst_player.id, "exempt_proof")
					while #_LEAVER_AUDIT_LOG > log_snap do table.remove(_LEAVER_AUDIT_LOG) end

					exempt_tested = exempt_tested + 1
					local verdict = "?"
					if age_result == "blocked" and is_exempt then
						verdict = "AGE-BLOCKED→EXEMPT (correct)"
						exempt_pass = exempt_pass + 1
					elseif age_result == "ok" or age_result == "bypassed" then
						verdict = "AGE-OK (gate did not trigger — receiver age sufficient)"
						exempt_pass = exempt_pass + 1 -- still valid: no block needed
					elseif age_result == "blocked" and not is_exempt then
						verdict = "AGE-BLOCKED + NOT EXEMPT (unexpected)"
					end
					print(string.format("  [%s] %s → %s (%s) | %s",
						(age_result == "blocked" and not is_exempt) and "FAIL" or "PASS",
						probe_bp, target_bp, route.route, verdict))
				end
			end
			if exempt_tested > 0 and exempt_pass == exempt_tested then
				print(string.format("  [PASS] %d/%d exempt archetype routes verified", exempt_pass, exempt_tested))
				pass_count = pass_count + 1
			elseif exempt_tested > 0 then
				print(string.format("  [FAIL] %d/%d exempt archetype routes passed", exempt_pass, exempt_tested))
				fail_count = fail_count + 1
			end

			-- Test non-exempt control (trebuchet should remain blocked)
			local control_bp = "unit_trebuchet_4_" .. src_suffix
			local ok_ctrl, ctrl_route = pcall(_ResolveMilitaryRoute, control_bp, src_civ, dst_civ)
			if ok_ctrl and ctrl_route ~= nil and ctrl_route.to_sbp ~= nil then
				local ctrl_exempt = _Leaver_IsSpawnerExemptBP(ctrl_route.bp_name)
				if not ctrl_exempt then
					print(string.format("  [PASS] %s → NOT exempt (control)", control_bp))
					pass_count = pass_count + 1
				else
					print(string.format("  [FAIL] %s → exempt=true (should not be)", control_bp))
					fail_count = fail_count + 1
				end
			end

			_LEAVER_DEBUG_BYPASS_GATES = saved_bypass
			_LEAVER_DEBUG_BYPASS_CAPABILITY_GATES = saved_cap
		else
			print("  [SKIP] Cannot find two alive non-local players")
		end
	end

	-- === Summary ===
	local total_pass = fail_count == 0
	print("")
	print("============================================================")
	print(string.format("  SPAWNER-EXEMPT PROOF: %s  (pass=%d fail=%d)",
		total_pass and "PASS" or "FAIL", pass_count, fail_count))
	print(string.format("  Prefixes: %s", table.concat(_LEAVER_SPAWNER_EXEMPT_PREFIXES, ", ")))
	print("============================================================")

	return total_pass, total_pass and "exempt_proof_ok" or "exempt_proof_fail"
end

-- Console-friendly global alias for the registered all-pairs matrix command key.
-- Usage: leaver_matrix_all_pairs() or leaver_matrix_all_pairs("verbose")
function leaver_matrix_all_pairs(opt_mode)
	return Debug_LeaverCrossCivMatrix(opt_mode)
end

---------------------------------------------------------------------------------------------------
-- Namespace Registration
---------------------------------------------------------------------------------------------------
if debug then
	debug.leaver = debug.leaver or {}
	debug.leaver.mil = debug.leaver.mil or {}
	debug.leaver.coverage = debug.leaver.coverage or {}

	-- Hierarchical leaver aliases (compat): debug.leaver.*
	debug.leaver.run = Debug_LeaverConversion_Full
	debug.leaver.inspect = Debug_LeaverConversion_Inspect
	debug.leaver.stress = Debug_LeaverConversion_Stress
	debug.leaver.visual = Debug_LeaverConversion_Visual
	debug.leaver.resolve = Debug_LeaverConversion_MilResolve
	debug.leaver.validation = Debug_LeaverValidation
	debug.leaver.performance = Debug_LeaverPerformance
	debug.leaver.status = Debug_LeaverPipelineStatus
	debug.leaver.full_validation_all = Debug_FullValidation_All

	debug.leaver.mil.test = Debug_LeaverMilTest
	debug.leaver.mil.proof = Debug_LeaverMilProof_OneShot
	debug.leaver.mil.pair = Debug_LeaverMilCoverage_Pair
	debug.leaver.mil.all = Debug_LeaverMilCoverage_AllPairs
	debug.leaver.mil.matrix = Debug_LeaverCrossCivMatrix
	debug.leaver.mil.exempt_proof = Debug_LeaverSpawnerExemptProof

	debug.leaver.coverage.all = Debug_LeaverCoverage_AllCivPairs
	debug.leaver.coverage.civ = Debug_LeaverCoverage_Civ
	debug.leaver.coverage.pair = Debug_LeaverCoverage_Pair

	debug.leaver.precache = debug.leaver.precache or {}
	debug.leaver.precache.summary = Debug_PrecacheManifest_Summary
	debug.leaver.precache.gaps = Debug_PrecacheManifest_Gaps
	debug.leaver.precache.confirmed = Debug_PrecacheManifest_Confirmed
	debug.leaver.precache.report = Debug_PrecacheManifest_Report
	debug.leaver.precache.forced = Debug_LeaverResolve_ForcedBP
	debug.leaver.precache.weaponaudit = Debug_LeaverWeaponAudit
	debug.leaver.precache.weaponaudit_rcv = Debug_LeaverWeaponAudit_ReceiverClass
	debug.leaver.precache.forcedcoverage = Debug_PrecacheManifest_ForcedCoverage
	debug.leaver.precache.transfer = Debug_LeaverTransferInspector
	debug.leaver.precache.transfer_all = Debug_LeaverTransferInspector_AllPairs

	-- Convenience alias: debug.leaver.crossciv.* redirects to debug.leaver.mil.*
	-- Prevents fatal nil-index errors from the common mistyping.
	debug.leaver.crossciv = debug.leaver.crossciv or {}
	debug.leaver.crossciv.matrix = debug.leaver.mil.matrix

	debug.players.leaver             = Debug_LeaverConversion_Full
	debug.players.leaverInspect      = Debug_LeaverConversion_Inspect
	debug.players.leaverStress       = Debug_LeaverConversion_Stress
	debug.players.leaverVisual       = Debug_LeaverConversion_Visual
	debug.players.leaverMilResolve   = Debug_LeaverConversion_MilResolve
	debug.players.leaverCoverage     = Debug_LeaverCoverage_AllCivPairs
	debug.players.leaverPerformance  = Debug_LeaverPerformance
	debug.players.leaverStatus       = Debug_LeaverPipelineStatus
	debug.players.full_validation_all = function(idx, mode)
		idx = idx or 2
		if not debug._safety.validate_target(idx) then return end
		Debug_FullValidation_All(idx, mode)
	end
	debug.players.forceDisconnect    = function(idx)
		if not debug._safety.validate_target(idx) then return end
		Debug_ForceDisconnect(idx)
	end
	debug.players.forceAnnihilation  = function(idx)
		if not debug._safety.validate_target(idx) then return end
		Debug_ForceAnnihilation(idx)
	end

	--- System master: full system validation across all player subsystems.
	-- Runs Debug_FullSystemValidation which handles its own async deferred pipeline.
	-- Safety-gated: excludes human player by default.
	-- @param player_idx  number  1-based player index to disconnect (default 2)
	function debug.players.run(player_idx)
		player_idx = player_idx or 2
		if not debug._safety.validate_target(player_idx) then return end
		Debug_FullSystemValidation(player_idx)
	end

	debug._register("leaver", Debug_LeaverConversion_Full, "Leaver pipeline: 6-stage conversion, coverage, stress, performance", 2)
	debug._register("leaver_matrix_all_pairs", Debug_LeaverCrossCivMatrix, "Directed all-player pair matrix (mil+bldg) with global cross-civ route coverage", 2)
	debug._register("players", debug.players.run, "Player full system validation: leaver + limits + siege cross-val (safety-gated)", 2)
	debug._register("full_validation_all", debug.players.full_validation_all, "One-command leaver full + building/military matrix + house guard", 2)
	debug._register("leaver_exempt_proof", Debug_LeaverSpawnerExemptProof, "Spawner-exempt age-bypass proof: validates BP-name prefix table covers all reward archetypes", 2)
end
