---------------------------------------------------------------------------------------------------
-- CBA Debug — Leaver Tests
-- Tests disconnect, transfer, and annihilation edge cases.
-- WARNING: These functions MODIFY GAME STATE.
-- Console: Debug_LeaverValidation(), Debug_ForceDisconnect(1)
---------------------------------------------------------------------------------------------------

---------------------------------------------------------------------------------------------------
-- Disconnect Simulation
---------------------------------------------------------------------------------------------------

function Debug_ForceDisconnect(player_idx)
	if player_idx == nil then
		print("[DEBUG_LEAVER] Usage: Debug_ForceDisconnect(player_index)")
		return
	end

	local player = PLAYERS[player_idx]
	if player == nil then
		print(string.format("[DEBUG_LEAVER] PLAYERS[%d] is nil", player_idx))
		return
	end

	if Core_IsPlayerEliminated(player.id) then
		print(string.format("[DEBUG_LEAVER] Player %d already eliminated", player_idx))
		return
	end

	print(string.format("[DEBUG_LEAVER] Simulating disconnect for Player %d", player_idx))

	-- Snapshot pre-disconnect
	local eg = Player_GetEntities(player.id)
	local entity_count = EGroup_CountAlive(eg)
	local sg = Player_GetSquads(player.id)
	local squad_count = SGroup_CountAlive(sg)
	print(string.format("  Pre-disconnect: %d entities, %d squads", entity_count, squad_count))

	-- Trigger through standard elimination path
	if type(Mod_EliminatePlayerUnits) == "function" then
		Mod_EliminatePlayerUnits(player, nil, false)
	else
		Core_SetPlayerDefeated(player.id, Annihilation_LoserPresentation, WR_DISCONNECT)
	end

	print("  Disconnect triggered. Monitor transfer and counter updates.")
end

---------------------------------------------------------------------------------------------------
-- Transfer Validation (non-destructive read)
---------------------------------------------------------------------------------------------------

function Debug_TransferValidation(src_idx, dst_idx)
	if src_idx == nil or dst_idx == nil then
		print("[DEBUG_LEAVER] Usage: Debug_TransferValidation(src_index, dst_index)")
		return
	end

	local src = PLAYERS[src_idx]
	local dst = PLAYERS[dst_idx]
	if src == nil or dst == nil then
		print("[DEBUG_LEAVER] Invalid player indices")
		return
	end

	print(string.format("[DEBUG_LEAVER] Transfer validation: Player %d -> Player %d", src_idx, dst_idx))

	-- Check team relationship
	local same_team = Player_ObserveRelationship(src.id, dst.id) == R_ALLY
	print(string.format("  Same team: %s", tostring(same_team)))

	-- Source state
	local src_eliminated = Core_IsPlayerEliminated(src.id)
	print(string.format("  Source eliminated: %s", tostring(src_eliminated)))

	-- Dest capacity
	local dst_bl = dst.obj_buildingLimit_count or 0
	local max_bl = 0
	if _buildingLimit ~= nil and _buildingLimit.max ~= nil then
		max_bl = _buildingLimit.max
	end
	print(string.format("  Dest building count: %d/%d", dst_bl, max_bl))

	-- Dest siege
	local dst_sl = dst.siegeLimit_count or 0
	local max_sl = 0
	if _buildingLimit ~= nil and _buildingLimit.siegeMax ~= nil then
		max_sl = _buildingLimit.siegeMax
	end
	print(string.format("  Dest siege count: %d/%d", dst_sl, max_sl))

	-- Entity counts
	local src_eg = Player_GetEntities(src.id)
	local dst_eg = Player_GetEntities(dst.id)
	print(string.format("  Source entities: %d", EGroup_CountAlive(src_eg)))
	print(string.format("  Dest entities: %d", EGroup_CountAlive(dst_eg)))
end

---------------------------------------------------------------------------------------------------
-- Leaver Validation Suite
---------------------------------------------------------------------------------------------------

function Debug_LeaverValidation()
	_cba_debug.enabled = true

	print("")
	print("============================================")
	print("  CBA DEBUG — LEAVER VALIDATION")
	print("============================================")

	local issues = 0

	-- Check all players for orphaned entities after elimination
	for i, player in ipairs(PLAYERS) do
		if Core_IsPlayerEliminated(player.id) then
			local eg = Player_GetEntities(player.id)
			local count = EGroup_CountAlive(eg)
			if count > 0 then
				print(string.format("  [WARN] Eliminated Player %d still has %d entities", i, count))
				issues = issues + 1
			else
				print(string.format("  [OK] Eliminated Player %d has 0 entities", i))
			end
		end
	end

	-- Check building limit consistency for alive players
	for i, player in ipairs(PLAYERS) do
		if not Core_IsPlayerEliminated(player.id) then
			local counted = player.obj_buildingLimit_count or 0
			if counted < 0 then
				print(string.format("  [WARN] Player %d has negative building count: %d", i, counted))
				issues = issues + 1
			end

			local siege = player.siegeLimit_count or 0
			if siege < 0 then
				print(string.format("  [WARN] Player %d has negative siege count: %d", i, siege))
				issues = issues + 1
			end
		end
	end

	-- Summary
	print("")
	if issues == 0 then
		print("  LEAVER VALIDATION: ALL CLEAR")
	else
		print(string.format("  LEAVER VALIDATION: %d issue(s) found", issues))
	end
end

---------------------------------------------------------------------------------------------------
-- Force Annihilation
---------------------------------------------------------------------------------------------------

function Debug_ForceAnnihilation(player_idx)
	if player_idx == nil then
		print("[DEBUG_LEAVER] Usage: Debug_ForceAnnihilation(player_index)")
		return
	end

	local player = PLAYERS[player_idx]
	if player == nil then
		print(string.format("[DEBUG_LEAVER] PLAYERS[%d] is nil", player_idx))
		return
	end

	if Core_IsPlayerEliminated(player.id) then
		print(string.format("[DEBUG_LEAVER] Player %d already eliminated", player_idx))
		return
	end

	print(string.format("[DEBUG_LEAVER] Forcing annihilation for Player %d", player_idx))

	-- Kill all entities
	local eg = Player_GetEntities(player.id)
	local count = EGroup_CountAlive(eg)
	print(string.format("  Killing %d entities...", count))
	EGroup_DestroyAllEntities(eg)

	-- Kill all squads
	local sg = Player_GetSquads(player.id)
	local scount = SGroup_CountAlive(sg)
	print(string.format("  Killing %d squads...", scount))
	SGroup_DestroyAllSquads(sg)

	print("  Annihilation complete. Monitor win condition triggers.")
end

---------------------------------------------------------------------------------------------------
-- Leaver Balance State (read-only)
---------------------------------------------------------------------------------------------------

function Debug_GetLeaverBalanceState()
	print("")
	print("[DEBUG_LEAVER] Post-Leaver Balance State:")

	local alive_players = 0
	local alive_teams = {}

	for i, player in ipairs(PLAYERS) do
		if not Core_IsPlayerEliminated(player.id) then
			alive_players = alive_players + 1
			local team = Player_GetTeam(player.id)
			alive_teams[team] = (alive_teams[team] or 0) + 1
		end
	end

	print(string.format("  Alive players: %d / %d", alive_players, #PLAYERS))

	for team, count in pairs(alive_teams) do
		print(string.format("  Team %d: %d alive", team, count))
	end

	-- Check for game-ending imbalance
	local team_count = 0
	for _ in pairs(alive_teams) do
		team_count = team_count + 1
	end

	if team_count <= 1 and alive_players > 0 then
		print("  [WARN] Only one team remains — game should end soon")
	elseif alive_players == 0 then
		print("  [WARN] No alive players — check for draw condition")
	end
end
