---------------------------------------------------------------------------------------------------

Debug_RegisterModule({
	name        = "ai_stress",
	tags        = { "ai_stress", "ai_robustness" },
	tier        = 3,
	depends     = { "core", "ai_player_test" },
	state_tables = { "_ai_players" },
	required_game = { "PLAYERS", "_AI_IsEliminated" },
	namespace   = "ai_stress",
	description = "15-category AI player stress, edge-case, and robustness verification suite",
}, {
	full       = Debug_AIStressTest,
	category   = Debug_AIStressCategory,
})

if debug then
	debug._register("ai_stress", Debug_AIStressTest,
		"15-category AI stress & robustness (invariants, construction, army, villagers, zones, elimination, economy, patrol, telemetry, handlers, placement, throughput, maa, wall/stage/zone, producers)", 3)
end
