---------------------------------------------------------------------------------------------------
-- CBA Debug — Entry Point
-- Imports all debug sub-files in dependency order.
-- Loaded via: cba.scar → import("cba_debug.scar") → import("debug/cba_debug.scar")
--
-- Branch: onslaught-v3.3
-- Source files validated: cba.scar, rewards/cba_rewards.scar, cba_annihilation.scar,
--   cba_religious.scar, wonder.scar, cba_options.scar, cba_auto_age.scar,
--   ags_global_settings.scar, gameplay/cba_economy.scar
-- State tables: _mod, _CBA, _buildingLimit, _autoage, _annihilation, _religious, _wonder,
--   AGS_GLOBAL_SETTINGS
---------------------------------------------------------------------------------------------------

-- Infrastructure registries (loaded before core so modules can register during import)
import("debug/cba_debug_settings.scar")
import("debug/cba_debug_registry.scar")
import("debug/cba_debug_rules.scar")

-- Core (state, logging, test runner, reusable helpers — depends on registries above)
