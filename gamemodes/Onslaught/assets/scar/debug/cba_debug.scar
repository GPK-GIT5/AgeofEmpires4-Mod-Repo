-- 12-category comprehensive stress suite
import("debug/cba_debug_comprehensive_stress.scar")

-- 8-scenario AI behavior validation (visual + Q&A)
import("debug/cba_debug_ai_behavior.scar")

-- 8-topic Q&A diagnostic runner
import("debug/cba_debug_qa_runner.scar")

-- PlayerUI initialization/data/rendering diagnostics
import("debug/cba_debug_playerui.scar")

-- PlayerUI animation/crash isolation diagnostics
import("debug/cba_debug_playerui_anim.scar")

-- 7-stage scenario orchestrator
import("debug/cba_debug_scenario.scar")

-- Unified siege test: BP audit + ram/ST/weapons/SE/field/workshop/events (1 command: Debug_SiegeTest)
import("debug/cba_debug_siege_test.scar")

-- Blueprint existence audit (1 command: Debug_BlueprintAudit)
import("debug/cba_debug_blueprint_audit.scar")

-- Boon selection UI diagnostics (BoonDebug_ShowTestPanel, BoonDebug_ShowTemplar, etc.)
import("debug/cba_debug_boon_selection.scar")

-- Structured civ data overview and consistency audit
import("debug/cba_debug_civ_overview.scar")

-- Runtime data extraction (BP enumeration, costs, garrison, race squads)
