-- Leaver military pipeline verification (routes, heroes, elephants, stats)
import("debug/cba_verify_military_pipeline.scar")

-- 10-phase AI player module verification (bootstrap, economy, buildings, production, armies, allies, scouts, outposts, events, integration)
import("debug/cba_debug_ai_player.scar")

-- Mass battle lag harness (100 men-at-arms per player to sacred site + event telemetry)
import("debug/cba_debug_battle_lag.scar")

-- 10-category AI player stress, edge-case, and robustness verification suite
import("debug/cba_debug_ai_stress.scar")

-- Single-command session stress runners (Debug_StressUI / Debug_StressGamemode)
-- Wraps every UI suite and every gamemode suite into one console command each
-- and emits machine-parseable [STRESS_SESSION_*] markers for cross-session handoff.
import("debug/cba_debug_session_stress.scar")

