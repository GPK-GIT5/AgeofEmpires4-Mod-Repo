-- 6-phase validation
import("debug/cba_debug_validation.scar")

-- Read-only inspectors
import("debug/cba_debug_inspectors.scar")

-- 8-stage stress test
import("debug/cba_debug_stress.scar")

-- 10-batch API coverage
import("debug/cba_debug_coverage.scar")

-- Event handler resilience probes
import("debug/cba_debug_event_probes.scar")

-- Destructive game-state helpers
import("debug/cba_debug_destructive.scar")

-- Building/siege limit UI diagnostics
import("debug/cba_debug_limits_ui.scar")

-- Disconnect/transfer/annihilation edge cases
import("debug/cba_debug_leaver.scar")

-- Controlled spawn sequences (spawn plan engine)
import("debug/cba_debug_spawn_sequences.scar")

-- Advanced stress scenarios (extreme edge cases)
import("debug/cba_debug_advanced_stress.scar")

-- UI-driven interactive checks (prompts, precache validation)
