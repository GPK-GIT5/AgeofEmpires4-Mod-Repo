	_bl.fps_last_game_time = 0
	_bl.wall_last_time = 0
	_bl.wall_start_time = 0
	_bl.fps_sum = 0
	_bl.fps_min = 999
	_bl.fps_max = 0
	_bl.fps_count = 0
	_bl.fps_true_count = 0
	_bl.fps_proxy_count = 0
	_bl.frame_time_sum = 0
	_bl.prev_entity_total = 0
	_bl.prev_bucket_events = 0
	_bl.prev_ge_totals = {}
	_bl.prod_total_spawned = 0
	_bl.prod_tick_count = 0
	_bl.frame_counter_total = 0
	_bl.frame_counter_window = 0
