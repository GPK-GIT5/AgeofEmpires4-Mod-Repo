local function _BL_GetSacredTarget()
	if _CBA ~= nil and _CBA.center ~= nil then
		return _CBA.center, "_CBA.center"
	end

	local ok, eg = pcall(function()
		local egroup = EGroup_Create("eg_bl_sites")
		World_GetAllNeutralEntities(egroup)
		EGroup_Filter(egroup, "special_beacon", FILTER_KEEP)
		return egroup
	end)
	if ok and eg ~= nil and EGroup_Count(eg) > 0 then
		local ent = EGroup_GetEntityAt(eg, 1)
		if ent ~= nil then
			local pos = Entity_GetPosition(ent)
			if pos ~= nil then
				return pos, "special_beacon"
			end
		end
	end

	return World_Pos(0, 0, 0), "fallback_origin"
end

local function _BL_ResolveMenAtArmsSbp(player)
	local candidates = {
		"scar_manatarms",
		"scar_men_at_arms",
		"scar_spearman",
	}
	for _, type_key in ipairs(candidates) do
		local ok, sbp = pcall(Cardinal_ConvertTypeToSquadBlueprint, type_key, player.id)
		if ok and sbp ~= nil then
			return sbp, type_key
		end
	end
	return nil, "unresolved"
end

local function _BL_ResolveCrossbowSbp(player)
	local candidates = {
		"scar_crossbowman",
		"scar_crossbow",
		"scar_archer",
	}
	for _, type_key in ipairs(candidates) do
		local ok, sbp = pcall(Cardinal_ConvertTypeToSquadBlueprint, type_key, player.id)
		if ok and sbp ~= nil then
			return sbp, type_key
		end
	end
	return nil, "unresolved"
end

-- ╔═══════════════════════════════════════════════════════════════════════════╗
-- ║  PERMANENT: _BL_RewardSpawn is the SOLE spawn entry point.              ║
-- ║  All initial, production, and respawn paths route through this.         ║
-- ║  It enforces per-player hard caps (125 MAA / 30 XBOW), routes          ║
-- ║  through CBA_Rewards_SpawnAndMove for pop-awareness + precache,         ║
-- ║  transfers squads into harness tracking SGroups via SGroup_AddGroup,    ║
-- ║  and overrides the reward system's FormationMove with AttackMove.       ║
-- ║  DO NOT bypass this function. DO NOT remove the hard cap checks.        ║
-- ║  Falls back to native UnitEntry_DeploySquads if reward system absent.   ║
-- ╚═══════════════════════════════════════════════════════════════════════════╝
local function _BL_RewardSpawn(player, sbp, count, tracking_sg, target, is_xbow)
	local pkey = "P" .. tostring(player.id)
	local cap = is_xbow and _BL_CROSSBOW_BATCH_SIZE or _BL_BATCH_SIZE
	local tag = is_xbow and "_xbow" or "_maa"

	-- PERMANENT: Per-player hard cap — 125 MAA / 30 XBOW. DO NOT raise these limits.
	local ok_alive, alive_count = pcall(SGroup_CountSpawned, tracking_sg)
	local alive = (ok_alive and alive_count) or 0
	local allowed = math.min(count, math.max(0, cap - alive))
	if allowed <= 0 then
		_BL_RecordEvent("cap_block" .. tag, pkey)
		return 0
	end

	-- Clamp to current population headroom before reward call so the reward queue path
	-- is not used by this harness. Queued spawns happen later outside this code path,
	-- which can miss deterministic attack-move dispatch during lag tests.
	if player ~= nil and player.id ~= nil then
		local ok_pop, current_pop = pcall(Player_GetCurrentPopulation, player.id, CT_Personnel)
		local ok_cap, max_pop = pcall(Player_GetCurrentPopulationCap, player.id, CT_Personnel)
		if ok_pop and ok_cap then
			local pop_allowed = math.max(0, max_pop - current_pop)
			if pop_allowed < allowed then
				allowed = pop_allowed
				_BL_RecordEvent("pop_clamp" .. tag, pkey)
			end
		end
	end
	if allowed <= 0 then
		_BL_RecordEvent("pop_block" .. tag, pkey)
		return 0
	end

	-- PERMANENT: Crossbow MUST be precached before EVERY spawn. DO NOT remove.
	if is_xbow then
		pcall(Squad_Precache, sbp, 0, player.id, "", "battle_lag", "crossbow")
	end

	-- Route through CBA Rewards system when available (pop-cap aware, precache-integrated, queue overflow)
	if type(CBA_Rewards_SpawnAndMove) == "function" then
		local reward_sg = SGroup_CreateIfNotFound("sg_reward_" .. tostring(player.id))

		-- If the reward group already has squads alive, command them immediately before
		-- reward spawn runs. This guarantees start-of-match reward units are pushed to
		-- center when Debug_BattleLagTest is active.
		local pre_existing = SGroup_CountSpawned(reward_sg) or 0
		if pre_existing > 0 and target ~= nil then
			pcall(AI_LockSquads, player.id, reward_sg)
			local ok_pre_cmd = pcall(Cmd_AttackMove, reward_sg, target, false)
			if not ok_pre_cmd then
				pcall(Cmd_Move, reward_sg, target, false)
			end
			_BL_RecordEvent("reward_preexisting_dispatch" .. tag, pkey)
		end

		CBA_Rewards_SpawnAndMove(player, sbp, allowed)

		-- Reward spawner clears sg_reward_<player> before deploy, so the spawned count
		-- after this call represents the current wave only.
		local spawned = SGroup_CountSpawned(reward_sg) or 0
		if spawned > 0 and tracking_sg ~= nil then
			pcall(SGroup_AddGroup, tracking_sg, reward_sg)
		end

		-- Override: reward system issues FormationMove toward _CBA.center;
		-- harness needs AttackMove toward the sacred site target for deterministic battle.
		if target ~= nil and spawned > 0 then
			-- Command the newly spawned reward group directly so starter/prod spawns
			-- always receive an immediate combat order in this same tick.
			pcall(AI_LockSquads, player.id, reward_sg)
			local ok_reward_cmd = pcall(Cmd_AttackMove, reward_sg, target, false)
			if not ok_reward_cmd then
				pcall(Cmd_Move, reward_sg, target, false)
			end
		end
		if target ~= nil and tracking_sg ~= nil and (SGroup_CountSpawned(tracking_sg) or 0) > 0 then
			pcall(AI_LockSquads, player.id, tracking_sg)
			local ok_track_cmd = pcall(Cmd_AttackMove, tracking_sg, target, false)
			if not ok_track_cmd then
				pcall(Cmd_Move, tracking_sg, target, false)
			end
		end

		_BL_RecordEvent("reward_spawn" .. tag, pkey)
		return spawned
	end

	-- Fallback: native deploy when reward system is not available
	local spawn_pos = _BL_ResolveSpawnAnchor(player, target)
	local ok_deploy = pcall(UnitEntry_DeploySquads, player.id, tracking_sg,
		{{ sbp = sbp, numSquads = allowed }}, spawn_pos)
	if not ok_deploy then
		_BL_AddFailure(string.format("%s%s fallback deploy failed", pkey, tag))
		return 0
	end

	pcall(AI_LockSquads, player.id, tracking_sg)
	local ok_cmd = pcall(Cmd_AttackMove, tracking_sg, target, false)
	if not ok_cmd then
		pcall(Cmd_Move, tracking_sg, target, false)
	end

	_BL_RecordEvent("native_spawn" .. tag, pkey)
	return SGroup_CountSpawned(tracking_sg) or 0
end

-- While the harness is active, continuously commandeer reward spawner groups to center.
-- This covers reward groups that already existed at test start and any late reward spawns.
function _BL_RewardGroupWatchdog()
	if not _bl.running or _bl.phase ~= "observe" then return end
	if _bl.target == nil then return end
	_BL_DispatchExistingRewardGroups(false)
end

-- Fire on activation, then every 60s:
-- select player's idle military and issue attack-move to sacred site target.
function _BL_OrderIdleMilitaryToTarget()
	if not _bl.running or _bl.phase ~= "observe" then return end
	if _bl.target == nil then return end

	for _, p in ipairs(_bl.players) do
		if p ~= nil and p.id ~= nil then
			local pkey = "P" .. tostring(p.id)
			local sg_all = Player_GetSquads(p.id)
			local sg_idle = SGroup_CreateIfNotFound("sg_bl_idle_mil_" .. tostring(p.id))
			SGroup_Clear(sg_idle)

			local total = SGroup_Count(sg_all) or 0
			for idx = 1, total do
				local squad = SGroup_GetSquadAt(sg_all, idx)
				if squad ~= nil then
					local is_idle = Squad_IsIdle(squad)
					local is_worker = Squad_IsOfType(squad, "worker")
					if is_idle and not is_worker then
						SGroup_Add(sg_idle, squad)
					end
				end
			end

			local idle_count = SGroup_CountSpawned(sg_idle) or 0
			if idle_count > 0 then
				pcall(AI_LockSquads, p.id, sg_idle)
				local ok_cmd = pcall(Cmd_AttackMove, sg_idle, _bl.target, false)
				if not ok_cmd then
					pcall(Cmd_Move, sg_idle, _bl.target, false)
				end
				_BL_RecordEvent("idle_mil_dispatch", pkey)
			end
		end
	end
end

-- Force-dispatch existing reward groups (and mirror them into harness tracking groups).
-- Used at test startup to ensure any already-alive reward units immediately attack center.
function _BL_DispatchExistingRewardGroups(force_dispatch)
	if not _bl.running then return end
	if _bl.target == nil then return end

	for _, p in ipairs(_bl.players) do
		if p ~= nil and p.id ~= nil then
			local pkey = "P" .. tostring(p.id)
			local reward_sg = SGroup_CreateIfNotFound("sg_reward_" .. tostring(p.id))
			local alive = SGroup_CountSpawned(reward_sg) or 0
			if alive > 0 then
				local should_dispatch = force_dispatch == true
				if not should_dispatch then
					should_dispatch = true
					local ok_pos, pos = pcall(SGroup_GetPosition, reward_sg)
					if ok_pos and pos ~= nil then
						local ok_d, dist = pcall(World_DistancePointToPoint, pos, _bl.target)
						if ok_d and dist <= _BL_REASSERT_DIST then
							should_dispatch = false
						end
					end
				end

				if should_dispatch then
					pcall(AI_LockSquads, p.id, reward_sg)
					local ok_cmd = pcall(Cmd_AttackMove, reward_sg, _bl.target, false)
					if not ok_cmd then
						pcall(Cmd_Move, reward_sg, _bl.target, false)
					end
					_BL_RecordEvent(force_dispatch and "reward_start_dispatch" or "reward_watchdog_dispatch", pkey)
				end
			end
		end
	end
end

local function _BL_RegisterEvents()
	CBA_EntityKillBatch_SetHandler("battle_lag", true)
	CBA_SquadKillBatch_SetHandler("battle_lag", true)
	CBA_BuildItemBatch_SetHandler("battle_lag", true)
	pcall(Rule_AddGlobalEvent, _BL_OnDamageReceived, GE_DamageReceived)
	pcall(Rule_AddGlobalEvent, _BL_OnConstructionStart, GE_ConstructionStart)
	pcall(Rule_AddGlobalEvent, _BL_OnConstructionComplete, GE_ConstructionComplete)
	pcall(Rule_AddGlobalEvent, _BL_OnUpgradeComplete, GE_UpgradeComplete)
	pcall(Rule_AddGlobalEvent, _BL_OnStrategicPointChanged, GE_StrategicPointChanged)
	pcall(Rule_AddGlobalEvent, _BL_OnProjectileLanded, GE_ProjectileLanded)
	pcall(Rule_AddGlobalEvent, _BL_OnEntityLandmarkDestroyed, GE_EntityLandmarkDestroyed)
	pcall(Rule_AddGlobalEvent, _BL_OnLocalPlayerChanged, GE_LocalPlayerChanged)
	pcall(Rule_AddGlobalEvent, _BL_OnConstructionCancelled, GE_ConstructionCancelled)
	pcall(Rule_AddGlobalEvent, _BL_OnAbilityExecuted, GE_AbilityExecuted)
	pcall(Rule_AddGlobalEvent, _BL_OnEntitySpawn, GE_EntitySpawn)
	pcall(Rule_AddGlobalEvent, _BL_OnEntityDespawn, GE_EntityDespawn)
	pcall(Rule_AddGlobalEvent, _BL_OnSquadSpawn, GE_SquadSpawn)
	pcall(Rule_AddGlobalEvent, _BL_OnProjectileFired, GE_ProjectileFired)
	pcall(Rule_AddGlobalEvent, _BL_OnBuildItemStart, GE_BuildItemStart)
	pcall(Rule_AddGlobalEvent, _BL_OnPathfindingBlockersUpdated, GE_PathfindingBlockersUpdated)
	pcall(Rule_AddGlobalEvent, _BL_OnMoveFailed, GE_MoveFailed)
	pcall(Rule_AddGlobalEvent, _BL_OnDamageArea, GE_DamageArea)
	_BL_RecordEvent("events_registered")
end

local function _BL_UnregisterEvents()
	CBA_EntityKillBatch_SetHandler("battle_lag", false)
	CBA_SquadKillBatch_SetHandler("battle_lag", false)
	CBA_BuildItemBatch_SetHandler("battle_lag", false)
	pcall(Rule_RemoveGlobalEvent, _BL_OnDamageReceived)
	pcall(Rule_RemoveGlobalEvent, _BL_OnConstructionStart)
	pcall(Rule_RemoveGlobalEvent, _BL_OnConstructionComplete)
	pcall(Rule_RemoveGlobalEvent, _BL_OnUpgradeComplete)
	pcall(Rule_RemoveGlobalEvent, _BL_OnStrategicPointChanged)
	pcall(Rule_RemoveGlobalEvent, _BL_OnProjectileLanded)
	pcall(Rule_RemoveGlobalEvent, _BL_OnEntityLandmarkDestroyed)
	pcall(Rule_RemoveGlobalEvent, _BL_OnLocalPlayerChanged)
	pcall(Rule_RemoveGlobalEvent, _BL_OnConstructionCancelled)
	pcall(Rule_RemoveGlobalEvent, _BL_OnAbilityExecuted)
	pcall(Rule_RemoveGlobalEvent, _BL_OnEntitySpawn)
	pcall(Rule_RemoveGlobalEvent, _BL_OnEntityDespawn)
	pcall(Rule_RemoveGlobalEvent, _BL_OnSquadSpawn)
	pcall(Rule_RemoveGlobalEvent, _BL_OnProjectileFired)
	pcall(Rule_RemoveGlobalEvent, _BL_OnBuildItemStart)
	pcall(Rule_RemoveGlobalEvent, _BL_OnPathfindingBlockersUpdated)
	pcall(Rule_RemoveGlobalEvent, _BL_OnMoveFailed)
	pcall(Rule_RemoveGlobalEvent, _BL_OnDamageArea)
end

function _BL_OnEntityKilled(context)
	if not _bl.running then return end
	local owner = context and context.victimOwner
	_BL_RecordEvent("GE_EntityKilled", owner and _BL_PlayerKeyById(owner) or nil)
end

function _BL_OnSquadKilled(context)
	if not _bl.running then return end
	local owner = context and context.squadOwner
	_BL_RecordEvent("GE_SquadKilled", owner and _BL_PlayerKeyById(owner) or nil)
end

-- Global wrapper for batch processor (local _BL_RecordEvent/_BL_PlayerKeyById are not visible cross-file).
function _BL_BatchSquadKilled(owner_id)
	if not _bl or not _bl.running then return end
	_BL_RecordEvent("GE_SquadKilled", owner_id and _BL_PlayerKeyById(owner_id) or nil)
end

-- Global wrapper for entity-kill batch processor.
function _BL_BatchEntityKilled(owner_id)
	if not _bl or not _bl.running then return end
	_BL_RecordEvent("GE_EntityKilled", owner_id and _BL_PlayerKeyById(owner_id) or nil)
end

-- Global wrapper for build-item-complete batch processor.
function _BL_BatchBuildItemComplete(player_handle)
	if not _bl or not _bl.running then return end
	_BL_RecordEvent("GE_BuildItemComplete", player_handle and _BL_PlayerKeyById(player_handle) or nil)
end

local function _BL_IsWonderVictim(entity)
	if entity == nil then return false end

	if type(AGS_IsAWonder) == "function" then
		local ok, is_wonder = pcall(AGS_IsAWonder, entity)
		if ok and is_wonder then
			return true
		end
	end

	if type(_wonder) == "table" and _wonder.types ~= nil and _wonder.types.age4 ~= nil then
		local ok, is_wonder = pcall(Entity_IsOfType, entity, _wonder.types.age4)
		if ok and is_wonder then
			return true
		end
	end

	return false
end

