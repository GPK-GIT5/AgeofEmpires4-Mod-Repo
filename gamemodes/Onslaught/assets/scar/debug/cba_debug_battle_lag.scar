---------------------------------------------------------------------------------------------------
-- CBA Debug — Battle Lag Harness
-- Manual performance harness:
--   * Tracks high-coverage combat/system events with bounded aggregation
--   * 10-second structured summary: global events, systems, and performance metrics
--   * 1s heartbeat with wall-clock + sim-clock deltas for lag/stutter diagnosis
--   * Falls back to PerfStats dump when SCAR exposes no FPS getter
--   * Spawns 125 men-at-arms + 30 crossbowmen per active player (human + AI)
--   * All spawn paths route through CBA_Rewards_SpawnAndMove (pop-cap + precache + queue)
--   * Harness overrides reward FormationMove with AttackMove toward sacred site target
--   * SGroup_AddGroup transfers reward-spawned squads into harness tracking groups
--   * Production loop: MAA + Crossbow ONLY, 25% of full group per tick, 15s interval
--   * Crossbows are ALWAYS precached via Squad_Precache before any spawn (initial + production)
--   * Forces all spawned groups toward sacred site center for large deterministic battle
--   * At <=50% group strength, spawns missing squads and attack-moves to the same waypoint
--   * Units are AI-locked via AI_LockSquads so AI tactics cannot override harness commands
--   * Optional AI activity toggle: can leave AI scripted loops enabled for realistic load
--   * Per-sim-frame counter via Rule_Add for true in-game tick-rate measurement
--   * Stutter detection: warns when heartbeat wall_dt exceeds 2x expected interval
--
-- ╔══════════════════════════════════════════════════════════════════════════╗
-- ║  PERMANENT DESIGN GOALS — DO NOT MODIFY WITHOUT FULL REVIEW            ║
-- ║  1. Debug logger must NOT introduce lag (no per-event pcall overhead)   ║
-- ║  2. Production spawner: MAA + Crossbowman ONLY (no other unit types)   ║
-- ║  3. Crossbowman MUST be precached before EVERY spawn (initial + prod)  ║
-- ║  4. Production: 25% of full group per tick, 15s interval               ║
-- ║  5. Logger must detect and report ALL stutter/performance issues        ║
-- ║  6. FPS measurement via Rule_Add per-sim-frame counter (not Timer*)    ║
-- ║  7. All spawns route through CBA_Rewards_SpawnAndMove (pop-cap aware)  ║
-- ╚══════════════════════════════════════════════════════════════════════════╝
--
-- Console:
--   Debug_BattleLagTest()          -- starts test and keeps it running until manual stop
--   Debug_BattleLagStop()          -- REQUIRED to end test and perform cleanup
--   Debug_BattleLagStatus()        -- current counters/state snapshot
--   Debug_BattleLagConfig()        -- prints current harness configuration
--
-- AI NOTE: Always provide Debug_BattleLagStop() alongside Debug_BattleLagTest() in console
-- command tables. Always list both commands together.
--
-- Depends: cba_debug_core.scar, gameplay/cba_ai_player.scar
---------------------------------------------------------------------------------------------------

local _BL_SUITE = "BattleLagTest"
local _BL_BATCH_SIZE = 125
local _BL_CROSSBOW_BATCH_SIZE = 30
local _BL_SUMMARY_INTERVAL = 10.0
local _BL_FPS_LOG_INTERVAL = 1.0
local _BL_REASSERT_INTERVAL = 3.0
local _BL_REASSERT_DIST = 35.0
local _BL_REWARD_REASSERT_INTERVAL = 1.0
local _BL_IDLE_MIL_ORDER_INTERVAL = 60.0
local _BL_HEALTH_CHECK_INTERVAL = 10.0
local _BL_HEALTH_THRESHOLD = 0.50
local _BL_ENABLE_HEALTH_RESPAWN = false  -- PERF: disabled by default; respawn spike (+307 squads) caused ~50% perf drop
local _BL_MAX_EVENTS_PER_BUCKET = 100000
local _BL_STUTTER_WALL_DT_THRESHOLD = 2.0  -- warn when heartbeat wall_dt exceeds this (seconds)

-- ── Stress configuration ──────────────────────────────────────────────────
-- PERMANENT: Production spawner is MAA + Crossbowman ONLY.
--   DO NOT add other unit types here. This is a core design constraint.
-- PERMANENT: Batch sizes are 25% of full group. Interval is 60s.
--   DO NOT change these ratios without full performance review.
local _BL_ENABLE_PRODUCTION_LOOP = true
local _BL_PRODUCTION_INTERVAL = 60.0                                    -- DO NOT CHANGE — 60s is the validated interval
local _BL_PRODUCTION_MAA_BATCH = math.floor(_BL_BATCH_SIZE * 0.25)      -- 25% of full MAA group per tick
local _BL_PRODUCTION_XBOW_BATCH = math.floor(_BL_CROSSBOW_BATCH_SIZE * 0.25) -- 25% of full Crossbow group per tick
local _BL_PRODUCTION_XBOW_RATIO = 0.25
local _BL_MAX_TOTAL_UNITS = 2000
local _BL_ENABLE_AI_ACTIVITY = false
-- PERMANENT: MAA + Crossbow only. DO NOT add spearman, archer, horseman, knight, or any other type.
local _BL_PRODUCTION_UNIT_TYPES = {
	"scar_manatarms",
	"scar_crossbowman",
}

local _bl = {
	running = false,
	start_time = 0,
	phase = "idle",
	target = nil,
	players = {},
	human_players = {},
	groups = {},
	xbow_groups = {},
	events = {},
	bucket = {},
	sample = {},
	failures = {},
	observer_started = 0,
	ai_paused = {},
	ai_locked = false,
	respawn_count = {},
	fps_last_game_time = 0,
	wall_last_time = 0,
	wall_start_time = 0,
	fps_sum = 0,
	fps_min = 999,
	fps_max = 0,
	fps_count = 0,
	fps_true_count = 0,
	fps_proxy_count = 0,
	frame_time_sum = 0,
	prev_entity_total = 0,
	prev_bucket_events = 0,
	prev_ge_totals = {},
	prod_total_spawned = 0,
	prod_tick_count = 0,
	frame_counter_total = 0,
	frame_counter_window = 0,
	heartbeat_last_frame_count = 0,
	fps_probe_name = nil,
	fps_probe_available = false,
	wall_clock_source = "none",
	perfstats_enabled = false,
	perfstats_enabled_by_harness = false,
	cached_game_time = 0,           -- updated per sim-frame; avoids per-event pcall overhead
	stutter_count = 0,              -- number of heartbeats where wall_dt > threshold
	max_wall_dt = 0,                -- worst heartbeat gap observed (seconds)
	min_frame_delta = 999999,       -- lowest frame count in any heartbeat window
}

local function _BL_IsAIPlayer(player)
	if player == nil or player.id == nil then return false end
	local ok, is_ai = pcall(AI_IsAIPlayer, player.id)
	return ok and is_ai
end

local function _BL_AddFailure(msg)
	table.insert(_bl.failures, tostring(msg))
	print(string.format("[BATTLE_LAG][FAIL] %s", tostring(msg)))
end

local function _BL_Bump(tbl, key, amount)
	amount = amount or 1
	tbl[key] = (tbl[key] or 0) + amount
end

-- PERMANENT: BucketKey uses cached game time (updated per sim-frame in _BL_FrameCounterTick).
-- DO NOT replace with pcall(World_GetGameTime) — that adds per-event overhead and introduces lag.
local function _BL_BucketKey()
	local t = _bl.cached_game_time or 0
	return math.floor(t / _BL_SUMMARY_INTERVAL)
end

local function _BL_RecordEvent(event_name, player_key)
	local name = tostring(event_name or "unknown")
	_BL_Bump(_bl.events, name, 1)

	local bkey = _BL_BucketKey()
	if _bl.bucket[bkey] == nil then
		_bl.bucket[bkey] = {}
	end
	if _bl.bucket[bkey].total == nil then
		_bl.bucket[bkey].total = 0
	end

	if _bl.bucket[bkey].total < _BL_MAX_EVENTS_PER_BUCKET then
		_BL_Bump(_bl.bucket[bkey], name, 1)
		if player_key ~= nil then
			_BL_Bump(_bl.bucket[bkey], string.format("%s:%s", name, tostring(player_key)), 1)
		end
		_bl.bucket[bkey].total = _bl.bucket[bkey].total + 1
	else
		_BL_Bump(_bl.events, "bucket_overflow", 1)
	end
end

local function _BL_PlayerKeyById(player_id)
	-- Key is always "P<player.id>" — no playerIndex dependency
	if player_id ~= nil then
		return "P" .. tostring(player_id)
	end
	return "P?"
end

