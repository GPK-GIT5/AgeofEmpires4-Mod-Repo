---------------------------------------------------------------------------------------------------
-- CBA Debug — Read-Only State Inspectors
-- Console commands that dump current game state without modification.
--
-- Branch: onslaught-v3.3
-- State tables inspected: _buildingLimit, _religious, _wonder, _mod, _CBA, _autoage,
--   AGS_GLOBAL_SETTINGS (settings read from ags_global_settings.scar)
---------------------------------------------------------------------------------------------------

---------------------------------------------------------------------------------------------------
-- Building Limit State
---------------------------------------------------------------------------------------------------

function Debug_GetBuildingLimitState()
	print("")
	print("[CBA_DEBUG] Building Limit State:")
	if _buildingLimit == nil then
		print("  _buildingLimit module not loaded")
		return
	end
	local max_bld = AGS_GLOBAL_SETTINGS.MaximumProductionBuildings or "nil"
	local max_ws = AGS_GLOBAL_SETTINGS.MaximumSiegeWorkshop or "nil"
	print(string.format("  Max production buildings: %s (AGS_GLOBAL_SETTINGS.MaximumProductionBuildings)",
		tostring(max_bld)))
	print(string.format("  Max siege workshops: %s (AGS_GLOBAL_SETTINGS.MaximumSiegeWorkshop)",
		tostring(max_ws)))
	print("")
	for i, player in ipairs(PLAYERS) do
		local bld = player.obj_buildingLimit_count or "nil"
		local ws = player.obj_buildingLimit_workshop_count or "nil"
		local op = player.obj_buildingLimit_outpost_count or "nil"
		local civ = _Debug_GetPlayerCiv(player)
		local elim = ""
		local ok, e = pcall(Core_IsPlayerEliminated, player.id)
		if ok and e then elim = " [ELIMINATED]" end
		-- English starter keep tracking
		local sk_str = ""
		local branch = AGS_CIV_PARENT_MAP and (AGS_CIV_PARENT_MAP[civ] or civ) or civ
		if branch == "english" then
			local sk_id = player.obj_buildingLimit_english_start_keep_id
			local sk_alive = "?"
			if sk_id ~= nil then
				local ok2, alive = pcall(Entity_IsAlive, sk_id)
				if ok2 then sk_alive = tostring(alive) else sk_alive = "invalid" end
			end
			sk_str = string.format(" starter_keep=%s(alive=%s)", tostring(sk_id), sk_alive)
		end
		print(string.format("  P%d (%s): bld=%s ws=%s outpost=%s%s%s",
			i, civ, tostring(bld), tostring(ws), tostring(op), sk_str, elim))
	end
end

---------------------------------------------------------------------------------------------------
-- Siege Limit State
---------------------------------------------------------------------------------------------------

function Debug_GetSiegeLimitState()
	print("")
	print("[CBA_DEBUG] Siege Limit State:")
	local max_siege = AGS_GLOBAL_SETTINGS.MaximumMedicPopulation or "nil"
	print(string.format("  Siege limit setting: %s (AGS_GLOBAL_SETTINGS.MaximumMedicPopulation)",
		tostring(max_siege)))
	print(string.format("  NoSiege: %s", tostring(AGS_GLOBAL_SETTINGS.NoSiege)))
	print(string.format("  RAM_LIMIT_MAX: %s", tostring(RAM_LIMIT_MAX)))
	print(string.format("  SIEGE_TOWER_LIMIT_MAX: %s", tostring(SIEGE_TOWER_LIMIT_MAX)))
	print("")
	for i, player in ipairs(PLAYERS) do
		local siege = player.siegeLimit_count or "nil"
		local ram = player.ramLimit_count or "nil"
		local tower = player.siegeTowerLimit_count or "nil"
		local pending_ram = player.ramLimit_pending or 0
		local pending_st = player.siegeTowerLimit_pending or 0
		local civ = _Debug_GetPlayerCiv(player)
		-- Siege Engineers unlocked state
		local has_siege_eng = "N/A"
		local ok_up, up_result = pcall(function()
			return Player_HasUpgrade(player.id, AGS_GetCivilizationUpgrade(civ, AGS_UP_SIEGE_ENGINEERS))
		end)
		if ok_up then has_siege_eng = tostring(up_result) end
		-- English age gate
		local age_gate = ""
		if civ == "english" then
			local ok_age, age = pcall(Player_GetCurrentAge, player.id)
			if ok_age then
				age_gate = string.format(" age=%d pre_castle=%s", age, tostring(age < AGS_GS_AGE_CASTLE))
			end
		end
		print(string.format("  P%d (%s): siege=%s ram=%s tower=%s pendingRam=%d pendingST=%d siege_eng=%s%s",
			i, civ, tostring(siege), tostring(ram), tostring(tower),
			pending_ram, pending_st, has_siege_eng, age_gate))
	end
end

-- Ram/Siege Tower Limit detailed state dump
function Debug_RamSiegeTowerLimitState()
	print("")
	print("[CBA_DEBUG] Ram/Siege Tower Limit State:")
	if type(CBA_Options_GetRamLimitMax) ~= "function" or type(CBA_Options_GetSiegeTowerLimitMax) ~= "function" then
		print("  ERROR: Ram/ST accessor functions not loaded. Ensure cba_options.scar exports them.")
		return
	end
	print(string.format("  RAM_LIMIT_MAX=%d  SIEGE_TOWER_LIMIT_MAX=%d",
		CBA_Options_GetRamLimitMax(), CBA_Options_GetSiegeTowerLimitMax()))
	print("")
	for i, player in ipairs(PLAYERS) do
		local civ = _Debug_GetPlayerCiv(player)
		local ok_gate, gate = pcall(CBA_Options_SiegeLimit_GetGateTotals, player)
		if ok_gate and gate then
			print(string.format("  P%d (%s): ram_total=%d/%d  st_total=%d/%d  (live_ram=%s queued_ram=%s pending_ram=%s | live_st=%s queued_st=%s pending_st=%s)",
				i, civ,
				gate.ram_total, gate.ram_cap,
				gate.st_total, gate.st_cap,
				tostring(player.ramLimit_count or 0),
				tostring(CBA_Options_RamLimit_GetQueuedCount(player)),
				tostring(player.ramLimit_pending or 0),
				tostring(player.siegeTowerLimit_count or 0),
				tostring(CBA_Options_SiegeTowerLimit_GetQueuedCount(player)),
				tostring(player.siegeTowerLimit_pending or 0)
			))
		else
			print(string.format("  P%d (%s): gate totals unavailable: %s", i, civ, tostring(gate)))
		end
	end
end

---------------------------------------------------------------------------------------------------
-- Team Balance Cap State — all 6 per-player effective limits vs global base
---------------------------------------------------------------------------------------------------

function Debug_TeamBalanceCapState()
	print("")
	print("[CBA_DEBUG] Team Balance Cap State:")
	print(string.format("  MaintainTeamBalance=%s  (NONE=0 POP=1 RES=2 FULL=3)",
		tostring(AGS_GLOBAL_SETTINGS.MaintainTeamBalance)))
	print(string.format("  Bases: prod=%s  siege=%s  ram=%s  st=%s  ws=%s  outpost=20",
		tostring(AGS_GLOBAL_SETTINGS.MaximumProductionBuildings),
		tostring(AGS_GLOBAL_SETTINGS.MaximumMedicPopulation),
		tostring(RAM_LIMIT_MAX),
		tostring(SIEGE_TOWER_LIMIT_MAX),
		tostring(AGS_GLOBAL_SETTINGS.MaximumSiegeWorkshop)))
	print("")
	for i, player in ipairs(PLAYERS) do
		local civ = _Debug_GetPlayerCiv(player)
		local ok_elim, elim = pcall(Core_IsPlayerEliminated, player.id)
		local elim_str = (ok_elim and elim) and " [ELIMINATED]" or ""
		local eff_prod  = type(CBA_Options_GetPlayerProdLimit) == "function" and CBA_Options_GetPlayerProdLimit(player) or "?"
		local eff_siege = type(CBA_Options_GetPlayerSiegeLimit) == "function" and CBA_Options_GetPlayerSiegeLimit(player) or "?"
		local eff_ram   = type(CBA_Options_GetPlayerRamLimit) == "function" and CBA_Options_GetPlayerRamLimit(player) or "?"
		local eff_st    = type(CBA_Options_GetPlayerSiegeTowerLimit) == "function" and CBA_Options_GetPlayerSiegeTowerLimit(player) or "?"
		local eff_ws    = type(CBA_Options_GetPlayerWorkshopLimit) == "function" and CBA_Options_GetPlayerWorkshopLimit(player) or "?"
		local eff_op    = type(CBA_Options_GetPlayerOutpostLimit) == "function" and CBA_Options_GetPlayerOutpostLimit(player) or "?"
		print(string.format("  P%d (%s): prod=%s  siege=%s  ram=%s  st=%s  ws=%s  outpost=%s%s",
			i, civ,
			tostring(eff_prod), tostring(eff_siege),
			tostring(eff_ram),  tostring(eff_st),
			tostring(eff_ws),   tostring(eff_op),
			elim_str))
	end
end

---------------------------------------------------------------------------------------------------
-- Keep Ownership Map
---------------------------------------------------------------------------------------------------

function Debug_GetKeepOwnershipMap()
	print("")
	print("[CBA_DEBUG] Keep Ownership Map:")
	for i, player in ipairs(PLAYERS) do
		if player.keep and player.keep.entity then
			local alive = "?"
			local ok_alive, a = pcall(Entity_IsAlive, player.keep.entity)
			if ok_alive then alive = tostring(a) end
			local owner = "?"
			local ok_own, o = pcall(Entity_GetPlayerOwner, player.keep.entity)
			if ok_own then
				for j, p in ipairs(PLAYERS) do
					if p.id == o then owner = "P" .. j break end
				end
			end
			print(string.format("  P%d: alive=%s owner=%s", i, alive, owner))
		else
			print(string.format("  P%d: NO KEEP", i))
		end
	end
end

---------------------------------------------------------------------------------------------------
-- Villager State
---------------------------------------------------------------------------------------------------

function Debug_GetVillagerState()
	print("")
	print("[CBA_DEBUG] Villager State:")
	for i, player in ipairs(PLAYERS) do
		local count = 0
		local ok, eg = pcall(function()
			local eg = Player_GetEntities(player.id)
			EGroup_Filter(eg, "villager", FILTER_KEEP)
			return eg
		end)
		if ok and eg then
			local ok2, c = pcall(EGroup_Count, eg)
			if ok2 then count = c end
		end
		local civ = _Debug_GetPlayerCiv(player)
		print(string.format("  P%d (%s): villagers=%d", i, civ, count))
	end
end

---------------------------------------------------------------------------------------------------
-- Option Parse Results (from ags_global_settings.scar + cba_options.scar + cba_economy.scar)
---------------------------------------------------------------------------------------------------

function Debug_GetOptionParseResults()
	print("")
	print("[CBA_DEBUG] Option Parse Results:")
	if _mod.options == nil then
		print("  _mod.options is nil")
	end
	print("  _mod fields:")
	print(string.format("    pop_cap = %s", tostring(_mod.pop_cap)))
	print(string.format("    pop_start = %s", tostring(_mod.pop_start)))
	print(string.format("    pop_interval = %s", tostring(_mod.pop_interval)))
	print("")
	print("  AGS_GLOBAL_SETTINGS:")
	local keys = {
		"MaximumPopulation", "MinimumPopulation", "AutoAge", "CBA_Rewards",
		"NoSiege", "NoWall", "NoDock", "EliminatedLoseKeep",
		"MaximumProductionBuildings", "MaximumSiegeWorkshop",
		"StartingAge", "EndingAge", "StartingVillagers", "MaintainTeamBalance",
	}
	for _, k in ipairs(keys) do
		print(string.format("    %s = %s", k, tostring(AGS_GLOBAL_SETTINGS[k])))
	end
end

---------------------------------------------------------------------------------------------------
-- Post-Defeat State
---------------------------------------------------------------------------------------------------

function Debug_GetPostDefeatState()
	print("")
	print("[CBA_DEBUG] Post-Defeat State:")
	for i, player in ipairs(PLAYERS) do
		local ok, elim = pcall(Core_IsPlayerEliminated, player.id)
		local status = (ok and elim) and "ELIMINATED" or "ACTIVE"
		local entities = 0
		local ok2, eg = pcall(Player_GetEntities, player.id)
		if ok2 and eg then
			local ok3, c = pcall(EGroup_Count, eg)
			if ok3 then entities = c end
		end
		local civ = _Debug_GetPlayerCiv(player)
		print(string.format("  P%d (%s): %s entities=%d", i, civ, status, entities))
	end
end

---------------------------------------------------------------------------------------------------
-- Religious State (from cba_religious.scar)
---------------------------------------------------------------------------------------------------

function Debug_GetReligiousState()
	print("")
	print("[CBA_DEBUG] Religious State (cba_religious.scar):")
	if _religious == nil then
		print("  _religious module not loaded")
		return
	end
	print(string.format("  time_victory = %s", tostring(_religious.time_victory)))
	print(string.format("  conversion_radius = %s", tostring(_religious.conversion_radius)))
	print(string.format("  update_interval = %s", tostring(_religious.update_interval)))
	if _religious.sites then
		local count = 0
		for _, site in pairs(_religious.sites) do
			count = count + 1
			print(string.format("  Site %d: progress=%s player_last_capturing=%s",
				count, tostring(site.progress), tostring(site.player_last_capturing)))
		end
	end
end

