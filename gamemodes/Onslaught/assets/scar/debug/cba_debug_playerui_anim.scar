---------------------------------------------------------------------------------------------------
if debug then
	debug.playerUI.anim          = Debug_PlayerUI_Anim
	debug.playerUI.animMonitor   = Debug_PlayerUI_Anim_Monitor
	debug.playerUI.animStress    = Debug_PlayerUI_Anim_Stress
	debug.playerUI.animSnapshot  = Debug_PlayerUI_Anim_Snapshot
	debug.playerUI.animFeatures  = Debug_PlayerUI_Anim_Features
	debug.playerUI.animStaged    = Debug_PlayerUI_Anim_RunStaged
        debug.playerUI.animValidate  = Debug_PlayerUI_Anim_ValidateDataContext
        debug.playerUI.rewardSnapshot = Debug_PlayerUI_RewardPlayback_Snapshot
	debug.playerUI.rewardCaptureFull = Debug_PlayerUI_RewardPlayback_CaptureFull
        debug.playerUI.rewardInject     = Debug_PlayerUI_RewardPlayback_Inject
        debug.playerUI.rewardInjectReal  = Debug_PlayerUI_RewardPlayback_InjectReal
        debug.playerUI.rewardSkip        = Debug_PlayerUI_RewardPlayback_SkipPhase
        debug.playerUI.rewardReset       = Debug_PlayerUI_RewardPlayback_Reset
        debug.playerUI.rewardValidate    = Debug_PlayerUI_RewardPlayback_ValidateCycle
	debug.playerUI.stressTest       = Debug_PlayerUI_StressTest_Staged
	debug.playerUI.dataSnapshot     = Debug_PlayerUI_DataContextSnapshot
	debug.playerUI.throttleTest     = Debug_PlayerUI_ToggleThrottleTest
	debug.playerUI.crashProbe       = Debug_PlayerUI_CrashProbe
	debug.playerUI.crashProbeFields = Debug_PlayerUI_CrashProbe_Fields
	debug.playerUI.crashProbeAutoShow = Debug_PlayerUI_CrashProbe_AutoShow
end
