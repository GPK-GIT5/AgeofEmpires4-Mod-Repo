---------------------------------------------------------------------------------------------------
-- Standalone: Debug_FactionMapDiagnostic — One-command faction / parent-map audit
--
-- Console: Debug_FactionMapDiagnostic()
--
-- Sections:
--   A. AGS_CIV_FACTION_MAP coverage (all variants mapped, parents valid)
--   B. False-vs-nil diagnostics (every explicit false entry per variant, conflict detection)
--   C. Transfer-path simulation (building resolve through Tier 1/2/3 for all cross-civ pairs)
--   D. Reward alias coverage (every variant has a reward table)
--   E. Pass/fail summary
---------------------------------------------------------------------------------------------------

function Debug_FactionMapDiagnostic()
	print("")
	print("############################################################")
	print("###  CBA DEBUG — FACTION MAP DIAGNOSTIC                  ###")
	print("############################################################")
	print("")

	local total_tests = 0
	local total_pass = 0
	local failures = {}

	local function _fmd_test(name, pass, detail)
		total_tests = total_tests + 1
		if pass then
			total_pass = total_pass + 1
			print(string.format("  [PASS] %s — %s", name, detail))
		else
			table.insert(failures, {name = name, detail = detail})
			print(string.format("  [FAIL] %s — %s", name, detail))
		end
	end

	---------------------------------------------------------------------------
	-- Section A: AGS_CIV_FACTION_MAP Coverage
	---------------------------------------------------------------------------
	print("--- A. FACTION MAP COVERAGE ---")

	_fmd_test("A.1 AGS_CIV_FACTION_MAP exists", AGS_CIV_FACTION_MAP ~= nil, AGS_CIV_FACTION_MAP ~= nil and "defined" or "NIL")

	if AGS_CIV_FACTION_MAP ~= nil then
		local fm_count = 0
		local fm_issues = {}
		for child, parent in pairs(AGS_CIV_FACTION_MAP) do
			fm_count = fm_count + 1
			if AGS_ENTITY_TABLE[parent] == nil then
				table.insert(fm_issues, child .. "->" .. parent .. " MISSING_PARENT_TABLE")
			end
		end
		_fmd_test("A.2 All parents have entity tables", #fm_issues == 0,
			#fm_issues == 0 and fm_count .. " mappings valid" or table.concat(fm_issues, "; "))

		-- Check faction map is superset of parent map
		local superset_issues = {}
		if AGS_CIV_PARENT_MAP ~= nil then
			for child, _ in pairs(AGS_CIV_PARENT_MAP) do
				if AGS_CIV_FACTION_MAP[child] == nil then
					table.insert(superset_issues, child .. " in PARENT_MAP but missing from FACTION_MAP")
				end
			end
		end
		_fmd_test("A.3 FACTION_MAP superset of PARENT_MAP", #superset_issues == 0,
			#superset_issues == 0 and "superset OK" or table.concat(superset_issues, "; "))

		-- Check Knights DLC civs are included
		local knights_civs = {"abbasid_ha_01", "chinese_ha_01", "french_ha_01", "hre_ha_01"}
		local knights_missing = {}
		for _, kc in ipairs(knights_civs) do
			if AGS_CIV_FACTION_MAP[kc] == nil then
				table.insert(knights_missing, kc)
			end
		end
		_fmd_test("A.4 Knights DLC civs in faction map", #knights_missing == 0,
			#knights_missing == 0 and "4/4 present" or "missing: " .. table.concat(knights_missing, ", "))

		print(string.format("  [INFO] AGS_CIV_FACTION_MAP: %d entries", fm_count))
		for child, parent in pairs(AGS_CIV_FACTION_MAP) do
			local own_table = AGS_ENTITY_TABLE[child] ~= nil
			print(string.format("    %s -> %s  (own_table=%s)", child, parent, tostring(own_table)))
		end
	end
	print("")

	---------------------------------------------------------------------------
	-- Section B: False-vs-Nil Diagnostics
	---------------------------------------------------------------------------
	print("--- B. FALSE-VS-NIL DIAGNOSTICS ---")

	if AGS_CIV_PARENT_MAP ~= nil then
		local total_false = 0
		local total_conflicts = 0
		local total_guarded = 0
		local guard_failures = {}

		for child, parent in pairs(AGS_CIV_PARENT_MAP) do
			local child_table = AGS_ENTITY_TABLE[child]
			local parent_table = AGS_ENTITY_TABLE[parent]
			if child_table == nil then
				print(string.format("  [WARN] %s has no own entity table", child))
				goto continue_child_b
			end
			if parent_table == nil then
				print(string.format("  [WARN] %s parent %s has no entity table", child, parent))
				goto continue_child_b
			end

			local child_false_count = 0
			local child_conflicts = {}

			for key, val in pairs(child_table) do
				if val == false then
					child_false_count = child_false_count + 1
					total_false = total_false + 1

					local parent_val = parent_table[key]
					local is_conflict = type(parent_val) == "string"
					local guard_ok = AGS_CivTableHasExplicitFalse(child, key)

					if is_conflict then
						total_conflicts = total_conflicts + 1
						local status = guard_ok and "GUARDED" or "LEAK"
						if guard_ok then
							total_guarded = total_guarded + 1
						else
							table.insert(guard_failures, child .. "/" .. key)
						end
						table.insert(child_conflicts, string.format("    %-25s false vs parent %-40s [%s]", key, parent_val, status))
					end
				end
			end

			if child_false_count > 0 then
				print(string.format("  %s (parent: %s): %d false entries, %d conflicts",
					child, parent, child_false_count, #child_conflicts))
				for _, line in ipairs(child_conflicts) do
					print(line)
				end
			end

			::continue_child_b::
		end

		_fmd_test("B.1 All false-override conflicts guarded", #guard_failures == 0,
			#guard_failures == 0
				and total_conflicts .. " conflicts, all guarded by AGS_CivTableHasExplicitFalse"
				or "UNGUARDED: " .. table.concat(guard_failures, ", "))

		print(string.format("  [INFO] Total: %d false entries, %d parent-has-value conflicts, %d guarded",
			total_false, total_conflicts, total_guarded))
	else
		_fmd_test("B.1 AGS_CIV_PARENT_MAP exists", false, "NIL — cannot run false-vs-nil analysis")
	end
	print("")

	---------------------------------------------------------------------------
	-- Section C: Transfer-Path Simulation (Building Resolve)
	---------------------------------------------------------------------------
	print("--- C. TRANSFER-PATH SIMULATION ---")

	-- Gather all civs that have entity tables
	local all_civs = {}
	if AGS_ENTITY_TABLE ~= nil then
		for civ, tbl in pairs(AGS_ENTITY_TABLE) do
			if civ ~= "neutral" then
				table.insert(all_civs, civ)
			end
		end
		table.sort(all_civs)
	end

	-- Gather building keys from all civ tables
	local all_bldg_keys = {}
	local key_set = {}
	for _, civ in ipairs(all_civs) do
		for key, val in pairs(AGS_ENTITY_TABLE[civ]) do
			if type(val) == "string" and string.sub(val, 1, 9) == "building_" and not key_set[key] then
				key_set[key] = true
				table.insert(all_bldg_keys, key)
			end
		end
	end
	table.sort(all_bldg_keys)

	local c_total_pairs = 0
	local c_total_keys = 0
	local c_exact = 0
	local c_parent = 0
	local c_lossy = 0
	local c_killed = 0
	local c_false_blocked = 0
	local c_unresolved_log = {}

	local function _fmd_try_resolve(civ, key)
		local ok, bp = pcall(AGS_GetCivilizationEntity, civ, key)
		if ok and bp ~= nil then return bp end
		return nil
	end

	for _, src_civ in ipairs(all_civs) do
		local src_table = AGS_ENTITY_TABLE[src_civ]
		for _, rcv_civ in ipairs(all_civs) do
			if src_civ ~= rcv_civ then
				c_total_pairs = c_total_pairs + 1
				for key, val in pairs(src_table) do
					if type(val) ~= "string" or string.sub(val, 1, 9) ~= "building_" then
						goto continue_key_c
					end
					c_total_keys = c_total_keys + 1

					-- Tier 1: exact
					local bp = _fmd_try_resolve(rcv_civ, key)
					if bp ~= nil then
						c_exact = c_exact + 1
						goto continue_key_c
					end

					-- Tier 2: parent fallback (with false-guard)
					if AGS_CIV_PARENT_MAP[rcv_civ] ~= nil then
						if AGS_CivTableHasExplicitFalse(rcv_civ, key) then
							c_false_blocked = c_false_blocked + 1
							-- Don't try parent — proceed to Tier 3
						else
							bp = _fmd_try_resolve(AGS_CIV_PARENT_MAP[rcv_civ], key)
							if bp ~= nil then
								c_parent = c_parent + 1
								goto continue_key_c
							end
						end
					end

					-- Tier 3: AGS_BUILDING_FALLBACK_MAP
					if AGS_BUILDING_FALLBACK_MAP ~= nil then
						local fb_key = AGS_BUILDING_FALLBACK_MAP[key]
						if fb_key ~= nil then
							bp = _fmd_try_resolve(rcv_civ, fb_key)
							if bp == nil and AGS_CIV_PARENT_MAP[rcv_civ] ~= nil
								and not AGS_CivTableHasExplicitFalse(rcv_civ, fb_key) then
								bp = _fmd_try_resolve(AGS_CIV_PARENT_MAP[rcv_civ], fb_key)
							end
							if bp ~= nil then
								c_lossy = c_lossy + 1
								goto continue_key_c
							end
						end
					end

					-- Unresolved → kill
					c_killed = c_killed + 1
					local log_key = src_civ .. "->" .. rcv_civ .. "/" .. key
					if #c_unresolved_log < 50 then
						table.insert(c_unresolved_log, log_key)
					end

					::continue_key_c::
				end
			end
		end
	end

	print(string.format("  Pairs: %d cross-civ pairs, %d key resolutions", c_total_pairs, c_total_keys))
	print(string.format("  Results: exact=%d parent=%d lossy=%d killed=%d false_blocked=%d",
		c_exact, c_parent, c_lossy, c_killed, c_false_blocked))

	if #c_unresolved_log > 0 then
		print(string.format("  Unresolved samples (max 50):"))
		for _, entry in ipairs(c_unresolved_log) do
			print("    " .. entry)
		end
	end

	local c_resolved = c_exact + c_parent + c_lossy
	_fmd_test("C.1 All keys resolve or are cleanly killed", true,
		string.format("%d resolved + %d killed = %d total (%d false-blocked)",
			c_resolved, c_killed, c_resolved + c_killed, c_false_blocked))

	-- Verify no false-override leaks: for any variant civ with explicit false,
	-- Tier 2 must NOT produce a parent BP
	local c_leak_tests = 0
	local c_leaks = {}
	if AGS_CIV_PARENT_MAP ~= nil then
		for child, parent in pairs(AGS_CIV_PARENT_MAP) do
			local child_table = AGS_ENTITY_TABLE[child]
			if child_table == nil then goto continue_child_c end
			for key, val in pairs(child_table) do
				if val == false then
					c_leak_tests = c_leak_tests + 1
					-- Simulate: would Tier 2 produce a BP?
					local parent_bp = _fmd_try_resolve(parent, key)
					local guard = AGS_CivTableHasExplicitFalse(child, key)
					if parent_bp ~= nil and not guard then
						table.insert(c_leaks, child .. "/" .. key .. " -> parent " .. parent .. " LEAKED")
					end
				end
			end
			::continue_child_c::
		end
	end

	_fmd_test("C.2 No false-override leaks in Tier 2", #c_leaks == 0,
		#c_leaks == 0
			and c_leak_tests .. " false-entries tested, 0 leaks"
			or table.concat(c_leaks, "; "))
	print("")

	---------------------------------------------------------------------------
	-- Section D: Reward Alias Coverage
	---------------------------------------------------------------------------
	print("--- D. REWARD ALIAS COVERAGE ---")

	if _CBA ~= nil and _CBA.rewards ~= nil and AGS_CIV_FACTION_MAP ~= nil then
		local reward_missing = {}
		for variant, parent in pairs(AGS_CIV_FACTION_MAP) do
			if _CBA.rewards[variant] == nil then
				table.insert(reward_missing, variant)
			elseif _CBA.rewards[parent] ~= nil and _CBA.rewards[variant] ~= _CBA.rewards[parent] then
				-- Variant has own reward table (not aliased) — informational
				print(string.format("  [INFO] %s has OWN reward table (not aliased to %s)", variant, parent))
			end
		end
		_fmd_test("D.1 All faction-map variants have reward tables", #reward_missing == 0,
			#reward_missing == 0
				and "all variants covered"
				or "missing: " .. table.concat(reward_missing, ", "))
	else
		_fmd_test("D.1 Reward tables loaded", false,
			_CBA == nil and "_CBA is nil" or (_CBA.rewards == nil and "_CBA.rewards is nil" or "AGS_CIV_FACTION_MAP is nil"))
	end
	print("")

	---------------------------------------------------------------------------
	-- Section E: Siege + Upgrade Table Coverage
	---------------------------------------------------------------------------
	print("--- E. SIEGE + UPGRADE TABLE COVERAGE ---")

	if AGS_CIV_FACTION_MAP ~= nil then
		local siege_missing = {}
		local upgrade_missing = {}
		local correction_missing = {}
		for variant, parent in pairs(AGS_CIV_FACTION_MAP) do
			if CBA_SIEGE_TABLE ~= nil and CBA_SIEGE_TABLE[variant] == nil then
				table.insert(siege_missing, variant)
			end
			if AGS_UPGRADE_TABLE ~= nil and AGS_UPGRADE_TABLE[variant] == nil then
				table.insert(upgrade_missing, variant)
			end
			if AGS_UPGRADE_CORRECTION_TABLE ~= nil and AGS_UPGRADE_CORRECTION_TABLE[variant] == nil then
				table.insert(correction_missing, variant)
			end
		end
		_fmd_test("E.1 All faction-map variants have siege tables", #siege_missing == 0,
			#siege_missing == 0
				and "all variants covered"
				or "missing: " .. table.concat(siege_missing, ", "))
		_fmd_test("E.2 All faction-map variants have upgrade tables", #upgrade_missing == 0,
			#upgrade_missing == 0
				and "all variants covered"
				or "missing: " .. table.concat(upgrade_missing, ", "))
		_fmd_test("E.3 All faction-map variants have correction tables", #correction_missing == 0,
			#correction_missing == 0
				and "all variants covered"
				or "missing: " .. table.concat(correction_missing, ", "))
	end
	print("")

	---------------------------------------------------------------------------
	-- Section F: Summary
	---------------------------------------------------------------------------
	print("############################################################")
	print(string.format("###  RESULT: %d / %d tests passed", total_pass, total_tests))
	if #failures > 0 then
		print("###  FAILURES:")
		for _, f in ipairs(failures) do
			print(string.format("###    [FAIL] %s — %s", f.name, f.detail))
		end
	else
		print("###  ALL TESTS PASSED")
	end
	print("############################################################")
end

---------------------------------------------------------------------------------------------------
-- Debug_VerifyDynastiesData — Single-command verification for Dynasties data additions
-- Validates: upgrade table entries, correction table entries, key parity, arena reward tables
-- Console: Debug_VerifyDynastiesData()
---------------------------------------------------------------------------------------------------
function Debug_VerifyDynastiesData()
	print("")
	print("############################################################")
	print("###  CBA DEBUG — DYNASTIES DATA VERIFICATION             ###")
	print("############################################################")
	print("")

	local total_tests = 0
	local total_pass = 0
	local failures = {}

	local function _test(name, pass, detail)
		total_tests = total_tests + 1
		if pass then
			total_pass = total_pass + 1
			print(string.format("  [PASS] %s — %s", name, detail))
		else
			table.insert(failures, {name = name, detail = detail})
			print(string.format("  [FAIL] %s — %s", name, detail))
		end
	end

	local dynasties_variants = {
		"mongol_ha_gol", "lancaster", "templar",
		"byzantine_ha_mac", "japanese_ha_sen", "sultanate_ha_tug",
	}
	local dynasties_parent = {
		mongol_ha_gol = "mongol", lancaster = "english", templar = "french",
		byzantine_ha_mac = "byzantine", japanese_ha_sen = "japanese", sultanate_ha_tug = "sultanate",
	}
	local arena_base_civs = {
		"english", "chinese", "french", "hre", "mongol", "rus",
		"sultanate", "abbasid", "malian", "ottoman", "japanese", "byzantine",
	}

	---------------------------------------------------------------------------
	-- Section 1: AGS_UPGRADE_TABLE — Dynasties entries exist
	---------------------------------------------------------------------------
	print("--- 1. UPGRADE TABLE COVERAGE ---")

	local upgrade_missing = {}
	if AGS_UPGRADE_TABLE ~= nil then
		for _, v in ipairs(dynasties_variants) do
			if AGS_UPGRADE_TABLE[v] == nil then
				table.insert(upgrade_missing, v)
			end
		end
		_test("1.1 All 6 Dynasties variants in AGS_UPGRADE_TABLE", #upgrade_missing == 0,
			#upgrade_missing == 0
				and "all 6 present"
				or "missing: " .. table.concat(upgrade_missing, ", "))
	else
		_test("1.1 AGS_UPGRADE_TABLE exists", false, "AGS_UPGRADE_TABLE is nil")
	end

	---------------------------------------------------------------------------
	-- Section 2: AGS_UPGRADE_CORRECTION_TABLE — Dynasties entries exist
	---------------------------------------------------------------------------
	print("--- 2. CORRECTION TABLE COVERAGE ---")

	local correction_missing = {}
	if AGS_UPGRADE_CORRECTION_TABLE ~= nil then
		for _, v in ipairs(dynasties_variants) do
			if AGS_UPGRADE_CORRECTION_TABLE[v] == nil then
				table.insert(correction_missing, v)
			end
		end
		_test("2.1 All 6 Dynasties variants in AGS_UPGRADE_CORRECTION_TABLE", #correction_missing == 0,
			#correction_missing == 0
				and "all 6 present"
				or "missing: " .. table.concat(correction_missing, ", "))
	else
		_test("2.1 AGS_UPGRADE_CORRECTION_TABLE exists", false, "AGS_UPGRADE_CORRECTION_TABLE is nil")
	end

	---------------------------------------------------------------------------
	-- Section 3: Named key parity — variant matches parent
	---------------------------------------------------------------------------
	print("--- 3. UPGRADE TABLE KEY PARITY ---")

	local named_keys = {
		"melee1_attack", "melee1_defense", "melee2_attack", "melee2_defense",
		"melee3_attack", "melee3_defense", "ranged1_attack", "ranged1_defense",
		"ranged2_attack", "ranged2_defense", "ranged3_attack", "ranged3_defense",
		"maa_elite_tactics", "spear_elite_tactics", "biology", "barding",
		"grapered_lance", "military_academy", "ranged_incendiary",
		"university_architecture", "university_chemistry", "siege_works",
		"siege_speed", "roller_trigger", "adjustable_crossbar", "siege_engineers",
	}

	if AGS_UPGRADE_TABLE ~= nil then
		local parity_issues = {}
		for _, v in ipairs(dynasties_variants) do
			local parent = dynasties_parent[v]
			local v_table = AGS_UPGRADE_TABLE[v]
			local p_table = AGS_UPGRADE_TABLE[parent]
			if v_table ~= nil and p_table ~= nil then
				for _, key in ipairs(named_keys) do
					local v_val = v_table[key]
					local p_val = p_table[key]
					if v_val ~= p_val then
						table.insert(parity_issues, v .. "." .. key .. ": " .. tostring(v_val) .. " ~= " .. tostring(p_val))
					end
				end
			end
		end
		_test("3.1 Named keys match parent for all 6 variants", #parity_issues == 0,
			#parity_issues == 0
				and #named_keys .. " keys checked per variant, all match"
				or (#parity_issues .. " mismatches: " .. table.concat(parity_issues, "; ")))
	end

	---------------------------------------------------------------------------
	-- Section 4: Arena reward tables — base civs
	---------------------------------------------------------------------------
	print("--- 4. ARENA REWARD TABLES ---")

	if _CBA ~= nil and _CBA.rewards ~= nil then
		local reward_mode = "unknown"
		if AGS_GLOBAL_SETTINGS ~= nil and AGS_GLOBAL_SETTINGS.CBA_Rewards ~= nil then
			reward_mode = AGS_GLOBAL_SETTINGS.CBA_Rewards
		end
		print("    [INFO] Active rewards mode: " .. tostring(reward_mode))

		local arena_missing = {}
		for _, civ in ipairs(arena_base_civs) do
			if _CBA.rewards[civ] == nil then
				table.insert(arena_missing, civ)
			end
		end
		_test("4.1 All 12 base civs have arena reward tables", #arena_missing == 0,
			#arena_missing == 0
				and "all 12 present"
				or "missing: " .. table.concat(arena_missing, ", "))

		-- Check Japanese and Byzantine are not aliased to other civs
		local jpn_aliased = _CBA.rewards["japanese"] ~= nil
			and (_CBA.rewards["japanese"] == _CBA.rewards["ottoman"]
				or _CBA.rewards["japanese"] == _CBA.rewards["abbasid"])
		local byz_aliased = _CBA.rewards["byzantine"] ~= nil
			and (_CBA.rewards["byzantine"] == _CBA.rewards["ottoman"]
				or _CBA.rewards["byzantine"] == _CBA.rewards["abbasid"])
		_test("4.2 Japanese has own arena table (not aliased)", not jpn_aliased,
			jpn_aliased and "still aliased to another civ" or "own table")
		_test("4.3 Byzantine has own arena table (not aliased)", not byz_aliased,
			byz_aliased and "still aliased to another civ" or "own table")

		-- Check thresholds against the active reward mode.
		local function _reward_has_thresholds(civ, third_threshold)
			return _CBA.rewards[civ] ~= nil
				and _CBA.rewards[civ][0] ~= nil
				and _CBA.rewards[civ][100] ~= nil
				and _CBA.rewards[civ][third_threshold] ~= nil
		end

		local jpn_arena_thresholds = _reward_has_thresholds("japanese", 200)
		local byz_arena_thresholds = _reward_has_thresholds("byzantine", 200)
		local jpn_onslaught_thresholds = _reward_has_thresholds("japanese", 350)
		local byz_onslaught_thresholds = _reward_has_thresholds("byzantine", 350)

		if reward_mode == "arena" then
			_test("4.4 Japanese arena has 3 thresholds (0/100/200)", jpn_arena_thresholds == true,
				jpn_arena_thresholds and "0, 100, 200 populated" or "missing thresholds for arena mode")
			_test("4.5 Byzantine arena has 3 thresholds (0/100/200)", byz_arena_thresholds == true,
				byz_arena_thresholds and "0, 100, 200 populated" or "missing thresholds for arena mode")
		elseif reward_mode == "onslaught" then
			_test("4.4 Japanese onslaught has 3 thresholds (0/100/350)", jpn_onslaught_thresholds == true,
				jpn_onslaught_thresholds and "0, 100, 350 populated" or "missing thresholds for onslaught mode")
			_test("4.5 Byzantine onslaught has 3 thresholds (0/100/350)", byz_onslaught_thresholds == true,
				byz_onslaught_thresholds and "0, 100, 350 populated" or "missing thresholds for onslaught mode")
		else
			local jpn_thresholds = jpn_arena_thresholds or jpn_onslaught_thresholds
			local byz_thresholds = byz_arena_thresholds or byz_onslaught_thresholds
			_test("4.4 Japanese reward table has a valid threshold trio", jpn_thresholds == true,
				jpn_thresholds and "matched arena or onslaught threshold pattern" or "missing both 0/100/200 and 0/100/350 patterns")
			_test("4.5 Byzantine reward table has a valid threshold trio", byz_thresholds == true,
				byz_thresholds and "matched arena or onslaught threshold pattern" or "missing both 0/100/200 and 0/100/350 patterns")
		end
	else
		_test("4.1 Arena rewards loaded", false,
			_CBA == nil and "_CBA is nil" or "_CBA.rewards is nil")
	end
	print("")

	---------------------------------------------------------------------------
	-- Section 5: Mongol variant siege double coverage
	---------------------------------------------------------------------------
	print("--- 5. MONGOL VARIANT SIEGE DOUBLE COVERAGE ---")

	local required_mongol_double_keys = {
		"springald_double", "mangonel_double", "ribauldequin_double", "culverin_double",
		"cannon_double", "bombard_double", "trebuchet_cw_double", "trebuchet_tr_double",
	}

	if CBA_SIEGE_TABLE ~= nil and CBA_SIEGE_TABLE["mongol_ha_gol"] ~= nil then
		local missing_double_keys = {}
		for _, key in ipairs(required_mongol_double_keys) do
			if CBA_SIEGE_TABLE["mongol_ha_gol"][key] == nil then
				table.insert(missing_double_keys, key)
			end
		end
		_test("5.1 mongol_ha_gol includes all *_double siege keys", #missing_double_keys == 0,
			#missing_double_keys == 0
				and "all 8 keys present"
				or "missing: " .. table.concat(missing_double_keys, ", "))
	else
		_test("5.1 mongol_ha_gol siege table exists", false,
			CBA_SIEGE_TABLE == nil and "CBA_SIEGE_TABLE is nil" or "CBA_SIEGE_TABLE[mongol_ha_gol] is nil")
	end
	print("")

	---------------------------------------------------------------------------
	-- Section 6: NoWall Mongol-family guard preconditions
	---------------------------------------------------------------------------
	print("--- 6. NOWALL MONGOL-FAMILY PRECONDITIONS ---")

	if AGS_CIV_FACTION_MAP ~= nil and AGS_GetCivilizationEntity ~= nil then
		local branch_ok = (AGS_CIV_FACTION_MAP["mongol_ha_gol"] == "mongol")
		_test("6.1 mongol_ha_gol maps to mongol faction", branch_ok,
			branch_ok and "branch map uses mongol" or "branch map missing or incorrect")

		local ok_variant, variant_stonewall = pcall(AGS_GetCivilizationEntity, "mongol_ha_gol", AGS_BP_STONEWALL)
		local ok_parent, parent_stonewall = pcall(AGS_GetCivilizationEntity, "mongol", AGS_BP_STONEWALL)
		local variant_nil = ok_variant and variant_stonewall == nil
		local parent_nil = ok_parent and parent_stonewall == nil
		_test("6.2 Mongol-family stone_wall blueprint resolves nil", variant_nil and parent_nil,
			(variant_nil and parent_nil)
				and "stone_wall missing as expected for mongol and mongol_ha_gol"
				or "unexpected non-nil stone_wall blueprint for mongol-family")
	else
		_test("6.1 NoWall precondition dependencies loaded", false,
			AGS_CIV_FACTION_MAP == nil and "AGS_CIV_FACTION_MAP is nil" or "AGS_GetCivilizationEntity is nil")
	end
	print("")

	---------------------------------------------------------------------------
	-- Section 7: Summary
	---------------------------------------------------------------------------
	print("############################################################")
	print(string.format("###  RESULT: %d / %d tests passed", total_pass, total_tests))
	if #failures > 0 then
		print("###  FAILURES:")
		for _, f in ipairs(failures) do
			print(string.format("###    [FAIL] %s — %s", f.name, f.detail))
		end
	else
		print("###  ALL TESTS PASSED")
	end
	print("############################################################")
end

---------------------------------------------------------------------------------------------------
-- Namespace Registration
---------------------------------------------------------------------------------------------------
if debug then
	debug.validation.run  = Debug_FullValidation
	debug.validation.limits = Debug_LimitEnforcementValidator
	debug.validation.faction = Debug_FactionMapDiagnostic
	debug.validation.dynasties = Debug_VerifyDynastiesData
	debug._register("validation", Debug_FullValidation, "6-phase boot/config/runtime/data/endstate/limits (~10s)", 2)
	debug._register("faction", Debug_FactionMapDiagnostic, "Faction map + false-vs-nil + transfer-path + reward audit", 2)
	debug._register("dynasties", Debug_VerifyDynastiesData, "Dynasties upgrade/correction/arena table verification", 2)
end
