---------------------------------------------------------------------------------------------------
-- CBA Debug — Validation (Phase 0-4 + FinalReport + FullValidation Orchestrator)
-- Validates all core systems: boot state, config, runtime, data, endstate.
-- Depends on: cba_debug_core.scar, cba_debug_helpers.scar
---------------------------------------------------------------------------------------------------

---------------------------------------------------------------------------------------------------
-- Phase 0: Boot — Globals, tables, module registration
---------------------------------------------------------------------------------------------------

function _Debug_Phase0_Boot()
	_Debug_PhaseHeader(0, "Boot")

	_Debug_RunTest("0.1 PLAYERS table exists", function()
		if PLAYERS == nil then return false, "PLAYERS is nil" end
		if #PLAYERS == 0 then return false, "PLAYERS is empty" end
		return true, #PLAYERS .. " players"
	end)

	_Debug_RunTest("0.2 _mod orchestrator exists", function()
		if _mod == nil then return false, "_mod is nil" end
		if type(_mod.module) ~= "string" then return false, "_mod.module not a string" end
		return true, "_mod.module=" .. _mod.module
	end)

	_Debug_RunTest("0.3 _CBA rewards table exists", function()
		if _CBA == nil then return false, "_CBA is nil" end
		return true, type(_CBA)
	end)

	_Debug_RunTest("0.4 AGS_GLOBAL_SETTINGS exists", function()
		if AGS_GLOBAL_SETTINGS == nil then return false, "AGS_GLOBAL_SETTINGS is nil" end
		return true, type(AGS_GLOBAL_SETTINGS)
	end)

	_Debug_RunTest("0.5 AGS_ENTITY_TABLE exists", function()
		if AGS_ENTITY_TABLE == nil then return false, "AGS_ENTITY_TABLE is nil" end
		local count = 0
		for _ in pairs(AGS_ENTITY_TABLE) do count = count + 1 end
		return true, count .. " civs"
	end)

	_Debug_RunTest("0.6 Entry point detection", function()
		return true, "entry=" .. tostring(_cba_debug.entry_point)
	end)

	_Debug_RunTest("0.7 World_GetPlayerCount matches PLAYERS", function()
		local ok, wpc = pcall(World_GetPlayerCount)
		if not ok then return false, "World_GetPlayerCount failed" end
		if wpc ~= #PLAYERS then return false, "mismatch: World=" .. wpc .. " PLAYERS=" .. #PLAYERS end
		return true, wpc .. " players"
	end)

	_Debug_PhaseFooter(0, "Boot")
end

---------------------------------------------------------------------------------------------------
-- Phase 1: Config — Settings types and parsed values
---------------------------------------------------------------------------------------------------

function _Debug_Phase1_Config()
	_Debug_PhaseHeader(1, "Config")

	_Debug_RunTest("1.1 MaximumPopulation type", function()
		local v = AGS_GLOBAL_SETTINGS.MaximumPopulation
		if type(v) ~= "number" then return false, "expected number, got " .. type(v) end
		return true, "MaxPop=" .. tostring(v)
	end)

	_Debug_RunTest("1.2 AutoAge setting", function()
		local v = AGS_GLOBAL_SETTINGS.AutoAge
		return true, "AutoAge=" .. tostring(v) .. " (" .. type(v) .. ")"
	end)

	_Debug_RunTest("1.3 CBA_Rewards setting", function()
		local v = AGS_GLOBAL_SETTINGS.CBA_Rewards
		return true, "CBA_Rewards=" .. tostring(v) .. " (" .. type(v) .. ")"
	end)

	_Debug_RunTest("1.4 Win condition flags", function()
		local issues = {}
		local flags = {"Annihilation", "Elimination", "Surrender", "Religious", "Wonder"}
		for _, f in ipairs(flags) do
			local v = AGS_GLOBAL_SETTINGS[f]
			if v == nil then
				table.insert(issues, f .. "=nil")
			end
		end
		if #issues > 0 then return false, table.concat(issues, ", ") end
		return true, #flags .. " win condition flags present"
	end)

	_Debug_RunTest("1.5 Resource amount parsed", function()
		if _mod.resource_amount == nil then return false, "_mod.resource_amount is nil" end
		return true, "resource_amount=" .. tostring(_mod.resource_amount)
	end)

	_Debug_RunTest("1.6 Starting resources parsed", function()
		if _mod.startingResources == nil then return false, "_mod.startingResources is nil" end
		return true, "startingResources=" .. tostring(_mod.startingResources)
	end)

	_Debug_RunTest("1.7 Siege restriction settings", function()
		local ns = AGS_GLOBAL_SETTINGS.NoSiege
		local nw = AGS_GLOBAL_SETTINGS.NoWall
		local nd = AGS_GLOBAL_SETTINGS.NoDock
		return true, string.format("NoSiege=%s NoWall=%s NoDock=%s", tostring(ns), tostring(nw), tostring(nd))
	end)

	_Debug_RunTest("1.8 Pop cap and interval", function()
		if _mod.pop_cap == nil then return false, "_mod.pop_cap is nil" end
		if _mod.pop_interval == nil then return false, "_mod.pop_interval is nil" end
		return true, string.format("cap=%s start=%s interval=%ss",
			tostring(_mod.pop_cap), tostring(_mod.pop_start), tostring(_mod.pop_interval))
	end)

	_Debug_PhaseFooter(1, "Config")
end

---------------------------------------------------------------------------------------------------
-- Phase 2: Runtime — Player state, entity references, team setup
---------------------------------------------------------------------------------------------------

function _Debug_Phase2_Runtime()
	_Debug_PhaseHeader(2, "Runtime")

	_Debug_RunTest("2.1 Player keeps found", function()
		local missing = {}
		for i, player in ipairs(PLAYERS) do
			if player.keep == nil then
				table.insert(missing, "P" .. i)
			elseif player.keep.entity == nil then
				table.insert(missing, "P" .. i .. "(entity nil)")
			end
		end
		if #missing > 0 then return false, "missing keeps: " .. table.concat(missing, ", ") end
		return true, #PLAYERS .. " keeps found"
	end)

	_Debug_RunTest("2.2 Keep positions valid", function()
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			if player.keep and player.keep.position then
				local pos = player.keep.position
				local ok, x = pcall(function() return pos.x end)
				if not ok or x == nil then
					table.insert(issues, "P" .. i .. " pos.x invalid")
				end
			end
		end
		if #issues > 0 then return false, table.concat(issues, ", ") end
		return true, "all positions valid"
	end)

	_Debug_RunTest("2.3 _mod.castles populated", function()
		if _mod.castles == nil then return false, "_mod.castles is nil" end
		local count = 0
		for _ in pairs(_mod.castles) do count = count + 1 end
		if count == 0 then return false, "_mod.castles is empty" end
		return true, count .. " castle entries"
	end)

	_Debug_RunTest("2.4 Sacred site center found", function()
		if _CBA == nil then return false, "_CBA is nil" end
		if _CBA.center == nil then return false, "_CBA.center is nil" end
		return true, "center found"
	end)

	_Debug_RunTest("2.5 Player civ resolution", function()
		local civs = {}
		for i, player in ipairs(PLAYERS) do
			local ok, civ = pcall(Player_GetRaceName, player.id)
			if not ok then
				table.insert(civs, "P" .. i .. "=ERROR")
			else
				table.insert(civs, civ)
			end
		end
		return true, table.concat(civs, ", ")
	end)

	_Debug_RunTest("2.6 Team setup", function()
		local teams = {}
		for i, player in ipairs(PLAYERS) do
			local team = player.team or "nil"
			teams["T" .. tostring(team)] = (teams["T" .. tostring(team)] or 0) + 1
		end
		local parts = {}
		for t, c in pairs(teams) do
			table.insert(parts, t .. "=" .. c)
		end
		return true, table.concat(parts, " ")
	end)

	_Debug_RunTest("2.7 Population state", function()
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			local ok_pop, pop = pcall(Player_GetCurrentPopulation, player.id, CT_Personnel)
			local ok_cap, cap = pcall(Player_GetCurrentPopulationCap, player.id, CT_Personnel)
			if ok_pop and ok_cap then
				if pop > cap and cap > 0 then
					table.insert(issues, string.format("P%d overflow %d/%d", i, pop, cap))
				end
			end
		end
		if #issues > 0 then return false, table.concat(issues, "; ") end
		return true, "all within cap"
	end)

	_Debug_PhaseFooter(2, "Runtime")
end

---------------------------------------------------------------------------------------------------
-- Phase 3: Data — Table completeness, key coverage
---------------------------------------------------------------------------------------------------

function _Debug_Phase3_Data()
	_Debug_PhaseHeader(3, "Data")

	_Debug_RunTest("3.1 AGS_ENTITY_TABLE civ coverage", function()
		local expected = {
			"english", "chinese", "french", "hre", "mongol", "rus",
			"sultanate", "abbasid", "malian", "ottoman",
			"japanese", "byzantine",
		}
		local missing = {}
		for _, civ in ipairs(expected) do
			if AGS_ENTITY_TABLE[civ] == nil then
				table.insert(missing, civ)
			end
		end
		if #missing > 0 then return false, #missing .. " missing: " .. table.concat(missing, ", ") end
		return true, #expected .. " civs covered"
	end)

	_Debug_RunTest("3.2 AGS_ENTITY_TABLE castle field", function()
		local issues = {}
		for civ, data in pairs(AGS_ENTITY_TABLE) do
			if civ ~= "neutral" and data.castle == nil then
				if civ ~= "mongol" then  -- Mongol has no keep
					table.insert(issues, civ)
				end
			end
		end
		if #issues > 0 then return false, "missing castle: " .. table.concat(issues, ", ") end
		return true, "all non-mongol civs have castle"
	end)

	_Debug_RunTest("3.3 Reward tables present", function()
		if _CBA == nil or _CBA.rewards == nil then return false, "_CBA.rewards is nil" end
		local count = 0
		for _ in pairs(_CBA.rewards) do count = count + 1 end
		if count == 0 then return false, "rewards table is empty" end
		return true, count .. " reward sets"
	end)

	_Debug_RunTest("3.4 CBA_SIEGE_UNITS table", function()
		if CBA_SIEGE_UNITS == nil then return false, "CBA_SIEGE_UNITS is nil" end
		local keys = {}
		for k in pairs(CBA_SIEGE_UNITS) do table.insert(keys, k) end
		return true, #keys .. " siege groups"
	end)

	_Debug_RunTest("3.5 Building limit state per player", function()
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			if player.obj_buildingLimit_count == nil then
				table.insert(issues, "P" .. i .. " bld_count=nil")
			end
		end
		if #issues > 0 then return false, table.concat(issues, ", ") end
		return true, #PLAYERS .. " players have building counters"
	end)

	_Debug_RunTest("3.6 Siege limit state per player", function()
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			if player.siegeLimit_count == nil then
				table.insert(issues, "P" .. i .. " siege_count=nil")
			end
		end
		if #issues > 0 then return false, table.concat(issues, ", ") end
		return true, #PLAYERS .. " players have siege counters"
	end)

	_Debug_RunTest("3.7 _annihilation module state", function()
		if _annihilation == nil then return false, "_annihilation is nil" end
		return true, "module present"
	end)

	_Debug_RunTest("3.8 _religious module state", function()
		if _religious == nil then return false, "_religious is nil" end
		if _religious.sites == nil then return false, "_religious.sites is nil" end
		local count = 0
		for _ in pairs(_religious.sites) do count = count + 1 end
		return true, count .. " sacred sites"
	end)

	_Debug_RunTest("3.9 _wonder module state", function()
		if _wonder == nil then return false, "_wonder is nil" end
		return true, "module present"
	end)

	_Debug_PhaseFooter(3, "Data")
end

---------------------------------------------------------------------------------------------------
-- Phase 4: Endstate — Win conditions, game-over checks
---------------------------------------------------------------------------------------------------

function _Debug_Phase4_Endstate()
	_Debug_PhaseHeader(4, "Endstate")

	_Debug_RunTest("4.1 Objective initialized", function()
		if _mod.objective == nil then return false, "_mod.objective is nil" end
		return true, string.format("req=%s met=%s",
			tostring(_mod.objective_requirement), tostring(_mod.objective_meet))
	end)

	_Debug_RunTest("4.2 No premature game over", function()
		local ok, go = pcall(function() return g_gameOver end)
		if ok and go == true then return false, "g_gameOver is true at validation time" end
		return true, "game still active"
	end)

	_Debug_RunTest("4.3 No eliminated players at start", function()
		local eliminated = {}
		for i, player in ipairs(PLAYERS) do
			local ok, elim = pcall(Core_IsPlayerEliminated, player.id)
			if ok and elim then
				table.insert(eliminated, "P" .. i)
			end
		end
		if #eliminated > 0 then return false, "eliminated: " .. table.concat(eliminated, ", ") end
		return true, "all players active"
	end)

	_Debug_RunTest("4.4 Kill tracking per player", function()
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			if player.killed_number == nil then
				table.insert(issues, "P" .. i .. " killed_number=nil")
			end
		end
		if #issues > 0 then return false, table.concat(issues, ", ") end
		return true, #PLAYERS .. " players have kill counters"
	end)

	_Debug_RunTest("4.5 Auto-age module state", function()
		if _autoage == nil then
			if AGS_GLOBAL_SETTINGS.AutoAge then
				return false, "_autoage nil but AutoAge enabled"
			end
			return true, "AutoAge disabled, module not loaded"
		end
		return true, "module present"
	end)

	_Debug_PhaseFooter(4, "Endstate")
end

---------------------------------------------------------------------------------------------------
-- Final Report
---------------------------------------------------------------------------------------------------

function _Debug_FinalReport()
	print("")
	print("############################################")
	print("###   CBA DEBUG — VALIDATION REPORT      ###")
	print("############################################")
	print("")

	print("  PHASE SUMMARY")
	for _, pr in ipairs(_cba_debug.phase_results) do
		local icon = (pr.passed == pr.total) and "OK" or "!!"
		print(string.format("  [%s] Phase %d %-12s  %d / %d",
			icon, pr.phase, pr.name, pr.passed, pr.total))
	end

	local failures = {}
	for _, r in ipairs(_cba_debug.test_results) do
		if not r.pass then
			table.insert(failures, r)
		end
	end

	if #failures > 0 then
		print("")
		print("  FAILURES")
		for _, f in ipairs(failures) do
			print(string.format("  [FAIL] %s — %s", f.name, f.detail))
		end
	end

	local total = #_cba_debug.test_results
	local passed = total - #failures
	print("")
	print(string.format("  TOTAL: %d / %d tests passed", passed, total))
	print("############################################")
end

---------------------------------------------------------------------------------------------------
-- Debug_FullValidation — Master entry point (~10s)
---------------------------------------------------------------------------------------------------

function Debug_FullValidation()
	_cba_debug.test_results = {}
	_cba_debug.phase_results = {}
	_cba_debug.enabled = true

	print("")
	print("============================================")
	print("  CBA DEBUG — FULL VALIDATION")
	print("============================================")

	-- Phase 0 runs immediately
	_Debug_Phase0_Boot()

	-- Phases 1-4 with staggered delays
	Rule_AddOneShot(_Debug_FullValidation_Phase1, _cba_debug.phase_delay)
end

function _Debug_FullValidation_Phase1()
	_Debug_Phase1_Config()
	Rule_AddOneShot(_Debug_FullValidation_Phase2, _cba_debug.phase_delay)
end
function _Debug_FullValidation_Phase2()
	_Debug_Phase2_Runtime()
	Rule_AddOneShot(_Debug_FullValidation_Phase3, _cba_debug.phase_delay)
end
function _Debug_FullValidation_Phase3()
	_Debug_Phase3_Data()
	Rule_AddOneShot(_Debug_FullValidation_Phase4, _cba_debug.phase_delay)
end
function _Debug_FullValidation_Phase4()
	_Debug_Phase4_Endstate()
	Rule_AddOneShot(_Debug_FinalReport, _cba_debug.phase_delay)
end
