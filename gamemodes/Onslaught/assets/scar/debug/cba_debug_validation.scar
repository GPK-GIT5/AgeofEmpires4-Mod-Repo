---------------------------------------------------------------------------------------------------
-- CBA Debug — Validation (6-Phase: Boot, Config, Runtime, Data, Endstate, Limits)
-- Validates all core systems across the onslaught-v3.3 branch.
-- Depends on: cba_debug_core.scar, cba_debug_helpers.scar
--
-- State tables validated: _mod, _CBA, _buildingLimit, _autoage,
--   _annihilation, _religious, _wonder, AGS_GLOBAL_SETTINGS
-- Console: Debug_FullValidation()  (~10s with phase delays)
--          Debug_LimitEnforcementValidator()  (Phase 5 only)
---------------------------------------------------------------------------------------------------

---------------------------------------------------------------------------------------------------
-- Phase 0: Boot — Globals, tables, module registration
---------------------------------------------------------------------------------------------------

function _Debug_Phase0_Boot()
	_Debug_PhaseHeader(0, "Boot")

	_Debug_RunTest("0.1 PLAYERS table exists", function()
		if PLAYERS == nil then return false, "PLAYERS is nil" end
		if #PLAYERS == 0 then return false, "PLAYERS is empty" end
		return true, #PLAYERS .. " players"
	end)

	_Debug_RunTest("0.2 _mod orchestrator exists", function()
		if _mod == nil then return false, "_mod is nil" end
		if type(_mod.module) ~= "string" then return false, "_mod.module not a string" end
		return true, "_mod.module=" .. _mod.module
	end)

	_Debug_RunTest("0.3 _CBA rewards table exists", function()
		-- From rewards/cba_rewards.scar
		if _CBA == nil then return false, "_CBA is nil" end
		return true, type(_CBA)
	end)

	_Debug_RunTest("0.4 AGS_GLOBAL_SETTINGS exists", function()
		if AGS_GLOBAL_SETTINGS == nil then return false, "AGS_GLOBAL_SETTINGS is nil" end
		return true, "build=" .. tostring(AGS_GLOBAL_SETTINGS_BUILD)
	end)

	_Debug_RunTest("0.5 AGS_ENTITY_TABLE exists", function()
		if AGS_ENTITY_TABLE == nil then return false, "AGS_ENTITY_TABLE is nil" end
		return true, _Debug_CountKeys(AGS_ENTITY_TABLE) .. " civs"
	end)

	_Debug_RunTest("0.6 Entry point detection", function()
		return true, "entry=" .. tostring(_cba_debug.entry_point)
	end)

	_Debug_RunTest("0.7 World_GetPlayerCount matches PLAYERS", function()
		local ok, wpc = pcall(World_GetPlayerCount)
		if not ok then return false, "World_GetPlayerCount failed" end
		if wpc ~= #PLAYERS then return false, "mismatch: World=" .. wpc .. " PLAYERS=" .. #PLAYERS end
		return true, wpc .. " players"
	end)

	_Debug_PhaseFooter(0, "Boot")
end

---------------------------------------------------------------------------------------------------
-- Phase 1: Config — Settings types and parsed values
---------------------------------------------------------------------------------------------------

function _Debug_Phase1_Config()
	_Debug_PhaseHeader(1, "Config")

	_Debug_RunTest("1.1 MaximumPopulation type", function()
		local v = AGS_GLOBAL_SETTINGS.MaximumPopulation
		if type(v) ~= "number" then return false, "expected number, got " .. type(v) end
		return true, "MaxPop=" .. tostring(v)
	end)

	_Debug_RunTest("1.2 AutoAge setting", function()
		local v = AGS_GLOBAL_SETTINGS.AutoAge
		return true, "AutoAge=" .. tostring(v) .. " (" .. type(v) .. ")"
	end)

	_Debug_RunTest("1.3 CBA_Rewards setting", function()
		local v = AGS_GLOBAL_SETTINGS.CBA_Rewards
		return true, "CBA_Rewards=" .. tostring(v) .. " (" .. type(v) .. ")"
	end)

	_Debug_RunTest("1.4 Win condition flags", function()
		local flags = {"Annihilation", "Elimination", "Surrender", "Religious", "Wonder"}
		local issues = {}
		for _, f in ipairs(flags) do
			if AGS_GLOBAL_SETTINGS[f] == nil then
				table.insert(issues, f .. "=nil")
			end
		end
		if #issues > 0 then return false, table.concat(issues, ", ") end
		return true, #flags .. " win condition flags present"
	end)

	_Debug_RunTest("1.5 Pop cap and interval", function()
		if _mod.pop_cap == nil then return false, "_mod.pop_cap is nil" end
		if _mod.pop_interval == nil then return false, "_mod.pop_interval is nil" end
		return true, string.format("cap=%s start=%s interval=%ss",
			tostring(_mod.pop_cap), tostring(_mod.pop_start), tostring(_mod.pop_interval))
	end)

	_Debug_RunTest("1.6 Siege restriction settings", function()
		local ns = AGS_GLOBAL_SETTINGS.NoSiege
		local nw = AGS_GLOBAL_SETTINGS.NoWall
		local nd = AGS_GLOBAL_SETTINGS.NoDock
		return true, string.format("NoSiege=%s NoWall=%s NoDock=%s", tostring(ns), tostring(nw), tostring(nd))
	end)

	_Debug_RunTest("1.7 Building limit settings from AGS", function()
		local mpb = AGS_GLOBAL_SETTINGS.MaximumProductionBuildings
		local msw = AGS_GLOBAL_SETTINGS.MaximumSiegeWorkshop
		return true, string.format("MaxProdBuildings=%s MaxSiegeWorkshop=%s", tostring(mpb), tostring(msw))
	end)

	_Debug_RunTest("1.8 Speed settings", function()
		if _mod.speed == nil then return false, "_mod.speed is nil" end
		return true, string.format("build=%s gather=%s production=%s",
			tostring(_mod.speed.build), tostring(_mod.speed.gather), tostring(_mod.speed.production))
	end)

	_Debug_PhaseFooter(1, "Config")
end

---------------------------------------------------------------------------------------------------
-- Phase 2: Runtime — Player state, entity references, team setup
---------------------------------------------------------------------------------------------------

function _Debug_Phase2_Runtime()
	_Debug_PhaseHeader(2, "Runtime")

	_Debug_RunTest("2.1 Player keeps found", function()
		local missing = {}
		for i, player in ipairs(PLAYERS) do
			if player.keep == nil then
				table.insert(missing, "P" .. i)
			elseif player.keep.entity == nil then
				table.insert(missing, "P" .. i .. "(entity nil)")
			end
		end
		if #missing > 0 then return false, "missing keeps: " .. table.concat(missing, ", ") end
		return true, #PLAYERS .. " keeps found"
	end)

	_Debug_RunTest("2.2 Keep positions valid", function()
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			if player.keep and player.keep.position then
				local pos = player.keep.position
				local ok, x = pcall(function() return pos.x end)
				if not ok or x == nil then
					table.insert(issues, "P" .. i .. " pos.x invalid")
				end
			end
		end
		if #issues > 0 then return false, table.concat(issues, ", ") end
		return true, "all positions valid"
	end)

	_Debug_RunTest("2.3 _mod.castles populated", function()
		if _mod.castles == nil then return false, "_mod.castles is nil" end
		local count = _Debug_CountKeys(_mod.castles)
		if count == 0 then return false, "_mod.castles is empty" end
		return true, count .. " castle entries"
	end)

	_Debug_RunTest("2.4 Sacred site center found", function()
		if _CBA == nil then return false, "_CBA is nil" end
		if _CBA.center == nil then return false, "_CBA.center is nil" end
		return true, "center found"
	end)

	_Debug_RunTest("2.5 Player civ resolution", function()
		local civs = {}
		for i, player in ipairs(PLAYERS) do
			table.insert(civs, _Debug_GetPlayerCiv(player))
		end
		return true, table.concat(civs, ", ")
	end)

	_Debug_RunTest("2.6 Team setup", function()
		local teams = {}
		for i, player in ipairs(PLAYERS) do
			local team = player.team or "nil"
			local key = "T" .. tostring(team)
			teams[key] = (teams[key] or 0) + 1
		end
		local parts = {}
		for t, c in pairs(teams) do table.insert(parts, t .. "=" .. c) end
		return true, table.concat(parts, " ")
	end)

	_Debug_RunTest("2.7 Population state", function()
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			local ok_pop, pop = pcall(Player_GetCurrentPopulation, player.id, CT_Personnel)
			local ok_cap, cap = pcall(Player_GetCurrentPopulationCap, player.id, CT_Personnel)
			if ok_pop and ok_cap then
				if pop > cap and cap > 0 then
					table.insert(issues, string.format("P%d overflow %d/%d", i, pop, cap))
				end
			end
		end
		if #issues > 0 then return false, table.concat(issues, "; ") end
		return true, "all within cap"
	end)

	_Debug_RunTest("2.8 Auto-pop cross-civ cap equality", function()
		if _AGS_AutoPop_Caps == nil or next(_AGS_AutoPop_Caps) == nil then
			return true, "auto-pop disabled or not yet initialized (skip)"
		end
		local ref_cap = nil
		local ref_idx = nil
		local diverged = {}
		for i, player in ipairs(PLAYERS) do
			if not Core_IsPlayerEliminated(player.id) then
				local tracked = _AGS_AutoPop_Caps[player.id]
				if tracked == nil then
					table.insert(diverged, string.format("P%d no tracked cap", i))
				elseif ref_cap == nil then
					ref_cap = tracked
					ref_idx = i
				elseif tracked ~= ref_cap then
					table.insert(diverged, string.format("P%d tracked=%d (ref P%d=%d)", i, tracked, ref_idx, ref_cap))
				end
			end
		end
		if #diverged > 0 then return false, table.concat(diverged, "; ") end
		local n = 0
		for _, player in ipairs(PLAYERS) do
			if not Core_IsPlayerEliminated(player.id) then n = n + 1 end
		end
		return true, string.format("%d active players all at tracked cap=%d", n, ref_cap or 0)
	end)

	_Debug_RunTest("2.9 Only authorized systems modified pop caps", function()
		if _AGS_AutoPop_Caps == nil or next(_AGS_AutoPop_Caps) == nil then
			return true, "auto-pop disabled or not yet initialized (skip)"
		end
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			local ok_eff, effective = pcall(Player_GetCurrentPopulationCap, player.id, CT_Personnel)
			if ok_eff then
				local tracked   = _AGS_AutoPop_Caps[player.id] or 0
				local tb        = player.teamBalance_popBonus or 0
				local accounted = tb
				local residual  = effective - tracked - accounted
				if math.abs(residual) > 5 then
					table.insert(issues, string.format("P%d residual=%+d (eff=%d tracked=%d tb=%d)",
						i, residual, effective, tracked, tb))
				end
			end
		end
		if #issues > 0 then return false, table.concat(issues, "; ") end
		return true, string.format("%d players — all pop deltas accounted for", #PLAYERS)
	end)

	_Debug_PhaseFooter(2, "Runtime")
end

---------------------------------------------------------------------------------------------------
-- Phase 3: Data — Table completeness, key coverage
---------------------------------------------------------------------------------------------------

function _Debug_Phase3_Data()
	_Debug_PhaseHeader(3, "Data")

	_Debug_RunTest("3.1 AGS_ENTITY_TABLE civ coverage", function()
		local expected = {
			"english", "chinese", "french", "hre", "mongol", "rus",
			"sultanate", "abbasid", "malian", "ottoman",
			"japanese", "byzantine",
		}
		local missing = {}
		for _, civ in ipairs(expected) do
			if AGS_ENTITY_TABLE[civ] == nil then table.insert(missing, civ) end
		end
		if #missing > 0 then return false, #missing .. " missing: " .. table.concat(missing, ", ") end
		return true, #expected .. " civs covered"
	end)

	_Debug_RunTest("3.1a DLC parent-mapped civ resolution", function()
		if AGS_CIV_PARENT_MAP == nil then return false, "AGS_CIV_PARENT_MAP is nil" end
		local issues = {}
		for child, parent in pairs(AGS_CIV_PARENT_MAP) do
			if AGS_ENTITY_TABLE[parent] == nil then
				table.insert(issues, child .. " -> " .. parent .. " (parent missing)")
			end
			if AGS_UNIT_BP_OVERRIDES == nil or AGS_UNIT_BP_OVERRIDES.villager == nil or AGS_UNIT_BP_OVERRIDES.villager[child] == nil then
				table.insert(issues, child .. " (no villager override)")
			end
		end
		if #issues > 0 then return false, table.concat(issues, "; ") end
		local count = 0
		for _ in pairs(AGS_CIV_PARENT_MAP) do count = count + 1 end
		return true, count .. " DLC civs resolved"
	end)

	_Debug_RunTest("3.1a2 AGS_CIV_FACTION_MAP coverage", function()
		if AGS_CIV_FACTION_MAP == nil then return false, "AGS_CIV_FACTION_MAP is nil" end
		local issues = {}
		-- Every variant in FACTION_MAP must have a parent in AGS_ENTITY_TABLE
		for child, parent in pairs(AGS_CIV_FACTION_MAP) do
			if AGS_ENTITY_TABLE[parent] == nil then
				table.insert(issues, child .. " -> " .. parent .. " (parent entity table missing)")
			end
			-- Every variant must have its own entity table (or be in parent map)
			if AGS_ENTITY_TABLE[child] == nil and (AGS_CIV_PARENT_MAP == nil or AGS_CIV_PARENT_MAP[child] == nil) then
				table.insert(issues, child .. " (no own entity table and not in parent map)")
			end
		end
		-- FACTION_MAP must be a superset of PARENT_MAP
		if AGS_CIV_PARENT_MAP ~= nil then
			for child, parent in pairs(AGS_CIV_PARENT_MAP) do
				if AGS_CIV_FACTION_MAP[child] == nil then
					table.insert(issues, child .. " in PARENT_MAP but missing from FACTION_MAP")
				elseif AGS_CIV_FACTION_MAP[child] ~= parent then
					table.insert(issues, child .. " faction mismatch: PARENT=" .. parent .. " FACTION=" .. AGS_CIV_FACTION_MAP[child])
				end
			end
		end
		if #issues > 0 then return false, table.concat(issues, "; ") end
		local count = 0
		for _ in pairs(AGS_CIV_FACTION_MAP) do count = count + 1 end
		return true, count .. " variant civs in faction map"
	end)

	_Debug_RunTest("3.1a3 Explicit-false vs parent override guard", function()
		-- For every variant that has explicit false entries, verify the false-guard
		-- would block parent fallback (i.e. AGS_CivTableHasExplicitFalse returns true).
		if AGS_CIV_PARENT_MAP == nil then return true, "no parent map, skip" end
		local violations = {}
		local checked = 0
		for child, parent in pairs(AGS_CIV_PARENT_MAP) do
			local child_table = AGS_ENTITY_TABLE[child]
			local parent_table = AGS_ENTITY_TABLE[parent]
			if child_table ~= nil and parent_table ~= nil then
				for key, val in pairs(child_table) do
					if val == false then
						checked = checked + 1
						-- Guard function must return true
						if not AGS_CivTableHasExplicitFalse(child, key) then
							table.insert(violations, child .. "/" .. key .. " (guard returned false)")
						end
						-- If parent has a real value, this would have been a false-override leak
						if type(parent_table[key]) == "string" then
							table.insert(violations, child .. "/" .. key .. " CONFLICT: parent " .. parent .. " has '" .. parent_table[key] .. "'")
						end
					end
				end
			end
		end
		-- Report conflicts as informational, not failures — the guard prevents the leak
		local conflicts = 0
		local clean = {}
		for _, v in ipairs(violations) do
			if string.find(v, "CONFLICT") then
				conflicts = conflicts + 1
			else
				table.insert(clean, v)
			end
		end
		if #clean > 0 then return false, table.concat(clean, "; ") end
		return true, checked .. " false-entries checked, " .. conflicts .. " parent-override conflicts guarded"
	end)

	-- === Civ-sync validator: iterate AGS_CIV_PREFIXES against all dependent tables ===

	_Debug_RunTest("3.1b AGS_CIV_PREFIXES -> AGS_ENTITY_TABLE sync", function()
		if AGS_CIV_PREFIXES == nil then return false, "AGS_CIV_PREFIXES is nil" end
		local missing = {}
		for civ, _ in pairs(AGS_CIV_PREFIXES) do
			if AGS_ENTITY_TABLE[civ] == nil then
				-- Allow faction-map or parent-map fallback for variant civs
				local parent = AGS_CIV_FACTION_MAP and AGS_CIV_FACTION_MAP[civ]
				if parent == nil then parent = AGS_CIV_PARENT_MAP and AGS_CIV_PARENT_MAP[civ] end
				if parent == nil or AGS_ENTITY_TABLE[parent] == nil then
					table.insert(missing, civ)
				end
			end
		end
		if #missing > 0 then return false, #missing .. " missing: " .. table.concat(missing, ", ") end
		local count = 0
		for _ in pairs(AGS_CIV_PREFIXES) do count = count + 1 end
		return true, count .. " civs synced"
	end)

	_Debug_RunTest("3.1c AGS_CIV_PREFIXES -> _CBA.rewards sync", function()
		if _CBA == nil or _CBA.rewards == nil then return false, "_CBA.rewards is nil" end
		local missing = {}
		for civ, _ in pairs(AGS_CIV_PREFIXES) do
			if _CBA.rewards[civ] == nil then
				table.insert(missing, civ)
			end
		end
		if #missing > 0 then return false, #missing .. " missing: " .. table.concat(missing, ", ") end
		local count = 0
		for _ in pairs(AGS_CIV_PREFIXES) do count = count + 1 end
		return true, count .. " civs have rewards"
	end)

	_Debug_RunTest("3.1d AGS_CIV_PREFIXES -> CBA_CIV_BP_SUFFIX sync", function()
		if CBA_CIV_BP_SUFFIX == nil then return true, "CBA_CIV_BP_SUFFIX not loaded (ok)" end
		local missing = {}
		for civ, _ in pairs(AGS_CIV_PREFIXES) do
			if CBA_CIV_BP_SUFFIX[civ] == nil then
				table.insert(missing, civ)
			end
		end
		if #missing > 0 then return false, #missing .. " missing: " .. table.concat(missing, ", ") end
		local count = 0
		for _ in pairs(AGS_CIV_PREFIXES) do count = count + 1 end
		return true, count .. " civs synced"
	end)

	_Debug_RunTest("3.1e _LEAVER_MILITARY_SUFFIX_OVERRIDE consistency", function()
		if _LEAVER_MILITARY_SUFFIX_OVERRIDE == nil then return true, "no overrides defined (ok)" end
		local issues = {}
		for civ, override_suffix in pairs(_LEAVER_MILITARY_SUFFIX_OVERRIDE) do
			local prefix = AGS_CIV_PREFIXES[civ]
			if prefix == nil then
				table.insert(issues, civ .. " not in AGS_CIV_PREFIXES")
			else
				local default_suffix = string.sub(prefix, 1, -2)
				if default_suffix == override_suffix then
					table.insert(issues, civ .. " override '" .. override_suffix .. "' equals default (redundant)")
				end
			end
		end
		if #issues > 0 then return false, table.concat(issues, "; ") end
		local count = 0
		for _ in pairs(_LEAVER_MILITARY_SUFFIX_OVERRIDE) do count = count + 1 end
		return true, count .. " overrides valid"
	end)

	_Debug_RunTest("3.1f Reward BP precache manifest coverage", function()
		if _PRECACHE_MANIFEST == nil then return false, "_PRECACHE_MANIFEST not built" end
		local M = _PRECACHE_MANIFEST
		local excluded_total = (M.excluded_age1_sources or 0) + (M.excluded_age1_targets or 0)
		if M.total_gaps > 0 then
			local gap_summary = {}
			for _, gap in ipairs(M.gaps) do
				gap_summary[gap.src_bp] = (gap_summary[gap.src_bp] or 0) + 1
			end
			local parts = {}
			for bp, count in pairs(gap_summary) do
				table.insert(parts, bp .. " x" .. count)
			end
			return false, M.total_gaps .. " required gaps: " .. table.concat(parts, ", ") .. " | excluded_age1=" .. excluded_total
		end
		local n_confirmed = 0
		for _ in pairs(M.confirmed) do n_confirmed = n_confirmed + 1 end
		return true, M.total_routes .. " required routes, " .. n_confirmed .. " unique targets confirmed, excluded_age1=" .. excluded_total
	end)

	_Debug_RunTest("3.1g Weapon-audit: forced-precache BP hardpoints", function()
		-- Consumes results from Debug_LeaverWeaponAudit() if already run.
		-- Passes when no concrete weapon failures exist; skips when audit not yet run.
		if _WEAPON_AUDIT_RESULTS == nil then
			return true, "weapon-audit not yet run (run Debug_LeaverWeaponAudit to populate)"
		end
		local W = _WEAPON_AUDIT_RESULTS
		local issues = {}
		if (W.weapon_missing or 0) > 0 then
			table.insert(issues, W.weapon_missing .. " weapon_missing")
		end
		if (W.spawn_error or 0) > 0 then
			table.insert(issues, W.spawn_error .. " spawn_error")
		end
		if (W.bp_phantom or 0) > 0 then
			table.insert(issues, W.bp_phantom .. " bp_phantom")
		end
		if (W.weapon_query_error or 0) > 0 then
			table.insert(issues, W.weapon_query_error .. " weapon_query_error")
		end
		if #issues > 0 then
			return false, table.concat(issues, ", ") .. " out of " .. (W.total or 0) .. " forced BPs"
		end
		local ok_count = (W.weapon_ok or 0)
		local total = (W.total or 0)
		local msg = ok_count .. "/" .. total .. " weapon_ok"
		return true, msg
	end)

	_Debug_RunTest("3.1h Precache coverage: reward BPs in forced table", function()
		-- Verifies every recurring unit_upgrade BP in reward tables is covered
		-- by _LEAVER_PRECACHE_ALWAYS_REQUIRED_BP. Catches gaps like unit_horseman_4_mal.
		if _LEAVER_PRECACHE_ALWAYS_REQUIRED_BP == nil then
			return false, "_LEAVER_PRECACHE_ALWAYS_REQUIRED_BP is nil"
		end
		if _CBA == nil or _CBA.rewards == nil then
			return true, "no reward tables loaded (skip)"
		end
		local missing = {}
		local checked = 0
		for civ, thresholds in pairs(_CBA.rewards) do
			for _, reward in pairs(thresholds) do
				if reward.unit_upgrade ~= nil then
					checked = checked + 1
					local ok_name, bp_name = pcall(BP_GetName, reward.unit_upgrade)
					if ok_name and bp_name ~= nil then
						if _LEAVER_PRECACHE_ALWAYS_REQUIRED_BP[bp_name] == nil then
							missing[bp_name] = (missing[bp_name] or 0) + 1
						end
					end
				end
			end
		end
		if next(missing) ~= nil then
			local parts = {}
			for bp, count in pairs(missing) do
				table.insert(parts, bp .. " x" .. count)
			end
			return false, #parts .. " reward BPs not in forced-precache: " .. table.concat(parts, ", ")
		end
		return true, checked .. " recurring reward BPs all covered"
	end)

	_Debug_RunTest("3.1i Spawner-exempt prefix table initialized", function()
		-- Verifies _LEAVER_SPAWNER_EXEMPT_PREFIXES exists and has the expected 3 entries.
		if _LEAVER_SPAWNER_EXEMPT_PREFIXES == nil then
			return false, "_LEAVER_SPAWNER_EXEMPT_PREFIXES is nil — spawner exemption disabled"
		end
		if type(_LEAVER_SPAWNER_EXEMPT_PREFIXES) ~= "table" then
			return false, "_LEAVER_SPAWNER_EXEMPT_PREFIXES is " .. type(_LEAVER_SPAWNER_EXEMPT_PREFIXES) .. ", expected table"
		end
		if #_LEAVER_SPAWNER_EXEMPT_PREFIXES < 3 then
			return false, "expected at least 3 exempt prefixes, found " .. #_LEAVER_SPAWNER_EXEMPT_PREFIXES
		end
		if type(_Leaver_IsSpawnerExemptBP) ~= "function" then
			return false, "_Leaver_IsSpawnerExemptBP function not available"
		end
		-- Spot check: unit_manatarms_3_eng must be exempt, unit_trebuchet_4_eng must not
		if not _Leaver_IsSpawnerExemptBP("unit_manatarms_3_eng") then
			return false, "unit_manatarms_3_eng not exempt (expected exempt)"
		end
		if _Leaver_IsSpawnerExemptBP("unit_trebuchet_4_eng") then
			return false, "unit_trebuchet_4_eng is exempt (expected non-exempt)"
		end
		return true, #_LEAVER_SPAWNER_EXEMPT_PREFIXES .. " exempt prefixes present"
	end)

	_Debug_RunTest("3.2 AGS_ENTITY_TABLE castle field", function()
		local issues = {}
		for civ, data in pairs(AGS_ENTITY_TABLE) do
			if civ ~= "neutral" and data.castle == nil then
				if civ ~= "mongol" then
					table.insert(issues, civ)
				end
			end
		end
		if #issues > 0 then return false, "missing castle: " .. table.concat(issues, ", ") end
		return true, "all non-mongol civs have castle"
	end)

	_Debug_RunTest("3.3 Reward tables present (rewards.scar)", function()
		if _CBA == nil or _CBA.rewards == nil then return false, "_CBA.rewards is nil" end
		local count = _Debug_CountKeys(_CBA.rewards)
		if count == 0 then return false, "rewards table is empty" end
		return true, count .. " reward sets"
	end)

	_Debug_RunTest("3.4 Building limit state per player", function()
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			if player.obj_buildingLimit_count == nil then
				table.insert(issues, "P" .. i .. " bld_count=nil")
			end
		end
		if #issues > 0 then return false, table.concat(issues, ", ") end
		return true, #PLAYERS .. " players have building counters"
	end)

	_Debug_RunTest("3.5 Siege limit state per player", function()
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			if player.siegeLimit_count == nil then
				table.insert(issues, "P" .. i .. " siege_count=nil")
			end
		end
		if #issues > 0 then return false, table.concat(issues, ", ") end
		return true, #PLAYERS .. " players have siege counters"
	end)

	_Debug_RunTest("3.5a Ram limit state per player", function()
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			if player.ramLimit_count == nil then
				table.insert(issues, "P" .. i .. " ram_count=nil")
			end
		end
		if #issues > 0 then return false, table.concat(issues, ", ") end
		return true, #PLAYERS .. " players have ram counters"
	end)

	_Debug_RunTest("3.5b Siege tower limit state per player", function()
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			if player.siegeTowerLimit_count == nil then
				table.insert(issues, "P" .. i .. " tower_count=nil")
			end
		end
		if #issues > 0 then return false, table.concat(issues, ", ") end
		return true, #PLAYERS .. " players have siege tower counters"
	end)

	_Debug_RunTest("3.5c Pending counters initialized", function()
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			if player.ramLimit_pending == nil then
				table.insert(issues, "P" .. i .. " ramLimit_pending=nil")
			end
			if player.siegeTowerLimit_pending == nil then
				table.insert(issues, "P" .. i .. " siegeTowerLimit_pending=nil")
			end
		end
		if #issues > 0 then return false, table.concat(issues, ", ") end
		return true, #PLAYERS .. " players have pending counters"
	end)

	_Debug_RunTest("3.5e Reward upgrade constant: AGS_UP_SIEGE_ENGINEERS", function()
		if AGS_UP_SIEGE_ENGINEERS == nil then return false, "AGS_UP_SIEGE_ENGINEERS is nil" end
		-- Verify English 100-kill reward uses the canonical constant
		if _CBA and _CBA.rewards and _CBA.rewards["english"] and _CBA.rewards["english"][100] then
			local r = _CBA.rewards["english"][100]
			if r.upgrade ~= AGS_UP_SIEGE_ENGINEERS then
				return false, "English 100-kill reward uses wrong upgrade constant"
			end
		end
		return true, "AGS_UP_SIEGE_ENGINEERS verified"
	end)

	_Debug_RunTest("3.6 _annihilation module (cba_annihilation.scar)", function()
		if _annihilation == nil then return false, "_annihilation is nil" end
		return true, "module present"
	end)

	_Debug_RunTest("3.7 _religious module (cba_religious.scar)", function()
		if _religious == nil then return false, "_religious is nil" end
		if _religious.sites == nil then return false, "_religious.sites is nil" end
		local count = _Debug_CountKeys(_religious.sites)
		return true, count .. " sacred sites"
	end)

	_Debug_RunTest("3.8 _wonder module (wonder.scar)", function()
		if _wonder == nil then return false, "_wonder is nil" end
		return true, "time_victory=" .. tostring(_wonder.time_victory)
	end)

	_Debug_RunTest("3.9 _autoage module (cba_auto_age.scar)", function()
		if _autoage == nil then
			if AGS_GLOBAL_SETTINGS.AutoAge then
				return false, "_autoage nil but AutoAge enabled"
			end
			return true, "AutoAge disabled, module not loaded"
		end
		return true, "module=" .. tostring(_autoage.module)
	end)

	_Debug_PhaseFooter(3, "Data")
end

---------------------------------------------------------------------------------------------------
-- Phase 4: Endstate — Win conditions, game-over checks
---------------------------------------------------------------------------------------------------

function _Debug_Phase4_Endstate()
	_Debug_PhaseHeader(4, "Endstate")

	_Debug_RunTest("4.1 Objective initialized", function()
		if _mod.objective == nil then return false, "_mod.objective is nil" end
		return true, string.format("req=%s met=%s",
			tostring(_mod.objective_requirement), tostring(_mod.objective_meet))
	end)

	_Debug_RunTest("4.2 No premature game over", function()
		local ok, go = pcall(function() return g_gameOver end)
		if ok and go == true then return false, "g_gameOver is true at validation time" end
		return true, "game still active"
	end)

	_Debug_RunTest("4.3 No eliminated players at start", function()
		local eliminated = {}
		for i, player in ipairs(PLAYERS) do
			local ok, elim = pcall(Core_IsPlayerEliminated, player.id)
			if ok and elim then table.insert(eliminated, "P" .. i) end
		end
		if #eliminated > 0 then return false, "eliminated: " .. table.concat(eliminated, ", ") end
		return true, "all players active"
	end)

	_Debug_RunTest("4.4 Kill tracking per player (rewards.scar)", function()
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			if player.killed_number == nil then
				table.insert(issues, "P" .. i .. " killed_number=nil")
			end
		end
		if #issues > 0 then return false, table.concat(issues, ", ") end
		return true, #PLAYERS .. " players have kill counters"
	end)

	_Debug_RunTest("4.5 Annihilation module ready (cba_annihilation.scar)", function()
		if _annihilation == nil then return false, "_annihilation is nil" end
		local p, d = _Debug_FunctionExists("Annihilation_CheckVictory")
		return p, d
	end)

	_Debug_PhaseFooter(4, "Endstate")
end

---------------------------------------------------------------------------------------------------
-- Phase 5: Limits — Enforcement pipeline, reward queue, deferred UI
---------------------------------------------------------------------------------------------------

function _Debug_Phase5_Limits()
	_Debug_PhaseHeader(5, "Limits")

	_Debug_RunTest("5.1 CBA_Options_EnforcePostTransfer exists", function()
		return _Debug_FunctionExists("CBA_Options_EnforcePostTransfer")
	end)

	_Debug_RunTest("5.2 CBA_Options_RevalidateAll exists", function()
		return _Debug_FunctionExists("CBA_Options_RevalidateAll")
	end)

	_Debug_RunTest("5.3 CBA_Options_RevalidateAllPlayers exists", function()
		return _Debug_FunctionExists("CBA_Options_RevalidateAllPlayers")
	end)

	_Debug_RunTest("5.4 Population cap validity", function()
		local issues = {}
		for i, player in ipairs(PLAYERS) do
			local ok_pop, pop = pcall(Player_GetCurrentPopulation, player.id, CT_Personnel)
			local ok_cap, cap = pcall(Player_GetCurrentPopulationCap, player.id, CT_Personnel)
			if ok_pop and ok_cap and pop > cap then
				table.insert(issues, string.format("P%d pop=%d cap=%d", i, pop, cap))
			end
		end
		if #issues > 0 then return false, "over cap: " .. table.concat(issues, ", ") end
		return true, #PLAYERS .. " players within pop cap"
	end)

	_Debug_RunTest("5.5 _reward_queue is a table", function()
		if _reward_queue == nil then return false, "_reward_queue is nil" end
		if type(_reward_queue) ~= "table" then return false, "type=" .. type(_reward_queue) end
		return true, "type=table"
	end)

	_Debug_RunTest("5.6 AGS_LimitsUI_DeferUpdate exists", function()
		return _Debug_FunctionExists("AGS_LimitsUI_DeferUpdate")
	end)

	_Debug_PhaseFooter(5, "Limits")
end

---------------------------------------------------------------------------------------------------
-- Final Report
---------------------------------------------------------------------------------------------------

function _Debug_FinalReport()
	print("")
	print("############################################")
	print("###   CBA DEBUG — VALIDATION REPORT      ###")
	print("############################################")
	print("")

	print("  PHASE SUMMARY")
	for _, pr in ipairs(_cba_debug.phase_results) do
		local icon = (pr.passed == pr.total) and "OK" or "!!"
		print(string.format("  [%s] Phase %d %-12s  %d / %d",
			icon, pr.phase, pr.name, pr.passed, pr.total))
	end

	local failures = {}
	for _, r in ipairs(_cba_debug.test_results) do
		if not r.pass then table.insert(failures, r) end
	end

	if #failures > 0 then
		print("")
		print("  FAILURES")
		for _, f in ipairs(failures) do
			print(string.format("  [FAIL] %s — %s", f.name, f.detail))
		end
	end

	local total = #_cba_debug.test_results
	local passed = total - #failures
	print("")
	print(string.format("  TOTAL: %d / %d tests passed", passed, total))
	print("############################################")

	-- Restore debug logging to pre-validation state
	if _cba_debug._full_validation_prev_enabled ~= nil then
		_cba_debug.enabled = _cba_debug._full_validation_prev_enabled
		_cba_debug._full_validation_prev_enabled = nil
	end
	print("[CBA_DEBUG] FullValidation complete: debug logging restored to previous state")

	-- Emit the end marker so the master/sub orchestrators (StressGamemode,
	-- MasterSuite) can chain to the next sub-suite.  No-op when run standalone.
	_Debug_EndMarker("Validation", passed, total, 0)
end

---------------------------------------------------------------------------------------------------
-- Debug_FullValidation — Master entry point (~10s)
---------------------------------------------------------------------------------------------------

function Debug_FullValidation()
	_cba_debug.test_results = {}
	_cba_debug.phase_results = {}
	_cba_debug._full_validation_prev_enabled = _cba_debug.enabled
	_cba_debug.enabled = true

	print("")
	print("============================================")
	print("  CBA DEBUG — FULL VALIDATION (6 phases)")
	print("  Branch: onslaught-v3.3")
	print("============================================")

	_Debug_Phase0_Boot()
	Rule_AddOneShot(_Debug_FullValidation_Phase1, _cba_debug.phase_delay)
end

function _Debug_FullValidation_Phase1()
	_Debug_Phase1_Config()
	Rule_AddOneShot(_Debug_FullValidation_Phase2, _cba_debug.phase_delay)
end
function _Debug_FullValidation_Phase2()
	_Debug_Phase2_Runtime()
	Rule_AddOneShot(_Debug_FullValidation_Phase3, _cba_debug.phase_delay)
end
function _Debug_FullValidation_Phase3()
	_Debug_Phase3_Data()
	Rule_AddOneShot(_Debug_FullValidation_Phase4, _cba_debug.phase_delay)
end
function _Debug_FullValidation_Phase4()
	_Debug_Phase4_Endstate()
	Rule_AddOneShot(_Debug_FullValidation_Phase5, _cba_debug.phase_delay)
end
function _Debug_FullValidation_Phase5()
	_Debug_Phase5_Limits()
	Rule_AddOneShot(_Debug_FinalReport, _cba_debug.phase_delay)
end

