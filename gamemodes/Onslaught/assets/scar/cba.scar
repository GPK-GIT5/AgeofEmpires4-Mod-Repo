-- Fix: Mongol 2x 
-- Add: Restriction lobby section
-- Add: Restriction lobby option: Maximum stone/palisade wall (team based)
-- Add: Upgrade limit (outpost)
-----------------------------------------------------------------------
-- WIP: Siege Limit / Set restrictions 
function CBA_Options_SiegeLimit_Disable(player_id, siege_limit, lock_type)
	
	local player_civ = Player_GetRaceName(player_id)
	local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ
	local player = Core_GetPlayersTableEntry(player_id)
	
	-- Filter: Siege Production Buildings
	local player_buildings = Player_GetAllEntities(player.id)
	EGroup_Filter(player_buildings, "scar_siegeworkshop", FILTER_REMOVE, player.eg_siegeproduction)
	
	-- Filter: Siege Production Buildings / Faction Specific
	if branch_civ == "english" then
		EGroup_Filter(player_buildings, "scar_keep", FILTER_REMOVE, player.eg_siegeproduction)
		
	elseif player_civ == "chinese" then
		EGroup_Filter(player_buildings, EBP.CHINESE.BUILDING_LANDMARK_AGE2_CLOCKTOWER_CONTROL_CHI, FILTER_REMOVE, player.eg_siegeproduction)
		
	elseif branch_civ == "french" then
		EGroup_Filter(player_buildings, EBP.FRENCH.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE, FILTER_REMOVE, player.eg_siegeproduction)
		-- Expansion
	elseif player_civ == "french_ha_01" then
		EGroup_Filter(player_buildings, EBP.FRENCH_HA_01.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE_HA_01, FILTER_REMOVE, player.eg_siegeproduction)
		
	elseif player_civ == "ottoman" then
		EGroup_Filter(player_buildings, EBP.OTTOMAN.BUILDING_LANDMARK_AGE2_TOPHANE_ARMORY_OTT, FILTER_REMOVE, player.eg_siegeproduction)
	end
	
	-- Siege limit (1) - Springald
	if (siege_limit == 1 and lock_type == ITEM_LOCKED) or (siege_limit >= 1 and lock_type == ITEM_UNLOCKED) then
		-- Springald / Faction ALL
		AGS_SetSquadProductionAvailabilitySafe(player.id, AGS_GetSiegeUnit(player.raceName, BP_SIEGE_SPRINGALD), lock_type, "CBA_Options_SiegeLimit_Disable/springald/" .. tostring(player.raceName))
		if player_civ == "sultanate_ha_tug" then
			AGS_SetSquadProductionAvailabilitySafe(player.id, BP_GetSquadBlueprint("unit_war_elephant_ballista_3_sul_ha_tug"), lock_type, "CBA_Options_SiegeLimit_Disable/springald_ballista_elephant_3")
			AGS_SetSquadProductionAvailabilitySafe(player.id, BP_GetSquadBlueprint("unit_war_elephant_ballista_4_sul_ha_tug"), lock_type, "CBA_Options_SiegeLimit_Disable/springald_ballista_elephant_4")
		end
		-- Springald / Faction unique
		if branch_civ == "mongol" then
			Player_SetEntityProductionAvailability(player.id, EBP.MONGOL.UNIT_SPRINGALD_3_FIELD_CONSTRUCT_MON, lock_type)
		elseif player_civ == "abbasid" then
			Player_SetEntityProductionAvailability(player.id, EBP.ABBASID.UNIT_SPRINGALD_3_BUILDABLE_ABB, lock_type)
		elseif player_civ == "abbasid_ha_01" then
			Player_SetEntityProductionAvailability(player.id, EBP.ABBASID_HA_01.UNIT_SPRINGALD_3_BUILDABLE_ABB_HA_01, lock_type)
		end
		
		-- Disable siege units / FACTION UNIQUE
		if branch_civ == "mongol" then
			for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_faction_mon) do
				local unit_SBP = AGS_GetSiegeUnit(player.raceName, unit_blueprint)
				if unit_SBP == nil then
					AGS_WarnNilBlueprint("AGS_GetSiegeUnit", "SquadBlueprint", "CBA_Options_SiegeLimit_Disable/mongol_limit1/" .. tostring(player.raceName) .. "/" .. tostring(unit_blueprint))
				elseif not AGS_IsSBPOfTypeSafe(unit_SBP, "springald", "CBA_Options_SiegeLimit_Disable/mongol_limit1") and not AGS_IsSBPOfTypeSafe(unit_SBP, "culverin", "CBA_Options_SiegeLimit_Disable/mongol_limit1") and not AGS_IsSBPOfTypeSafe(unit_SBP, "trebuchet_traction", "CBA_Options_SiegeLimit_Disable/mongol_limit1") then
					AGS_SetSquadProductionAvailabilitySafe(player.id, unit_SBP, lock_type, "CBA_Options_SiegeLimit_Disable/mongol_limit1/" .. tostring(player.raceName) .. "/" .. tostring(unit_blueprint))
				end
			end
			for id, entity_blueprint in pairs(CBA_SIEGE_UNITS.siege_buildable_mon) do
				-- Filter types
				if entity_blueprint ~= "unit_springald_3_field_construct_mon" and entity_blueprint ~= "unit_trebuchet_4_tr_field_construct_mon" then
					AGS_SetEntityProductionAvailabilitySafe(player.id, BP_GetEntityBlueprint(entity_blueprint), lock_type, "CBA_Options_SiegeLimit_Disable/mongol_buildable_limit1/" .. tostring(entity_blueprint)) -- Field Constructed = Entity
				end
			end
		elseif player_civ == "abbasid" then
			Player_SetEntityProductionAvailability(player.id, EBP.ABBASID.UNIT_MANGONEL_3_BUILDABLE_ABB, lock_type) -- Field Constructed = Entity

		elseif player_civ == "abbasid_ha_01" then
			Player_SetEntityProductionAvailability(player.id, EBP.ABBASID_HA_01.UNIT_MANGONEL_3_BUILDABLE_ABB_HA_01, lock_type) -- Field Constructed = Entity

		elseif player_civ == "french" or player_civ == "french_ha_01" then
			for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_faction_fre) do
				local unit_SBP = AGS_GetSiegeUnit(player.raceName, unit_blueprint)
				if unit_SBP == nil then
					AGS_WarnNilBlueprint("AGS_GetSiegeUnit", "SquadBlueprint", "CBA_Options_SiegeLimit_Disable/french_limit1/" .. tostring(player.raceName) .. "/" .. tostring(unit_blueprint))
				elseif not AGS_IsSBPOfTypeSafe(unit_SBP, "culverin", "CBA_Options_SiegeLimit_Disable/french_limit1") then
					AGS_SetSquadProductionAvailabilitySafe(player.id, unit_SBP, lock_type, "CBA_Options_SiegeLimit_Disable/french_limit1/" .. tostring(player.raceName) .. "/" .. tostring(unit_blueprint))
				end
			end
			
		elseif player_civ == "chinese" then
			for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_faction_chi) do
				AGS_SetSquadProductionAvailabilitySafe(player.id, AGS_GetSiegeUnit(player.raceName, unit_blueprint), lock_type, "CBA_Options_SiegeLimit_Disable/chinese_limit1/" .. tostring(player.raceName) .. "/" .. tostring(unit_blueprint))
			end
			
		elseif player_civ == "chinese_ha_01" then
			Player_SetSquadProductionAvailability(player.id, SBP.CHINESE_HA_01.UNIT_NEST_OF_BEES_4_CHI_HA_01, lock_type)
		else
			AGS_SetSquadProductionAvailabilitySafe(player.id, AGS_GetSiegeUnit(player.raceName, BP_SIEGE_RIBAULDEQUIN), lock_type, "CBA_Options_SiegeLimit_Disable/ribauldequin_limit1/" .. tostring(player.raceName))
		end
		
		-- Queue preservation: items already in production queues are never cancelled.
		-- Over-cap enforcement is handled at spawn time by EnforceSpawnCap.
	end
	
	-- Siege limit (2) - Trebuchet TR/Culverin (rams managed independently by RamLimit)
	if (siege_limit <= 2 and lock_type == ITEM_LOCKED) or (siege_limit >= 2 and lock_type == ITEM_UNLOCKED) then
		
		-- Disable Groups
		for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_value_2) do
			AGS_SetSquadProductionAvailabilitySafe(player.id, AGS_GetSiegeUnit(player.raceName, unit_blueprint), lock_type, "CBA_Options_SiegeLimit_Disable/limit2/" .. tostring(player.raceName) .. "/" .. tostring(unit_blueprint))	
		end
		
		-- Disable unit: Trebuchet (Traction)
		if branch_civ == "mongol" then
			Player_SetSquadProductionAvailability(player.id, SBP.MONGOL.UNIT_TREBUCHET_4_TR_MON, lock_type)
			Player_SetSquadProductionAvailability(player.id, SBP.MONGOL.UNIT_SPRINGALD_3_DOUBLE_MON, lock_type)
			Player_SetEntityProductionAvailability(player.id, EBP.MONGOL.UNIT_TREBUCHET_4_TR_FIELD_CONSTRUCT_MON, lock_type)
		end
		
		-- Queue preservation: items already in production queues are never cancelled.
	end
	
	-- Siege limit (3) - Mangonel/Ribauldequin/Trebuchet CW/Bombard (Excl. Great Bombard)
	if (siege_limit <= 3 and lock_type == ITEM_LOCKED) or (siege_limit >= 3 and lock_type == ITEM_UNLOCKED) then
		
		-- Disable siege units / ALL FACTIONS
		for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_faction_all) do
			local unit_SBP = AGS_GetSiegeUnit(player.raceName, unit_blueprint)
			if unit_SBP == nil then
				AGS_WarnNilBlueprint("AGS_GetSiegeUnit", "SquadBlueprint", "CBA_Options_SiegeLimit_Disable/all_limit3/" .. tostring(player.raceName) .. "/" .. tostring(unit_blueprint))
			elseif not AGS_IsSBPOfTypeSafe(unit_SBP, "springald", "CBA_Options_SiegeLimit_Disable/all_limit3") and not AGS_IsSBPOfTypeSafe(unit_SBP, "culverin", "CBA_Options_SiegeLimit_Disable/all_limit3") and not AGS_IsSBPOfTypeSafe(unit_SBP, "trebuchet_traction", "CBA_Options_SiegeLimit_Disable/all_limit3") and not AGS_IsSBPOfTypeSafe(unit_SBP, "ram", "CBA_Options_SiegeLimit_Disable/all_limit3") 
				and not (AGS_IsSBPOfTypeSafe(unit_SBP, "bombard", "CBA_Options_SiegeLimit_Disable/all_limit3") and player_civ == "ottoman") then
				AGS_SetSquadProductionAvailabilitySafe(player.id, unit_SBP, lock_type, "CBA_Options_SiegeLimit_Disable/all_limit3/" .. tostring(player.raceName) .. "/" .. tostring(unit_blueprint))
			end
		end
		
		-- Disable siege units / FACTION UNIQUE
		if branch_civ == "mongol" then
			for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_faction_mon) do
				local unit_SBP = AGS_GetSiegeUnit(player.raceName, unit_blueprint)
				if unit_SBP == nil then
					AGS_WarnNilBlueprint("AGS_GetSiegeUnit", "SquadBlueprint", "CBA_Options_SiegeLimit_Disable/mongol_limit3/" .. tostring(player.raceName) .. "/" .. tostring(unit_blueprint))
				elseif not AGS_IsSBPOfTypeSafe(unit_SBP, "springald", "CBA_Options_SiegeLimit_Disable/mongol_limit3") and not AGS_IsSBPOfTypeSafe(unit_SBP, "culverin", "CBA_Options_SiegeLimit_Disable/mongol_limit3") and not AGS_IsSBPOfTypeSafe(unit_SBP, "trebuchet_traction", "CBA_Options_SiegeLimit_Disable/mongol_limit3") then
					AGS_SetSquadProductionAvailabilitySafe(player.id, unit_SBP, lock_type, "CBA_Options_SiegeLimit_Disable/mongol_limit3/" .. tostring(player.raceName) .. "/" .. tostring(unit_blueprint))
				end
			end
			for id, entity_blueprint in pairs(CBA_SIEGE_UNITS.siege_buildable_mon) do
				-- Filter types
				if entity_blueprint ~= "unit_springald_3_field_construct_mon" and entity_blueprint ~= "unit_trebuchet_4_tr_field_construct_mon" then
					AGS_SetEntityProductionAvailabilitySafe(player.id, BP_GetEntityBlueprint(entity_blueprint), lock_type, "CBA_Options_SiegeLimit_Disable/mongol_buildable_limit3/" .. tostring(entity_blueprint)) -- Field Constructed = Entity
				end
			end
			
		elseif player_civ == "abbasid" then
			Player_SetEntityProductionAvailability(player.id, EBP.ABBASID.UNIT_MANGONEL_3_BUILDABLE_ABB, lock_type) -- Field Constructed = Entity

		elseif player_civ == "abbasid_ha_01" then
			Player_SetEntityProductionAvailability(player.id, EBP.ABBASID_HA_01.UNIT_MANGONEL_3_BUILDABLE_ABB_HA_01, lock_type) -- Field Constructed = Entity
			-- Ram Tower moved to RamLimit_Disable (counts as 2 rams)

		elseif player_civ == "french" or player_civ == "french_ha_01" then
			for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_faction_fre) do
				local unit_SBP = AGS_GetSiegeUnit(player.raceName, unit_blueprint)
				if unit_SBP == nil then
					AGS_WarnNilBlueprint("AGS_GetSiegeUnit", "SquadBlueprint", "CBA_Options_SiegeLimit_Disable/french_limit3/" .. tostring(player.raceName) .. "/" .. tostring(unit_blueprint))
				elseif not AGS_IsSBPOfTypeSafe(unit_SBP, "culverin", "CBA_Options_SiegeLimit_Disable/french_limit3") then
					AGS_SetSquadProductionAvailabilitySafe(player.id, unit_SBP, lock_type, "CBA_Options_SiegeLimit_Disable/french_limit3/" .. tostring(player.raceName) .. "/" .. tostring(unit_blueprint))
				end
			end
			
		elseif player_civ == "chinese" then
			for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_faction_chi) do
				AGS_SetSquadProductionAvailabilitySafe(player.id, AGS_GetSiegeUnit(player.raceName, unit_blueprint), lock_type, "CBA_Options_SiegeLimit_Disable/chinese_limit3/" .. tostring(player.raceName) .. "/" .. tostring(unit_blueprint))
			end
			
		elseif player_civ == "chinese_ha_01" then
			Player_SetSquadProductionAvailability(player.id, SBP.CHINESE_HA_01.UNIT_NEST_OF_BEES_4_CHI_HA_01, lock_type)
			
		else
			AGS_SetSquadProductionAvailabilitySafe(player.id, AGS_GetSiegeUnit(player.raceName, BP_SIEGE_RIBAULDEQUIN), lock_type, "CBA_Options_SiegeLimit_Disable/ribauldequin_limit3/" .. tostring(player.raceName))
		end
		
		-- Queue preservation: items already in production queues are never cancelled.
	end
	
	-- Siege limit (4) - Great Bombard
	if (siege_limit <= 4 and lock_type == ITEM_LOCKED) or (siege_limit == 4 and lock_type == ITEM_UNLOCKED) then
		if player_civ == "ottoman" then
			Player_SetSquadProductionAvailability(player.id, SBP.OTTOMAN.UNIT_GREAT_BOMBARD_4_OTT, lock_type)
			-- Queue preservation: items already in production queues are never cancelled.
		end
	end		
end

-- DEPRECATED: Queue items are no longer cancelled. Spawn-reject via EnforceSpawnCap handles over-cap.
-- Retained as no-op for debug coverage compatibility. Remove in next major update.
function CBA_Options_SiegeLimit_Cancel_filter(siege_limit, player)
	-- no-op: queue preservation policy
end

-- Siege Limit / Increase value / Siege Completed
function CBA_Options_SiegeLimit_BuildItemComplete(context)
	
	-- Store the player who constructed the building
	local player = Core_GetPlayersTableEntry(context.player)
	
	-- Check to see if there was a player
	if player ~= nil and not player.isEliminated then
		local player_civ = player.raceName or Player_GetRaceName(player.id)
		local rt_sbp = AGS_GetSiegeUnit(player_civ, "ram_tower")
		
		-- Recount on any siege completion, including ram/siege-tower variants that may not expose generic "siege".
		local pbg = context.pbg
		local t_siege = pbg ~= nil and Squad_IsSBPOfType(pbg, "siege")
		local t_ram = pbg ~= nil and Squad_IsSBPOfType(pbg, "ram")
		local t_scar_ram = pbg ~= nil and Squad_IsSBPOfType(pbg, "scar_ram")
		local t_fire = pbg ~= nil and Squad_IsSBPOfType(pbg, "fire_ram")
		local t_scar_fire = pbg ~= nil and Squad_IsSBPOfType(pbg, "scar_fire_ram")
		local t_rt = pbg ~= nil and Squad_IsSBPOfType(pbg, "ram_tower")
		local t_rt_sbp = pbg ~= nil and rt_sbp ~= nil and BP_GetName(pbg) == BP_GetName(rt_sbp)
		local t_st = pbg ~= nil and Squad_IsSBPOfType(pbg, "siege_tower")
		local is_recount_target = t_siege or t_ram or t_scar_ram or t_fire or t_scar_fire or t_rt or t_rt_sbp or t_st
		-- Buildable variants may lack type tags; check BP identity map as fallback
		if not is_recount_target and pbg ~= nil then
			is_recount_target = CBA_Options_IsSiegeWeaponBPMatch_SBP(pbg, player_civ)
		end
		
		local before_siege = player.siegeLimit_count or 0
		local before_ram = player.ramLimit_count or 0
		local before_st = player.siegeTowerLimit_count or 0
		local before_ram_q, before_st_q = _CBA_Options_GetAllQueuedCounts(player)
		local before_ram_total = before_ram + (player.ramLimit_pending or 0) + before_ram_q
		local before_st_total = before_st + (player.siegeTowerLimit_pending or 0) + before_st_q
		
		-- PERF: Incremental count update instead of full RecountAll.
		-- Classify the just-completed unit and add its weight directly.
		-- Deferred recheck (0.25s) corrects any drift via full RecountAll.
		if is_recount_target and pbg ~= nil then
			if t_rt or t_rt_sbp then
				-- Ram tower: weight 2 toward ram limit
				player.ramLimit_count = (player.ramLimit_count or 0) + 2
			elseif t_ram or t_scar_ram or t_fire or t_scar_fire then
				-- Ram: weight 1
				player.ramLimit_count = (player.ramLimit_count or 0) + 1
			elseif t_st then
				-- Siege tower: weight 1 (separate limit)
				player.siegeTowerLimit_count = (player.siegeTowerLimit_count or 0) + 1
			else
				-- Generic siege weapon: use point classifier
				local spawn_pts = CBA_Options_GetSiegeWeaponPointsSBP(pbg, player_civ)
				if spawn_pts > 0 then
					player.siegeLimit_count = (player.siegeLimit_count or 0) + spawn_pts
				end
			end
			-- Schedule deferred full recount as safety net for drift correction
			CBA_Options_SiegeLimit_ScheduleDeferredRecheck(player, "BuildItemComplete_incremental")
		end
		
		local after_ram = player.ramLimit_count or 0
		local after_st = player.siegeTowerLimit_count or 0
		
		if CBA_Options_ShouldLogSiegeVerbose ~= nil and CBA_Options_ShouldLogSiegeVerbose() then
			print(string.format(
				"[CBA_OPTIONS][SIEGE_LIMIT] BuildItemComplete P%d civ=%s sbp_tags=[siege=%s ram=%s scar_ram=%s fire_ram=%s scar_fire=%s ram_tower=%s rt_sbp_match=%s siege_tower=%s] is_recount=%s pre[siege=%d ram=%d ram_total=%d] post[siege=%d ram=%d] spawn_delta_ram=%d",
				player.index or 0, tostring(player_civ),
				tostring(t_siege), tostring(t_ram), tostring(t_scar_ram), tostring(t_fire), tostring(t_scar_fire), tostring(t_rt), tostring(t_rt_sbp), tostring(t_st),
				tostring(is_recount_target),
				before_siege, before_ram, before_ram_total,
				player.siegeLimit_count or 0, after_ram,
				after_ram - before_ram))
		end
		
		CBA_Options_SiegeLimit_ApplyAllThresholds(player)
		
		-- Hard cap correction for multi-workshop burst races:
		-- if this completion pushed ram/siege tower/siege total over cap, remove the just-produced squad.
		if context.squad ~= nil then
			CBA_Options_RamLimit_EnforceSpawnCap(player, context.squad)
			CBA_Options_SiegeTowerLimit_EnforceSpawnCap(player, context.squad)
			CBA_Options_SiegeLimit_EnforceSpawnCap(player, context.squad)
		end
		
		-- Post-enforcement cap violation check (uses per-player caps, not global constants)
		if CBA_Options_ShouldLogSiegeStandard ~= nil and CBA_Options_ShouldLogSiegeStandard() then
			local final_ram = player.ramLimit_count or 0
			local final_st = player.siegeTowerLimit_count or 0
			local final_ram_q, final_st_q, final_siege_q = _CBA_Options_GetAllQueuedCounts(player)
			local final_ram_total = final_ram + (player.ramLimit_pending or 0) + final_ram_q
			local final_st_total = final_st + (player.siegeTowerLimit_pending or 0) + final_st_q
			local max_ram = CBA_Options_GetPlayerRamLimit(player)
			local max_st = CBA_Options_GetPlayerSiegeTowerLimit(player)
			local ram_violation = final_ram_total > max_ram
			local st_violation = final_st_total > max_st
			local siege_violation = false
			local final_siege_total, max_siege = 0, 0
			if AGS_GLOBAL_SETTINGS.MaximumMedicPopulation ~= 0 then
				max_siege = CBA_Options_GetPlayerSiegeLimit(player)
				local final_siege = player.siegeLimit_count or 0
				final_siege_total = final_siege + (player.siegeLimit_pending or 0) + final_siege_q
				siege_violation = final_siege_total > max_siege
			end
			local violation_marker = (ram_violation or st_violation or siege_violation) and " [VIOLATION]" or ""
			local state = string.format("ram=%d st=%d siege=%d", final_ram_total, final_st_total, final_siege_total)
			local should_log = (ram_violation or st_violation or siege_violation)
			if not should_log and CBA_Options_ShouldLogSiegeStateChange ~= nil then
				should_log = CBA_Options_ShouldLogSiegeStateChange(player, "spawn_enforce", state)
			end
			if should_log then
				print(string.format(
					"[CBA_OPTIONS][SPAWN_ENFORCE] P%d post_enforce: ram_live=%d queued=%d pending=%d total=%d/%d st_live=%d queued=%d pending=%d total=%d/%d siege_eff=%d/%d%s",
					player.index or 0,
					final_ram, final_ram_q, player.ramLimit_pending or 0, final_ram_total, max_ram,
					final_st, final_st_q, player.siegeTowerLimit_pending or 0, final_st_total, max_st,
					final_siege_total, max_siege,
					violation_marker))
			end
		end
		CBA_Options_ValidateEnforcement(player, "BuildItemComplete")
	end
end

-- Siege Limit / Decrease value / Siege killed 
function CBA_Options_SiegeLimit_SquadKilled(context)
	
	if context.victim == nil then
		return
	end
	
	local squad = context.victim
	if World_OwnsSquad(squad) then
		return
	end
	local owner = Squad_GetPlayerOwner(squad)
	if owner == nil then
		return
	end
	local player = PLAYERS[World_GetPlayerIndex(owner)]
	local player_civ = player.raceName or Player_GetRaceName(player.id)
	local rt_sbp = AGS_GetSiegeUnit(player_civ, "ram_tower")
	local is_rt_squad = Squad_IsOfType(squad, "ram_tower")
	if not is_rt_squad and rt_sbp ~= nil then
		local ok_sbp, squad_sbp = pcall(Squad_GetBlueprint, squad)
		if ok_sbp and squad_sbp ~= nil and BP_GetName(squad_sbp) == BP_GetName(rt_sbp) then
			is_rt_squad = true
		end
	end

	-- Recount on any siege death, including ram/siege-tower variants that may not expose generic "siege".
	local t_siege = Squad_IsOfType(squad, "siege")
	local t_ram = Squad_IsOfType(squad, "ram")
	local t_scar_ram = Squad_IsOfType(squad, "scar_ram")
	local t_fire = Squad_IsOfType(squad, "fire_ram")
	local t_scar_fire = Squad_IsOfType(squad, "scar_fire_ram")
	local t_st = Squad_IsOfType(squad, "siege_tower")
	local is_recount_target = t_siege or t_ram or t_scar_ram or t_fire or t_scar_fire or is_rt_squad or t_st
	-- Buildable variants may lack type tags; check BP identity map as fallback
	if not is_recount_target then
		local ok_sbp, sq_sbp = pcall(Squad_GetBlueprint, squad)
		if ok_sbp and sq_sbp ~= nil then
			is_recount_target = CBA_Options_IsSiegeWeaponBPMatch_SBP(sq_sbp, player_civ)
		end
	end
	
	local before_siege = player.siegeLimit_count or 0
	local before_ram = player.ramLimit_count or 0
	local before_st = player.siegeTowerLimit_count or 0
	-- PERF: Incremental count update instead of full RecountAll.
	-- Classify the just-killed unit and subtract its weight directly.
	-- Deferred recheck (0.25s) corrects any drift via full RecountAll.
	if is_recount_target then
		if is_rt_squad then
			-- Ram tower death: decrement by 2
			player.ramLimit_count = math.max(0, (player.ramLimit_count or 0) - 2)
		elseif t_ram or t_scar_ram or t_fire or t_scar_fire then
			-- Ram death: decrement by 1
			player.ramLimit_count = math.max(0, (player.ramLimit_count or 0) - 1)
		elseif t_st then
			-- Siege tower death: decrement by 1
			player.siegeTowerLimit_count = math.max(0, (player.siegeTowerLimit_count or 0) - 1)
		else
			-- Generic siege weapon: use point classifier on the dead squad's BP
			local ok_sbp2, sq_sbp2 = pcall(Squad_GetBlueprint, squad)
			if ok_sbp2 and sq_sbp2 ~= nil then
				local death_pts = CBA_Options_GetSiegeWeaponPointsSBP(sq_sbp2, player_civ)
				if death_pts > 0 then
					player.siegeLimit_count = math.max(0, (player.siegeLimit_count or 0) - death_pts)
				end
			end
		end
		-- Schedule deferred full recount as safety net for drift correction
		CBA_Options_SiegeLimit_ScheduleDeferredRecheck(player, "SquadKilled_incremental")
	end
	
	if CBA_Options_ShouldLogSiegeVerbose ~= nil and CBA_Options_ShouldLogSiegeVerbose() then
		print(string.format(
			"[CBA_OPTIONS][SIEGE_LIMIT] SquadKilled P%d civ=%s squad_tags=[siege=%s ram=%s scar_ram=%s fire_ram=%s scar_fire=%s ram_tower=%s(rt_sbp=%s) siege_tower=%s] is_recount=%s before[siege=%d ram=%d st=%d] after[siege=%d ram=%d st=%d]",
			player.index or 0, tostring(player_civ),
			tostring(t_siege), tostring(t_ram), tostring(t_scar_ram), tostring(t_fire), tostring(t_scar_fire),
			tostring(Squad_IsOfType(squad, "ram_tower")), tostring(is_rt_squad and not Squad_IsOfType(squad, "ram_tower")),
			tostring(t_st),
			tostring(is_recount_target),
			before_siege, before_ram, before_st,
			player.siegeLimit_count or 0, player.ramLimit_count or 0, player.siegeTowerLimit_count or 0))
	end
	
	CBA_Options_SiegeLimit_ApplyAllThresholds(player)
	CBA_Options_ValidateEnforcement(player, "SquadKilled")
end

---------------------------------------------------------------------------------------------------
-- Transfer System — Leaver Conversion Pipeline
-- Converts defeated player's assets to receiver civ equivalents via
-- blueprint-level building conversion (delete+respawn) and military squad
-- conversion via civ-suffix swap. Eco squads killed. Unresolvable units killed.
-- Triggered by surrender, disconnect, and elimination defeat paths.
---------------------------------------------------------------------------------------------------

-- Fire-and-forget precache warmup: loads visual resources for all cross-civ
-- building BPs at match start so Entity_CreateFacing won't trigger engine
-- red-box overlays during conversion. Async — no callback needed.
function _Leaver_WarmupPrecache()
	local _PRECACHE_BUILDING_KEYS = {
		"barracks", "archery_range", "stable", "siege_workshop", "blacksmith",
		"house", "town_center", "market", "university", "arsenal",
		"monastery", "castle", "stone_wall", "palisade_wall", "palisade_gate",
		"scar_dock", "wonder_imperial_age",
	}
	local count = 0
	for _, player in ipairs(PLAYERS) do
		local civ = Player_GetRaceName(player.id)
		for _, key in ipairs(_PRECACHE_BUILDING_KEYS) do
			local ok, ebp = pcall(AGS_GetCivilizationEntity, civ, key)
			if ok and ebp ~= nil then
				pcall(Entity_Precache, ebp, 0, player.id, "", "leaver_warmup", key)
				count = count + 1
			end
		end
	end
	DebugLog("leaver", string.format("_Leaver_WarmupPrecache: %d EBPs precached across %d players", count, #PLAYERS))
end

---------------------------------------------------------------------------------------------------
-- Precache Manifest — reward BP → leaver conversion target validation
-- Built at init time; checks every reward BP × receiver civ pair through
-- _ResolveMilitaryRoute to confirm target BPs resolve. Gaps are logged and
-- surfaced in validation test 3.1f.
---------------------------------------------------------------------------------------------------

-- Registry of all conversion targets the gamemode may create at runtime.
-- Built once at init by _Leaver_BuildPrecacheManifest(); queried by validation + runtime audit.
_PRECACHE_MANIFEST = nil

-- 100% precache category: Onslaught reward BPs that can be present from game
-- start/round start independent of receiver age.
_LEAVER_PRECACHE_ALWAYS_REQUIRED_BP = {
	["unit_manatarms_3_eng"] = true,
	["unit_manatarms_3_chi"] = true,
	["unit_manatarms_3_fre"] = true,
	["unit_manatarms_3_hre"] = true,
	["unit_manatarms_3_mon"] = true,
	["unit_manatarms_3_rus"] = true,
	["unit_manatarms_3_sul"] = true,
	["unit_manatarms_3_abb"] = false, -- does not load with this precache method.
	["unit_manatarms_3_ott"] = false, -- does not load with this precache method.
	["unit_manatarms_3_abb_ha_01"] = false, -- does not load with this precache method.
	["unit_manatarms_3_fre_ha_01"] = true,
	["unit_manatarms_3_chi_ha_01"] = true,
	["unit_manatarms_3_hre_ha_01"] = true,
	["unit_manatarms_3_byz"] = true,
	["unit_manatarms_3_byz_ha_mac"] = true,
	["unit_manatarms_3_mon_ha_gol"] = true,
	["unit_manatarms_3_sul_ha_tug"] = false, -- does not load with this precache method.
	["unit_manatarms_3_tem"] = false, -- does not load with this precache method.
	["unit_earlsguard_3_lan"] = false, -- does not load with this precache method.
	["unit_gbeto_3_mal"] = true,
	["unit_samurai_3_jpn"] = true,
	["unit_samurai_3_jpn_ha_sen"] = true,
	["unit_knight_4_eng"] = true,
	["unit_knight_4_chi"] = true,
	["unit_knight_4_fre"] = true,
	["unit_knight_4_hre"] = true,
	["unit_knight_4_mon"] = true,
	["unit_knight_4_rus"] = true,
	["unit_knight_4_sul"] = true,
	["unit_knight_4_abb"] = true,
	["unit_knight_4_ott"] = true,
	["unit_knight_4_abb_ha_01"] = true,
	["unit_knight_4_fre_ha_01"] = true,
	["unit_knight_4_chi_ha_01"] = true,
	["unit_knight_4_hre_ha_01"] = true,
	["unit_knight_4_byz"] = true,
	["unit_knight_4_byz_ha_mac"] = true,
	["unit_knight_4_jpn"] = true,
	["unit_knight_4_jpn_ha_sen"] = true,
	["unit_knight_4_lan"] = true,
	["unit_knight_4_sul_ha_tug"] = true,
	["unit_knight_hospitaller_4_tem"] = true,
	["unit_stone_knight_4_mon_ha_gol"] = true,
	["unit_horseman_4_mal"] = true,
}

_LEAVER_PRECACHE_TARGET_CIVS = {
	["lancaster"] = true,
	["abbasid"] = true,
	["abbasid_ha_01"] = true,
	["ottoman"] = true,
	["sultanate_ha_tug"] = true,
}

-- Legacy active startup precache path (warmup spawn + SBP precache).
-- Unit warmup is currently handled on demand at runtime instead.
_LEAVER_LEGACY_PRECACHE_ENABLED = false

function _Leaver_IsAlwaysPrecacheBP(bp_name)
	return bp_name ~= nil and _LEAVER_PRECACHE_ALWAYS_REQUIRED_BP[bp_name] == true
end

-- Targeted startup building precache for known affected civs.
-- Scoped to civs with an active player in the match — no wasted precache for
-- civs not participating. Called during startup initialization.
-- Extracts required age tier from a BP name when possible.
-- Returns nil when no tier pattern is present.
function _Leaver_GetRequiredAgeForBP(bp_name)
	if bp_name == nil then return nil end
	local tier = string.match(bp_name, "_(%d)_[%w_]+$")
	if tier ~= nil then
		return tonumber(tier)
	end
	return nil
end

-- Shared policy for whether a unit BP requires runtime precache for a receiver.
-- Policy:
--   1) Age-1 units never require precache.
--   2) If receiver already meets required age, precache is not required.
-- Returns (required:boolean, reason:string)
function _Leaver_IsPrecacheRequiredForReceiver(bp_name, player_id)
	if _Leaver_IsAlwaysPrecacheBP(bp_name) then
		return true, "forced_reward"
	end
	local req_age = _Leaver_GetRequiredAgeForBP(bp_name)
	if req_age == nil then
		return true, "no_age_info"
	end
	if req_age <= 1 then
		return false, "age1_excluded"
	end
	if player_id ~= nil then
		local rcv_age = Player_GetCurrentAge(player_id)
		if rcv_age >= req_age then
			return false, "age_met"
		end
	end
	return true, "required"
end

-- Runtime tracker used by all live spawn paths (leaver conversion + rewards).
-- Validates both manifest membership and per-player entity-precache execution.
function _Leaver_RuntimeTrackPrecache(bp_name, player_id, context, route_label)
	if _PRECACHE_MANIFEST == nil or bp_name == nil or player_id == nil then
		return
	end
	local M = _PRECACHE_MANIFEST
	local required, reason = _Leaver_IsPrecacheRequiredForReceiver(bp_name, player_id)
	if not required then
		if reason == "age1_excluded" then
			M.runtime_skipped_age1 = (M.runtime_skipped_age1 or 0) + 1
		elseif reason == "age_met" then
			M.runtime_skipped_age_met = (M.runtime_skipped_age_met or 0) + 1
		end
		return
	end

	M.runtime_checks = (M.runtime_checks or 0) + 1
	local runtime_context = tostring(context or "unknown")
	M.runtime_context = M.runtime_context or {}
	if M.runtime_context[runtime_context] == nil then
		M.runtime_context[runtime_context] = { checks = 0, hits = 0, misses = 0 }
	end
	M.runtime_context[runtime_context].checks = (M.runtime_context[runtime_context].checks or 0) + 1
	local in_manifest = (M.confirmed and M.confirmed[bp_name]) or false
	local ledger = M.entity_precache_by_player or {}
	local warmup_key = "warmup|" .. tostring(bp_name)
	local player_key = tostring(player_id) .. "|" .. tostring(bp_name)
	local warmup_done = ledger[warmup_key] == true or ledger[player_key] == true
	if in_manifest and warmup_done then
		M.runtime_hits = (M.runtime_hits or 0) + 1
		M.runtime_context[runtime_context].hits = (M.runtime_context[runtime_context].hits or 0) + 1
		return
	end

	M.runtime_misses = (M.runtime_misses or 0) + 1
	M.runtime_context[runtime_context].misses = (M.runtime_context[runtime_context].misses or 0) + 1
	local miss_reason = "manifest_missing"
	if in_manifest and not warmup_done then
		miss_reason = "runtime_warmup_missing"
	elseif (not in_manifest) and warmup_done then
		miss_reason = "manifest_missing_but_runtime_warmup_done"
	end
	print(string.format("[RUNTIME-PRECACHE-MISS] bp=%s player=%s context=%s route=%s reason=%s",
		tostring(bp_name), tostring(player_id), tostring(context or "unknown"), tostring(route_label or "n/a"), miss_reason))
end

function _Leaver_EnsureRuntimeUnitPrecache(bp_name, sbp, player_id, context, route_label)
	if _PRECACHE_MANIFEST == nil or bp_name == nil or player_id == nil then
		return false, "invalid_args"
	end

	local M = _PRECACHE_MANIFEST
	local required, reason = _Leaver_IsPrecacheRequiredForReceiver(bp_name, player_id)
	if not required then
		return true, reason or "not_required"
	end

	M.entity_precache_by_player = M.entity_precache_by_player or {}
	local ledger = M.entity_precache_by_player
	local ledger_key = tostring(player_id) .. "|" .. tostring(bp_name)
	if ledger[ledger_key] == true then
		return true, "already_precached"
	end

	if sbp == nil then
		local ok_sbp, resolved_sbp = pcall(BP_GetSquadBlueprint, bp_name)
		if not ok_sbp or resolved_sbp == nil then
			M.total_runtime_precache_failed = (M.total_runtime_precache_failed or 0) + 1
			print(string.format("[RUNTIME-PRECACHE-WARN] sbp resolve failed bp=%s player=%s context=%s route=%s",
				tostring(bp_name), tostring(player_id), tostring(context or "unknown"), tostring(route_label or "n/a")))
			return false, "sbp_resolve_failed"
		end
		sbp = resolved_sbp
	end

	local ok_precache, precache_err = pcall(Scar_PrecachePrematchResource, sbp)
	if not ok_precache then
		M.total_runtime_precache_failed = (M.total_runtime_precache_failed or 0) + 1
		print(string.format("[RUNTIME-PRECACHE-WARN] prematch precache failed bp=%s player=%s context=%s route=%s err=%s",
			tostring(bp_name), tostring(player_id), tostring(context or "unknown"), tostring(route_label or "n/a"), tostring(precache_err)))
		return false, "prematch_precache_failed"
	end

	local warmup_pos = World_Pos(0, 0, 0)
	pcall(function() warmup_pos = Position_New(-500, 0, -500) end)
	local sg_warmup = SGroup_CreateIfNotFound("sg_precache_runtime_" .. tostring(player_id))
	SGroup_Clear(sg_warmup)
	local ok_warmup, warmup_err = pcall(Util_CreateSquads, player_id, sg_warmup, sbp, warmup_pos, nil, 1)
	if ok_warmup and SGroup_Count(sg_warmup) > 0 then
		pcall(SGroup_DestroyAllSquads, sg_warmup)
		SGroup_Clear(sg_warmup)
		ledger[ledger_key] = true
		M.total_runtime_precached = (M.total_runtime_precached or 0) + 1
		print(string.format("[RUNTIME-PRECACHE] bp=%s player=%s context=%s route=%s status=precached",
			tostring(bp_name), tostring(player_id), tostring(context or "unknown"), tostring(route_label or "n/a")))
		return true, "precached"
	end

	pcall(SGroup_DestroyAllSquads, sg_warmup)
	SGroup_Clear(sg_warmup)
	M.total_runtime_precache_failed = (M.total_runtime_precache_failed or 0) + 1
	print(string.format("[RUNTIME-PRECACHE-WARN] warmup spawn failed bp=%s player=%s context=%s route=%s err=%s",
		tostring(bp_name), tostring(player_id), tostring(context or "unknown"), tostring(route_label or "n/a"), tostring(warmup_err)))
	return false, "warmup_spawn_failed"
end

function _Leaver_BuildPrecacheManifest()
	local ok_gt, t_start = pcall(World_GetGameTime)
	t_start = (ok_gt and t_start) or 0

	_PRECACHE_MANIFEST = {
		confirmed = {},      -- [bp_name] = true : target BPs confirmed resolvable
		gaps = {},           -- list of {src_bp, src_civ, rcv_civ, route}
		reward_sources = {}, -- [bp_name] = {{civ, threshold, type}, ...}
		entity_precache_by_player = {}, -- ["playerID|bp_name"] = true
		total_routes = 0,
		total_confirmed = 0,
		total_gaps = 0,
		total_destroy = 0,
		excluded_age1_sources = 0,
		excluded_age1_targets = 0,
		skipped_precache_age1 = 0,
		skipped_precache_age_met = 0,
		runtime_context = {},
	}
	local M = _PRECACHE_MANIFEST

	-- Phase A: Collect all reward source BPs, keyed by owning civ.
	-- DLC variant civs alias parent reward tables, so BP suffix may differ from
	-- the variant's military suffix — this is the primary precache coverage risk.
	if _CBA and _CBA.rewards then
		for civ, rewards in pairs(_CBA.rewards) do
			if type(rewards) == "table" then
				for threshold, reward in pairs(rewards) do
					if type(threshold) == "number" then
						for _, field in ipairs({"unit_upgrade", "unit"}) do
							if reward[field] ~= nil then
								local ok, name = pcall(BP_GetName, reward[field])
								if ok and name then
									local req_age = _Leaver_GetRequiredAgeForBP(name)
									if req_age ~= nil and req_age <= 1 then
										M.excluded_age1_sources = (M.excluded_age1_sources or 0) + 1
									else
										M.reward_sources[name] = M.reward_sources[name] or {}
										local rtype = (field == "unit_upgrade") and "interval" or "oneshot"
										table.insert(M.reward_sources[name], {civ = civ, threshold = threshold, type = rtype})
									end
								end
							end
						end
					end
				end
			end
		end
	end

	-- Phase B: For each reward BP × owning civ × each receiver civ, check route.
	local checked = {}
	for src_bp, entries in pairs(M.reward_sources) do
		for _, entry in ipairs(entries) do
			for rcv_civ, _ in pairs(AGS_CIV_PREFIXES) do
				if rcv_civ ~= entry.civ then
					local key = src_bp .. "|" .. entry.civ .. "|" .. rcv_civ
					if not checked[key] then
						checked[key] = true
						M.total_routes = M.total_routes + 1
						local ok, route = pcall(_ResolveMilitaryRoute, src_bp, entry.civ, rcv_civ)
						if ok and route then
							if route.to_sbp and route.bp_name then
								local req_age = _Leaver_GetRequiredAgeForBP(route.bp_name)
								if req_age ~= nil and req_age <= 1 then
									M.excluded_age1_targets = (M.excluded_age1_targets or 0) + 1
								else
									M.confirmed[route.bp_name] = true
									M.total_confirmed = M.total_confirmed + 1
								end
							elseif route.route == "same_bp" then
								M.total_confirmed = M.total_confirmed + 1
							elseif route.route == "destroy_policy" then
								M.total_destroy = M.total_destroy + 1
							else
								M.total_gaps = M.total_gaps + 1
								table.insert(M.gaps, {
									src_bp = src_bp, src_civ = entry.civ,
									rcv_civ = rcv_civ, route = route.route or "nil",
								})
							end
						else
							M.total_gaps = M.total_gaps + 1
							table.insert(M.gaps, {
								src_bp = src_bp, src_civ = entry.civ,
								rcv_civ = rcv_civ, route = "error:" .. tostring(route),
							})
						end
					end
				end
			end
		end
	end

	-- Phase C: startup unit warmup is disabled.
	-- Units are now precached on demand immediately before runtime spawn/create.
	local ok_gt_pc, t_precache_start = pcall(World_GetGameTime)
	t_precache_start = (ok_gt_pc and t_precache_start) or t_start
	M.total_precached = 0
	M.total_entity_precached = 0
	M.total_entity_precache_failed = 0
	M.total_runtime_precached = 0
	M.total_runtime_precache_failed = 0
	print("[PRECACHE-MANIFEST] Startup unit warmup disabled; runtime on-demand precache enabled")
	local ok_gt_pc2, t_precache_end = pcall(World_GetGameTime)
	t_precache_end = (ok_gt_pc2 and t_precache_end) or t_precache_start

	local ok_gt2, t_end = pcall(World_GetGameTime)
	t_end = (ok_gt2 and t_end) or 0
	M.init_elapsed = t_end - t_start
	M.precache_elapsed = t_precache_end - t_precache_start
	M.runtime_checks = 0
	M.runtime_hits = 0
	M.runtime_misses = 0
	M.runtime_context = {}
	M.runtime_skipped_age1 = 0
	M.runtime_skipped_age_met = 0
	local n_sources = 0
	for _ in pairs(M.reward_sources) do n_sources = n_sources + 1 end
	M.total_src_bps = n_sources
	local n_confirmed = 0
	for _ in pairs(M.confirmed) do n_confirmed = n_confirmed + 1 end
	M.total_unique_targets = n_confirmed

	print(string.format("[PRECACHE-MANIFEST] %d sources (%d age1 excluded), %d routes, %d confirmed (%d unique targets), %d gaps, %d destroy (%.2fs total, %.2fs precache)",
		n_sources, M.excluded_age1_sources or 0, M.total_routes, M.total_confirmed, n_confirmed, M.total_gaps, M.total_destroy, M.init_elapsed, M.precache_elapsed))
	print(string.format("[PRECACHE-MANIFEST] Precached %d unique unit BPs, %d failed; warmup-spawned %d (%d failed) (policy skips per player: age1=%d, age_met=%d, target_age1_excluded=%d)",
		M.total_precached, M.total_precache_failed or 0, M.total_entity_precached or 0, M.total_entity_precache_failed or 0, M.skipped_precache_age1 or 0, M.skipped_precache_age_met or 0, M.excluded_age1_targets or 0))

	if M.total_gaps > 0 then
		print(string.format("[PRECACHE-MANIFEST] %d GAPS detected:", M.total_gaps))
		for i, gap in ipairs(M.gaps) do
			if i <= 30 then
				print(string.format("  [GAP] %s (%s -> %s) route=%s", gap.src_bp, gap.src_civ, gap.rcv_civ, gap.route))
			end
		end
		if #M.gaps > 30 then
			print(string.format("  ... and %d more", #M.gaps - 30))
		end
	end
end

-- Resource types for transfer
_LEAVER_RESOURCE_TYPES = { RT_Food, RT_Wood, RT_Gold, RT_Stone }

-- Military suffix overrides for civs whose standard military units use a
-- different BP suffix than AGS_CIV_PREFIXES. Empty table retained so
-- _Leaver_GetMilitarySuffix and validation test 3.1e operate normally.
_LEAVER_MILITARY_SUFFIX_OVERRIDE = {
}

-- Returns the correct BP suffix for military unit construction for a given civ.
-- Applies _LEAVER_MILITARY_SUFFIX_OVERRIDE before falling back to AGS_CIV_PREFIXES.
function _Leaver_GetMilitarySuffix(civ)
	local override = _LEAVER_MILITARY_SUFFIX_OVERRIDE[civ]
	if override then return override end
	local prefix = AGS_CIV_PREFIXES[civ]
	if prefix == nil then return nil end
	return string.sub(prefix, 1, -2)
end

-- Debug override: set to true in console to bypass age gates (logs all bypasses).
-- Usage: _LEAVER_DEBUG_BYPASS_GATES = true
_LEAVER_DEBUG_BYPASS_GATES = false

-- Debug override: set to true in console to bypass capability/tech gates (logs all bypasses).
-- Separate from age bypass so each gate layer can be tested independently.
-- Usage: _LEAVER_DEBUG_BYPASS_CAPABILITY_GATES = true
_LEAVER_DEBUG_BYPASS_CAPABILITY_GATES = false

-- Verbose leaver pipeline logging. When true, prints per-unit detail for every
-- transfer/conversion decision including no-create same-BP and no-fallback paths.
-- Toggle in console: _LEAVER_DEBUG_VERBOSE = true
-- Usage: _LEAVER_DEBUG_VERBOSE = true
_LEAVER_DEBUG_VERBOSE = false

-- Audit log for leaver conversion decisions (accumulated per transfer, flushed at end).
-- Each entry: { bp_name, decision, reason, receiver_civ, ags_key, age_required, rcv_age }
_LEAVER_AUDIT_LOG = {}

-- Returns true when the resolved target BP matches a spawner-utilized unit prefix.
-- These are the 3 standard archetypes used by the reward spawner across all 22 civs.
-- All civ-unique reward variants (gbeto, samurai, etc.) resolve via archetype fallback
-- to a target matching one of these prefixes. Checked on `route.bp_name` (the resolved
-- target), not the source BP.
function _Leaver_IsSpawnerExemptBP(bp_name)
	if bp_name == nil then return false end
	for _, prefix in ipairs(_LEAVER_SPAWNER_EXEMPT_PREFIXES) do
		if string.sub(bp_name, 1, #prefix) == prefix then
			return true
		end
	end
	return false
end

-- Shared age-requirement gate for all leaver creation paths.
-- Checks whether the receiver player has reached the minimum age tier for a given blueprint.
--   Buildings: uses _LEAVER_AGE_REQUIREMENTS keyed by ags_key.
--   Squads:    extracts age tier from BP name (unit_NAME_TIER_CIV pattern).
-- Returns: "ok" (no requirement / passed), "blocked" (age too low), "bypassed" (debug override)
function _Leaver_MeetsAgeRequirement(bp_name, ags_key, player_id, context)
	local req_age = nil

	-- Building age requirement (explicit table lookup)
	if ags_key ~= nil and _LEAVER_AGE_REQUIREMENTS[ags_key] ~= nil then
		req_age = _LEAVER_AGE_REQUIREMENTS[ags_key]
	end

	-- Squad age requirement: extract tier digit from BP name (unit_xxx_N_civsuffix)
	if req_age == nil and bp_name ~= nil then
		req_age = _Leaver_GetRequiredAgeForBP(bp_name)
	end

	-- No requirement identified — allow creation
	if req_age == nil then return "ok" end

	local rcv_age = Player_GetCurrentAge(player_id)
	if rcv_age >= req_age then
		table.insert(_LEAVER_AUDIT_LOG, {
			bp = bp_name, decision = "AGE_OK", ags_key = tostring(ags_key or ""),
			required = req_age, actual = rcv_age, context = context})
		if _LEAVER_DEBUG_VERBOSE then
			print(string.format("[AGE-OK] %s | age %d >= %d | %s", bp_name, rcv_age, req_age, context))
		end
		return "ok"
	end

	if _LEAVER_DEBUG_BYPASS_GATES then
		table.insert(_LEAVER_AUDIT_LOG, {
			bp = bp_name, decision = "AGE_BYPASS", ags_key = tostring(ags_key or ""),
			required = req_age, actual = rcv_age, context = context})
		if _LEAVER_DEBUG_VERBOSE then
			print(string.format("[AGE-BYPASS] %s | age %d < %d | %s", bp_name, rcv_age, req_age, context))
		end
		return "bypassed"
	end

	table.insert(_LEAVER_AUDIT_LOG, {
		bp = bp_name, decision = "AGE_BLOCK", ags_key = tostring(ags_key or ""),
		required = req_age, actual = rcv_age, context = context})
	if _LEAVER_DEBUG_VERBOSE then
		print(string.format("[AGE-BLOCK] %s | age %d < %d | %s", bp_name, rcv_age, req_age, context))
	end
	return "blocked"
end

-- Minimum age required to spawn certain buildings (1=Dark, 2=Feudal, 3=Castle, 4=Imperial)
_LEAVER_AGE_REQUIREMENTS = {
	university = 3,
	arsenal = 3,
	castle = 3,
	wonder_imperial_age = 4,
}

-- Capability/tech prerequisites for leaver creation paths.
-- Each entry: { upgrade_key = AGS upgrade table key, description = human-readable label }
-- Only buildings/units that require a specific researched upgrade are listed here.
-- Default policy: if a bp_name/ags_key is NOT in this table, creation is allowed (no capability gate).
_LEAVER_CAPABILITY_REQUIREMENTS = {
	-- Buildings requiring Siege Engineers (or civ equivalent) to be functional
	arsenal = { upgrade_key = "siege_engineers", description = "Siege Engineers" },
}

-- BP-name prefixes for the 3 standard unit archetypes used by the reward spawner.
-- Any conversion target matching one of these prefixes bypasses the military age gate.
-- Deliberately broad: exempts ALL conversions producing these types, not just reward-spawned.
_LEAVER_SPAWNER_EXEMPT_PREFIXES = {
	"unit_manatarms_3_",  -- All 13 civ manatarms variants (core spawner unit)
	"unit_knight_4_",     -- All 14 civ knight variants (high-tier spawner unit)
	"unit_horseman_4_",   -- Malian horseman_4 (Malian uses horseman_4 instead of knight_4)
	-- Civ-unique MaA equivalents: receiver-class remap targets that serve
	-- the same spawner role as unit_manatarms_3_ for their faction.
	"unit_earlsguard_3_",            -- Lancaster MaA equivalent
	"unit_samurai_3_",               -- Japanese/Sengoku MaA equivalent
	"unit_gbeto_3_",                 -- Malian MaA equivalent
	-- Civ-unique knight equivalents: receiver-class remap targets or direct rewards.
	"unit_stone_knight_4_",          -- Golden Horde knight equivalent
	"unit_knight_hospitaller_4_",    -- Templar knight equivalent
}

-- Per-player capability gate cache. Populated once per pipeline tick to avoid repeated
-- Player_HasUpgrade calls inside the squad hot-loop. Keyed by player_id, value is table
-- of { [upgrade_key] = true/false }. Cleared at pipeline start and end.
_LEAVER_CAP_CACHE = {}

-- Resolves a capability upgrade blueprint for a player's civ.
-- Returns the upgrade BP, or nil if the upgrade key is not recognized for that civ.
function _Leaver_ResolveUpgradeBP(player_id, upgrade_key)
	if upgrade_key == nil then return nil end
	local civ = Player_GetRaceName(player_id)
	-- Map upgrade keys to AGS upgrade tables (same pattern as CBA_Options_HasSiegeEngineers)
	local upgrade_table_map = {
		siege_engineers = AGS_UP_SIEGE_ENGINEERS,
	}
	local ags_table = upgrade_table_map[upgrade_key]
	if ags_table == nil then return nil end
	local ok, ubp = pcall(AGS_GetCivilizationUpgrade, civ, ags_table)
	if ok and ubp ~= nil then return ubp end
	-- Parent-civ fallback for variant civs
	local parent = AGS_CIV_PARENT_MAP[civ]
	if parent ~= nil then
		ok, ubp = pcall(AGS_GetCivilizationUpgrade, parent, ags_table)
		if ok and ubp ~= nil then return ubp end
	end
	return nil
end

-- Checks whether a player has a specific upgrade, with per-pipeline caching.
-- Returns true/false. Uses _LEAVER_CAP_CACHE to avoid redundant API calls.
function _Leaver_PlayerHasUpgradeCached(player_id, upgrade_key)
	if _LEAVER_CAP_CACHE[player_id] == nil then
		_LEAVER_CAP_CACHE[player_id] = {}
	end
	if _LEAVER_CAP_CACHE[player_id][upgrade_key] ~= nil then
		return _LEAVER_CAP_CACHE[player_id][upgrade_key]
	end
	local ubp = _Leaver_ResolveUpgradeBP(player_id, upgrade_key)
	if ubp == nil then
		_LEAVER_CAP_CACHE[player_id][upgrade_key] = false
		return false
	end
	local ok, done = pcall(Player_HasUpgrade, player_id, ubp)
	local result = ok and done or false
	_LEAVER_CAP_CACHE[player_id][upgrade_key] = result
	return result
end

-- Shared capability/tech-requirement gate for all leaver creation paths.
-- Checks whether the receiver player meets tech prerequisites for a given blueprint.
-- Returns: "ok" (no requirement / passed), "blocked" (tech not researched), "bypassed" (debug override)
function _Leaver_MeetsCapabilityRequirement(bp_name, ags_key, player_id, context)
	local req = nil

	-- Building capability requirement (explicit table lookup by ags_key)
	if ags_key ~= nil and _LEAVER_CAPABILITY_REQUIREMENTS[ags_key] ~= nil then
		req = _LEAVER_CAPABILITY_REQUIREMENTS[ags_key]
	end

	-- No capability requirement identified — allow creation
	if req == nil then return "ok" end

	local has_upgrade = _Leaver_PlayerHasUpgradeCached(player_id, req.upgrade_key)
	if has_upgrade then
		table.insert(_LEAVER_AUDIT_LOG, {
			bp = bp_name, decision = "CAP_OK", ags_key = tostring(ags_key or ""),
			upgrade = req.upgrade_key, description = req.description, context = context})
		if _LEAVER_DEBUG_VERBOSE then
			print(string.format("[CAP-OK] %s | %s researched | %s", bp_name, req.description, context))
		end
		return "ok"
	end

	if _LEAVER_DEBUG_BYPASS_CAPABILITY_GATES then
		table.insert(_LEAVER_AUDIT_LOG, {
			bp = bp_name, decision = "CAP_BYPASS", ags_key = tostring(ags_key or ""),
			upgrade = req.upgrade_key, description = req.description, context = context})
		if _LEAVER_DEBUG_VERBOSE then
			print(string.format("[CAP-BYPASS] %s | %s not researched (bypassed) | %s", bp_name, req.description, context))
		end
		return "bypassed"
	end

	table.insert(_LEAVER_AUDIT_LOG, {
		bp = bp_name, decision = "CAP_BLOCK", ags_key = tostring(ags_key or ""),
		upgrade = req.upgrade_key, description = req.description, context = context})
	if _LEAVER_DEBUG_VERBOSE then
		print(string.format("[CAP-BLOCK] %s | %s not researched | %s", bp_name, req.description, context))
	end
	return "blocked"
end

