-- Safety net: keep console cleanup command available even if a debug import fails.
if type(Debug_LeaverConversion_VisualCleanup) ~= "function" then
	function Debug_LeaverConversion_VisualCleanup()
		if type(_VISUAL_TEST_DEFERRED_CLEANUP) == "table" then
			print("[VISUAL_CLEANUP] Deferred cleanup already in progress.")
			return
		end

		local n_e = (type(_VISUAL_TEST_CLEANUP_EIDS) == "table") and #_VISUAL_TEST_CLEANUP_EIDS or 0
		local n_s = (type(_VISUAL_TEST_CLEANUP_SQS) == "table") and #_VISUAL_TEST_CLEANUP_SQS or 0

		if n_e == 0 and n_s == 0 then
			print("[VISUAL_CLEANUP] Nothing to clean.")
			return
		end

		if type(_VisualTest_DeferredCleanup) == "function" then
			_VISUAL_TEST_STATE = nil
			print(string.format("[VISUAL_CLEANUP] Scheduling deferred cleanup for %d entities, %d squads.", n_e, n_s))
			_VisualTest_DeferredCleanup()
			return
		end

		print("[VISUAL_CLEANUP] Command fallback active, but debug visual cleanup runtime is not loaded.")
	end
end

-----------------------------------------------------------------------
-- Shared Onslaught score + endgame presentation helpers
-----------------------------------------------------------------------

-- Canonical score source for Onslaught (reward/kill points).
function Onslaught_GetPlayerScore(player)
	return (player and player.killed_number) or 0
end

-- PERF: Per-player score cache — skip UI_SetPlayerDataContext when score unchanged.
_onslaught_prev_scores = _onslaught_prev_scores or {}

-- Override engine's internal score with reward score for all players.
-- Runs on an interval so the postgame summary shows reward score
-- instead of the engine's own score (which can go negative).
function Onslaught_SyncScoreToEngine()
	if _onslaught_teardown_detected then return end
	local ok_gt, gt = pcall(World_GetGameTime)
	for _, player in ipairs(PLAYERS) do
		if player == nil then
			if Onslaught_ShouldLogTrace() then
				print("[TRACE_CRASH] Onslaught_SyncScoreToEngine: player is nil, skipping")
			end
			break
		end
		local score = Onslaught_GetPlayerScore(player)
		player.score = score
		local key = player.index or 0
		if score ~= (_onslaught_prev_scores[key] or -1) then
			_onslaught_prev_scores[key] = score
			Player_SetStateModelFloat(player.id, "total_score", score)
			if player.scarModel ~= nil then
				player.scarModel.PlayerScore_Current = score
				-- INSTRUMENTATION: wrap UI call in pcall to detect post-teardown state
				local ok_ui, err_ui = pcall(UI_SetPlayerDataContext, player.id, player.scarModel)
				if not ok_ui then
					_onslaught_teardown_detected = true
					if Onslaught_ShouldLogTrace() then
						print("[TRACE_CRASH] UI_SetPlayerDataContext FAILED on player " .. tostring(player.id) .. " — teardown detected! Error: " .. tostring(err_ui))
					end
				end
			end
		end
	end
end

-- One-shot latch: prevents duplicate endgame presentation queuing
-- when multiple win conditions fire near-simultaneously.
_onslaught_gameover_queued = false

-- Instrumentation: detect teardown phase for callback tracing
_onslaught_teardown_detected = false
_onslaught_core_gameover_executed = false
_onslaught_trace_seq = 0
_onslaught_probe_last_bucket = -1
_onslaught_enable_heartbeat_probe = false

-- Opt-in debug channels (console override supported).
_ONSLAUGHT_DEBUG_TRACE = false
_ONSLAUGHT_DEBUG_FORCE_TEAM_POSITIONS = false
_ONSLAUGHT_DEBUG_KEEP_CAP = false

local function _Onslaught_IsDebugEnabled(flag)
	if flag == true then
		return true
	end
	if _mod ~= nil and _mod.debug == true then
		return true
	end
	if _cba_debug ~= nil and _cba_debug.enabled == true then
		return true
	end
	return false
end

local function Onslaught_ShouldLogTrace()
	return _Onslaught_IsDebugEnabled(_ONSLAUGHT_DEBUG_TRACE)
end

local function Onslaught_ShouldLogForceTeamPositions()
	return _Onslaught_IsDebugEnabled(_ONSLAUGHT_DEBUG_FORCE_TEAM_POSITIONS)
end

local function Onslaught_ShouldLogKeepCap()
	return _Onslaught_IsDebugEnabled(_ONSLAUGHT_DEBUG_KEEP_CAP)
end

local function Onslaught_LogForceTeamPositions(msg)
	if Onslaught_ShouldLogForceTeamPositions() then
		print(msg)
	end
end

local function Onslaught_LogKeepCap(msg)
	if Onslaught_ShouldLogKeepCap() then
		print(msg)
	end
end

-- AI Player system toggle (vestigial — actual gate is _AI_IsModuleEnabledFromSettings
-- in cba_ai/lifecycle.scar which reads AGS_GLOBAL_SETTINGS.AIPlayers).
-- Retained for backward compatibility with debug inspectors.
_CBA_ENABLE_AI_PLAYER = false

local function Onslaught_Trace(tag, message)
	if not Onslaught_ShouldLogTrace() then
		return
	end
	_onslaught_trace_seq = _onslaught_trace_seq + 1
	local ok_gt, gt = pcall(World_GetGameTime)
	print(string.format("[%s][%04d][t=%.2f] %s", tostring(tag), _onslaught_trace_seq, (ok_gt and gt) or 0, tostring(message)))
end

local _original_Core_OnGameOver = Core_OnGameOver
function Core_OnGameOver(...)
	_onslaught_core_gameover_executed = true
	Onslaught_Trace("TRACE_GAMEOVER", "Core_OnGameOver invoked")
	return _original_Core_OnGameOver(...)
end

function Onslaught_CrashProbeTick()
	local ok_gt, gt = pcall(World_GetGameTime)
	if not ok_gt then
		_onslaught_teardown_detected = true
		Onslaught_Trace("TRACE_CRASH", "Onslaught_CrashProbeTick: World_GetGameTime failed")
		return
	end
	local bucket = math.floor(gt / 10)
	if bucket ~= _onslaught_probe_last_bucket then
		_onslaught_probe_last_bucket = bucket
		Onslaught_Trace("TRACE_HEARTBEAT", "probe alive")
	end
end

function Onslaught_TryQueueGameOver(delay, payload)
	if _onslaught_gameover_queued then
		return
	end
	_onslaught_gameover_queued = true
	Rule_AddOneShot(_gameOver_message, delay, payload)
end

-----------------------------------------------------------------------
-- Defeat-path overrides: inject Mod_EliminatePlayerUnits before the
-- default handlers call World_KillPlayer, so assets transfer first.
-----------------------------------------------------------------------

local function _Onslaught_ResolvePlayerId(playerLike)
	if playerLike == nil then
		return nil
	end
	if type(playerLike) == "table" then
		if playerLike.id ~= nil then
			return playerLike.id
		end
		if playerLike.PlayerID ~= nil then
			return playerLike
		end
		print(string.format("[WARN] _Onslaught_ResolvePlayerId: unexpected table shape (keys: %s)",
			table.concat((function() local k={} for key,_ in pairs(playerLike) do k[#k+1]=tostring(key) end return k end)(), ",")))
		return nil
	end
	return playerLike
end

local function _Onslaught_ResolvePlayersEntry(playerLike)
	if playerLike == nil then
		return nil, nil
	end
	if type(playerLike) == "table" and playerLike.id ~= nil and playerLike.index ~= nil then
		return playerLike, playerLike.id
	end
	local playerId = _Onslaught_ResolvePlayerId(playerLike)
	if playerId == nil then
		return nil, nil
	end
	return Core_GetPlayersTableEntry(playerId), playerId
end

local function _Onslaught_SetEliminationReason(playerLike, reason)
	local playersEntry, playerId = _Onslaught_ResolvePlayersEntry(playerLike)
	if playersEntry ~= nil then
		if reason == WR_SURRENDER then
			playersEntry.eliminationReason = "surrender"
		elseif reason == WR_DISCONNECT then
			playersEntry.eliminationReason = "disconnect"
		elseif reason == WR_ELIMINATION then
			-- Only write "eliminated" when no more specific reason (disconnect/surrender)
			-- was already set -- AGS_Elimination_OnPlayerAITakeover sets "disconnect"
			-- before calling Core_SetPlayerDefeated(WR_ELIMINATION), and we must not
			-- overwrite it.
			local existing = playersEntry.eliminationReason
			if existing == nil or existing == "alive" then
				-- MP fallback: the engine cannot reliably distinguish elimination
				-- vs disconnect in multiplayer (it always reports WR_ELIMINATION).
				-- If the player's ORIGINAL starter Keep entity is still alive
				-- (regardless of who currently owns it after the leaver-transfer
				-- pipeline ran), the player must have left rather than been wiped
				-- out -- classify as "disconnect" at the source so any consumer
				-- (UI, debug, telemetry) sees the correct reason.
				if playersEntry.keep ~= nil
						and playersEntry.keep.entity_id ~= nil
						and Entity_IsValid(playersEntry.keep.entity_id) then
					playersEntry.eliminationReason = "disconnect"
				else
					playersEntry.eliminationReason = "eliminated"
				end
			end
		end
	else
		print(string.format("[WARN] _Onslaught_SetEliminationReason: could not resolve player entry for %s (type=%s)",
			tostring(playerLike), type(playerLike)))
	end
	return playerId, playersEntry
end

local _original_Surrender_OnPlayerDefeated = Surrender_OnPlayerDefeated
function Surrender_OnPlayerDefeated(defeatedPlayer, reason)
	local resolvedPlayerId, resolvedPlayerEntry = _Onslaught_SetEliminationReason(defeatedPlayer, reason)
	Onslaught_Trace("TRACE_DEFEAT", "Surrender_OnPlayerDefeated reason=" .. tostring(reason) .. " player=" .. tostring(resolvedPlayerId or defeatedPlayer))
	if reason == WR_SURRENDER then
		Mod_EliminatePlayerUnits(resolvedPlayerEntry or resolvedPlayerId or defeatedPlayer, nil, false)
	end
	_original_Surrender_OnPlayerDefeated(resolvedPlayerEntry or defeatedPlayer, reason)
end

local _original_Elimination_OnPlayerDefeated = Elimination_OnPlayerDefeated
function Elimination_OnPlayerDefeated(player, reason)
	local resolvedPlayerId, resolvedPlayerEntry = _Onslaught_SetEliminationReason(player, reason)
	Onslaught_Trace("TRACE_DEFEAT", "Elimination_OnPlayerDefeated reason=" .. tostring(reason) .. " player=" .. tostring(resolvedPlayerId or player))
	if reason == WR_ELIMINATION or reason == WR_DISCONNECT then
		Mod_EliminatePlayerUnits(resolvedPlayerEntry or resolvedPlayerId or player, nil, false)
	end
	_original_Elimination_OnPlayerDefeated(resolvedPlayerEntry or player, reason)
end

