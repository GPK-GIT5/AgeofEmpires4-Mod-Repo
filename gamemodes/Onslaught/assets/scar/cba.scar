---------------------------------------------------------------------------------------------------
-- Maps standard archetype unit BP prefixes to their role classification for receiver-side
-- class fallback resolution. Enables role-based unit matching when exact suffix-swap fails.
---------------------------------------------------------------------------------------------------
_LEAVER_UNIT_ROLE_MAP = {
	-- Melee Infantry
	"unit_spearman_", "unit_manatarms_", "unit_landsknecht_",
	-- Ranged (bows)
	"unit_archer_", "unit_crossbowman_", "unit_handcannoneer_", "unit_handcannon_",
	-- Cavalry
	"unit_horseman_", "unit_knight_", "unit_sipahi_", "unit_camel_rider_",
	-- Religious / Support
	"unit_monk_", "unit_monk_buddhist_", "unit_monk_shinto_", "unit_monk_ikko_",
	-- Siege
	"unit_springald_", "unit_mangonel_", "unit_bombard_", "unit_trebuchet_", "unit_culverin_", "unit_ribauldequin_", "unit_ram_", "unit_siege_tower_", "unit_siege_",
}

-- Helper to get role from BP name via _LEAVER_UNIT_ROLE_MAP.
function _Leaver_GetUnitRole(sbp_name)
	if sbp_name == nil then return nil end
	for _, prefix in ipairs(_LEAVER_UNIT_ROLE_MAP) do
		if string.sub(sbp_name, 1, #prefix) == prefix then
			return prefix -- Return the matched prefix as the role identifier
		end
	end
	return nil
end

