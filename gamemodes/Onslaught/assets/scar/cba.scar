-- WIP: Siege Limit / Set restrictions 
function CBA_Options_SiegeLimit_Disable(player_id, siege_limit, lock_type)
	
	local player_civ = Player_GetRaceName(player_id)
	local player = Core_GetPlayersTableEntry(player_id)
	
	-- Filter: Siege Production Buildings
	local player_buildings = Player_GetAllEntities(player.id)
	EGroup_Filter(player_buildings, "scar_siegeworkshop", FILTER_REMOVE, player.eg_siegeproduction)
	
	-- Filter: Siege Production Buildings / Faction Specific
	if player_civ == "english" then
		EGroup_Filter(player_buildings, "scar_keep", FILTER_REMOVE, player.eg_siegeproduction)
		
	elseif player_civ == "chinese" then
		EGroup_Filter(player_buildings, EBP.CHINESE.BUILDING_LANDMARK_AGE2_CLOCKTOWER_CONTROL_CHI, FILTER_REMOVE, player.eg_siegeproduction)
		
	elseif player_civ == "french" then
		EGroup_Filter(player_buildings, EBP.FRENCH.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE, FILTER_REMOVE, player.eg_siegeproduction)
		-- Expansion
	elseif player_civ == "french_ha_01" then
		EGroup_Filter(player_buildings, EBP.FRENCH_HA_01.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE_HA_01, FILTER_REMOVE, player.eg_siegeproduction)
		
	elseif player_civ == "ottoman" then
		EGroup_Filter(player_buildings, EBP.OTTOMAN.BUILDING_LANDMARK_AGE2_TOPHANE_ARMORY_OTT, FILTER_REMOVE, player.eg_siegeproduction)
	end
	
	-- Siege limit (1) - Springald
	if (siege_limit == 1 and lock_type == ITEM_LOCKED) or (siege_limit >= 1 and lock_type == ITEM_UNLOCKED) then
		-- Springald / Faction ALL
		Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeUnit(player.raceName, BP_SIEGE_SPRINGALD), lock_type)
		-- Springald / Faction unique
		if player_civ == "mongol" then
			Player_SetEntityProductionAvailability(player.id, EBP.MONGOL.UNIT_SPRINGALD_3_FIELD_CONSTRUCT_MON, lock_type)
		elseif player_civ == "abbasid" then
			Player_SetEntityProductionAvailability(player.id, EBP.ABBASID.UNIT_SPRINGALD_3_BUILDABLE_ABB, lock_type)
		elseif player_civ == "abbasid_ha_01" then
			Player_SetEntityProductionAvailability(player.id, EBP.ABBASID_HA_01.UNIT_SPRINGALD_3_BUILDABLE_ABB_HA_01, lock_type)
		end
		
		-- Disable siege units / FACTION UNIQUE
		if player_civ == "mongol" then
			for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_faction_mon) do
				local unit_SBP = AGS_GetSiegeUnit(player.raceName, unit_blueprint)
				-- Filter types
				if not Squad_IsSBPOfType(unit_SBP, "springald") and not Squad_IsSBPOfType(unit_SBP, "culverin") and not Squad_IsSBPOfType(unit_SBP, "trebuchet_traction") then
					Player_SetSquadProductionAvailability(player.id, unit_SBP, lock_type)
				end
			end
			for id, entity_blueprint in pairs(CBA_SIEGE_UNITS.siege_buildable_mon) do
				-- Filter types
				if entity_blueprint ~= "unit_springald_3_field_construct_mon" or entity_blueprint ~= "unit_trebuchet_4_tr_field_construct_mon" then
					Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint(entity_blueprint), lock_type) -- Field Constructed = Entity
				end
			end
--[[
		elseif player_civ == "abbasid" then
			Player_SetEntityProductionAvailability(player.id, EBP.ABBASID.UNIT_MANGONEL_3_BUILDABLE_ABB, lock_type) -- Field Constructed = Entity

		elseif player_civ == "abbasid_ha_01" then
			Player_SetEntityProductionAvailability(player.id, EBP.ABBASID_HA_01.UNIT_MANGONEL_3_BUILDABLE_ABB_HA_01, lock_type) -- Field Constructed = Entity
]]
		elseif player_civ == "french" then
			for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_faction_fre) do
				local unit_SBP = AGS_GetSiegeUnit(player.raceName, unit_blueprint)
				if not Squad_IsSBPOfType(unit_SBP, "culverin") then
					Player_SetSquadProductionAvailability(player.id, unit_SBP, lock_type)
				end
			end
			
		elseif player_civ == "chinese" then
			for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_faction_chi) do
				Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeUnit(player.raceName, unit_blueprint), lock_type)
			end
			
		elseif player_civ == "chinese_ha_01" then
			Player_SetSquadProductionAvailability(player.id, SBP.CHINESE_HA_01.UNIT_NEST_OF_BEES_4_CHI_HA_01, lock_type)
		else
			Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeUnit(player.raceName, BP_SIEGE_RIBAULDEQUIN), lock_type)
		end
		
		-- Cancel Production 
		if siege_limit == 1 and lock_type == ITEM_LOCKED then
			CBA_Options_SiegeLimit_Cancel_filter(1, player)
		end
	end
	
	-- Siege limit (2) - Ram/Trebuchet TR/Culverin
	if (siege_limit <= 2 and lock_type == ITEM_LOCKED) or (siege_limit >= 2 and lock_type == ITEM_UNLOCKED) then
		
		-- Disable Groups
		for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_value_2) do
			Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeUnit(player.raceName, unit_blueprint), lock_type)	
		end
		
		-- Disable unit: Ram
		Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeUnit(player.raceName, BP_SIEGE_WORKSHOP_RAM), lock_type)
		Player_SetEntityProductionAvailability(player.id, AGS_GetSiegeEntity(player.raceName, BP_SIEGE_RAM), lock_type)
		
		-- Faction Unique / Ram
		if player_civ == "chinese" then
			-- Unique: Ram / Clocktower
			Player_SetSquadProductionAvailability(player.id, SBP.CHINESE.UNIT_RAM_3_CLOCKTOWER_CHI, lock_type)
			
		elseif player_civ == "byzantine" then
			-- Unique: Ram / Fire
			Player_SetEntityProductionAvailability(player.id, EBP.BYZANTINE.UNIT_RAM_FIRE_3_BYZ, lock_type)
			Player_SetSquadProductionAvailability(player.id, SBP.BYZANTINE.UNIT_WORKSHOP_FIRE_RAM_3_BYZ, lock_type)
		end
		
		-- Disable unit: Trebuchet (Traction)
		if player_civ == "mongol" then
			Player_SetSquadProductionAvailability(player.id, SBP.MONGOL.UNIT_TREBUCHET_4_TR_MON, lock_type)
			Player_SetSquadProductionAvailability(player.id, SBP.MONGOL.UNIT_SPRINGALD_3_DOUBLE_MON, lock_type)
			Player_SetEntityProductionAvailability(player.id, EBP.MONGOL.UNIT_TREBUCHET_4_TR_FIELD_CONSTRUCT_MON, lock_type)
		end
		
		-- Cancel Production 
		if siege_limit == 2 and lock_type == ITEM_LOCKED then
			CBA_Options_SiegeLimit_Cancel_filter(2, player)
		end
	end
	
	-- Siege limit (3) - Mangonel/Ribauldequin/Trebuchet CW/Bombard (Excl. Great Bombard)
	if (siege_limit <= 3 and lock_type == ITEM_LOCKED) or (siege_limit >= 3 and lock_type == ITEM_UNLOCKED) then
		
		-- Disable siege units / ALL FACTIONS
		for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_faction_all) do
			local unit_SBP = AGS_GetSiegeUnit(player.raceName, unit_blueprint)
			-- Filter types
			if not Squad_IsSBPOfType(unit_SBP, "springald") and not Squad_IsSBPOfType(unit_SBP, "culverin") and not Squad_IsSBPOfType(unit_SBP, "trebuchet_traction") and not Squad_IsSBPOfType(unit_SBP, "ram") 
				and not (Squad_IsSBPOfType(unit_SBP, "bombard") and player_civ == "ottoman") then
				Player_SetSquadProductionAvailability(player.id, unit_SBP, lock_type)
			end
		end
		
		-- Disable siege units / FACTION UNIQUE
		if player_civ == "mongol" then
			for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_faction_mon) do
				local unit_SBP = AGS_GetSiegeUnit(player.raceName, unit_blueprint)
				-- Filter types
				if not Squad_IsSBPOfType(unit_SBP, "springald") and not Squad_IsSBPOfType(unit_SBP, "culverin") and not Squad_IsSBPOfType(unit_SBP, "trebuchet_traction") then
					Player_SetSquadProductionAvailability(player.id, unit_SBP, lock_type)
				end
			end
			for id, entity_blueprint in pairs(CBA_SIEGE_UNITS.siege_buildable_mon) do
				-- Filter types
				if entity_blueprint ~= "unit_springald_3_field_construct_mon" or entity_blueprint ~= "unit_trebuchet_4_tr_field_construct_mon" then
					Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint(entity_blueprint), lock_type) -- Field Constructed = Entity
				end
			end
			
		elseif player_civ == "abbasid" then
			Player_SetEntityProductionAvailability(player.id, EBP.ABBASID.UNIT_MANGONEL_3_BUILDABLE_ABB, lock_type) -- Field Constructed = Entity

		elseif player_civ == "abbasid_ha_01" then
			Player_SetEntityProductionAvailability(player.id, EBP.ABBASID_HA_01.UNIT_MANGONEL_3_BUILDABLE_ABB_HA_01, lock_type) -- Field Constructed = Entity
			-- Unique: Ram / Tower
			Player_SetEntityProductionAvailability(player.id, EBP.ABBASID_HA_01.UNIT_RAM_TOWER_3_ABB_HA_01, lock_type) 

		elseif player_civ == "french" then
			for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_faction_fre) do
				local unit_SBP = AGS_GetSiegeUnit(player.raceName, unit_blueprint)
				if not Squad_IsSBPOfType(unit_SBP, "culverin") then
					Player_SetSquadProductionAvailability(player.id, unit_SBP, lock_type)
				end
			end
			
		elseif player_civ == "chinese" then
			for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_faction_chi) do
				Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeUnit(player.raceName, unit_blueprint), lock_type)
			end
			
		elseif player_civ == "chinese_ha_01" then
			Player_SetSquadProductionAvailability(player.id, SBP.CHINESE_HA_01.UNIT_NEST_OF_BEES_4_CHI_HA_01, lock_type)
			
		elseif player_civ ~= "chinese" then
			Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeUnit(player.raceName, BP_SIEGE_RIBAULDEQUIN), lock_type)
		end
		
		-- Cancel Production 
		if siege_limit == 3 and lock_type == ITEM_LOCKED then
			CBA_Options_SiegeLimit_Cancel_filter(3, player)
		end
	end
	
	-- Siege limit (4) - Great Bombard
	if (siege_limit <= 4 and lock_type == ITEM_LOCKED) or (siege_limit == 4 and lock_type == ITEM_UNLOCKED) then
		if player_civ == "ottoman" then
			Player_SetSquadProductionAvailability(player.id, SBP.OTTOMAN.UNIT_GREAT_BOMBARD_4_OTT, lock_type)
			if siege_limit == 4 and lock_type == ITEM_LOCKED then
				CBA_Options_SiegeLimit_Cancel_filter(4, player) -- Only for ottoman faction
			end
		end
	end		
end

function CBA_Options_SiegeLimit_Cancel_filter(siege_limit, player)
	
	local player_civ = Player_GetRaceName(player.id)
	local eg_count = EGroup_Count(player.eg_siegeproduction)
	
	for indx2 = 1, eg_count do
		local entity = EGroup_GetSpawnedEntityAt(player.eg_siegeproduction, indx2)
		
		if Entity_HasProductionQueue(entity) then
			local queue_count = Entity_GetProductionQueueSize(entity)
			
		for index = 1, queue_count do
			local bp_type = Entity_GetProductionQueueItemType(entity, queue_count - index)
			
				if bp_type == PITEM_Spawn then
					local bp_queue = Entity_GetProductionQueueItem(entity, queue_count - index)
					
					-- Siege limit (1) - ALL
					if siege_limit == 1 then
						if Squad_IsSBPOfType(bp_queue, "siege") then
							Entity_CancelProductionQueueItem(entity, queue_count - index)
						end
					-- Siege limit (2) - Skip siege with value 1
					elseif siege_limit == 2 then
						if not Squad_IsSBPOfType(bp_queue, "springald") then
							Entity_CancelProductionQueueItem(entity, queue_count - index)
						end
					-- Siege limit (3) - Skip siege with value 2
					elseif siege_limit == 3 then
						if not (Squad_IsSBPOfType(bp_queue, "trebuchet_traction") or Squad_IsSBPOfType(bp_queue, "ram") or Squad_IsSBPOfType(bp_queue, "culverin") or Squad_IsSBPOfType(bp_queue, "springald")) then
							Entity_CancelProductionQueueItem(entity, queue_count - index)
						end
					-- Siege limit (4) - Unique only
					elseif siege_limit == 4 then
						if Squad_IsSBPOfType(bp_queue, "bombard") and player_civ == "ottoman" then
							Entity_CancelProductionQueueItem(entity, queue_count - index)
						end
					end
				end
			end
		end
	end
end

-- Siege Limit / Increase value / Siege Completed
function CBA_Options_SiegeLimit_BuildItemComplete(context)
	
	-- Store the player who constructed the building
	local player = Core_GetPlayersTableEntry(context.player)
	local player_civ = Player_GetRaceName(player.id)
	
	-- Check to see if there was a player
	if player ~= nil and not player.isEliminated then
		
		-- Siege Filter
		if Squad_IsSBPOfType(context.pbg, "siege") then
			-- Filter for value
			if Squad_IsSBPOfType(context.pbg, "scar_springald") then
				player.siegeLimit_count = player.siegeLimit_count + 1
				
			elseif Squad_IsSBPOfType(context.pbg, "scar_trebuchet_traction") or Squad_IsSBPOfType(context.pbg, "scar_culverin") or Squad_IsSBPOfType(context.pbg, "scar_ram") then
				player.siegeLimit_count = player.siegeLimit_count + 2
				
			elseif Squad_IsSBPOfType(context.pbg, "scar_mangonel") or Squad_IsSBPOfType(context.pbg, "scar_trebuchet_cw") or Squad_IsSBPOfType(context.pbg, "scar_cannon") or 
				Squad_IsSBPOfType(context.pbg, "scar_bombard") or Squad_IsSBPOfType(context.pbg, "nest_of_bees") or Squad_IsSBPOfType(context.pbg, "scar_ribauldequin") then
				player.siegeLimit_count = player.siegeLimit_count + 3
				
			elseif Squad_IsSBPOfType(context.pbg, "bombard") and player_civ == "ottoman" then
				player.siegeLimit_count = player.siegeLimit_count + 4
			end
		end
		
		-- Siege limit reached
		if player.siegeLimit_count >= AGS_GLOBAL_SETTINGS.MaximumMedicPopulation then
			
			CBA_Options_SiegeLimit_Disable(player.id, 1, ITEM_LOCKED)
			
		elseif player.siegeLimit_count + 1 >= AGS_GLOBAL_SETTINGS.MaximumMedicPopulation then
			
			CBA_Options_SiegeLimit_Disable(player.id, 2, ITEM_LOCKED)
			
		elseif player.siegeLimit_count + 2 >= AGS_GLOBAL_SETTINGS.MaximumMedicPopulation then
			
			CBA_Options_SiegeLimit_Disable(player.id, 3, ITEM_LOCKED)
			
		elseif player.siegeLimit_count + 3 >= AGS_GLOBAL_SETTINGS.MaximumMedicPopulation then
			
			CBA_Options_SiegeLimit_Disable(player.id, 4, ITEM_LOCKED)

		end
	end
end

-- Siege Limit / Decrease value / Siege killed 
function CBA_Options_SiegeLimit_SquadKilled(context)
	
	if context.killer==nil then
		return 
	end
	
	if context.victim == nil then
		return
	end
	
	local squad = Squad_FromID(context.victim.SquadID)
	local player = Util_GetPlayerOwner(context.victim)
	if player==nil then
		return
	end
	player = PLAYERS[World_GetPlayerIndex(player)]
	local player_civ = Player_GetRaceName(player.id)

	-- Siege Filter
	if Squad_IsOfType(squad, "siege") then
		-- Filter for value
			if Squad_IsOfType(squad, "scar_springald") then
				player.siegeLimit_count = player.siegeLimit_count - 1
				
			elseif Squad_IsOfType(squad, "scar_trebuchet_traction") or Squad_IsOfType(squad, "scar_culverin") or Squad_IsOfType(squad, "scar_ram") then
				player.siegeLimit_count = player.siegeLimit_count - 2
				
			elseif Squad_IsOfType(squad, "scar_mangonel") or Squad_IsOfType(squad, "scar_trebuchet_cw") or Squad_IsOfType(squad, "scar_cannon") or 
			Squad_IsOfType(squad, "scar_bombard") or Squad_IsOfType(squad, "nest_of_bees") or Squad_IsOfType(squad, "scar_ribauldequin") then
				player.siegeLimit_count = player.siegeLimit_count - 3
				
			elseif Squad_IsOfType(squad, "bombard") and player_civ == "ottoman" then
				player.siegeLimit_count = player.siegeLimit_count - 4
			end
		end
	
	-- Siege limit reached
	if player.siegeLimit_count == AGS_GLOBAL_SETTINGS.MaximumMedicPopulation - 1 then
		
		CBA_Options_SiegeLimit_Disable(player.id, 1, ITEM_UNLOCKED)
		
	elseif player.siegeLimit_count == AGS_GLOBAL_SETTINGS.MaximumMedicPopulation - 2 then
		
		CBA_Options_SiegeLimit_Disable(player.id, 2, ITEM_UNLOCKED)
		
	elseif player.siegeLimit_count == AGS_GLOBAL_SETTINGS.MaximumMedicPopulation - 3 then
		
		CBA_Options_SiegeLimit_Disable(player.id, 3, ITEM_UNLOCKED)
		
	elseif player.siegeLimit_count <= AGS_GLOBAL_SETTINGS.MaximumMedicPopulation - 4 then
		
		CBA_Options_SiegeLimit_Disable(player.id, 4, ITEM_UNLOCKED)
	end
	
	--[[ Siege limit reached
	if player.siegeLimit_count < AGS_GLOBAL_SETTINGS.MaximumMedicPopulation then
		
		-- Enable siege units / ALL FACTIONS
		for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_faction_all) do
			Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeUnit(player.raceName, unit_blueprint), ITEM_DEFAULT)	
		end
		-- Disable ram
		Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeUnit(player.raceName, BP_SIEGE_WORKSHOP_RAM), ITEM_DEFAULT)
		Player_SetEntityProductionAvailability(player.id, AGS_GetSiegeEntity(player.raceName, BP_SIEGE_RAM), ITEM_DEFAULT)
		
		-- Enable siege units / FACTION UNIQUE
		if player_civ == "mongol" then
			for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_faction_mon) do
				Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeUnit(player.raceName, unit_blueprint), ITEM_DEFAULT)
			end
			
			for id, entity_blueprint in pairs(CBA_SIEGE_UNITS.siege_buildable_mon) do
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint(entity_blueprint), ITEM_DEFAULT) -- Field Constructed = Entity
			end
			
		elseif player_civ == "abbasid" then
			for id, entity_blueprint in pairs(CBA_SIEGE_UNITS.siege_buildable_abb) do
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint(entity_blueprint), ITEM_DEFAULT) -- Field Constructed = Entity
			end
			
		elseif player_civ == "french" then
			for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_faction_fre) do
				Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeUnit(player.raceName, unit_blueprint), ITEM_DEFAULT)
			end
			
		elseif player_civ == "chinese" then
			for id, unit_blueprint in pairs(CBA_SIEGE_UNITS.siege_faction_chi) do
				Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeUnit(player.raceName, unit_blueprint), ITEM_DEFAULT)
			end
			Player_SetSquadProductionAvailability(player.id, SBP.CHINESE.UNIT_RAM_3_CLOCKTOWER_CHI, ITEM_DEFAULT)
		else
			Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeUnit(player.raceName, BP_SIEGE_RIBAULDEQUIN), ITEM_DEFAULT)
		end
		
	end]]
end
