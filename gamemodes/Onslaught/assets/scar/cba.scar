-----------------------------------------------------------------------
-- Scripting framework 
-----------------------------------------------------------------------

-- Called during load as part of the game setup sequence
function Mod_OnGameSetup()
	Setup_GetWinConditionOptions(_mod.options)
	-- Lobby Options    
	if _mod.options.economy_section then -- Economy Section
		-- Resources per minute
		if _mod.options.economy_section.resource_amount.enum_value == _mod.options.economy_section.resource_amount.enum_items.resource_1000 then
			_mod.resource_amount = 1000
		elseif _mod.options.economy_section.resource_amount.enum_value == _mod.options.economy_section.resource_amount.enum_items.resource_2500 then
			_mod.resource_amount = 2500			
		elseif _mod.options.economy_section.resource_amount.enum_value == _mod.options.economy_section.resource_amount.enum_items.resource_5000 then			
			_mod.resource_amount = 5000
		elseif _mod.options.economy_section.resource_amount.enum_value == _mod.options.economy_section.resource_amount.enum_items.resource_unlimited then			
			_mod.resource_amount = "unlimited"
		elseif _mod.options.economy_section.resource_amount.enum_value == _mod.options.economy_section.resource_amount.enum_items.resource_disabled then			
			_mod.resource_amount = "disabled"
		end
		
		-- Starting Resources
		if _mod.options.economy_section.startingResources.enum_value == _mod.options.economy_section.startingResources.enum_items.startingResources_standard then
			_mod.startingResources = "standard"
		elseif _mod.options.economy_section.startingResources.enum_value == _mod.options.economy_section.startingResources.enum_items.startingResources_high then
			_mod.startingResources = "high"
		elseif _mod.options.economy_section.startingResources.enum_value == _mod.options.economy_section.startingResources.enum_items.startingResources_max then
			_mod.startingResources = "max"
		end
	end
	-- AGS
	AGS_Print("AGS_Cardinal_OnGameSetup")
	local options = { }
	Setup_GetWinConditionOptions(options)
	Core_CallDelegateFunctions("SetupSettings", options)
	Core_CallDelegateFunctions("AdjustSettings")
	_CBA_ENABLE_AI_PLAYER = not (AGS_GLOBAL_SETTINGS ~= nil and AGS_GLOBAL_SETTINGS.AIPlayers == "disabled")
	AGS_Print(AGS_GLOBAL_SETTINGS)
	Core_CallDelegateFunctions("UpdateModuleSettings")
	-- Leaver handling: snapshot base values for auto-rate scaling
	_mod.start_player_count = #PLAYERS
	_mod._base_resource_amount = _mod.resource_amount
	_mod._base_pop_interval_amount = _mod.pop_cap_incease_on_interval
	-- Keep-as-Capital: when auto-pop is ON or passive income is OFF, the Starter Keep
	-- acts as the player's capital building (no separate capital TC is constructed).
	_mod.keep_as_capital = (_mod.pop_cap_incease_on_interval ~= 0) or (_mod.resource_amount == "disabled")
end

-----------------------------------------------------------------------
-- Force Team Positions
-- Post-load pass: validates team-vs-side keep constraints and swaps keep
-- positions between violating pairs. This runs before spawner scheduling.
-----------------------------------------------------------------------
local function _ForceTeamPositions_BuildSideSnapshot()
	local player_count = World_GetPlayerCount()
	local players = {}
	local min_x, max_x = nil, nil
	local min_z, max_z = nil, nil

	for i = 1, player_count do
		local pid = World_GetPlayerAt(i)
		local player_entry = Core_GetPlayersTableEntry(pid)
		if player_entry ~= nil and player_entry.keep ~= nil and player_entry.keep.entity ~= nil then
			local pos = Entity_GetPosition(player_entry.keep.entity)
			if pos ~= nil then
				if min_x == nil or pos.x < min_x then min_x = pos.x end
				if max_x == nil or pos.x > max_x then max_x = pos.x end
				if min_z == nil or pos.z < min_z then min_z = pos.z end
				if max_z == nil or pos.z > max_z then max_z = pos.z end
				table.insert(players, {
					entry = player_entry,
					pid = pid,
					slot = Player_GetSlotIndex(pid),
					team = Player_GetTeam(pid),
					pos = pos,
				})
			end
		end
	end

	if #players == 0 then
		return nil
	end

	local spread_x = (max_x or 0) - (min_x or 0)
	local spread_z = (max_z or 0) - (min_z or 0)
	local axis = "z"
	if spread_x > spread_z then
		axis = "x"
	end

	local pivot = 0
	if axis == "x" then
		pivot = ((min_x or 0) + (max_x or 0)) * 0.5
	else
		pivot = ((min_z or 0) + (max_z or 0)) * 0.5
	end

	for _, row in ipairs(players) do
		local v = (axis == "x") and row.pos.x or row.pos.z
		row.side = (v >= pivot) and "pos" or "neg"
	end

	return {
		axis = axis,
		pivot = pivot,
		players = players,
	}
end

local function _ForceTeamPositions_GetSideFromPos(axis, pivot, pos)
	if pos == nil then
		return nil
	end
	local v = (axis == "x") and pos.x or pos.z
	if v == nil then
		return nil
	end
	return (v >= pivot) and "pos" or "neg"
end

local function _ForceTeamPositions_RefreshKeepVisual(ent)
	if ent == nil then
		return
	end
	pcall(Entity_SnapToGridAndGround, ent, false)
	pcall(Entity_VisHide, ent, true)
	pcall(Entity_VisHide, ent, false)
	pcall(Misc_SetEntitySelectable, ent, true)
end

local function _ForceTeamPositions_SnapPosToTerrain(pos)
	if pos == nil or pos.x == nil or pos.z == nil then
		return pos
	end
	local y = World_GetHeightAt(pos.x, pos.z)
	return World_Pos(pos.x, y, pos.z)
end

local function _ForceTeamPositions_FocusLocalPlayerCamera(source_tag)
	local local_pid = Game_GetLocalPlayer()
	if local_pid == nil or local_pid == -1 then
		return
	end
	local p = Core_GetPlayersTableEntry(local_pid)
	if p == nil or p.keep == nil or p.keep.entity == nil then
		return
	end
	local pos = Entity_GetPosition(p.keep.entity)
	if pos == nil then
		return
	end
	pcall(Camera_MoveTo, pos, true)
	Onslaught_LogForceTeamPositions(string.format("[FORCE_TEAM_POSITIONS] camera_focus(%s): local_player=%s keep=(%.2f, %.2f, %.2f)", tostring(source_tag), tostring(local_pid), pos.x or -1, pos.y or -1, pos.z or -1))
end

local function _ForceTeamPositions_SnapshotEntities(player_id)
	local out = {}
	local eg = Player_GetEntities(player_id)
	local n = EGroup_Count(eg)
	for i = 1, n do
		local ent = EGroup_GetEntityAt(eg, i)
		if ent ~= nil then
			table.insert(out, ent)
		end
	end
	return out
end

local function _ForceTeamPositions_SnapshotSquads(player_id)
	local out = {}
	local sg = Player_GetSquads(player_id)
	local n = SGroup_Count(sg)
	for i = 1, n do
		local sq = SGroup_GetSquadAt(sg, i)
		if sq ~= nil then
			table.insert(out, sq)
		end
	end
	return out
end

local function _ForceTeamPositions_TransferEntityList(entities, dst_player_id, keep_id_a, keep_id_b)
	local stats = {
		entities_moved = 0,
		entities_failed = 0,
	}
	for _, ent in ipairs(entities) do
		if ent ~= nil and Entity_IsAlive(ent) then
			local eid = Entity_GetID(ent)
			if eid ~= keep_id_a and eid ~= keep_id_b then
				local ok = pcall(Entity_SetPlayerOwner, ent, dst_player_id)
				if ok then
					stats.entities_moved = stats.entities_moved + 1
				else
					stats.entities_failed = stats.entities_failed + 1
				end
			end
		end
	end
	return stats
end

local function _ForceTeamPositions_TransferSquadList(squads, dst_player_id)
	local stats = {
		squads_moved = 0,
		squads_failed = 0,
	}
	for _, sq in ipairs(squads) do
		if sq ~= nil then
			local ok = pcall(Squad_SetPlayerOwner, sq, dst_player_id)
			if ok then
				stats.squads_moved = stats.squads_moved + 1
			else
				stats.squads_failed = stats.squads_failed + 1
			end
		end
	end
	return stats
end

local function _ForceTeamPositions_ReconcilePairBySide(pair, axis, pivot)
	if pair == nil then
		return 0, 0, 0
	end
	local moved_entities = 0
	local moved_squads = 0
	local errors = 0

	for _, owner_id in ipairs({ pair.player_a_id, pair.player_b_id }) do
		local entities = _ForceTeamPositions_SnapshotEntities(owner_id)
		for _, ent in ipairs(entities) do
			if ent ~= nil and Entity_IsAlive(ent) then
				local eid = Entity_GetID(ent)
				if eid ~= pair.keep_id_a and eid ~= pair.keep_id_b then
					local pos = Entity_GetPosition(ent)
					local side = _ForceTeamPositions_GetSideFromPos(axis, pivot, pos)
					if side ~= nil then
						local desired_owner = (side == "pos") and pair.owner_pos_id or pair.owner_neg_id
						if owner_id ~= desired_owner then
							local ok = pcall(Entity_SetPlayerOwner, ent, desired_owner)
							if ok then
								moved_entities = moved_entities + 1
							else
								errors = errors + 1
							end
						end
					end
				end
			end
		end

		local squads = _ForceTeamPositions_SnapshotSquads(owner_id)
		for _, sq in ipairs(squads) do
			if sq ~= nil then
				local ok_pos, sq_pos = pcall(Squad_GetPosition, sq)
				if ok_pos and sq_pos ~= nil then
					local side = _ForceTeamPositions_GetSideFromPos(axis, pivot, sq_pos)
					if side ~= nil then
						local desired_owner = (side == "pos") and pair.owner_pos_id or pair.owner_neg_id
						if owner_id ~= desired_owner then
							local ok = pcall(Squad_SetPlayerOwner, sq, desired_owner)
							if ok then
								moved_squads = moved_squads + 1
							else
								errors = errors + 1
							end
						end
					end
				end
			end
		end
	end

	return moved_entities, moved_squads, errors
end

function Mod_ForceTeamPositions_ReconcileSpawnedOwnership(source_tag)
	local st = _FORCE_TEAM_POSITIONS_LAST
	if st == nil or st.axis == nil or st.pivot == nil or type(st.pairs_detail) ~= "table" then
		Onslaught_LogForceTeamPositions(string.format("[FORCE_TEAM_POSITIONS] reconcile(%s): skipped (no transition state)", tostring(source_tag)))
		return
	end
	local moved_entities = 0
	local moved_squads = 0
	local errors = 0
	for _, pair in ipairs(st.pairs_detail) do
		local em, sm, er = _ForceTeamPositions_ReconcilePairBySide(pair, st.axis, st.pivot)
		moved_entities = moved_entities + em
		moved_squads = moved_squads + sm
		errors = errors + er
	end
	st.entities_moved = (st.entities_moved or 0) + moved_entities
	st.squads_moved = (st.squads_moved or 0) + moved_squads
	st.errors = (st.errors or 0) + errors
	Onslaught_LogForceTeamPositions(string.format("[FORCE_TEAM_POSITIONS] reconcile(%s): entities_moved=%d squads_moved=%d errors=%d", tostring(source_tag), moved_entities, moved_squads, errors))
end

function Mod_ForceTeamPositions()
	_FORCE_TEAM_POSITIONS_LAST = {
		transition_started = true,
		transition_done = false,
		axis = nil,
		pivot = nil,
		pairs = 0,
		pairs_detail = {},
		entities_moved = 0,
		squads_moved = 0,
		errors = 0,
	}

	local player_count = World_GetPlayerCount()
	if player_count ~= 8 then
		Onslaught_LogForceTeamPositions("[FORCE_TEAM_POSITIONS] Disabled: requires exactly 8 players.")
		_FORCE_TEAM_POSITIONS_LAST.transition_done = true
		return
	end

	local snapshot = _ForceTeamPositions_BuildSideSnapshot()
	if snapshot == nil then
		Onslaught_LogForceTeamPositions("[FORCE_TEAM_POSITIONS] Disabled: could not build side snapshot.")
		_FORCE_TEAM_POSITIONS_LAST.transition_done = true
		_FORCE_TEAM_POSITIONS_LAST.errors = _FORCE_TEAM_POSITIONS_LAST.errors + 1
		return
	end

	_FORCE_TEAM_POSITIONS_LAST.axis = snapshot.axis
	_FORCE_TEAM_POSITIONS_LAST.pivot = snapshot.pivot

	local team_ids = {}
	local team_seen = {}
	for _, row in ipairs(snapshot.players) do
		local team_id = row.team
		if not team_seen[team_id] then
			team_seen[team_id] = true
			table.insert(team_ids, team_id)
		end
	end
	if #team_ids ~= 2 then
		Onslaught_LogForceTeamPositions(string.format("[FORCE_TEAM_POSITIONS] Disabled: expected 2 teams, found %d.", #team_ids))
		_FORCE_TEAM_POSITIONS_LAST.transition_done = true
		_FORCE_TEAM_POSITIONS_LAST.errors = _FORCE_TEAM_POSITIONS_LAST.errors + 1
		return
	end
	table.sort(team_ids)
	local team_a = team_ids[1]
	local team_b = team_ids[2]

	local counts = {
		[team_a] = { pos = 0, neg = 0 },
		[team_b] = { pos = 0, neg = 0 },
	}
	for _, row in ipairs(snapshot.players) do
		if counts[row.team] ~= nil then
			counts[row.team][row.side] = counts[row.team][row.side] + 1
		end
	end

	-- Choose mapping that minimizes swaps:
	-- mapping1: team_a->pos, team_b->neg
	-- mapping2: team_a->neg, team_b->pos
	local mapping1_violations = counts[team_a].neg + counts[team_b].pos
	local mapping2_violations = counts[team_a].pos + counts[team_b].neg

	local target = {}
	if mapping1_violations <= mapping2_violations then
		target[team_a] = "pos"
		target[team_b] = "neg"
	else
		target[team_a] = "neg"
		target[team_b] = "pos"
	end

	local wrong_pos = {}
	local wrong_neg = {}
	for _, row in ipairs(snapshot.players) do
		if row.side ~= target[row.team] then
			if row.side == "pos" then
				table.insert(wrong_pos, row.entry)
			else
				table.insert(wrong_neg, row.entry)
			end
		end
	end

	Onslaught_LogForceTeamPositions(string.format("[FORCE_TEAM_POSITIONS] precheck: axis=%s pivot=%.2f wrong_pos=%d wrong_neg=%d", snapshot.axis, snapshot.pivot, #wrong_pos, #wrong_neg))
	if #wrong_pos == 0 and #wrong_neg == 0 then
		Onslaught_LogForceTeamPositions("[FORCE_TEAM_POSITIONS] already valid; no keep swap needed.")
		_FORCE_TEAM_POSITIONS_LAST.transition_done = true
		return
	end

	-- Deterministic pair order by slot index.
	table.sort(wrong_pos, function(a, b) return Player_GetSlotIndex(a.id) < Player_GetSlotIndex(b.id) end)
	table.sort(wrong_neg, function(a, b) return Player_GetSlotIndex(a.id) < Player_GetSlotIndex(b.id) end)

	local swap_count = math.min(#wrong_pos, #wrong_neg)
	if #wrong_pos ~= #wrong_neg then
		Onslaught_LogForceTeamPositions("[FORCE_TEAM_POSITIONS] WARNING: mismatch in violating pairs; applying partial correction.")
	end

	local moved = 0
	for i = 1, swap_count do
		local p_pos = wrong_pos[i]
		local p_neg = wrong_neg[i]
		local p_left = p_pos
		local p_right = p_neg
		if p_left ~= nil and p_right ~= nil and p_left.keep ~= nil and p_right.keep ~= nil and p_left.keep.entity ~= nil and p_right.keep.entity ~= nil then
			local left_ent = p_left.keep.entity
			local right_ent = p_right.keep.entity
			local left_keep_id = Entity_GetID(left_ent)
			local right_keep_id = Entity_GetID(right_ent)
			local pos_entities = _ForceTeamPositions_SnapshotEntities(p_pos.id)
			local neg_entities = _ForceTeamPositions_SnapshotEntities(p_neg.id)
			local pos_squads = _ForceTeamPositions_SnapshotSquads(p_pos.id)
			local neg_squads = _ForceTeamPositions_SnapshotSquads(p_neg.id)
			local left_pos = Entity_GetPosition(left_ent)
			local right_pos = Entity_GetPosition(right_ent)
			local snapped_right_pos = _ForceTeamPositions_SnapPosToTerrain(right_pos)
			local snapped_left_pos = _ForceTeamPositions_SnapPosToTerrain(left_pos)
			local ok_a = pcall(Entity_SetPosition, left_ent, snapped_right_pos)
			local ok_b = pcall(Entity_SetPosition, right_ent, snapped_left_pos)
			if ok_a and ok_b then
				_ForceTeamPositions_RefreshKeepVisual(left_ent)
				_ForceTeamPositions_RefreshKeepVisual(right_ent)
				moved = moved + 2
				local team_pos = Player_GetTeam(p_pos.id)
				local team_neg = Player_GetTeam(p_neg.id)
				local desired_side_pos = target[team_pos]
				local desired_side_neg = target[team_neg]
				local owner_pos_id = (desired_side_pos == "pos") and p_pos.id or p_neg.id
				local owner_neg_id = (desired_side_pos == "neg") and p_pos.id or p_neg.id
				if desired_side_neg == "pos" then
					owner_pos_id = p_neg.id
					owner_neg_id = p_pos.id
				end
				table.insert(_FORCE_TEAM_POSITIONS_LAST.pairs_detail, {
					player_a_id = p_pos.id,
					player_b_id = p_neg.id,
					keep_id_a = left_keep_id,
					keep_id_b = right_keep_id,
					owner_pos_id = owner_pos_id,
					owner_neg_id = owner_neg_id,
				})
				-- Custom map compatibility: swap ownership of pre-existing entities/squads
				-- (excluding the two keep entities we just repositioned).
				local ent_to_pos = _ForceTeamPositions_TransferEntityList(neg_entities, p_pos.id, left_keep_id, right_keep_id)
				local ent_to_neg = _ForceTeamPositions_TransferEntityList(pos_entities, p_neg.id, left_keep_id, right_keep_id)
				local sq_to_pos = _ForceTeamPositions_TransferSquadList(neg_squads, p_pos.id)
				local sq_to_neg = _ForceTeamPositions_TransferSquadList(pos_squads, p_neg.id)
				_FORCE_TEAM_POSITIONS_LAST.entities_moved = _FORCE_TEAM_POSITIONS_LAST.entities_moved + ent_to_pos.entities_moved + ent_to_neg.entities_moved
				_FORCE_TEAM_POSITIONS_LAST.squads_moved = _FORCE_TEAM_POSITIONS_LAST.squads_moved + sq_to_pos.squads_moved + sq_to_neg.squads_moved
				_FORCE_TEAM_POSITIONS_LAST.errors = _FORCE_TEAM_POSITIONS_LAST.errors + ent_to_pos.entities_failed + ent_to_neg.entities_failed + sq_to_pos.squads_failed + sq_to_neg.squads_failed
				_FORCE_TEAM_POSITIONS_LAST.pairs = _FORCE_TEAM_POSITIONS_LAST.pairs + 1
			else
				Onslaught_LogForceTeamPositions(string.format("[FORCE_TEAM_POSITIONS] WARNING: keep move failed for slots %s <-> %s", tostring(Player_GetSlotIndex(p_left.id)), tostring(Player_GetSlotIndex(p_right.id))))
				_FORCE_TEAM_POSITIONS_LAST.errors = _FORCE_TEAM_POSITIONS_LAST.errors + 1
			end
		else
			Onslaught_LogForceTeamPositions("[FORCE_TEAM_POSITIONS] WARNING: missing keep data for a violating pair.")
			_FORCE_TEAM_POSITIONS_LAST.errors = _FORCE_TEAM_POSITIONS_LAST.errors + 1
		end
	end

	-- Refresh keep caches so all systems (rewards/AI/debug) use corrected positions.
	_mod.castles = {}
	Mod_FindKeep()
	if _mod.keep_as_capital then
		for _, player in ipairs(PLAYERS) do
			Mod_EnsureKeepAsCapital(player, "ForceTeamPositions", false)
		end
	end

	-- Post-check (warn-only): do not halt gameplay on residual violations.
	local post_snapshot = _ForceTeamPositions_BuildSideSnapshot()
	local remain_pos = 0
	local remain_neg = 0
	if post_snapshot ~= nil then
		for _, row in ipairs(post_snapshot.players) do
			if row.side ~= target[row.team] then
				if row.side == "pos" then
					remain_pos = remain_pos + 1
				else
					remain_neg = remain_neg + 1
				end
			end
		end
		Onslaught_LogForceTeamPositions(string.format("[FORCE_TEAM_POSITIONS] applied keep_moves=%d; postcheck axis=%s pivot=%.2f wrong_pos=%d wrong_neg=%d", moved, post_snapshot.axis, post_snapshot.pivot, remain_pos, remain_neg))
	else
		remain_pos = -1
		remain_neg = -1
		Onslaught_LogForceTeamPositions(string.format("[FORCE_TEAM_POSITIONS] applied keep_moves=%d; postcheck unavailable", moved))
	end
	if remain_pos > 0 or remain_neg > 0 then
		Onslaught_LogForceTeamPositions("[FORCE_TEAM_POSITIONS] WARNING: residual team-side violations remain after correction.")
	end

	-- Startup safety pass: side-based reconcile to catch assets spawned/initialized
	-- during transition and align ownership with post-transition side owners.
	Mod_ForceTeamPositions_ReconcileSpawnedOwnership("transition_end")
	_ForceTeamPositions_FocusLocalPlayerCamera("transition_end")

	_FORCE_TEAM_POSITIONS_LAST.transition_done = true
	Onslaught_LogForceTeamPositions(string.format("[FORCE_TEAM_POSITIONS] transition_done=true pairs=%d entities_moved=%d squads_moved=%d errors=%d", _FORCE_TEAM_POSITIONS_LAST.pairs or 0, _FORCE_TEAM_POSITIONS_LAST.entities_moved or 0, _FORCE_TEAM_POSITIONS_LAST.squads_moved or 0, _FORCE_TEAM_POSITIONS_LAST.errors or 0))
end

-- Console helper: dump slot/team/keep position snapshot for timing checks.
function Debug_ForceTeamPositionsDump()
	local snapshot = _ForceTeamPositions_BuildSideSnapshot()
	if snapshot == nil then
		print("[FORCE_TEAM_POSITIONS] dump unavailable: no side snapshot.")
		return
	end
	print(string.format("[FORCE_TEAM_POSITIONS] dump players=%d axis=%s pivot=%.2f", #snapshot.players, snapshot.axis, snapshot.pivot))
	for _, row in ipairs(snapshot.players) do
		local ent_count = EGroup_Count(Player_GetEntities(row.entry.id))
		local sq_count = SGroup_Count(Player_GetSquads(row.entry.id))
		print(string.format("[FORCE_TEAM_POSITIONS] slot=%s pid=%s team=%s side=%s keep=(%.2f, %.2f, %.2f)", tostring(row.slot), tostring(row.pid), tostring(row.team), row.side, row.pos.x or -1, row.pos.y or -1, row.pos.z or -1))
		print(string.format("[FORCE_TEAM_POSITIONS]   ownership: entities=%d squads=%d", ent_count, sq_count))
	end
end

-- Console helper: force immediate post-load swap pass regardless of lobby timing.
function Debug_ForceTeamPositionsNow()
	if type(Mod_ForceTeamPositions) ~= "function" then
		print("[FORCE_TEAM_POSITIONS] Debug_ForceTeamPositionsNow: Mod_ForceTeamPositions missing.")
		return
	end
	print("[FORCE_TEAM_POSITIONS] Debug_ForceTeamPositionsNow: before")
	Debug_ForceTeamPositionsDump()
	Mod_ForceTeamPositions()
	print("[FORCE_TEAM_POSITIONS] Debug_ForceTeamPositionsNow: after")
	Debug_ForceTeamPositionsDump()
end

-- Internal deferred callback used by Debug_ForceTeamPositionsIn.
function _Debug_ForceTeamPositionsDelayedApply()
	if _onslaught_teardown_detected then
		return
	end
	Debug_ForceTeamPositionsNow()
end

-- Console helper: schedule a delayed force-swap pass to test timing windows.
-- Usage: Debug_ForceTeamPositionsIn(1.0)
function Debug_ForceTeamPositionsIn(delay_seconds)
	local delay = tonumber(delay_seconds)
	if delay == nil then
		delay = 1.0
	end
	if delay < 0 then
		delay = 0
	end
	print(string.format("[FORCE_TEAM_POSITIONS] Debug_ForceTeamPositionsIn: scheduled in %.2fs", delay))
	Rule_AddOneShot(_Debug_ForceTeamPositionsDelayedApply, delay)
end

-- Called before initialization, preceding other module OnInit functions
function Mod_PreInit()
	-- Diplomacy & Tribute / Disabled
	Core_CallDelegateFunctions("DiplomacyEnabled", false)
	Core_CallDelegateFunctions("TributeEnabled", false)
	
end

-- Called on match initialization before handing control to the player
function Mod_OnInit() 
	-- Store the local player so we can reference them later
	localPlayer = Core_GetPlayersTableEntry(Game_GetLocalPlayer())
	-- Set player behaviour when eliminated
	_allow_spectators = true
	-- From Advanced Game Script
	Core_CallDelegateFunctions("EarlyInitializations")
	-- CALLING FUNCTIONS
	Mod_FindKeep()
	Mod_SetFOW()
	Mod_setStartingResources()
	Mod_RemoveGaia()
	Religious_UpdateConditions(_mod)
	
	-- NOTE: Causes Error when no sacred site in map
	egroup = EGroup_Create("sites")
	World_GetAllNeutralEntities(egroup)
	EGroup_Filter(egroup,"special_beacon",FILTER_KEEP)
	local site =  EGroup_GetEntityAt(egroup, 1)
	_CBA.center = Entity_GetPosition(site)
	
	-- Help Text @ Start of the match
	local uiColour = Player_GetUIColour(localPlayer.id)
	if AGS_GLOBAL_SETTINGS.Option_Reward_Age == true then 
		UI_CreateEventCueClickable(-1, 60.0, 0, 20.0, "$f5a005650ae44d2b8e05306aa891f90c:131", "", "event_with_player_color", "", "", uiColour.r, uiColour.g, uiColour.b, uiColour.a, ECV_Queue, nothing)
	end -- Message: "Age up by eliminating enemies"
	UI_CreateEventCueClickable(-1, 45.0, 0, 20.0, "$f5a005650ae44d2b8e05306aa891f90c:132", Loc_Empty(), "event_with_player_color", "", "", uiColour.r, uiColour.g, uiColour.b, uiColour.a, ECV_Queue, nothing)
	
	-- GLOBAL EVENT RULES: 
	Rule_AddGlobalEvent(Mod_OnEntityKilled, GE_EntityKilled)
end

-- OnInit invokes custom handle for AGS modules.
function Mod_PostInit()
	AGS_Print("AGS_Cardinal_PostInit")
	Core_CallDelegateFunctions("LateInitializations")	
end

-- Preset is safe state for anything that should be done before start. Such as additional entities, vision etc.
function Mod_Preset() 	
	AGS_Print("AGS_Cardinal_Preset")
	Core_CallDelegateFunctions("PresetInitialize")
	Core_CallDelegateFunctions("PresetExecute")
	Core_CallDelegateFunctions("PresetFinalize")
end
		
-- PreStart is followed by 1 frame delay with normal Start.
function Mod_PreStart()
	AGS_Print("AGS_Cardinal_PreStart")
	Core_CallDelegateFunctions("PrepareStart")
end

-- Called after initialization is done when game is fading up from black
function Mod_Start()
	
	-- Setup the player's objective UI by calling the below function directly
	Mod_SetupObjective()
	Core_CallDelegateFunctions("OnStarting")

	-- Keep-as-Capital: ensure every player's Keep acts as their capital TC
	-- when keep_as_capital mode is active. Must run after OnStarting (all
	-- settlement/start modules have run) but before OnPlay (economy ticks start).
	if _mod.keep_as_capital then
		for _, player in ipairs(PLAYERS) do
			Mod_EnsureKeepAsCapital(player, "Mod_Start", false)
		end
	end

	-- Force Team Positions post-load correction.
	-- Run here (after world init, before OnPlay) so reward spawners and AI caches
	-- pick up corrected keep positions from refreshed keep data.
	if AGS_GLOBAL_SETTINGS.ForceTeamPositions then
		Mod_ForceTeamPositions()
	end

	-- Starter reward spawns must wait until startup precache initialization finishes.
	_LEAVER_PRECACHE_READY = false

	if AGS_GLOBAL_SETTINGS.ForceTeamPositions then
		local st = _FORCE_TEAM_POSITIONS_LAST or {}
		Onslaught_LogForceTeamPositions(string.format("[FORCE_TEAM_POSITIONS] pre-OnPlay gate: transition_done=%s pairs=%s entities_moved=%s squads_moved=%s errors=%s", tostring(st.transition_done), tostring(st.pairs or 0), tostring(st.entities_moved or 0), tostring(st.squads_moved or 0), tostring(st.errors or 0)))
	end

	Core_CallDelegateFunctions("OnPlay")
	if AGS_GLOBAL_SETTINGS.ForceTeamPositions then
		Mod_ForceTeamPositions_ReconcileSpawnedOwnership("post_onplay")
		_ForceTeamPositions_FocusLocalPlayerCamera("post_onplay")
	end
	if type(statechange) == "function" then
		statechange()
		Rule_AddInterval(statechange, 600)
		if Onslaught_ShouldLogTrace() then
			print("[TRACE] Registered statechange interval")
		end
	else
		if Onslaught_ShouldLogTrace() then
			print("[TRACE] Day/night cycle disabled: statechange() not loaded")
		end
	end
	
	-- Show right-side player score list (normally enabled by stock Score module which is disabled in Onslaught).
	UI_SetShowPlayerScores(true)

	for _, player in ipairs(PLAYERS) do
		if player.scarModel ~= nil then
			player.scarModel.show_actual_score = true
			UI_SetPlayerDataContext(player.id, player.scarModel)
		end
	end
	Onslaught_SyncScoreToEngine()
	
	-- Sync reward score to engine state model every 2s for postgame display
	Rule_AddInterval(Onslaught_SyncScoreToEngine, 2)
	if Onslaught_ShouldLogTrace() then
		print("[TRACE] Registered Onslaught_SyncScoreToEngine interval")
	end

	-- Investigation probe: periodic heartbeat so we can see last-known live tick
	-- even if crash happens before other traces flush.
	if _onslaught_enable_heartbeat_probe then
		Rule_AddInterval(Onslaught_CrashProbeTick, 1)
		if Onslaught_ShouldLogTrace() then
			print("[TRACE] Registered Onslaught_CrashProbeTick interval")
		end
	end

	-- Legacy building warmup path remains optional.
	if _LEAVER_LEGACY_PRECACHE_ENABLED == true then
		pcall(_Leaver_WarmupPrecache)
	end

	-- Build precache manifest: validates all reward BP -> leaver conversion targets resolve.
	-- Unit warmup is now runtime/on-demand at actual spawn sites.
	pcall(_Leaver_BuildPrecacheManifest)
	if AGS_GLOBAL_SETTINGS.ForceTeamPositions then
		Mod_ForceTeamPositions_ReconcileSpawnedOwnership("pre_precache_ready")
		_ForceTeamPositions_FocusLocalPlayerCamera("pre_precache_ready")
	end

	_LEAVER_PRECACHE_READY = true
	print("[PRECACHE-INIT] precache_ready=true")
	
end

-- Centralized lifecycle cleanup: called by Core_OnGameOver delegate dispatch.
-- Removes every interval/event registered by Mod_Start and sets the teardown
-- flag so any deferred/async callback that fires after this point aborts immediately.
function Mod_OnGameOver()
	_onslaught_teardown_detected = true
	Onslaught_Trace("TRACE_TEARDOWN", "Mod_OnGameOver: tearing down intervals/events")

	-- Intervals registered in Mod_Start
	pcall(Rule_Remove, Onslaught_SyncScoreToEngine)
	pcall(Rule_Remove, Onslaught_CrashProbeTick)
	pcall(Rule_Remove, statechange)

	-- Global event registered in Mod_Start
	pcall(Rule_RemoveGlobalEvent, Mod_OnEntityKilled)

	-- Siege-limit reconciler registered by cba_options (may already be removed by leaver pause)
	pcall(Rule_Remove, CBA_Options_SiegeLimit_Reconcile)
	
	-- Building-limit reconciler registered by cba_options
	pcall(Rule_Remove, CBA_Options_BuildingLimit_Reconcile)

	-- CBA_Options global events (no CBA_Options_OnGameOver exists; clean up all GE registrations)
	pcall(Rule_RemoveGlobalEvent, CBA_Options_AddScuttle_ConstructionComplete)
	pcall(Rule_RemoveGlobalEvent, CBA_Options_BuildingLimit_ConstructionStart)
	pcall(Rule_RemoveGlobalEvent, CBA_Options_BuildingLimit_ConstructionCancelled)
	CBA_EntityKillBatch_SetHandler("building_limit", false)
	pcall(Rule_RemoveGlobalEvent, CBA_BuildItemBatch_Capture)
	pcall(Rule_Remove, CBA_BuildItemBatch_Process)
	pcall(Rule_RemoveGlobalEvent, CBA_SquadKillBatch_Capture)
	pcall(Rule_Remove, CBA_SquadKillBatch_Process)
	pcall(Rule_RemoveGlobalEvent, CBA_EntityKillBatch_Capture)
	pcall(Rule_Remove, CBA_EntityKillBatch_Process)
	pcall(Rule_RemoveGlobalEvent, CBA_Options_SiegeLimit_ConstructionStart)
	pcall(Rule_RemoveGlobalEvent, CBA_Options_SiegeLimit_ConstructionCancelled)
	pcall(Rule_RemoveGlobalEvent, CBA_Options_SiegeLimit_ConstructionComplete)
	CBA_EntityKillBatch_SetHandler("siege_limit", false)

	-- Day/night cycle one-shots scheduled by statechange()
	pcall(Rule_Remove, toDusk)
	pcall(Rule_Remove, toDusk2)
	pcall(Rule_Remove, toNight)
	pcall(Rule_Remove, toNight2)
	pcall(Rule_Remove, toDawn)
	pcall(Rule_Remove, toDay)

	-- CBA_Options intervals (VillagerSpawner has no module-level OnGameOver)
	if type(CBA_Options_VillagerSpawner) == "function" then
		pcall(Rule_Remove, CBA_Options_VillagerSpawner)
	end

	-- CBA_AutoAge intervals/events (no CBA_AutoAge_OnGameOver exists)
	if type(CBA_AutoAge_UpdateTimer) == "function" then
		pcall(Rule_Remove, CBA_AutoAge_UpdateTimer)
	end
	if type(CBA_AutoAge_ConstructionComplete) == "function" then
		pcall(Rule_RemoveGlobalEvent, CBA_AutoAge_ConstructionComplete)
	end
	if type(CBA_AutoAge_UpgradeComplete) == "function" then
		pcall(Rule_RemoveGlobalEvent, CBA_AutoAge_UpgradeComplete)
	end
	if type(CBA_Auto_Age_1) == "function" then pcall(Rule_Remove, CBA_Auto_Age_1) end
	if type(CBA_Auto_Age_2) == "function" then pcall(Rule_Remove, CBA_Auto_Age_2) end
	if type(CBA_Auto_Age_3) == "function" then pcall(Rule_Remove, CBA_Auto_Age_3) end

	-- AGS_PopulationAutomatic interval (no OnGameOver exists)
	if type(AGS_IncreasePopulation) == "function" then
		pcall(Rule_Remove, AGS_IncreasePopulation)
	end
	pcall(Rule_Remove, AGS_PopulationAutomatic_ReconcileCapDrift)
	pcall(Rule_RemoveGlobalEvent, AGS_AutoPop_OnConstructionComplete)
	CBA_EntityKillBatch_SetHandler("auto_pop", false)

	-- AGS_AutoResources interval (no OnGameOver exists)
	if type(AGS_AutoResources) == "function" then
		pcall(Rule_Remove, AGS_AutoResources)
	end

	-- PlayerUI intervals (not registered via Core_RegisterModule; no OnGameOver path)
	if type(_PlayerUI_RingRule) == "function" then
		pcall(Rule_Remove, _PlayerUI_RingRule)
	end
	if type(_PlayerUI_Animate_Tick) == "function" then
		pcall(Rule_Remove, _PlayerUI_Animate_Tick)
	end

	-- AGS_DockHouse events (module not registered; cleanup via batch handler flag)
	if type(AGS_DockHouse_OnConstructionComplete) == "function" then
		pcall(Rule_RemoveGlobalEvent, AGS_DockHouse_OnConstructionComplete)
	end
	CBA_EntityKillBatch_SetHandler("dock_house", false)

	Onslaught_Trace("TRACE_TEARDOWN", "Mod_OnGameOver: cleanup complete")
end

-----------------------------------------------------------------------
-- Mod Functions
-----------------------------------------------------------------------

-- Score/Kills Tracker
-- PERF: Direct hash lookup O(1) instead of pairs() iteration O(P) per kill event.
function Mod_OnEntityKilled(context)
	if _onslaught_teardown_detected then return end
	local castle = _mod.castles[context.victim.EntityID]
	if castle == nil then return end

	local victim = context.victimOwner

	if victim==nil then		
		return 
	end

	if Core_IsPlayerEliminated(victim) and Player_ObserveRelationship(victim, localPlayer.id) ~= R_ALLY then
		_mod.objective_meet = _mod.objective_meet + 1
		Obj_SetCounterCount(_mod.objective, _mod.objective_meet)
		Obj_SetProgress(_mod.objective, _mod.objective_meet / _mod.objective_requirement)
		if _mod.objective_meet==_mod.objective_requirement then
			Core_SetPlayerVictorious(localPlayer.id, Mod_WinnerPresentation, WR_CONQUEST)		
			Core_OnGameOver()
		end				

		return  
	end

	if victim ~= localPlayer.id and Player_ObserveRelationship(victim, localPlayer.id) ~= R_ALLY then
		_mod.objective_meet = _mod.objective_meet + 1
		Obj_SetCounterCount(_mod.objective, _mod.objective_meet)
		Obj_SetProgress(_mod.objective, _mod.objective_meet / _mod.objective_requirement)
		if _mod.objective_meet==_mod.objective_requirement then
			Core_SetPlayerVictorious(localPlayer.id, Mod_WinnerPresentation, WR_CONQUEST)		
			Core_OnGameOver()
		end
	end

	--Set player to eliminated when keep is destroyed
	if not AGS_GLOBAL_SETTINGS.EliminatedLoseKeep then
		Mod_EliminatePlayerUnits(victim, nil, false)
		Core_SetPlayerDefeated(victim, Mod_LoserPresentation, WR_CONQUEST)
		World_KillPlayer(victim, KPR_Lost)
		Surrender_CheckVictory(victim)
	end
end

-- Lobby Option - Remove Gaia
function Mod_RemoveGaia()
	if _mod.options.economy_section and
		_mod.options.economy_section.nogaia then
		local egroup = EGroup_CreateUnique()
		World_GetAllNeutralEntities(egroup)
		EGroup_Filter(egroup, "animal", FILTER_KEEP)
		EGroup_DestroyAllEntities(egroup)    		
		EGroup_Destroy(egroup)
	end
end

-- Lobby Option: Setup Starting Resources
function Mod_setStartingResources()
	
	for i, player in pairs(PLAYERS) do
		-- Set player starting resources
		-- RT stands for Resource Type
		if _mod.startingResources == "standard" then
			Player_SetResource(player.id, RT_Food, 10000)		
			Player_SetResource(player.id, RT_Wood, 7500)
			Player_SetResource(player.id, RT_Gold, 1000)
			Player_SetResource(player.id, RT_Stone, 5000)
		elseif _mod.startingResources == "high" then
			Player_SetResource(player.id, RT_Food, 30000)		
			Player_SetResource(player.id, RT_Wood, 25000)
			Player_SetResource(player.id, RT_Gold, 10000)
			Player_SetResource(player.id, RT_Stone, 10000)
		elseif _mod.startingResources == "max" then
			Player_SetResource(player.id, RT_Food, 100000)		
			Player_SetResource(player.id, RT_Wood, 100000)
			Player_SetResource(player.id, RT_Gold, 100000)
			Player_SetResource(player.id, RT_Stone, 100000)

		end
	end
end

-- Lobby Option - Setup the Fog of War
function Mod_SetFOW()
	if (_mod.options.economy_section and _mod.options.economy_section.option_fow) then
		if (_mod.options.economy_section.option_fow.enum_value == _mod.options.economy_section.option_fow.enum_items.option_fow_explore) then 
			FOW_ExploreAll()
		elseif (_mod.options.economy_section.option_fow.enum_value == _mod.options.economy_section.option_fow.enum_items.option_fow_reveal) then
			FOW_ForceRevealAllUnblockedAreas()
		end
	end
end

-- This function creates the objective UI: Eliminate all Castles
function Mod_SetupObjective()
	
	-- Objective: Eliminate Enemey Keeps
	if _mod.objective == nil then        -- Check if an objective has not been created yet
		
		-- Create and store objective in the global table created at the start of this script
		_mod.objective = Obj_Create(localPlayer.id, _mod.objective_title, Loc_Empty(), "icons\\races\\common\\victory_conditions\\victory_condition_conquest", "ConquestObjectiveTemplate", localPlayer.raceName, OT_Primary, 0, "conquestObj")		
		
		
		
		_mod.objective_requirement = 0	
		_mod.objective_meet = 0	
		
		for _, player in pairs(PLAYERS) do
			if Player_ObserveRelationship(player.id, localPlayer.id) == R_ALLY then
				-- nothing 
			else
				_mod.objective_requirement = _mod.objective_requirement + 1 
			end
		end
		
		-- Sets the objective's state to incomplete
		Obj_SetState(_mod.objective, OS_Incomplete)
		-- Sets the objective to visible so players can see it
		Obj_SetVisible(_mod.objective, true)
		-- Sets the progress element of the objective to visible so players can see it
		Obj_SetProgressVisible(_mod.objective, true)		
		-- Sets the objective progress type to a counter
		Obj_SetCounterType(_mod.objective, COUNTER_CountUpTo)
		-- Set the starting objective progress to 1 because we spawn a House for the player in Mod_SpawnBuilding()
		Obj_SetCounterCount(_mod.objective, 0)
		-- Set the maximum objective progress
		Obj_SetCounterMax(_mod.objective, _mod.objective_requirement)
		-- Set the objective progress bar percentage value
		Obj_SetProgress(_mod.objective, 0)
		
	end

end

-- This function finds the starting Keeps for all players in the match, reveals it to all other players
function Mod_FindKeep()
	
	-- This is a for loop that does something for each player in the match.
	-- PLAYERS is a table that contains all of the players in the match.
	-- If there are two players it will run twice, if there are eight players it will run eight times, etc.
	for i, player in pairs(PLAYERS) do
		
		-- Get the player's entities and place them into an ENTITY GROUP
		local eg_player_entities = Player_GetEntities(player.id)
		
		-- Filter out everything in the ENTITY GROUP except for the Town Center
		EGroup_Filter(eg_player_entities, "castle", FILTER_KEEP)
		
		-- Get the Town Center ENTITY by getting the first entry in the ENTITY GROUP we just filtered
		local entity =  EGroup_GetEntityAt(eg_player_entities, 1)
		
		-- entity.init = true
		
		-- Get the Town Center's ENTITY ID
		-- Some functions require the ENTITY ID to perform an action on the ENTITY
		local entity_id = Entity_GetID(entity) 
		-- Get the Town Center's position
		local position = Entity_GetPosition(entity)
		
		_mod.castles[entity_id] = entity
		
		-- Store the player's Town Center information so it can be referenced later
		player.keep = {
			entity = entity,
			entity_id = entity_id,
			position = position,
		}
		
		
		-- Extra options
		FOW_RevealArea(player.keep.position, 80, 5) -- Reveal all Starting Locations
		Entity_RemoveAbility(entity, BP_GetAbilityBlueprint("core_building_scuttle")) -- Disable Scuttle for 'Castle'
		Player_SetStateModelBool(player.id, "disable_landmark_rebuild", true) -- Landmarks die outright, no downed/ruin state repair
		
		--Modifier_ApplyToEntity(Modifier_Create(MAT_Entity, "production_speed_modifier", MUT_Multiplication, false, 20, nil), player.keep.entity, 0.0)
		
	end
end

function Mod_ConfigureKeepAsCapitalAgeProducer(player, keep_ent, ghost_ent, source_tag)
	if player == nil or player.id == nil or keep_ent == nil or ghost_ent == nil then
		return
	end

	local function _KeepCap_GetSpecialUpgradeList(player_civ)
		local cfg = _AUTOAGE_SPECIAL_UPGRADES and _AUTOAGE_SPECIAL_UPGRADES[player_civ]
		if cfg == nil then
			return nil
		end
		local out = {}
		for _, upg in ipairs(cfg.feudal or {}) do table.insert(out, upg) end
		for _, upg in ipairs(cfg.castle or {}) do table.insert(out, upg) end
		for _, upg in ipairs(cfg.imperial or {}) do table.insert(out, upg) end
		return out
	end

	local KEEP_CAP_SPECIAL_UPGRADE_PBG = {
		upgrade_age_dark_com_1_tem = 5000201,
		upgrade_age_dark_com_2_tem = 5000202,
		upgrade_age_dark_com_3_tem = 5000203,
		upgrade_age_feudal_com_1_tem = 5000206,
		upgrade_age_feudal_com_2_tem = 5000207,
		upgrade_age_feudal_com_3_tem = 5000208,
		upgrade_age_castle_com_1_tem = 5000210,
		upgrade_age_castle_com_2_tem = 5000211,
		upgrade_age_castle_com_3_tem = 5000212,
		upgrade_tent_dark_1_khan_mon_ha_gol = 9001446,
		upgrade_tent_dark_2_cart_mon_ha_gol = 9001447,
		upgrade_tent_feudal_1_pasture_mon_ha_gol = 9001610,
		upgrade_tent_feudal_2_relics_mon_ha_gol = 9001611,
		upgrade_tent_castle_1_tribute_mon_ha_gol = 9001612,
		upgrade_tent_castle_2_batch_production_mon_ha_gol = 9001613,
	}

	local function _KeepCap_ResolveAgeUpAbility(upg_name)
		if type(upg_name) ~= "string" or upg_name == "" then
			return nil, nil, "invalid_upgrade_name"
		end

		local pbg = KEEP_CAP_SPECIAL_UPGRADE_PBG[upg_name]
		if pbg ~= nil then
			local ok_pbg, abp_pbg = pcall(BP_GetAbilityBlueprintByPbgID, pbg)
			if ok_pbg and abp_pbg ~= nil then
				return abp_pbg, string.format("pbg:%d", pbg), "pbg"
			end
		end

		local stripped = string.gsub(upg_name, "^upgrade_", "")
		local explicit = {
			upg_name,
			stripped,
			"research_" .. upg_name,
			"research_" .. stripped,
			"ability_" .. upg_name,
			"ability_" .. stripped,
			"age_up_" .. upg_name,
			"age_up_" .. stripped,
		}

		local seen = {}
		local candidates = {}
		for _, candidate in ipairs(explicit) do
			if candidate ~= nil and candidate ~= "" and not seen[candidate] then
				seen[candidate] = true
				table.insert(candidates, candidate)
			end
		end

		local candidate_count = #candidates

		for _, candidate in ipairs(candidates) do
			if candidate ~= nil and candidate ~= "" then
				local ok_bp, abp = pcall(BP_GetAbilityBlueprint, candidate)
				if ok_bp and abp ~= nil then
					return abp, candidate, "name"
				end
			end
		end

		return nil, nil, string.format("no_match/%d_candidates", candidate_count)
	end

	local function _KeepCap_InjectAgeUpAbilities(player_obj, player_civ, keep_entity, tag)
		local upgrades = _KeepCap_GetSpecialUpgradeList(player_civ)
		if upgrades == nil or #upgrades == 0 then
			return
		end

		local unsupported_reason = {
			templar = "upgrade_driven_commandery",
			mongol_ha_gol = "upgrade_driven_tent",
		}

		local reason = unsupported_reason[player_civ]
		if reason ~= nil then
			Onslaught_LogKeepCap(string.format("[KEEP_CAP] %s: age-up ability inject skipped civ=%s keep=%d reason=%s upgrades=%d official_path=GE_UpgradeComplete(age_up_upgrade)",
				tostring(tag), tostring(player_civ), Entity_GetID(keep_entity), tostring(reason), #upgrades))
			return
		end

		local added = 0
		local present = 0
		local unresolved = 0
		local missing_upgrade_bp = 0
		local unresolved_ability_bp = 0
		local add_failed = 0
		for _, upg_name in ipairs(upgrades) do
			local ok_upg, upg_bp = pcall(BP_GetUpgradeBlueprint, upg_name)
			if not ok_upg or upg_bp == nil then
				missing_upgrade_bp = missing_upgrade_bp + 1
				print(string.format("[KEEP_CAP][WARN] %s: missing upgrade blueprint civ=%s upgrade=%s",
					tostring(tag), tostring(player_civ), tostring(upg_name)))
			end

			local abp, resolved_name, resolved_via = _KeepCap_ResolveAgeUpAbility(upg_name)
			if abp ~= nil then
				if Entity_HasAbility(keep_entity, abp) then
					present = present + 1
				else
					local ok_add = pcall(Entity_AddAbility, keep_entity, abp)
					if ok_add then
						added = added + 1
					else
						add_failed = add_failed + 1
						print(string.format("[KEEP_CAP][WARN] %s: failed add ability civ=%s upgrade=%s ability=%s",
							tostring(tag), tostring(player_civ), tostring(upg_name), tostring(resolved_name)))
					end
				end
			else
				unresolved = unresolved + 1
				unresolved_ability_bp = unresolved_ability_bp + 1
				print(string.format("[KEEP_CAP][WARN] %s: unresolved age-up ability civ=%s upgrade=%s reason=%s",
					tostring(tag), tostring(player_civ), tostring(upg_name), tostring(resolved_via)))
			end
		end

		Onslaught_LogKeepCap(string.format("[KEEP_CAP] %s: age-up ability inject civ=%s keep=%d added=%d present=%d unresolved=%d missing_upgrade_bp=%d unresolved_ability_bp=%d add_failed=%d",
			tostring(tag), tostring(player_civ), Entity_GetID(keep_entity), added, present, unresolved,
			missing_upgrade_bp, unresolved_ability_bp, add_failed))
	end

	local player_civ = player.raceName or Player_GetRaceName(player.id)
	if player_civ == "templar" then
		player.keep_age_producer = {
			mode = "templar_commandery",
			keep_id = Entity_GetID(keep_ent),
			proxy_id = Entity_GetID(ghost_ent),
		}
		Onslaught_LogKeepCap(string.format("[KEEP_CAP] %s: templar keep age producer mapped keep=%d proxy=%d",
			tostring(source_tag), Entity_GetID(keep_ent), Entity_GetID(ghost_ent)))
		_KeepCap_InjectAgeUpAbilities(player, player_civ, keep_ent, source_tag)
	elseif player_civ == "mongol_ha_gol" then
		player.keep_age_producer = {
			mode = "golden_tent",
			keep_id = Entity_GetID(keep_ent),
			proxy_id = Entity_GetID(ghost_ent),
			producer_ebp = "building_landmark_golden_tent_mon_ha_gol",
		}
		Onslaught_LogKeepCap(string.format("[KEEP_CAP] %s: golden horde keep age producer mapped keep=%d proxy=%d",
			tostring(source_tag), Entity_GetID(keep_ent), Entity_GetID(ghost_ent)))
		_KeepCap_InjectAgeUpAbilities(player, player_civ, keep_ent, source_tag)
	end
end

function Mod_EnsureKeepAsCapital(player, source_tag, opt_force_respawn)
	if player == nil then
		print("[KEEP_CAP] ERROR: Mod_EnsureKeepAsCapital called with nil player")
		return false
	end
	local pid_label = tostring(player.id)
	if not _mod.keep_as_capital then
		print(string.format("[KEEP_CAP] %s: skipped for player %s because _mod.keep_as_capital=false", tostring(source_tag), pid_label))
		return false
	end
	if player.keep == nil or player.keep.entity == nil then
		print(string.format("[KEEP_CAP] %s: ERROR player %s has no cached keep", tostring(source_tag), pid_label))
		return false
	end

	local player_civ = player.raceName or Player_GetRaceName(player.id)
	local keep_eid = Entity_GetID(player.keep.entity)
	Onslaught_LogKeepCap(string.format("[KEEP_CAP] %s: begin player=%s civ=%s keep=%d", tostring(source_tag), pid_label, tostring(player_civ), keep_eid))

	Player_SetStateModelFloat(player.id, "has_capital", 1)
	pcall(Entity_SetStateModelBool, player.keep.entity, "town_center_is_capital", true)

	local cap_ebp = AGS_GetCivilizationEntity(player_civ, AGS_BP_TC_CAPITAL)
	if cap_ebp == nil then
		print(string.format("[KEEP_CAP] %s: ERROR player=%s could not resolve %s", tostring(source_tag), pid_label, tostring(AGS_BP_TC_CAPITAL)))
		return false
	end

	Player_SetEntityProductionAvailability(player.id, cap_ebp, ITEM_LOCKED)
	Onslaught_LogKeepCap(string.format("[KEEP_CAP] %s: player=%s cap blueprint=%s", tostring(source_tag), pid_label, tostring(BP_GetName(cap_ebp))))

	local ghost_ent = nil
	local existing_ghost_id = player.ghost_capital_tc
	local existing_valid = existing_ghost_id ~= nil and Entity_IsValid(existing_ghost_id)
	local existing_alive = existing_valid and Entity_IsAlive(Entity_FromID(existing_ghost_id))

	if existing_alive and not opt_force_respawn then
		ghost_ent = Entity_FromID(existing_ghost_id)
		local keep_pos = Entity_GetPosition(player.keep.entity)
		if keep_pos ~= nil then
			local snapped_keep_pos = World_Pos(keep_pos.x, World_GetHeightAt(keep_pos.x, keep_pos.z), keep_pos.z)
			pcall(Entity_SetPosition, ghost_ent, snapped_keep_pos)
			pcall(Entity_SnapToGridAndGround, ghost_ent, false)
		end
		Onslaught_LogKeepCap(string.format("[KEEP_CAP] %s: reusing existing ghost TC eid=%d", tostring(source_tag), existing_ghost_id))
	else
		if existing_alive and opt_force_respawn then
			Onslaught_LogKeepCap(string.format("[KEEP_CAP] %s: destroying existing ghost TC eid=%d before respawn", tostring(source_tag), existing_ghost_id))
			pcall(Entity_Destroy, Entity_FromID(existing_ghost_id))
		end
		local ghost_pos = Entity_GetPosition(player.keep.entity)
		local eg_ghost = EGroup_CreateIfNotFound("eg_keep_cap_ghost_" .. pid_label)
		EGroup_Clear(eg_ghost)
		-- Co-op scenario parity: spawn buildings via Util_CreateEntities, not manual ForceConstruct.
		Util_CreateEntities(player.id, eg_ghost, cap_ebp, ghost_pos, 1, false, true, false, false)
		if EGroup_CountSpawned(eg_ghost) > 0 then
			ghost_ent = EGroup_GetEntityAt(eg_ghost, 1)
			Onslaught_LogKeepCap(string.format("[KEEP_CAP] %s: created ghost TC via Util_CreateEntities eid=%d at (%.1f, %.1f, %.1f)", tostring(source_tag), Entity_GetID(ghost_ent), ghost_pos.x, ghost_pos.y, ghost_pos.z))
		else
			-- Fallback keeps the path alive for diagnosis if Util_CreateEntities fails unexpectedly.
			ghost_ent = Entity_Create(cap_ebp, player.id, ghost_pos, true)
			Entity_Spawn(ghost_ent)
			Entity_SnapToGridAndGround(ghost_ent, false)
			Onslaught_LogKeepCap(string.format("[KEEP_CAP] %s: WARN Util_CreateEntities produced no spawn; fallback eid=%d", tostring(source_tag), Entity_GetID(ghost_ent)))
		end
	end

	Entity_VisHide(ghost_ent, true)
		Misc_SetEntitySelectable(ghost_ent, false)
	Entity_SetTargetingType(ghost_ent, Targeting_None)
	pcall(Entity_SetStateModelBool, ghost_ent, "town_center_is_capital", false)
	player.ghost_capital_tc = Entity_GetID(ghost_ent)
	Mod_ConfigureKeepAsCapitalAgeProducer(player, player.keep.entity, ghost_ent, source_tag)

	local keep_cap_ok, keep_cap = pcall(Entity_GetStateModelBool, player.keep.entity, "town_center_is_capital")
	local ghost_cap_ok, ghost_cap = pcall(Entity_GetStateModelBool, ghost_ent, "town_center_is_capital")
	local has_cap_ok, has_cap = pcall(Player_GetStateModelFloat, player.id, "has_capital")
	local ghost_is_tc_cap = Entity_IsOfType(ghost_ent, "town_center_capital")
	local ghost_is_tc = Entity_IsOfType(ghost_ent, "town_center")
	local build_progress = Entity_GetBuildingProgress(ghost_ent)
	Onslaught_LogKeepCap(string.format("[KEEP_CAP] %s: final player=%s has_capital=%s keep_capital=%s ghost=%d ghost_bp=%s ghost_is_tc_cap=%s ghost_is_tc=%s ghost_capital=%s alive=%s build_progress=%.3f",
		tostring(source_tag),
		pid_label,
		tostring(has_cap),
		tostring(keep_cap),
		Entity_GetID(ghost_ent),
		tostring(BP_GetName(Entity_GetBlueprint(ghost_ent))),
		tostring(ghost_is_tc_cap),
		tostring(ghost_is_tc),
		tostring(ghost_cap),
		tostring(Entity_IsAlive(ghost_ent)),
		build_progress))
	return true
end

function Debug_KeepAsCapitalStatus(opt_player_id)
	local player_id = opt_player_id or Game_GetLocalPlayer()
	local player = Core_GetPlayersTableEntry(player_id)
	if player == nil then
		print(string.format("[KEEP_CAP] STATUS ERROR: no player for id=%s", tostring(player_id)))
		return
	end
	local pid_label = tostring(player.id)
	local has_cap = Player_GetStateModelFloat(player.id, "has_capital")
	local keep_eid = (player.keep ~= nil and player.keep.entity ~= nil) and Entity_GetID(player.keep.entity) or -1
	local keep_cap = (player.keep ~= nil and player.keep.entity ~= nil) and Entity_GetStateModelBool(player.keep.entity, "town_center_is_capital") or false
	local ghost_id = player.ghost_capital_tc
	local ghost_valid = ghost_id ~= nil and Entity_IsValid(ghost_id)
	local ghost_handle = ghost_valid and Entity_FromID(ghost_id) or nil
	local ghost_alive = ghost_valid and Entity_IsAlive(ghost_handle)
	local ghost_bp = ghost_valid and BP_GetName(Entity_GetBlueprint(ghost_handle)) or "nil"
	local ghost_is_tc_cap = ghost_valid and Entity_IsOfType(ghost_handle, "town_center_capital") or false
	local ghost_is_tc = ghost_valid and Entity_IsOfType(ghost_handle, "town_center") or false
	print(string.format("[KEEP_CAP] STATUS player=%s civ=%s keep_as_capital=%s has_capital=%s keep=%d keep_capital=%s ghost_valid=%s ghost_alive=%s ghost_id=%s ghost_bp=%s ghost_is_tc_cap=%s ghost_is_tc=%s",
		pid_label,
		tostring(player.raceName),
		tostring(_mod.keep_as_capital),
		tostring(has_cap),
		keep_eid,
		tostring(keep_cap),
		tostring(ghost_valid),
		tostring(ghost_alive),
		tostring(ghost_id),
		tostring(ghost_bp),
		tostring(ghost_is_tc_cap),
		tostring(ghost_is_tc)))
end

function Debug_KeepAsCapitalApply(opt_player_id, opt_force_respawn)
	local player_id = opt_player_id or Game_GetLocalPlayer()
	local player = Core_GetPlayersTableEntry(player_id)
	if player == nil then
		print(string.format("[KEEP_CAP] APPLY ERROR: no player for id=%s", tostring(player_id)))
		return
	end
	Mod_EnsureKeepAsCapital(player, "Debug_KeepAsCapitalApply", opt_force_respawn == true)
	Debug_KeepAsCapitalStatus(player_id)
end

-----------------------------------------------------------------------
-- Win/Lose Presentation Functions
-----------------------------------------------------------------------

function Mod_WinnerPresentation(playerID)
	
	-- If player is local
	if playerID == localPlayer.id then
		
		-- Clear player's selection
		Misc_ClearSelection()
		-- Hide UI
		Taskbar_SetVisibility(false)		
		-- Set Win Condition Objective to complete
		Obj_SetState(_mod.objective, OS_Complete)

		-- Trigger objective complete pop up
		Obj_CreatePopup(_mod.objective, _mod.objective_title, "")
		-- Play Victory sfx
		Music_PlayStinger(MUS_STING_PRIMARY_OBJ_COMPLETE)
		-- Set objective to invisible
		Obj_SetVisible(_mod.objective, false)
		
		-- Create Victory Stinger (guarded: only one endgame presentation per match)
		Onslaught_TryQueueGameOver(
			GAMEOVER_OBJECTIVE_TIME, { 
			_playerID = playerID, 
			_icon = _mod.icons.objective, 
			_endType = Loc_GetString(11161277), 					-- "VICTORY"  
			_message = Loc_Empty(),
			_sound = "mus_stinger_landmark_objective_complete_success", 
			_videoURI = "stinger_victory" 
		})
	end
end

function Mod_LoserPresentation(playerID)
	
	-- If player is local
	if playerID == localPlayer.id then
		
		-- Clear player's selection
		Misc_ClearSelection()
		-- Hide UI
		Taskbar_SetVisibility(false)		
		-- Set Win Condition Objective to failed
		Obj_SetState(_mod.objective, OS_Failed)

		-- Trigger objective complete pop up
		Obj_CreatePopup(_mod.objective, _mod.objective_title, "")
		-- Play Victory sfx
		Music_PlayStinger(MUS_STING_PRIMARY_OBJ_FAIL)
		-- Set objective to invisible
		Obj_SetVisible(_mod.objective, false)

		-- Create Defeat Stinger (guarded: only one endgame presentation per match)
		Onslaught_TryQueueGameOver(
			GAMEOVER_OBJECTIVE_TIME, {
			_playerID = playerID, 
			_icon = _mod.icons.objective, 
			_endType = Loc_GetString(11045235), 					-- "DEFEAT"  
			_message = Loc_Empty(),
			_sound = "mus_stinger_landmark_objective_complete_fail", 
			_videoURI = "stinger_defeat"})
	end
end

