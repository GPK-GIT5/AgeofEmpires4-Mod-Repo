		["unit_monk_buddhist_"] = { policy = "destroy" },
		["unit_monk_shinto_"] = { policy = "destroy" },
		["unit_monk_ikko_"] = { policy = "destroy" },
	},

	-- === Lancaster: no archer/horseman/manatarms/crossbowman; use yeoman/hobelar/earlsguard ===
	lancaster = {
		["unit_archer_"] = { target = "unit_yeoman_", default_tier = 2 },
		["unit_horseman_"] = { target = "unit_hobelar_", default_tier = 2 },
		["unit_knight_"] = { target = "unit_hobelar_", default_tier = 3 },
		["unit_manatarms_"] = { target = "unit_earlsguard_", default_tier = 3 },
		["unit_crossbowman_"] = { target = "unit_yeoman_", default_tier = 3 },
		-- Siege: all variants map to springald (provisional catch-all)
		["unit_springald_"] = { target = "unit_siege_springald_3_lan", full_name = true },
		["unit_mangonel_"] = { target = "unit_siege_springald_3_lan", full_name = true },
		["unit_bombard_"] = { target = "unit_siege_springald_3_lan", full_name = true },
		["unit_trebuchet_"] = { target = "unit_siege_springald_3_lan", full_name = true },
		["unit_culverin_"] = { target = "unit_siege_springald_3_lan", full_name = true },
		["unit_ribauldequin_"] = { target = "unit_siege_springald_3_lan", full_name = true },
		["unit_ram_"] = { target = "unit_siege_springald_3_lan", full_name = true },
		["unit_siege_tower_"] = { target = "unit_siege_springald_3_lan", full_name = true },
	},

	-- === HRE: monk at tier 1 (Prelate) ===
	hre = {
		["unit_monk_"] = { target = "unit_monk_", default_tier = 1 },
	},
	hre_ha_01 = {
		["unit_monk_"] = { target = "unit_monk_", default_tier = 1 },
	},

	-- === Byzantine: monk at tier 2 ===
	byzantine = {
		["unit_monk_"] = { target = "unit_monk_", default_tier = 2 },
	},
	byzantine_ha_mac = {
		["unit_monk_"] = { target = "unit_monk_", default_tier = 2 },
	},

	-- === Sultanate: monk at tier 2 (Scholar) ===
	sultanate = {
		["unit_monk_"] = { target = "unit_monk_", default_tier = 2 },
	},
	sultanate_ha_tug = {
		["unit_monk_"] = { target = "unit_monk_", default_tier = 2 },
	},

	-- === Malian: no knight/manatarms/crossbowman; use role equivalents ===
	malian = {
		["unit_knight_"] = { target = "unit_horseman_", default_tier = 3 },
		["unit_manatarms_"] = { target = "unit_gbeto_", default_tier = 3 },
		["unit_crossbowman_"] = { target = "unit_javelin_", default_tier = 3 },
	},

	-- === Templar: no knight/bombard/culverin/ribauldequin ===
	templar = {
		["unit_knight_"] = { target = "unit_horseman_", default_tier = 3 },
		["unit_bombard_"] = { target = "unit_trebuchet_4_cw_tem", full_name = true },
		["unit_culverin_"] = { target = "unit_springald_", default_tier = 3 },
		["unit_ribauldequin_"] = { target = "unit_mangonel_", default_tier = 3 },
	},

	-- === Chinese: no standard ribauldequin, archer, or manatarms; remap ===
	chinese = {
		["unit_ribauldequin_"] = { target = "unit_nest_of_bees_", default_tier = 4 },
		["unit_archer_"] = { target = "unit_zhuge_nu_", default_tier = 3 },
		["unit_manatarms_"] = { target = "unit_palace_guard_", default_tier = 3 },
	},
	chinese_ha_01 = {
		["unit_ribauldequin_"] = { target = "unit_nest_of_bees_", default_tier = 4 },
		["unit_archer_"] = { target = "unit_zhuge_nu_", default_tier = 3 },
		["unit_manatarms_"] = { target = "unit_palace_guard_", default_tier = 3 },
	},

	-- === Abbasid HA: no HA monk BP; remap to base Abbasid imam ===
	abbasid_ha_01 = {
		["unit_monk_"] = { target = "unit_monk_3_abb", full_name = true },
	},

	-- === Mongol ha_gol: advanced siege variants ===
	mongol_ha_gol = {
		["unit_trebuchet_"] = { target = "unit_mangonel_", default_tier = 3 },
		["unit_culverin_"] = { target = "unit_bombard_", default_tier = 4 },
