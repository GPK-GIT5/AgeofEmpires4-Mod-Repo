}

-- Returns true if the squad BP matches a civ-unique prefix that has an explicit
-- fallback rule in _LEAVER_CIV_UNIQUE_FALLBACK.
function _Leaver_IsCivUniqueFallbackCandidate(sbp_name)
	if sbp_name == nil then return false end
	for _, entry in ipairs(_LEAVER_CIV_UNIQUE_FALLBACK) do
		if string.sub(sbp_name, 1, #entry.prefix) == entry.prefix then
			return true
		end
	end
	return false
end

-- Returns the policy string ("destroy" or "archetype") for a matched civ-unique
-- BP prefix, or nil if the BP is not in the policy table.
function _Leaver_GetCivUniquePolicy(sbp_name)
	if sbp_name == nil then return nil end
	for _, entry in ipairs(_LEAVER_CIV_UNIQUE_FALLBACK) do
		if string.sub(sbp_name, 1, #entry.prefix) == entry.prefix then
			return entry.policy or "archetype"
		end
	end
	return nil
end

-- Transfer-only classifier for non-military squads that should never go through
-- military civ-swap/fallback logic.
function _Leaver_IsNeutralOrTransferOnlySquad(squad, sbp_name)
	if sbp_name == nil then return false, nil end
	-- Only explicit neutral blueprint families are transfer-only.
	-- Do not use World_OwnsSquad here: leaver teardown can transiently world-own
	-- normal military squads that still need full military resolve/fallback/gating.
	if string.sub(sbp_name, 1, 5) == "gaia_" then return true, "neutral_gaia" end
	if string.find(sbp_name, "herdable") then return true, "neutral_herdable" end
	return false, nil
end

-- Receiver-side class fallback: resolves units that fail suffix-swap via class-based remapping.
-- Checks _LEAVER_RECEIVER_CLASS_MAP for receiver-specific remaps, or generic class defaults.
-- Returns (sbp, ratio) on success, (nil, nil) on failure/destroy-policy.
function _ResolveReceiverClassFallback(sbp_name, rcv_civ)
	if sbp_name == nil or rcv_civ == nil then return nil, nil end

	local rcv_prefix = AGS_CIV_PREFIXES[rcv_civ]
	if rcv_prefix == nil then return nil, nil end
	local rcv_suffix = string.sub(rcv_prefix, 1, -2)

	-- Get the role/prefix of the source unit
	local role = _Leaver_GetUnitRole(sbp_name)
	if role == nil then return nil, nil end -- Unknown role, destroy

	-- Check for receiver-specific override in _LEAVER_RECEIVER_CLASS_MAP
	local rcv_map = _LEAVER_RECEIVER_CLASS_MAP[rcv_civ]
	if rcv_map ~= nil then
		local entry = rcv_map[role]
		if entry ~= nil then
			if entry.policy == "destroy" then
				return nil, nil, "destroy" -- Explicit destroy policy
			elseif entry.full_name == true then
				-- Direct full BP name (e.g., Lancaster siege catch-all)
				local ok, sbp = pcall(BP_GetSquadBlueprint, entry.target)
				if ok and sbp ~= nil then
					return sbp, 1.0
				end
				return nil, nil
			elseif entry.target ~= nil then
				-- Try tier and default tier
				local tier_str = string.sub(sbp_name, -2, -2)
				local tier = tonumber(tier_str)
				if tier ~= nil then
					local target_name = entry.target .. tostring(tier) .. "_" .. rcv_suffix
					local ok, sbp = pcall(BP_GetSquadBlueprint, target_name)
					if ok and sbp ~= nil then return sbp, 1.0 end
				end
				-- Try default tier
				if entry.default_tier ~= nil then
					local target_name = entry.target .. tostring(entry.default_tier) .. "_" .. rcv_suffix
					local ok, sbp = pcall(BP_GetSquadBlueprint, target_name)
					if ok and sbp ~= nil then return sbp, 1.0 end
				end
			end
		end
	end

	-- No receiver-specific entry found
	return nil, nil
end

---------------------------------------------------------------------------------------------------
-- Canonical role → universal archetype mapping for generic fallback.
-- Maps every role prefix from _LEAVER_UNIT_ROLE_MAP to its most universal standard equivalent.
---------------------------------------------------------------------------------------------------
_LEAVER_CANONICAL_ROLE = {
	["unit_spearman_"]       = "unit_spearman_",
	["unit_manatarms_"]      = "unit_manatarms_",
	["unit_landsknecht_"]    = "unit_manatarms_",
	["unit_archer_"]         = "unit_archer_",
	["unit_crossbowman_"]    = "unit_crossbowman_",
	["unit_handcannoneer_"]  = "unit_handcannoneer_",
	["unit_handcannon_"]     = "unit_handcannoneer_",
	["unit_horseman_"]       = "unit_horseman_",
	["unit_knight_"]         = "unit_knight_",
	["unit_sipahi_"]         = "unit_knight_",
	["unit_camel_rider_"]    = "unit_horseman_",
	["unit_monk_"]           = "unit_monk_",
	["unit_monk_buddhist_"]  = "unit_monk_",
	["unit_monk_shinto_"]    = "unit_monk_",
	["unit_monk_ikko_"]      = "unit_monk_",
	["unit_springald_"]      = "unit_springald_",
	["unit_mangonel_"]       = "unit_mangonel_",
	["unit_bombard_"]        = "unit_bombard_",
	["unit_trebuchet_"]      = "unit_trebuchet_",
	["unit_culverin_"]       = "unit_culverin_",
	["unit_ribauldequin_"]   = "unit_mangonel_",
	["unit_ram_"]            = "unit_ram_",
	["unit_siege_tower_"]    = "unit_siege_tower_",
	["unit_siege_"]          = "unit_springald_",
}

-- Generic archetype fallback: resolves any military unit to its role-based generic
-- equivalent for the receiver civ. Tries source tier first, then common tiers.
-- Returns (sbp, ratio) on success, (nil, nil) if no valid BP found.
function _ResolveGenericArchetypeFallback(sbp_name, rcv_civ)
	local rcv_suffix = _Leaver_GetMilitarySuffix(rcv_civ)
	if rcv_suffix == nil then return nil, nil end

	local role = _Leaver_GetUnitRole(sbp_name)
	if role == nil then return nil, nil end

	local canonical = _LEAVER_CANONICAL_ROLE[role] or role

	-- Extract tier digit after role prefix
	local after_role = string.sub(sbp_name, #role + 1)
	local tier = tonumber(string.sub(after_role, 1, 1))

	-- Build candidate list: source tier first, then common fallback tiers
	local tried = {}
	local tiers = {}
	if tier ~= nil then table.insert(tiers, tier); tried[tier] = true end
	for _, t in ipairs({3, 2, 4, 1}) do
		if not tried[t] then table.insert(tiers, t); tried[t] = true end
	end

	for _, try_tier in ipairs(tiers) do
		local target = canonical .. tostring(try_tier) .. "_" .. rcv_suffix
		local ok, sbp = pcall(BP_GetSquadBlueprint, target)
		if ok and sbp ~= nil then return sbp, 1.0 end
	end

	return nil, nil
end

-- Reverse-map lookup with variant normalization for civ sub-variants.
-- Example: building_resource_farm_fre_ha_01 -> building_resource_farm_fre
function _Leaver_GetReverseMapKey(bp_name)
	if bp_name == nil then return nil, nil end
	local direct = _BLUEPRINT_REVERSE_MAP[bp_name]
	if direct ~= nil then return direct, bp_name end

	local candidates = {}
	local stripped_ha = string.gsub(bp_name, "_ha_[%w]+$", "")
	if stripped_ha ~= bp_name then table.insert(candidates, stripped_ha) end
	local stripped_variant = string.gsub(bp_name, "_variant_[%w]+$", "")
	if stripped_variant ~= bp_name and stripped_variant ~= stripped_ha then
		table.insert(candidates, stripped_variant)
	end

	for _, candidate in ipairs(candidates) do
		local key = _BLUEPRINT_REVERSE_MAP[candidate]
		if key ~= nil then return key, candidate end
	end
	return nil, nil
end

-- Resolves a civ-unique unit to the receiver civ's closest standard equivalent.
-- Returns (replacement_sbp, ratio) or (nil, nil) if no fallback applies.
function _ResolveFallbackSquadBP(sbp_name, rcv_civ)
	local rcv_suffix = _Leaver_GetMilitarySuffix(rcv_civ)
	if rcv_suffix == nil then return nil, nil end

	for _, entry in ipairs(_LEAVER_CIV_UNIQUE_FALLBACK) do
		if string.sub(sbp_name, 1, #entry.prefix) == entry.prefix then
			-- Destroy-policy entries have no archetype target
			if entry.target == nil then return nil, nil end
			-- Extract age tier digit from source BP (e.g., "unit_gbeto_3_mal" → "3")
			local tier_str = string.sub(sbp_name, #entry.prefix + 1, #entry.prefix + 1)
			local tier = tonumber(tier_str) or entry.default_tier
			local target_name = entry.target .. tostring(tier) .. "_" .. rcv_suffix
			local ok, sbp = pcall(BP_GetSquadBlueprint, target_name)
			if ok and sbp ~= nil then
				return sbp, entry.ratio
			end
			-- Tier unavailable — try default tier
			if tier ~= entry.default_tier then
				target_name = entry.target .. tostring(entry.default_tier) .. "_" .. rcv_suffix
				ok, sbp = pcall(BP_GetSquadBlueprint, target_name)
				if ok and sbp ~= nil then
					return sbp, entry.ratio
				end
			end
			return nil, nil
		end
	end
	return nil, nil
end

-- Resolves a military squad's receiver-civ equivalent blueprint by swapping
-- the civ suffix in the BP name using AGS_CIV_PREFIXES, with tier-bump fallback.
-- Tier-bump: if exact swap fails and source has a numeric tier < 4, try tier+1/+2.
-- Returns resolved SBP or nil if not resolvable (civ-unique unit).
function _ResolveMilitarySquadBP(sbp_name, src_civ, rcv_civ)
	local src_suffix = _Leaver_GetMilitarySuffix(src_civ)
	local rcv_suffix = _Leaver_GetMilitarySuffix(rcv_civ)
	if src_suffix == nil or rcv_suffix == nil then return nil end
	-- Check if BP name ends with the source civ suffix
	local suffix_pos = #sbp_name - #src_suffix + 1
	if suffix_pos < 1 then return nil end
	if string.sub(sbp_name, suffix_pos) ~= src_suffix then return nil end
	-- Swap suffix and validate
	local new_name = string.sub(sbp_name, 1, suffix_pos - 1) .. rcv_suffix
	local ok, sbp = pcall(BP_GetSquadBlueprint, new_name)
	if ok and sbp ~= nil then return sbp, "direct" end
	
	-- Tier-bump fallback: try tier+1 and tier+2 if exact swap failed.
	-- Extract tier digit at suffix_pos - 2 (position just before the `_` before suffix).
	if suffix_pos >= 2 then
		local tier_char = string.sub(sbp_name, suffix_pos - 2, suffix_pos - 2)
		local tier = tonumber(tier_char)
		if tier ~= nil and tier < 4 then
			-- Reconstruct with bumped tier(s)
			local base = string.sub(sbp_name, 1, suffix_pos - 3)
			for bump_tier = tier + 1, 4 do
				local bumped_name = base .. tostring(bump_tier) .. "_" .. rcv_suffix
				local ok_bump, sbp_bump = pcall(BP_GetSquadBlueprint, bumped_name)
				if ok_bump and sbp_bump ~= nil then
					return sbp_bump, "tier_bump"
				end
			end
		end
	end
	
	return nil
end

-- Resolves the military conversion route for a squad BP through the full fallback stack.
-- Returns a table: { route, to_sbp, ratio, bp_name } describing how to handle the squad.
-- Route names: "same_bp", "direct", "tier_bump", "civ_unique_archetype",
--   "receiver_class", "generic_archetype", "destroy_policy", "destroy_no_mapping"
function _ResolveMilitaryRoute(sbp_name, src_civ, rcv_civ)
	-- Tier 1+2: Direct suffix swap + tier bump
	local to_sbp, swap_route = _ResolveMilitarySquadBP(sbp_name, src_civ, rcv_civ)
	if to_sbp ~= nil then
		local to_name = BP_GetName(to_sbp)
		if to_name == sbp_name then
			return { route = "same_bp", to_sbp = to_sbp, ratio = 1.0, bp_name = to_name }
		end
		return { route = swap_route or "direct", to_sbp = to_sbp, ratio = 1.0, bp_name = to_name }
	end

	-- Tier 3: Civ-unique archetype fallback
	local unique_policy = _Leaver_GetCivUniquePolicy(sbp_name)
	if unique_policy == "destroy" then
		return { route = "destroy_policy" }
	end
	local unique_ratio = 1.0
	if unique_policy == "archetype" then
		local fb_sbp, fb_ratio = _ResolveFallbackSquadBP(sbp_name, rcv_civ)
		if fb_sbp ~= nil then
			return { route = "civ_unique_archetype", to_sbp = fb_sbp, ratio = fb_ratio or 1.0, bp_name = BP_GetName(fb_sbp) }
		end
		-- Civ-unique archetype BP doesn't exist for receiver: promote the archetype
		-- role so Tiers 4/5 resolve using the standard role instead of the unique prefix.
		-- E.g., samurai→manatarms, so malian's receiver-class can remap manatarms→gbeto.
		for _, entry in ipairs(_LEAVER_CIV_UNIQUE_FALLBACK) do
			if string.sub(sbp_name, 1, #entry.prefix) == entry.prefix and entry.target ~= nil then
				local tier_str = string.sub(sbp_name, #entry.prefix + 1, #entry.prefix + 1)
				local tier = tonumber(tier_str) or entry.default_tier or 3
				sbp_name = entry.target .. tostring(tier) .. "_archetype"
				unique_ratio = entry.ratio or 1.0
				break
			end
		end
	end

	-- Tier 4: Receiver-side class fallback
	local rcv_bp, rcv_ratio, rcv_policy = _ResolveReceiverClassFallback(sbp_name, rcv_civ)
	if rcv_policy == "destroy" then
		return { route = "destroy_policy" }
	end
	if rcv_bp ~= nil then
		return { route = "receiver_class", to_sbp = rcv_bp, ratio = (rcv_ratio or 1.0) * unique_ratio, bp_name = BP_GetName(rcv_bp) }
	end

	-- Tier 5: Generic archetype fallback
	local gen_sbp, gen_ratio = _ResolveGenericArchetypeFallback(sbp_name, rcv_civ)
	if gen_sbp ~= nil then
		return { route = "generic_archetype", to_sbp = gen_sbp, ratio = (gen_ratio or 1.0) * unique_ratio, bp_name = BP_GetName(gen_sbp) }
	end

	-- No resolution path found
	return { route = "destroy_no_mapping" }
end

-- Returns the best ally for receiving transferred assets.
-- Priority: Human allies over AI, then lowest population, then fewest prior absorptions.
function Mod_FindBestAlly(victim_id)
	local best = nil
	local best_pop = math.huge
	local best_absorb = math.huge
	local best_is_human = false
	for _, player in ipairs(PLAYERS) do
		if player.id ~= victim_id and not Core_IsPlayerEliminated(player.id)
			and Player_ObserveRelationship(player.id, victim_id) == R_ALLY then
			local pop = Player_GetCurrentPopulation(player.id, CT_Personnel)
			local absorb = player._leaver_absorb_count or 0
			local ok_h, is_human = pcall(Player_IsHuman, player.id)
			if not ok_h then is_human = false end
			-- Human beats AI unconditionally; among equal types use pop then absorb.
			local human_wins = is_human and not best_is_human
			local same_type = (is_human == best_is_human)
			local better_rank = same_type and (pop < best_pop or (pop == best_pop and absorb < best_absorb))
			if human_wins or better_rank then
				best = player
				best_pop = pop
				best_absorb = absorb
				best_is_human = is_human
			end
		end
	end
	return best
end

-- Returns true if recipient has capacity for one more production building.
function _Transfer_CanAcceptBuilding(recipient)
	local limit = CBA_Options_GetPlayerProdLimit(recipient)
	if limit == 0 then return true end
	return (recipient.obj_buildingLimit_count or 0) < limit
end

-- Returns true if recipient has capacity for one more outpost.
function _Transfer_CanAcceptOutpost(recipient)
	local op_max = CBA_Options_GetPlayerOutpostLimit(recipient)
	return (recipient.obj_buildingLimit_outpost_count or 0) < op_max
end

-- Returns true if recipient has capacity for one more workshop.
function _Transfer_CanAcceptWorkshop(recipient)
	if AGS_GLOBAL_SETTINGS.MaximumSiegeWorkshop == 0 then return true end
	local ws_max = CBA_Options_GetPlayerWorkshopLimit(recipient)
	return (recipient.obj_buildingLimit_workshop_count or 0) < ws_max
end

-- Categorizes a building entity for limit checking.
-- Returns: "production", "workshop", "outpost", "landmark", or "other"
function _Transfer_ClassifyBuilding(eid, owner_civ)
	local branch_civ = AGS_CIV_FACTION_MAP[owner_civ] or owner_civ
	-- Keep-as-Capital: a Keep with the capital state flag is treated as a town_center
	-- for classification purposes (population gate under auto-pop).
	if _mod.keep_as_capital and Entity_IsOfType(eid, "castle") then
		local ok, is_cap = pcall(Entity_GetStateModelBool, eid, "town_center_is_capital")
		if ok and is_cap then
			return "town_center"
		end
	end
	-- Population-increasing: Town Centers (regular, capital, TC-landmark, moving).
	-- Checked before landmarks so capital TCs are classified by population role.
	-- Explicitly enumerates all TC subtypes for robustness against type hierarchy variations.
	if Entity_IsOfType(eid, "town_center") or Entity_IsOfType(eid, "town_center_capital")
		or Entity_IsOfType(eid, "town_center_landmark") or Entity_IsOfType(eid, "town_center_moving") then
		return "town_center"
	end
	-- Landmarks (non-TC) handled separately in conversion
	if Entity_IsOfType(eid, "landmark") then
		return "landmark"
	end
	if Entity_IsOfType(eid, "scar_outpost") or Entity_IsOfType(eid, "stone_wall_tower") then
		return "outpost"
	end
	-- Population-increasing: Houses (regular and Mongol moving ger)
	if Entity_IsOfType(eid, "house") or Entity_IsOfType(eid, "house_moving") then
		return "house"
	end
	-- Workshop check (independent of production)
	if AGS_GLOBAL_SETTINGS.MaximumSiegeWorkshop ~= 0 and not AGS_GLOBAL_SETTINGS.NoSiege then
		local is_ws =
			(owner_civ == "chinese" and Entity_HasBlueprint(eid, EBP.CHINESE.BUILDING_LANDMARK_AGE2_CLOCKTOWER_CONTROL_CHI)) or
			(branch_civ == "french" and Entity_HasBlueprint(eid, EBP.FRENCH.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE)) or
			(owner_civ == "french_ha_01" and Entity_HasBlueprint(eid, EBP.FRENCH_HA_01.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE_HA_01)) or
			(branch_civ == "english" and Entity_IsOfType(eid, "scar_keep")) or
			Entity_IsOfType(eid, "scar_siegeworkshop")
		if is_ws then return "workshop" end
	end
	-- Production building check
	if (Entity_IsOfType(eid, "military_only_production") or Entity_IsOfType(eid, "military_production_building")) and not
		(Entity_IsOfType(eid, "military_school_ott")) then
		return "production"
	end
	return "other"
end

-- Finds any ally (not just "best") that can legally accept a building of the given class.
function _Transfer_FindLegalRecipient(victim_id, bld_class)
	for _, player in ipairs(PLAYERS) do
		if player.id ~= victim_id and not Core_IsPlayerEliminated(player.id)
			and Player_ObserveRelationship(player.id, victim_id) == R_ALLY then
			if bld_class == "production" and _Transfer_CanAcceptBuilding(player) then
				return player
			elseif bld_class == "workshop" and _Transfer_CanAcceptWorkshop(player) then
				return player
			elseif bld_class == "outpost" and _Transfer_CanAcceptOutpost(player) then
				return player
			elseif bld_class == "other" or bld_class == "landmark" or bld_class == "house" or bld_class == "town_center" then
				return player
			end
		end
	end
	return nil
end

-- Transfers a single building entity to recipient, cancels production queue.
function _Transfer_BuildingToPlayer(eid, recipient)
	if eid == nil or recipient == nil or recipient.id == nil then
		return false
	end
	if not Entity_IsAlive(eid) then
		return false
	end
	local ok_has_q, has_q = pcall(Entity_HasProductionQueue, eid)
	if ok_has_q and has_q then
		local ok_qc, qc = pcall(Entity_GetProductionQueueSize, eid)
		if ok_qc and type(qc) == "number" then
			for q = qc, 1, -1 do
				pcall(Entity_CancelProductionQueueItem, eid, q - 1)
			end
		end
	end
	local ok_set = pcall(Entity_SetPlayerOwner, eid, recipient.id)
	return ok_set
end

---------------------------------------------------------------------------------------------------
-- Phase 1: Resource Transfer
---------------------------------------------------------------------------------------------------
function _Transfer_Resources(victim_id, recipient)
	for _, rt in ipairs(_LEAVER_RESOURCE_TYPES) do
		local amount = Player_GetResource(victim_id, rt)
		if amount > 0 then
			Player_AddResource(recipient.id, rt, amount)
			Player_SetResource(victim_id, rt, 0)
		end
	end
end

---------------------------------------------------------------------------------------------------
-- Phase 2: Garrison Ejection (Entity_UnloadAllFromHold — official Relic pattern)
---------------------------------------------------------------------------------------------------
function _Transfer_EjectGarrisons(victim_id)
	local eg = Player_GetEntities(victim_id)
	local count = EGroup_Count(eg)
	for idx = 1, count do
		local ent = EGroup_GetEntityAt(eg, idx)
		if ent ~= nil then
			pcall(Entity_UnloadAllFromHold, ent)
		end
	end
end

---------------------------------------------------------------------------------------------------
-- Phase 3: Building Conversion (delete+respawn with heading/health preservation)
---------------------------------------------------------------------------------------------------

-- Convert a single building entity to the recipient's faction equivalent.
-- Returns: "converted", "transferred", "killed", or "skipped_dead"
function _Convert_Building(eid, recipient, receiver_civ, source_civ, stats, source_player_id)
	if not Entity_IsAlive(eid) then
		local audit = {bp = "<dead_entity>", decision = "SKIPPED_DEAD_BUILDING", receiver = receiver_civ}
		table.insert(_LEAVER_AUDIT_LOG, audit)
		if _LEAVER_DEBUG_VERBOSE then
			print("[LEAVER_BLDG] skipped dead entity from snapshot")
		end
		return "skipped_dead"
	end

	local bp = Entity_GetBlueprint(eid)
	local bp_name = BP_GetName(bp)

	-- Walls, palisades, defense towers, and keeps: ALWAYS transfer-only regardless of AGS mapping.
	-- These can transiently appear ownerless during defeat teardown, so handle before owner lookups.
	if string.find(bp_name, "defense_wall") or string.find(bp_name, "palisade") or string.find(bp_name, "defense_tower") or string.find(bp_name, "defense_keep") then
		if _LEAVER_DEBUG_VERBOSE then
			print(string.format("[LEAVER_XFER] %s | wall/defense transfer (no create) | bldg_wall", bp_name))
		end
		if _Transfer_BuildingToPlayer(eid, recipient) then
			return "transferred"
		end
		local audit = {bp = bp_name, decision = "KILLED_WALL_TRANSFER_FAIL", receiver = receiver_civ}
		table.insert(_LEAVER_AUDIT_LOG, audit)
		print(string.format("[LEAVER] wall/defense transfer failed for %s — destroying to avoid silent skip", bp_name))
		pcall(Entity_Kill, eid)
		return "killed"
	end

	-- Resolve owner civ for classification. Entities may be player-owned (batch 1, before
	-- World_KillPlayer) or world-owned (batch 2+, after defeat teardown releases ownership).
	-- World_OwnsEntity returns TRUE for neutral/world-owned, FALSE for player-owned.
	local owner_id = nil
	local owner_civ = source_civ  -- fallback: use the leaving player's civ
	if _VISUAL_TEST_CIV_OVERRIDE then
		-- Surrogate visual test: trust source_civ parameter, skip entity owner re-derivation
		owner_id = source_player_id
	elseif not World_OwnsEntity(eid) then
		-- Entity is still player-owned — get actual owner
		local ok_owner, pid = pcall(Entity_GetPlayerOwner, eid)
		if ok_owner and pid ~= nil then
			owner_id = pid
			local ok_civ, civ = pcall(Player_GetRaceName, pid)
			if ok_civ and civ ~= nil then
				owner_civ = civ
			end
		end
	else
		-- Entity is world-owned (released by defeat teardown) — use source player
		owner_id = source_player_id
	end
	local bld_class = _Transfer_ClassifyBuilding(eid, owner_civ)

	-- AUTO-POP POPULATION GATE: When automatic population is active, buildings that increase
	-- population capacity (houses, town centers, capitals) must not be transferred or converted.
	-- This class-level gate runs before AGS resolution to catch ALL population buildings
	-- regardless of fallback mapping or civ-unique equivalences.
	if _mod.pop_cap_incease_on_interval ~= 0 and (bld_class == "house" or bld_class == "town_center") then
		local audit = {bp = bp_name, decision = "KILLED_AUTOPOP_POP_BUILDING", bld_class = bld_class, receiver = receiver_civ}
		table.insert(_LEAVER_AUDIT_LOG, audit)
		print(string.format("[LEAVER] Auto-pop population gate: %s (class=%s) blocked for %s",
			bp_name, bld_class, receiver_civ))
		if bld_class == "house" then
			stats.bldg_killed_autopop_house = (stats.bldg_killed_autopop_house or 0) + 1
		else
			stats.bldg_killed_autopop_tc = (stats.bldg_killed_autopop_tc or 0) + 1
		end
		pcall(Entity_Kill, eid)
		return "killed"
	end

	-- Landmarks: always destroy.
	if bld_class == "landmark" then
		local audit = {bp = bp_name, decision = "KILLED_LANDMARK", ags_key = "landmark", receiver = receiver_civ}
		table.insert(_LEAVER_AUDIT_LOG, audit)
		print(string.format("[LEAVER] Landmark %s destroyed", bp_name))
		-- Clear any min-cap clamp left by prior runs before killing.
		pcall(Entity_SetInvulnerableMinCap, eid, 0.0, -1)
		pcall(Entity_Kill, eid)
		if Entity_IsAlive(eid) then
			pcall(Entity_Destroy, eid)
		end
		return "killed"
	end

	-- Starter keep: transfer-only, update cached ref (G2)
	local src_player = Core_GetPlayersTableEntry(source_player_id or owner_id)
	if src_player ~= nil and eid == src_player.obj_buildingLimit_english_start_keep_id then
		_Transfer_BuildingToPlayer(eid, recipient)
		-- Update receiver's starter keep ref so limit counting stays correct
		local rcv_civ = AGS_CIV_FACTION_MAP[receiver_civ] or receiver_civ
		if rcv_civ == "english" then
			recipient.obj_buildingLimit_english_start_keep_id = eid
		end
		return "transferred"
	end

	-- Mongol moving buildings: always kill (non-Mongol receivers can't use them)
	if Entity_IsOfType(eid, "house_moving") or Entity_IsOfType(eid, "town_center_moving") then
		local audit = {bp = bp_name, decision = "KILLED_MONGOL_MOVING", ags_key = "mongol_moving", receiver = receiver_civ}
		table.insert(_LEAVER_AUDIT_LOG, audit)
		pcall(Entity_Kill, eid)
		return "killed"
	end

	-- Check limit capacity for classified building types
	local can_accept = true
	if bld_class == "production" then
		can_accept = _Transfer_CanAcceptBuilding(recipient)
	elseif bld_class == "workshop" then
		can_accept = _Transfer_CanAcceptWorkshop(recipient)
	elseif bld_class == "outpost" then
		can_accept = _Transfer_CanAcceptOutpost(recipient)
	end

	-- Try overflow to other allies if primary can't accept
	local target = recipient
	if not can_accept then
		local overflow = _Transfer_FindLegalRecipient(owner_id, bld_class)
		if overflow ~= nil then
			target = overflow
		end
		-- No overflow found: fall through with target = recipient.
		-- Phase 7 enforcement handles limits; conversion still needed to avoid foreign BPs.
	end

	local target_civ
	if _VISUAL_TEST_CIV_OVERRIDE then
		target_civ = receiver_civ
	else
		target_civ = Player_GetRaceName(target.id)
	end
	-- Capital town centers must downgrade to the recipient civ's standard TC.
	-- Do this before generic reverse-map resolution so they never become foreign capital TCs.
	local ags_key = nil
	local ags_lookup_name = bp_name
	if AGS_IsACapital(eid) then
		ags_key = AGS_BP_TC
	else
		ags_key, ags_lookup_name = _Leaver_GetReverseMapKey(bp_name)
		if ags_key ~= nil and ags_lookup_name ~= bp_name and _LEAVER_DEBUG_VERBOSE then
			print(string.format("[LEAVER_MAP] %s normalized to %s for reverse-map key %s", bp_name, ags_lookup_name, ags_key))
		end
	end

	-- No AGS mapping: kill
	if ags_key == nil then
		local audit = {bp = bp_name, decision = "KILLED_NO_MAPPING", receiver = target_civ}
		table.insert(_LEAVER_AUDIT_LOG, audit)
		DebugLog("leaver", string.format("No AGS mapping: %s — killed", bp_name))
		pcall(Entity_Kill, eid)
		return "killed"
	end

	-- Resolve receiver's equivalent blueprint (pcall-protected: BP_GetEntityBlueprint can throw)
	local resolve_ok, to_bp = pcall(AGS_GetCivilizationEntity, target_civ, ags_key)
	local resolve_quality = "exact"
	local resolved_ags_key = ags_key

	-- Tier 2: parent civ fallback for variant civs
	-- GUARD: Skip if variant explicitly declares this key false (civ doesn't have this building).
	-- false = authoritative "doesn't exist"; nil = key not listed, parent fallback is valid.
	if (not resolve_ok or to_bp == nil) and AGS_CIV_PARENT_MAP[target_civ] ~= nil
		and not AGS_CivTableHasExplicitFalse(target_civ, ags_key) then
		local parent_civ = AGS_CIV_PARENT_MAP[target_civ]
		resolve_ok, to_bp = pcall(AGS_GetCivilizationEntity, parent_civ, ags_key)
		if resolve_ok and to_bp ~= nil then
			resolve_quality = "parent"
		end
	end

	-- Tier 3: AGS_BUILDING_FALLBACK_MAP for civ-unique buildings
	if (not resolve_ok or to_bp == nil) and AGS_BUILDING_FALLBACK_MAP ~= nil then
		local fallback_key = AGS_BUILDING_FALLBACK_MAP[ags_key]
		if fallback_key ~= nil then
			resolve_ok, to_bp = pcall(AGS_GetCivilizationEntity, target_civ, fallback_key)
			if (not resolve_ok or to_bp == nil) and AGS_CIV_PARENT_MAP[target_civ] ~= nil
				and not AGS_CivTableHasExplicitFalse(target_civ, fallback_key) then
				resolve_ok, to_bp = pcall(AGS_GetCivilizationEntity, AGS_CIV_PARENT_MAP[target_civ], fallback_key)
			end
			if resolve_ok and to_bp ~= nil then
				resolve_quality = "lossy"
				resolved_ags_key = fallback_key
			end
		end
	end

	if not resolve_ok or to_bp == nil then
		if not resolve_ok then
			print(string.format("[LEAVER] AGS resolve failed for %s/%s: %s", target_civ, ags_key, tostring(to_bp)))
		end
		-- Receiver civ has no equivalent — kill
		local audit = {bp = bp_name, decision = "KILLED_NO_RESOLVE", ags_key = ags_key, receiver = target_civ,
			err = not resolve_ok and tostring(to_bp) or "nil"}
		table.insert(_LEAVER_AUDIT_LOG, audit)
		pcall(Entity_Kill, eid)
		return "killed"
	end

	-- AUTO-POP RESOLVED-KEY GUARD (defense-in-depth): Catches population buildings that
	-- reach this point via fallback mapping (e.g. Byzantine cistern → house, or any future
	-- civ-unique → town_center mapping). Primary gate is the class-level check above;
	-- this catches buildings that were classified as non-population but resolved to a pop key.
	local _is_pop_resolved = (resolved_ags_key == AGS_BP_HOUSE
		or resolved_ags_key == AGS_BP_TC or resolved_ags_key == AGS_BP_TC_CAPITAL
		or resolved_ags_key == AGS_BP_TC_LANDMARK)
	if _mod.pop_cap_incease_on_interval ~= 0 and _is_pop_resolved then
		local pop_type = (resolved_ags_key == AGS_BP_HOUSE) and "house" or "tc"
		local audit = {bp = bp_name, decision = "KILLED_AUTOPOP_RESOLVED", ags_key = ags_key,
			resolved_key = resolved_ags_key, receiver = target_civ}
		table.insert(_LEAVER_AUDIT_LOG, audit)
		print(string.format("[LEAVER] Auto-pop resolved-key guard: %s (key=%s→%s) blocked for %s",
			bp_name, ags_key, resolved_ags_key, target_civ))
		if pop_type == "house" then
			stats.bldg_killed_autopop_house = (stats.bldg_killed_autopop_house or 0) + 1
		else
			stats.bldg_killed_autopop_tc = (stats.bldg_killed_autopop_tc or 0) + 1
		end
		pcall(Entity_Kill, eid)
		return "killed"
	end

	-- Age-gate: skip creation if receiver hasn't reached the required age
	local age_result = _Leaver_MeetsAgeRequirement(bp_name, ags_key, target.id, "building")
	if age_result == "blocked" then
		pcall(Entity_Kill, eid)
		return "killed"
	end

	-- Capability-gate: skip creation if receiver lacks required tech/upgrade
	local cap_result = _Leaver_MeetsCapabilityRequirement(bp_name, ags_key, target.id, "building")
	if cap_result == "blocked" then
		pcall(Entity_Kill, eid)
		return "killed"
	end

	local is_tc_like = AGS_IsACapital(eid) or AGS_IsATownCenter(eid)

	-- Same blueprint optimization (G8): just transfer ownership.
	-- Keep this after age-gating so same-BP structures cannot bypass age requirements.
	if BP_GetName(to_bp) == bp_name then
		if _LEAVER_DEBUG_VERBOSE then
			print(string.format("[LEAVER_XFER] %s | bldg same-BP (no create) | %s", bp_name, resolve_quality))
		end
		stats["bldg_q_" .. resolve_quality] = (stats["bldg_q_" .. resolve_quality] or 0) + 1
		_Transfer_BuildingToPlayer(eid, target)
		if is_tc_like then
			-- Never let transferred TC-like entities retain capital state.
			pcall(Entity_SetStateModelBool, eid, "town_center_is_capital", false)
		end
		return "transferred"
	end

	-- Different blueprint: create-before-destroy with facing and health preservation (G4)
	local pos = Entity_GetPosition(eid)
	local heading = Entity_GetHeading(eid)  -- direction vector {x,y,z}
	-- Entity_CreateFacing expects a world position to face towards, not a direction vector
	local facing_pos = World_Pos(pos.x + heading.x, pos.y + heading.y, pos.z + heading.z)
	local health_pct = math.max(0.0, math.min(1.0, Entity_GetHealthPercentage(eid) or 1.0))

	-- Attempt to create replacement FIRST (safe: buildings can briefly overlap)
	local create_ok, new_ent = pcall(Entity_CreateFacing, to_bp, target.id, pos, facing_pos, true)
	if (not create_ok or new_ent == nil) and is_tc_like then
		-- Town centers are the main case where same-tile replacement can fail.
		-- Retry on a small ring before falling back to foreign-BP transfer.
		local retry_offsets = {
			{x = 12, z = 0}, {x = -12, z = 0}, {x = 0, z = 12}, {x = 0, z = -12},
		}
		local first_err = tostring(new_ent)
		for _, off in ipairs(retry_offsets) do
			local retry_pos = World_Pos(pos.x + off.x, pos.y, pos.z + off.z)
			local retry_facing = World_Pos(retry_pos.x + heading.x, retry_pos.y + heading.y, retry_pos.z + heading.z)
			create_ok, new_ent = pcall(Entity_CreateFacing, to_bp, target.id, retry_pos, retry_facing, true)
			if create_ok and new_ent ~= nil then
				print(string.format("[LEAVER] TC retry placement succeeded for %s→%s at offset (%d,%d); initial_err=%s",
					bp_name, BP_GetName(to_bp), off.x, off.z, first_err))
				break
			end
		end
	end
	if not create_ok or new_ent == nil then
		print(string.format("[LEAVER] Entity_CreateFacing failed for %s→%s: %s", bp_name, BP_GetName(to_bp), tostring(new_ent)))
		if is_tc_like then
			-- Capital TC / TC conversion failed after all retries — destroy rather than
			-- silently transferring a foreign capital TC with the wrong blueprint.
			local audit = {bp = bp_name, decision = "KILLED_TC_CREATE_FAIL", ags_key = tostring(ags_key), receiver = target_civ,
				err = tostring(new_ent)}
			table.insert(_LEAVER_AUDIT_LOG, audit)
			print(string.format("[LEAVER] Capital/TC %s destroyed (all placement retries exhausted)", bp_name))
			pcall(Entity_Kill, eid)
			return "killed"
		end
		-- Non-TC creation failure — transfer ownership (keep foreign BP) as last resort
		local audit = {bp = bp_name, decision = "TRANSFERRED_CREATE_FAIL", ags_key = tostring(ags_key), receiver = target_civ,
			err = tostring(new_ent)}
		table.insert(_LEAVER_AUDIT_LOG, audit)
		_Transfer_BuildingToPlayer(eid, target)
		return "transferred"
	end

	-- Creation succeeded — now safe to destroy original
	-- Safety: eject garrisons (defensive — already done in Phase 2)
	pcall(Entity_UnloadAllFromHold, eid)

	-- Cancel any production queue before destroying
	if Entity_HasProductionQueue(eid) then
		local qc = Entity_GetProductionQueueSize(eid)
		for q = qc, 1, -1 do
			pcall(Entity_CancelProductionQueueItem, eid, q - 1)
		end
	end

	-- Destroy original (no kill event)
	Entity_Destroy(eid)

	-- Finalize new entity
	Entity_Spawn(new_ent)

	-- Farm special dispatch (official Relic pattern from gamescarutil.scar)
	if Entity_IsOfType(new_ent, "farm") then
		pcall(Entity_DispatchConstructionStarted, new_ent)
	end

	Entity_ForceConstruct(new_ent)

	-- Safety net: ensure converted TCs never inherit capital status from the original.
	-- Entity_CreateFacing uses a non-capital blueprint, but clear the state model flag
	-- defensively in case the engine copies state from nearby context.
	if is_tc_like then
		pcall(Entity_SetStateModelBool, new_ent, "town_center_is_capital", false)
	end

	-- Restore health ratio (Entity_SetHealth expects percentage in [0.0, 1.0])
	if health_pct < 1.0 then
		Entity_SetHealth(new_ent, health_pct)
	end

	stats["bldg_q_" .. resolve_quality] = (stats["bldg_q_" .. resolve_quality] or 0) + 1
	if _LEAVER_DEBUG_VERBOSE and resolve_quality ~= "exact" then
		print(string.format("[LEAVER_BLDG] %s → %s | quality=%s key=%s", bp_name, BP_GetName(to_bp), resolve_quality, ags_key))
	end

	return "converted"
end

---------------------------------------------------------------------------------------------------
-- Phase 4: Eco Squad Transfer (villager, scout, king, monk, crossbow)
---------------------------------------------------------------------------------------------------

-- Returns the number of villagers owned by a player.
function _Leaver_CountVillagers(player)
	local sg = Player_GetSquads(player.id)
	local sg_temp = SGroup_CreateIfNotFound("sg_leaver_vill_count")
	SGroup_Clear(sg_temp)
	SGroup_AddGroup(sg_temp, sg)
	SGroup_Filter(sg_temp, "scar_villager", FILTER_KEEP)
	return SGroup_Count(sg_temp)
end

function _Convert_EcoSquad(squad, recipient, receiver_civ)
	if not Squad_IsAlive(squad) then return "skipped" end

	local sbp = Squad_GetBlueprint(squad)
	local sbp_name = BP_GetName(sbp)

	local ags_key, ags_lookup_name = _Leaver_GetReverseMapKey(sbp_name)
	if ags_key ~= nil and ags_lookup_name ~= sbp_name and _LEAVER_DEBUG_VERBOSE then
		print(string.format("[LEAVER_MAP] %s normalized to %s for eco reverse-map key %s", sbp_name, ags_lookup_name, ags_key))
	end
	if ags_key == nil then
		-- No mapping — cannot resolve receiver equivalent; destroy to prevent cross-civ transfer
		if _LEAVER_DEBUG_VERBOSE then
			print(string.format("[LEAVER_XFER] %s | eco no-mapping (destroyed) | eco_no_map", sbp_name))
		end
		Squad_Kill(squad)
		return "killed"
	end

	-- Resolve receiver's equivalent squad (pcall-protected: BP_GetSquadBlueprint can throw)
	local resolve_ok, to_sbp = pcall(AGS_GetCivilizationUnit, receiver_civ, ags_key)
	if not resolve_ok or to_sbp == nil then
		if not resolve_ok then
			print(string.format("[LEAVER] AGS unit resolve failed for %s/%s: %s", receiver_civ, ags_key, tostring(to_sbp)))
		end
		-- Receiver civ has no equivalent — destroy to prevent cross-civ transfer
		if _LEAVER_DEBUG_VERBOSE then
			print(string.format("[LEAVER_XFER] %s | eco no-resolve for %s/%s (destroyed) | eco_no_resolve", sbp_name, receiver_civ, ags_key))
		end
		Squad_Kill(squad)
		return "killed"
	end

	-- Same blueprint: just transfer ownership
	if BP_GetName(to_sbp) == sbp_name then
		if _LEAVER_DEBUG_VERBOSE then
			print(string.format("[LEAVER_XFER] %s | eco same-BP (no create) | eco_same_bp", sbp_name))
		end
		Squad_SetPlayerOwner(squad, recipient.id)
		return "transferred"
	end

	-- Blueprint differs — destroy to prevent cross-civ transfer.
	-- Converting eco units is not worth the system cost; clean elimination is safer.
	if _LEAVER_DEBUG_VERBOSE then
		print(string.format("[LEAVER_XFER] %s | eco bp-differs (destroyed, target was %s) | eco_bp_differs", sbp_name, BP_GetName(to_sbp)))
	end
	Squad_Kill(squad)
	return "killed"
end

---------------------------------------------------------------------------------------------------
-- Full Elimination Pipeline (all 8 phases)
---------------------------------------------------------------------------------------------------

function Mod_EliminatePlayerUnits(player, recipient_override, is_silent)
	local victim_id = player.id or player

	-- Guard: prevent double execution (disconnect → OnPlayerAITakeover + OnPlayerDefeated)
	local player_entry = Core_GetPlayersTableEntry(victim_id)
	if player_entry ~= nil and player_entry._leaver_converted then
		return
	end
	if player_entry ~= nil then
		player_entry._leaver_converted = true
		player_entry._leaver_eliminated = true
	end

	local primary_recipient = recipient_override or Mod_FindBestAlly(victim_id)

	if primary_recipient == nil then
		-- No ally: kill everything
		local eg = Player_GetEntities(victim_id)
		local eg_count = EGroup_Count(eg)
		for idx = eg_count, 1, -1 do
			local ent = EGroup_GetEntityAt(eg, idx)
			if ent ~= nil then pcall(Entity_Kill, ent) end
		end
		local sg = Player_GetSquads(victim_id)
		local sg_count = SGroup_Count(sg)
		for idx = sg_count, 1, -1 do
			local squad = SGroup_GetSquadAt(sg, idx)
			if squad ~= nil then pcall(Squad_Kill, squad) end
		end
		if not is_silent then
			DebugLog("elimination", "No ally found — all entities killed")
		end
		return
	end

	local src_civ = Player_GetRaceName(victim_id)
	local rcv_civ = Player_GetRaceName(primary_recipient.id)

	-- Tracking counters (military buckets are mutually exclusive per squad)
	local stats = {
		resources = false,
		garrisons_ejected = 0,
		bldg_converted = 0, bldg_transferred = 0, bldg_killed = 0,
		bldg_skipped_dead = 0,
		bldg_silent_skip = 0,
		eco_transferred = 0, eco_killed = 0,
		-- Military conversion routes
		mil_direct = 0,
		mil_tier_bump = 0,
		mil_civ_unique_archetype = 0,
		mil_receiver_class = 0,
		mil_generic_archetype = 0,
		mil_same_bp = 0,
		mil_transfer_only = 0,
		-- Military destroy routes
		mil_destroy_policy = 0,
		mil_destroy_age_blocked = 0,
		mil_bypass_age_spawner_exempt = 0,
		mil_destroy_cap_blocked = 0,
		mil_destroy_create_fail = 0,
		mil_destroy_no_mapping = 0,
		mil_destroy_ratio_skip = 0,
		mil_destroy_pop_capped = 0,
		-- Terminal handled-decision accounting
		skipped_dead = 0,
		mil_silent_skip = 0,
	}

	-- ---- Phase 0: Recipient selection ----
	primary_recipient._leaver_absorb_count = (primary_recipient._leaver_absorb_count or 0) + 1

	-- Recipient-only pop bonus disabled: population scaling is handled team-wide via
	-- AGS_TeamBalance_UpdateAllLimits so humans and AI receive symmetric cap growth.
	local _pop_bonus = 0

	-- ---- Phase 1: Resource Transfer ----
	_Transfer_Resources(victim_id, primary_recipient)
	stats.resources = true

	-- ---- Phase 2: Garrison Ejection ----
	_Transfer_EjectGarrisons(victim_id)

	-- ---- Phase 3: Building Conversion (DEFERRED — batched across frames) ----
	local eg_all = Player_GetEntities(victim_id)
	local eg_count = EGroup_Count(eg_all)
	-- Snapshot entity refs (conversion destroys entities, avoid mutation during iteration)
	local bldg_snapshot = {}
	for idx = 1, eg_count do
		local ent = EGroup_GetEntityAt(eg_all, idx)
		if ent ~= nil then table.insert(bldg_snapshot, ent) end
	end

	-- ---- Phase 4+5 prep: Snapshot squads + build recipient list ----
	local squad_recipients = { primary_recipient }
	for _, p in ipairs(PLAYERS) do
		if p.id ~= victim_id and p.id ~= primary_recipient.id
			and not Core_IsPlayerEliminated(p.id)
			and Player_ObserveRelationship(p.id, victim_id) == R_ALLY then
			table.insert(squad_recipients, p)
		end
	end

	local sg_all = Player_GetSquads(victim_id)
	local sg_count = SGroup_Count(sg_all)
	local all_squads = {}
	for idx = 1, sg_count do
		local squad = SGroup_GetSquadAt(sg_all, idx)
		if squad ~= nil then
			table.insert(all_squads, squad)
		end
	end

	-- PERF: Pre-compute villager counts for all recipients once (O(n) total).
	-- Updated inline as villagers are assigned — avoids O(n²) full-scan per villager.
	local _vill_counts = {}
	for _, r in ipairs(squad_recipients) do
		_vill_counts[r.id] = _Leaver_CountVillagers(r)
	end

	-- PERF: Store transfer state for deferred multi-frame processing.
	-- Phases 3, 4+5, and 7 are batched across frames to avoid single-tick lag spikes.
	_leaver_transfer_state = {
		victim_id = victim_id,
		primary_recipient = primary_recipient,
		rcv_civ = rcv_civ,
		src_civ = src_civ,
		stats = stats,
		is_silent = is_silent,
		_pop_bonus = _pop_bonus,
		-- Phase 3 state
		bldg_snapshot = bldg_snapshot,
		bldg_idx = #bldg_snapshot,
		-- Phase 4+5 state
		squad_recipients = squad_recipients,
		all_squads = all_squads,
		squad_idx = 1,
		rcv_idx = 1,
		_vill_counts = _vill_counts,
		-- Phase tracking
		phase = 3,
		allies_to_enforce = nil,
		enforce_idx = 1,
		-- Fallback ratio accumulator: keyed by target BP name → fractional count
		_fallback_accum = {},
	}

	-- Record pipeline start time for timing instrumentation.
	local ok_gt, gt = pcall(World_GetGameTime)
	local st = _leaver_transfer_state
	st.start_time = (ok_gt and gt) or 0
	st.entity_total = #bldg_snapshot
	st.squad_total = #all_squads

	-- Per-phase timing (populated as phases complete)
	st.phase_timings = {}

	-- Snapshot annihilation cascade counter at pipeline start for delta
	st._annihilation_checks_start = _LEAVER_PERF_ANNIHILATION_CHECKS or 0

	-- Pause competing interval rules during leaver processing to free frame budget.
	-- Restored at pipeline end (Phase 7 completion).
	_Leaver_PauseIntervalRules()

	-- Pipeline header: always printed so every run is visible in scarlog.
	print(string.format("[LEAVER_START] %s→%s | %d entities, %d squads | bypass_age=%s bypass_cap=%s verbose=%s",
		src_civ, rcv_civ, st.entity_total, st.squad_total,
		tostring(_LEAVER_DEBUG_BYPASS_GATES), tostring(_LEAVER_DEBUG_BYPASS_CAPABILITY_GATES),
		tostring(_LEAVER_DEBUG_VERBOSE)))

	-- Reset audit log and capability cache for this pipeline run
	_LEAVER_AUDIT_LOG = {}
	_LEAVER_CAP_CACHE = {}

	-- Begin deferred processing (first batch runs immediately)
	_Leaver_ContinueTransfer()
end

-- Batch sizes for deferred transfer processing
_LEAVER_BATCH_BUILDINGS = 10
_LEAVER_BATCH_SQUADS = 20

-- Last completed transfer stats (persisted after pipeline clears for debug inspection).
_leaver_last_transfer_stats = nil

-- Deferred transfer continuation — processes one batch per call, then schedules the next.
-- Uses while-loop so empty phases advance immediately without wasting a tick.
function _Leaver_ContinueTransfer()
	local st = _leaver_transfer_state
	if st == nil then return end
	if _onslaught_teardown_detected then
		Onslaught_Trace("TRACE_TEARDOWN", "_Leaver_ContinueTransfer aborted at phase " .. tostring(st.phase))
		return
	end

	while true do

	if st.phase == 3 then
		-- ---- Phase 3: Building Conversion (batch) ----
		local processed = 0
		while st.bldg_idx >= 1 and processed < _LEAVER_BATCH_BUILDINGS do
			local ent = st.bldg_snapshot[st.bldg_idx]
			local _bldg_tc_before = st.stats.bldg_converted + st.stats.bldg_transferred
				+ st.stats.bldg_killed + (st.stats.bldg_skipped_dead or 0)
			local ok, result = pcall(_Convert_Building, ent, st.primary_recipient, st.rcv_civ, st.src_civ, st.stats, st.victim_id)
			if ok then
				if result == "converted" then st.stats.bldg_converted = st.stats.bldg_converted + 1
				elseif result == "transferred" then st.stats.bldg_transferred = st.stats.bldg_transferred + 1
				elseif result == "killed" then st.stats.bldg_killed = st.stats.bldg_killed + 1
				elseif result == "skipped_dead" then st.stats.bldg_skipped_dead = (st.stats.bldg_skipped_dead or 0) + 1
				else
					st.stats.bldg_silent_skip = (st.stats.bldg_silent_skip or 0) + 1
					print(string.format("[LEAVER_FAIL] BLDG_SILENT_SKIP idx=%d result=%s", st.bldg_idx, tostring(result)))
					if ent ~= nil and Entity_IsAlive(ent) then
						pcall(Entity_Kill, ent)
						st.stats.bldg_killed = st.stats.bldg_killed + 1
					end
				end
			else
				print(string.format("[LEAVER] _Convert_Building threw: %s", tostring(result)))
				local recovered = false
				if ent ~= nil and Entity_IsAlive(ent) then
					local bp_ok, bp = pcall(Entity_GetBlueprint, ent)
					if bp_ok and bp ~= nil then
						local name_ok, bp_name = pcall(BP_GetName, bp)
						if name_ok and bp_name ~= nil then
							if string.find(bp_name, "defense_wall") or string.find(bp_name, "palisade") or string.find(bp_name, "defense_tower") or string.find(bp_name, "defense_keep") then
								local xfer_ok, xfer_result = pcall(_Transfer_BuildingToPlayer, ent, st.primary_recipient)
								if xfer_ok and xfer_result then
									recovered = true
									st.stats.bldg_transferred = st.stats.bldg_transferred + 1
								end
							end
						end
					end
				end
				if not recovered then
					pcall(Entity_Kill, ent)
					st.stats.bldg_killed = st.stats.bldg_killed + 1
				end
			end
			local _bldg_tc_after = st.stats.bldg_converted + st.stats.bldg_transferred
				+ st.stats.bldg_killed + (st.stats.bldg_skipped_dead or 0)
			if _bldg_tc_after == _bldg_tc_before then
				st.stats.bldg_silent_skip = (st.stats.bldg_silent_skip or 0) + 1
				print(string.format("[LEAVER_FAIL] BLDG_SILENT_SKIP idx=%d — no terminal stat increment", st.bldg_idx))
				if ent ~= nil and Entity_IsAlive(ent) then
					pcall(Entity_Kill, ent)
					st.stats.bldg_killed = st.stats.bldg_killed + 1
				end
			end
			st.bldg_idx = st.bldg_idx - 1
			processed = processed + 1
		end
		if st.bldg_idx < 1 then
			-- Record Phase 3 completion time
			local ok_t3, t3 = pcall(World_GetGameTime)
			if ok_t3 and t3 then st.phase_timings.phase3_end = t3 end
			st.phase = 4
			-- Phase-skip: if no squads, advance immediately (no wasted tick)
			if #st.all_squads == 0 then
				-- fall through to next phase via while loop
			else
				Rule_AddOneShot(_Leaver_ContinueTransfer, 0)
				return
			end
		else
			Rule_AddOneShot(_Leaver_ContinueTransfer, 0)
			return
		end

	elseif st.phase == 4 then
		-- ---- Phase 4+5: Squad Conversion (batch) ----
		local processed = 0
		while st.squad_idx <= #st.all_squads and processed < _LEAVER_BATCH_SQUADS do
			local squad = st.all_squads[st.squad_idx]
			st.squad_idx = st.squad_idx + 1
			processed = processed + 1
			if not Squad_IsAlive(squad) then
				-- skip dead
				st.stats.skipped_dead = st.stats.skipped_dead + 1
			else
				-- Terminal handled-decision accounting: snapshot stat sum before processing.
				-- After the alive branch, compare to detect any path that fails to increment a terminal stat.
							local _sq_tc_before = st.stats.eco_transferred + st.stats.eco_killed
					+ st.stats.mil_transfer_only + st.stats.mil_same_bp
					+ st.stats.mil_destroy_policy + st.stats.mil_destroy_age_blocked
					+ st.stats.mil_destroy_cap_blocked + st.stats.mil_destroy_create_fail
					+ st.stats.mil_destroy_no_mapping + st.stats.mil_destroy_ratio_skip
					+ (st.stats.mil_destroy_pop_capped or 0)
					+ st.stats.mil_direct + st.stats.mil_tier_bump
					+ st.stats.mil_civ_unique_archetype + st.stats.mil_receiver_class
					+ st.stats.mil_generic_archetype
					+ st.stats.mil_bypass_age_spawner_exempt
				-- Advance to next recipient if current is at pop cap
				local all_rcv_at_cap = false
				while st.rcv_idx <= #st.squad_recipients do
					local r = st.squad_recipients[st.rcv_idx]
					local pop = Player_GetCurrentPopulation(r.id, CT_Personnel)
					local cap = Player_GetCurrentPopulationCap(r.id, CT_Personnel)
					if pop < cap then break end
					st.rcv_idx = st.rcv_idx + 1
				end
				if st.rcv_idx > #st.squad_recipients then
					all_rcv_at_cap = true
					st.rcv_idx = 1
				end

				local receiver = st.squad_recipients[st.rcv_idx]
				local rcv_civ_local = Player_GetRaceName(receiver.id)
				local is_eco = Squad_IsOfType(squad, "scar_villager") or Squad_IsOfType(squad, "scar_monk")
					or Squad_IsOfType(squad, "scar_scout") or Squad_IsOfType(squad, "king")
					or Squad_IsOfType(squad, "scar_crossbow")
					or Squad_IsOfType(squad, "scar_trader") or Squad_IsOfType(squad, "scar_fishing")

				if is_eco then
					if Squad_IsOfType(squad, "scar_villager") then
						local vill_receiver = nil
						if (st._vill_counts[receiver.id] or 0) < 10 then
							vill_receiver = receiver
						else
							for _, r in ipairs(st.squad_recipients) do
								if r.id ~= receiver.id and not Core_IsPlayerEliminated(r.id) and (st._vill_counts[r.id] or 0) < 10 then
									vill_receiver = r
									break
								end
							end
						end
						if vill_receiver == nil then
							pcall(Squad_Kill, squad)
							st.stats.eco_killed = (st.stats.eco_killed or 0) + 1
						else
							st._vill_counts[vill_receiver.id] = (st._vill_counts[vill_receiver.id] or 0) + 1
							local vill_civ = Player_GetRaceName(vill_receiver.id)
							local ok, result = pcall(_Convert_EcoSquad, squad, vill_receiver, vill_civ)
							if ok and (result == "converted" or result == "transferred") then
								st.stats.eco_transferred = st.stats.eco_transferred + 1
							elseif ok and result == "killed" then
								st.stats.eco_killed = (st.stats.eco_killed or 0) + 1
							else
								-- Conversion threw or returned unexpected result — destroy to prevent cross-civ transfer
								pcall(Squad_Kill, squad)
								st.stats.eco_killed = (st.stats.eco_killed or 0) + 1
							end
						end
					else
						local ok, result = pcall(_Convert_EcoSquad, squad, receiver, rcv_civ_local)
						if ok and (result == "converted" or result == "transferred") then
							st.stats.eco_transferred = st.stats.eco_transferred + 1
						elseif ok and result == "killed" then
							st.stats.eco_killed = (st.stats.eco_killed or 0) + 1
						else
							-- Conversion threw or returned unexpected result — destroy to prevent cross-civ transfer
							pcall(Squad_Kill, squad)
							st.stats.eco_killed = (st.stats.eco_killed or 0) + 1
						end
					end
				else
					local sbp = Squad_GetBlueprint(squad)
					local sbp_name = BP_GetName(sbp)

					local transfer_only, transfer_only_reason = _Leaver_IsNeutralOrTransferOnlySquad(squad, sbp_name)
					if transfer_only then
						pcall(Squad_SetPlayerOwner, squad, receiver.id)
						st.stats.mil_transfer_only = (st.stats.mil_transfer_only or 0) + 1
						if _LEAVER_DEBUG_VERBOSE then
							print(string.format("[LEAVER_XFER] %s | transfer-only non-military (%s) | mil_transfer_only", sbp_name, tostring(transfer_only_reason)))
						end
					else
						-- Route-based military resolution (never re-owns — always convert or destroy)
						local route = _ResolveMilitaryRoute(sbp_name, st.src_civ, rcv_civ_local)

						if route.route == "same_bp" then
							-- Same BP: ownership transfer only (approved exception)
							pcall(Squad_SetPlayerOwner, squad, receiver.id)
							st.stats.mil_same_bp = (st.stats.mil_same_bp or 0) + 1
							table.insert(_LEAVER_AUDIT_LOG, {bp = sbp_name, decision = "MIL_SAME_BP", route = route.route, receiver = rcv_civ_local})
							if _LEAVER_DEBUG_VERBOSE then
								print(string.format("[LEAVER_XFER] %s | same-BP transfer (no create) | mil_same_bp", sbp_name))
							end
						elseif route.route == "destroy_policy" then
							pcall(Squad_Kill, squad)
							st.stats.mil_destroy_policy = (st.stats.mil_destroy_policy or 0) + 1
							table.insert(_LEAVER_AUDIT_LOG, {bp = sbp_name, decision = "KILLED_MIL_DESTROY_POLICY", route = route.route, receiver = rcv_civ_local})
							if _LEAVER_DEBUG_VERBOSE then
								print(string.format("[LEAVER_XFER] %s | destroy policy | mil_destroy_policy", sbp_name))
							end
						elseif route.route == "destroy_no_mapping" then
							pcall(Squad_Kill, squad)
							st.stats.mil_destroy_no_mapping = (st.stats.mil_destroy_no_mapping or 0) + 1
							table.insert(_LEAVER_AUDIT_LOG, {bp = sbp_name, decision = "KILLED_MIL_NO_MAPPING", route = route.route, receiver = rcv_civ_local})
							if _LEAVER_DEBUG_VERBOSE then
								print(string.format("[LEAVER_XFER] %s | no resolve path | mil_destroy_no_mapping", sbp_name))
							end
						elseif route.to_sbp ~= nil then
							-- PERF: When all recipients are at pop cap, skip the expensive
							-- Util_CreateSquads path — the created unit would be immediately
							-- killed by Phase 7 EnforcePopulationCap anyway.
							if all_rcv_at_cap then
								Squad_Destroy(squad)
								st.stats.mil_destroy_pop_capped = (st.stats.mil_destroy_pop_capped or 0) + 1
								table.insert(_LEAVER_AUDIT_LOG, {bp = sbp_name, decision = "KILLED_MIL_POP_CAPPED", route = route.route, receiver = rcv_civ_local, target_bp = route.bp_name})
								if _LEAVER_DEBUG_VERBOSE then
									print(string.format("[LEAVER_XFER] %s | all recipients at pop cap | mil_destroy_pop_capped", sbp_name))
								end
							else
							-- Conversion route: age-gate then capability-gate then create with ratio accumulation
							local age_result = _Leaver_MeetsAgeRequirement(route.bp_name, nil, receiver.id, "mil_" .. route.route)
							-- Spawner-exempt BPs bypass the military age gate (covers all 3 reward archetypes).
							if age_result == "blocked" then
								if _Leaver_IsSpawnerExemptBP(route.bp_name) then
									age_result = "bypassed"
									st.stats.mil_bypass_age_spawner_exempt = (st.stats.mil_bypass_age_spawner_exempt or 0) + 1
									table.insert(_LEAVER_AUDIT_LOG, {bp = sbp_name, decision = "AGE_BYPASS_SPAWNER_EXEMPT", route = route.route, receiver = rcv_civ_local, target_bp = route.bp_name})
									if _LEAVER_DEBUG_VERBOSE then
										print(string.format("[LEAVER_XFER] %s | %s spawner-exempt age bypass | mil_bypass_age_spawner_exempt", sbp_name, route.route))
									end
								end
							end
							if age_result == "blocked" then
								pcall(Squad_Kill, squad)
								st.stats.mil_destroy_age_blocked = (st.stats.mil_destroy_age_blocked or 0) + 1
								table.insert(_LEAVER_AUDIT_LOG, {bp = sbp_name, decision = "KILLED_MIL_AGE_BLOCKED", route = route.route, receiver = rcv_civ_local, target_bp = route.bp_name})
								if _LEAVER_DEBUG_VERBOSE then
									print(string.format("[LEAVER_XFER] %s | %s age blocked | mil_destroy_age_blocked", sbp_name, route.route))
								end
							else
								local cap_result = _Leaver_MeetsCapabilityRequirement(route.bp_name, nil, receiver.id, "mil_" .. route.route)
								if cap_result == "blocked" then
									pcall(Squad_Kill, squad)
									st.stats.mil_destroy_cap_blocked = (st.stats.mil_destroy_cap_blocked or 0) + 1
									table.insert(_LEAVER_AUDIT_LOG, {bp = sbp_name, decision = "KILLED_MIL_CAP_BLOCKED", route = route.route, receiver = rcv_civ_local, target_bp = route.bp_name})
									if _LEAVER_DEBUG_VERBOSE then
										print(string.format("[LEAVER_XFER] %s | %s cap blocked | mil_destroy_cap_blocked", sbp_name, route.route))
									end
								else
									st._fallback_accum[route.bp_name] = (st._fallback_accum[route.bp_name] or 0) + route.ratio
									if st._fallback_accum[route.bp_name] >= 1.0 then
										st._fallback_accum[route.bp_name] = st._fallback_accum[route.bp_name] - 1.0
										local pos = Squad_GetPosition(squad)
										local sg_temp = SGroup_CreateIfNotFound("sg_leaver_mil_temp")
										SGroup_Clear(sg_temp)
										_Leaver_EnsureRuntimeUnitPrecache(route.bp_name, route.to_sbp, receiver.id, "leaver_conversion", route.route)
										_Leaver_RuntimeTrackPrecache(route.bp_name, receiver.id, "leaver_conversion", route.route)
										local cr_ok, cr_err = pcall(Util_CreateSquads, receiver.id, sg_temp, route.to_sbp, pos, nil, 1)
										if cr_ok and SGroup_Count(sg_temp) > 0 then
											Squad_Destroy(squad)
											st.stats["mil_" .. route.route] = (st.stats["mil_" .. route.route] or 0) + 1
											table.insert(_LEAVER_AUDIT_LOG, {bp = sbp_name, decision = "MIL_CONVERTED", route = route.route, receiver = rcv_civ_local, target_bp = route.bp_name})
											if _LEAVER_DEBUG_VERBOSE then
												print(string.format("[LEAVER_XFER] %s → %s | %s | mil_%s", sbp_name, route.bp_name, route.route, route.route))
											end
										else
											print(string.format("[LEAVER] Create failed %s→%s (%s): %s", sbp_name, route.bp_name, route.route, tostring(cr_err)))
											pcall(Squad_Kill, squad)
											st.stats.mil_destroy_create_fail = (st.stats.mil_destroy_create_fail or 0) + 1
											table.insert(_LEAVER_AUDIT_LOG, {bp = sbp_name, decision = "KILLED_MIL_CREATE_FAIL", route = route.route, receiver = rcv_civ_local, target_bp = route.bp_name, err = tostring(cr_err)})
										end
									else
										-- Ratio threshold not reached: destroy original (fractional reduction)
										Squad_Destroy(squad)
										st.stats.mil_destroy_ratio_skip = (st.stats.mil_destroy_ratio_skip or 0) + 1
										table.insert(_LEAVER_AUDIT_LOG, {bp = sbp_name, decision = "KILLED_MIL_RATIO_SKIP", route = route.route, receiver = rcv_civ_local, target_bp = route.bp_name, ratio = route.ratio})
										if _LEAVER_DEBUG_VERBOSE then
											print(string.format("[LEAVER_XFER] %s | ratio skip (%.2f) | mil_destroy_ratio_skip", sbp_name, route.ratio))
										end
									end
								end
							end
							end -- all_rcv_at_cap
						end
					end
				end
				-- Silent-skip detection: verify at least one terminal stat was incremented
				local _sq_tc_after = st.stats.eco_transferred + st.stats.eco_killed
					+ st.stats.mil_transfer_only + st.stats.mil_same_bp
					+ st.stats.mil_destroy_policy + st.stats.mil_destroy_age_blocked
					+ st.stats.mil_destroy_cap_blocked + st.stats.mil_destroy_create_fail
					+ st.stats.mil_destroy_no_mapping + st.stats.mil_destroy_ratio_skip
					+ (st.stats.mil_destroy_pop_capped or 0)
					+ st.stats.mil_direct + st.stats.mil_tier_bump
					+ st.stats.mil_civ_unique_archetype + st.stats.mil_receiver_class
					+ st.stats.mil_generic_archetype
					+ st.stats.mil_bypass_age_spawner_exempt
				if _sq_tc_after == _sq_tc_before then
					st.stats.mil_silent_skip = st.stats.mil_silent_skip + 1
					print(string.format("[LEAVER_FAIL] SILENT_SKIP squad_idx=%d — no terminal stat increment", st.squad_idx - 1))
				end
			end
		end
		if st.squad_idx > #st.all_squads then
			-- Record Phase 4+5 completion time
			local ok_t45, t45 = pcall(World_GetGameTime)
			if ok_t45 and t45 then st.phase_timings.phase45_end = t45 end
			-- Prepare Phase 7: allies to enforce
			st.phase = 7
			st.allies_to_enforce = {}
			for _, p in ipairs(PLAYERS) do
				if p.id ~= st.victim_id and not Core_IsPlayerEliminated(p.id)
					and Player_ObserveRelationship(p.id, st.victim_id) == R_ALLY then
					table.insert(st.allies_to_enforce, p)
				end
			end
			st.enforce_idx = 1
			-- Phase-skip: if no allies to enforce, advance immediately
			if #st.allies_to_enforce == 0 then
				-- fall through to Phase 7 completion via while loop
			else
				Rule_AddOneShot(_Leaver_ContinueTransfer, 0)
				return
			end
		else
			Rule_AddOneShot(_Leaver_ContinueTransfer, 0)
			return
		end

	elseif st.phase == 7 then
		-- ---- Phase 7: Post-Transfer Enforcement (3 sub-phases per ally) ----
		-- Sub-phases: 1=recount, 2=enforce/kill, 3=UI — one sub-phase per frame.
		-- Sub-phase 2 repeats if pop-cap enforcement was budget-limited (spreads kills across frames).
		st.enforce_subphase = st.enforce_subphase or 1
		if st.enforce_idx <= #st.allies_to_enforce then
			local ally = st.allies_to_enforce[st.enforce_idx]
			if st.enforce_subphase == 1 then
				CBA_Options_EnforcePostTransfer_Recount(ally)
				st.enforce_subphase = 2
			elseif st.enforce_subphase == 2 then
				local enforce_result = CBA_Options_EnforcePostTransfer_Enforce(ally)
				-- Stay on sub-phase 2 if pop-cap kills are still pending (batched across frames)
				if enforce_result ~= "pending" then
					st.enforce_subphase = 3
				end
			else
				CBA_Options_EnforcePostTransfer_UI(ally)
				st.enforce_subphase = 1
				st.enforce_idx = st.enforce_idx + 1
			end
			Rule_AddOneShot(_Leaver_ContinueTransfer, 0)
			return
		else
			-- All phases complete — compute elapsed time and persist stats for debug.
			if type(AGS_PopulationAutomatic_ReconcileCapDrift) == "function" then
				AGS_PopulationAutomatic_ReconcileCapDrift()
			end
			-- Record Phase 7 completion time
			local ok_t7, t7 = pcall(World_GetGameTime)
			if ok_t7 and t7 then st.phase_timings.phase7_end = t7 end
			local elapsed = 0
			local ok_gt2, gt2 = pcall(World_GetGameTime)
			if ok_gt2 and gt2 and st.start_time then
				elapsed = gt2 - st.start_time
			end

			-- Annihilation cascade delta
			local annihilation_cascade = (_LEAVER_PERF_ANNIHILATION_CHECKS or 0) - (st._annihilation_checks_start or 0)

			-- Compute backward-compatible aggregates
			local mil_converted = (st.stats.mil_direct or 0) + (st.stats.mil_tier_bump or 0)
				+ (st.stats.mil_civ_unique_archetype or 0) + (st.stats.mil_receiver_class or 0)
				+ (st.stats.mil_generic_archetype or 0) + (st.stats.mil_same_bp or 0)
			local mil_destroyed = (st.stats.mil_destroy_policy or 0) + (st.stats.mil_destroy_age_blocked or 0)
				+ (st.stats.mil_destroy_cap_blocked or 0) + (st.stats.mil_destroy_create_fail or 0)
				+ (st.stats.mil_destroy_no_mapping or 0)
				+ (st.stats.mil_destroy_ratio_skip or 0)
				+ (st.stats.mil_destroy_pop_capped or 0)

			-- Persist last transfer stats for debug commands
			_leaver_last_transfer_stats = {
				src_civ = st.src_civ,
				rcv_civ = st.rcv_civ,
				bldg_converted = st.stats.bldg_converted,
				bldg_transferred = st.stats.bldg_transferred,
				bldg_killed = st.stats.bldg_killed,
				bldg_skipped_dead = st.stats.bldg_skipped_dead or 0,
				bldg_silent_skip = st.stats.bldg_silent_skip or 0,
				bldg_killed_autopop_house = st.stats.bldg_killed_autopop_house or 0,
				bldg_killed_autopop_tc = st.stats.bldg_killed_autopop_tc or 0,
				bldg_q_exact = st.stats.bldg_q_exact or 0,
				bldg_q_parent = st.stats.bldg_q_parent or 0,
				bldg_q_lossy = st.stats.bldg_q_lossy or 0,
				eco_transferred = st.stats.eco_transferred,
				eco_killed = st.stats.eco_killed,
				-- Military conversion routes
				mil_direct = st.stats.mil_direct or 0,
				mil_tier_bump = st.stats.mil_tier_bump or 0,
				mil_civ_unique_archetype = st.stats.mil_civ_unique_archetype or 0,
				mil_receiver_class = st.stats.mil_receiver_class or 0,
				mil_generic_archetype = st.stats.mil_generic_archetype or 0,
				mil_same_bp = st.stats.mil_same_bp or 0,
				mil_transfer_only = st.stats.mil_transfer_only or 0,
				-- Military destroy routes
				mil_destroy_policy = st.stats.mil_destroy_policy or 0,
				mil_destroy_age_blocked = st.stats.mil_destroy_age_blocked or 0,
				mil_bypass_age_spawner_exempt = st.stats.mil_bypass_age_spawner_exempt or 0,
				mil_destroy_cap_blocked = st.stats.mil_destroy_cap_blocked or 0,
				mil_destroy_create_fail = st.stats.mil_destroy_create_fail or 0,
				mil_destroy_no_mapping = st.stats.mil_destroy_no_mapping or 0,
				mil_destroy_ratio_skip = st.stats.mil_destroy_ratio_skip or 0,
				mil_destroy_pop_capped = st.stats.mil_destroy_pop_capped or 0,
				-- Terminal handled-decision accounting
				skipped_dead = st.stats.skipped_dead or 0,
				mil_silent_skip = st.stats.mil_silent_skip or 0,
				-- Backward-compatible aggregates
				mil_converted = mil_converted,
				mil_killed = mil_destroyed,
				pop_bonus = st._pop_bonus,
				entity_total = st.entity_total or 0,
				squad_total = st.squad_total or 0,
				elapsed = elapsed,
				phase_timings = st.phase_timings,
				annihilation_cascade = annihilation_cascade,
			}

			-- Always-on compact pipeline summary (one line per run)
			print(string.format(
				"[LEAVER_END] %s→%s | %.2fs | ent=%d sq=%d | bldg[conv=%d xfer=%d kill=%d dead=%d silent=%d pop_house=%d pop_tc=%d q:e=%d p=%d l=%d] eco[xfer=%d] mil[conv=%d dest=%d same=%d xfer=%d | direct=%d bump=%d unique=%d class=%d generic=%d | d:pol=%d age=%d cap=%d fail=%d nomap=%d ratio=%d popcap=%d | exempt_age=%d] bypass_age=%s bypass_cap=%s",
				st.src_civ, st.rcv_civ, elapsed,
				st.entity_total or 0, st.squad_total or 0,
				st.stats.bldg_converted, st.stats.bldg_transferred, st.stats.bldg_killed,
				st.stats.bldg_skipped_dead or 0, st.stats.bldg_silent_skip or 0,
				st.stats.bldg_killed_autopop_house or 0, st.stats.bldg_killed_autopop_tc or 0,
				st.stats.bldg_q_exact or 0, st.stats.bldg_q_parent or 0, st.stats.bldg_q_lossy or 0,
				st.stats.eco_transferred,
				mil_converted, mil_destroyed,
				st.stats.mil_same_bp or 0, st.stats.mil_transfer_only or 0,
				st.stats.mil_direct or 0, st.stats.mil_tier_bump or 0,
				st.stats.mil_civ_unique_archetype or 0, st.stats.mil_receiver_class or 0,
				st.stats.mil_generic_archetype or 0,
				st.stats.mil_destroy_policy or 0, st.stats.mil_destroy_age_blocked or 0,
				st.stats.mil_destroy_cap_blocked or 0,
				st.stats.mil_destroy_create_fail or 0, st.stats.mil_destroy_no_mapping or 0,
				st.stats.mil_destroy_ratio_skip or 0,
				st.stats.mil_destroy_pop_capped or 0,
				st.stats.mil_bypass_age_spawner_exempt or 0,
				tostring(_LEAVER_DEBUG_BYPASS_GATES), tostring(_LEAVER_DEBUG_BYPASS_CAPABILITY_GATES)))

			-- Terminal handled-decision reconciliation
			local eco_total = st.stats.eco_transferred + st.stats.eco_killed
			local handled_total = eco_total + mil_converted + mil_destroyed + (st.stats.mil_transfer_only or 0)
			local skipped_dead = st.stats.skipped_dead or 0
			local silent_skip = st.stats.mil_silent_skip or 0
			local eligible_total = (st.squad_total or 0) - skipped_dead
			if silent_skip > 0 then
				print(string.format("[LEAVER_FAIL] silent_skip=%d — unhandled squads detected", silent_skip))
			end
			if handled_total ~= eligible_total then
				print(string.format("[LEAVER_FAIL] handled_total=%d != eligible_total=%d (eco=%d mil_conv=%d mil_dest=%d mil_xfer=%d dead=%d)",
					handled_total, eligible_total, eco_total, mil_converted, mil_destroyed, st.stats.mil_transfer_only or 0, skipped_dead))
			else
				print(string.format("[LEAVER_HANDLED] eligible=%d handled=%d (eco=%d mil_conv=%d mil_dest=%d mil_xfer=%d dead=%d silent_skip=%d)",
					eligible_total, handled_total, eco_total, mil_converted, mil_destroyed, st.stats.mil_transfer_only or 0, skipped_dead, silent_skip))
			end

			-- Building handled-decision reconciliation (no silent skip guarantees)
			local bldg_handled = st.stats.bldg_converted + st.stats.bldg_transferred + st.stats.bldg_killed
			local bldg_skipped_dead = st.stats.bldg_skipped_dead or 0
			local bldg_silent_skip = st.stats.bldg_silent_skip or 0
			local bldg_eligible = (st.entity_total or 0) - bldg_skipped_dead
			if bldg_silent_skip > 0 then
				print(string.format("[LEAVER_FAIL] bldg_silent_skip=%d — unhandled buildings detected", bldg_silent_skip))
			end
			if bldg_handled ~= bldg_eligible then
				print(string.format("[LEAVER_FAIL] bldg_handled=%d != bldg_eligible=%d (conv=%d xfer=%d kill=%d dead=%d)",
					bldg_handled, bldg_eligible, st.stats.bldg_converted, st.stats.bldg_transferred, st.stats.bldg_killed, bldg_skipped_dead))
			else
				print(string.format("[LEAVER_BLDG_HANDLED] eligible=%d handled=%d (conv=%d xfer=%d kill=%d dead=%d silent_skip=%d)",
					bldg_eligible, bldg_handled, st.stats.bldg_converted, st.stats.bldg_transferred,
					st.stats.bldg_killed, bldg_skipped_dead, bldg_silent_skip))
			end

			-- Always-on audit summary (unconditional — explains 0-entry case)
			-- Sort decision keys for deterministic log diffs across runs.
			if #_LEAVER_AUDIT_LOG > 0 then
				local counts = {}
				for _, entry in ipairs(_LEAVER_AUDIT_LOG) do
					local d = entry.decision or "UNKNOWN"
					counts[d] = (counts[d] or 0) + 1
				end
				local sorted_keys = {}
				for d, _ in pairs(counts) do
					table.insert(sorted_keys, d)
				end
				table.sort(sorted_keys)
				local parts = {}
				for _, d in ipairs(sorted_keys) do
					table.insert(parts, string.format("%s=%d", d, counts[d]))
				end
				print(string.format("[LEAVER_AUDIT] %d entries: %s",
					#_LEAVER_AUDIT_LOG, table.concat(parts, ", ")))
			else
				print(string.format("[LEAVER_AUDIT] 0 entries — all paths resolved to same-BP or transfer-only (same=%d xfer=%d)",
					st.stats.mil_same_bp or 0, st.stats.mil_transfer_only or 0))
			end

			-- Verbose: per-phase timing + full entry dump
			if _LEAVER_DEBUG_VERBOSE then
				local pt = st.phase_timings or {}
				local p3 = (pt.phase3_end and st.start_time) and (pt.phase3_end - st.start_time) or -1
				local p45 = (pt.phase45_end and pt.phase3_end) and (pt.phase45_end - pt.phase3_end) or -1
				local p7 = (pt.phase7_end and pt.phase45_end) and (pt.phase7_end - pt.phase45_end) or -1
				print(string.format("[LEAVER_DETAIL] Phase3=%.2fs Phase4+5=%.2fs Phase7=%.2fs | annihilation_checks=%d",
					p3, p45, p7, annihilation_cascade))
				print(string.format("[LEAVER_DETAIL] routes: direct=%d bump=%d unique=%d class=%d generic=%d same=%d xfer=%d | destroy: pol=%d age=%d cap=%d fail=%d nomap=%d ratio=%d | exempt_age=%d eco_killed=%d",
					st.stats.mil_direct or 0, st.stats.mil_tier_bump or 0,
					st.stats.mil_civ_unique_archetype or 0, st.stats.mil_receiver_class or 0,
					st.stats.mil_generic_archetype or 0, st.stats.mil_same_bp or 0,
					st.stats.mil_transfer_only or 0,
					st.stats.mil_destroy_policy or 0, st.stats.mil_destroy_age_blocked or 0,
					st.stats.mil_destroy_cap_blocked or 0,
					st.stats.mil_destroy_create_fail or 0, st.stats.mil_destroy_no_mapping or 0,
					st.stats.mil_destroy_ratio_skip or 0, st.stats.mil_bypass_age_spawner_exempt or 0, st.stats.eco_killed or 0))
				print(string.format("[LEAVER_DETAIL] bldg_quality: exact=%d parent=%d lossy=%d",
					st.stats.bldg_q_exact or 0, st.stats.bldg_q_parent or 0, st.stats.bldg_q_lossy or 0))
				-- Dump individual audit entries when verbose
				for i, entry in ipairs(_LEAVER_AUDIT_LOG) do
					local detail
					if entry.upgrade ~= nil then
						detail = string.format("upgrade=%s", entry.upgrade)
					else
						detail = string.format("age %s/%s", tostring(entry.actual or ""), tostring(entry.required or ""))
					end
					print(string.format("[LEAVER_DETAIL] #%d %s | %s | %s | %s",
						i, entry.decision or "?", entry.bp or "?",
						detail, entry.context or ""))
				end
			end
			_LEAVER_AUDIT_LOG = {}
			_LEAVER_CAP_CACHE = {}

			-- Resume interval rules that were paused at pipeline start.
			_Leaver_ResumeIntervalRules()

			-- Disconnect cleanup: destroy the disconnected player's ORIGINAL
			-- starter Keep AFTER the leaver pipeline has transferred ownership.
			-- Use Entity_Destroy (no kill event) so the new owner is NOT
			-- credited with losing a building -- Annihilation_OnEntityKilled
			-- never fires, so the recipient cannot be eliminated as a side
			-- effect of this cleanup.  Surrender/genuine elimination paths
			-- skip this: the keep was either already destroyed or the player
			-- chose to leave their assets behind.
			local victim_id = st.victim_id
			local victim_entry = victim_id and Core_GetPlayersTableEntry(victim_id) or nil
			if victim_entry ~= nil
					and victim_entry.eliminationReason == "disconnect"
					and victim_entry.keep ~= nil
					and victim_entry.keep.entity_id ~= nil
					and Entity_IsValid(victim_entry.keep.entity_id) then
				local keep_eid = victim_entry.keep.entity_id
				if _LEAVER_DEBUG_VERBOSE then
					local ok_owner, owner_pid = pcall(Entity_GetPlayerOwner, Entity_FromID(keep_eid))
					print(string.format("[LEAVER_XFER] disconnect cleanup: destroying original starter Keep eid=%s currentOwner=%s",
						tostring(keep_eid), ok_owner and tostring(owner_pid) or "?"))
				end
				_mod.castles[keep_eid] = nil
				pcall(Entity_Destroy, Entity_FromID(keep_eid))
				victim_entry.keep.entity = nil
				victim_entry.keep.entity_id = nil
			end

			_leaver_transfer_state = nil

			-- PERF: Single post-transfer LimitsUI reconciliation (replaces N skipped updates during pipeline)
			if type(AGS_LimitsUI_DeferUpdate) == "function" then
				AGS_LimitsUI_DeferUpdate("leaver_complete")
			end

			return
		end

	end -- phase dispatch
	end -- while true
end

---------------------------------------------------------------------------------------------------
-- Performance: Annihilation cascade counter (incremented by annihilation check, read by pipeline)
---------------------------------------------------------------------------------------------------
_LEAVER_PERF_ANNIHILATION_CHECKS = 0

---------------------------------------------------------------------------------------------------
-- Performance: Interval rule pause/resume during leaver processing
-- Pauses Religious_Update and SiegeLimit_Reconcile to free frame budget during mass entity
-- destruction. Rules are restored at pipeline completion.
---------------------------------------------------------------------------------------------------
_LEAVER_RULES_PAUSED = false

function _Leaver_PauseIntervalRules()
	if _LEAVER_RULES_PAUSED then return end
	_LEAVER_RULES_PAUSED = true
	pcall(Rule_Remove, CBA_Options_SiegeLimit_Reconcile)
	if type(Religious_Update) == "function" then
		pcall(Rule_Remove, Religious_Update)
	end
end

function _Leaver_ResumeIntervalRules()
	if not _LEAVER_RULES_PAUSED then return end
	_LEAVER_RULES_PAUSED = false
	-- Abort if teardown already started — do not re-register cleaned-up rules
	if _onslaught_teardown_detected then return end
	-- Restore SiegeLimit_Reconcile with original stagger interval
	local stagger = math.max(0.25, 3.0 / math.max(1, #PLAYERS))
	pcall(Rule_AddInterval, CBA_Options_SiegeLimit_Reconcile, stagger)
	-- Restore Religious_Update if the module is still registered
	if type(Religious_Update) == "function" and _religious ~= nil then
		pcall(Rule_AddInterval, Religious_Update, _religious.update_interval or 1.0)
	end
end

import("debug/cba_debug_autopop.scar")           -- Auto-population validation and reconciliation debugging
