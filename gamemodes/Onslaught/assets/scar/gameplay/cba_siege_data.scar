---------------------------------------------------------------------------------------------------
-- Canonical Siege Tag Registry
-- Single source of truth for type-tag classification across all limit subsystems.
-- Used by: cba_options.scar (enforcement), cba.scar (events), cba_debug_inspectors.scar (validator)
--
-- Limit subsystems and their tag logic:
--   Ram limit:         Squad/Entity matches ANY tag in ram_tags (OR) → weight 1
--   Ram tower:         Squad/Entity matches ram_tower_tag → weight 2 (ram limit)
--   Siege tower limit: Squad matches siege_gate_tag AND siege_tower_tag (AND)
--   General siege:     Squad/Entity matches siege_gate_tag
---------------------------------------------------------------------------------------------------
CBA_SIEGE_TAG_REGISTRY = {

	-- Tags checked by the ram limit system (OR-logic: any one match counts)
	ram_tags = { "ram", "scar_ram", "fire_ram", "scar_fire_ram" },

	-- Special ram tower tag (weight-2 in ram limit; checked via IsRamTower* helpers)
	ram_tower_tag = "ram_tower",

	-- Tags checked by the siege tower limit system (AND-logic: both required on the unit)
	siege_tower_tag = "siege_tower",

	-- Generic siege gate tag (prerequisite filter in recount, queue cancel, point limit)
	siege_gate_tag = "siege",

	-- Ram weight per classification
	ram_weight = {
		ram       = 1,
		ram_tower = 2,
	},

	-- Per-key classification for every CBA_SIEGE_TABLE key.
	-- Maps table key → limit category so the validator knows what to check.
	--
	-- Categories:
	--   "ram"       → ram limit (weight 1); expects ≥1 of ram_tags + siege_gate_tag
	--   "ram_tower" → ram limit (weight 2); expects ram_tower_tag + siege_gate_tag
	--   "tower"     → siege tower limit;    expects siege_gate_tag + siege_tower_tag
	--   "weapon"    → general siege points;  expects siege_gate_tag
	--   "buildable" → entity-side field construction; expects siege_gate_tag
	--   "building"  → siege workshop structure; excluded from unit limit validation
	key_class = {
		-- Ram class
		ram              = "ram",
		workshop_ram     = "ram",
		ram_tower        = "ram_tower",
		-- Siege tower class
		siege_tower      = "tower",
		-- Generic siege weapons (all factions)
		springald        = "weapon",
		mangonel         = "weapon",
		ribauldequin     = "weapon",
		culverin         = "weapon",
		cannon           = "weapon",
		bombard          = "weapon",
		trebuchet_cw     = "weapon",
		trebuchet_tr     = "weapon",
		-- Chinese unique
		nest_of_bees              = "weapon",
		nestofbees_clocktower_chi = "weapon",
		mangonel_clocktower_chi   = "weapon",
		springald_clocktower_chi  = "weapon",
		trebuchet_clocktower_chi  = "weapon",
		bombard_clocktower_chi    = "weapon",
		-- French unique
		royal_cannon       = "weapon",
		royal_culverin     = "weapon",
		royal_ribauldequin = "weapon",
		-- Mongol doubles
		springald_double     = "weapon",
		mangonel_double      = "weapon",
		ribauldequin_double  = "weapon",
		culverin_double      = "weapon",
		cannon_double        = "weapon",
		bombard_double       = "weapon",
		trebuchet_cw_double  = "weapon",
		trebuchet_tr_double  = "weapon",
		-- Field-constructible (entity-side blueprints)
		springald_buildable   = "buildable",
		mangonel_buildable    = "buildable",
		trebuchet_tr_buildable = "buildable",
		trebuchet_cw_buildable = "buildable",
		-- Building (siege workshop — not a combat unit)
		scar_siegeworkshop = "building",
	},

	-- Expected minimum type tags per classification.
	-- The validator checks: does the resolved SBP/EBP expose at least these tags?
	expected_tags = {
		ram       = { "siege", "ram" },         -- plus variant tags (scar_ram, fire_ram, etc.) accepted
		ram_tower = { "siege", "ram_tower" },
		tower     = { "siege", "siege_tower" },
		weapon    = { "siege" },
		buildable = { "siege" },
		building  = {},                         -- no siege unit tags expected
	},

	-- Tags accepted as equivalent to "ram" in the ram limit system.
	-- Any ONE of these satisfies the ram-class requirement.
	ram_equivalent_tags = { "ram", "scar_ram", "fire_ram", "scar_fire_ram" },

	-- All civs that should have entries in CBA_SIEGE_TABLE (direct, not fallback).
	-- Used by the validator to confirm completeness.
	expected_direct_civs = {
		"english", "chinese", "french", "hre", "rus", "abbasid", "mongol",
		"sultanate", "malian", "ottoman", "japanese", "byzantine",
		"abbasid_ha_01", "chinese_ha_01", "french_ha_01", "hre_ha_01",
		"mongol_ha_gol", "lancaster", "templar", "byzantine_ha_mac", "japanese_ha_sen", "sultanate_ha_tug",
	},

	-- Minimum set of keys every standard civ should have (base siege loadout).
	-- Civ-specific extras (nest_of_bees, royal_*, doubles, etc.) are validated separately.
	required_base_keys = {
		"ram", "workshop_ram", "springald", "mangonel", "ribauldequin",
		"culverin", "cannon", "bombard", "trebuchet_cw", "trebuchet_tr",
		"scar_siegeworkshop", "siege_tower",
	},

	-- Civ-specific required extras beyond required_base_keys.
	required_civ_extras = {
		chinese = {
			"nest_of_bees", "nestofbees_clocktower_chi", "mangonel_clocktower_chi",
			"springald_clocktower_chi", "trebuchet_clocktower_chi", "bombard_clocktower_chi",
		},
		chinese_ha_01 = { "nest_of_bees" },
		french = { "royal_cannon", "royal_culverin", "royal_ribauldequin" },
		french_ha_01 = { "royal_cannon", "royal_culverin", "royal_ribauldequin" },
		abbasid = { "springald_buildable", "mangonel_buildable" },
		mongol = {
			"springald_buildable", "mangonel_buildable",
			"trebuchet_tr_buildable", "trebuchet_cw_buildable",
			"trebuchet_cw_double", "trebuchet_tr_double",
			"springald_double", "mangonel_double", "ribauldequin_double",
			"culverin_double", "cannon_double", "bombard_double",
		},
		abbasid_ha_01 = { "ram_tower", "springald_buildable", "mangonel_buildable" },
	},
}

