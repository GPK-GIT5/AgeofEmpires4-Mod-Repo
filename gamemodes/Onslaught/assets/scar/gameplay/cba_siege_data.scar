-- Siege
function AGS_GetSiegeEntity(player_civ, bp_type)
	local civ_table = CBA_SIEGE_TABLE[player_civ]
	if civ_table == nil and AGS_CIV_FACTION_MAP[player_civ] ~= nil then
		-- WARNING: All known civs now have own siege tables; this path is dead code.
		-- If this fires, a new variant civ was added without a CBA_SIEGE_TABLE entry.
		local parent = AGS_CIV_FACTION_MAP[player_civ]
		print(string.format("[AGS_WARN] Siege entity table fallback fired for '%s' -> '%s' (add CBA_SIEGE_TABLE entry)", player_civ, parent))
		civ_table = CBA_SIEGE_TABLE[parent]
	end
	if civ_table == nil then return nil end
	local bp = civ_table[bp_type]
	if bp == nil or bp == false then return nil end
	return BP_GetEntityBlueprint(bp)
end

function AGS_GetSiegeUnit(player_civ, bp_type)
	local civ_table = CBA_SIEGE_TABLE[player_civ]
	if civ_table == nil and AGS_CIV_FACTION_MAP[player_civ] ~= nil then
		local parent = AGS_CIV_FACTION_MAP[player_civ]
		print(string.format("[AGS_WARN] Siege unit table fallback fired for '%s' -> '%s' (add CBA_SIEGE_TABLE entry)", player_civ, parent))
		civ_table = CBA_SIEGE_TABLE[parent]
	end
	if civ_table == nil then return nil end
	local bp = civ_table[bp_type]
	if bp == nil or bp == false then return nil end
	return BP_GetSquadBlueprint(bp)
end
