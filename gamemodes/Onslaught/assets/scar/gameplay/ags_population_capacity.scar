---------------------------------------------------------------------------------------------------
-- Authors:
-- Relic
-- Woprock
--
-- Description:
-- Alters players population limits.
-- Edit @ Compatability with Population Automatic
-- Edit @ Duplicated original functions to work with Medic Capacity for limiting ships
---------------------------------------------------------------------------------------------------

AGS_POPULATION_CAPACITY_MODULE = "AGS_PopulationCapacity"
AGS_MedicPopulation_CAPACITY_MODULE = "AGS_MedicPopulationCapacity"

---------------------------------------------------------------------------------------------------
-- Delegates:
---------------------------------------------------------------------------------------------------

Core_RegisterModule(AGS_POPULATION_CAPACITY_MODULE)	

function AGS_PopulationCapacity_UpdateModuleSettings()
	AGS_Print("AGS_PopulationCapacity_UpdateModuleSettings")
	local minimum_population, maximum_population = AGS_PopulationCapacity_NormalizeSettings()
	if maximum_population == 200 and minimum_population == 0 then
		Core_UnregisterModule(AGS_POPULATION_CAPACITY_MODULE)
	end
end

function AGS_PopulationCapacity_AdjustSettings()
	AGS_Print("AGS_PopulationCapacity_AdjustSettings")
	AGS_PopulationCapacity_NormalizeSettings()
end

function AGS_PopulationCapacity_PresetFinalize()
	AGS_Print("AGS_PopulationCapacity_PresetFinalize")
	AGS_PopulationCapacity_Change()
end

-- Medic/Ship Capacity
Core_RegisterModule(AGS_MedicPopulation_CAPACITY_MODULE)	

function AGS_MedicPopulationCapacity_UpdateModuleSettings()
	AGS_Print("AGS_MedicPopulationCapacity_UpdateModuleSettings")
	if AGS_PopulationCapacity_GetNumericSetting("MaximumMedicPopulation", 0) == 0 then
		Core_UnregisterModule(AGS_MedicPopulation_CAPACITY_MODULE)
	end
end

function AGS_MedicPopulationCapacity_PresetFinalize()
	AGS_Print("AGS_MedicPopulationCapacity_PresetFinalize")
	AGS_MedicPopulationCapacity_Change()
end
---------------------------------------------------------------------------------------------------
-- Functions:
---------------------------------------------------------------------------------------------------

function AGS_PopulationCapacity_GetNumericSetting(setting_name, default_value)
	if AGS_GLOBAL_SETTINGS == nil then
		return default_value
	end

	local value = AGS_GLOBAL_SETTINGS[setting_name]
	if type(value) ~= "number" then
		AGS_GLOBAL_SETTINGS[setting_name] = default_value
		return default_value
	end

	return value
end

function AGS_PopulationCapacity_NormalizeSettings()
	local maximum_population = AGS_PopulationCapacity_GetNumericSetting("MaximumPopulation", 200)
	local minimum_population = AGS_PopulationCapacity_GetNumericSetting("MinimumPopulation", 0)

	if minimum_population > maximum_population then
		minimum_population = maximum_population
		if AGS_GLOBAL_SETTINGS ~= nil then
			AGS_GLOBAL_SETTINGS.MinimumPopulation = minimum_population
		end
	end

	AGS_PopulationCapacity_GetNumericSetting("MaximumMedicPopulation", 0)

	return minimum_population, maximum_population
end

function AGS_PopulationCapacity_Change()
	local minimum_population, maximum_population = AGS_PopulationCapacity_NormalizeSettings()

	for _, player in pairs(PLAYERS) do		
		AGS_PopulationCapacity_ApplyMaxCapPopulation(player, maximum_population)
		AGS_PopulationCapacity_SetMinPopulation(player, minimum_population) 
	end
end

function AGS_PopulationCapacity_SetMinPopulation(player, pop_size)
	local value = pop_size
--[[ Mongols receive always maximum to maintain their unique bonus.
	if _mod.pop_cap_incease_on_interval == 0 then -- Check if Population_Automatic is enabled
		if player.raceName == AGS_CIV_MONGOL then
			if AGS_GLOBAL_SETTINGS.MinimumPopulationReset then
				value = value - 200			
			else
				value = AGS_GLOBAL_SETTINGS.MaximumPopulation - 200
			end	
		end
	end	
]]
	AGS_PopulationCapacity_ApplyMinPopulation(player, value)
	
end
	
function AGS_PopulationCapacity_ApplyMinPopulation(player, pop_size)
	Modifier_ApplyToPlayer(Modifier_Create(MAT_Player, "personnel_cap_player_modifier", MUT_Addition, false, pop_size, ""), player.id, 0)
end

function AGS_PopulationCapacity_ApplyMaxCapPopulation(player, pop_size)
	pop_size = pop_size or AGS_PopulationCapacity_GetNumericSetting("MaximumPopulation", 200)
	local value = - (200 - pop_size)
	Modifier_ApplyToPlayer(Modifier_Create(MAT_Player, "max_personnel_cap_player_modifier", MUT_Addition, false, value, ""), player.id, 0)
end

-- Medic/Ship Capacity
function AGS_MedicPopulationCapacity_Change()
	local max_medic_population = AGS_PopulationCapacity_GetNumericSetting("MaximumMedicPopulation", 0)

	for _, player in pairs(PLAYERS) do		
		AGS_MedicPopulationCapacity_ApplyMaxCapMedicPopulation(player, max_medic_population)
		AGS_MedicPopulationCapacity_SetMinMedicPopulation(player, max_medic_population) 
	end
end

function AGS_MedicPopulationCapacity_SetMinMedicPopulation(player, pop_size)
	local value = pop_size
	AGS_MedicPopulationCapacity_ApplyMinMedicPopulation(player, value)
	
end

function AGS_MedicPopulationCapacity_ApplyMinMedicPopulation(player, pop_size)
	Modifier_ApplyToPlayer(Modifier_Create(MAT_Player, "medic_cap_player_modifier", MUT_Addition, false, pop_size, ""), player.id, 0)
end

function AGS_MedicPopulationCapacity_ApplyMaxCapMedicPopulation(player, pop_size)
	local value = - (0 - pop_size)
	Modifier_ApplyToPlayer(Modifier_Create(MAT_Player, "max_medic_cap_player_modifier", MUT_Addition, false, pop_size, ""), player.id, 0)
end