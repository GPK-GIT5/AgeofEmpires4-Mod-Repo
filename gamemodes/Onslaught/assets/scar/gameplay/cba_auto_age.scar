---------------------------------------------------------------------------------------------------
-- Delegates:
---------------------------------------------------------------------------------------------------

Core_RegisterModule(CBA_AUTO_AGE_AUTOAGE_MODULE)	

function CBA_AutoAge_UpdateModuleSettings()
	AGS_Print("CBA_AutoAge_UpdateModuleSettings")
	if AGS_GLOBAL_SETTINGS.AutoAge == 0 or AGS_GLOBAL_SETTINGS.StartingAge == AGS_GS_AGE_IMPERIAL then
		Core_UnregisterModule(CBA_AUTO_AGE_AUTOAGE_MODULE)
	end
end

function CBA_AutoAge_PresetFinalize()
	AGS_Print("CBA_AutoAge_PresetFinalize")
	
	-- Functions
	_AUTOAGE_DIAG_PASS = 0
	CBA_AutoAge_SetMaxAge()
	Rule_AddOneShot(CBA_AutoAge_ReapplyStartingRestrictions, 1)
	Rule_AddOneShot(CBA_AutoAge_ReapplyStartingRestrictions, 3)
	Rule_AddOneShot(CBA_AutoAge_ReapplyStartingRestrictions, 5)
	CBA_AutoAge_SetupObjective()
	CBA_Auto_Age()
	-- Rules
	Rule_AddInterval(CBA_AutoAge_UpdateTimer, 1)
	Rule_AddGlobalEvent(CBA_AutoAge_ConstructionComplete, GE_ConstructionComplete)
	Rule_AddGlobalEvent(CBA_AutoAge_UpgradeComplete, GE_UpgradeComplete)
	
end

function CBA_AutoAge_PlayerHasAnyUpgrade(player_id, upgrades)
	for _, upg_name in ipairs(upgrades) do
		local ok_bp, ubp = pcall(BP_GetUpgradeBlueprint, upg_name)
		if not ok_bp then
			ubp = nil
		end
		if ubp ~= nil and Player_HasUpgrade(player_id, ubp) then
			return true
		end
	end
	return false
end

function CBA_AutoAge_SetUpgradeAvailabilitySafe(player_id, upg_name, lock_type, context)
	local ok_bp, ubp = pcall(BP_GetUpgradeBlueprint, upg_name)
	if not ok_bp or ubp == nil then
		print(string.format("[AUTOAGE][WARN] missing upgrade blueprint context=%s name=%s",
			tostring(context), tostring(upg_name)))
		return false
	end

	local ok_set = pcall(Player_SetUpgradeAvailability, player_id, ubp, lock_type)
	if not ok_set then
		print(string.format("[AUTOAGE][WARN] failed Player_SetUpgradeAvailability context=%s player=%s name=%s lock=%s",
			tostring(context), tostring(player_id), tostring(upg_name), tostring(lock_type)))
		return false
	end

	return true
end

-- Golden Tent building is now unrestricted; upgrades remain controlled via SyncSpecialUpgradeAvailability.
-- Retained as a no-op stub for call-site compatibility.
function CBA_AutoAge_EnforceGoldenTentLock(player, context)
	return false
end

