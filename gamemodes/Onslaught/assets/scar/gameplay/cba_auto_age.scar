		end
	end
end

---------------------------------------------------------------------------------------------------
-- Cross-civ menu lock validation (debug / console-callable)
-- Iterates all players and all expected menu names, reports success/failure per civ.
-- Usage: CBA_AutoAge_ValidateAllMenuLocks()
---------------------------------------------------------------------------------------------------

function CBA_AutoAge_ValidateAllMenuLocks()
	if PLAYERS == nil then
		print("[AUTOAGE][VALIDATE] PLAYERS table is nil")
		return
	end

	print("[AUTOAGE][VALIDATE] === Menu Lock Validation Start ===")

	local total_ok = 0
	local total_fail = 0
	local total_skip = 0

	for _, player in ipairs(PLAYERS) do
		if player.isEliminated then
			total_skip = total_skip + 1
		else
			local resolvedRace, rawRace = CBA_AutoAge_ResolveRaceName(player.id)
			local maxAge = Player_GetStateModelInt(player.id, "player_max_age")
			local curAge = Player_GetCurrentAge(player.id)
			local civMenus = _AUTOAGE_CIV_MENUS[resolvedRace]

			print(string.format("[AUTOAGE][VALIDATE] player=%s raw=%s resolved=%s curAge=%d maxAge=%s",
				tostring(player.id), tostring(rawRace), tostring(resolvedRace),
				curAge, tostring(maxAge)))

			if civMenus == nil then
				print(string.format("[AUTOAGE][VALIDATE]   WARN: no _AUTOAGE_CIV_MENUS entry for %s", tostring(resolvedRace)))
				total_fail = total_fail + 1
			else
				-- Test age menus: probe each candidate with ITEM_DEFAULT then re-lock if needed
				for age = 2, 4 do
					local candidates = civMenus.age_menus and civMenus.age_menus[age]
					if candidates ~= nil then
						for _, menuName in ipairs(candidates) do
							local ok = CBA_AutoAge_SetConstructionMenuAvailabilitySafe(
								player.id, menuName, ITEM_DEFAULT, "validate/age" .. age, true)
							local status = ok and "OK" or "FAIL"
							print(string.format("[AUTOAGE][VALIDATE]   age%d menu=%s %s", age, menuName, status))
							if ok then total_ok = total_ok + 1 else total_fail = total_fail + 1 end
							-- Re-lock if this age should be locked
							if ok and maxAge ~= nil and maxAge > 0 and maxAge < age then
								CBA_AutoAge_SetConstructionMenuAvailabilitySafe(
									player.id, menuName, ITEM_REMOVED, "validate/relock", true)
							end
						end
					end
				end

				-- Test wonder menus (non-wing civs only)
				local wingCfg = _AUTOAGE_WING_UPGRADES[resolvedRace]
				if wingCfg == nil and civMenus.wonder_menus ~= nil then
					for wonderAge = 1, 3 do
						local candidates = civMenus.wonder_menus[wonderAge]
						if candidates ~= nil then
							for _, menuName in ipairs(candidates) do
								local ok = CBA_AutoAge_SetConstructionMenuAvailabilitySafe(
									player.id, menuName, ITEM_DEFAULT, "validate/wonder" .. wonderAge, true)
								local status = ok and "OK" or "FAIL"
								print(string.format("[AUTOAGE][VALIDATE]   wonder%d menu=%s %s", wonderAge, menuName, status))
								if ok then total_ok = total_ok + 1 else total_fail = total_fail + 1 end
								-- Re-lock if this wonder age should be locked
								if ok and maxAge ~= nil and maxAge > 0 and maxAge < (wonderAge + 1) then
									CBA_AutoAge_SetConstructionMenuAvailabilitySafe(
										player.id, menuName, ITEM_REMOVED, "validate/relock", true)
								end
							end
						end
					end
				end
			end
		end
	end

	print(string.format("[AUTOAGE][VALIDATE] === Summary: ok=%d fail=%d skip=%d ===",
		total_ok, total_fail, total_skip))
end

---------------------------------------------------------------------------------------------------
-- Enhanced debug commands (console-callable)
---------------------------------------------------------------------------------------------------

-- Dumps full auto-age state for all players. Usage: CBA_AutoAge_Dump()
function CBA_AutoAge_Dump()
	if PLAYERS == nil then
		print("[AUTOAGE][DUMP] PLAYERS table is nil")
		return
	end
	print("[AUTOAGE][DUMP] ============================================================")
	print(string.format("[AUTOAGE][DUMP] StartingAge=%s AutoAge=%s DiagEnabled=%s DiagPass=%s",
		tostring(AGS_GLOBAL_SETTINGS.StartingAge), tostring(AGS_GLOBAL_SETTINGS.AutoAge),
		tostring(_AUTOAGE_DIAG_ENABLED), tostring(_AUTOAGE_DIAG_PASS)))
	for i, player in ipairs(PLAYERS) do
		if player ~= nil and player.id ~= nil then
			local civ = "<unknown>"
			local ok_c, cn = pcall(Player_GetRaceName, player.id)
			if ok_c and cn ~= nil then civ = tostring(cn) end
			local resolved, raw = CBA_AutoAge_ResolveRaceName(player.id)
			local age = Player_GetCurrentAge(player.id)
			local max_age = Player_GetStateModelInt(player.id, "player_max_age")
			local is_special = _AUTOAGE_SPECIAL_UPGRADES[civ] ~= nil
			local needs_force = _AUTOAGE_SPECIAL_NEEDS_FORCE_AGE[civ] == true
			local has_menus = _AUTOAGE_CIV_MENUS[tostring(resolved)] ~= nil
			local prefix = AGS_CIV_PREFIXES[tostring(resolved)]
			print(string.format("[AUTOAGE][DUMP] PLAYERS[%d] id=%s civ=%s resolved=%s raw=%s prefix=%s age=%d max_age=%s build_count=%s isLocal=%s isElim=%s isSpecial=%s needsForce=%s hasMenus=%s",
				i, tostring(player.id), civ, tostring(resolved), tostring(raw),
				tostring(prefix), age, tostring(max_age), tostring(player.obj_build_count),
				tostring(player.isLocal), tostring(player.isEliminated),
				tostring(is_special), tostring(needs_force), tostring(has_menus)))

			-- Report special upgrade progress if applicable
			if is_special then
				local civ_cfg = _AUTOAGE_SPECIAL_UPGRADES[civ]
				for _, tier in ipairs({"feudal", "castle", "imperial"}) do
					local has = civ_cfg[tier] ~= nil and CBA_AutoAge_PlayerHasAnyUpgrade(player.id, civ_cfg[tier])
					print(string.format("[AUTOAGE][DUMP]   special_tier=%s has_upgrade=%s", tier, tostring(has)))
				end
			end
		end
	end
	print("[AUTOAGE][DUMP] ============================================================")
end

-- Force age-up for the local human player. Auto-selects the local player.
-- Usage: CBA_AutoAge_ForceAge()         -- advance one age tier
-- Usage: CBA_AutoAge_ForceAge(4)        -- force to Age IV directly
-- Usage: CBA_AutoAge_ForceAge(nil, 2)   -- target specific PLAYERS[n]
function CBA_AutoAge_ForceAge(target_age, player_index)
	local player = nil
	if player_index ~= nil then
		player = PLAYERS[player_index]
	else
		-- Auto-select the local human player
		for _, p in ipairs(PLAYERS) do
			if p.isLocal and not p.isEliminated then
				player = p
				break
			end
		end
	end
	if player == nil or player.id == nil then
		print("[AUTOAGE][FORCE] ERROR: no valid player found")
		return
	end

	local civ = "<unknown>"
	local ok_c, cn = pcall(Player_GetRaceName, player.id)
	if ok_c and cn ~= nil then civ = tostring(cn) end
	local age_before = Player_GetCurrentAge(player.id)

	if target_age ~= nil and target_age >= 1 and target_age <= 4 then
		-- Direct force to specific age: set build_count AND max_age, then advance
		print(string.format("[AUTOAGE][FORCE] forcing player=%s civ=%s from age %d to %d",
			tostring(player.id), civ, age_before, target_age))
		player.obj_build_count = target_age
		Player_SetStateModelInt(player.id, "player_max_age", target_age)
		CBA_AutoAge_SetMaximumAge(player.id, target_age)
		if target_age > age_before then
			Player_SetCurrentAge(player.id, target_age)
			CBA_Options_RevalidateAll(player)
			CBA_AutoAge_ReassertPlayerLocks(player)
		end
		-- Handle special civ upgrades for each tier up to target
		local is_special = _AUTOAGE_SPECIAL_UPGRADES[civ] ~= nil
		if is_special then
			for t = age_before + 1, target_age do
				CBA_AutoAge_HandleSpecialAgeTrigger(player, t, "CBA_AutoAge_ForceAge")
			end
		end
		CBA_AutoAge_ReconcileSpecialProgress(player)
		CBA_AutoAge_SyncSpecialUpgradeAvailability(player)
	else
		-- One-step: advance by one tier (same as AgeUp but auto-selecting local player)
		print(string.format("[AUTOAGE][FORCE] stepping player=%s civ=%s from age %d",
			tostring(player.id), civ, age_before))
		-- Set build_count to next age to ensure TryAdvanceAge can advance
		local next_age = age_before + 1
		if next_age <= 4 then
			if player.obj_build_count == nil or player.obj_build_count < next_age then
				player.obj_build_count = next_age
			end
			CBA_Auto_Age_AgeUp(player)
		end
	end

	local age_after = Player_GetCurrentAge(player.id)
	print(string.format("[AUTOAGE][FORCE] DONE player=%s civ=%s age=%d->%d build_count=%s max_age=%s",
		tostring(player.id), civ, age_before, age_after,
		tostring(player.obj_build_count),
		tostring(Player_GetStateModelInt(player.id, "player_max_age"))))
end

-- Unlocks the next age tier for the local human player WITHOUT forcing age-up.
-- The player must still construct a landmark (or pick a special upgrade) to actually advance.
-- Simulates what the auto-age timer does when it fires.
-- Usage: CBA_AutoAge_Unlock()          -- unlock one tier
-- Usage: CBA_AutoAge_Unlock(4)         -- unlock up to Age IV
-- Usage: CBA_AutoAge_Unlock(nil, 2)    -- target specific PLAYERS[n]
function CBA_AutoAge_Unlock(target_max_age, player_index)
	local player = nil
	if player_index ~= nil then
		player = PLAYERS[player_index]
	else
		for _, p in ipairs(PLAYERS) do
			if p.isLocal and not p.isEliminated then
				player = p
				break
			end
		end
	end
	if player == nil or player.id == nil then
		print("[AUTOAGE][UNLOCK] ERROR: no valid player found")
		return
	end

	local civ = "<unknown>"
	local ok_c, cn = pcall(Player_GetRaceName, player.id)
	if ok_c and cn ~= nil then civ = tostring(cn) end
	local age = Player_GetCurrentAge(player.id)
	local current_max = Player_GetStateModelInt(player.id, "player_max_age")
	if current_max == nil or current_max <= 0 then current_max = age end

	-- Determine unlock target
	local unlock_to = nil
	if target_max_age ~= nil and target_max_age >= 1 and target_max_age <= 4 then
		unlock_to = target_max_age
	else
		-- One step: unlock next tier above current max_age
		unlock_to = math.min(current_max + 1, 4)
	end

	if unlock_to <= current_max then
		print(string.format("[AUTOAGE][UNLOCK] NO-OP player=%s civ=%s age=%d max_age already=%d unlock_to=%d",
			tostring(player.id), civ, age, current_max, unlock_to))
		return
	end

	print(string.format("[AUTOAGE][UNLOCK] unlocking player=%s civ=%s age=%d max_age=%d->%d (player must build landmark to advance)",
		tostring(player.id), civ, age, current_max, unlock_to))

	-- Unlock each tier sequentially, same as Auto_Age_1/2/3 timers do
	for tier = current_max + 1, unlock_to do
		local age_const = ({AGE_DARK, AGE_FEUDAL, AGE_CASTLE, AGE_IMPERIAL})[tier]
		if age_const ~= nil then
			CBA_AutoAge_SetMaximumAge(player.id, age_const)
			CBA_AutoAge_HandleSpecialAgeTrigger(player, tier, "CBA_AutoAge_Unlock")
			CBA_AutoAge_SyncSpecialUpgradeAvailability(player)
		end
	end

	-- TryAdvanceAge will only advance if obj_build_count already justifies it
	CBA_AutoAge_TryAdvanceAge(player)

	local new_max = Player_GetStateModelInt(player.id, "player_max_age")
	print(string.format("[AUTOAGE][UNLOCK] DONE player=%s civ=%s age=%d max_age=%s build_count=%s",
		tostring(player.id), civ, Player_GetCurrentAge(player.id),
		tostring(new_max), tostring(player.obj_build_count)))
end

