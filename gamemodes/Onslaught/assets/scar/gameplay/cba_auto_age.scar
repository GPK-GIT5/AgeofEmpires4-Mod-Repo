-- Diagnostic tracking: set true to always print menu lock diagnostics (even without _AUTOAGE_DEBUG_LOGS).
-- Automatically enabled for the first lock pass, then disabled after +3s reapply.
_AUTOAGE_DIAG_ENABLED = true
_AUTOAGE_DIAG_PASS = 0

-- Opt-in informational logging; warnings remain enabled by default.
_AUTOAGE_DEBUG_LOGS = false
_AUTOAGE_WARN_ONCE = _AUTOAGE_WARN_ONCE or {}

local function _AutoAge_ShouldLogInfo()
	if _AUTOAGE_DEBUG_LOGS == true then
		return true
	end
	if _mod ~= nil and _mod.debug == true then
		return true
	end
	if _cba_debug ~= nil and _cba_debug.enabled == true then
		return true
	end
	return false
end

local function _AutoAge_LogInfo(message)
	if _AutoAge_ShouldLogInfo() then
		print(message)
	end
end

local function _AutoAge_LogWarn(message, once_key)
	if once_key ~= nil then
		if _AUTOAGE_WARN_ONCE[once_key] then
			return
		end
		_AUTOAGE_WARN_ONCE[once_key] = true
	end
	print(message)
end

function CBA_AutoAge_ResolveRaceName(playerID)
	local raceName = Player_GetRaceName(playerID)
	if raceName == nil then
		return nil, nil
	end

	local normalized = _AUTOAGE_RACE_ALIASES[raceName]
	if normalized ~= nil then
		return normalized, raceName
	end

	return raceName, raceName
end

function CBA_AutoAge_SetConstructionMenuAvailabilitySafe(playerID, menuName, state, context, suppressLog)
	local ok_set, err = pcall(Player_SetConstructionMenuAvailability, playerID, menuName, state)
	if not ok_set then
		if not suppressLog then
			print(string.format("[AUTOAGE][WARN] failed Player_SetConstructionMenuAvailability context=%s player=%s menu=%s state=%s err=%s",
				tostring(context), tostring(playerID), tostring(menuName), tostring(state), tostring(err)))
		end
		return false
	end

	return true
end

function CBA_AutoAge_GetMenuPrefixesForRace(raceName)
	local prefixes = {}
	local seen = {}

	local function pushPrefix(prefix)
		if prefix == nil or prefix == "" or seen[prefix] then
			return
		end
		seen[prefix] = true
		table.insert(prefixes, prefix)
	end

	pushPrefix(AGS_CIV_PREFIXES[raceName])

	local parentRace = nil
	if AGS_CIV_FACTION_MAP ~= nil then
		parentRace = AGS_CIV_FACTION_MAP[raceName]
	end
	if parentRace == nil and AGS_CIV_PARENT_MAP ~= nil then
		parentRace = AGS_CIV_PARENT_MAP[raceName]
	end
	if parentRace ~= nil then
		pushPrefix(AGS_CIV_PREFIXES[parentRace])
	end

	return prefixes
end

function CBA_AutoAge_SetMenuAvailabilityWithFallback(playerID, raceName, menuSuffix, state, context)
	local prefixes = CBA_AutoAge_GetMenuPrefixesForRace(raceName)
	if #prefixes == 0 then
		_AutoAge_LogWarn(string.format("[AUTOAGE][WARN] no menu prefix candidates race=%s player=%s context=%s suffix=%s",
			tostring(raceName), tostring(playerID), tostring(context), tostring(menuSuffix)),
			"no_prefix|" .. tostring(raceName) .. "|" .. tostring(context) .. "|" .. tostring(menuSuffix))
		return false
	end

	-- Try ALL prefix candidates, not just the first that succeeds.
	-- Parent-prefix fallback may silently "succeed" without affecting the variant player's actual menu.
	local tried = {}
	local any_succeeded = false
	local first_success = nil
	for idx, prefix in ipairs(prefixes) do
		local menuName = prefix .. menuSuffix
		table.insert(tried, menuName)
		local ok = CBA_AutoAge_SetConstructionMenuAvailabilitySafe(playerID, menuName, state, context, true)
		if ok then
			any_succeeded = true
			if first_success == nil then
				first_success = menuName
			end
			if idx > 1 then
				_AutoAge_LogInfo(string.format("[AUTOAGE] menu fallback also applied race=%s player=%s context=%s using=%s",
					tostring(raceName), tostring(playerID), tostring(context), tostring(menuName)))
			end
		end
	end

	if any_succeeded then
		return true
	end

	_AutoAge_LogWarn(string.format("[AUTOAGE][WARN] unresolved menu race=%s player=%s context=%s suffix=%s tried=%s",
		tostring(raceName), tostring(playerID), tostring(context), tostring(menuSuffix), table.concat(tried, ",")),
		"unresolved|" .. tostring(raceName) .. "|" .. tostring(context) .. "|" .. tostring(menuSuffix))
	return false
end

-- Exhaustive menu lock: tries ALL candidate menu names from _AUTOAGE_CIV_MENUS.
-- Returns {succeeded=count, failed=count, details={...}}
function CBA_AutoAge_LockMenuExhaustive(playerID, candidates, state, context)
	local result = { succeeded = 0, failed = 0, details = {} }
	if candidates == nil then
		return result
	end
	for _, menuName in ipairs(candidates) do
		local ok = CBA_AutoAge_SetConstructionMenuAvailabilitySafe(playerID, menuName, state, context, true)
		if ok then
			result.succeeded = result.succeeded + 1
		else
			result.failed = result.failed + 1
		end
		table.insert(result.details, { name = menuName, ok = ok })
	end
	return result
end

-- Set maximum age for a player with correct menu handling for ALL civs.
-- Replaces Player_SetMaximumAge which silently no-ops for 13 civs.
-- Uses _AUTOAGE_CIV_MENUS for exhaustive menu name coverage; falls back to prefix construction.
function CBA_AutoAge_SetMaximumAge(playerID, maximumAge)
	-- Imperial or above: proceed to unlock all menus that were previously ITEM_REMOVED.
	-- The loop logic naturally sets everything to ITEM_DEFAULT (age/wonder menus) or
	-- ITEM_LOCKED (wing tiers) when maximumAge >= 4, which is the correct Imperial state.

	local resolvedRaceName, rawRaceName = CBA_AutoAge_ResolveRaceName(playerID)
	if resolvedRaceName == nil then
		print(string.format("[AUTOAGE][WARN] CBA_AutoAge_SetMaximumAge nil race player=%s — menus not locked",
			tostring(playerID)))
		Player_SetStateModelInt(playerID, "player_max_age", maximumAge)
		return
	end

	local prefix = AGS_CIV_PREFIXES[resolvedRaceName]
	local diag = _AUTOAGE_DIAG_ENABLED == true
	local diag_results = {}

	if prefix == nil then
		print(string.format("[AUTOAGE][WARN] CBA_AutoAge_SetMaximumAge unknown race=%s player=%s — menus not locked",
			tostring(resolvedRaceName), tostring(playerID)))
	else
		if rawRaceName ~= nil and rawRaceName ~= resolvedRaceName then
			_AutoAge_LogInfo(string.format("[AUTOAGE] race alias normalized raw=%s resolved=%s player=%s",
				tostring(rawRaceName), tostring(resolvedRaceName), tostring(playerID)))
		end

		local civMenus = _AUTOAGE_CIV_MENUS[resolvedRaceName]

		-- Lock/unlock age construction menus
		for age = 2, 4 do
			local state = (maximumAge < age) and ITEM_REMOVED or ITEM_DEFAULT
			local candidates = civMenus and civMenus.age_menus and civMenus.age_menus[age]
			local locked_any = false

			if candidates ~= nil and #candidates > 0 then
				-- Exhaustive: try ALL candidate menu names from CIV_MENUS table
				local result = CBA_AutoAge_LockMenuExhaustive(playerID, candidates, state, "SetMaximumAge/age" .. age)
				locked_any = result.succeeded > 0
				if diag then
					for _, d in ipairs(result.details) do
						table.insert(diag_results, { menu = d.name, ok = d.ok, tier = "age" .. age })
					end
				end
			end

			if not locked_any then
				-- Fallback: prefix construction (original approach)
				local menuSuffix = "age" .. tostring(age)
				local fb_ok = CBA_AutoAge_SetMenuAvailabilityWithFallback(playerID, resolvedRaceName, menuSuffix, state,
					"CBA_AutoAge_SetMaximumAge/age")
				if diag and not fb_ok then
					table.insert(diag_results, { menu = prefix .. menuSuffix, ok = false, tier = "age" .. age, note = "fallback_also_failed" })
				end
			end
		end

		-- Wing civs: lock/unlock wing upgrade availability
		local wingCfg = _AUTOAGE_WING_UPGRADES[resolvedRaceName]
		if wingCfg ~= nil then
			local function setWingTier(tierName, lock)
				local upgrades = wingCfg[tierName]
				if upgrades ~= nil then
					for _, upg_name in ipairs(upgrades) do
						CBA_AutoAge_SetUpgradeAvailabilitySafe(playerID, upg_name, lock,
							"CBA_AutoAge_SetMaximumAge/" .. tierName)
					end
				end
			end

			-- Wing tiers: ITEM_REMOVED while max age hasn't reached, ITEM_LOCKED once reachable.
			-- Kept ITEM_LOCKED (not ITEM_DEFAULT) to prevent manual research at HoW;
			-- Player_CompleteUpgrade in BoonSelection callback bypasses the lock.
			setWingTier("dark",     maximumAge < 2 and ITEM_REMOVED or ITEM_LOCKED)
			setWingTier("feudal",   maximumAge < 3 and ITEM_REMOVED or ITEM_LOCKED)
			setWingTier("castle",   maximumAge < 4 and ITEM_REMOVED or ITEM_LOCKED)
			setWingTier("imperial", maximumAge < 4 and ITEM_REMOVED or ITEM_LOCKED)
		else
			-- Non-wing civs: lock/unlock wonder/landmark menus
			for wonderAge = 1, 3 do
				local state = (maximumAge < (wonderAge + 1)) and ITEM_REMOVED or ITEM_DEFAULT
				local candidates = civMenus and civMenus.wonder_menus and civMenus.wonder_menus[wonderAge]
				local locked_any = false

				if candidates ~= nil and #candidates > 0 then
					local result = CBA_AutoAge_LockMenuExhaustive(playerID, candidates, state, "SetMaximumAge/wonder" .. wonderAge)
					locked_any = result.succeeded > 0
					if diag then
						for _, d in ipairs(result.details) do
							table.insert(diag_results, { menu = d.name, ok = d.ok, tier = "wonder" .. wonderAge })
						end
					end
				end

				if not locked_any then
					local menuSuffix = "age" .. tostring(wonderAge) .. "_wonders"
					local fb_ok = CBA_AutoAge_SetMenuAvailabilityWithFallback(playerID, resolvedRaceName, menuSuffix, state,
						"CBA_AutoAge_SetMaximumAge/wonders")
					if diag and not fb_ok then
						table.insert(diag_results, { menu = prefix .. menuSuffix, ok = false, tier = "wonder" .. wonderAge, note = "fallback_also_failed" })
					end
				end
			end
		end

		-- Supplementary: native Player_SetMaximumAge from cardinal.scar (handles 9 base + campaign civs).
		-- Does not cover DLC civs but provides a redundant safety net for base civs.
		pcall(Player_SetMaximumAge, playerID, maximumAge)
	end

	Player_SetStateModelInt(playerID, "player_max_age", maximumAge)

	-- Diagnostic summary
	if diag and #diag_results > 0 then
		local ok_count = 0
		local fail_count = 0
		local failed_menus = {}
		for _, d in ipairs(diag_results) do
			if d.ok then
				ok_count = ok_count + 1
			else
				fail_count = fail_count + 1
				table.insert(failed_menus, d.menu .. "(" .. d.tier .. ")")
			end
		end
		local failed_str = #failed_menus > 0 and table.concat(failed_menus, ",") or "none"
		print(string.format("[AUTOAGE][DIAG] pass=%d player=%s race=%s maxAge=%d locked=%d/%d failed=[%s]",
			_AUTOAGE_DIAG_PASS, tostring(playerID), tostring(resolvedRaceName), maximumAge,
			ok_count, ok_count + fail_count, failed_str))
	end
end

-- Re-assert menu locks for a player based on their current max age state model value.
-- Safe to call at any time; reads the stored max age and re-applies all locks.
function CBA_AutoAge_ReassertPlayerLocks(player)
	if player == nil or player.id == nil or player.isEliminated then
		return
	end
	local maxAge = Player_GetStateModelInt(player.id, "player_max_age")
	if maxAge == nil or maxAge <= 0 then
		return
	end
	CBA_AutoAge_SetMaximumAge(player.id, maxAge)
end

---------------------------------------------------------------------------------------------------
-- Unified age advancement helper
-- Advances a player's age to match their landmark/upgrade progress (obj_build_count),
-- capped by the maximum age the timer has unlocked (player_max_age).
-- Safe to call at any time; no-ops if the player is already at the correct age.
---------------------------------------------------------------------------------------------------
function CBA_AutoAge_TryAdvanceAge(player)
	if player == nil or player.id == nil or player.isEliminated then return false end

	local age = Player_GetCurrentAge(player.id)
	if age >= 4 then return false end

	local max_age = Player_GetStateModelInt(player.id, "player_max_age")
	if max_age == nil or max_age <= 0 then max_age = age end

	local build_count = player.obj_build_count or age
	local build_count_raw = player.obj_build_count
	local target = math.min(build_count, max_age)

	if target <= age then
		-- Throttled trace: only log on state change (not every 1s tick)
		if build_count ~= age or max_age ~= age then
			local snap_key = tostring(player.id)
			local snap = string.format("%d_%d_%s_%d", age, max_age, tostring(build_count_raw), target)
			if _autoage_noop_snap == nil then _autoage_noop_snap = {} end
			if _autoage_noop_snap[snap_key] ~= snap then
				_autoage_noop_snap[snap_key] = snap
				local civ = "<unknown>"
				local ok, cn = pcall(Player_GetRaceName, player.id)
				if ok and cn ~= nil then civ = tostring(cn) end
				print(string.format("[AUTOAGE][TRACE] TryAdvanceAge NO-OP player=%s civ=%s age=%d max_age=%d build_count=%s(raw=%s) target=%d reason=target<=age",
					tostring(player.id), civ, age, max_age, tostring(build_count), tostring(build_count_raw), target))
			end
		end
		return false
	end

	local civ = "<unknown>"
	local ok, cn = pcall(Player_GetRaceName, player.id)
	if ok and cn ~= nil then civ = tostring(cn) end
	print(string.format("[AUTOAGE][TRACE] TryAdvanceAge ADVANCING player=%s civ=%s age=%d->%d max_age=%d build_count=%s(raw=%s)",
		tostring(player.id), civ, age, target, max_age, tostring(build_count), tostring(build_count_raw)))

	Player_SetCurrentAge(player.id, target)
	CBA_Options_RevalidateAll(player)

	-- Re-assert menu availability so next-age landmarks are accessible.
	CBA_AutoAge_ReassertPlayerLocks(player)

	if player.isLocal and _autoage.objective_main ~= nil then
		Obj_CreatePopup(_autoage.objective_main, _autoage.objective_main_title, "")
	end

	local new_age = Player_GetCurrentAge(player.id)
	print(string.format("[AUTOAGE][TRACE] TryAdvanceAge DONE player=%s civ=%s confirmed_age=%d",
		tostring(player.id), civ, new_age))

	return true
end

function CBA_AutoAge_SyncSpecialUpgradeAvailability(player)
	if player == nil or player.id == nil or player.isEliminated then
		return
	end

	local player_civ = Player_GetRaceName(player.id)
	local civ_cfg = _AUTOAGE_SPECIAL_UPGRADES[player_civ]
	if civ_cfg == nil then
		return
	end

	-- All special-civ upgrades are kept ITEM_LOCKED to prevent manual research.
	-- Player_CompleteUpgrade in the BoonSelection callback bypasses the lock.
	for _, upg_name in ipairs(civ_cfg.feudal) do
		CBA_AutoAge_SetUpgradeAvailabilitySafe(player.id, upg_name, ITEM_LOCKED,
			"CBA_AutoAge_SyncSpecialUpgradeAvailability/feudal")
	end

	for _, upg_name in ipairs(civ_cfg.castle) do
		CBA_AutoAge_SetUpgradeAvailabilitySafe(player.id, upg_name, ITEM_LOCKED,
			"CBA_AutoAge_SyncSpecialUpgradeAvailability/castle")
	end

	for _, upg_name in ipairs(civ_cfg.imperial) do
		CBA_AutoAge_SetUpgradeAvailabilitySafe(player.id, upg_name, ITEM_LOCKED,
			"CBA_AutoAge_SyncSpecialUpgradeAvailability/imperial")
	end

	-- Wing civs: after Age 4 with all 3 picks done, unlock leftover family's upgrades.
	if _AUTOAGE_SPECIAL_NEEDS_FORCE_AGE[player_civ] then
		CBA_AutoAge_UnlockLeftoverWings(player)
	end
end

---------------------------------------------------------------------------------------------------
-- Imperial leftover unlock
-- At Age 4, once all 3 age-up wing picks are complete, the remaining (unpicked) family's
-- upgrades are unlocked for manual research (or auto-completed if toggle is set).
---------------------------------------------------------------------------------------------------

function CBA_AutoAge_UnlockLeftoverWings(player)
	if player == nil or player.id == nil or player.isEliminated then return end

	local age = Player_GetCurrentAge(player.id)
	if age < 4 then return end

	local player_civ = Player_GetRaceName(player.id)
	local civ_cfg = _AUTOAGE_SPECIAL_UPGRADES[player_civ]
	if civ_cfg == nil then return end

	-- All 3 age-up tiers must have a completed pick.
	local has_feudal = CBA_AutoAge_PlayerHasAnyUpgrade(player.id, civ_cfg.feudal)
	local has_castle = CBA_AutoAge_PlayerHasAnyUpgrade(player.id, civ_cfg.castle)
	local has_imperial = CBA_AutoAge_PlayerHasAnyUpgrade(player.id, civ_cfg.imperial)
	if not (has_feudal and has_castle and has_imperial) then return end

	-- Determine unpicked families.
	local chosen_families = BoonSelection_GetChosenWingFamilies(player.id, player_civ)
	local unpicked = {}
	for _, family in ipairs(_BOON_WING_FAMILIES) do
		if not chosen_families[family] then
			table.insert(unpicked, family)
		end
	end
	if #unpicked == 0 then return end

	-- Scan full wing upgrade table (dark/feudal/castle/imperial tiers) for leftover families.
	local wing_cfg = _AUTOAGE_WING_UPGRADES[player_civ]
	if wing_cfg == nil then return end

	for _, family in ipairs(unpicked) do
		for _, tier_name in ipairs({"dark", "feudal", "castle", "imperial"}) do
			local tier_wings = wing_cfg[tier_name]
			if tier_wings ~= nil then
				for _, upg_name in ipairs(tier_wings) do
					local wing_family = BoonSelection_GetWingFamily(upg_name)
					if wing_family == family then
						local ok_bp, ubp = pcall(BP_GetUpgradeBlueprint, upg_name)
						if ok_bp and ubp ~= nil and not Player_HasUpgrade(player.id, ubp) then
							if _AUTOAGE_WING_AUTOCOMPLETE_LEFTOVER then
								pcall(Player_CompleteUpgrade, player.id, ubp)
								print(string.format("[AUTOAGE] leftover wing auto-completed civ=%s player=%s family=%s upgrade=%s",
									tostring(player_civ), tostring(player.id), family, upg_name))
							else
								CBA_AutoAge_SetUpgradeAvailabilitySafe(player.id, upg_name, ITEM_DEFAULT,
									"CBA_AutoAge_UnlockLeftoverWings/" .. family)
								print(string.format("[AUTOAGE] leftover wing unlocked civ=%s player=%s family=%s upgrade=%s",
									tostring(player_civ), tostring(player.id), family, upg_name))
							end
						end
					end
				end
			end
		end
	end
end

local _AUTOAGE_SPECIAL_AUTOPICK_INDEX = {
	templar = { feudal = 1, castle = 1, imperial = 1 },
	mongol_ha_gol = { feudal = 1, castle = 1, imperial = 1 },
	abbasid = { feudal = 1, castle = 1, imperial = 1 },
	abbasid_ha_01 = { feudal = 1, castle = 1, imperial = 1 },
}

-- Civs whose wing/tent upgrades do NOT trigger age advancement natively.
-- The callback must explicitly call Player_SetCurrentAge + CBA_Options_RevalidateAll.
_AUTOAGE_SPECIAL_NEEDS_FORCE_AGE = {
	abbasid = true,
	abbasid_ha_01 = true,
}

local _AUTOAGE_TEMPLAR_CHOICE_TIMEOUT = 30

-- When true, leftover (unpicked) wing upgrades are auto-completed at Age 4 instead of just unlocked.
_AUTOAGE_WING_AUTOCOMPLETE_LEFTOVER = false

function CBA_AutoAge_GetSpecialTierByTargetAge(target_age)
	if target_age == 2 then return "feudal" end
	if target_age == 3 then return "castle" end
	if target_age == 4 then return "imperial" end
	return nil
end

function CBA_AutoAge_GetAutopickUpgradeName(player_civ, tier_name, upgrades)
	if upgrades == nil or #upgrades == 0 then
		return nil, 0
	end

	local civ_cfg = _AUTOAGE_SPECIAL_AUTOPICK_INDEX[player_civ]
	local idx = 1
	if civ_cfg ~= nil and civ_cfg[tier_name] ~= nil then
		idx = civ_cfg[tier_name]
	end

	if type(idx) ~= "number" then
		idx = 1
	end
	if idx < 1 then
		idx = 1
	end
	if idx > #upgrades then
		idx = #upgrades
	end

	return upgrades[idx], idx
end

function CBA_AutoAge_TryAutoSelectSpecialUpgrade(player, target_age)
	if player == nil or player.id == nil or player.isEliminated then
		return false
	end

	local player_civ = Player_GetRaceName(player.id)
	local civ_cfg = _AUTOAGE_SPECIAL_UPGRADES[player_civ]
	if civ_cfg == nil then
		return false
	end

	local tier_name = CBA_AutoAge_GetSpecialTierByTargetAge(target_age)
	if tier_name == nil then
		return false
	end

	local tier_upgrades = civ_cfg[tier_name]
	if tier_upgrades == nil or #tier_upgrades == 0 then
		print(string.format("[AUTOAGE][WARN] special autopick missing tier upgrades civ=%s tier=%s",
			tostring(player_civ), tostring(tier_name)))
		return false
	end

	if CBA_AutoAge_PlayerHasAnyUpgrade(player.id, tier_upgrades) then
		return true
	end

	CBA_AutoAge_SyncSpecialUpgradeAvailability(player)

	-- Wing civs: pick the first available non-chosen family to enforce uniqueness.
	local upg_name, chosen_index
	if _AUTOAGE_SPECIAL_NEEDS_FORCE_AGE[player_civ] then
		local chosen_families = BoonSelection_GetChosenWingFamilies(player.id, player_civ)
		for i, name in ipairs(tier_upgrades) do
			local family = BoonSelection_GetWingFamily(name)
			if family == nil or not chosen_families[family] then
				upg_name = name
				chosen_index = i
				break
			end
		end
		if upg_name == nil then
			-- All families chosen; fallback to default picker.
			upg_name, chosen_index = CBA_AutoAge_GetAutopickUpgradeName(player_civ, tier_name, tier_upgrades)
		end
	else
		upg_name, chosen_index = CBA_AutoAge_GetAutopickUpgradeName(player_civ, tier_name, tier_upgrades)
	end
	if upg_name == nil then
		print(string.format("[AUTOAGE][WARN] special autopick failed civ=%s tier=%s reason=no_upgrade_choice",
			tostring(player_civ), tostring(tier_name)))
		return false
	end

	local ok_bp, upg_bp = pcall(BP_GetUpgradeBlueprint, upg_name)
	if not ok_bp or upg_bp == nil then
		print(string.format("[AUTOAGE][WARN] special autopick missing upgrade blueprint civ=%s tier=%s upgrade=%s",
			tostring(player_civ), tostring(tier_name), tostring(upg_name)))
		return false
	end

	local ok_complete = pcall(Player_CompleteUpgrade, player.id, upg_bp)
	if not ok_complete then
		print(string.format("[AUTOAGE][WARN] special autopick failed Player_CompleteUpgrade civ=%s tier=%s upgrade=%s",
			tostring(player_civ), tostring(tier_name), tostring(upg_name)))
		return false
	end

	print(string.format("[AUTOAGE] special autopick applied civ=%s player=%s tier=%s choice=%d/%d upgrade=%s",
		tostring(player_civ), tostring(player.id), tostring(tier_name), chosen_index, #tier_upgrades, tostring(upg_name)))

	-- Wing civs need explicit age advancement (wings don't trigger age-up natively).
	if _AUTOAGE_SPECIAL_NEEDS_FORCE_AGE[player_civ] then
		pcall(Player_SetCurrentAge, player.id, target_age)
		CBA_Options_RevalidateAll(player)
		print(string.format("[AUTOAGE] force-age applied civ=%s player=%s target_age=%d",
			tostring(player_civ), tostring(player.id), target_age))
	end

	return true
end

-- Present any special-upgrade civ (Templar, Abbasid, Ayyubid, Golden Horde) with a
-- BoonSelection card panel. Non-local players auto-pick option 1.
-- On timeout, auto-selects option 1. On answer, completes the chosen upgrade.
function CBA_AutoAge_ForceSpecialAgeChoicePrompt(player, target_age, context)
	if player == nil or player.id == nil or player.isEliminated then
		return false
	end

	local player_civ = Player_GetRaceName(player.id)
	local civ_cfg = _AUTOAGE_SPECIAL_UPGRADES[player_civ]
	if civ_cfg == nil then return false end

	local tier_name = CBA_AutoAge_GetSpecialTierByTargetAge(target_age)
	if tier_name == nil then return false end

	local tier_upgrades = civ_cfg[tier_name]
	if tier_upgrades == nil or #tier_upgrades == 0 then return false end

	-- Already completed this tier: nothing to choose.
	if CBA_AutoAge_PlayerHasAnyUpgrade(player.id, tier_upgrades) then
		return true
	end

	-- Non-local players: auto-pick immediately (no UI).
	if not player.isLocal then
		return CBA_AutoAge_TryAutoSelectSpecialUpgrade(player, target_age)
	end

	-- Re-entry guard: don't open duplicate prompts.
	if player._special_choice_pending then
		print(string.format("[AUTOAGE] special choice already pending, skipping duplicate prompt civ=%s player=%s tier=%s",
			tostring(player_civ), tostring(player.id), tostring(tier_name)))
		return false
	end
	player._special_choice_pending = true

	-- Fetch filtered choices BEFORE callback definition so the closure captures them.
	local choices, title, subtitle = nil, nil, nil
	if type(BoonSelection_GetChoicesForCiv) == "function" then
		choices, title, subtitle = BoonSelection_GetChoicesForCiv(player_civ, tier_name, player.id)
	else
		print(string.format("[AUTOAGE][WARN] missing BoonSelection_GetChoicesForCiv; fallback to autopick civ=%s player=%s tier=%s",
			tostring(player_civ), tostring(player.id), tostring(tier_name)))
	end
	if choices == nil or #choices == 0 then
		-- Fallback: auto-pick if data/filter is exhausted.
		player._special_choice_pending = false
		return CBA_AutoAge_TryAutoSelectSpecialUpgrade(player, target_age)
	end

	-- Choice callback: applies the selected upgrade and cleans up.
	local function _OnSpecialChoice(choice_index)
		player._special_choice_pending = false

		if player.isEliminated then
			print(string.format("[AUTOAGE] special choice callback civ=%s player=%s eliminated, ignoring",
				tostring(player_civ), tostring(player.id)))
			return
		end

		local idx = choice_index or 1
		if idx < 1 or idx > #choices then idx = 1 end
		local upg_name = choices[idx].upgrade

		local ok_bp, upg_bp = pcall(BP_GetUpgradeBlueprint, upg_name)
		if ok_bp and upg_bp ~= nil then
			local ok_complete = pcall(Player_CompleteUpgrade, player.id, upg_bp)
			if ok_complete then
				print(string.format("[AUTOAGE] special choice applied civ=%s player=%s tier=%s choice=%d/%d upgrade=%s",
					tostring(player_civ), tostring(player.id), tostring(tier_name), idx, #choices, tostring(upg_name)))
			else
				print(string.format("[AUTOAGE][WARN] special choice Player_CompleteUpgrade failed civ=%s player=%s tier=%s upgrade=%s",
					tostring(player_civ), tostring(player.id), tostring(tier_name), tostring(upg_name)))
			end
		else
			print(string.format("[AUTOAGE][WARN] special choice missing blueprint civ=%s player=%s tier=%s upgrade=%s",
				tostring(player_civ), tostring(player.id), tostring(tier_name), tostring(upg_name)))
		end

		-- Wing civs need explicit age advancement.
		if _AUTOAGE_SPECIAL_NEEDS_FORCE_AGE[player_civ] then
			pcall(Player_SetCurrentAge, player.id, target_age)
			CBA_Options_RevalidateAll(player)
			print(string.format("[AUTOAGE] force-age applied civ=%s player=%s target_age=%d",
				tostring(player_civ), tostring(player.id), target_age))
		end

		CBA_AutoAge_ReconcileSpecialProgress(player)
		CBA_AutoAge_SyncSpecialUpgradeAvailability(player)
	end

	if type(BoonSelection_Show) ~= "function" then
		print(string.format("[AUTOAGE][WARN] missing BoonSelection_Show; fallback to autopick civ=%s player=%s tier=%s",
			tostring(player_civ), tostring(player.id), tostring(tier_name)))
		player._special_choice_pending = false
		return CBA_AutoAge_TryAutoSelectSpecialUpgrade(player, target_age)
	end

	BoonSelection_Show({
		title = title,
		subtitle = subtitle,
		choices = choices,
		on_select = _OnSpecialChoice,
		timeout = _AUTOAGE_TEMPLAR_CHOICE_TIMEOUT,
		default_choice = 1,
	})

	print(string.format("[AUTOAGE] special age choice prompt shown civ=%s context=%s player=%s target_age=%s tier=%s",
		tostring(player_civ), tostring(context), tostring(player.id), tostring(target_age), tostring(tier_name)))
	return false
end

function CBA_AutoAge_HandleSpecialAgeTrigger(player, target_age, context)
	if player == nil or player.id == nil or player.isEliminated then
		return false
	end

	local player_civ = Player_GetRaceName(player.id)
	local civ_cfg = _AUTOAGE_SPECIAL_UPGRADES[player_civ]
	if civ_cfg == nil then
		print(string.format("[AUTOAGE][TRACE] HandleSpecialAgeTrigger NOT_SPECIAL civ=%s player=%s target_age=%d context=%s (uses landmarks)",
			tostring(player_civ), tostring(player.id), target_age, tostring(context)))
		return false
	end

	print(string.format("[AUTOAGE][TRACE] HandleSpecialAgeTrigger IS_SPECIAL civ=%s player=%s target_age=%d context=%s",
		tostring(player_civ), tostring(player.id), target_age, tostring(context)))
	-- All special civs: sync availability then present choice (local) or auto-pick (non-local/AI).
	CBA_AutoAge_SyncSpecialUpgradeAvailability(player)
	return CBA_AutoAge_ForceSpecialAgeChoicePrompt(player, target_age, context)
end

function CBA_AutoAge_SetBuildCount(player, new_count)
	if player == nil or new_count == nil then
		return
	end

	if player.obj_build_count == nil then
		player.obj_build_count = AGS_GLOBAL_SETTINGS.StartingAge
	end

	if new_count <= player.obj_build_count then
		-- Throttled: only log once per unique state
		local snap_key = tostring(player.id) .. "_sbc"
		local snap = string.format("%d_%s", new_count, tostring(player.obj_build_count))
		if _autoage_noop_snap == nil then _autoage_noop_snap = {} end
		if _autoage_noop_snap[snap_key] ~= snap then
			_autoage_noop_snap[snap_key] = snap
			local civ = "<unknown>"
			local ok, cn = pcall(Player_GetRaceName, player.id)
			if ok and cn ~= nil then civ = tostring(cn) end
			print(string.format("[AUTOAGE][TRACE] SetBuildCount SKIP player=%s civ=%s new=%d current=%s reason=not_higher",
				tostring(player.id), civ, new_count, tostring(player.obj_build_count)))
		end
		return
	end

	local old_count = player.obj_build_count
	player.obj_build_count = new_count

	local civ = "<unknown>"
	local ok, cn = pcall(Player_GetRaceName, player.id)
	if ok and cn ~= nil then civ = tostring(cn) end
	print(string.format("[AUTOAGE][TRACE] SetBuildCount UPDATED player=%s civ=%s build_count=%d->%d",
		tostring(player.id), civ, old_count, new_count))

	if player.isLocal then
		Obj_SetCounterCount(_autoage.objective_secondary, player.obj_build_count)
		Obj_SetProgress(_autoage.objective_secondary, player.obj_build_count / _autoage.objective_secondary_requirement)
	end
end

function CBA_AutoAge_ReconcileSpecialProgress(player)
	if player == nil or player.id == nil or player.isEliminated then
		return
	end

	local player_civ = Player_GetRaceName(player.id)
	local civ_cfg = _AUTOAGE_SPECIAL_UPGRADES[player_civ]
	if civ_cfg == nil then
		return
	end

	if CBA_AutoAge_PlayerHasAnyUpgrade(player.id, civ_cfg.imperial) then
		CBA_AutoAge_SetBuildCount(player, 4)
	elseif CBA_AutoAge_PlayerHasAnyUpgrade(player.id, civ_cfg.castle) then
		CBA_AutoAge_SetBuildCount(player, 3)
	elseif CBA_AutoAge_PlayerHasAnyUpgrade(player.id, civ_cfg.feudal) then
		CBA_AutoAge_SetBuildCount(player, 2)
	end
end

function CBA_AutoAge_UpgradeComplete(context)
	local player = Core_GetPlayersTableEntry(context.player)
	if player == nil or player.isEliminated then
		return
	end

	local player_civ = Player_GetRaceName(player.id)
	local upgrade_debug_name = "<unknown>"
	if context ~= nil and context.upgrade ~= nil then
		local ok_n, n = pcall(BP_GetName, context.upgrade)
		if ok_n and n ~= nil then upgrade_debug_name = tostring(n) end
	end
	print(string.format("[AUTOAGE][TRACE] UpgradeComplete player=%s civ=%s upgrade=%s age=%d obj_build_count=%s max_age=%s",
		tostring(player.id), tostring(player_civ), upgrade_debug_name,
		Player_GetCurrentAge(player.id), tostring(player.obj_build_count),
		tostring(Player_GetStateModelInt(player.id, "player_max_age"))))

	local civ_cfg = _AUTOAGE_SPECIAL_UPGRADES[player_civ]
	if civ_cfg ~= nil and context ~= nil and context.upgrade ~= nil then
		local ok_age_type, is_age_up = pcall(BP_IsUpgradeOfType, context.upgrade, "age_up_upgrade")
		if ok_age_type and is_age_up then
			local upgrade_name = "<unknown>"
			local ok_name, name_or_err = pcall(BP_GetName, context.upgrade)
			if ok_name and name_or_err ~= nil then
				upgrade_name = tostring(name_or_err)
			end
			print(string.format("[AUTOAGE] special age-up upgrade complete civ=%s player=%s upgrade=%s path=GE_UpgradeComplete(age_up_upgrade)",
				tostring(player_civ), tostring(player.id), tostring(upgrade_name)))
		end
	end

	CBA_AutoAge_ReconcileSpecialProgress(player)
	CBA_AutoAge_SyncSpecialUpgradeAvailability(player)

	-- Re-assert menu locks: engine may re-enable menus after processing upgrade events.
	-- This catches async menu mutations that occur after age upgrade completion.
	CBA_AutoAge_ReassertPlayerLocks(player)

	-- Advance age if upgrade completion updated obj_build_count past current age.
	CBA_AutoAge_TryAdvanceAge(player)
end

