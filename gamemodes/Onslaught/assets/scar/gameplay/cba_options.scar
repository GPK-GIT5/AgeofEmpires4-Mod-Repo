---------------------------------------------------------------------------------------------------
-- Description:
-- Additional options that can be used in the lobby for CBA / Onslaught tuning pack
---------------------------------------------------------------------------------------------------
CBA_OPTIONS_MODULE = "CBA_Options"

---------------------------------------------------------------------------------------------------
-- Delegates:
---------------------------------------------------------------------------------------------------

Core_RegisterModule(CBA_OPTIONS_MODULE)	

-- DebugLog is provided by debug modules, but those may be omitted in non-debug loads.
if type(DebugLog) ~= "function" then
	function DebugLog(area, msg, opt_data)
		return
	end
end

function CBA_Options_ShouldLogSiegeStandard()
	return _cba_debug ~= nil and _cba_debug.enabled
end

function CBA_Options_ShouldLogSiegeVerbose()
	if not CBA_Options_ShouldLogSiegeStandard() then return false end
	local mode = _cba_debug.siege_log_mode
	if mode == nil then
		mode = _cba_debug.siegeLogMode
	end
	mode = string.lower(tostring(mode or "standard"))
	return mode == "verbose"
end

function CBA_Options_ShouldLogSiegeStateChange(player, key, state)
	if not CBA_Options_ShouldLogSiegeStandard() then return false end
	if player == nil then return false end
	player._cba_siege_log_state = player._cba_siege_log_state or {}
	if player._cba_siege_log_state[key] == state then
		return false
	end
	player._cba_siege_log_state[key] = state
	return true
end

function CBA_Options_UpdateModuleSettings()
	AGS_Print("CBA_Options_UpdateModuleSettings")
	--[[if AGS_GLOBAL_SETTINGS.CBA_Options == 0 then
		Core_UnregisterModule(CBA_OPTIONS_MODULE)
	end
	]]
end

function CBA_Options_PresetFinalize()
	AGS_Print("CBA_Options_PresetFinalize")

	-- PERF: Cache ability BPs at init (avoids per-event BP_GetAbilityBlueprint lookups)
	_CBA_ABP_Scuttle = BP_GetAbilityBlueprint("core_building_scuttle")
	_CBA_ABP_ScuttleNoEnemies = BP_GetAbilityBlueprint("core_building_scuttle_no_enemies")
	_CBA_ABP_PackMon = BP_GetAbilityBlueprint("pack_building_mon")

	-- Scuttle ability replacement
	Rule_AddGlobalEvent(CBA_Options_AddScuttle_ConstructionComplete, GE_ConstructionComplete)
	
	-- Building Limit
	if AGS_GLOBAL_SETTINGS.MaximumProductionBuildings ~= 0 then
		
		-- Setup objective UI
		CBA_Options_BuildingLimit_SetupObjective()
		-- Rules
		Rule_AddGlobalEvent(CBA_Options_BuildingLimit_ConstructionStart, GE_ConstructionStart)
		Rule_AddGlobalEvent(CBA_Options_BuildingLimit_ConstructionCancelled, GE_ConstructionCancelled)
		CBA_EntityKillBatch_SetHandler("building_limit", true)
	end
	
	-- Siege Limit (always init — MaximumMedicPopulation==0 means unlimited, not disabled)
	Rule_AddGlobalEvent(CBA_BuildItemBatch_Capture, GE_BuildItemComplete)
	Rule_AddInterval(CBA_BuildItemBatch_Process, 1.0)
	CBA_BuildItemBatch_SetHandler("siege_limit", true)
	Rule_AddGlobalEvent(CBA_SquadKillBatch_Capture, GE_SquadKilled)
	Rule_AddInterval(CBA_SquadKillBatch_Process, 1.0)
	CBA_SquadKillBatch_SetHandler("siege_limit", true)
	Rule_AddGlobalEvent(CBA_EntityKillBatch_Capture, GE_EntityKilled)
	Rule_AddInterval(CBA_EntityKillBatch_Process, 1.0)
	Rule_AddGlobalEvent(CBA_Options_SiegeLimit_ConstructionStart, GE_ConstructionStart)
	Rule_AddGlobalEvent(CBA_Options_SiegeLimit_ConstructionCancelled, GE_ConstructionCancelled)
	Rule_AddGlobalEvent(CBA_Options_SiegeLimit_ConstructionComplete, GE_ConstructionComplete)
	CBA_EntityKillBatch_SetHandler("siege_limit", true)
	
	for i, player in ipairs(PLAYERS) do				
		player.siegeLimit_count = 0
		player.siegeLimit_pending = 0
		player.ramLimit_count = 0
		player.siegeTowerLimit_count = 0
		player.ramLimit_pending = 0
		player.siegeTowerLimit_pending = 0
		player._cba_siege_log_state = {}
		player.eg_siegeproduction = EGroup_CreateUnique("eg_siegeproduction")
	end
	-- Apply initial siege restrictions (English pre-Castle gate, ram/ST limits)
	for i, player in ipairs(PLAYERS) do
		CBA_Options_SiegeLimit_ApplyThreshold(player)
		CBA_Options_RamLimit_ApplyThreshold(player)
		CBA_Options_SiegeTowerLimit_ApplyThreshold(player)
		CBA_Options_FieldConstruct_Gate(player)
	end
	
	-- Periodic reconciliation catches stale counts from missing/delayed construction events
	-- Staggered: processes one player per tick, completing a full cycle every ~6 seconds.
	_CBA_Reconcile_PlayerIdx = 1
	local stagger_interval = math.max(0.5, 6.0 / math.max(1, #PLAYERS))
	Rule_AddInterval(CBA_Options_SiegeLimit_Reconcile, stagger_interval)
	
	-- Building limit reconciliation — same stagger pattern as siege.
	-- Catches missed GE_EntityKilled events (owner resolution failure, queue overflow, etc.).
	if AGS_GLOBAL_SETTINGS.MaximumProductionBuildings ~= 0 then
		_CBA_BuildingLimit_Reconcile_PlayerIdx = 1
		Rule_AddInterval(CBA_Options_BuildingLimit_Reconcile, stagger_interval)
	end
	
	-- Village spawner
	Rule_AddInterval(CBA_Options_VillagerSpawner, 20)
	
	-- Keep Modifier
	CBA_Option_KeepModifier()
	
	-- Restrict: Outpost Cannon emplacement
	CBA_Options_OutpostRestrictions()
	
	-- Enable Archery/Stable @ Dark Age / Moved into cba_auto_age.scar
	-- CBA_Options_DarkAge_Unlocks()
	
	-- Build reverse blueprint map for leaver conversion system
	_BuildBlueprintReverseMap()
	
end

---------------------------------------------------------------------------------------------------
-- Reverse Blueprint Map (for leaver conversion: attribName → AGS key)
---------------------------------------------------------------------------------------------------

-- Global: maps attribName string → AGS_ENTITY_TABLE key string.
-- Example: "building_unit_infantry_control_eng" → "barracks"
_BLUEPRINT_REVERSE_MAP = {}

-- Iterates ALL civs × ALL keys in AGS_ENTITY_TABLE and AGS_UNIT_BP_OVERRIDES
-- to produce a flat lookup from attribName → AGS key.
function _BuildBlueprintReverseMap()
	_BLUEPRINT_REVERSE_MAP = {}
	for _, tbl in pairs(AGS_ENTITY_TABLE) do
		for key, attrib in pairs(tbl) do
			if type(attrib) == "string" then
				_BLUEPRINT_REVERSE_MAP[attrib] = key
			end
		end
	end
	-- Also index DLC unit override attribNames
	if type(AGS_UNIT_BP_OVERRIDES) == "table" then
		for key, overrides in pairs(AGS_UNIT_BP_OVERRIDES) do
			for _, attrib in pairs(overrides) do
				if type(attrib) == "string" then
					_BLUEPRINT_REVERSE_MAP[attrib] = key
				end
			end
		end
	end
	local count = 0
	for _ in pairs(_BLUEPRINT_REVERSE_MAP) do count = count + 1 end
	DebugLog("leaver", string.format("_BuildBlueprintReverseMap: %d entries indexed", count))
end

---------------------------------------------------------------------------------------------------
-- Functions:
---------------------------------------------------------------------------------------------------

-- Returns the effective production building limit for a player (may be increased by team balance).
function CBA_Options_GetPlayerProdLimit(player)
	return player.teamBalance_prodLimit or AGS_GLOBAL_SETTINGS.MaximumProductionBuildings
end

-- Returns the effective workshop-family cap (clamped to hard max of 2; 0 = disabled).
function CBA_Options_GetWorkshopLimit()
	local raw = AGS_GLOBAL_SETTINGS.MaximumSiegeWorkshop or 0
	if raw == 0 then return 0 end
	return math.min(2, raw)
end

-- Returns the effective per-player workshop limit (may be increased by team balance).
function CBA_Options_GetPlayerWorkshopLimit(player)
	return player.teamBalance_workshopLimit or CBA_Options_GetWorkshopLimit()
end

-- Returns the effective per-player siege point limit (may be increased by team balance).
function CBA_Options_GetPlayerSiegeLimit(player)
	return player.teamBalance_siegeLimit or AGS_GLOBAL_SETTINGS.MaximumMedicPopulation or 15
end

-- Returns the effective per-player ram weight limit (may be increased by team balance).
function CBA_Options_GetPlayerRamLimit(player)
	return player.teamBalance_ramLimit or RAM_LIMIT_MAX or 5
end

-- Returns the effective per-player siege tower limit (may be increased by team balance).
function CBA_Options_GetPlayerSiegeTowerLimit(player)
	return player.teamBalance_siegeTowerLimit or SIEGE_TOWER_LIMIT_MAX or 5
end

-- Returns the effective per-player outpost limit (may be increased by team balance).
function CBA_Options_GetPlayerOutpostLimit(player)
	return player.teamBalance_outpostLimit or 20
end

-- Unified production-cap classifier.
-- Landmarks are always excluded from production cap.
local function CBA_Options_BuildingLimit_IsProductionCapBuildingByEntity(entity, is_starter_keep)
	if entity == nil then return false end
	if is_starter_keep then return false end
	local is_prod = Entity_IsOfType(entity, "military_only_production") or Entity_IsOfType(entity, "military_production_building")
	if not is_prod then return false end
	if Entity_IsOfType(entity, "military_school_ott") or Entity_IsOfType(entity, "landmark") or Entity_IsOfType(entity, "scar_siegeworkshop") then
		return false
	end
	return true
end

-- Unified production-cap classifier for construction events where context provides pbg + entity.
-- Uses both EBP and entity checks to avoid variant/type mismatch.
local function CBA_Options_BuildingLimit_IsProductionCapBuildingFromContext(pbg, entity, is_starter_keep)
	if is_starter_keep then return false end
	local is_prod =
		(pbg ~= nil and (Entity_IsEBPOfType(pbg, "military_only_production") or Entity_IsEBPOfType(pbg, "military_production_building"))) or
		(entity ~= nil and (Entity_IsOfType(entity, "military_only_production") or Entity_IsOfType(entity, "military_production_building")))
	if not is_prod then return false end
	local is_excluded =
		(pbg ~= nil and (Entity_IsEBPOfType(pbg, "military_school_ott") or Entity_IsEBPOfType(pbg, "landmark") or Entity_IsEBPOfType(pbg, "scar_siegeworkshop"))) or
		(entity ~= nil and (Entity_IsOfType(entity, "military_school_ott") or Entity_IsOfType(entity, "landmark") or Entity_IsOfType(entity, "scar_siegeworkshop")))
	return not is_excluded
end

-- Unified workshop/siege-landmark classifier.
-- Landmarks count only for workshop/siege when they are in the explicit allowlist below.
local function CBA_Options_BuildingLimit_IsWorkshopCapBuilding(entity, player_civ, branch_civ, is_starter_keep)
	if entity == nil then return false end
	local is_english_keep = (branch_civ == "english" and Entity_IsOfType(entity, "scar_keep"))
	if is_english_keep then
		return not is_starter_keep
	end
	return
		(player_civ == "chinese" and Entity_HasBlueprint(entity, EBP.CHINESE.BUILDING_LANDMARK_AGE2_CLOCKTOWER_CONTROL_CHI)) or
		(branch_civ == "french" and Entity_HasBlueprint(entity, EBP.FRENCH.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE)) or
		(player_civ == "french_ha_01" and Entity_HasBlueprint(entity, EBP.FRENCH_HA_01.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE_HA_01)) or
		(player_civ == "ottoman" and Entity_HasBlueprint(entity, EBP.OTTOMAN.BUILDING_LANDMARK_AGE2_TOPHANE_ARMORY_OTT)) or
		Entity_IsOfType(entity, "scar_siegeworkshop")
end

-- Unified workshop classifier for construction events where context provides pbg + entity.
local function CBA_Options_BuildingLimit_IsWorkshopCapBuildingFromContext(pbg, entity, player_civ, branch_civ, is_starter_keep)
	if CBA_Options_BuildingLimit_IsWorkshopCapBuilding(entity, player_civ, branch_civ, is_starter_keep) then
		return true
	end
	if pbg == nil then return false end
	if branch_civ == "english" and Entity_IsEBPOfType(pbg, "scar_keep") then
		return not is_starter_keep
	end
	return Entity_IsEBPOfType(pbg, "scar_siegeworkshop")
end

-- Re-applies workshop lock/unlock based on current counter vs effective cap.
-- Called after RecountPlayer and during RevalidateAll/EnforcePostTransfer.
function CBA_Options_WorkshopLimit_ApplyThreshold(player)
	if player == nil or player.id == nil then return end
	local cap = CBA_Options_GetPlayerWorkshopLimit(player)
	if cap == 0 or AGS_GLOBAL_SETTINGS.NoSiege then return end
	local ws = player.obj_buildingLimit_workshop_count or 0
	local player_civ = Player_GetRaceName(player.id)
	local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ
	local age = Player_GetCurrentAge(player.id)
	if ws >= cap then
		AGS_SetEntityProductionAvailabilitySafe(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_WORKSHOP), ITEM_LOCKED, "CBA_Options_WorkshopLimit_ApplyThreshold/workshop_locked/" .. tostring(player.raceName))
		if player_civ == "chinese" then
			Player_SetEntityProductionAvailability(player.id, EBP.CHINESE.BUILDING_LANDMARK_AGE2_CLOCKTOWER_CONTROL_CHI, ITEM_LOCKED)
		elseif branch_civ == "french" then
			Player_SetEntityProductionAvailability(player.id, EBP.FRENCH.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE, ITEM_LOCKED)
			if player_civ == "french_ha_01" then
				Player_SetEntityProductionAvailability(player.id, EBP.FRENCH_HA_01.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE_HA_01, ITEM_LOCKED)
			end
		elseif player_civ == "ottoman" then
			Player_SetEntityProductionAvailability(player.id, EBP.OTTOMAN.BUILDING_LANDMARK_AGE2_TOPHANE_ARMORY_OTT, ITEM_LOCKED)
		end
	elseif age >= 3 then
		AGS_SetEntityProductionAvailabilitySafe(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_WORKSHOP), ITEM_DEFAULT, "CBA_Options_WorkshopLimit_ApplyThreshold/workshop_default/" .. tostring(player.raceName))
		if player_civ == "chinese" then
			Player_SetEntityProductionAvailability(player.id, EBP.CHINESE.BUILDING_LANDMARK_AGE2_CLOCKTOWER_CONTROL_CHI, ITEM_DEFAULT)
		elseif branch_civ == "french" then
			Player_SetEntityProductionAvailability(player.id, EBP.FRENCH.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE, ITEM_DEFAULT)
			if player_civ == "french_ha_01" then
				Player_SetEntityProductionAvailability(player.id, EBP.FRENCH_HA_01.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE_HA_01, ITEM_DEFAULT)
			end
		elseif player_civ == "ottoman" then
			Player_SetEntityProductionAvailability(player.id, EBP.OTTOMAN.BUILDING_LANDMARK_AGE2_TOPHANE_ARMORY_OTT, ITEM_DEFAULT)
		end
	end
end

-- Re-applies production lock/unlock based on current counter vs effective cap.
-- Called after reconciliation/recount and during revalidation/enforcement flows.
function CBA_Options_ProductionLimit_ApplyThreshold(player)
	if player == nil or player.id == nil then return end
	local cap = CBA_Options_GetPlayerProdLimit(player)
	if cap == nil or cap <= 0 then
		CBA_Options_BuildingLimit_UnlockPlayer(player)
		return
	end
	local prod = player.obj_buildingLimit_count or 0
	if prod >= cap then
		CBA_Options_BuildingLimit_LockPlayer(player)
	else
		CBA_Options_BuildingLimit_UnlockPlayer(player)
	end
end

-- Building / Set maximum allowed Unit Production buildings
function CBA_Options_BuildingLimit_SetupObjective()
	
	-- Objective data
	_buildingLimit = {
	module = "buildingLimit",
	objective_main_title = "$f5a005650ae44d2b8e05306aa891f90c:277", -- "Time remaining until next Age unlocked"
	objective_buildingLimit_title = Loc_FormatText("$11168874","$2957","$11255701"), -- "%1% : %2%, 1. Maximum, 2. Military Production Buildings"
	cancelled_entities = {}, -- EntityIDs seen in GE_ConstructionCancelled; used to dedupe GE_EntityKilled.
	debug_on_entity_killed = false, -- Verbose kill-event diagnostics; disabled by default to avoid log spam.
	icons = {
		objective = "icons\\races\\common\\victory_conditions\\victory_condition_conquest",
	},
}
	
	-- Checks for a build production building and increases objective counter, this counter will be used to set restrictions with set lobby values
	if _buildingLimit.objective_buildingLimit == nil then 
		
		-- Create and store objective in the global table created at the start of this script
		_buildingLimit.objective_buildingLimit = Obj_Create(localPlayer.id, _buildingLimit.objective_buildingLimit_title, Loc_Empty(), _buildingLimit.icons.objective, "WonderObjectiveTemplate", localPlayer.raceName, OT_Primary, 0, "wonderObj")
		
		-- Create local player counts for objectives/limits
		for i, player in ipairs(PLAYERS) do				
			player.obj_buildingLimit_count = 0
			player.obj_buildingLimit_workshop_count = 0
			player.obj_buildingLimit_outpost_count = 0
			player.obj_buildingLimit_english_start_keep_id = nil
			player.teamBalance_prodLimit = AGS_GLOBAL_SETTINGS.MaximumProductionBuildings
		end
		
		-- Reconcile counters with pre-existing map entities (e.g. prefab/spawned keeps)
		for i, player in ipairs(PLAYERS) do
			local eg_existing = Player_GetEntities(player.id)
			local player_civ = Player_GetRaceName(player.id)
			local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ
			-- Use the authoritative starting Keep set by Mod_FindKeep() (runs before PresetFinalize).
			-- player.keep.entity is the definitive starting Keep for every civ.
			if branch_civ == "english" and player.keep ~= nil and player.keep.entity ~= nil then
				player.obj_buildingLimit_english_start_keep_id = player.keep.entity
				DebugLog("bld_limit", string.format(
					"Reconcile: P%d (%s) starter keep excluded entity=%s id=%s",
					player.playerIndex or 0, player_civ,
					tostring(player.keep.entity), tostring(player.keep.entity_id)
				))
			end
			EGroup_ForEach(eg_existing, function(gid, idx, eid)
				local is_starter_keep = (eid == player.obj_buildingLimit_english_start_keep_id)
				if CBA_Options_BuildingLimit_IsProductionCapBuildingByEntity(eid, is_starter_keep) then
					player.obj_buildingLimit_count = player.obj_buildingLimit_count + 1
				end
				if AGS_GLOBAL_SETTINGS.MaximumSiegeWorkshop ~= 0 and not AGS_GLOBAL_SETTINGS.NoSiege and
					CBA_Options_BuildingLimit_IsWorkshopCapBuilding(eid, player_civ, branch_civ, is_starter_keep) then
					player.obj_buildingLimit_workshop_count = player.obj_buildingLimit_workshop_count + 1
				end
				-- Outpost (includes Stone Wall Towers)
				if Entity_IsOfType(eid, "scar_outpost") or Entity_IsOfType(eid, "stone_wall_tower") then
					player.obj_buildingLimit_outpost_count = player.obj_buildingLimit_outpost_count + 1
				end
			end)
			EGroup_Destroy(eg_existing)
			CBA_Options_ProductionLimit_ApplyThreshold(player)
		end
		
		local obj_buildingLimit_count = 0
		for _, player in ipairs(PLAYERS) do
			if player.id == localPlayer.id then
				obj_buildingLimit_count = player.obj_buildingLimit_count
			end
		end
		 
		-- Sets the objective's state to incomplete
		Obj_SetState(_buildingLimit.objective_buildingLimit, OS_Incomplete)
		-- Sets the objective to visible so players can see it
		Obj_SetVisible(_buildingLimit.objective_buildingLimit, true)
		-- Sets the progress element of the objective to visible so players can see it
		Obj_SetProgressVisible(_buildingLimit.objective_buildingLimit, true)
		-- Sets the objective progress type to a counter
		Obj_SetCounterType(_buildingLimit.objective_buildingLimit, COUNTER_CountUpTo)
		-- Set the starting objective progress to Starting Age value
		Obj_SetCounterCount(_buildingLimit.objective_buildingLimit, obj_buildingLimit_count)
		-- Set the maximum objective progress
		Obj_SetCounterMax(_buildingLimit.objective_buildingLimit, CBA_Options_GetPlayerProdLimit(localPlayer))
		-- Set the objective progress bar percentage value
		Obj_SetProgress(_buildingLimit.objective_buildingLimit, obj_buildingLimit_count)
	end
end

-- Building + Siege Limit / Increase value / Construction started
function CBA_Options_BuildingLimit_ConstructionStart(context)
	
	-- Store the player who constructed the building
	local player = Core_GetPlayersTableEntry(context.player)
	local player_civ = Player_GetRaceName(player.id)
	local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ
	
	-- Check to see if there was a player (just in case the building was constructed via script or some other means) and that the player has not been eliminated yet
	if player ~= nil and not player.isEliminated then
		local is_starter_keep = (context.entity ~= nil and context.entity == player.obj_buildingLimit_english_start_keep_id)
		
		-- Building Limits
		if AGS_GLOBAL_SETTINGS.MaximumProductionBuildings ~= 0 then
			
			if CBA_Options_BuildingLimit_IsProductionCapBuildingFromContext(context.pbg, context.entity, is_starter_keep) then
				
				
				-- Since the player constructed a production building, calculate their new progress
				player.obj_buildingLimit_count = player.obj_buildingLimit_count + 1
				
				-- Check if the player is the local player, we only want to run the below code for the local player as only their objective UI needs to be updated
				if player.isLocal then
					
					-- Update their objective progress UI
					Obj_SetCounterCount(_buildingLimit.objective_buildingLimit, player.obj_buildingLimit_count)
					Obj_SetProgress(_buildingLimit.objective_buildingLimit, player.obj_buildingLimit_count / CBA_Options_GetPlayerProdLimit(player))
				end
				
				-- Enable restrictions
				if player.obj_buildingLimit_count >= CBA_Options_GetPlayerProdLimit(player) then
					CBA_Options_BuildingLimit_LockPlayer(player)
					
					-- Display notification limit has been reached
					if player.isLocal then
						local event_cue_text = Loc_FormatText("$f5a005650ae44d2b8e05306aa891f90c:411", "$11194216", CBA_Options_GetPlayerProdLimit(player))
						UI_CreateEventCueClickable(-1, 15, -1, 0, event_cue_text, "", "low_priority", "", "sfx_ui_event_queue_low_priority_play", 255, 255, 255, 255, ECV_Queue, nothing)
					end
				end
			end
			
			-- FIX: Workshop limit — independent of production building type check.
			-- Was nested inside the production building block, so non-production siege buildings
			-- (e.g. standalone siege workshops) were not counted independently.
			if AGS_GLOBAL_SETTINGS.MaximumSiegeWorkshop ~= 0 and not AGS_GLOBAL_SETTINGS.NoSiege and
				CBA_Options_BuildingLimit_IsWorkshopCapBuildingFromContext(context.pbg, context.entity, player_civ, branch_civ, is_starter_keep) then
				
				-- Add to player's count / +1
				player.obj_buildingLimit_workshop_count = player.obj_buildingLimit_workshop_count + 1
				-- If limit reached, disable workshop
				if player.obj_buildingLimit_workshop_count >= CBA_Options_GetPlayerWorkshopLimit(player) then
					AGS_SetEntityProductionAvailabilitySafe(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_WORKSHOP), ITEM_LOCKED, "CBA_Options_BuildingLimit_SetupObjective/workshop_locked/" .. tostring(player.raceName))
					
					-- Restrictions: Siege Workshop / Faction unique 
					if player_civ == "chinese" then
						Player_SetEntityProductionAvailability(player.id, EBP.CHINESE.BUILDING_LANDMARK_AGE2_CLOCKTOWER_CONTROL_CHI, ITEM_LOCKED)
					elseif branch_civ == "french" then
						Player_SetEntityProductionAvailability(player.id, EBP.FRENCH.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE, ITEM_LOCKED)
						if player_civ == "french_ha_01" then
							Player_SetEntityProductionAvailability(player.id, EBP.FRENCH_HA_01.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE_HA_01, ITEM_LOCKED)
						end
					elseif player_civ == "ottoman" then
						Player_SetEntityProductionAvailability(player.id, EBP.OTTOMAN.BUILDING_LANDMARK_AGE2_TOPHANE_ARMORY_OTT, ITEM_LOCKED)
					end
					
					-- Display notification limit has been reached
					if player.isLocal then
						local event_cue_text = Loc_FormatText("$f5a005650ae44d2b8e05306aa891f90c:411", "$11119481", CBA_Options_GetPlayerWorkshopLimit(player))
						UI_CreateEventCueClickable(-1, 15, -1, 0, event_cue_text, "", "low_priority", "", "sfx_ui_event_queue_low_priority_play", 255, 255, 255, 255, ECV_Queue, nothing)
					end
				end	
			end
			
			-- Outpost limit (includes Stone Wall Towers)
			if Entity_IsEBPOfType(context.pbg, "scar_outpost") or Entity_IsEBPOfType(context.pbg, "stone_wall_tower") then
				
				-- Add to player's count / +1
				player.obj_buildingLimit_outpost_count = player.obj_buildingLimit_outpost_count + 1
				-- If limit reached, disable outpost
				if player.obj_buildingLimit_outpost_count >= CBA_Options_GetPlayerOutpostLimit(player) then
					Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprintsWithType("scar_outpost"), ITEM_LOCKED)
					Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprintsWithType("stone_wall_tower"), ITEM_LOCKED)
					-- Display notification limit has been reached
					if player.isLocal then
						local event_cue_text_outpost = Loc_FormatText("$f5a005650ae44d2b8e05306aa891f90c:411", "$11121046", CBA_Options_GetPlayerOutpostLimit(player))
						UI_CreateEventCueClickable(-1, 15, -1, 0, event_cue_text_outpost, "", "low_priority", "", "sfx_ui_event_queue_low_priority_play", 255, 255, 255, 255, ECV_Queue, nothing)
					end
				end	
			end
		end
		
		-- Refresh Limits Panel for local player (covers all limit counter changes above)
		if player.isLocal then
			AGS_LimitsUI_Update()
		end
	end			
end

-- Building + Siege Limit Limit / Decrease value / Construction cancelled
function CBA_Options_BuildingLimit_ConstructionCancelled(context)
	
	-- Store the player who constructed the building
	local player = Core_GetPlayersTableEntry(context.player)
	local player_civ = Player_GetRaceName(player.id)
	local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ
	local age = Player_GetCurrentAge(player.id)
	
	-- Check to see if there was a player (just in case the building was constructed via script or some other means) and that the player has not been eliminated yet
	if player ~= nil and not player.isEliminated then
		local is_starter_keep = (context.entity ~= nil and context.entity == player.obj_buildingLimit_english_start_keep_id)
		-- Mark this cancelled scaffold so GE_EntityKilled for the same entity does not double-decrement.
		if _buildingLimit ~= nil and _buildingLimit.cancelled_entities ~= nil and context.entity ~= nil then
			local ok_id, cancelled_id = pcall(Entity_GetID, context.entity)
			if ok_id and cancelled_id ~= nil then
				_buildingLimit.cancelled_entities[cancelled_id] = true
			end
		end
		
		-- Building Limit
		if AGS_GLOBAL_SETTINGS.MaximumProductionBuildings ~= 0 then
			
			if CBA_Options_BuildingLimit_IsProductionCapBuildingFromContext(context.pbg, context.entity, is_starter_keep) then
				
				-- Military Building Count/Objective
				if player.obj_buildingLimit_count ~= 0 then
					-- Since the player constructed a production building, calculate their new progress
					player.obj_buildingLimit_count = player.obj_buildingLimit_count - 1
					-- Check if the player is the local player, we only want to run the below code for the local player as only their objective UI needs to be updated
					if player.isLocal then
						-- Update their objective progress UI
						Obj_SetCounterCount(_buildingLimit.objective_buildingLimit, player.obj_buildingLimit_count)
						Obj_SetProgress(_buildingLimit.objective_buildingLimit, player.obj_buildingLimit_count / CBA_Options_GetPlayerProdLimit(player))
					end	
				end
			end
			
			-- FIX: Workshop Count — independent of production building type check
			if AGS_GLOBAL_SETTINGS.MaximumSiegeWorkshop ~= 0 and not AGS_GLOBAL_SETTINGS.NoSiege and
				CBA_Options_BuildingLimit_IsWorkshopCapBuildingFromContext(context.pbg, context.entity, player_civ, branch_civ, is_starter_keep) then
				
				-- Add to player's count / -1 (floor at 0)
				player.obj_buildingLimit_workshop_count = math.max(0, player.obj_buildingLimit_workshop_count - 1)
			end
			
			-- Disable restriction
			if player.obj_buildingLimit_count < CBA_Options_GetPlayerProdLimit(player) then
				-- Restrictions: Siege Workshop
				if player.obj_buildingLimit_workshop_count < CBA_Options_GetPlayerWorkshopLimit(player) and age >= 3 then
					AGS_SetEntityProductionAvailabilitySafe(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_WORKSHOP), ITEM_DEFAULT, "CBA_Options_BuildingLimit_OnEntityKilled/workshop_default/" .. tostring(player.raceName))
					-- Restrictions: Siege Workshop / Faction unique 
					if player_civ == "chinese" then
						Player_SetEntityProductionAvailability(player.id, EBP.CHINESE.BUILDING_LANDMARK_AGE2_CLOCKTOWER_CONTROL_CHI, ITEM_DEFAULT)
					elseif branch_civ == "french" then
						Player_SetEntityProductionAvailability(player.id, EBP.FRENCH.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE, ITEM_DEFAULT)
						if player_civ == "french_ha_01" then
							Player_SetEntityProductionAvailability(player.id, EBP.FRENCH_HA_01.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE_HA_01, ITEM_DEFAULT)
						end
					elseif player_civ == "ottoman" then
						Player_SetEntityProductionAvailability(player.id, EBP.OTTOMAN.BUILDING_LANDMARK_AGE2_TOPHANE_ARMORY_OTT, ITEM_DEFAULT)
					end
				end
				
				CBA_Options_BuildingLimit_UnlockPlayer(player)
			end
			
			-- Outpost limit (includes Stone Wall Towers)
			if Entity_IsEBPOfType(context.pbg, "scar_outpost") or Entity_IsEBPOfType(context.pbg, "stone_wall_tower") then
				
				-- Add to player's count / -1 (floor at 0)
				player.obj_buildingLimit_outpost_count = math.max(0, player.obj_buildingLimit_outpost_count - 1)
				-- If no limit reached, disable outpost
				if player.obj_buildingLimit_outpost_count < CBA_Options_GetPlayerOutpostLimit(player) then
					Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprintsWithType("scar_outpost"), ITEM_DEFAULT)
					Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprintsWithType("stone_wall_tower"), ITEM_DEFAULT)
				end	
			end
		end
		
		-- Refresh Limits Panel for local player
		if player.isLocal then
			AGS_LimitsUI_Update()
		end
	end
end

-- Building Limit / Decrease value / Building destroyed 
function CBA_Options_BuildingLimit_OnEntityKilled(context)
	
	if context.victimOwner == nil then
		return
	end
	
	local entity = Entity_FromID(context.victim.EntityID)
	local player = Util_GetPlayerOwner(context.victimOwner)
	if player == nil then
		return
	end
	player = PLAYERS[World_GetPlayerIndex(player)]
	if player == nil then
		return
	end
	-- FIX: Removed isEliminated early-return guard. Eliminated players' buildings may
	-- still be alive (transferred to allies or pending destruction). Counters must
	-- still decrement when these buildings die, otherwise the counter drifts positive
	-- and restrictions never unlock for the surviving owner.
	-- Production availability calls below are safe to call on eliminated players (no-op).
	local player_civ = Player_GetRaceName(player.id)
	local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ
	local age = Player_GetCurrentAge(player.id)

	-- Avoid -2 counter drift: cancellation already decremented on GE_ConstructionCancelled.
	if _buildingLimit ~= nil and _buildingLimit.cancelled_entities ~= nil and context.victim.EntityID ~= nil then
		if _buildingLimit.cancelled_entities[context.victim.EntityID] then
			_buildingLimit.cancelled_entities[context.victim.EntityID] = nil
			if _buildingLimit.debug_on_entity_killed == true then
				DebugLog("bld_limit", string.format(
					"OnEntityKilled: skip cancelled entity_id=%d (already processed by ConstructionCancelled)",
					context.victim.EntityID
				))
			end
			if player.isLocal then
				AGS_LimitsUI_Update()
			end
			return
		end
	end
	
	-- [DIAG] Log entity type and counter state before decrement
	local is_prod = Entity_IsOfType(entity, "military_only_production") or Entity_IsOfType(entity, "military_production_building")
	local is_workshop = Entity_IsOfType(entity, "scar_siegeworkshop")
	local is_keep = Entity_IsOfType(entity, "scar_keep")
	local is_outpost = Entity_IsOfType(entity, "scar_outpost")
	local is_stone_wall_tower = Entity_IsOfType(entity, "stone_wall_tower")
	if _buildingLimit ~= nil and _buildingLimit.debug_on_entity_killed == true then
		DebugLog("bld_limit", string.format(
			"OnEntityKilled: P%d (%s) entity_id=%d prod=%s ws=%s keep=%s outpost=%s sw_tower=%s counters=[bld=%s ws=%s op=%s]",
			player.playerIndex or World_GetPlayerIndex(player.id),
			player_civ,
			context.victim.EntityID,
			tostring(is_prod), tostring(is_workshop), tostring(is_keep), tostring(is_outpost), tostring(is_stone_wall_tower),
			tostring(player.obj_buildingLimit_count),
			tostring(player.obj_buildingLimit_workshop_count),
			tostring(player.obj_buildingLimit_outpost_count)
		))
	end
	
	-- FIX: Starter Keep was excluded from both production and workshop counts at init;
	-- skip all decrements to maintain counter symmetry.
	if context.victim.EntityID == player.obj_buildingLimit_english_start_keep_id then
		if _buildingLimit ~= nil and _buildingLimit.debug_on_entity_killed == true then
			DebugLog("bld_limit", string.format(
				"OnEntityKilled: skip starter keep entity_id=%d (excluded at reconciliation)",
				context.victim.EntityID
			))
		end
		if player.isLocal then
			AGS_LimitsUI_Update()
		end
		return
	end
	
	if CBA_Options_BuildingLimit_IsProductionCapBuildingByEntity(entity, false) then
		
		-- Objective setup
		if player.obj_buildingLimit_count ~= 0 then
			-- Since the player constructed a production building, calculate their new progress
			player.obj_buildingLimit_count = player.obj_buildingLimit_count - 1
			-- Check if the player is the local player, we only want to run the below code for the local player as only their objective UI needs to be updated
			if player.isLocal then
				-- Update their objective progress UI
				Obj_SetCounterCount(_buildingLimit.objective_buildingLimit, player.obj_buildingLimit_count)
				Obj_SetProgress(_buildingLimit.objective_buildingLimit, player.obj_buildingLimit_count / CBA_Options_GetPlayerProdLimit(player))
			end
		end
	end
	
	-- FIX: Workshop limit — independent of production building type check
	if AGS_GLOBAL_SETTINGS.MaximumSiegeWorkshop ~= 0 and not AGS_GLOBAL_SETTINGS.NoSiege and
		CBA_Options_BuildingLimit_IsWorkshopCapBuilding(entity, player_civ, branch_civ, false) then
		-- Add to player's count / -1 (floor at 0)
		player.obj_buildingLimit_workshop_count = math.max(0, player.obj_buildingLimit_workshop_count - 1)
	end
	
	-- Disable restrictions
	if player.obj_buildingLimit_count < CBA_Options_GetPlayerProdLimit(player) then
		-- Restrictions: Siege Workshop
		if player.obj_buildingLimit_workshop_count < CBA_Options_GetPlayerWorkshopLimit(player) and age >= 3 then
			AGS_SetEntityProductionAvailabilitySafe(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_WORKSHOP), ITEM_DEFAULT, "CBA_Options_BuildingLimit_OnScaffoldKilled/workshop_default/" .. tostring(player.raceName))
			-- Restrictions: Siege Workshop / Faction unique 
			if player_civ == "chinese" then
				Player_SetEntityProductionAvailability(player.id, EBP.CHINESE.BUILDING_LANDMARK_AGE2_CLOCKTOWER_CONTROL_CHI, ITEM_DEFAULT)
			elseif branch_civ == "french" then
				Player_SetEntityProductionAvailability(player.id, EBP.FRENCH.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE, ITEM_DEFAULT)
				if player_civ == "french_ha_01" then
					Player_SetEntityProductionAvailability(player.id, EBP.FRENCH_HA_01.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE_HA_01, ITEM_DEFAULT)
				end
			elseif player_civ == "ottoman" then
				Player_SetEntityProductionAvailability(player.id, EBP.OTTOMAN.BUILDING_LANDMARK_AGE2_TOPHANE_ARMORY_OTT, ITEM_DEFAULT)
			end
		end
		CBA_Options_BuildingLimit_UnlockPlayer(player)
	end
	
	-- Outpost limit (includes Stone Wall Towers)
	if Entity_IsOfType(entity, "scar_outpost") or Entity_IsOfType(entity, "stone_wall_tower") then
		
		-- Add to player's count / -1 (floor at 0)
		player.obj_buildingLimit_outpost_count = math.max(0, player.obj_buildingLimit_outpost_count - 1)
		-- If no limit reached, disable outpost
		if player.obj_buildingLimit_outpost_count < CBA_Options_GetPlayerOutpostLimit(player) then
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprintsWithType("scar_outpost"), ITEM_DEFAULT)
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprintsWithType("stone_wall_tower"), ITEM_DEFAULT)
		end	
	end
	
	-- Refresh Limits Panel for local player
	if player.isLocal then
		AGS_LimitsUI_Update()
	end
end

-- DEPRECATED: Queue items are no longer cancelled. Spawn-reject via EnforceSpawnCap handles over-cap.
-- Retained as no-ops for debug coverage compatibility. Remove in next major update.
function CBA_Options_SiegeLimit_Cancel_1(gid, index, iid) end
function CBA_Options_SiegeLimit_Cancel_2(gid, index, iid) end
function CBA_Options_SiegeLimit_Cancel_3(gid, index, iid) end

-- Building Ability / Adds 'Scuttle no enemies' to all buildings
function CBA_Options_AddScuttle_ConstructionComplete(context)
	
	-- Check 'tent' to avoid error on 'dropped_banner_jpn'
	if Entity_IsOfType(context.entity, "tent") == false then
		
		-- Replace 'Scuttle' ability (uses cached BPs from PresetFinalize)
		if Entity_HasAbility(context.entity, _CBA_ABP_Scuttle) then
			Entity_RemoveAbility(context.entity, _CBA_ABP_Scuttle)
			Entity_AddAbility(context.entity, _CBA_ABP_ScuttleNoEnemies)
		end
		
		-- Mongol only
		if Entity_HasAbility(context.entity, _CBA_ABP_PackMon) then
			Entity_RemoveAbility(context.entity, _CBA_ABP_PackMon)
		end
	end
end

-- Restriction: Archery/Stable unlocked in Dark Age / CBA_Auto_Age
function CBA_Options_DarkAge_Unlocks()
	
	for _, player in ipairs(PLAYERS) do
		local player_civ = Player_GetRaceName(player.id)
		-- Buildings
		if player.obj_buildingLimit_count < CBA_Options_GetPlayerProdLimit(player) then
			AGS_SetEntityProductionAvailabilitySafe(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_STABLE), ITEM_UNLOCKED, "CBA_Options_DarkAge_Unlocks/stable_unlocked/" .. tostring(player.raceName))
		end
		-- Units
		Player_SetSquadProductionAvailability(player.id, BP_GetSquadBlueprintsWithType("scar_archer"), ITEM_UNLOCKED)
		Player_SetSquadProductionAvailability(player.id, BP_GetSquadBlueprintsWithType("scar_horseman"), ITEM_UNLOCKED)
	end
end

-- Villager Spawner
function CBA_Options_VillagerSpawner()
	for i, player in ipairs(PLAYERS) do
		-- Check #1 - Player is alive & not max population
		if Core_IsPlayerEliminated(player.id) == false then
			if Player_GetCurrentPopulation(player.id,CT_Personnel) >= AGS_GLOBAL_SETTINGS.MaximumPopulation + 15 then
				-- FIX: Was 'return' which exited entire function, skipping remaining players.
				-- Use goto to skip only this player.
				goto continue_villager
			end
			
			
			local player_civ = Player_GetRaceName(player.id)
			local unit_type = AGS_GetCivilizationUnit(player_civ, AGS_BP_VILLAGER)
			local unit_num = 1
			local sg_vill = SGroup_CreateIfNotFound("sg_villager_count")
			Player_GetAll(player.id, sg_vill)
			SGroup_Filter(sg_vill, "scar_villager", FILTER_KEEP)
			local villager_count = SGroup_Count(sg_vill)
			if villager_count < 10 then
				CBA_Rewards_SpawnAndMove(player,unit_type,unit_num)
			end
		end
		::continue_villager::
	end	
end

-- Keep HP Boost & Production Lock
-- Applies 5x HP multiplier and locks keep production for every player.
-- Civs with castle = false (e.g. Mongol) fall back to the keep discovered
-- at runtime by Mod_FindKeep() — typically an .rdo-placed prefab.
function CBA_Option_KeepModifier()
	for _, player in ipairs(PLAYERS) do
		-- Prefer canonical civ-table keep BP; fall back to runtime-discovered keep
		local keep_ebp = AGS_GetCivilizationEntity(player.raceName, AGS_BP_KEEP)
		if keep_ebp == nil and player.keep ~= nil and player.keep.entity ~= nil then
			local ok, bp = pcall(Entity_GetBlueprint, player.keep.entity)
			if ok and bp ~= nil then
				keep_ebp = bp
				print(string.format("[CBA_OPTIONS] Using runtime keep BP for P%d (%s)", player.index, player.raceName))
			end
		end
		if keep_ebp ~= nil then
			-- Keep restriction is the intended gameplay behavior and should always apply.
			Player_SetEntityProductionAvailability(player.id, keep_ebp, ITEM_LOCKED)

			-- health_maximum_modifier can be unavailable for MAT_EntityType in some runtime data sets.
			-- Guard this so the match never hard-crashes during preset finalization.
			local ok_create, modifier_or_err = pcall(Modifier_Create, MAT_EntityType, "health_maximum_modifier", MUT_Multiplication, false, 5, keep_ebp)
			if ok_create and modifier_or_err ~= nil then
				local ok_apply, apply_err = pcall(Modifier_ApplyToPlayer, modifier_or_err, player.id, 0)
				if not ok_apply then
					print("[CBA_OPTIONS] Keep HP modifier apply failed for P" .. tostring(player.index) .. ": " .. tostring(apply_err))
				end
			else
				print("[CBA_OPTIONS] Keep HP modifier unavailable for P" .. tostring(player.index) .. ", skipping: " .. tostring(modifier_or_err))
			end
		else
			print(string.format("[CBA_OPTIONS] No keep BP for P%d (%s) — HP boost and production lock skipped", player.index, player.raceName))
		end
	end
end

-- Placeholder: Restriction for Outpost's upgrade: Cannon
function CBA_Options_OutpostRestrictions()
	for i, player in ipairs(PLAYERS) do
		local player_civ = Player_GetRaceName(player.id)
		local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ
		
		if branch_civ == "mongol" then
			Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint("upgrade_outpost_cannon_mon"), ITEM_REMOVED)
		else
			Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint("upgrade_outpost_cannon"), ITEM_REMOVED)
		end		
	end		
end			
---------------------------------------------------------------------------------------------------
-- Siege Limit — Shared threshold + deferred recheck helpers
---------------------------------------------------------------------------------------------------

-- Applies all three siege/ram/ST thresholds + field-construct gate in a single call.
-- Avoids repeating the same 4-call pattern in every handler.
function CBA_Options_SiegeLimit_ApplyAllThresholds(player)
	local ram_q, st_q, siege_q = _CBA_Options_GetAllQueuedCounts(player)
	CBA_Options_SiegeLimit_ApplyThreshold(player, siege_q)
	CBA_Options_RamLimit_ApplyThreshold(player, ram_q)
	CBA_Options_SiegeTowerLimit_ApplyThreshold(player, st_q)
	CBA_Options_FieldConstruct_Gate(player)
	return ram_q, st_q, siege_q
end

---------------------------------------------------------------------------------------------------
-- Siege Limit — Construction events (field-built siege: Mongol trebs, Abbasid units)
---------------------------------------------------------------------------------------------------

-- Field-built siege scaffold started — increment pending and apply thresholds.
-- DO NOT call RamLimit_Recount or SiegeTowerLimit_Recount here: their self-correction
-- resets pending to the current scaffold count in the entity list, but the new scaffold
-- may not have materialized yet. When multiple constructions fire in the same tick,
-- this causes pending to reset to 0 before each increment, so it never exceeds 1.
-- Recounts run on ConstructionComplete/Cancelled where scaffold state is settled.
function CBA_Options_SiegeLimit_ConstructionStart(context)
	local player = Core_GetPlayersTableEntry(context.player)
	if player ~= nil and not player.isEliminated then
		local player_civ = player.raceName or Player_GetRaceName(player.id)
		-- Early-exit: skip full recount/threshold cascade for non-siege buildings
		if context.pbg ~= nil then
			local dominated = Entity_IsEBPOfType(context.pbg, "siege") or Entity_IsEBPOfType(context.pbg, "ram")
				or Entity_IsEBPOfType(context.pbg, "fire_ram") or Entity_IsEBPOfType(context.pbg, "scar_ram")
				or Entity_IsEBPOfType(context.pbg, "scar_fire_ram") or Entity_IsEBPOfType(context.pbg, "ram_tower")
				or Entity_IsEBPOfType(context.pbg, "siege_tower")
			-- Buildable variants may lack type tags; check BP identity map as fallback
			if not dominated then
				dominated = CBA_Options_IsSiegeWeaponBPMatch_EBP(context.pbg, player_civ)
			end
			if not dominated then return end
		end
		local before_rp = player.ramLimit_pending or 0
		local before_sp = player.siegeTowerLimit_pending or 0
		local before_siege_p = player.siegeLimit_pending or 0
		-- Recount general siege (does not touch ram/ST/siege pending)
		CBA_Options_SiegeLimit_Recount(player)
		
		-- Increment pending for the new scaffold — no recount to avoid self-correction reset
		if context.pbg ~= nil then
			if CBA_Options_IsRamTowerEBP(context.pbg, player_civ) then
				-- Ram tower counts as 2 rams toward the ram limit
				player.ramLimit_pending = (player.ramLimit_pending or 0) + 2
			elseif Entity_IsEBPOfType(context.pbg, "ram") or Entity_IsEBPOfType(context.pbg, "fire_ram") or Entity_IsEBPOfType(context.pbg, "scar_ram") or Entity_IsEBPOfType(context.pbg, "scar_fire_ram") then
				player.ramLimit_pending = (player.ramLimit_pending or 0) + 1
			elseif Entity_IsEBPOfType(context.pbg, "siege_tower") then
				player.siegeTowerLimit_pending = (player.siegeTowerLimit_pending or 0) + 1
			else
				-- Generic siege weapon scaffolds (Mongol/Abbasid field-built)
				local weapon_pts = CBA_Options_GetSiegeWeaponPointsEBP(context.pbg, player_civ)
				if weapon_pts > 0 then
					player.siegeLimit_pending = (player.siegeLimit_pending or 0) + weapon_pts
				end
			end
		end
		
		if CBA_Options_ShouldLogSiegeVerbose() then
			local t_siege = context.pbg ~= nil and Entity_IsEBPOfType(context.pbg, "siege")
			local t_ram = context.pbg ~= nil and Entity_IsEBPOfType(context.pbg, "ram")
			local t_fire = context.pbg ~= nil and Entity_IsEBPOfType(context.pbg, "fire_ram")
			local t_scar_ram = context.pbg ~= nil and Entity_IsEBPOfType(context.pbg, "scar_ram")
			local t_scar_fire = context.pbg ~= nil and Entity_IsEBPOfType(context.pbg, "scar_fire_ram")
			local t_rt = context.pbg ~= nil and CBA_Options_IsRamTowerEBP(context.pbg, player_civ)
			local t_st = context.pbg ~= nil and Entity_IsEBPOfType(context.pbg, "siege_tower")
			local weapon_pts = context.pbg ~= nil and CBA_Options_GetSiegeWeaponPointsEBP(context.pbg, player_civ) or 0
			print(string.format(
				"[CBA_OPTIONS][SIEGE_LIMIT] ConstructionStart P%d civ=%s tags=[siege=%s ram=%s fire_ram=%s scar_ram=%s scar_fire=%s ram_tower=%s siege_tower=%s weapon_pts=%d] ram_pending %d->%d st_pending %d->%d siege_pending %d->%d",
				player.index or 0, tostring(player_civ),
				tostring(t_siege), tostring(t_ram), tostring(t_fire), tostring(t_scar_ram), tostring(t_scar_fire), tostring(t_rt), tostring(t_st), weapon_pts,
				before_rp, player.ramLimit_pending or 0,
				before_sp, player.siegeTowerLimit_pending or 0,
				before_siege_p, player.siegeLimit_pending or 0))
		end
		
		-- Single queue snapshot for thresholds + hotfix checks
		local snap_ram_q, snap_st_q, snap_siege_q = CBA_Options_SiegeLimit_ApplyAllThresholds(player)

		-- Hotfix: if rapid field placement overshoots cap before lock propagation,
		-- kill excess active ram scaffolds immediately and reapply enforcement.
		-- If immediate rollback can't find scaffolds (not yet materialized), schedule deferred retry.
		local ram_live = player.ramLimit_count or 0
		local ram_pending = player.ramLimit_pending or 0
		local ram_total = ram_live + ram_pending + snap_ram_q
		local ram_max = CBA_Options_GetPlayerRamLimit(player)
		if ram_total > ram_max then
			local excess = ram_total - ram_max
			local removed_weight, removed_scaffolds = CBA_Options_RamLimit_RollbackExcessScaffolds(player, excess)
			if removed_weight > 0 then
				CBA_Options_RamLimit_Recount(player)
				CBA_Options_SiegeLimit_ApplyAllThresholds(player)
			end
			if CBA_Options_ShouldLogSiegeStandard() then
				local after_live = player.ramLimit_count or 0
				local after_pending = player.ramLimit_pending or 0
				local after_total = after_live + after_pending + snap_ram_q
				print(string.format(
					"[CBA_OPTIONS][CAP_HOTFIX] ConstructionStart P%d ram_total=%d/%d excess=%d removed_weight=%d removed_scaffolds=%d post_total=%d/%d",
					player.index or 0,
					ram_total, ram_max, excess,
					removed_weight, removed_scaffolds,
					after_total, ram_max))
			end
			-- If immediate rollback didn't fully resolve, schedule deferred retry
			-- (scaffolds may not have materialized yet in Player_GetEntities)
			if removed_weight < excess then
				CBA_Options_SiegeLimit_ScheduleDeferredRecheck(player, "CAP_HOTFIX_DEFERRED")
			end
		end

		-- Hotfix: generic siege field placement overshoot cap
		if AGS_GLOBAL_SETTINGS.MaximumMedicPopulation ~= 0 then
			local max_siege = CBA_Options_GetPlayerSiegeLimit(player)
			local siege_live = player.siegeLimit_count or 0
			local siege_pending = player.siegeLimit_pending or 0
			local siege_total = siege_live + siege_pending + snap_siege_q
			if siege_total > max_siege then
				local siege_excess = siege_total - max_siege
				local removed_pts, removed_scaffolds = CBA_Options_SiegeLimit_RollbackExcessScaffolds(player, siege_excess)
				if removed_pts > 0 then
					CBA_Options_SiegeLimit_Recount(player)
					CBA_Options_SiegeLimit_ApplyAllThresholds(player)
				end
				if CBA_Options_ShouldLogSiegeStandard() then
					print(string.format(
						"[CBA_OPTIONS][CAP_HOTFIX_SIEGE] ConstructionStart P%d siege_total=%d/%d excess=%d removed_pts=%d removed_scaffolds=%d",
						player.index or 0, siege_total, max_siege, siege_excess, removed_pts, removed_scaffolds))
				end
				if removed_pts < siege_excess then
					CBA_Options_SiegeLimit_ScheduleDeferredRecheck(player, "CAP_HOTFIX_SIEGE_DEFERRED")
				end
			end
		end

		CBA_Options_ValidateEnforcement(player, "ConstructionStart")
	end
end

_CBA_SiegeLimit_DeferredRecheckPending = _CBA_SiegeLimit_DeferredRecheckPending or {}
_CBA_SiegeLimit_DeferredRecheckScheduled = _CBA_SiegeLimit_DeferredRecheckScheduled or false

function CBA_Options_SiegeLimit_ScheduleDeferredRecheck(player, reason)
	if player == nil or player.id == nil then return end
	local key = player.index or World_GetPlayerIndex(player.id)
	if key == nil then return end
	_CBA_SiegeLimit_DeferredRecheckPending[key] = {
		reason = reason or "unknown",
	}
	if not _CBA_SiegeLimit_DeferredRecheckScheduled then
		_CBA_SiegeLimit_DeferredRecheckScheduled = true
		-- PERF: 1.0s delay (was 0.25s) — coalesces rapid-fire siege events into one scan.
		Rule_AddOneShot(CBA_Options_SiegeLimit_RunDeferredRecheck, 1.0)
	end
end

function CBA_Options_SiegeLimit_RunDeferredRecheck()
	_CBA_SiegeLimit_DeferredRecheckScheduled = false
	for key, data in pairs(_CBA_SiegeLimit_DeferredRecheckPending) do
		local player = PLAYERS[key]
		if player ~= nil and not Core_IsPlayerEliminated(player.id) then
			local before_rp = player.ramLimit_pending or 0
			local before_sp = player.siegeTowerLimit_pending or 0
			local before_siege_p = player.siegeLimit_pending or 0
			CBA_Options_SiegeLimit_RecountAll(player)

			-- Single queue scan for rollback + thresholds
			local ram_queued, st_queued, siege_queued = _CBA_Options_GetAllQueuedCounts(player)

			-- Deferred rollback: if ram cap still exceeded, kill excess scaffolds
			local ram_live = player.ramLimit_count or 0
			local ram_pending = player.ramLimit_pending or 0
			local ram_total = ram_live + ram_pending + ram_queued
			local ram_max = CBA_Options_GetPlayerRamLimit(player)
			if ram_total > ram_max then
				local excess = ram_total - ram_max
				local removed_weight, removed_scaffolds = CBA_Options_RamLimit_RollbackExcessScaffolds(player, excess)
				if removed_weight > 0 then
					CBA_Options_RamLimit_Recount(player)
				end
				if CBA_Options_ShouldLogSiegeStandard() then
					print(string.format(
						"[CBA_OPTIONS][CAP_HOTFIX_DEFERRED] P%d ram_total=%d/%d excess=%d removed_weight=%d removed_scaffolds=%d",
						player.index or 0, ram_total, ram_max, excess, removed_weight, removed_scaffolds))
				end
			end

			-- Deferred rollback: if generic siege cap still exceeded, kill excess scaffolds
			if AGS_GLOBAL_SETTINGS.MaximumMedicPopulation ~= 0 then
				local max_siege = CBA_Options_GetPlayerSiegeLimit(player)
				local siege_live = player.siegeLimit_count or 0
				local siege_pending = player.siegeLimit_pending or 0
				local siege_total = siege_live + siege_pending + siege_queued
				if siege_total > max_siege then
					local siege_excess = siege_total - max_siege
					local removed_pts, removed_scaffolds = CBA_Options_SiegeLimit_RollbackExcessScaffolds(player, siege_excess)
					if removed_pts > 0 then
						CBA_Options_SiegeLimit_Recount(player)
					end
					if CBA_Options_ShouldLogSiegeStandard() then
						print(string.format(
							"[CBA_OPTIONS][CAP_HOTFIX_SIEGE_DEFERRED] P%d siege_total=%d/%d excess=%d removed_pts=%d removed_scaffolds=%d",
							player.index or 0, siege_total, max_siege, siege_excess, removed_pts, removed_scaffolds))
					end
				end
			end
			
			CBA_Options_SiegeLimit_ApplyAllThresholds(player)
			if CBA_Options_ShouldLogSiegeVerbose() then
				print(string.format("[CBA_OPTIONS][SIEGE_LIMIT] DeferredRecheck P%d (%s) ram_pending %d->%d st_pending %d->%d siege_pending %d->%d",
					player.index or 0,
					tostring(data.reason),
					before_rp,
					player.ramLimit_pending or 0,
					before_sp,
					player.siegeTowerLimit_pending or 0,
					before_siege_p,
					player.siegeLimit_pending or 0))
			end
			CBA_Options_ValidateEnforcement(player, "DeferredRecheck")
		end
		_CBA_SiegeLimit_DeferredRecheckPending[key] = nil
	end
end

-- Field-built siege scaffold cancelled — full recount to release the slot.
-- Recount self-correction rebuilds pending from ground truth (live scaffolds),
-- so no manual decrement is needed (it was redundant and caused double-decrement).
function CBA_Options_SiegeLimit_ConstructionCancelled(context)
	local player = Core_GetPlayersTableEntry(context.player)
	if player ~= nil and not player.isEliminated then
		local player_civ = player.raceName or Player_GetRaceName(player.id)
		-- Early-exit: skip full recount/threshold cascade for non-siege buildings
		if context.pbg ~= nil then
			local dominated = Entity_IsEBPOfType(context.pbg, "siege") or Entity_IsEBPOfType(context.pbg, "ram")
				or Entity_IsEBPOfType(context.pbg, "fire_ram") or Entity_IsEBPOfType(context.pbg, "scar_ram")
				or Entity_IsEBPOfType(context.pbg, "scar_fire_ram") or Entity_IsEBPOfType(context.pbg, "ram_tower")
				or Entity_IsEBPOfType(context.pbg, "siege_tower")
			-- Buildable variants may lack type tags; check BP identity map as fallback
			if not dominated then
				dominated = CBA_Options_IsSiegeWeaponBPMatch_EBP(context.pbg, player_civ)
			end
			if not dominated then return end
		end
		local before_rp = player.ramLimit_pending or 0
		local before_sp = player.siegeTowerLimit_pending or 0
		local before_siege = player.siegeLimit_count or 0
		local before_ram = player.ramLimit_count or 0
		local before_st = player.siegeTowerLimit_count or 0
		-- PERF: Incremental pending decrement instead of full RecountAll.
		-- Scaffold cancelled → decrement the pending slot that ConstructionStart added.
		-- Deferred recheck (0.25s) corrects any drift via full RecountAll.
		if context.pbg ~= nil then
			if CBA_Options_IsRamTowerEBP(context.pbg, player_civ) then
				player.ramLimit_pending = math.max(0, (player.ramLimit_pending or 0) - 2)
			elseif Entity_IsEBPOfType(context.pbg, "ram") or Entity_IsEBPOfType(context.pbg, "fire_ram") or Entity_IsEBPOfType(context.pbg, "scar_ram") or Entity_IsEBPOfType(context.pbg, "scar_fire_ram") then
				player.ramLimit_pending = math.max(0, (player.ramLimit_pending or 0) - 1)
			elseif Entity_IsEBPOfType(context.pbg, "siege_tower") then
				player.siegeTowerLimit_pending = math.max(0, (player.siegeTowerLimit_pending or 0) - 1)
			else
				local cancel_pts = CBA_Options_GetSiegeWeaponPointsEBP(context.pbg, player_civ)
				if cancel_pts > 0 then
					player.siegeLimit_pending = math.max(0, (player.siegeLimit_pending or 0) - cancel_pts)
				end
			end
		end
		CBA_Options_SiegeLimit_ApplyAllThresholds(player)
		if CBA_Options_ShouldLogSiegeVerbose() then
			local t_siege = context.pbg ~= nil and Entity_IsEBPOfType(context.pbg, "siege")
			local t_ram = context.pbg ~= nil and Entity_IsEBPOfType(context.pbg, "ram")
			local t_st = context.pbg ~= nil and Entity_IsEBPOfType(context.pbg, "siege_tower")
			local player_civ = player.raceName or Player_GetRaceName(player.id)
			local t_rt = context.pbg ~= nil and CBA_Options_IsRamTowerEBP(context.pbg, player_civ)
			print(string.format(
				"[CBA_OPTIONS][SIEGE_LIMIT] ConstructionCancelled P%d tags=[siege=%s ram=%s ram_tower=%s siege_tower=%s] before[siege=%d ram=%d st=%d rp=%d sp=%d] after[siege=%d ram=%d st=%d rp=%d sp=%d]",
				player.index or 0,
				tostring(t_siege), tostring(t_ram), tostring(t_rt), tostring(t_st),
				before_siege, before_ram, before_st, before_rp, before_sp,
				player.siegeLimit_count or 0, player.ramLimit_count or 0, player.siegeTowerLimit_count or 0,
				player.ramLimit_pending or 0, player.siegeTowerLimit_pending or 0))
		end
		CBA_Options_SiegeLimit_ScheduleDeferredRecheck(player, "ConstructionCancelled")
	end
end

-- Field-built siege scaffold completed — full recount to pick up the new unit.
-- Recount self-correction rebuilds pending from ground truth (live scaffolds),
-- so no manual decrement is needed (it was redundant and caused double-decrement).
function CBA_Options_SiegeLimit_ConstructionComplete(context)
	local player = Core_GetPlayersTableEntry(context.player)
	if player ~= nil and not player.isEliminated then
		local player_civ = player.raceName or Player_GetRaceName(player.id)
		-- Early-exit: skip full recount/threshold cascade for non-siege buildings
		if context.pbg ~= nil then
			local dominated = Entity_IsEBPOfType(context.pbg, "siege") or Entity_IsEBPOfType(context.pbg, "ram")
				or Entity_IsEBPOfType(context.pbg, "fire_ram") or Entity_IsEBPOfType(context.pbg, "scar_ram")
				or Entity_IsEBPOfType(context.pbg, "scar_fire_ram") or Entity_IsEBPOfType(context.pbg, "ram_tower")
				or Entity_IsEBPOfType(context.pbg, "siege_tower")
			-- Buildable variants may lack type tags; check BP identity map as fallback
			if not dominated then
				dominated = CBA_Options_IsSiegeWeaponBPMatch_EBP(context.pbg, player_civ)
			end
			if not dominated then return end
		end
		local before_siege = player.siegeLimit_count or 0
		local before_ram = player.ramLimit_count or 0
		local before_st = player.siegeTowerLimit_count or 0
		local before_rp = player.ramLimit_pending or 0
		local before_sp = player.siegeTowerLimit_pending or 0
		-- PERF: Incremental pending→count transfer instead of full RecountAll.
		-- Scaffold completed → move its weight from pending to count.
		-- Deferred recheck (0.25s) corrects any drift via full RecountAll.
		if context.pbg ~= nil then
			if CBA_Options_IsRamTowerEBP(context.pbg, player_civ) then
				player.ramLimit_pending = math.max(0, (player.ramLimit_pending or 0) - 2)
				player.ramLimit_count = (player.ramLimit_count or 0) + 2
			elseif Entity_IsEBPOfType(context.pbg, "ram") or Entity_IsEBPOfType(context.pbg, "fire_ram") or Entity_IsEBPOfType(context.pbg, "scar_ram") or Entity_IsEBPOfType(context.pbg, "scar_fire_ram") then
				player.ramLimit_pending = math.max(0, (player.ramLimit_pending or 0) - 1)
				player.ramLimit_count = (player.ramLimit_count or 0) + 1
			elseif Entity_IsEBPOfType(context.pbg, "siege_tower") then
				player.siegeTowerLimit_pending = math.max(0, (player.siegeTowerLimit_pending or 0) - 1)
				player.siegeTowerLimit_count = (player.siegeTowerLimit_count or 0) + 1
			else
				local complete_pts = CBA_Options_GetSiegeWeaponPointsEBP(context.pbg, player_civ)
				if complete_pts > 0 then
					player.siegeLimit_pending = math.max(0, (player.siegeLimit_pending or 0) - complete_pts)
					player.siegeLimit_count = (player.siegeLimit_count or 0) + complete_pts
				end
			end
		end
		local _bc_ram_q, _bc_st_q, _bc_siege_q = _CBA_Options_GetAllQueuedCounts(player)
		if CBA_Options_ShouldLogSiegeVerbose() then
			print(string.format(
				"[CBA_OPTIONS][SIEGE_LIMIT] ConstructionComplete P%d before[siege=%d ram=%d st=%d rp=%d sp=%d] after[siege=%d ram=%d st=%d rp=%d sp=%d]",
				player.index or 0,
				before_siege, before_ram, before_st, before_rp, before_sp,
				player.siegeLimit_count or 0, player.ramLimit_count or 0, player.siegeTowerLimit_count or 0,
				player.ramLimit_pending or 0, player.siegeTowerLimit_pending or 0))
		end
		
		CBA_Options_SiegeLimit_ApplyAllThresholds(player)
		CBA_Options_SiegeLimit_ScheduleDeferredRecheck(player, "ConstructionComplete")
	end
end

-- Siege scaffold killed by enemy — full recount to release the slot immediately.
-- Building limits register GE_EntityKilled; siege limits need the same to catch scaffold
-- destruction where only GE_EntityKilled fires (not GE_ConstructionCancelled).
function CBA_Options_SiegeLimit_EntityKilled(context)
	if context.victim == nil then return end
	local entity = context.victim
	if not World_OwnsEntity(entity) then return end
	-- Get owner first — entities mid-destruction may pass World_OwnsEntity but lack a player owner
	local ok_owner, owner = pcall(Entity_GetPlayerOwner, entity)
	if not ok_owner or owner == nil then return end
	local player = PLAYERS[World_GetPlayerIndex(owner)]
	-- PERF: Cached siege classification — avoids 7+ type checks per non-siege kill
	_CBA_PERF.ge_entity_killed_siege = _CBA_PERF.ge_entity_killed_siege + 1
	local ek_civ = (player ~= nil) and (player.raceName or Player_GetRaceName(owner)) or nil
	if not CBA_Options_IsSiegeEntityCached(entity, ek_civ) then return end
	if player ~= nil and not player.isEliminated then
		local before_rp = player.ramLimit_pending or 0
		local before_sp = player.siegeTowerLimit_pending or 0
		local before_siege = player.siegeLimit_count or 0
		local before_ram = player.ramLimit_count or 0
		local before_st_count = player.siegeTowerLimit_count or 0
		-- PERF: Incremental decrement instead of full RecountAll.
		-- Determine if killed entity was a scaffold (pending) or completed (count).
		-- Deferred recheck (0.25s) corrects any drift via full RecountAll.
		local ok_prog, prog = pcall(Entity_GetBuildingProgress, entity)
		local was_scaffold = ok_prog and prog < 1.0
		local is_ram_type = Entity_IsOfType(entity, "ram") or Entity_IsOfType(entity, "scar_ram") or Entity_IsOfType(entity, "fire_ram") or Entity_IsOfType(entity, "scar_fire_ram")
		local is_rt_type = Entity_IsOfType(entity, "ram_tower") or CBA_Options_IsRamTowerEntity(entity, player.raceName or Player_GetRaceName(player.id))
		local is_st_type = Entity_IsOfType(entity, "siege_tower")
		if is_rt_type then
			if was_scaffold then
				player.ramLimit_pending = math.max(0, (player.ramLimit_pending or 0) - 2)
			else
				player.ramLimit_count = math.max(0, (player.ramLimit_count or 0) - 2)
			end
		elseif is_ram_type then
			if was_scaffold then
				player.ramLimit_pending = math.max(0, (player.ramLimit_pending or 0) - 1)
			else
				player.ramLimit_count = math.max(0, (player.ramLimit_count or 0) - 1)
			end
		elseif is_st_type then
			if was_scaffold then
				player.siegeTowerLimit_pending = math.max(0, (player.siegeTowerLimit_pending or 0) - 1)
			else
				player.siegeTowerLimit_count = math.max(0, (player.siegeTowerLimit_count or 0) - 1)
			end
		else
			local ek_pts = CBA_Options_GetSiegeWeaponPointsEntity(entity, player.raceName or Player_GetRaceName(player.id))
			if ek_pts > 0 then
				if was_scaffold then
					player.siegeLimit_pending = math.max(0, (player.siegeLimit_pending or 0) - ek_pts)
				else
					player.siegeLimit_count = math.max(0, (player.siegeLimit_count or 0) - ek_pts)
				end
			end
		end
		CBA_Options_SiegeLimit_ApplyAllThresholds(player)
		if CBA_Options_ShouldLogSiegeVerbose() then
			print(string.format(
				"[CBA_OPTIONS][SIEGE_LIMIT] EntityKilled P%d entity_tags=[siege=%s ram=%s ram_tower=%s siege_tower=%s] progress=%.2f scaffold=%s before[siege=%d ram=%d st=%d rp=%d sp=%d] after[siege=%d ram=%d st=%d rp=%d sp=%d]",
				player.index or 0,
				tostring(Entity_IsOfType(entity, "siege")), tostring(is_ram_type), tostring(is_rt_type), tostring(is_st_type),
				ok_prog and prog or -1,
				tostring(was_scaffold),
				before_siege, before_ram, before_st_count, before_rp, before_sp,
				player.siegeLimit_count or 0, player.ramLimit_count or 0, player.siegeTowerLimit_count or 0,
				player.ramLimit_pending or 0, player.siegeTowerLimit_pending or 0))
		end
		CBA_Options_SiegeLimit_ScheduleDeferredRecheck(player, "EntityKilled")
	end
end

-- Squad produced from building queue — schedule deferred recount if siege-class.
-- GE_BuildItemComplete fires for all train-queue completions; early-exit for non-siege.
-- PERF: Uses SBP-keyed cache — after warm-up (~15 unique BPs), non-siege fires
-- cost 1 Lua table lookup instead of 7+ Squad_IsSBPOfType engine calls.
function CBA_Options_SiegeLimit_BuildItemComplete(context)
	if context.player == nil or context.pbg == nil then return end
	local player = Core_GetPlayersTableEntry(context.player)
	if player == nil or player.isEliminated then return end
	local player_civ = player.raceName or Player_GetRaceName(player.id)
	-- Early-exit: only process siege-class squads (cached SBP lookup)
	if not CBA_Options_IsSiegeSBPCached(context.pbg, player_civ) then return end
	_CBA_PERF.ge_build_item_siege = _CBA_PERF.ge_build_item_siege + 1
	-- PERF: Skip immediate ApplyAllThresholds (full entity+queue scan).
	-- The unit has already spawned — threshold enforcement can wait for the deferred
	-- recheck which does RecountAll + GetAllQueuedCounts + ApplyAllThresholds in one pass.
	CBA_Options_SiegeLimit_ScheduleDeferredRecheck(player, "BuildItemComplete")
end

-- Squad killed in combat — schedule deferred recount if siege-class to release slot.
-- GE_SquadKilled fires for all squad deaths; early-exit for non-siege.
function CBA_Options_SiegeLimit_SquadKilled(context)
	if context.victim == nil then return end
	if World_OwnsSquad(context.victim) then return end
	local ok_owner, owner = pcall(Squad_GetPlayerOwner, context.victim)
	if not ok_owner or owner == nil then return end
	local player = PLAYERS[World_GetPlayerIndex(owner)]
	if player == nil or player.isEliminated then return end
	-- PERF: Cached siege classification — avoids 7+ type checks per non-siege kill
	_CBA_PERF.ge_squad_killed_siege = _CBA_PERF.ge_squad_killed_siege + 1
	local sq_civ = player.raceName or Player_GetRaceName(owner)
	if not CBA_Options_IsSiegeSquadCached(context.victim, sq_civ) then return end
	CBA_Options_SiegeLimit_ApplyAllThresholds(player)
	CBA_Options_SiegeLimit_ScheduleDeferredRecheck(player, "SquadKilled")
end

---------------------------------------------------------------------------------------------------
-- Siege Limit — Recount & Threshold (reusable from transfer, age-up, rewards)
---------------------------------------------------------------------------------------------------

-- PERF: Maximum queue depth before capture handlers start dropping events.
-- Prevents unbounded memory growth under extreme kill spam (e.g., area-damage wipe).
-- Dropped events are counted in _CBA_PERF.batch_*_dropped; functional impact is minimal
-- since batched handlers are telemetry/UI only — immediate handlers still fire per-kill.
_CBA_BATCH_MAX_QUEUE = 500

-- Performance tracking for group allocations.
_CBA_PERF = _CBA_PERF or { sg_allocs = 0, eg_allocs = 0, recount_calls = 0, queue_scans = 0, disable_skipped = 0, reconcile_ticks = 0, last_reset_tick = 0,
	ge_entity_killed_siege = 0, ge_squad_killed_siege = 0, ge_build_item_siege = 0, siege_cache_hits = 0, siege_cache_misses = 0,
	batch_sq_processed = 0, batch_sq_ticks = 0, batch_sq_max_depth = 0, batch_sq_dropped = 0,
	batch_ek_processed = 0, batch_ek_ticks = 0, batch_ek_max_depth = 0, batch_ek_dropped = 0,
	batch_bi_processed = 0, batch_bi_ticks = 0, batch_bi_max_depth = 0, batch_bi_dropped = 0,
	batch_bld_decremented = 0, batch_bld_skipped_player_nil = 0, batch_bld_skipped_cancelled = 0,
	bld_reconcile_ticks = 0, bld_reconcile_drift = 0 }

-- PERF: Blueprint-keyed siege classification cache.
-- Maps SBP/EBP userdata -> true (siege-class) or false (not siege-class).
-- Populated lazily on first encounter; never invalidated (siege tags are BP-intrinsic).
_CBA_SIEGE_SBP_CACHE = _CBA_SIEGE_SBP_CACHE or {}
_CBA_SIEGE_EBP_CACHE = _CBA_SIEGE_EBP_CACHE or {}

---------------------------------------------------------------------------------------------------
-- GE_SquadKilled Batch Processor
-- Unified handler: captures context snapshot at event time, processes in 1-second batches.
-- Reduces per-event dispatch overhead from 5 handlers to 1 capture handler.
-- Side effects (threshold application, UI updates, deferred rechecks) consolidated per batch.
---------------------------------------------------------------------------------------------------
_CBA_SQUAD_KILL_BATCH = {
	queue = {},
	dirty = false,
	-- Sub-handler activation flags (modules set these instead of registering GE_SquadKilled)
	handlers = {
		siege_limit = false,    -- Set by CBA_Options_PresetFinalize
		battle_lag = false,     -- Set by battle lag harness start/stop
		limits_ui = false,      -- Set by AGS_LimitsUI OnPlay/OnGameOver
		special_pop_ui = false, -- Set by AGS_SpecialPopulationUI OnPlay/OnGameOver
		squad_losses = false,   -- Set by SquadLosses Initialize/Reset
	},
}

-- Module activation API: modules call this instead of Rule_Add/RemoveGlobalEvent for GE_SquadKilled.
function CBA_SquadKillBatch_SetHandler(key, active)
	_CBA_SQUAD_KILL_BATCH.handlers[key] = (active == true)
end

-- Capture handler: snapshots all context data while squad is still valid.
-- Registered as the single GE_SquadKilled handler; replaces 5 individual registrations.
function CBA_SquadKillBatch_Capture(context)
	if context == nil or context.victim == nil then return end
	if #_CBA_SQUAD_KILL_BATCH.queue >= _CBA_BATCH_MAX_QUEUE then
		_CBA_PERF.batch_sq_dropped = (_CBA_PERF.batch_sq_dropped or 0) + 1
		return
	end
	local squad = context.victim
	if World_OwnsSquad(squad) then return end

	local ok_owner, owner = pcall(Squad_GetPlayerOwner, squad)
	if not ok_owner or owner == nil then return end

	local player_idx = World_GetPlayerIndex(owner)
	local player = PLAYERS[player_idx]
	if player == nil then return end
	local player_civ = player.raceName or Player_GetRaceName(owner)

	-- Snapshot: siege classification (cache check while squad is valid)
	-- Only evaluate for non-eliminated players (siege handler skips eliminated)
	local is_siege = false
	if not player.isEliminated then
		is_siege = CBA_Options_IsSiegeSquadCached(squad, player_civ)
	end

	-- Snapshot: squad losses classification (only if handler active, avoid unnecessary type checks)
	local is_worker = false
	local is_military = false
	if _CBA_SQUAD_KILL_BATCH.handlers.squad_losses then
		is_worker = Squad_IsOfType(squad, "worker")
		is_military = not is_worker and Squad_IsOfType(squad, "military")
	end

	table.insert(_CBA_SQUAD_KILL_BATCH.queue, {
		player = player,
		player_idx = player_idx,
		owner_id = owner,
		is_siege = is_siege,
		is_worker = is_worker,
		is_military = is_military,
	})
	_CBA_SQUAD_KILL_BATCH.dirty = true
end

-- Batch processor: drains queue every 1 second.
-- Side effects consolidated: siege thresholds once per player, UI updates once per batch.
function CBA_SquadKillBatch_Process()
	if not _CBA_SQUAD_KILL_BATCH.dirty then return end

	local queue = _CBA_SQUAD_KILL_BATCH.queue
	_CBA_SQUAD_KILL_BATCH.queue = {}
	_CBA_SQUAD_KILL_BATCH.dirty = false

	local handlers = _CBA_SQUAD_KILL_BATCH.handlers
	local siege_dirty_players = {}
	local batch_size = #queue

	_CBA_PERF.batch_sq_processed = (_CBA_PERF.batch_sq_processed or 0) + batch_size
	_CBA_PERF.batch_sq_ticks = (_CBA_PERF.batch_sq_ticks or 0) + 1
	if batch_size > (_CBA_PERF.batch_sq_max_depth or 0) then
		_CBA_PERF.batch_sq_max_depth = batch_size
	end

	for _, entry in ipairs(queue) do
		-- Sub-handler: Siege limit
		if handlers.siege_limit and not entry.player.isEliminated then
			_CBA_PERF.ge_squad_killed_siege = _CBA_PERF.ge_squad_killed_siege + 1
			if entry.is_siege then
				siege_dirty_players[entry.player] = true
			end
		end

		-- Sub-handler: Battle lag telemetry
		if handlers.battle_lag and type(_BL_BatchSquadKilled) == "function" then
			_BL_BatchSquadKilled(entry.owner_id)
		end

		-- Sub-handler: Squad losses tracking
		if handlers.squad_losses then
			if SquadLosses ~= nil and SquadLosses[entry.player_idx] ~= nil then
				if entry.is_worker then
					SquadLosses[entry.player_idx].Worker = SquadLosses[entry.player_idx].Worker + 1
				elseif entry.is_military then
					SquadLosses[entry.player_idx].Military = SquadLosses[entry.player_idx].Military + 1
				end
			end
		end
	end

	-- Consolidated siege side-effects (once per dirty player per batch)
	if handlers.siege_limit then
		for player, _ in pairs(siege_dirty_players) do
			CBA_Options_SiegeLimit_ApplyAllThresholds(player)
			CBA_Options_SiegeLimit_ScheduleDeferredRecheck(player, "SquadKilled_Batch")
		end
	end

	-- Consolidated UI updates (once per batch)
	if batch_size > 0 then
		if handlers.limits_ui and type(AGS_LimitsUI_DeferUpdate) == "function" then
			AGS_LimitsUI_DeferUpdate("SquadKilled_Batch")
		end
		if handlers.special_pop_ui and type(AGS_SpecialPopulationUI_DeferUpdate) == "function" then
			AGS_SpecialPopulationUI_DeferUpdate()
		end
	end
end

---------------------------------------------------------------------------------------------------
-- GE_EntityKilled Batch Processor — Phase 1+2
-- Phase 1 (context-free): battle_lag, limits_ui, special_pop_ui, ai_player
-- Phase 2 (property-snapshot): siege_limit, building_limit, auto_pop, dock_house
-- Remaining handlers (wonder, rewards, annihilation) stay as immediate GE_EntityKilled listeners.
-- Net dispatch reduction: 15 → 7 per entity kill event.
---------------------------------------------------------------------------------------------------
_CBA_ENTITY_KILL_BATCH = {
	queue = {},
	dirty = false,
	handlers = {
		-- Phase 1
		battle_lag = false,     -- Set by battle lag harness start/stop
		limits_ui = false,      -- Set by AGS_LimitsUI OnPlay/OnGameOver
		special_pop_ui = false, -- Set by AGS_SpecialPopulationUI OnPlay/OnGameOver
		ai_player = false,      -- Set by CBA_AIPlayer Initialize/OnGameOver
		-- Phase 2
		siege_limit = false,    -- Set by CBA_Options_PresetFinalize / Mod_OnGameOver
		building_limit = false, -- Set by CBA_Options_PresetFinalize / Mod_OnGameOver
		auto_pop = false,       -- Set by AGS_AutoPopulationStart / Mod_OnGameOver
		dock_house = false,     -- Set by AGS_DockHouse_OnPlay / AGS_DockHouse_GameOver
	},
}

function CBA_EntityKillBatch_SetHandler(key, active)
	_CBA_ENTITY_KILL_BATCH.handlers[key] = (active == true)
end

-- Capture handler: snapshots entity properties while entity context is valid.
-- Phase 1 fields: victim handle + victimOwner (for battle_lag + AI).
-- Phase 2 fields: entity ID, owner resolution, type classification, building progress.
function CBA_EntityKillBatch_Capture(context)
	if context == nil then return end
	if #_CBA_ENTITY_KILL_BATCH.queue >= _CBA_BATCH_MAX_QUEUE then
		_CBA_PERF.batch_ek_dropped = (_CBA_PERF.batch_ek_dropped or 0) + 1
		return
	end

	local victim = context.victim
	local victim_owner = context.victimOwner
	local handlers = _CBA_ENTITY_KILL_BATCH.handlers

	local entry = {
		victim = victim,
		victim_owner = victim_owner,
	}

	-- Phase 2: extended snapshot while entity is still valid.
	if handlers.siege_limit or handlers.building_limit or handlers.auto_pop or handlers.dock_house then
		-- Entity ID (needed by building_limit for cancelled-entity dedup + starter keep check)
		local ok_id, eid = pcall(Entity_GetID, victim)
		if ok_id then
			entry.entity_id = eid
		end

		-- Owner resolution (shared by all Phase 2 handlers)
		-- Primary: Entity_GetPlayerOwner (most reliable when entity is still valid).
		-- Fallback: context.victimOwner (pre-resolved by engine; handles dying-entity edge cases).
		if victim_owner ~= nil then
			local ok_own, opid = pcall(Entity_GetPlayerOwner, victim)
			if not ok_own or opid == nil then
				-- Fallback: use context.victimOwner directly (mirrors old direct handler pattern)
				opid = victim_owner
			end
			if opid ~= nil then
				entry.owner_pid = opid
				local pidx = World_GetPlayerIndex(opid)
				entry.player_idx = pidx
				entry.player = PLAYERS[pidx]
				if entry.player ~= nil then
					entry.player_civ = entry.player.raceName or Player_GetRaceName(opid)
					entry.branch_civ = AGS_CIV_FACTION_MAP[entry.player_civ] or entry.player_civ
					entry.age = Player_GetCurrentAge(opid)
				end
			end
		end

		-- Building progress (siege scaffold/complete + dock_house completion gate)
		local ok_prog, prog = pcall(Entity_GetBuildingProgress, victim)
		entry.progress = ok_prog and prog or -1
		entry.is_finished = (ok_prog and prog >= 1.0)

		-- Core type classification
		entry.is_building = Entity_IsOfType(victim, "building")

		-- Siege classification (for siege_limit handler)
		if handlers.siege_limit and entry.player_civ ~= nil then
			entry.is_siege = CBA_Options_IsSiegeEntityCached(victim, entry.player_civ)
			if entry.is_siege then
				entry.is_ram_type = Entity_IsOfType(victim, "ram") or Entity_IsOfType(victim, "scar_ram") or Entity_IsOfType(victim, "fire_ram") or Entity_IsOfType(victim, "scar_fire_ram")
				entry.is_rt_type = Entity_IsOfType(victim, "ram_tower") or CBA_Options_IsRamTowerEntity(victim, entry.player_civ)
				entry.is_st_type = Entity_IsOfType(victim, "siege_tower")
				if not entry.is_ram_type and not entry.is_rt_type and not entry.is_st_type then
					entry.siege_points = CBA_Options_GetSiegeWeaponPointsEntity(victim, entry.player_civ)
				end
			end
		end

		-- Blueprint for auto_pop forbidden-set lookup (buildings only)
		if handlers.auto_pop and entry.is_building then
			local ok_ebp, ebp = pcall(Entity_GetBlueprint, victim)
			entry.ebp = ok_ebp and ebp or nil
		end

		-- Building limit type flags
		if handlers.building_limit then
			entry.is_prod = CBA_Options_BuildingLimit_IsProductionCapBuildingByEntity(victim, false)
			if entry.player_civ ~= nil then
				entry.is_workshop = CBA_Options_BuildingLimit_IsWorkshopCapBuilding(victim, entry.player_civ, entry.branch_civ or entry.player_civ, false)
			end
			entry.is_outpost = Entity_IsOfType(victim, "scar_outpost")
			entry.is_stone_wall_tower = Entity_IsOfType(victim, "stone_wall_tower")
		end

		-- Dock classification (for dock_house handler)
		if handlers.dock_house and type(AGS_DockHouse_IsDock) == "function" then
			entry.is_dock = AGS_DockHouse_IsDock(victim)
		end
	end

	table.insert(_CBA_ENTITY_KILL_BATCH.queue, entry)
	_CBA_ENTITY_KILL_BATCH.dirty = true
end

-- Batch processor: drains queue every 1 second.
-- Phase 1 sub-handlers dispatch per entry; Phase 2 sub-handlers use snapshot fields only.
-- Side effects consolidated: siege thresholds once per dirty player, UI updates once per batch.
function CBA_EntityKillBatch_Process()
	if not _CBA_ENTITY_KILL_BATCH.dirty then return end

	local queue = _CBA_ENTITY_KILL_BATCH.queue
	_CBA_ENTITY_KILL_BATCH.queue = {}
	_CBA_ENTITY_KILL_BATCH.dirty = false

	local handlers = _CBA_ENTITY_KILL_BATCH.handlers
	local batch_size = #queue
	local had_kills = batch_size > 0

	_CBA_PERF.batch_ek_processed = (_CBA_PERF.batch_ek_processed or 0) + batch_size
	_CBA_PERF.batch_ek_ticks = (_CBA_PERF.batch_ek_ticks or 0) + 1
	if batch_size > (_CBA_PERF.batch_ek_max_depth or 0) then
		_CBA_PERF.batch_ek_max_depth = batch_size
	end

	local siege_dirty_players = {}
	local auto_pop_triggered = false

	for _, entry in ipairs(queue) do
		-- Sub-handler: Battle lag telemetry (Phase 1)
		if handlers.battle_lag and type(_BL_BatchEntityKilled) == "function" then
			_BL_BatchEntityKilled(entry.victim_owner)
		end

		-- Sub-handler: AI building rebuild (Phase 1, synthetic context)
		if handlers.ai_player and type(_AI_OnEntityKilled) == "function" then
			_AI_OnEntityKilled({ victim = entry.victim, victimOwner = entry.victim_owner })
		end

		-- Sub-handler: Siege limit entity killed (Phase 2)
		-- Mirrors CBA_Options_SiegeLimit_EntityKilled using snapshot fields only.
		if handlers.siege_limit and entry.owner_pid ~= nil and entry.player ~= nil then
			_CBA_PERF.ge_entity_killed_siege = _CBA_PERF.ge_entity_killed_siege + 1
			if entry.is_siege and not entry.player.isEliminated then
				local was_scaffold = entry.progress >= 0 and entry.progress < 1.0
				if entry.is_rt_type then
					if was_scaffold then
						entry.player.ramLimit_pending = math.max(0, (entry.player.ramLimit_pending or 0) - 2)
					else
						entry.player.ramLimit_count = math.max(0, (entry.player.ramLimit_count or 0) - 2)
					end
				elseif entry.is_ram_type then
					if was_scaffold then
						entry.player.ramLimit_pending = math.max(0, (entry.player.ramLimit_pending or 0) - 1)
					else
						entry.player.ramLimit_count = math.max(0, (entry.player.ramLimit_count or 0) - 1)
					end
				elseif entry.is_st_type then
					if was_scaffold then
						entry.player.siegeTowerLimit_pending = math.max(0, (entry.player.siegeTowerLimit_pending or 0) - 1)
					else
						entry.player.siegeTowerLimit_count = math.max(0, (entry.player.siegeTowerLimit_count or 0) - 1)
					end
				else
					local ek_pts = entry.siege_points or 0
					if ek_pts > 0 then
						if was_scaffold then
							entry.player.siegeLimit_pending = math.max(0, (entry.player.siegeLimit_pending or 0) - ek_pts)
						else
							entry.player.siegeLimit_count = math.max(0, (entry.player.siegeLimit_count or 0) - ek_pts)
						end
					end
				end
				siege_dirty_players[entry.player] = true
				if CBA_Options_ShouldLogSiegeVerbose() then
					print(string.format(
						"[CBA_OPTIONS][SIEGE_LIMIT] EntityKilled(batch) P%d siege_sub=[ram=%s rt=%s st=%s] progress=%.2f scaffold=%s after[siege=%d ram=%d st=%d rp=%d sp=%d]",
						entry.player.index or 0,
						tostring(entry.is_ram_type or false), tostring(entry.is_rt_type or false), tostring(entry.is_st_type or false),
						entry.progress or -1,
						tostring(was_scaffold),
						entry.player.siegeLimit_count or 0, entry.player.ramLimit_count or 0, entry.player.siegeTowerLimit_count or 0,
						entry.player.ramLimit_pending or 0, entry.player.siegeTowerLimit_pending or 0))
				end
			end
		end

		-- Sub-handler: Building limit entity killed (Phase 2)
		-- Mirrors CBA_Options_BuildingLimit_OnEntityKilled using snapshot fields only.
		if handlers.building_limit and (entry.player == nil or entry.victim_owner == nil) then
			_CBA_PERF.batch_bld_skipped_player_nil = _CBA_PERF.batch_bld_skipped_player_nil + 1
		end
		if handlers.building_limit and entry.player ~= nil and entry.victim_owner ~= nil then
			local bl_player = entry.player
			local bl_skip = false

			-- Cancelled-entity dedup: cancellation already decremented on GE_ConstructionCancelled
			if _buildingLimit ~= nil and _buildingLimit.cancelled_entities ~= nil and entry.entity_id ~= nil then
				if _buildingLimit.cancelled_entities[entry.entity_id] then
					_buildingLimit.cancelled_entities[entry.entity_id] = nil
					_CBA_PERF.batch_bld_skipped_cancelled = _CBA_PERF.batch_bld_skipped_cancelled + 1
					if _buildingLimit.debug_on_entity_killed == true then
						DebugLog("bld_limit", string.format(
							"OnEntityKilled(batch): skip cancelled entity_id=%d (already processed by ConstructionCancelled)",
							entry.entity_id))
					end
					bl_skip = true
				end
			end

			-- Starter Keep exclusion: excluded from both production and workshop counts at init
			if not bl_skip and entry.entity_id == bl_player.obj_buildingLimit_english_start_keep_id then
				if _buildingLimit ~= nil and _buildingLimit.debug_on_entity_killed == true then
					DebugLog("bld_limit", string.format(
						"OnEntityKilled(batch): skip starter keep entity_id=%d (excluded at reconciliation)",
						entry.entity_id or 0))
				end
				bl_skip = true
			end

			if not bl_skip then
				-- Debug log
				if _buildingLimit ~= nil and _buildingLimit.debug_on_entity_killed == true then
					DebugLog("bld_limit", string.format(
						"OnEntityKilled(batch): P%d (%s) entity_id=%d prod=%s ws=%s outpost=%s sw_tower=%s counters=[bld=%s ws=%s op=%s]",
						bl_player.playerIndex or (entry.player_idx or 0),
						entry.player_civ or "?",
						entry.entity_id or 0,
						tostring(entry.is_prod or false), tostring(entry.is_workshop or false),
						tostring(entry.is_outpost or false), tostring(entry.is_stone_wall_tower or false),
						tostring(bl_player.obj_buildingLimit_count),
						tostring(bl_player.obj_buildingLimit_workshop_count),
						tostring(bl_player.obj_buildingLimit_outpost_count)))
				end

				-- Production building count decrement
				if entry.is_prod then
					if bl_player.obj_buildingLimit_count ~= 0 then
						bl_player.obj_buildingLimit_count = bl_player.obj_buildingLimit_count - 1
						if bl_player.isLocal then
							Obj_SetCounterCount(_buildingLimit.objective_buildingLimit, bl_player.obj_buildingLimit_count)
							Obj_SetProgress(_buildingLimit.objective_buildingLimit, bl_player.obj_buildingLimit_count / CBA_Options_GetPlayerProdLimit(bl_player))
						end
					end
				end

				-- Workshop count decrement
				if AGS_GLOBAL_SETTINGS.MaximumSiegeWorkshop ~= 0 and not AGS_GLOBAL_SETTINGS.NoSiege and entry.is_workshop then
					bl_player.obj_buildingLimit_workshop_count = math.max(0, bl_player.obj_buildingLimit_workshop_count - 1)
				end

				-- Production availability unlock
				if bl_player.obj_buildingLimit_count < CBA_Options_GetPlayerProdLimit(bl_player) then
					if bl_player.obj_buildingLimit_workshop_count < CBA_Options_GetPlayerWorkshopLimit(bl_player) and (entry.age or 0) >= 3 then
						AGS_SetEntityProductionAvailabilitySafe(bl_player.id, AGS_GetCivilizationEntity(bl_player.raceName, AGS_BP_WORKSHOP), ITEM_DEFAULT, "CBA_Options_BuildingLimit_OnEntityKilled_Batch/workshop_default/" .. tostring(bl_player.raceName))
						if entry.player_civ == "chinese" then
							Player_SetEntityProductionAvailability(bl_player.id, EBP.CHINESE.BUILDING_LANDMARK_AGE2_CLOCKTOWER_CONTROL_CHI, ITEM_DEFAULT)
						elseif entry.branch_civ == "french" then
							Player_SetEntityProductionAvailability(bl_player.id, EBP.FRENCH.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE, ITEM_DEFAULT)
							if entry.player_civ == "french_ha_01" then
								Player_SetEntityProductionAvailability(bl_player.id, EBP.FRENCH_HA_01.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE_HA_01, ITEM_DEFAULT)
							end
						elseif entry.player_civ == "ottoman" then
							Player_SetEntityProductionAvailability(bl_player.id, EBP.OTTOMAN.BUILDING_LANDMARK_AGE2_TOPHANE_ARMORY_OTT, ITEM_DEFAULT)
						end
					end
					CBA_Options_BuildingLimit_UnlockPlayer(bl_player)
				end

				-- Outpost count decrement (includes Stone Wall Towers)
				if entry.is_outpost or entry.is_stone_wall_tower then
					bl_player.obj_buildingLimit_outpost_count = math.max(0, bl_player.obj_buildingLimit_outpost_count - 1)
					if bl_player.obj_buildingLimit_outpost_count < CBA_Options_GetPlayerOutpostLimit(bl_player) then
						Player_SetEntityProductionAvailability(bl_player.id, BP_GetEntityBlueprintsWithType("scar_outpost"), ITEM_DEFAULT)
						Player_SetEntityProductionAvailability(bl_player.id, BP_GetEntityBlueprintsWithType("stone_wall_tower"), ITEM_DEFAULT)
					end
				end

				-- Perf: count any building limit decrement that actually fired
				if entry.is_prod or entry.is_workshop or entry.is_outpost or entry.is_stone_wall_tower then
					_CBA_PERF.batch_bld_decremented = _CBA_PERF.batch_bld_decremented + 1
				end
			end
		end

		-- Sub-handler: Auto population reconcile (Phase 2)
		-- Mirrors AGS_AutoPop_OnEntityKilled; coalesces via existing ScheduleDeferredReconcile.
		if handlers.auto_pop and entry.is_building and entry.ebp ~= nil then
			if _AGS_AutoPop_ForbiddenBPSet ~= nil and _AGS_AutoPop_ForbiddenBPSet[entry.ebp] then
				if entry.player ~= nil and not entry.player.isEliminated then
					if not auto_pop_triggered then
						AGS_AutoPop_ScheduleDeferredReconcile("EntityKilled_Batch")
						auto_pop_triggered = true
					end
					if _AUTOPOP_DEBUG_VERBOSE then
						print(string.format("[AUTOPOP_EVENT] EntityKilled(batch) P%d [%s] forbidden pop building destroyed; deferred reconcile scheduled",
							entry.player.playerIndex or 0, tostring(entry.player.raceName)))
					end
				end
			end
		end

		-- Sub-handler: Dock house population (Phase 2)
		-- Mirrors AGS_DockHouse_OnEntityKilled; removes medic cap for destroyed docks.
		if handlers.dock_house and entry.is_dock and entry.is_finished then
			if entry.player ~= nil and not entry.player.isEliminated then
				AGS_DockHouse_RemoveMinPopulation(entry.player, AGS_DOCKHOUSE_POPULATION)
			end
		end
	end

	-- Consolidated siege side-effects (once per dirty player per batch)
	if handlers.siege_limit then
		for player, _ in pairs(siege_dirty_players) do
			CBA_Options_SiegeLimit_ApplyAllThresholds(player)
			CBA_Options_SiegeLimit_ScheduleDeferredRecheck(player, "EntityKilled_Batch")
		end
	end

	-- Consolidated UI updates (once per batch, not per kill)
	if had_kills then
		if handlers.limits_ui and type(AGS_LimitsUI_DeferUpdate) == "function" then
			AGS_LimitsUI_DeferUpdate("EntityKilled_Batch")
		end
		if handlers.special_pop_ui and type(AGS_SpecialPopulationUI_DeferUpdate) == "function" then
			AGS_SpecialPopulationUI_DeferUpdate()
		end
	end
end

---------------------------------------------------------------------------------------------------
-- GE_BuildItemComplete Batch Processor
-- Unified handler: captures context snapshot at event time, processes in 1-second batches.
-- Reduces per-event dispatch overhead from 4 handlers to 1 capture handler.
-- Side effects (siege deferred recheck, UI updates, telemetry) consolidated per batch.
---------------------------------------------------------------------------------------------------
_CBA_BUILD_ITEM_BATCH = {
	queue = {},
	dirty = false,
	-- Sub-handler activation flags (modules set these instead of registering GE_BuildItemComplete)
	handlers = {
		siege_limit = false,    -- Set by CBA_Options_PresetFinalize
		battle_lag = false,     -- Set by battle lag harness start/stop
		limits_ui = false,      -- Set by AGS_LimitsUI OnPlay/OnGameOver
		special_pop_ui = false, -- Set by AGS_SpecialPopulationUI OnPlay/OnGameOver
	},
}

-- Module activation API: modules call this instead of Rule_Add/RemoveGlobalEvent for GE_BuildItemComplete.
function CBA_BuildItemBatch_SetHandler(key, active)
	_CBA_BUILD_ITEM_BATCH.handlers[key] = (active == true)
end

-- Capture handler: snapshots context while it is still valid.
-- Registered as the single GE_BuildItemComplete handler; replaces 4 individual registrations.
function CBA_BuildItemBatch_Capture(context)
	if context == nil then return end
	if #_CBA_BUILD_ITEM_BATCH.queue >= _CBA_BATCH_MAX_QUEUE then
		_CBA_PERF.batch_bi_dropped = (_CBA_PERF.batch_bi_dropped or 0) + 1
		return
	end
	local player_handle = context.player
	if player_handle == nil then return end

	local player = Core_GetPlayersTableEntry(player_handle)
	if player == nil then return end

	-- Siege classification via SBP-keyed cache (Phase 1).
	-- Evaluated here while context.pbg is valid; result stored in snapshot.
	local is_siege = false
	local pbg = context.pbg
	if pbg ~= nil and not player.isEliminated then
		local player_civ = player.raceName or Player_GetRaceName(player.id)
		is_siege = CBA_Options_IsSiegeSBPCached(pbg, player_civ)
	end

	table.insert(_CBA_BUILD_ITEM_BATCH.queue, {
		player = player,
		player_handle = player_handle,
		is_siege = is_siege,
	})
	_CBA_BUILD_ITEM_BATCH.dirty = true
end

-- Batch processor: drains queue every 1 second.
-- Side effects consolidated: siege deferred recheck once per dirty player, UI updates once per batch.
function CBA_BuildItemBatch_Process()
	if not _CBA_BUILD_ITEM_BATCH.dirty then return end

	local queue = _CBA_BUILD_ITEM_BATCH.queue
	_CBA_BUILD_ITEM_BATCH.queue = {}
	_CBA_BUILD_ITEM_BATCH.dirty = false

	local handlers = _CBA_BUILD_ITEM_BATCH.handlers
	local batch_size = #queue
	local had_items = batch_size > 0

	_CBA_PERF.batch_bi_processed = (_CBA_PERF.batch_bi_processed or 0) + batch_size
	_CBA_PERF.batch_bi_ticks = (_CBA_PERF.batch_bi_ticks or 0) + 1
	if batch_size > (_CBA_PERF.batch_bi_max_depth or 0) then
		_CBA_PERF.batch_bi_max_depth = batch_size
	end

	local siege_dirty_players = {}

	for _, entry in ipairs(queue) do
		-- Sub-handler: Siege limit
		if handlers.siege_limit and entry.is_siege and not entry.player.isEliminated then
			_CBA_PERF.ge_build_item_siege = _CBA_PERF.ge_build_item_siege + 1
			siege_dirty_players[entry.player] = true
		end

		-- Sub-handler: Battle lag telemetry
		if handlers.battle_lag and type(_BL_BatchBuildItemComplete) == "function" then
			_BL_BatchBuildItemComplete(entry.player_handle)
		end
	end

	-- Consolidated siege side-effects (once per dirty player per batch)
	if handlers.siege_limit then
		for player, _ in pairs(siege_dirty_players) do
			CBA_Options_SiegeLimit_ScheduleDeferredRecheck(player, "BuildItemComplete_Batch")
		end
	end

	-- Consolidated UI updates (once per batch)
	if had_items then
		if handlers.limits_ui and type(AGS_LimitsUI_DeferUpdate) == "function" then
			AGS_LimitsUI_DeferUpdate("BuildItemComplete_Batch")
		end
		if handlers.special_pop_ui and type(AGS_SpecialPopulationUI_DeferUpdate) == "function" then
			AGS_SpecialPopulationUI_DeferUpdate()
		end
	end
end

-- PERF: Cached siege classification by SBP userdata (no squad handle needed).
-- Used by GE_BuildItemComplete (context.pbg) and batch capture path.
-- Returns true if the SBP is siege-class (any type: siege, ram, siege tower).
function CBA_Options_IsSiegeSBPCached(sbp, player_civ)
	if sbp == nil then return false end
	local cached = _CBA_SIEGE_SBP_CACHE[sbp]
	if cached ~= nil then
		_CBA_PERF.siege_cache_hits = _CBA_PERF.siege_cache_hits + 1
		return cached
	end
	_CBA_PERF.siege_cache_misses = _CBA_PERF.siege_cache_misses + 1
	local is_siege = Squad_IsSBPOfType(sbp, "siege") or Squad_IsSBPOfType(sbp, "ram")
		or Squad_IsSBPOfType(sbp, "scar_ram") or Squad_IsSBPOfType(sbp, "fire_ram")
		or Squad_IsSBPOfType(sbp, "scar_fire_ram") or Squad_IsSBPOfType(sbp, "ram_tower")
		or Squad_IsSBPOfType(sbp, "siege_tower")
	if not is_siege then
		is_siege = CBA_Options_IsSiegeWeaponBPMatch_SBP(sbp, player_civ)
	end
	_CBA_SIEGE_SBP_CACHE[sbp] = is_siege
	return is_siege
end

-- PERF: Cached siege classification for squads by SBP (squad-handle variant).
-- Extracts SBP from squad handle, then delegates to SBP-keyed cache.
function CBA_Options_IsSiegeSquadCached(squad, player_civ)
	local ok_sbp, sbp = pcall(Squad_GetBlueprint, squad)
	if not ok_sbp or sbp == nil then return false end
	return CBA_Options_IsSiegeSBPCached(sbp, player_civ)
end

-- PERF: Cached siege classification for entities by EBP.
function CBA_Options_IsSiegeEntityCached(entity, player_civ)
	local ok_ebp, ebp = pcall(Entity_GetBlueprint, entity)
	if not ok_ebp or ebp == nil then return false end
	local cached = _CBA_SIEGE_EBP_CACHE[ebp]
	if cached ~= nil then
		_CBA_PERF.siege_cache_hits = _CBA_PERF.siege_cache_hits + 1
		return cached
	end
	_CBA_PERF.siege_cache_misses = _CBA_PERF.siege_cache_misses + 1
	local is_siege = Entity_IsOfType(entity, "siege") or Entity_IsOfType(entity, "ram")
		or Entity_IsOfType(entity, "scar_ram") or Entity_IsOfType(entity, "fire_ram")
		or Entity_IsOfType(entity, "scar_fire_ram") or Entity_IsOfType(entity, "ram_tower")
		or Entity_IsOfType(entity, "siege_tower")
	if not is_siege then
		is_siege = CBA_Options_IsSiegeWeaponBPMatch_EBP(ebp, player_civ)
	end
	_CBA_SIEGE_EBP_CACHE[ebp] = is_siege
	return is_siege
end

-- Combined single-pass recount: classifies all siege/ram/ST by creating only 1 SGroup + 1 EGroup.
-- Replaces 3 separate recount calls (SiegeLimit_Recount + RamLimit_Recount + SiegeTowerLimit_Recount).
function CBA_Options_SiegeLimit_RecountAll(player)
	if player == nil or player.id == nil then return end
	_CBA_PERF.recount_calls = _CBA_PERF.recount_calls + 1
	local player_civ = Player_GetRaceName(player.id)
	local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ

	-- Snapshot old values for drift detection
	local old_siege = player.siegeLimit_count or 0
	local old_siege_pending = player.siegeLimit_pending or 0
	local old_ram = player.ramLimit_count or 0
	local old_ram_pending = player.ramLimit_pending or 0
	local old_st = player.siegeTowerLimit_count or 0
	local old_st_pending = player.siegeTowerLimit_pending or 0

	local siege_total = 0
	local ram_total = 0
	local st_total = 0

	-- Diagnostic sub-counters (only used for verbose logging)
	local n_springald, n_tr, n_mangonel, n_bombard = 0, 0, 0, 0
	local n_ram_squads, n_ram_tower_squads, n_st_squads = 0, 0, 0

	-- === SQUAD SCAN (single pass) ===
	_CBA_PERF.sg_allocs = _CBA_PERF.sg_allocs + 1
	local sg_all = Player_GetSquads(player.id)
	local sq_count = SGroup_Count(sg_all)
	for idx = 1, sq_count do
		local squad = SGroup_GetSquadAt(sg_all, idx)
		if squad ~= nil then
			local counted_generic = false
			-- Ram classification first (RamLimit_Recount checks without siege gate)
			local is_ram_tower = CBA_Options_IsRamTowerSquad(squad, player_civ)
			if is_ram_tower then
				ram_total = ram_total + 2
				n_ram_tower_squads = n_ram_tower_squads + 1
			elseif Squad_IsOfType(squad, "ram") or Squad_IsOfType(squad, "scar_ram") or Squad_IsOfType(squad, "fire_ram") or Squad_IsOfType(squad, "scar_fire_ram") then
				ram_total = ram_total + 1
				n_ram_squads = n_ram_squads + 1
			-- Siege-classified units (requires "siege" tag; rams already handled above)
			elseif Squad_IsOfType(squad, "siege") then
				-- Siege tower
				if Squad_IsOfType(squad, "siege_tower") then
					st_total = st_total + 1
					n_st_squads = n_st_squads + 1
					counted_generic = true
				-- Ottoman great bombard: 4 points
				elseif branch_civ == "ottoman" and (Squad_IsOfType(squad, "great_bombard") or Squad_IsOfType(squad, "bombard") or Squad_IsOfType(squad, "scar_bombard")) then
					siege_total = siege_total + 4
					n_bombard = n_bombard + 1
					counted_generic = true
				-- 1-point: Springald
				elseif Squad_IsOfType(squad, "scar_springald") then
					siege_total = siege_total + 1
					n_springald = n_springald + 1
					counted_generic = true
				-- 2-point: Trebuchet TR, Culverin
				elseif Squad_IsOfType(squad, "scar_trebuchet_traction") or Squad_IsOfType(squad, "scar_culverin") then
					siege_total = siege_total + 2
					n_tr = n_tr + 1
					counted_generic = true
				-- 3-point: Mangonel, Trebuchet CW, Cannon, Bombard, Nest of Bees, Ribauldequin
				elseif Squad_IsOfType(squad, "scar_mangonel") or Squad_IsOfType(squad, "scar_trebuchet_cw") or Squad_IsOfType(squad, "scar_cannon") or
					Squad_IsOfType(squad, "scar_bombard") or Squad_IsOfType(squad, "nest_of_bees") or Squad_IsOfType(squad, "scar_ribauldequin") then
					siege_total = siege_total + 3
					n_mangonel = n_mangonel + 1
					counted_generic = true
				end
				-- Some buildable/civ-variant siege squads expose "siege" but not scar_* subtype tags.
				-- If subtype checks miss, fall back to BP identity map classification.
				if not counted_generic then
					local ok_sbp, sq_sbp = pcall(Squad_GetBlueprint, squad)
					if ok_sbp and sq_sbp ~= nil then
						local sbp_pts = CBA_Options_GetSiegeWeaponPointsSBP(sq_sbp, player_civ)
						if sbp_pts > 0 then
							siege_total = siege_total + sbp_pts
							n_mangonel = n_mangonel + 1
						end
					end
				end
			-- Buildable siege variant fallback (may lack "siege" type tag)
			else
				local ok_sbp, sq_sbp = pcall(Squad_GetBlueprint, squad)
				if ok_sbp and sq_sbp ~= nil then
					local sbp_pts = CBA_Options_GetSiegeWeaponPointsSBP(sq_sbp, player_civ)
					if sbp_pts > 0 then
						siege_total = siege_total + sbp_pts
						n_mangonel = n_mangonel + 1
					end
				end
			end
		end
	end
	SGroup_Destroy(sg_all)

	-- === ENTITY SCAN (single pass — ram + siege tower scaffolds & completed field units) ===
	_CBA_PERF.eg_allocs = _CBA_PERF.eg_allocs + 1
	local eg_all = Player_GetEntities(player.id)
	local eg_count = EGroup_CountSpawned(eg_all)
	local active_ram_scaffolds = 0
	local ram_completed_ents = 0
	local active_st_scaffolds = 0
	local st_completed_ents = 0
	local active_siege_weapon_scaffolds = 0
	local siege_weapon_completed_ents = 0
	for idx = 1, eg_count do
		local entity = EGroup_GetSpawnedEntityAt(eg_all, idx)
		if entity ~= nil then
			-- Ram entity classification
			local is_ram_tower = CBA_Options_IsRamTowerEntity(entity, player_civ)
			local is_ram_type = is_ram_tower or
				(Entity_IsOfType(entity, "ram") or Entity_IsOfType(entity, "scar_ram") or Entity_IsOfType(entity, "fire_ram") or Entity_IsOfType(entity, "scar_fire_ram"))
			if is_ram_type then
				local weight = is_ram_tower and 2 or 1
				if Entity_GetBuildingProgress(entity) < 1.0 then
					active_ram_scaffolds = active_ram_scaffolds + weight
				else
					ram_total = ram_total + weight
					ram_completed_ents = ram_completed_ents + 1
				end
			-- Siege tower entity classification
			elseif Entity_IsOfType(entity, "siege") and Entity_IsOfType(entity, "siege_tower") then
				if Entity_GetBuildingProgress(entity) < 1.0 then
					active_st_scaffolds = active_st_scaffolds + 1
				else
					st_total = st_total + 1
					st_completed_ents = st_completed_ents + 1
				end
			-- Generic siege weapon entity classification (field-built Mongol/Abbasid siege weapons)
			-- Classifier handles both tagged and untagged buildable variants via BP identity map
			else
				local weapon_pts = CBA_Options_GetSiegeWeaponPointsEntity(entity, player_civ)
				if weapon_pts > 0 then
					if Entity_GetBuildingProgress(entity) < 1.0 then
						active_siege_weapon_scaffolds = active_siege_weapon_scaffolds + weapon_pts
					else
						siege_total = siege_total + weapon_pts
						siege_weapon_completed_ents = siege_weapon_completed_ents + 1
					end
				end
			end
		end
	end
	EGroup_Destroy(eg_all)

	-- === ASSIGN RESULTS ===
	player.siegeLimit_count = siege_total
	player.siegeLimit_pending = active_siege_weapon_scaffolds
	player.ramLimit_count = ram_total
	player.ramLimit_pending = active_ram_scaffolds
	player.siegeTowerLimit_count = st_total
	player.siegeTowerLimit_pending = active_st_scaffolds

	-- === LOGGING ===
	if CBA_Options_ShouldLogSiegeVerbose() then
		print(string.format(
			"[CBA_OPTIONS][RECOUNT_ALL] P%d civ=%s sq=%d eg=%d siege=%d->%d(pend=%d->%d)[spr=%d tr=%d mng=%d bmb=%d ent=%d scaff=%d] ram=%d->%d[sq=%d+rt=%d ent=%d pend=%d->%d] st=%d->%d[sq=%d ent=%d pend=%d->%d]",
			player.index or 0, tostring(player_civ), sq_count, eg_count,
			old_siege, siege_total, old_siege_pending, active_siege_weapon_scaffolds,
			n_springald, n_tr, n_mangonel, n_bombard, siege_weapon_completed_ents, active_siege_weapon_scaffolds,
			old_ram, ram_total, n_ram_squads, n_ram_tower_squads, ram_completed_ents, old_ram_pending, active_ram_scaffolds,
			old_st, st_total, n_st_squads, st_completed_ents, old_st_pending, active_st_scaffolds))
	else
		local drifted = (siege_total ~= old_siege) or (active_siege_weapon_scaffolds ~= old_siege_pending)
			or (ram_total ~= old_ram) or (active_ram_scaffolds ~= old_ram_pending)
			or (st_total ~= old_st) or (active_st_scaffolds ~= old_st_pending)
		if drifted then
			DebugLog("siege_limit", string.format(
				"RecountAll: P%d siege=%d->%d(pend=%d->%d) ram=%d->%d(pend=%d->%d) st=%d->%d(pend=%d->%d)",
				player.playerIndex or 0, old_siege, siege_total, old_siege_pending, active_siege_weapon_scaffolds,
				old_ram, ram_total, old_ram_pending, active_ram_scaffolds,
				old_st, st_total, old_st_pending, active_st_scaffolds))
		end
	end
end

---------------------------------------------------------------------------------------------------
-- Siege Limit — Individual Recount Functions (kept for ConstructionStart + debug console)
---------------------------------------------------------------------------------------------------

-- Recounts a player's siege value by iterating all live squads.
-- Rams and siege towers are excluded (tracked separately via future ram_limit).
function CBA_Options_SiegeLimit_Recount(player)
	if player == nil or player.id == nil then return end
	local old = player.siegeLimit_count or 0
	local total = 0
	local player_civ = Player_GetRaceName(player.id)
	local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ
	local sg_all = Player_GetSquads(player.id)
	local count = SGroup_Count(sg_all)
	local n_springald = 0
	local n_tr = 0
	local n_mangonel = 0
	local n_bombard = 0
	local n_other = 0
	local n_skipped = 0
	for idx = 1, count do
		local squad = SGroup_GetSquadAt(sg_all, idx)
		if squad ~= nil and Squad_IsOfType(squad, "siege") then
			local counted_generic = false
			-- Exclude siege towers (separate limit planned)
			if Squad_IsOfType(squad, "siege_tower") then
				n_skipped = n_skipped + 1
				counted_generic = true
			-- Exclude all ram-class units (tracked by ram limit; ram_tower counts as 2 rams)
			elseif Squad_IsOfType(squad, "ram_tower") or Squad_IsOfType(squad, "ram") or Squad_IsOfType(squad, "scar_ram") or Squad_IsOfType(squad, "fire_ram") or Squad_IsOfType(squad, "scar_fire_ram") then
				n_skipped = n_skipped + 1
				counted_generic = true
			-- Ottoman great bombard: 4 points
			elseif branch_civ == "ottoman" and (Squad_IsOfType(squad, "great_bombard") or Squad_IsOfType(squad, "bombard") or Squad_IsOfType(squad, "scar_bombard")) then
				total = total + 4
				n_bombard = n_bombard + 1
				counted_generic = true
			-- 1-point: Springald
			elseif Squad_IsOfType(squad, "scar_springald") then
				total = total + 1
				n_springald = n_springald + 1
				counted_generic = true
			-- 2-point: Trebuchet TR, Culverin
			elseif Squad_IsOfType(squad, "scar_trebuchet_traction") or Squad_IsOfType(squad, "scar_culverin") then
				total = total + 2
				n_tr = n_tr + 1
				counted_generic = true
			-- 3-point: Mangonel, Trebuchet CW, Cannon, Bombard, Nest of Bees, Ribauldequin
			elseif Squad_IsOfType(squad, "scar_mangonel") or Squad_IsOfType(squad, "scar_trebuchet_cw") or Squad_IsOfType(squad, "scar_cannon") or
				Squad_IsOfType(squad, "scar_bombard") or Squad_IsOfType(squad, "nest_of_bees") or Squad_IsOfType(squad, "scar_ribauldequin") then
				total = total + 3
				n_mangonel = n_mangonel + 1
				counted_generic = true
			end
			-- Buildable/civ-variant safety fallback inside siege branch.
			if not counted_generic then
				local ok_sbp, sq_sbp = pcall(Squad_GetBlueprint, squad)
				if ok_sbp and sq_sbp ~= nil then
					local sbp_pts = CBA_Options_GetSiegeWeaponPointsSBP(sq_sbp, player_civ)
					if sbp_pts > 0 then
						total = total + sbp_pts
						n_mangonel = n_mangonel + 1
					end
				end
			end
		-- Buildable siege variant fallback (may lack "siege" type tag)
		elseif squad ~= nil then
			local ok_sbp, sq_sbp = pcall(Squad_GetBlueprint, squad)
			if ok_sbp and sq_sbp ~= nil then
				local sbp_pts = CBA_Options_GetSiegeWeaponPointsSBP(sq_sbp, player_civ)
				if sbp_pts > 0 then
					total = total + sbp_pts
					n_mangonel = n_mangonel + 1
				end
			end
		end
	end
	SGroup_Destroy(sg_all)
	player.siegeLimit_count = total
	if CBA_Options_ShouldLogSiegeVerbose() then
		print(string.format(
			"[CBA_OPTIONS][SIEGE_RECOUNT] P%d civ=%s squads_scanned=%d springald=%d tr_culv=%d mangonel_3pt=%d bombard_4pt=%d skipped_ram_st=%d total=%d->%d",
			player.index or 0, tostring(player_civ), count,
			n_springald, n_tr, n_mangonel, n_bombard, n_skipped,
			old, total))
	elseif total ~= old then
		DebugLog("siege_limit", string.format("SiegeLimit_Recount: P%d drift %d→%d", player.playerIndex or 0, old, total))
	end
	return total
end

-- Returns true if the player has their civ-specific Siege Engineers upgrade.
-- Uses AGS_GetCivilizationUpgrade, which supports direct civ tables + parent-map fallback.
function CBA_Options_HasSiegeEngineers(player)
	if player == nil or player.id == nil then return false end
	if AGS_UP_SIEGE_ENGINEERS == nil then return false end
	local upgrade_bp = AGS_GetCivilizationUpgrade(player.raceName, AGS_UP_SIEGE_ENGINEERS)
	if upgrade_bp == nil then return false end
	local ok, done = pcall(Player_HasUpgrade, player.id, upgrade_bp)
	return ok and done
end

-- Applies cascading lock/unlock based on effective siege points (live + pending + queued) vs max.
function CBA_Options_SiegeLimit_ApplyThreshold(player, opt_siege_queued)
	if player == nil or player.id == nil then return end
	local max_siege = CBA_Options_GetPlayerSiegeLimit(player)

	-- Unlimited mode: MaximumMedicPopulation==0 → unlock all siege, skip cap logic
	if max_siege == 0 then
		if not CBA_Options_HasSiegeEngineers(player) then
			-- Still enforce SE gate even in unlimited mode
			CBA_Options_SiegeLimit_Disable(player.id, 1, ITEM_LOCKED)
			CBA_Options_RamLimit_Disable(player.id, ITEM_LOCKED)
			CBA_Options_SiegeTowerLimit_Disable(player.id, ITEM_LOCKED)
			if CBA_Options_ShouldLogSiegeStateChange(player, "siege_threshold", "UNLIMITED_NO_SE") then
				print(string.format("[CBA_OPTIONS][SIEGE_THRESHOLD] P%d unlimited=true has_se=false tier=UNLIMITED_NO_SE", player.index or 0))
			end
			player._siege_enforce_tier = "UNLIMITED_NO_SE"
		else
			CBA_Options_SiegeLimit_Disable(player.id, 4, ITEM_UNLOCKED)
			CBA_Options_RamLimit_Disable(player.id, ITEM_UNLOCKED)
			CBA_Options_SiegeTowerLimit_Disable(player.id, ITEM_UNLOCKED)
			if CBA_Options_ShouldLogSiegeStateChange(player, "siege_threshold", "UNLIMITED") then
				print(string.format("[CBA_OPTIONS][SIEGE_THRESHOLD] P%d unlimited=true has_se=true tier=UNLIMITED", player.index or 0))
			end
			player._siege_enforce_tier = "UNLIMITED"
		end
		return
	end

	local live = player.siegeLimit_count or 0
	local pending = player.siegeLimit_pending or 0
	local queued = opt_siege_queued or CBA_Options_SiegeLimit_GetQueuedPoints(player)
	local count = live + pending + queued

	-- Compute enforcement tier
	local tier
	if not CBA_Options_HasSiegeEngineers(player) then
		tier = "LOCKED_ALL"
	elseif count >= max_siege then
		tier = "1_full"
	elseif count + 1 >= max_siege then
		tier = "2_lock3pt"
	elseif count + 2 >= max_siege then
		tier = "3_lock2pt"
	elseif count + 3 >= max_siege then
		tier = "4_lock1pt"
	else
		tier = "unlocked"
	end

	-- Phase 3: skip expensive SiegeLimit_Disable when tier unchanged
	if player._siege_enforce_tier == tier then
		_CBA_PERF.disable_skipped = _CBA_PERF.disable_skipped + 1
		return
	end
	player._siege_enforce_tier = tier

	-- Apply enforcement
	if tier == "LOCKED_ALL" then
		CBA_Options_SiegeLimit_Disable(player.id, 1, ITEM_LOCKED)
		CBA_Options_RamLimit_Disable(player.id, ITEM_LOCKED)
		CBA_Options_SiegeTowerLimit_Disable(player.id, ITEM_LOCKED)
		if CBA_Options_ShouldLogSiegeStateChange(player, "siege_threshold", "LOCKED_ALL") then
			print(string.format("[CBA_OPTIONS][SIEGE_THRESHOLD] P%d effective=%d/%d(live=%d pend=%d q=%d) has_se=false tier=LOCKED_ALL", player.index or 0, count, max_siege, live, pending, queued))
		end
		return
	end

	-- Always reset to a clean unlocked state before applying the new lock tier.
	-- Without this, transitioning from a more restrictive tier (e.g. 1_full) to a
	-- less restrictive one (e.g. 2_lock3pt) leaves lower-point units stale-locked
	-- because Disable(N, LOCKED) only touches sections N..4, not sections below N.
	if tier == "1_full" then
		CBA_Options_SiegeLimit_Disable(player.id, 1, ITEM_LOCKED)
	elseif tier == "2_lock3pt" then
		CBA_Options_SiegeLimit_Disable(player.id, 4, ITEM_UNLOCKED)
		CBA_Options_SiegeLimit_Disable(player.id, 2, ITEM_LOCKED)
	elseif tier == "3_lock2pt" then
		CBA_Options_SiegeLimit_Disable(player.id, 4, ITEM_UNLOCKED)
		CBA_Options_SiegeLimit_Disable(player.id, 3, ITEM_LOCKED)
	elseif tier == "4_lock1pt" then
		CBA_Options_SiegeLimit_Disable(player.id, 4, ITEM_UNLOCKED)
		CBA_Options_SiegeLimit_Disable(player.id, 4, ITEM_LOCKED)
	else
		CBA_Options_SiegeLimit_Disable(player.id, 4, ITEM_UNLOCKED)
	end
	-- Trim over-cap queued siege items immediately; spawn-kill remains a safety fallback.
	local trimmed_siege = CBA_Options_SiegeLimit_TrimQueue(player, queued)
	if trimmed_siege > 0 then
		queued = math.max(0, queued - trimmed_siege)
		count = live + pending + queued
	end
	local should_log = CBA_Options_ShouldLogSiegeVerbose() or CBA_Options_ShouldLogSiegeStateChange(player, "siege_threshold", tier)
	if should_log then
		print(string.format("[CBA_OPTIONS][SIEGE_THRESHOLD] P%d live=%d pending=%d queued=%d effective=%d/%d has_se=true tier=%s",
			player.index or 0, live, pending, queued, count, max_siege, tier))
	end
end

---------------------------------------------------------------------------------------------------
-- Building Limit — Public Lock/Unlock Helpers
-- Exported for debug suites and external tooling.
---------------------------------------------------------------------------------------------------

local function CBA_Options_BuildingLimit_SetAdditionalProductionAvailability(player, lock_type, reason)
	if player == nil or player.id == nil then return end
	-- Keep in sync with unique production buildings that are counted by classifier helpers.
	local extra_keys = {
		"mercenary_house",
		"passive_trait_building",
		"daimyo_estate_hojo",
		"daimyo_estate_oda",
		"daimyo_estate_takeda",
	}
	for _, key in ipairs(extra_keys) do
		AGS_SetEntityProductionAvailabilitySafe(
			player.id,
			AGS_GetCivilizationEntity(player.raceName, key),
			lock_type,
			reason .. "/" .. key .. "/" .. tostring(player.raceName)
		)
	end
end

-- Locks all production buildings for a player who has reached or exceeded their limit.
function CBA_Options_BuildingLimit_LockPlayer(player)
	if player == nil or player.id == nil then return end
	local player_civ = Player_GetRaceName(player.id)
	local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ
	AGS_SetEntityProductionAvailabilitySafe(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_ARCHERY_RANGE), ITEM_LOCKED, "BuildingLimit_LockPlayer/archery/" .. tostring(player.raceName))
	AGS_SetEntityProductionAvailabilitySafe(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_STABLE), ITEM_LOCKED, "BuildingLimit_LockPlayer/stable/" .. tostring(player.raceName))
	AGS_SetEntityProductionAvailabilitySafe(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_DOCK), ITEM_LOCKED, "BuildingLimit_LockPlayer/dock/" .. tostring(player.raceName))
	AGS_SetEntityProductionAvailabilitySafe(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_BARRACKS), ITEM_LOCKED, "BuildingLimit_LockPlayer/barracks/" .. tostring(player.raceName))
	CBA_Options_BuildingLimit_SetAdditionalProductionAvailability(player, ITEM_LOCKED, "BuildingLimit_LockPlayer")
	if branch_civ == "english" then
		Player_SetEntityProductionAvailability(player.id, EBP.ENGLISH.BUILDING_LANDMARK_AGE1_WESTMINSTER_HALL_ENG, ITEM_LOCKED)
	elseif branch_civ == "french" then
		Player_SetEntityProductionAvailability(player.id, EBP.FRENCH.BUILDING_LANDMARK_AGE1_CASERNES_CENTRALES_FRE, ITEM_LOCKED)
	elseif branch_civ == "hre" then
		Player_SetEntityProductionAvailability(player.id, EBP.HRE.BUILDING_LANDMARK_AGE2_NUREMBERG_CASTLE_HRE, ITEM_LOCKED)
	elseif player_civ == "malian" then
		Player_SetEntityProductionAvailability(player.id, EBP.MALIAN.BUILDING_LANDMARK_AGE2_LANDMARKD_CONTROL_MAL, ITEM_LOCKED)
	end
end

-- Unlocks production buildings for a player below their limit.
function CBA_Options_BuildingLimit_UnlockPlayer(player)
	if player == nil or player.id == nil then return end
	local player_civ = Player_GetRaceName(player.id)
	local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ
	AGS_SetEntityProductionAvailabilitySafe(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_ARCHERY_RANGE), ITEM_DEFAULT, "BuildingLimit_UnlockPlayer/archery/" .. tostring(player.raceName))
	AGS_SetEntityProductionAvailabilitySafe(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_STABLE), ITEM_DEFAULT, "BuildingLimit_UnlockPlayer/stable/" .. tostring(player.raceName))
	AGS_SetEntityProductionAvailabilitySafe(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_BARRACKS), ITEM_DEFAULT, "BuildingLimit_UnlockPlayer/barracks/" .. tostring(player.raceName))
	CBA_Options_BuildingLimit_SetAdditionalProductionAvailability(player, ITEM_DEFAULT, "BuildingLimit_UnlockPlayer")
	if not AGS_GLOBAL_SETTINGS.NoDock then
		AGS_SetEntityProductionAvailabilitySafe(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_DOCK), ITEM_DEFAULT, "BuildingLimit_UnlockPlayer/dock/" .. tostring(player.raceName))
	end
	if branch_civ == "english" then
		Player_SetEntityProductionAvailability(player.id, EBP.ENGLISH.BUILDING_LANDMARK_AGE1_WESTMINSTER_HALL_ENG, ITEM_DEFAULT)
	elseif branch_civ == "french" then
		Player_SetEntityProductionAvailability(player.id, EBP.FRENCH.BUILDING_LANDMARK_AGE1_CASERNES_CENTRALES_FRE, ITEM_DEFAULT)
	elseif branch_civ == "hre" then
		Player_SetEntityProductionAvailability(player.id, EBP.HRE.BUILDING_LANDMARK_AGE2_NUREMBERG_CASTLE_HRE, ITEM_DEFAULT)
	elseif player_civ == "malian" then
		Player_SetEntityProductionAvailability(player.id, EBP.MALIAN.BUILDING_LANDMARK_AGE2_LANDMARKD_CONTROL_MAL, ITEM_DEFAULT)
	end
end

---------------------------------------------------------------------------------------------------
-- Building Limit — Recount (full re-derive from live entities)
---------------------------------------------------------------------------------------------------

-- Re-derives all building limit counters for a single player from live entities.
-- Mirrors the reconciliation logic in CBA_Options_BuildingLimit_SetupObjective.
function CBA_Options_BuildingLimit_RecountPlayer(player)
	if player == nil or player.id == nil then return end
	local player_civ = Player_GetRaceName(player.id)
	local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ

	local prod_count = 0
	local workshop_count = 0
	local outpost_count = 0

	local eg_existing = Player_GetEntities(player.id)
	EGroup_ForEach(eg_existing, function(gid, idx, eid)
		-- Skip starter keep (symmetry with init)
		if eid == player.obj_buildingLimit_english_start_keep_id then
			return
		end
		if CBA_Options_BuildingLimit_IsProductionCapBuildingByEntity(eid, false) then
			prod_count = prod_count + 1
		end
		if AGS_GLOBAL_SETTINGS.MaximumSiegeWorkshop ~= 0 and not AGS_GLOBAL_SETTINGS.NoSiege and
			CBA_Options_BuildingLimit_IsWorkshopCapBuilding(eid, player_civ, branch_civ, false) then
			workshop_count = workshop_count + 1
		end
		-- Outpost (includes stone wall tower)
		if Entity_IsOfType(eid, "scar_outpost") or Entity_IsOfType(eid, "stone_wall_tower") then
			outpost_count = outpost_count + 1
		end
	end)
	EGroup_Destroy(eg_existing)

	local old_p = player.obj_buildingLimit_count or 0
	local old_w = player.obj_buildingLimit_workshop_count or 0
	local old_o = player.obj_buildingLimit_outpost_count or 0
	player.obj_buildingLimit_count = prod_count
	player.obj_buildingLimit_workshop_count = workshop_count
	player.obj_buildingLimit_outpost_count = outpost_count
	CBA_Options_ProductionLimit_ApplyThreshold(player)

	if prod_count ~= old_p or workshop_count ~= old_w or outpost_count ~= old_o then
		DebugLog("bld_limit", string.format(
			"RecountPlayer: P%d prod %d→%d ws %d→%d op %d→%d",
			player.playerIndex or 0, old_p, prod_count, old_w, workshop_count, old_o, outpost_count
		))
	end

	-- Update local player objective UI
	if player.isLocal and _buildingLimit ~= nil and _buildingLimit.objective_buildingLimit ~= nil then
		Obj_SetCounterCount(_buildingLimit.objective_buildingLimit, prod_count)
		Obj_SetProgress(_buildingLimit.objective_buildingLimit, prod_count / math.max(1, CBA_Options_GetPlayerProdLimit(player)))
	end
end

---------------------------------------------------------------------------------------------------
-- Building Limit — Enforce Excess (destroy buildings above cap)
---------------------------------------------------------------------------------------------------

-- Destroys newest production buildings, workshops, and outposts that exceed limits.
-- Called after transfer to ensure recipient never exceeds cap.
function CBA_Options_BuildingLimit_EnforceExcess(player)
	if player == nil or player.id == nil then return end
	local max_prod = CBA_Options_GetPlayerProdLimit(player)
	local max_ws = CBA_Options_GetPlayerWorkshopLimit(player)
	local max_op = CBA_Options_GetPlayerOutpostLimit(player)

	if max_prod == 0 then return end

	local player_civ = Player_GetRaceName(player.id)
	local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ

	-- Collect entities by category (reverse order = newest first for destruction)
	local prod_entities = {}
	local workshop_entities = {}
	local outpost_entities = {}

	local eg_all = Player_GetEntities(player.id)
	EGroup_ForEach(eg_all, function(gid, idx, eid)
		if eid == player.obj_buildingLimit_english_start_keep_id then return end
		if CBA_Options_BuildingLimit_IsProductionCapBuildingByEntity(eid, false) then
			table.insert(prod_entities, eid)
		end
		if AGS_GLOBAL_SETTINGS.MaximumSiegeWorkshop ~= 0 and not AGS_GLOBAL_SETTINGS.NoSiege and
			CBA_Options_BuildingLimit_IsWorkshopCapBuilding(eid, player_civ, branch_civ, false) then
			table.insert(workshop_entities, eid)
		end
		if Entity_IsOfType(eid, "scar_outpost") or Entity_IsOfType(eid, "stone_wall_tower") then
			table.insert(outpost_entities, eid)
		end
	end)
	EGroup_Destroy(eg_all)

	-- Destroy excess (newest = last inserted)
	local function _kill_excess(list, cap, label)
		while #list > cap do
			local eid = table.remove(list)
			pcall(Entity_Kill, eid)
			DebugLog("bld_limit", string.format("EnforceExcess: killed %s entity for P%d", label, player.playerIndex or 0))
		end
	end
	_kill_excess(prod_entities, max_prod, "production")
	if max_ws > 0 then _kill_excess(workshop_entities, max_ws, "workshop") end
	_kill_excess(outpost_entities, max_op, "outpost")
end

---------------------------------------------------------------------------------------------------
-- Population Cap — Enforcement (remove units when over cap)
---------------------------------------------------------------------------------------------------

-- PERF: Per-frame kill budget for batched enforcement during leaver Phase 7.
-- Set high enough to clear all excess in a single pass and avoid enforcement cascades.
-- Previous value of 15 caused 6-pass cascade when excess=25+ after leaver transfers.
_ENFORCE_POP_CAP_BUDGET = 200

-- Removes units by priority (eco then military) until population is at or below cap.
-- Returns "pending" if budget was exhausted before all excess killed; nil when done.
function CBA_Options_EnforcePopulationCap(player, max_kills)
	if player == nil or player.id == nil then return end
	local current_pop = Player_GetCurrentPopulation(player.id, CT_Personnel)
	local max_pop = Player_GetCurrentPopulationCap(player.id, CT_Personnel)
	if current_pop <= max_pop then return end

	local excess = current_pop - max_pop
	local budget = max_kills or excess  -- no budget = kill all (legacy behavior)
	local killed = 0

	-- Single enumeration: classify squads into eco and military buckets
	local sg = Player_GetSquads(player.id)
	local sc = SGroup_Count(sg)
	local eco_squads = {}
	local mil_squads = {}
	for idx = 1, sc do
		local squad = SGroup_GetSquadAt(sg, idx)
		if squad ~= nil then
			if Squad_IsOfType(squad, "scar_villager") or Squad_IsOfType(squad, "scar_monk")
				or Squad_IsOfType(squad, "scar_trader") or Squad_IsOfType(squad, "scar_fishing") then
				table.insert(eco_squads, squad)
			else
				table.insert(mil_squads, squad)
			end
		end
	end
	SGroup_Destroy(sg)

	-- Phase 1: kill eco squads first (villager, monk, trader, fishing)
	for i = #eco_squads, 1, -1 do
		if killed >= excess or killed >= budget then break end
		pcall(Squad_Kill, eco_squads[i])
		killed = killed + 1
	end

	-- Phase 2: kill remaining military squads
	if killed < excess and killed < budget then
		for i = #mil_squads, 1, -1 do
			if killed >= excess or killed >= budget then break end
			pcall(Squad_Kill, mil_squads[i])
			killed = killed + 1
		end
	end

	if killed > 0 then
		DebugLog("pop_cap", string.format("EnforcePopulationCap: P%d killed %d squads (excess=%d budget=%s)",
			player.playerIndex or 0, killed, excess, tostring(max_kills or "unlimited")))
	end

	-- Return "pending" if budget was exhausted before excess was fully cleared
	if killed >= budget and killed < excess then
		return "pending"
	end
end

---------------------------------------------------------------------------------------------------
-- Post-Transfer Enforcement Pipeline
---------------------------------------------------------------------------------------------------

-- PERF: Flag to skip redundant recounts in FieldConstruct_Gate during enforcement.
_CBA_ENFORCE_IN_PROGRESS = false

-- Full enforcement after ownership transfer. Cancel queues, recount, destroy excess, fix pop.
function CBA_Options_EnforcePostTransfer(player)
	if player == nil or player.id == nil then return end
	_CBA_ENFORCE_IN_PROGRESS = true
	CBA_Options_BuildingLimit_RecountPlayer(player)
	CBA_Options_BuildingLimit_EnforceExcess(player)
	CBA_Options_ProductionLimit_ApplyThreshold(player)
	CBA_Options_WorkshopLimit_ApplyThreshold(player)
	CBA_Options_SiegeLimit_RecountAll(player)
	local _pt_ram_q, _pt_st_q, _pt_siege_q = _CBA_Options_GetAllQueuedCounts(player)
	CBA_Options_SiegeLimit_ApplyThreshold(player, _pt_siege_q)
	CBA_Options_RamLimit_ApplyThreshold(player, _pt_ram_q)
	CBA_Options_SiegeTowerLimit_ApplyThreshold(player, _pt_st_q)
	CBA_Options_FieldConstruct_Gate(player)
	CBA_Options_EnforcePopulationCap(player)
	if type(AGS_PopulationAutomatic_ReconcileCapDrift) == "function" then
		AGS_PopulationAutomatic_ReconcileCapDrift()
	end
	_CBA_ENFORCE_IN_PROGRESS = false
	if type(AGS_LimitsUI_DeferUpdate) == "function" then
		AGS_LimitsUI_DeferUpdate()
	end
end

---------------------------------------------------------------------------------------------------
-- Split Enforcement Sub-Phases (for leaver pipeline Phase 7 batching)
-- Spreads the enforcement work across 3 frames per ally to reduce per-frame peak cost.
---------------------------------------------------------------------------------------------------

-- Sub-phase 1: Recount all limits (building, siege, ram, ST)
function CBA_Options_EnforcePostTransfer_Recount(player)
	if player == nil or player.id == nil then return end
	_CBA_ENFORCE_IN_PROGRESS = true
	CBA_Options_BuildingLimit_RecountPlayer(player)
	CBA_Options_SiegeLimit_RecountAll(player)
	_CBA_ENFORCE_IN_PROGRESS = false
end

-- Sub-phase 2: Enforce limits — destroy excess, apply thresholds, enforce pop cap
-- Returns "pending" if pop-cap enforcement was budget-limited and needs another tick.
function CBA_Options_EnforcePostTransfer_Enforce(player)
	if player == nil or player.id == nil then return end
	_CBA_ENFORCE_IN_PROGRESS = true
	CBA_Options_BuildingLimit_EnforceExcess(player)
	CBA_Options_ProductionLimit_ApplyThreshold(player)
	CBA_Options_WorkshopLimit_ApplyThreshold(player)
	local _ep_ram_q, _ep_st_q, _ep_siege_q = _CBA_Options_GetAllQueuedCounts(player)
	CBA_Options_SiegeLimit_ApplyThreshold(player, _ep_siege_q)
	CBA_Options_RamLimit_ApplyThreshold(player, _ep_ram_q)
	CBA_Options_SiegeTowerLimit_ApplyThreshold(player, _ep_st_q)
	CBA_Options_FieldConstruct_Gate(player)
	local pop_result = CBA_Options_EnforcePopulationCap(player, _ENFORCE_POP_CAP_BUDGET)
	if type(AGS_PopulationAutomatic_ReconcileCapDrift) == "function" then
		AGS_PopulationAutomatic_ReconcileCapDrift()
	end
	_CBA_ENFORCE_IN_PROGRESS = false
	return pop_result
end

-- Sub-phase 3: UI update
function CBA_Options_EnforcePostTransfer_UI(player)
	if type(AGS_LimitsUI_DeferUpdate) == "function" then
		AGS_LimitsUI_DeferUpdate()
	end
end

---------------------------------------------------------------------------------------------------
-- Revalidation (lighter — recount + threshold, no destruction)
---------------------------------------------------------------------------------------------------

-- Recounts all limits and re-applies thresholds without destroying excess.
function CBA_Options_RevalidateAll(player)
	if player == nil or player.id == nil then return end
	CBA_Options_BuildingLimit_RecountPlayer(player)
	CBA_Options_ProductionLimit_ApplyThreshold(player)
	CBA_Options_WorkshopLimit_ApplyThreshold(player)
	CBA_Options_SiegeLimit_RecountAll(player)
	local _rv_ram_q, _rv_st_q, _rv_siege_q = _CBA_Options_GetAllQueuedCounts(player)
	CBA_Options_SiegeLimit_ApplyThreshold(player, _rv_siege_q)
	CBA_Options_RamLimit_ApplyThreshold(player, _rv_ram_q)
	CBA_Options_SiegeTowerLimit_ApplyThreshold(player, _rv_st_q)
	CBA_Options_FieldConstruct_Gate(player)
	if type(AGS_LimitsUI_DeferUpdate) == "function" then
		AGS_LimitsUI_DeferUpdate()
	end
end

-- Revalidates all non-eliminated players.
function CBA_Options_RevalidateAllPlayers()
	for _, player in ipairs(PLAYERS) do
		if not Core_IsPlayerEliminated(player.id) then
			CBA_Options_RevalidateAll(player)
		end
	end
end

---------------------------------------------------------------------------------------------------
-- Building Limit — Periodic Reconciliation
-- Safety net: re-derives building limit counters from live entities every ~6 seconds/player.
-- Catches missed GE_EntityKilled events (owner resolution failure, queue overflow, etc.).
-- Staggered: processes ONE player per tick, cycling through all players over ~6 seconds total.
---------------------------------------------------------------------------------------------------

_CBA_BuildingLimit_Reconcile_PlayerIdx = 1

function CBA_Options_BuildingLimit_Reconcile()
	local num_players = #PLAYERS
	if num_players == 0 then return end

	-- Find next non-eliminated player (skip up to num_players to avoid infinite loop)
	local checked = 0
	local player = nil
	while checked < num_players do
		local idx = _CBA_BuildingLimit_Reconcile_PlayerIdx
		_CBA_BuildingLimit_Reconcile_PlayerIdx = (idx % num_players) + 1
		checked = checked + 1
		local candidate = PLAYERS[idx]
		if candidate ~= nil and not Core_IsPlayerEliminated(candidate.id) then
			player = candidate
			break
		end
	end
	if player == nil then return end

	_CBA_PERF.bld_reconcile_ticks = (_CBA_PERF.bld_reconcile_ticks or 0) + 1

	-- Snapshot old values for drift detection
	local old_p = player.obj_buildingLimit_count or 0
	local old_w = player.obj_buildingLimit_workshop_count or 0
	local old_o = player.obj_buildingLimit_outpost_count or 0

	-- Full recount from live entities (also applies ProductionLimit_ApplyThreshold internally)
	CBA_Options_BuildingLimit_RecountPlayer(player)

	-- Apply workshop + outpost thresholds (RecountPlayer only applies production threshold)
	CBA_Options_WorkshopLimit_ApplyThreshold(player)

	-- Outpost threshold (inline — no dedicated function exists)
	local op_count = player.obj_buildingLimit_outpost_count or 0
	local op_max = CBA_Options_GetPlayerOutpostLimit(player)
	if op_count >= op_max then
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprintsWithType("scar_outpost"), ITEM_LOCKED)
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprintsWithType("stone_wall_tower"), ITEM_LOCKED)
	else
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprintsWithType("scar_outpost"), ITEM_DEFAULT)
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprintsWithType("stone_wall_tower"), ITEM_DEFAULT)
	end

	-- Track drift for diagnostics
	local new_p = player.obj_buildingLimit_count or 0
	local new_w = player.obj_buildingLimit_workshop_count or 0
	local new_o = player.obj_buildingLimit_outpost_count or 0
	if new_p ~= old_p or new_w ~= old_w or new_o ~= old_o then
		_CBA_PERF.bld_reconcile_drift = (_CBA_PERF.bld_reconcile_drift or 0) + 1
	end

	-- Trigger UI refresh if any counter changed for local player
	if player.isLocal and (new_p ~= old_p or new_w ~= old_w or new_o ~= old_o) then
		if type(AGS_LimitsUI_DeferUpdate) == "function" then
			AGS_LimitsUI_DeferUpdate("BuildingLimit_Reconcile")
		end
	end
end

-- Periodic reconciliation — catches stale counts from missing/delayed construction events.
-- Safety net for cancel-construction exploit and missing GE_ConstructionStart for field rams.
-- Staggered: processes ONE player per tick, cycling through all players over ~6 seconds total.
function CBA_Options_SiegeLimit_Reconcile()
	local num_players = #PLAYERS
	if num_players == 0 then return end

	-- Find next non-eliminated player (skip up to num_players to avoid infinite loop)
	local checked = 0
	local player = nil
	while checked < num_players do
		local idx = _CBA_Reconcile_PlayerIdx
		_CBA_Reconcile_PlayerIdx = (idx % num_players) + 1
		checked = checked + 1
		local candidate = PLAYERS[idx]
		if candidate ~= nil and not Core_IsPlayerEliminated(candidate.id) then
			player = candidate
			break
		end
	end
	if player == nil then return end

	_CBA_PERF.reconcile_ticks = _CBA_PERF.reconcile_ticks + 1

	CBA_Options_SiegeLimit_RecountAll(player)

	-- Single queue scan for ram, ST, and siege
	local ram_queued, st_queued, siege_queued = _CBA_Options_GetAllQueuedCounts(player)

	-- Periodic rollback: if ram cap exceeded, kill excess scaffolds
	local ram_live = player.ramLimit_count or 0
	local ram_pending = player.ramLimit_pending or 0
	local ram_total = ram_live + ram_pending + ram_queued
	local ram_max = CBA_Options_GetPlayerRamLimit(player)
	if ram_total > ram_max then
		local excess = ram_total - ram_max
		local removed_weight, removed_scaffolds = CBA_Options_RamLimit_RollbackExcessScaffolds(player, excess)
		if removed_weight > 0 then
			CBA_Options_RamLimit_Recount(player)
		end
		if CBA_Options_ShouldLogSiegeStandard() and (removed_weight > 0 or excess > 0) then
			print(string.format(
				"[CBA_OPTIONS][CAP_HOTFIX_RECONCILE] P%d ram_total=%d/%d excess=%d removed_weight=%d removed_scaffolds=%d",
				player.index or 0, ram_total, ram_max, excess, removed_weight, removed_scaffolds))
		end
		-- Squad-kill fallback: entity rollback only reaches scaffolds/just-completed entities.
		-- If squads have already fully converted (common at 3s reconcile interval), kill newest excess squads.
		local remaining_excess = excess - removed_weight
		if remaining_excess > 0 then
			local sq_civ = Player_GetRaceName(player.id)
			local sg_all = Player_GetSquads(player.id)
			local sq_count = SGroup_Count(sg_all)
			local killed_squads = 0
			local killed_weight = 0
			for idx = sq_count, 1, -1 do
				if remaining_excess <= 0 then break end
				local squad = SGroup_GetSquadAt(sg_all, idx)
				if squad ~= nil then
					local is_rt = CBA_Options_IsRamTowerSquad(squad, sq_civ)
					local is_ram = is_rt or
						Squad_IsOfType(squad, "ram") or Squad_IsOfType(squad, "scar_ram") or
						Squad_IsOfType(squad, "fire_ram") or Squad_IsOfType(squad, "scar_fire_ram")
					if is_ram then
						local weight = is_rt and 2 or 1
						CBA_Options_SiegeLimit_RefundSquadCost(player, squad)
						local ok_kill = pcall(Squad_Kill, squad)
						if ok_kill then
							remaining_excess = remaining_excess - weight
							killed_weight = killed_weight + weight
							killed_squads = killed_squads + 1
						end
					end
				end
			end
			SGroup_Destroy(sg_all)
			if killed_weight > 0 then
				CBA_Options_RamLimit_Recount(player)
			end
			if CBA_Options_ShouldLogSiegeStandard() then
				print(string.format(
					"[CBA_OPTIONS][CAP_RECONCILE_SQUAD_KILL] P%d excess=%d killed_squads=%d killed_weight=%d",
					player.index or 0, excess, killed_squads, killed_weight))
			end
		end
	end

	-- Periodic rollback: if siege tower cap exceeded, kill excess scaffolds then squads
	local st_live = player.siegeTowerLimit_count or 0
	local st_pending = player.siegeTowerLimit_pending or 0
	local st_total = st_live + st_pending + st_queued
	local st_max = CBA_Options_GetPlayerSiegeTowerLimit(player)
	if st_total > st_max then
		local st_excess = st_total - st_max
		local removed_st, removed_st_scaffolds = CBA_Options_SiegeTowerLimit_RollbackExcessScaffolds(player, st_excess)
		if removed_st > 0 then
			CBA_Options_SiegeTowerLimit_Recount(player)
		end
		if CBA_Options_ShouldLogSiegeStandard() and (removed_st > 0 or st_excess > 0) then
			print(string.format(
				"[CBA_OPTIONS][CAP_HOTFIX_ST_RECONCILE] P%d st_total=%d/%d excess=%d removed=%d removed_scaffolds=%d",
				player.index or 0, st_total, st_max, st_excess, removed_st, removed_st_scaffolds))
		end
		-- Squad-kill fallback for completed siege towers
		local remaining_st_excess = st_excess - removed_st
		if remaining_st_excess > 0 then
			local sg_all = Player_GetSquads(player.id)
			local sq_count = SGroup_Count(sg_all)
			local killed_st_squads = 0
			for idx = sq_count, 1, -1 do
				if remaining_st_excess <= 0 then break end
				local squad = SGroup_GetSquadAt(sg_all, idx)
				if squad ~= nil and Squad_IsOfType(squad, "siege") and Squad_IsOfType(squad, "siege_tower") then
					CBA_Options_SiegeLimit_RefundSquadCost(player, squad)
					local ok_kill = pcall(Squad_Kill, squad)
					if ok_kill then
						remaining_st_excess = remaining_st_excess - 1
						killed_st_squads = killed_st_squads + 1
					end
				end
			end
			SGroup_Destroy(sg_all)
			if killed_st_squads > 0 then
				CBA_Options_SiegeTowerLimit_Recount(player)
			end
			if CBA_Options_ShouldLogSiegeStandard() then
				print(string.format(
					"[CBA_OPTIONS][CAP_RECONCILE_ST_SQUAD_KILL] P%d excess=%d killed_squads=%d",
					player.index or 0, st_excess, killed_st_squads))
			end
		end
	end

	-- Periodic rollback: if generic siege cap exceeded, kill excess scaffolds then squads
	if AGS_GLOBAL_SETTINGS.MaximumMedicPopulation ~= 0 then
		local max_siege = CBA_Options_GetPlayerSiegeLimit(player)
		local siege_live = player.siegeLimit_count or 0
		local siege_pending = player.siegeLimit_pending or 0
		local siege_total = siege_live + siege_pending + siege_queued
		if siege_total > max_siege then
			local siege_excess = siege_total - max_siege
			local removed_pts, removed_scaffolds = CBA_Options_SiegeLimit_RollbackExcessScaffolds(player, siege_excess)
			if removed_pts > 0 then
				CBA_Options_SiegeLimit_Recount(player)
			end
			if CBA_Options_ShouldLogSiegeStandard() and (removed_pts > 0 or siege_excess > 0) then
				print(string.format(
					"[CBA_OPTIONS][CAP_HOTFIX_SIEGE_RECONCILE] P%d siege_total=%d/%d excess=%d removed_pts=%d removed_scaffolds=%d",
					player.index or 0, siege_total, max_siege, siege_excess, removed_pts, removed_scaffolds))
			end
			-- Squad-kill fallback for completed generic siege weapons
			local remaining_siege_excess = siege_excess - removed_pts
			if remaining_siege_excess > 0 then
				local sq_civ = Player_GetRaceName(player.id)
				local sg_all = Player_GetSquads(player.id)
				local sq_count = SGroup_Count(sg_all)
				local killed_siege_squads = 0
				local killed_siege_pts = 0
				for idx = sq_count, 1, -1 do
					if remaining_siege_excess <= 0 then break end
					local squad = SGroup_GetSquadAt(sg_all, idx)
					if squad ~= nil then
						local ok_sbp, sq_sbp = pcall(Squad_GetBlueprint, squad)
						if ok_sbp and sq_sbp ~= nil then
							local pts = CBA_Options_GetSiegeWeaponPointsSBP(sq_sbp, sq_civ)
							if pts > 0 then
								CBA_Options_SiegeLimit_RefundSquadCost(player, squad)
								local ok_kill = pcall(Squad_Kill, squad)
								if ok_kill then
									remaining_siege_excess = remaining_siege_excess - pts
									killed_siege_pts = killed_siege_pts + pts
									killed_siege_squads = killed_siege_squads + 1
								end
							end
						end
					end
				end
				SGroup_Destroy(sg_all)
				if killed_siege_pts > 0 then
					CBA_Options_SiegeLimit_Recount(player)
				end
				if CBA_Options_ShouldLogSiegeStandard() then
					print(string.format(
						"[CBA_OPTIONS][CAP_RECONCILE_SIEGE_SQUAD_KILL] P%d excess=%d killed_squads=%d killed_pts=%d",
						player.index or 0, siege_excess, killed_siege_squads, killed_siege_pts))
				end
			end
		end
	end
	
	CBA_Options_SiegeLimit_ApplyThreshold(player, siege_queued)
	CBA_Options_RamLimit_ApplyThreshold(player, ram_queued)
	CBA_Options_SiegeTowerLimit_ApplyThreshold(player, st_queued)
	CBA_Options_FieldConstruct_Gate(player)
end

---------------------------------------------------------------------------------------------------
-- Field-Construction Gate — Siege Engineers Upgrade Requirement
-- Locks all field-constructible siege EBPs until the player has Siege Engineers.
-- Called AFTER SiegeLimit_ApplyThreshold + Ram/ST limits as a final restriction layer.
-- Workshop production (SBP) is NOT affected — only entity (field) production.
---------------------------------------------------------------------------------------------------

function CBA_Options_FieldConstruct_Gate(player)
	if player == nil or player.id == nil then return end
	-- No zero-limit guard: SE and age gates are gameplay gates that apply even in unlimited mode
	
	local has_eng = CBA_Options_HasSiegeEngineers(player)
	local player_civ = Player_GetRaceName(player.id)
	local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ
	
	-- No Siege Engineers — lock ALL field-construction EBPs (rams, towers, and siege weapons)
	if not has_eng then
		local field_ram = AGS_GetSiegeEntity(player_civ, BP_SIEGE_RAM)
		if field_ram ~= nil then
			Player_SetEntityProductionAvailability(player.id, field_ram, ITEM_LOCKED)
		end
		local field_st = AGS_GetSiegeEntity(player_civ, BP_SIEGE_TOWER)
		if field_st ~= nil then
			Player_SetEntityProductionAvailability(player.id, field_st, ITEM_LOCKED)
		end
		if branch_civ == "mongol" then
			for _, entity_blueprint in pairs(CBA_SIEGE_UNITS.siege_buildable_mon) do
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint(entity_blueprint), ITEM_LOCKED)
			end
		elseif player_civ == "abbasid" then
			for _, entity_blueprint in pairs(CBA_SIEGE_UNITS.siege_buildable_abb) do
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint(entity_blueprint), ITEM_LOCKED)
			end
		elseif player_civ == "abbasid_ha_01" then
			for _, entity_blueprint in pairs(CBA_SIEGE_UNITS.siege_buildable_abb_ha_01) do
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint(entity_blueprint), ITEM_LOCKED)
			end
			Player_SetEntityProductionAvailability(player.id, EBP.ABBASID_HA_01.UNIT_RAM_TOWER_3_ABB_HA_01, ITEM_LOCKED)
		elseif branch_civ == "byzantine" then
			Player_SetEntityProductionAvailability(player.id, EBP.BYZANTINE.UNIT_RAM_FIRE_3_BYZ, ITEM_LOCKED)
		end
		if CBA_Options_ShouldLogSiegeVerbose() or CBA_Options_ShouldLogSiegeStateChange(player, "field_gate", "LOCKED_NO_SE") then
			print(string.format("[CBA_OPTIONS][FIELD_GATE] P%d civ=%s has_se=false decision=LOCKED_NO_SE", player.index or 0, tostring(player_civ)))
		end
		return
	end
	
	-- Has Siege Engineers but below Age 3 — lock civ-specific field siege weapons only
	-- (field rams and towers remain available, managed by their own limit systems)
	local age = Player_GetCurrentAge(player.id)
	if age < 3 then
		if branch_civ == "mongol" then
			for _, entity_blueprint in pairs(CBA_SIEGE_UNITS.siege_buildable_mon) do
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint(entity_blueprint), ITEM_LOCKED)
			end
		elseif player_civ == "abbasid" then
			for _, entity_blueprint in pairs(CBA_SIEGE_UNITS.siege_buildable_abb) do
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint(entity_blueprint), ITEM_LOCKED)
			end
		elseif player_civ == "abbasid_ha_01" then
			for _, entity_blueprint in pairs(CBA_SIEGE_UNITS.siege_buildable_abb_ha_01) do
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint(entity_blueprint), ITEM_LOCKED)
			end
		end
		if CBA_Options_ShouldLogSiegeVerbose() or CBA_Options_ShouldLogSiegeStateChange(player, "field_gate", "LOCKED_AGE") then
			print(string.format("[CBA_OPTIONS][FIELD_GATE] P%d civ=%s has_se=true age=%d decision=LOCKED_AGE", player.index or 0, tostring(player_civ), age))
		end
	else
		-- Explicitly unlock all civ-specific buildable EBPs via BP map resolution.
		-- Without this, buildables stay stale-locked from a prior no-SE / age<3 gate.
		local buildable_keys = { "springald_buildable", "mangonel_buildable", "trebuchet_tr_buildable", "trebuchet_cw_buildable" }
		for _, key in pairs(buildable_keys) do
			local ebp = AGS_GetSiegeEntity(player_civ, key)
			if ebp ~= nil then
				Player_SetEntityProductionAvailability(player.id, ebp, ITEM_UNLOCKED)
			end
		end
		-- Force cascade re-evaluation: clear cached tier so ApplyThreshold won't skip,
		-- then re-run RecountAll + ApplyThreshold to sync counts and apply tier locks.
		-- PERF: Skip redundant recount if called from EnforcePostTransfer (counts already fresh).
		player._siege_enforce_tier = nil
		if not _CBA_ENFORCE_IN_PROGRESS then
			CBA_Options_SiegeLimit_RecountAll(player)
			local _fg_ram_q, _fg_st_q, _fg_siege_q = _CBA_Options_GetAllQueuedCounts(player)
			CBA_Options_SiegeLimit_ApplyThreshold(player, _fg_siege_q)
		end
		if CBA_Options_ShouldLogSiegeVerbose() or CBA_Options_ShouldLogSiegeStateChange(player, "field_gate", "UNLOCKED") then
			print(string.format("[CBA_OPTIONS][FIELD_GATE] P%d civ=%s has_se=true age=%d decision=UNLOCKED recount_synced=true", player.index or 0, tostring(player_civ), age))
		end
	end
end

---------------------------------------------------------------------------------------------------
-- Ram / Siege Tower Limit — Enforcement, Accessors & Recount
-- Independent production caps for rams (RAM_LIMIT_MAX) and siege towers (SIEGE_TOWER_LIMIT_MAX).
-- Enforced via Player_SetSquadProductionAvailability / Player_SetEntityProductionAvailability.
-- Called AFTER SiegeLimit_ApplyThreshold so independent limits can override cascade unlocks.
---------------------------------------------------------------------------------------------------

-- Locks or unlocks all ram production for a player (workshop + field-built + civ variants).
function CBA_Options_RamLimit_Disable(player_id, lock_type)
	local player_civ = Player_GetRaceName(player_id)
	local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ
	
	-- Generic: workshop ram (squad) + field ram (entity)
	local ws_ram = AGS_GetSiegeUnit(player_civ, BP_SIEGE_WORKSHOP_RAM)
	if ws_ram ~= nil then
		Player_SetSquadProductionAvailability(player_id, ws_ram, lock_type)
	end
	local field_ram = AGS_GetSiegeEntity(player_civ, BP_SIEGE_RAM)
	if field_ram ~= nil then
		Player_SetEntityProductionAvailability(player_id, field_ram, lock_type)
	end
	
	-- Civ-specific variants
	if player_civ == "chinese" then
		-- Clocktower ram
		Player_SetSquadProductionAvailability(player_id, SBP.CHINESE.UNIT_RAM_3_CLOCKTOWER_CHI, lock_type)
	elseif player_civ == "abbasid_ha_01" then
		-- Ram Tower (field-built entity, counts as 2 rams)
		Player_SetEntityProductionAvailability(player_id, EBP.ABBASID_HA_01.UNIT_RAM_TOWER_3_ABB_HA_01, lock_type)
	elseif branch_civ == "byzantine" then
		-- Fire ram (field-built entity) — workshop fire ram already covered by generic ws_ram
		Player_SetEntityProductionAvailability(player_id, EBP.BYZANTINE.UNIT_RAM_FIRE_3_BYZ, lock_type)
		if player_civ == "byzantine_ha_mac" then
			-- mac variant has its own unique fire ram EBP distinct from parent
			local ok_mac_fire, mac_fire_ebp = pcall(BP_GetEntityBlueprint, "unit_ram_fire_3_byz_ha_mac")
			if ok_mac_fire and mac_fire_ebp ~= nil then
				Player_SetEntityProductionAvailability(player_id, mac_fire_ebp, lock_type)
			end
		end
	end
end

-- Locks or unlocks ONLY weight-2 ram variants (ram_tower) without touching weight-1 rams.
-- Used when remaining capacity is 1: enough for regular rams but not ram_tower.
function CBA_Options_RamTowerOnly_Disable(player_id, lock_type)
	local player_civ = Player_GetRaceName(player_id)
	if player_civ == "abbasid_ha_01" then
		Player_SetEntityProductionAvailability(player_id, EBP.ABBASID_HA_01.UNIT_RAM_TOWER_3_ABB_HA_01, lock_type)
	end
end

-- Locks or unlocks all siege tower production for a player (workshop + field-built).
function CBA_Options_SiegeTowerLimit_Disable(player_id, lock_type)
	local player_civ = Player_GetRaceName(player_id)
	
	-- Workshop siege tower (squad)
	local ws_st = AGS_GetSiegeUnit(player_civ, BP_SIEGE_TOWER)
	if ws_st ~= nil then
		Player_SetSquadProductionAvailability(player_id, ws_st, lock_type)
	end
	-- Field-built siege tower (entity) — may share BP name; nil-safe
	local field_st = AGS_GetSiegeEntity(player_civ, BP_SIEGE_TOWER)
	if field_st ~= nil then
		Player_SetEntityProductionAvailability(player_id, field_st, lock_type)
	end
end

-- Applies ram production lock/unlock based on total ram count (live + pending) vs RAM_LIMIT_MAX.
-- Pending units represent field-built scaffolds still under construction.
-- Called AFTER SiegeLimit_ApplyThreshold; FieldConstruct_Gate may re-lock field rams afterward.
function CBA_Options_RamLimit_ApplyThreshold(player, opt_ram_queued)
	if player == nil or player.id == nil then return end
	-- Respect the Siege Engineers gate — never unlock if SE not researched
	if not CBA_Options_HasSiegeEngineers(player) then
		CBA_Options_RamLimit_Disable(player.id, ITEM_LOCKED)
		if CBA_Options_ShouldLogSiegeStateChange(player, "ram_threshold", "LOCKED_NO_SE") then
			print(string.format("[CBA_OPTIONS][RAM_THRESHOLD] P%d decision=LOCKED_NO_SE", player.index or 0))
		end
		return
	end
	local live = player.ramLimit_count or 0
	local pending = player.ramLimit_pending or 0
	local queued = opt_ram_queued or CBA_Options_RamLimit_GetQueuedCount(player)
	local count = live + pending + queued
	local ram_max = CBA_Options_GetPlayerRamLimit(player)
	local remaining = ram_max - count
	local decision = "UNLOCKED"
	if count >= ram_max then
		CBA_Options_RamLimit_Disable(player.id, ITEM_LOCKED)
		decision = "LOCKED"
	elseif remaining < 2 then
		-- Not enough room for weight-2 ram_tower; keep weight-1 rams unlocked
		CBA_Options_RamLimit_Disable(player.id, ITEM_UNLOCKED)
		CBA_Options_RamTowerOnly_Disable(player.id, ITEM_LOCKED)
		decision = "LOCKED_RAM_TOWER"
	else
		CBA_Options_RamLimit_Disable(player.id, ITEM_UNLOCKED)
	end
	-- Trim over-cap queued rams immediately; spawn-kill remains a safety fallback.
	local trimmed_ram = CBA_Options_RamLimit_TrimQueue(player, queued)
	if trimmed_ram > 0 then
		queued = math.max(0, queued - trimmed_ram)
		count = live + pending + queued
	end
	local should_log = CBA_Options_ShouldLogSiegeVerbose() or CBA_Options_ShouldLogSiegeStateChange(player, "ram_threshold", decision)
	if should_log then
		print(string.format(
			"[CBA_OPTIONS][RAM_THRESHOLD] P%d live=%d pending=%d queued=%d effective=%d/%d decision=%s",
			player.index or 0, live, pending, queued, count, ram_max, decision))
	end
end

-- Applies siege tower production lock/unlock based on total ST count (live + pending) vs SIEGE_TOWER_LIMIT_MAX.
-- Pending units represent field-built scaffolds still under construction.
function CBA_Options_SiegeTowerLimit_ApplyThreshold(player, opt_st_queued)
	if player == nil or player.id == nil then return end
	-- Respect the Siege Engineers gate — never unlock if SE not researched
	if not CBA_Options_HasSiegeEngineers(player) then
		CBA_Options_SiegeTowerLimit_Disable(player.id, ITEM_LOCKED)
		if CBA_Options_ShouldLogSiegeStateChange(player, "st_threshold", "LOCKED_NO_SE") then
			print(string.format("[CBA_OPTIONS][ST_THRESHOLD] P%d decision=LOCKED_NO_SE", player.index or 0))
		end
		return
	end
	local live = player.siegeTowerLimit_count or 0
	local pending = player.siegeTowerLimit_pending or 0
	local queued = opt_st_queued or CBA_Options_SiegeTowerLimit_GetQueuedCount(player)
	local count = live + pending + queued
	local st_max = CBA_Options_GetPlayerSiegeTowerLimit(player)
	local decision = "UNLOCKED"
	if count >= st_max then
		CBA_Options_SiegeTowerLimit_Disable(player.id, ITEM_LOCKED)
		decision = "LOCKED"
	else
		CBA_Options_SiegeTowerLimit_Disable(player.id, ITEM_UNLOCKED)
	end
	-- Trim over-cap queued siege towers immediately; spawn-kill remains a safety fallback.
	local trimmed_st = CBA_Options_SiegeTowerLimit_TrimQueue(player, queued)
	if trimmed_st > 0 then
		queued = math.max(0, queued - trimmed_st)
		count = live + pending + queued
	end
	local should_log = CBA_Options_ShouldLogSiegeVerbose() or CBA_Options_ShouldLogSiegeStateChange(player, "st_threshold", decision)
	if should_log then
		print(string.format(
			"[CBA_OPTIONS][ST_THRESHOLD] P%d live=%d pending=%d queued=%d effective=%d/%d decision=%s",
			player.index or 0, live, pending, queued, count, st_max, decision))
	end
end

function CBA_Options_GetRamLimitMax()
	return RAM_LIMIT_MAX
end

function CBA_Options_GetSiegeTowerLimitMax()
	return SIEGE_TOWER_LIMIT_MAX
end

---------------------------------------------------------------------------------------------------
-- Post-Enforcement Cap Violation Checker — logs if any cap exceeded after enforcement complete
---------------------------------------------------------------------------------------------------

function CBA_Options_ValidateEnforcement(player, context_label)
	if player == nil or _cba_debug == nil or not _cba_debug.enabled then return end

	local ram_queued, st_queued = _CBA_Options_GetAllQueuedCounts(player)

	local ram_live = player.ramLimit_count or 0
	local ram_pending = player.ramLimit_pending or 0
	local ram_total = ram_live + ram_pending + ram_queued
	local ram_max = CBA_Options_GetPlayerRamLimit(player)
	local ram_violated = (ram_live + ram_pending) > ram_max

	local st_live = player.siegeTowerLimit_count or 0
	local st_pending = player.siegeTowerLimit_pending or 0
	local st_total = st_live + st_pending + st_queued
	local st_max = CBA_Options_GetPlayerSiegeTowerLimit(player)
	local st_violated = (st_live + st_pending) > st_max

	local siege_violated = false
	local siege_live, siege_pending, siege_queued, siege_total, max_siege = 0, 0, 0, 0, 0
	if AGS_GLOBAL_SETTINGS.MaximumMedicPopulation ~= 0 then
		max_siege = CBA_Options_GetPlayerSiegeLimit(player)
		siege_live = player.siegeLimit_count or 0
		siege_pending = player.siegeLimit_pending or 0
		siege_queued = CBA_Options_SiegeLimit_GetQueuedPoints(player)
		siege_total = siege_live + siege_pending + siege_queued
		siege_violated = (siege_live + siege_pending) > max_siege
	end
	
	if ram_violated or st_violated or siege_violated then
		print(string.format(
			"[CBA_OPTIONS][CAP_VIOLATION] %s P%d RAM %d/%d (live=%d pend=%d q=%d) ST %d/%d (live=%d pend=%d q=%d) SIEGE %d/%d (live=%d pend=%d q=%d)",
			context_label or "UNKNOWN", player.index or 0,
			ram_total, ram_max, ram_live, ram_pending, ram_queued,
			st_total, st_max, st_live, st_pending, st_queued,
			siege_total, max_siege, siege_live, siege_pending, siege_queued))
	elseif ram_total > ram_max or st_total > st_max or siege_total > max_siege then
		print(string.format(
			"[CBA_OPTIONS][CAP_QUEUED] %s P%d RAM %d/%d ST %d/%d SIEGE %d/%d (queued overflow — no-cancel policy)",
			context_label or "UNKNOWN", player.index or 0,
			ram_total, ram_max, st_total, st_max, siege_total, max_siege))
	end
end

-- Hard spawn-cap enforcement for workshop completion races.
-- If a newly produced ram-class squad would push RAM total over cap,
-- kill the just-produced squad and refresh recount/threshold state immediately.
function CBA_Options_RamLimit_EnforceSpawnCap(player, spawned_squad)
	if player == nil or player.id == nil then return false end
	if spawned_squad == nil then return false end

	local player_civ = player.raceName or Player_GetRaceName(player.id)
	local is_ram_tower = CBA_Options_IsRamTowerSquad(spawned_squad, player_civ)
	local is_ram = is_ram_tower or
		Squad_IsOfType(spawned_squad, "ram") or
		Squad_IsOfType(spawned_squad, "scar_ram") or
		Squad_IsOfType(spawned_squad, "fire_ram") or
		Squad_IsOfType(spawned_squad, "scar_fire_ram")
	if not is_ram then return false end

	local before_live = player.ramLimit_count or 0
	local before_pending = player.ramLimit_pending or 0
	local before_ram_q, before_st_q, before_siege_q = _CBA_Options_GetAllQueuedCounts(player)
	local before_total = before_live + before_pending + before_ram_q
	local ram_max = CBA_Options_GetPlayerRamLimit(player)
	if before_total <= ram_max then return false end

	local spawn_weight = is_ram_tower and 2 or 1
	CBA_Options_SiegeLimit_RefundSquadCost(player, spawned_squad)
	local ok_kill = pcall(Squad_Kill, spawned_squad)
	if not ok_kill then return false end

	-- Keep siege and ram/st counters in sync immediately after corrective kill.
	CBA_Options_SiegeLimit_RecountAll(player)
	local post_ram_q, post_st_q, post_siege_q = _CBA_Options_GetAllQueuedCounts(player)
	CBA_Options_SiegeLimit_ApplyThreshold(player, post_siege_q)
	CBA_Options_RamLimit_ApplyThreshold(player, post_ram_q)
	CBA_Options_SiegeTowerLimit_ApplyThreshold(player, post_st_q)
	CBA_Options_FieldConstruct_Gate(player)

	if CBA_Options_ShouldLogSiegeStandard() then
		local after_live = player.ramLimit_count or 0
		local after_pending = player.ramLimit_pending or 0
		local after_total = after_live + after_pending + post_ram_q
		print(string.format(
			"[CBA_OPTIONS][SPAWN_ENFORCE_KILL] P%d ram_total=%d/%d spawned_weight=%d post_total=%d/%d",
			player.index or 0,
			before_total, ram_max,
			spawn_weight,
			after_total, ram_max))
	end

	return true
end

-- Hard spawn-cap enforcement for workshop-produced generic siege weapons.
-- If a newly produced siege weapon squad would push effective siege points over cap,
-- kill the just-produced squad and refresh recount/threshold state immediately.
function CBA_Options_SiegeLimit_EnforceSpawnCap(player, spawned_squad)
	if player == nil or player.id == nil then return false end
	if spawned_squad == nil then return false end
	if AGS_GLOBAL_SETTINGS.MaximumMedicPopulation == 0 then return false end

	local player_civ = player.raceName or Player_GetRaceName(player.id)
	local spawn_pts = CBA_Options_GetSiegeWeaponPointsSBP(nil, player_civ)
	-- Get points from the squad's SBP
	local ok_sbp, sbp = pcall(Squad_GetBlueprint, spawned_squad)
	if ok_sbp and sbp ~= nil then
		spawn_pts = CBA_Options_GetSiegeWeaponPointsSBP(sbp, player_civ)
	end
	if spawn_pts <= 0 then return false end

	local max_siege = CBA_Options_GetPlayerSiegeLimit(player)
	local before_live = player.siegeLimit_count or 0
	local before_pending = player.siegeLimit_pending or 0
	local before_ram_q, before_st_q, before_siege_q = _CBA_Options_GetAllQueuedCounts(player)
	local before_total = before_live + before_pending + before_siege_q
	if before_total <= max_siege then return false end

	CBA_Options_SiegeLimit_RefundSquadCost(player, spawned_squad)
	local ok_kill = pcall(Squad_Kill, spawned_squad)
	if not ok_kill then return false end

	CBA_Options_SiegeLimit_RecountAll(player)
	local post_ram_q, post_st_q, post_siege_q = _CBA_Options_GetAllQueuedCounts(player)
	CBA_Options_SiegeLimit_ApplyThreshold(player, post_siege_q)
	CBA_Options_RamLimit_ApplyThreshold(player, post_ram_q)
	CBA_Options_SiegeTowerLimit_ApplyThreshold(player, post_st_q)
	CBA_Options_FieldConstruct_Gate(player)

	if CBA_Options_ShouldLogSiegeStandard() then
		local after_live = player.siegeLimit_count or 0
		local after_pending = player.siegeLimit_pending or 0
		local after_total = after_live + after_pending + post_siege_q
		print(string.format(
			"[CBA_OPTIONS][SIEGE_SPAWN_ENFORCE_KILL] P%d siege_total=%d/%d spawned_pts=%d post_total=%d/%d",
			player.index or 0,
			before_total, max_siege,
			spawn_pts,
			after_total, max_siege))
	end

	return true
end

---------------------------------------------------------------------------------------------------
-- Resource Refund Helpers — refund cost when siege is killed by cap enforcement.
-- Refund happens BEFORE the kill call since entity/squad may be invalid after kill.
---------------------------------------------------------------------------------------------------

-- Refunds the full blueprint cost of a squad about to be killed by cap enforcement.
-- Returns true if refund was applied, false otherwise.
function CBA_Options_SiegeLimit_RefundSquadCost(player, squad)
	if player == nil or player.id == nil or squad == nil then return false end
	local ok_sbp, sbp = pcall(Squad_GetBlueprint, squad)
	if not ok_sbp or sbp == nil then return false end
	local ok_cost, cost = pcall(Player_GetSquadBPCost, player.id, sbp)
	if not ok_cost or cost == nil then return false end
	local food = cost.food or 0
	local wood = cost.wood or 0
	local gold = cost.gold or 0
	local stone = cost.stone or 0
	if food <= 0 and wood <= 0 and gold <= 0 and stone <= 0 then return false end
	if food > 0 then Player_AddResource(player.id, RT_Food, food) end
	if wood > 0 then Player_AddResource(player.id, RT_Wood, wood) end
	if gold > 0 then Player_AddResource(player.id, RT_Gold, gold) end
	if stone > 0 then Player_AddResource(player.id, RT_Stone, stone) end
	if CBA_Options_ShouldLogSiegeStandard() then
		print(string.format(
			"[CBA_OPTIONS][SIEGE_REFUND_SQUAD] P%d food=%.0f wood=%.0f gold=%.0f stone=%.0f",
			player.index or 0, food, wood, gold, stone))
	end
	return true
end

-- Refunds a proportional cost for an in-progress entity scaffold about to be killed by cap enforcement.
-- Scales refund by Entity_GetBuildingProgress (0.0 → full refund, 0.5 → 50% refund, etc.)
-- matching vanilla cancel-refund behavior (resources are consumed gradually during construction).
-- Returns true if refund was applied, false otherwise.
function CBA_Options_SiegeLimit_RefundEntityCost(player, entity)
	if player == nil or player.id == nil or entity == nil then return false end
	local ok_prog, progress = pcall(Entity_GetBuildingProgress, entity)
	if not ok_prog then return false end
	-- Refund the unspent portion: if 30% built, 70% of cost is refunded.
	local refund_fraction = 1.0 - (progress or 0)
	if refund_fraction <= 0 then return false end
	-- Resolve entity blueprint to matching squad blueprint for cost lookup.
	-- Field-built siege entities are EBPs; cost lookup requires the paired SBP.
	local ok_ebp, ebp = pcall(Entity_GetBlueprint, entity)
	if not ok_ebp or ebp == nil then return false end
	local ok_name, bp_name = pcall(BP_GetName, ebp)
	if not ok_name or bp_name == nil then return false end
	-- Try to find matching SBP by resolving the same siege key from the civ's siege table.
	-- The BP name typically matches or has a _buildable suffix.
	local player_civ = Player_GetRaceName(player.id)
	local sbp = nil
	-- Check the siege weapon BP maps for a name match
	local sbp_map, _ = CBA_Options_GetSiegeWeaponBPMaps(player_civ)
	if sbp_map ~= nil then
		-- Search for an SBP whose name matches the EBP name (or without _buildable suffix)
		local search_names = { bp_name, bp_name:gsub("_buildable$", "") }
		for _, sname in ipairs(search_names) do
			-- Try resolving via AGS_GetSiegeUnit which returns SBPs
			local ok_s, resolved = pcall(AGS_GetSiegeUnit, player_civ, sname)
			if ok_s and resolved ~= nil then
				sbp = resolved
				break
			end
		end
	end
	-- Fallback: try common siege entity keys from CBA_SIEGE_TABLE naming convention
	if sbp == nil then
		local base_name = bp_name:gsub("_buildable$", "")
		local ok_s, resolved = pcall(AGS_GetSiegeUnit, player_civ, base_name)
		if ok_s and resolved ~= nil then
			sbp = resolved
		end
	end
	if sbp == nil then return false end
	local ok_cost, cost = pcall(Player_GetSquadBPCost, player.id, sbp)
	if not ok_cost or cost == nil then return false end
	local food = math.floor((cost.food or 0) * refund_fraction)
	local wood = math.floor((cost.wood or 0) * refund_fraction)
	local gold = math.floor((cost.gold or 0) * refund_fraction)
	local stone = math.floor((cost.stone or 0) * refund_fraction)
	if food <= 0 and wood <= 0 and gold <= 0 and stone <= 0 then return false end
	if food > 0 then Player_AddResource(player.id, RT_Food, food) end
	if wood > 0 then Player_AddResource(player.id, RT_Wood, wood) end
	if gold > 0 then Player_AddResource(player.id, RT_Gold, gold) end
	if stone > 0 then Player_AddResource(player.id, RT_Stone, stone) end
	if CBA_Options_ShouldLogSiegeStandard() then
		print(string.format(
			"[CBA_OPTIONS][SIEGE_REFUND_ENTITY] P%d progress=%.0f%% refund_frac=%.0f%% food=%.0f wood=%.0f gold=%.0f stone=%.0f",
			player.index or 0, (progress or 0) * 100, refund_fraction * 100, food, wood, gold, stone))
	end
	return true
end

---------------------------------------------------------------------------------------------------
-- Siege Tower Scaffold Rollback + Spawn-Cap Enforcement
-- Parallel to the existing Ram and Generic Siege enforcement functions.
---------------------------------------------------------------------------------------------------

-- Kills excess in-progress siege tower scaffolds when count exceeds cap.
-- Iterates field-built entities (Entity_GetBuildingProgress < 1.0) in reverse order (newest first).
function CBA_Options_SiegeTowerLimit_RollbackExcessScaffolds(player, excess_count)
	if player == nil or player.id == nil then return 0, 0 end
	if excess_count == nil or excess_count <= 0 then return 0, 0 end

	local removed_count = 0
	local removed_scaffolds = 0
	local eg_all = Player_GetEntities(player.id)
	local eg_count = EGroup_CountSpawned(eg_all)

	for idx = eg_count, 1, -1 do
		if removed_count >= excess_count then
			break
		end
		local entity = EGroup_GetSpawnedEntityAt(eg_all, idx)
		if entity ~= nil and Entity_IsOfType(entity, "siege") and Entity_IsOfType(entity, "siege_tower") then
			if Entity_GetBuildingProgress(entity) < 1.0 then
				CBA_Options_SiegeLimit_RefundEntityCost(player, entity)
				local ok_kill = pcall(Entity_Kill, entity)
				if ok_kill then
					removed_count = removed_count + 1
					removed_scaffolds = removed_scaffolds + 1
				end
			end
		end
	end

	EGroup_Destroy(eg_all)
	return removed_count, removed_scaffolds
end

-- Hard spawn-cap enforcement for workshop-produced siege towers.
-- If a newly produced siege tower squad would push ST total over cap,
-- kill the just-produced squad and refresh recount/threshold state immediately.
function CBA_Options_SiegeTowerLimit_EnforceSpawnCap(player, spawned_squad)
	if player == nil or player.id == nil then return false end
	if spawned_squad == nil then return false end

	if not (Squad_IsOfType(spawned_squad, "siege") and Squad_IsOfType(spawned_squad, "siege_tower")) then
		return false
	end

	local before_live = player.siegeTowerLimit_count or 0
	local before_pending = player.siegeTowerLimit_pending or 0
	local before_ram_q, before_st_q, before_siege_q = _CBA_Options_GetAllQueuedCounts(player)
	local before_total = before_live + before_pending + before_st_q
	local st_max = CBA_Options_GetPlayerSiegeTowerLimit(player)
	if before_total <= st_max then return false end

	CBA_Options_SiegeLimit_RefundSquadCost(player, spawned_squad)
	local ok_kill = pcall(Squad_Kill, spawned_squad)
	if not ok_kill then return false end

	CBA_Options_SiegeLimit_RecountAll(player)
	local post_ram_q, post_st_q, post_siege_q = _CBA_Options_GetAllQueuedCounts(player)
	CBA_Options_SiegeLimit_ApplyThreshold(player, post_siege_q)
	CBA_Options_RamLimit_ApplyThreshold(player, post_ram_q)
	CBA_Options_SiegeTowerLimit_ApplyThreshold(player, post_st_q)
	CBA_Options_FieldConstruct_Gate(player)

	if CBA_Options_ShouldLogSiegeStandard() then
		local after_live = player.siegeTowerLimit_count or 0
		local after_pending = player.siegeTowerLimit_pending or 0
		local after_total = after_live + after_pending + post_st_q
		print(string.format(
			"[CBA_OPTIONS][ST_SPAWN_ENFORCE_KILL] P%d st_total=%d/%d post_total=%d/%d",
			player.index or 0,
			before_total, st_max,
			after_total, st_max))
	end

	return true
end

-- Kills excess in-progress generic siege scaffolds when effective points exceed cap.
-- Iterates field-built entities (Entity_GetBuildingProgress < 1.0) in reverse order (newest first).
function CBA_Options_SiegeLimit_RollbackExcessScaffolds(player, excess_pts)
	if player == nil or player.id == nil then return 0, 0 end
	if excess_pts == nil or excess_pts <= 0 then return 0, 0 end

	local removed_pts = 0
	local removed_scaffolds = 0
	local player_civ = Player_GetRaceName(player.id)
	local eg_all = Player_GetEntities(player.id)
	local eg_count = EGroup_CountSpawned(eg_all)

	for idx = eg_count, 1, -1 do
		if removed_pts >= excess_pts then
			break
		end
		local entity = EGroup_GetSpawnedEntityAt(eg_all, idx)
		if entity ~= nil then
			local pts = CBA_Options_GetSiegeWeaponPointsEntity(entity, player_civ)
			if pts > 0 and Entity_GetBuildingProgress(entity) < 1.0 then
				CBA_Options_SiegeLimit_RefundEntityCost(player, entity)
				local ok_kill = pcall(Entity_Kill, entity)
				if ok_kill then
					removed_pts = removed_pts + pts
					removed_scaffolds = removed_scaffolds + 1
				end
			end
		end
	end

	EGroup_Destroy(eg_all)
	return removed_pts, removed_scaffolds
end

-- Ram tower classification helper with blueprint fallback.
-- Some civ variants resolve ram_tower blueprints that do not expose the "ram_tower"
-- type tag consistently at runtime; in that case we compare blueprint identity.
function CBA_Options_IsRamTowerSBP(sbp, player_civ)
	if sbp == nil then return false end
	if Squad_IsSBPOfType(sbp, "ram_tower") then return true end
	if player_civ ~= nil then
		local rt_sbp = AGS_GetSiegeUnit(player_civ, "ram_tower")
		if rt_sbp ~= nil then
			local ok1, n1 = pcall(BP_GetName, sbp)
			local ok2, n2 = pcall(BP_GetName, rt_sbp)
			if ok1 and ok2 and n1 == n2 then return true end
		end
	end
	return false
end

function CBA_Options_IsRamTowerSquad(squad, player_civ)
	if squad == nil then return false end
	if Squad_IsOfType(squad, "ram_tower") then return true end
	local ok, sbp = pcall(Squad_GetBlueprint, squad)
	if ok and sbp ~= nil then
		return CBA_Options_IsRamTowerSBP(sbp, player_civ)
	end
	local ok_tag, has_tag = pcall(Squad_IsOfType, squad, "ram_tower")
	if ok_tag and has_tag then return true end
	return false
end

function CBA_Options_IsRamTowerEBP(ebp, player_civ)
	if ebp == nil then return false end
	if Entity_IsEBPOfType(ebp, "ram_tower") then return true end
	if player_civ ~= nil then
		local rt_ebp = AGS_GetSiegeEntity(player_civ, "ram_tower")
		if rt_ebp ~= nil then
			local ok1, n1 = pcall(BP_GetName, ebp)
			local ok2, n2 = pcall(BP_GetName, rt_ebp)
			if ok1 and ok2 and n1 == n2 then return true end
		end
	end
	return false
end

function CBA_Options_IsRamTowerEntity(entity, player_civ)
	if entity == nil then return false end
	if Entity_IsOfType(entity, "ram_tower") then return true end
	local ok, ebp = pcall(Entity_GetBlueprint, entity)
	if ok and ebp ~= nil then
		return CBA_Options_IsRamTowerEBP(ebp, player_civ)
	end
	local ok_tag, has_tag = pcall(Entity_IsOfType, entity, "ram_tower")
	if ok_tag and has_tag then return true end
	return false
end

-- Cached blueprint name-keyed maps for siege weapon point classification.
-- Some civ variants/buildable EBPs do not expose the scar_* type tags consistently,
-- so we resolve known CBA_SIEGE_TABLE keys to BP_GetName strings and classify by name.
-- (Using BP_GetName strings instead of raw handles avoids userdata identity mismatches.)
_CBA_SiegeWeaponBPMapCache = _CBA_SiegeWeaponBPMapCache or {}

function CBA_Options_GetSiegeWeaponBPMaps(player_civ)
	local civ_key = player_civ or "__nil__"
	local cached = _CBA_SiegeWeaponBPMapCache[civ_key]
	if cached ~= nil then
		return cached.sbp, cached.ebp
	end

	local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ
	local sbp_map = {}
	local ebp_map = {}

	local function add_named_bp(bp_name, pts)
		if bp_name == nil then return end
		sbp_map[bp_name] = pts
		ebp_map[bp_name] = pts
	end

	local function add_bp(key, default_pts, opt_ottoman_pts)
		if player_civ == nil then return end
		local pts = default_pts
		if branch_civ == "ottoman" and opt_ottoman_pts ~= nil then
			pts = opt_ottoman_pts
		end
		local ok_sbp, sbp = pcall(AGS_GetSiegeUnit, player_civ, key)
		if ok_sbp and sbp ~= nil then
			local ok_n, name = pcall(BP_GetName, sbp)
			if ok_n and name ~= nil then
				sbp_map[name] = pts
			end
		end
		local ok_ebp, ebp = pcall(AGS_GetSiegeEntity, player_civ, key)
		if ok_ebp and ebp ~= nil then
			local ok_n, name = pcall(BP_GetName, ebp)
			if ok_n and name ~= nil then
				ebp_map[name] = pts
			end
		end
	end

	-- 1-point class
	add_bp("springald", 1)
	add_bp("springald_buildable", 1)
	add_bp("springald_clocktower_chi", 1)
	-- Sultanate (Tughlaq) Ballista Elephant behaves like springald for siege cap.
	if player_civ == "sultanate_ha_tug" then
		add_named_bp("unit_war_elephant_ballista_3_sul_ha_tug", 1)
		add_named_bp("unit_war_elephant_ballista_4_sul_ha_tug", 1)
	end

	-- 2-point class
	add_bp("trebuchet_tr", 2)
	add_bp("trebuchet_tr_buildable", 2)
	add_bp("culverin", 2)
	add_bp("royal_culverin", 2)

	-- 3-point class
	add_bp("mangonel", 3)
	add_bp("mangonel_buildable", 3)
	add_bp("trebuchet_cw", 3)
	add_bp("trebuchet_cw_buildable", 3)
	add_bp("cannon", 3)
	add_bp("bombard", 3, 4)
	add_bp("nest_of_bees", 3)
	add_bp("ribauldequin", 3)
	add_bp("royal_cannon", 3)
	add_bp("royal_ribauldequin", 3)
	add_bp("mangonel_clocktower_chi", 3)
	add_bp("trebuchet_clocktower_chi", 3)
	add_bp("nestofbees_clocktower_chi", 3)
	add_bp("bombard_clocktower_chi", 3)

	-- Mongol doubles (Khaganate Palace)
	add_bp("springald_double", 1)
	add_bp("culverin_double", 2)
	add_bp("trebuchet_tr_double", 2)
	add_bp("mangonel_double", 3)
	add_bp("trebuchet_cw_double", 3)
	add_bp("cannon_double", 3)
	add_bp("bombard_double", 3)
	add_bp("ribauldequin_double", 3)

	_CBA_SiegeWeaponBPMapCache[civ_key] = {
		sbp = sbp_map,
		ebp = ebp_map,
	}
	return sbp_map, ebp_map
end

-- Fast check: is this EBP a known siege weapon in the BP name map?
function CBA_Options_IsSiegeWeaponBPMatch_EBP(ebp, player_civ)
	if ebp == nil then return false end
	local _, ebp_map = CBA_Options_GetSiegeWeaponBPMaps(player_civ)
	local ok, name = pcall(BP_GetName, ebp)
	if not ok or name == nil then return false end
	return ebp_map[name] ~= nil
end

-- Fast check: is this SBP a known siege weapon in the BP name map?
function CBA_Options_IsSiegeWeaponBPMatch_SBP(sbp, player_civ)
	if sbp == nil then return false end
	local sbp_map, _ = CBA_Options_GetSiegeWeaponBPMaps(player_civ)
	local ok, name = pcall(BP_GetName, sbp)
	if not ok or name == nil then return false end
	return sbp_map[name] ~= nil
end

---------------------------------------------------------------------------------------------------
-- Generic Siege Weapon Point Classifiers
-- Returns the siege-point weight (1/2/3/4) for a siege weapon, or 0 if not a generic siege weapon.
-- Excludes rams, ram towers, and siege towers (tracked by independent limits).
---------------------------------------------------------------------------------------------------

function CBA_Options_GetSiegeWeaponPointsSBP(sbp, player_civ)
	if sbp == nil then return 0 end
	-- Exclude ram-class and siege tower (independent limits)
	if Squad_IsSBPOfType(sbp, "ram") or Squad_IsSBPOfType(sbp, "scar_ram")
		or Squad_IsSBPOfType(sbp, "fire_ram") or Squad_IsSBPOfType(sbp, "scar_fire_ram")
		or Squad_IsSBPOfType(sbp, "ram_tower") or CBA_Options_IsRamTowerSBP(sbp, player_civ) then
		return 0
	end
	if Squad_IsSBPOfType(sbp, "siege_tower") then return 0 end

	-- Blueprint name-keyed fallback (covers buildable/special variants with weak type tags)
	local sbp_map, _ = CBA_Options_GetSiegeWeaponBPMaps(player_civ)
	local ok_n, bp_name = pcall(BP_GetName, sbp)
	if ok_n and bp_name ~= nil then
		local mapped_pts = sbp_map[bp_name]
		if mapped_pts ~= nil then return mapped_pts end
	end

	if not Squad_IsSBPOfType(sbp, "siege") then return 0 end
	-- Ottoman great bombard: 4 points
	local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ
	if branch_civ == "ottoman" and (Squad_IsSBPOfType(sbp, "great_bombard") or Squad_IsSBPOfType(sbp, "bombard") or Squad_IsSBPOfType(sbp, "scar_bombard")) then
		return 4
	end
	-- 1-point: Springald
	if Squad_IsSBPOfType(sbp, "scar_springald") then return 1 end
	-- 2-point: Trebuchet TR, Culverin
	if Squad_IsSBPOfType(sbp, "scar_trebuchet_traction") or Squad_IsSBPOfType(sbp, "scar_culverin") then return 2 end
	-- 3-point: Mangonel, Trebuchet CW, Cannon, Bombard, Nest of Bees, Ribauldequin
	if Squad_IsSBPOfType(sbp, "scar_mangonel") or Squad_IsSBPOfType(sbp, "scar_trebuchet_cw") or Squad_IsSBPOfType(sbp, "scar_cannon") or
		Squad_IsSBPOfType(sbp, "scar_bombard") or Squad_IsSBPOfType(sbp, "nest_of_bees") or Squad_IsSBPOfType(sbp, "scar_ribauldequin") then
		return 3
	end
	return 0
end

function CBA_Options_GetSiegeWeaponPointsEBP(ebp, player_civ)
	if ebp == nil then return 0 end
	-- Exclude ram-class and siege tower (independent limits)
	if Entity_IsEBPOfType(ebp, "ram") or Entity_IsEBPOfType(ebp, "scar_ram")
		or Entity_IsEBPOfType(ebp, "fire_ram") or Entity_IsEBPOfType(ebp, "scar_fire_ram")
		or Entity_IsEBPOfType(ebp, "ram_tower") or CBA_Options_IsRamTowerEBP(ebp, player_civ) then
		return 0
	end
	if Entity_IsEBPOfType(ebp, "siege_tower") then return 0 end

	-- Blueprint name-keyed fallback (covers buildable/special variants with weak type tags)
	local _, ebp_map = CBA_Options_GetSiegeWeaponBPMaps(player_civ)
	local ok_n, bp_name = pcall(BP_GetName, ebp)
	if ok_n and bp_name ~= nil then
		local mapped_pts = ebp_map[bp_name]
		if mapped_pts ~= nil then return mapped_pts end
	end

	if not Entity_IsEBPOfType(ebp, "siege") then return 0 end
	local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ
	if branch_civ == "ottoman" and (Entity_IsEBPOfType(ebp, "great_bombard") or Entity_IsEBPOfType(ebp, "bombard") or Entity_IsEBPOfType(ebp, "scar_bombard")) then
		return 4
	end
	if Entity_IsEBPOfType(ebp, "scar_springald") then return 1 end
	if Entity_IsEBPOfType(ebp, "scar_trebuchet_traction") or Entity_IsEBPOfType(ebp, "scar_culverin") then return 2 end
	if Entity_IsEBPOfType(ebp, "scar_mangonel") or Entity_IsEBPOfType(ebp, "scar_trebuchet_cw") or Entity_IsEBPOfType(ebp, "scar_cannon") or
		Entity_IsEBPOfType(ebp, "scar_bombard") or Entity_IsEBPOfType(ebp, "nest_of_bees") or Entity_IsEBPOfType(ebp, "scar_ribauldequin") then
		return 3
	end
	return 0
end

function CBA_Options_GetSiegeWeaponPointsEntity(entity, player_civ)
	if entity == nil then return 0 end
	-- Exclude ram-class and siege tower (independent limits)
	if CBA_Options_IsRamTowerEntity(entity, player_civ) then return 0 end
	if Entity_IsOfType(entity, "ram") or Entity_IsOfType(entity, "scar_ram")
		or Entity_IsOfType(entity, "fire_ram") or Entity_IsOfType(entity, "scar_fire_ram") then
		return 0
	end
	if Entity_IsOfType(entity, "siege_tower") then return 0 end

	-- Blueprint name-keyed fallback (covers buildable/special variants with weak type tags)
	local ok_bp, ebp = pcall(Entity_GetBlueprint, entity)
	if ok_bp and ebp ~= nil then
		local ok_n, bp_name = pcall(BP_GetName, ebp)
		if ok_n and bp_name ~= nil then
			local _, ebp_map = CBA_Options_GetSiegeWeaponBPMaps(player_civ)
			local mapped_pts = ebp_map[bp_name]
			if mapped_pts ~= nil then return mapped_pts end
		end
	end

	if not Entity_IsOfType(entity, "siege") then return 0 end
	local branch_civ = AGS_CIV_FACTION_MAP[player_civ] or player_civ
	if branch_civ == "ottoman" and (Entity_IsOfType(entity, "great_bombard") or Entity_IsOfType(entity, "bombard") or Entity_IsOfType(entity, "scar_bombard")) then
		return 4
	end
	if Entity_IsOfType(entity, "scar_springald") then return 1 end
	if Entity_IsOfType(entity, "scar_trebuchet_traction") or Entity_IsOfType(entity, "scar_culverin") then return 2 end
	if Entity_IsOfType(entity, "scar_mangonel") or Entity_IsOfType(entity, "scar_trebuchet_cw") or Entity_IsOfType(entity, "scar_cannon") or
		Entity_IsOfType(entity, "scar_bombard") or Entity_IsOfType(entity, "nest_of_bees") or Entity_IsOfType(entity, "scar_ribauldequin") then
		return 3
	end
	return 0
end

function CBA_Options_GetRamWeight(squad, player_civ)
	if CBA_Options_IsRamTowerSquad(squad, player_civ) then
		return 2
	end
	return 1
end

function CBA_Options_GetRamWeightSBP(sbp, player_civ)
	if CBA_Options_IsRamTowerSBP(sbp, player_civ) then
		return 2
	end
	return 1
end

function CBA_Options_GetRamWeightEntity(entity, player_civ)
	if CBA_Options_IsRamTowerEntity(entity, player_civ) then
		return 2
	end
	return 1
end

function CBA_Options_RamLimit_RollbackExcessScaffolds(player, excess_weight)
	if player == nil or player.id == nil then return 0, 0 end
	if excess_weight == nil or excess_weight <= 0 then return 0, 0 end

	local removed_weight = 0
	local removed_scaffolds = 0
	local player_civ = Player_GetRaceName(player.id)
	local eg_all = Player_GetEntities(player.id)
	local eg_count = EGroup_CountSpawned(eg_all)

	for idx = eg_count, 1, -1 do
		if removed_weight >= excess_weight then
			break
		end
		local entity = EGroup_GetSpawnedEntityAt(eg_all, idx)
		if entity ~= nil then
			local is_ram_tower = CBA_Options_IsRamTowerEntity(entity, player_civ)
			local is_ram_type = is_ram_tower or
				(Entity_IsOfType(entity, "ram") or Entity_IsOfType(entity, "scar_ram") or Entity_IsOfType(entity, "fire_ram") or Entity_IsOfType(entity, "scar_fire_ram"))
			if is_ram_type then
				local weight = is_ram_tower and 2 or 1
				CBA_Options_SiegeLimit_RefundEntityCost(player, entity)
				local ok_kill = pcall(Entity_Kill, entity)
				if ok_kill then
					removed_weight = removed_weight + weight
					removed_scaffolds = removed_scaffolds + 1
				end
			end
		end
	end

	EGroup_Destroy(eg_all)
	return removed_weight, removed_scaffolds
end

-- Recounts a player's live ram squads (including ram_tower as 2) + field-built ram entities.
function CBA_Options_RamLimit_Recount(player)
	if player == nil or player.id == nil then return 0 end
	local old_total = player.ramLimit_count or 0
	local old_pending = player.ramLimit_pending or 0
	local total = 0
	local player_civ = Player_GetRaceName(player.id)
	
	-- Count workshop-produced squads
	local sg_all = Player_GetSquads(player.id)
	local count = SGroup_Count(sg_all)
	local ram_squads = 0
	local ram_tower_squads = 0
	for idx = 1, count do
		local squad = SGroup_GetSquadAt(sg_all, idx)
		if squad ~= nil then
			local is_ram_tower = CBA_Options_IsRamTowerSquad(squad, player_civ)
			if is_ram_tower then
				total = total + 2
				ram_tower_squads = ram_tower_squads + 1
			elseif Squad_IsOfType(squad, "ram") or Squad_IsOfType(squad, "scar_ram") or Squad_IsOfType(squad, "fire_ram") or Squad_IsOfType(squad, "scar_fire_ram") then
				total = total + 1
				ram_squads = ram_squads + 1
			end
		end
	end
	SGroup_Destroy(sg_all)
	
	-- Scan field-built ram entities: scaffolds → pending, completed entities → total.
	-- Completed field-built rams may briefly exist as entities before squad conversion.
	local eg_all = Player_GetEntities(player.id)
	local eg_count = EGroup_CountSpawned(eg_all)
	local active_ram_scaffolds = 0
	local completed_ents = 0
	for idx = 1, eg_count do
		local entity = EGroup_GetSpawnedEntityAt(eg_all, idx)
		if entity ~= nil then
			local is_ram_tower = CBA_Options_IsRamTowerEntity(entity, player_civ)
			local is_ram_type = is_ram_tower or
				(Entity_IsOfType(entity, "ram") or Entity_IsOfType(entity, "scar_ram") or Entity_IsOfType(entity, "fire_ram") or Entity_IsOfType(entity, "scar_fire_ram"))
			if is_ram_type then
				local weight = is_ram_tower and 2 or 1
				if Entity_GetBuildingProgress(entity) < 1.0 then
					active_ram_scaffolds = active_ram_scaffolds + weight
				else
					-- Completed field entity not yet converted to squad
					total = total + weight
					completed_ents = completed_ents + 1
				end
			end
		end
	end
	EGroup_Destroy(eg_all)
	
	player.ramLimit_count = total
	-- Self-correct stale pending: clamp to actual scaffold count
	player.ramLimit_pending = active_ram_scaffolds
	if CBA_Options_ShouldLogSiegeVerbose() then
		print(string.format(
			"[CBA_OPTIONS][RAM_RECOUNT] P%d squads_scanned=%d ram_squads=%d ram_tower_squads=%d ents_scanned=%d scaffolds=%d completed_ents=%d total=%d->%d pending=%d->%d",
			player.index or 0, count, ram_squads, ram_tower_squads,
			eg_count, active_ram_scaffolds, completed_ents,
			old_total, total, old_pending, active_ram_scaffolds))
	end
	return total
end

-- Recounts a player's live siege tower squads + field-built siege tower entities.
function CBA_Options_SiegeTowerLimit_Recount(player)
	if player == nil or player.id == nil then return 0 end
	local old_total = player.siegeTowerLimit_count or 0
	local old_pending = player.siegeTowerLimit_pending or 0
	local total = 0
	
	-- Count live siege tower squads (workshop-produced and completed field-built).
	-- Do NOT use Entity_GetBuildingProgress here: workshop-produced siege towers are
	-- mobile units, so Entity_GetBuildingProgress returns 0.0 (not-a-building), which
	-- would silently exclude them. Scaffolds are standalone entities tracked in the
	-- entity scan below, not in Player_GetSquads.
	local sg_all = Player_GetSquads(player.id)
	local count = SGroup_Count(sg_all)
	local st_squads = 0
	for idx = 1, count do
		local squad = SGroup_GetSquadAt(sg_all, idx)
		if squad ~= nil and Squad_IsOfType(squad, "siege") and Squad_IsOfType(squad, "siege_tower") then
			total = total + 1
			st_squads = st_squads + 1
		end
	end
	SGroup_Destroy(sg_all)
	
	-- Scan field-built siege tower entities: scaffolds → pending, completed entities → total.
	-- Completed field-built siege towers may briefly exist as entities before squad conversion.
	local eg_all = Player_GetEntities(player.id)
	local eg_count = EGroup_CountSpawned(eg_all)
	local active_st_scaffolds = 0
	local completed_ents = 0
	for idx = 1, eg_count do
		local entity = EGroup_GetSpawnedEntityAt(eg_all, idx)
		if entity ~= nil and Entity_IsOfType(entity, "siege") and Entity_IsOfType(entity, "siege_tower") then
			if Entity_GetBuildingProgress(entity) < 1.0 then
				active_st_scaffolds = active_st_scaffolds + 1
			else
				-- Completed field entity not yet converted to squad
				total = total + 1
				completed_ents = completed_ents + 1
			end
		end
	end
	EGroup_Destroy(eg_all)
	
	player.siegeTowerLimit_count = total
	-- Self-correct stale pending: clamp to actual scaffold count
	player.siegeTowerLimit_pending = active_st_scaffolds
	if CBA_Options_ShouldLogSiegeVerbose() then
		print(string.format(
			"[CBA_OPTIONS][ST_RECOUNT] P%d squads_scanned=%d st_squads=%d ents_scanned=%d scaffolds=%d completed_ents=%d total=%d->%d pending=%d->%d",
			player.index or 0, count, st_squads,
			eg_count, active_st_scaffolds, completed_ents,
			old_total, total, old_pending, active_st_scaffolds))
	end
	return total
end

local function _CBA_Options_ForEachQueueSpawnItem(player, callback)
	if player == nil or player.id == nil or callback == nil then return end
	_CBA_PERF.queue_scans = _CBA_PERF.queue_scans + 1
	_CBA_PERF.eg_allocs = _CBA_PERF.eg_allocs + 1
	local eg_all = Player_GetEntities(player.id)
	local eg_count = EGroup_CountSpawned(eg_all)
	for idx = 1, eg_count do
		local entity = EGroup_GetSpawnedEntityAt(eg_all, idx)
		if entity ~= nil and Entity_HasProductionQueue(entity) then
			local queue_count = Entity_GetProductionQueueSize(entity)
			for qidx = 1, queue_count do
				local queue_pos = queue_count - qidx
				local item_type = Entity_GetProductionQueueItemType(entity, queue_pos)
				if item_type == PITEM_Spawn then
					local sbp = Entity_GetProductionQueueItem(entity, queue_pos)
					callback(entity, queue_pos, sbp)
				end
			end
		end
	end
	EGroup_Destroy(eg_all)
end

-- Combined queue scan: counts ram, siege tower, and generic siege queued items in a single entity pass.
function _CBA_Options_GetAllQueuedCounts(player)
	if player == nil or player.id == nil then return 0, 0, 0 end
	local player_civ = Player_GetRaceName(player.id)
	local ram_total = 0
	local st_total = 0
	local siege_total = 0
	_CBA_Options_ForEachQueueSpawnItem(player, function(_entity, _queue_pos, sbp)
		if sbp == nil then return end
		if CBA_Options_IsRamTowerSBP(sbp, player_civ) then
			ram_total = ram_total + 2
		elseif Squad_IsSBPOfType(sbp, "ram") or Squad_IsSBPOfType(sbp, "scar_ram") or Squad_IsSBPOfType(sbp, "fire_ram") or Squad_IsSBPOfType(sbp, "scar_fire_ram") then
			ram_total = ram_total + 1
		elseif Squad_IsSBPOfType(sbp, "siege_tower") then
			st_total = st_total + 1
		else
			local pts = CBA_Options_GetSiegeWeaponPointsSBP(sbp, player_civ)
			siege_total = siege_total + pts
		end
	end)
	return ram_total, st_total, siege_total
end

function CBA_Options_RamLimit_GetQueuedCount(player)
	if player == nil or player.id == nil then return 0 end
	local total = 0
	local player_civ = Player_GetRaceName(player.id)
	_CBA_Options_ForEachQueueSpawnItem(player, function(_entity, _queue_pos, sbp)
		if sbp == nil then return end
		if CBA_Options_IsRamTowerSBP(sbp, player_civ) then
			total = total + 2
		elseif Squad_IsSBPOfType(sbp, "ram") or Squad_IsSBPOfType(sbp, "scar_ram") or Squad_IsSBPOfType(sbp, "fire_ram") or Squad_IsSBPOfType(sbp, "scar_fire_ram") then
			total = total + 1
		end
	end)
	return total
end

function CBA_Options_SiegeTowerLimit_GetQueuedCount(player)
	if player == nil or player.id == nil then return 0 end
	local total = 0
	_CBA_Options_ForEachQueueSpawnItem(player, function(_entity, _queue_pos, sbp)
		if sbp ~= nil and Squad_IsSBPOfType(sbp, "siege_tower") then
			total = total + 1
		end
	end)
	return total
end

function CBA_Options_RamLimit_TrimQueue(player, opt_ram_queued)
	if player == nil or player.id == nil then return 0 end
	local live = player.ramLimit_count or 0
	local pending = player.ramLimit_pending or 0
	local queued = opt_ram_queued or CBA_Options_RamLimit_GetQueuedCount(player)
	local ram_max = CBA_Options_GetPlayerRamLimit(player)
	local over = math.max(0, (live + pending + queued) - ram_max)
	if over <= 0 then return 0 end

	local player_civ = Player_GetRaceName(player.id)
	local removed = 0
	_CBA_Options_ForEachQueueSpawnItem(player, function(entity, queue_pos, sbp)
		if removed >= over or sbp == nil then return end
		local is_rt = CBA_Options_IsRamTowerSBP(sbp, player_civ)
		local is_ram = is_rt
			or Squad_IsSBPOfType(sbp, "ram")
			or Squad_IsSBPOfType(sbp, "scar_ram")
			or Squad_IsSBPOfType(sbp, "fire_ram")
			or Squad_IsSBPOfType(sbp, "scar_fire_ram")
		if not is_ram then return end
		local weight = is_rt and 2 or 1
		if pcall(Entity_CancelProductionQueueItem, entity, queue_pos) then
			removed = removed + weight
		end
	end)

	if removed > 0 and CBA_Options_ShouldLogSiegeStandard() then
		print(string.format("[CBA_OPTIONS][RAM_TRIM] P%d removed=%d over=%d", player.index or 0, removed, over))
	end
	return removed
end

function CBA_Options_SiegeTowerLimit_TrimQueue(player, opt_st_queued)
	if player == nil or player.id == nil then return 0 end
	local live = player.siegeTowerLimit_count or 0
	local pending = player.siegeTowerLimit_pending or 0
	local queued = opt_st_queued or CBA_Options_SiegeTowerLimit_GetQueuedCount(player)
	local st_max = CBA_Options_GetPlayerSiegeTowerLimit(player)
	local over = math.max(0, (live + pending + queued) - st_max)
	if over <= 0 then return 0 end

	local removed = 0
	_CBA_Options_ForEachQueueSpawnItem(player, function(entity, queue_pos, sbp)
		if removed >= over or sbp == nil then return end
		if not Squad_IsSBPOfType(sbp, "siege_tower") then return end
		if pcall(Entity_CancelProductionQueueItem, entity, queue_pos) then
			removed = removed + 1
		end
	end)

	if removed > 0 and CBA_Options_ShouldLogSiegeStandard() then
		print(string.format("[CBA_OPTIONS][ST_TRIM] P%d removed=%d over=%d", player.index or 0, removed, over))
	end
	return removed
end

-- Counts weighted siege points for generic siege weapons (non-ram, non-tower) in production queues.
function CBA_Options_SiegeLimit_GetQueuedPoints(player)
	if player == nil or player.id == nil then return 0 end
	local total = 0
	local player_civ = Player_GetRaceName(player.id)
	_CBA_Options_ForEachQueueSpawnItem(player, function(_entity, _queue_pos, sbp)
		if sbp == nil then return end
		local pts = CBA_Options_GetSiegeWeaponPointsSBP(sbp, player_civ)
		total = total + pts
	end)
	return total
end

function CBA_Options_SiegeLimit_TrimQueue(player, opt_siege_queued)
	if player == nil or player.id == nil then return 0 end
	local live = player.siegeLimit_count or 0
	local pending = player.siegeLimit_pending or 0
	local queued = opt_siege_queued or CBA_Options_SiegeLimit_GetQueuedPoints(player)
	local siege_max = CBA_Options_GetPlayerSiegeLimit(player)
	local over = math.max(0, (live + pending + queued) - siege_max)
	if over <= 0 then return 0 end

	local player_civ = Player_GetRaceName(player.id)
	local removed = 0
	_CBA_Options_ForEachQueueSpawnItem(player, function(entity, queue_pos, sbp)
		if removed >= over or sbp == nil then return end
		if CBA_Options_IsRamTowerSBP(sbp, player_civ)
			or Squad_IsSBPOfType(sbp, "ram")
			or Squad_IsSBPOfType(sbp, "scar_ram")
			or Squad_IsSBPOfType(sbp, "fire_ram")
			or Squad_IsSBPOfType(sbp, "scar_fire_ram")
			or Squad_IsSBPOfType(sbp, "siege_tower") then
			return
		end
		local pts = CBA_Options_GetSiegeWeaponPointsSBP(sbp, player_civ)
		if pts <= 0 then return end
		if pcall(Entity_CancelProductionQueueItem, entity, queue_pos) then
			removed = removed + pts
		end
	end)

	if removed > 0 and CBA_Options_ShouldLogSiegeStandard() then
		print(string.format("[CBA_OPTIONS][SIEGE_TRIM] P%d removed=%d over=%d", player.index or 0, removed, over))
	end
	return removed
end

-- Aggregates live + queued + pending counts for all siege limit subsystems.
function CBA_Options_SiegeLimit_GetGateTotals(player)
	if player == nil then
		return {
			ram_total = 0, ram_cap = RAM_LIMIT_MAX,
			st_total = 0, st_cap = SIEGE_TOWER_LIMIT_MAX,
			siege_total = 0, siege_cap = AGS_GLOBAL_SETTINGS.MaximumMedicPopulation or 0,
		}
	end
	local ram_live = player.ramLimit_count or 0
	local st_live = player.siegeTowerLimit_count or 0
	local ram_queued, st_queued = _CBA_Options_GetAllQueuedCounts(player)
	local ram_pending = player.ramLimit_pending or 0
	local st_pending = player.siegeTowerLimit_pending or 0
	local siege_live = player.siegeLimit_count or 0
	local siege_queued = CBA_Options_SiegeLimit_GetQueuedPoints(player)
	local siege_pending = player.siegeLimit_pending or 0
	return {
		ram_total = ram_live + ram_queued + ram_pending,
		ram_cap = CBA_Options_GetPlayerRamLimit(player),
		st_total = st_live + st_queued + st_pending,
		st_cap = CBA_Options_GetPlayerSiegeTowerLimit(player),
		siege_total = siege_live + siege_queued + siege_pending,
		siege_cap = CBA_Options_GetPlayerSiegeLimit(player),
	}
end

-----------------------------------------------------------------------
-- Debug Console Commands — Siege Limit Performance
-----------------------------------------------------------------------

function Debug_SiegePerfReset()
	_CBA_PERF = { sg_allocs = 0, eg_allocs = 0, recount_calls = 0, queue_scans = 0, disable_skipped = 0, reconcile_ticks = 0, last_reset_tick = World_GetGameTicks(),
		ge_entity_killed_siege = 0, ge_squad_killed_siege = 0, siege_cache_hits = 0, siege_cache_misses = 0,
		batch_sq_processed = 0, batch_sq_ticks = 0,
		batch_ek_processed = 0, batch_ek_ticks = 0,
		batch_bld_decremented = 0, batch_bld_skipped_player_nil = 0, batch_bld_skipped_cancelled = 0,
		bld_reconcile_ticks = 0, bld_reconcile_drift = 0 }
	_CBA_SIEGE_SBP_CACHE = {}
	_CBA_SIEGE_EBP_CACHE = {}
	_CBA_SQUAD_KILL_BATCH.queue = {}
	_CBA_SQUAD_KILL_BATCH.dirty = false
	_CBA_ENTITY_KILL_BATCH.queue = {}
	_CBA_ENTITY_KILL_BATCH.dirty = false
	print("[DEBUG] _CBA_PERF counters + siege cache + batch queues reset at tick " .. tostring(World_GetGameTicks()))
end

function Debug_SiegePerfReport()
	local p = _CBA_PERF or {}
	local elapsed = World_GetGameTicks() - (p.last_reset_tick or 0)
	print(string.format("[DEBUG] _CBA_PERF  sg=%d  eg=%d  rc=%d  qs=%d  ds=%d  rt=%d  ticks=%d", p.sg_allocs or 0, p.eg_allocs or 0, p.recount_calls or 0, p.queue_scans or 0, p.disable_skipped or 0, p.reconcile_ticks or 0, elapsed))
	print(string.format("[DEBUG] _CBA_PERF  ek_siege=%d  sk_siege=%d  cache_hit=%d  cache_miss=%d", p.ge_entity_killed_siege or 0, p.ge_squad_killed_siege or 0, p.siege_cache_hits or 0, p.siege_cache_misses or 0))
	print(string.format("[DEBUG] _CBA_PERF  batch_sq=%d/%d  batch_ek=%d/%d  sq_pending=%d  ek_pending=%d",
		p.batch_sq_processed or 0, p.batch_sq_ticks or 0,
		p.batch_ek_processed or 0, p.batch_ek_ticks or 0,
		#(_CBA_SQUAD_KILL_BATCH.queue or {}), #(_CBA_ENTITY_KILL_BATCH.queue or {})))
	print(string.format("[DEBUG] _CBA_PERF  bld_dec=%d  bld_skip_nil=%d  bld_skip_cancel=%d  bld_rc=%d  bld_drift=%d",
		p.batch_bld_decremented or 0, p.batch_bld_skipped_player_nil or 0, p.batch_bld_skipped_cancelled or 0,
		p.bld_reconcile_ticks or 0, p.bld_reconcile_drift or 0))
end

function Debug_SiegeStatus()
	for i = 1, World_GetPlayerCount() do
		local player = Core_GetPlayersTableEntry(World_GetPlayerAt(i))
		if player ~= nil and player.id ~= nil then
			local max_siege = CBA_Options_GetPlayerSiegeLimit(player)
			print(string.format("[DEBUG] P%d  siege=%d  siege_pend=%d  siege_cap=%d  ram=%d  st=%d  ram_pend=%d  st_pend=%d  tier=%s",
				player.index or i,
				player.siegeLimit_count or 0,
				player.siegeLimit_pending or 0,
				max_siege,
				player.ramLimit_count or 0,
				player.siegeTowerLimit_count or 0,
				player.ramLimit_pending or 0,
				player.siegeTowerLimit_pending or 0,
				tostring(player._siege_enforce_tier or "nil")))
		end
	end
end

function Debug_RecountValidate()
	for i = 1, World_GetPlayerCount() do
		local player = Core_GetPlayersTableEntry(World_GetPlayerAt(i))
		if player ~= nil and player.id ~= nil then
			local prev_s = player.siegeLimit_count or 0
			local prev_r = player.ramLimit_count or 0
			local prev_t = player.siegeTowerLimit_count or 0
			local prev_sp = player.siegeLimit_pending or 0
			CBA_Options_SiegeLimit_RecountAll(player)
			local delta_s = (player.siegeLimit_count or 0) - prev_s
			local delta_r = (player.ramLimit_count or 0) - prev_r
			local delta_t = (player.siegeTowerLimit_count or 0) - prev_t
			local delta_sp = (player.siegeLimit_pending or 0) - prev_sp
			if delta_s == 0 and delta_r == 0 and delta_t == 0 and delta_sp == 0 then
				print(string.format("[DEBUG] P%d RecountValidate OK  s=%d r=%d t=%d sp=%d", player.index or i, prev_s, prev_r, prev_t, prev_sp))
			else
				print(string.format("[DEBUG] P%d RecountValidate DRIFT  siege %d->%d  ram %d->%d  tower %d->%d  siege_pend %d->%d",
					player.index or i, prev_s, prev_s + delta_s, prev_r, prev_r + delta_r, prev_t, prev_t + delta_t, prev_sp, prev_sp + delta_sp))
			end
		end
	end
end