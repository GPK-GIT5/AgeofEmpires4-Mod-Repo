-- CBA: Reward List
function AGS_GlobalSettings_CBA_Rewards(reward_list)
	if reward_list.enum_value == reward_list.enum_items.reward_list_onslaught then
		AGS_GLOBAL_SETTINGS.CBA_Rewards = "onslaught"
		elseif reward_list.enum_value == reward_list.enum_items.reward_list_arena then
		AGS_GLOBAL_SETTINGS.CBA_Rewards = "arena"
	elseif reward_list.enum_value == reward_list.enum_items.reward_list_disabled then
		AGS_GLOBAL_SETTINGS.CBA_Rewards = "disabled"
	end
end
