-- Automatic Age up
function AGS_GlobalSettings_SetAutoAge(auto_age)
	if auto_age.enum_value == auto_age.enum_items.auto_age_300 then
		AGS_GLOBAL_SETTINGS.AutoAge = 300
	elseif auto_age.enum_value == auto_age.enum_items.auto_age_600 then
		AGS_GLOBAL_SETTINGS.AutoAge = 600
	elseif auto_age.enum_value == auto_age.enum_items.auto_age_900 then
		AGS_GLOBAL_SETTINGS.AutoAge = 900
	elseif auto_age.enum_value == auto_age.enum_items.auto_age_0 then
		AGS_GLOBAL_SETTINGS.AutoAge = 0
	end
end
-- Automatic Population 
