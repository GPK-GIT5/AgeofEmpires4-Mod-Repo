	if category.option_legacy_setting_unit_rates then
		AGS_GlobalSettings_SetUnitRates(category.option_legacy_setting_unit_rates)
	end
	if category.option_legacy_setting_game_rates then
		AGS_GlobalSettings_SetGameRates(category.option_legacy_setting_game_rates)
	end
	if category.option_legacy_setting_gather_rates then
		AGS_GlobalSettings_SetGatherRates(category.option_legacy_setting_gather_rates)
	end
end -- Active

function AGS_GlobalSettings_DefineHandicapSettings(category)
	if category.option_handicap_setting_handicap_type ~= nil then
		AGS_GlobalSettings_SetHandicapType(category.option_handicap_setting_handicap_type)
	end
	AGS_GlobalSettings_SetSlotHandicaps(category)
end -- Active
-- CBA Section
function AGS_GlobalSettings_DefineCbaSettings(category)	
	-- Select Reward list
	if category.option_cba_setting_reward_list then
		AGS_GlobalSettings_CBA_Rewards(category.option_cba_setting_reward_list)
	end 
	-- Enable/disable custom CBA AI controller
	if category.option_cba_setting_ai_players ~= nil then
		AGS_GlobalSettings_SetAIPlayers(category.option_cba_setting_ai_players)
	end
	-- Force Team Positions
	if category.option_cba_setting_force_team_positions ~= nil then
		AGS_GLOBAL_SETTINGS.ForceTeamPositions = category.option_cba_setting_force_team_positions
	end
	-- Additional AI controls can still be code-driven defaults when .rdo keys are absent.
	
end
-- Restrictions
function AGS_GlobalSettings_DefineRestrictionSettings(category)	
	
	-- Siege Limit 
	if category.option_restriction_setting_max_medicpopulation then
		AGS_GlobalSettings_SetMaximumMedicPopulation(category.option_restriction_setting_max_medicpopulation)
	end
	-- Max Production buildings / Max Siege Workshop are fixed in code.
	-- Intentionally not read from restriction .rdo option keys.
	-- Disable Stone Wall
	if category.option_restriction_setting_no_wall ~= nil then
		AGS_GLOBAL_SETTINGS.NoWall = category.option_restriction_setting_no_wall
	end
	-- Disable Siege
	if category.option_restriction_setting_no_siege ~= nil then
		AGS_GLOBAL_SETTINGS.NoSiege = category.option_restriction_setting_no_siege
	end
	-- Disable Arsenal
	if category.option_restriction_setting_no_arsenal ~= nil then
		AGS_GLOBAL_SETTINGS.NoArsenal = category.option_restriction_setting_no_arsenal
	end
	-- Disable Dock
	if category.option_restriction_setting_no_dock ~= nil then
		AGS_GLOBAL_SETTINGS.NoDock = category.option_restriction_setting_no_dock
	end

	
end
	
---------------------------------------------------------------------------------------------------
-- Assignment Functions:
---------------------------------------------------------------------------------------------------

function AGS_GlobalSettings_SetAIPlayers(ai_players)
	local val = ai_players
	if type(ai_players) == "table" then
		local items = ai_players.enum_items or {}
		val = ai_players.enum_value
		if val == items.ai_players_disabled or val == items.ai_players_off then
			AGS_GLOBAL_SETTINGS.AIPlayers = "disabled"
			return
		end
		if val == items.ai_players_enabled or val == items.ai_players_on then
			AGS_GLOBAL_SETTINGS.AIPlayers = "enabled"
			return
		end
	end

	if type(val) == "boolean" then
		AGS_GLOBAL_SETTINGS.AIPlayers = val and "enabled" or "disabled"
		return
	end
	if type(val) == "number" then
		AGS_GLOBAL_SETTINGS.AIPlayers = (val == 0) and "disabled" or "enabled"
		return
	end
	if type(val) == "string" then
		local lowered = string.lower(val)
		if lowered == "disabled" or lowered == "off" or lowered == "false" then
			AGS_GLOBAL_SETTINGS.AIPlayers = "disabled"
		else
			AGS_GLOBAL_SETTINGS.AIPlayers = "enabled"
		end
	end
end

function AGS_GlobalSettings_SetAIAggression(ai_aggression)
	local val = ai_aggression
	if type(ai_aggression) == "table" then
		local items = ai_aggression.enum_items or {}
		val = ai_aggression.enum_value
		if val == items.ai_aggression_low then
			AGS_GLOBAL_SETTINGS.AIAggression = "low"
			return
		elseif val == items.ai_aggression_medium then
			AGS_GLOBAL_SETTINGS.AIAggression = "medium"
			return
		elseif val == items.ai_aggression_high then
			AGS_GLOBAL_SETTINGS.AIAggression = "high"
			return
		end
	end

	if type(val) == "number" then
		if val <= 1 then
			AGS_GLOBAL_SETTINGS.AIAggression = "low"
		elseif val == 2 then
			AGS_GLOBAL_SETTINGS.AIAggression = "medium"
		else
			AGS_GLOBAL_SETTINGS.AIAggression = "high"
		end
		return
	end

	if type(val) == "string" then
		local lowered = string.lower(val)
		if lowered == "low" or lowered == "cautious" then
			AGS_GLOBAL_SETTINGS.AIAggression = "low"
		elseif lowered == "high" or lowered == "aggressive" then
			AGS_GLOBAL_SETTINGS.AIAggression = "high"
		else
			AGS_GLOBAL_SETTINGS.AIAggression = "medium"
		end
	end
end

function AGS_GlobalSettings_SetAIOutposts(ai_outposts)
	local val = ai_outposts
	if type(ai_outposts) == "table" then
		local items = ai_outposts.enum_items or {}
		val = ai_outposts.enum_value
		if val == items.ai_outposts_disabled or val == items.ai_outposts_off then
			AGS_GLOBAL_SETTINGS.AIOutposts = false
			return
		end
		if val == items.ai_outposts_enabled or val == items.ai_outposts_on then
			AGS_GLOBAL_SETTINGS.AIOutposts = true
			return
		end
	end

	if type(val) == "boolean" then
		AGS_GLOBAL_SETTINGS.AIOutposts = val
		return
	end
	if type(val) == "number" then
		AGS_GLOBAL_SETTINGS.AIOutposts = (val ~= 0)
		return
	end
	if type(val) == "string" then
		local lowered = string.lower(val)
		AGS_GLOBAL_SETTINGS.AIOutposts = not (lowered == "disabled" or lowered == "off" or lowered == "false")
	end
end

function AGS_GlobalSettings_SetMaintainTeamBalance(maintain_team_balance)
	local items = maintain_team_balance.enum_items or {}
	local val = maintain_team_balance.enum_value
	-- Try named enum items first
	if val == items.maintain_team_balance_none then
		AGS_GLOBAL_SETTINGS.MaintainTeamBalance = AGS_GS_TEAM_BALANCE_NONE
	elseif val == items.maintain_team_balance_population then
		AGS_GLOBAL_SETTINGS.MaintainTeamBalance = AGS_GS_TEAM_BALANCE_POPULATION
	elseif val == items.maintain_team_balance_resources then
		AGS_GLOBAL_SETTINGS.MaintainTeamBalance = AGS_GS_TEAM_BALANCE_RESOURCES
	elseif val == items.maintain_team_balance_full then
		AGS_GLOBAL_SETTINGS.MaintainTeamBalance = AGS_GS_TEAM_BALANCE_FULL
	else
		-- Numeric fallback: 0=None, 1=Pop, 2=Res, 3=Full
		local numeric_map = {
			[0] = AGS_GS_TEAM_BALANCE_NONE,
			[1] = AGS_GS_TEAM_BALANCE_POPULATION,
			[2] = AGS_GS_TEAM_BALANCE_RESOURCES,
			[3] = AGS_GS_TEAM_BALANCE_FULL,
		}
		local mapped = numeric_map[val]
		if mapped ~= nil then
			AGS_GLOBAL_SETTINGS.MaintainTeamBalance = mapped
		end
	end
end

function AGS_GlobalSettings_SetSettlement(settlement)
