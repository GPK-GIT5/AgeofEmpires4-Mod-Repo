
import("MissionOMatic/MissionOMatic.scar")		-- this imports the Cardinal scripts as well
import("missionomatic/missionomatic_artofwar.scar")
import("training/coretraininggoals.scar")
import("challenge_agincourt.events")
import("cardinal.scar")

function HC_Agincourt_SpawnFrenchWave3()
	
	HC_Agincourt_Wave3_SpawnUnits()
	
	SGroup_AddGroups(sg_enemyRow3_cannon, {sg_enemyRow3_cannon1, sg_enemyRow3_cannon3, sg_enemyRow3_cannon5})
	
	Modify_EntityMaxHealth(sg_enemyRow3_militia1, 1.5, MUT_Multiplication)
	Modify_EntityMaxHealth(sg_enemyRow3_militia3, 1.5, MUT_Multiplication)
	Modify_EntityMaxHealth(sg_enemyRow3_militia5, 1.5, MUT_Multiplication)
	Modify_EntityMaxHealth(sg_enemyRow3_leader, 3, MUT_Multiplication)	
	
	local mod_speed = Modifier_Create(MAT_EntityType, "speed_maximum_modifier", MUT_Multiplication, true, 1.5, SBP.FRENCH.UNIT_SHIELD_VILLAGER_CMP_FRE)	
	Modifier_ApplyToPlayer(mod_speed, enemyPlayer, 0)
	
	sg_wave3_AllUnits = SGroup_CreateIfNotFound("sg_wave3_AllUnits")
	SGroup_AddGroups(sg_wave3_AllUnits, {sg_enemyRow3_army1, sg_enemyRow3_army3, sg_enemyRow3_army5, sg_enemyRow3_leader})
	
	Cmd_FormationMove(sg_enemyRow3_army1, mkr_frenchArmy3_1, true, false, mkr_playerBase)
	Cmd_FormationMove(sg_enemyRow3_army3, mkr_frenchArmy3_3, true, false, mkr_playerBase)
	Cmd_FormationMove(sg_enemyRow3_army5, mkr_frenchArmy3_5, true, false, mkr_playerBase)
	Cmd_FormationMove(sg_enemyRow3_leader, mkr_frenchArmyL3, true, false, mkr_playerBase)
	
end

function HC_Agincourt_Wave3_SpawnUnits()
	
	sg_enemyRow3_army1 = SGroup_CreateIfNotFound("sg_enemyRow3_army1")
	sg_enemyRow3_army3 = SGroup_CreateIfNotFound("sg_enemyRow3_army3")
	sg_enemyRow3_army5 = SGroup_CreateIfNotFound("sg_enemyRow3_army5")
	sg_enemyRow3_cannon1 = SGroup_CreateIfNotFound("sg_enemyRow3_cannon1")
	sg_enemyRow3_cannon3 = SGroup_CreateIfNotFound("sg_enemyRow3_cannon3")
	sg_enemyRow3_cannon5 = SGroup_CreateIfNotFound("sg_enemyRow3_cannon5")
	sg_enemyRow3_cannon = SGroup_CreateIfNotFound("sg_enemyRow3_cannon")
	sg_enemyRow3_leader = SGroup_CreateIfNotFound("sg_enemyRow3_leader")
	
	--the militia groups, which can be promoted into men-at-arms
	sg_enemyRow3_militia1 = SGroup_CreateIfNotFound("sg_enemyRow3_militia1")
	sg_enemyRow3_militia2 = SGroup_CreateIfNotFound("sg_enemyRow3_militia2")
	sg_enemyRow3_militia3 = SGroup_CreateIfNotFound("sg_enemyRow3_militia3")
	sg_enemyRow3_militia4 = SGroup_CreateIfNotFound("sg_enemyRow3_militia4")
	sg_enemyRow3_militia5 = SGroup_CreateIfNotFound("sg_enemyRow3_militia5")
	
	--the spearmen or crossbowmen groups, which deplot pavises
	sg_enemyRow3_defenders1 = SGroup_CreateIfNotFound("sg_enemyRow3_defenders1")
	sg_enemyRow3_defenders3 = SGroup_CreateIfNotFound("sg_enemyRow3_defenders3")
	sg_enemyRow3_defenders5 = SGroup_CreateIfNotFound("sg_enemyRow3_defenders5")
	
	sg_enemyRow3_militiaLeader1 = SGroup_CreateIfNotFound("sg_enemyRow3_militiaLeader1")
	sg_enemyRow3_militiaLeader5 = SGroup_CreateIfNotFound("sg_enemyRow3_militiaLeader5")
	
	local sbp_manatarms_fre = SBP.FRENCH.UNIT_MANATARMS_3_FRE
	local sbp_spearmen_fre = SBP.FRENCH.UNIT_SPEARMAN_2_FRE
	local sbp_crossbowman_fre = SBP.FRENCH.UNIT_CROSSBOWMAN_3_FRE
	local sbp_cannon_fre = SBP.FRENCH.UNIT_CANNON_4_ROYAL_FRE
	local sbp_leader3 = SBP.FRENCH.UNIT_CHARLES_D_ALBRET_CMP_FRE
	local sbp_militia = SBP.FRENCH.UNIT_SHIELD_VILLAGER_CMP_FRE
	local sbp_villager = SBP.FRENCH.UNIT_VILLAGER_1_FRE
	
	local facingPos = Marker_GetPosition(mkr_playerBase)
	UnitEntry_DeploySquads(enemyPlayer, {sg_enemyRow3_army1, sg_enemyRow3_defenders1}, {sbp = sbp_spearmen_fre, numSquads = 16, facing = facingPos }, mkr_frenchArmyS3_1)
	UnitEntry_DeploySquads(enemyPlayer, {sg_enemyRow3_army1, sg_enemyRow3_cannon1}, {sbp = sbp_cannon_fre, numSquads = 1, facing = facingPos }, mkr_frenchArmyS3_1)
	UnitEntry_DeploySquads(enemyPlayer, {sg_enemyRow3_army1, sg_enemyRow3_militia1}, {sbp = sbp_militia, numSquads = 14, facing = facingPos }, mkr_frenchArmyS3_1)
	
	UnitEntry_DeploySquads(enemyPlayer, {sg_enemyRow3_army3, sg_enemyRow3_defenders3}, {sbp = sbp_crossbowman_fre, numSquads = 16, facing = facingPos }, mkr_frenchArmyS3_3)
	UnitEntry_DeploySquads(enemyPlayer, {sg_enemyRow3_army3, sg_enemyRow3_cannon3}, {sbp = sbp_cannon_fre, numSquads = 1, facing = facingPos }, mkr_frenchArmyS3_3)
	UnitEntry_DeploySquads(enemyPlayer, {sg_enemyRow3_army3, sg_enemyRow3_militia3}, {sbp = sbp_militia, numSquads = 14, facing = facingPos }, mkr_frenchArmyS3_3)
	
	UnitEntry_DeploySquads(enemyPlayer, {sg_enemyRow3_army5, sg_enemyRow3_defenders5}, {sbp = sbp_spearmen_fre, numSquads = 16, facing = facingPos }, mkr_frenchArmyS3_5)
	UnitEntry_DeploySquads(enemyPlayer, {sg_enemyRow3_army5, sg_enemyRow3_cannon5}, {sbp = sbp_cannon_fre, numSquads = 1, facing = facingPos }, mkr_frenchArmyS3_5)
	UnitEntry_DeploySquads(enemyPlayer, {sg_enemyRow3_army5, sg_enemyRow3_militia5}, {sbp = sbp_militia, numSquads = 14, facing = facingPos }, mkr_frenchArmyS3_5)
	
	
	
	SGroup_AddAbility(sg_enemyRow3_defenders1, ABILITY.DEPLOY_PAVISE_FRE)
	SGroup_AddAbility(sg_enemyRow3_defenders3, ABILITY.DEPLOY_PAVISE_FRE)
	SGroup_AddAbility(sg_enemyRow3_defenders5, ABILITY.DEPLOY_PAVISE_FRE)
	
	
	local options = {
		destination = mkr_frenchArmyL3,
		dynamicSpawnType = DST_FURTHEST_HIDDEN,
		holdPosition = true,
	}
	UnitEntry_DeploySquads(enemyPlayer, sg_enemyRow3_leader, {sbp = sbp_leader3, numSquads = 1, facing = facingPos }, mkr_frenchArmyL3S, nil, nil, options)
	
	--keep track of which phase of the advance we're in
	w3_attack_phase = 0
	
end

function HC_Agincourt_RevealFrenchWave3()
	
	UI_CreateMinimapBlip(sg_enemyRow3_army1, 10, "threat_group")
	UI_CreateMinimapBlip(sg_enemyRow3_army3, 10, "threat_group")
	UI_CreateMinimapBlip(sg_enemyRow3_army5, 10, "threat_group")
	
	FOW_PlayerRevealSGroup(localPlayer, sg_enemyRow3_army1,20,-1)
	FOW_PlayerRevealSGroup(localPlayer, sg_enemyRow3_army3,20,-1)
	FOW_PlayerRevealSGroup(localPlayer, sg_enemyRow3_army5,20,-1)
	
	SGroup_AddAbility(sg_enemyRow3_cannon3, ABILITY.GENERAL_AURA_GUNPOWDER)
	--also add auras to the left and right cannon if conqueror mode is active
	if(conquerorModeActivated == true) then
		SGroup_AddAbility(sg_enemyRow3_cannon1, ABILITY.GENERAL_AURA_GUNPOWDER)
		SGroup_AddAbility(sg_enemyRow3_cannon5, ABILITY.GENERAL_AURA_GUNPOWDER)
	end
end

function HC_Agincourt_Wave3_Start()
	
	Util_StartIntel(EVENTS.French_Battalion)
	Sound_Play2D("sfx_campaign_scripted_medium_group_engage")
	Sound_Play2D(MUS_STINGER_ALERT)
	
	rallyStartTime = World_GetGameTime()
	
	--track each group's progress down the battlefield
	w3_lane1_fit = 0
	w3_lane3_fit = 0
	w3_lane5_fit = 0
	
	reformingLanes = false
	
	w3_leader_target = 3
	w3_leader_target_changed = true
	
	w3_leader_rallyPosition = Util_GetPosition(mkr_frenchArmyL3)
	
	wave3Label1 = Objective_AddUIElements(SOBJ_AttackWave3, sg_enemyRow3_cannon1, false, "$11268426", true, 2)--French Reserves
	wave3Label3 = Objective_AddUIElements(SOBJ_AttackWave3, sg_enemyRow3_cannon3, false, "$11268426", true, 2)--French Reserves
	wave3Label5 = Objective_AddUIElements(SOBJ_AttackWave3, sg_enemyRow3_cannon5, false, "$11268426", true, 2)--French Reserves
	
	w3_startTime = World_GetGameTime()
	w3_currentTime = 0
	
	--enum for the current behavior state of each lane
	w3LaneState = {Idle = 0, Advancing = 1, SetupCircle = 2, CompleteCircle = 3, Deploying = 4, Firing = 5, Attacking = 6}
	
	w3_lane1State = w3LaneState.Idle
	w3_lane3State = w3LaneState.Idle
	w3_lane5State = w3LaneState.Idle
	w3_allAttacking = false
	
	w3_lane1Progress = 0
	w3_lane3Progress = 0
	w3_lane5Progress = 0
	
	w3_lane1AdvanceTime = 0
	w3_lane3AdvanceTime = 0
	w3_lane5AdvanceTime = 0
	
	w3_leaderPhase = 0
	w3_leaderTargetLane = 3 --which lane the leader should be in
	w3_leaderTargetProgress = 3 --how far down the lane the leader should be
	
	Rule_AddInterval(HC_Agincourt_Wave3_Update, 0.125)
	Rule_AddInterval(HC_Agincourt_Wave3_UpdateLeader, 3)
	
	advanceInterval = 60
	
	--set up timings for each lane to start advancing
	Rule_AddOneShot(HC_Agincourt_Wave3_BeginLaneAdvance, 0, {in_laneNumber = 1, in_advanceTarget = .2})
	Rule_AddOneShot(HC_Agincourt_Wave3_BeginLaneAdvance, (advanceInterval * 1), {in_laneNumber = 1, in_advanceTarget = .4})
	Rule_AddOneShot(HC_Agincourt_Wave3_BeginLaneAdvance, (advanceInterval * 2), {in_laneNumber = 1, in_advanceTarget = .6})
	Rule_AddOneShot(HC_Agincourt_Wave3_BeginLaneAdvance, (advanceInterval * 3), {in_laneNumber = 1, in_advanceTarget = .8})
	Rule_AddOneShot(HC_Agincourt_Wave3_Lane1Attack, (advanceInterval * 4) + 10)
	
	Rule_AddOneShot(HC_Agincourt_Wave3_BeginLaneAdvance, (advanceInterval / 2), {in_laneNumber = 3, in_advanceTarget = .3})
	Rule_AddOneShot(HC_Agincourt_Wave3_BeginLaneAdvance, (advanceInterval * 1) + (advanceInterval / 2), {in_laneNumber = 3, in_advanceTarget = .5})
	Rule_AddOneShot(HC_Agincourt_Wave3_BeginLaneAdvance, (advanceInterval * 2) + (advanceInterval / 2), {in_laneNumber = 3, in_advanceTarget = .7})
	Rule_AddOneShot(HC_Agincourt_Wave3_BeginLaneAdvance, (advanceInterval * 3) + (advanceInterval / 2), {in_laneNumber = 3, in_advanceTarget = .9})
	Rule_AddOneShot(HC_Agincourt_Wave3_Lane3Attack, (advanceInterval * 4) + 10)
	
	Rule_AddOneShot(HC_Agincourt_Wave3_BeginLaneAdvance, 0, {in_laneNumber = 5, in_advanceTarget = .2})
	Rule_AddOneShot(HC_Agincourt_Wave3_BeginLaneAdvance, (advanceInterval * 1), {in_laneNumber = 5, in_advanceTarget = .4})
	Rule_AddOneShot(HC_Agincourt_Wave3_BeginLaneAdvance, (advanceInterval * 2), {in_laneNumber = 5, in_advanceTarget = .6})
	Rule_AddOneShot(HC_Agincourt_Wave3_BeginLaneAdvance, (advanceInterval * 3), {in_laneNumber = 5, in_advanceTarget = .8})
	Rule_AddOneShot(HC_Agincourt_Wave3_Lane5Attack, (advanceInterval * 4) + 10)
	
end

function HC_Agincourt_Wave3_Lane1Attack()
	
	Sound_Play2D("sfx_campaign_scripted_medium_group_engage")
	Sound_Play2D(MUS_STINGER_ALERT)
	
	if(cannonReticuleID1 ~= nil) then
		UI_ModalVisual_Destroy(cannonReticuleID1)
	end
	Cmd_FormationAttackMove(sg_enemyRow3_army1, mkr_ArmyAttack1_3, false, false)
	Cmd_FormationAttackMove(sg_enemyRow3_army1, mkr_playerBase, true, false)
	
	w3_lane1State = w3LaneState.Attacking
end

function HC_Agincourt_Wave3_Lane3Attack()
	
	Sound_Play2D("sfx_campaign_scripted_medium_group_engage")
	Sound_Play2D(MUS_STINGER_ALERT)
	
	if(cannonReticuleID3 ~= nil) then
		UI_ModalVisual_Destroy(cannonReticuleID3)
	end
	Cmd_FormationAttackMove(sg_enemyRow3_army3, mkr_ArmyAttack3_3, false, false)
	Cmd_FormationAttackMove(sg_enemyRow3_army3, mkr_playerBase, true, false)
	
	w3_lane3State = w3LaneState.Attacking
end

function HC_Agincourt_Wave3_Lane5Attack()
	
	Sound_Play2D("sfx_campaign_scripted_medium_group_engage")
	Sound_Play2D(MUS_STINGER_ALERT)
	
	if(cannonReticuleID5 ~= nil) then
		UI_ModalVisual_Destroy(cannonReticuleID5)
	end
	Cmd_FormationAttackMove(sg_enemyRow3_army5, mkr_ArmyAttack5_3, false, false)
	Cmd_FormationAttackMove(sg_enemyRow3_army5, mkr_playerBase, true, false)
	
	w3_lane5State = w3LaneState.Attacking
end

function HC_Agincourt_Wave3_BeginLaneAdvance(context, data)
	--begin advancing down the lane
	if(data.in_laneNumber == 1) then
		w3_lane1State = w3LaneState.Advancing
		w3_lane1Progress = data.in_advanceTarget
		w3_lane1AdvanceTime = World_GetGameTime() - w3_startTime
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_army1, 1, w3_lane1Progress, true, true)
		if(cannonReticuleID1 ~= nil) then
			UI_ModalVisual_Destroy(cannonReticuleID1)
		end
	end
	if(data.in_laneNumber == 3) then
		w3_lane3State = w3LaneState.Advancing
		w3_lane3Progress = data.in_advanceTarget
		w3_lane3AdvanceTime = World_GetGameTime() - w3_startTime
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_army3, 3, w3_lane3Progress, true, true)
		if(cannonReticuleID3 ~= nil) then
			UI_ModalVisual_Destroy(cannonReticuleID3)
		end
	end
	if(data.in_laneNumber == 5) then
		w3_lane5State = w3LaneState.Advancing
		w3_lane5Progress = data.in_advanceTarget
		w3_lane5AdvanceTime = World_GetGameTime() - w3_startTime
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_army5, 5, w3_lane5Progress, true, true)
		if(cannonReticuleID5 ~= nil) then
			UI_ModalVisual_Destroy(cannonReticuleID5)
		end
	end
	
end


function HC_Agincourt_Wave3_Update()
	
	w3_currentTime = World_GetGameTime() - w3_startTime
	
	HC_Agincourt_Wave3_CheckFit()
	
	if(SGroup_CountSpawned(sg_wave3_AllUnits) == 0) then
		
		-- Set victory objective to complete
		Objective_Complete(OBJ_Victory, false, true)
		-- After a short delay end the mission.
		Rule_AddOneShot(HC_Agincourt_EndChallenge, 0)
		
		Rule_RemoveMe()
	end
	
	local cannonProgressOffset = .065 -- the distance to offset the cannon and defensive circle behind the wave target
	--advance the state of each wave according to the timer
	--lanes follow a pattern as they advance: move -> form defensive circle -> fire cannon -> idle
	----------
	--Lane 1:
	if(w3_lane1State == w3LaneState.Advancing and w3_currentTime > w3_lane1AdvanceTime + 20) then
		w3_lane1State = w3LaneState.SetupCircle
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_defenders1, 1, w3_lane1Progress - cannonProgressOffset, false, false, true)
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_cannon1, 1, w3_lane1Progress - cannonProgressOffset, true, false)
	end
	if(w3_lane1State == w3LaneState.SetupCircle and w3_currentTime > w3_lane1AdvanceTime + 26) then
		w3_lane1State = w3LaneState.CompleteCircle
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_defenders1, 1, w3_lane1Progress - cannonProgressOffset, false, false, false, true)
	end
	if(w3_lane1State == w3LaneState.CompleteCircle and w3_currentTime > w3_lane1AdvanceTime + 28) then
		w3_lane1State = w3LaneState.Deploying
		Player_ResetAbilityCooldowns(enemyPlayer, ABILITY.DEPLOY_PAVISE_FRE)
		
		if(SGroup_CountSpawned(sg_enemyRow3_defenders1) > 0) then
			for i = 1, SGroup_CountSpawned(sg_enemyRow3_defenders1) do
				local squad = SGroup_GetSquadAt(sg_enemyRow3_defenders1, i)
				if(squad ~= nil) then
					SGroup_Single(sg_single, squad)
					if(SGroup_CountSpawned(sg_single) > 0) then
						local squadPos = Util_GetPosition(sg_single)
						
						Cmd_Ability(sg_single, ABILITY.DEPLOY_PAVISE_FRE, squadPos, nil, true)
					end
				end
			end
		end
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_cannon1, 1, w3_lane1Progress - cannonProgressOffset, true, true, false, false, true)
	end
	if(w3_lane1State == w3LaneState.Deploying and w3_currentTime > w3_lane1AdvanceTime + 30) then
		w3_lane1State = w3LaneState.Firing
		
		if(SGroup_CountSpawned(sg_enemyRow3_cannon1) > 0) then
			local currentCannonTarget = mkr_CannonAttack1_1
			if(w3_lane1Progress == .2) then
				currentCannonTarget = mkr_CannonAttack1_1
			end
			if(w3_lane1Progress == .4) then
				currentCannonTarget = mkr_CannonAttack1_2
			end
			if(w3_lane1Progress == .6) then
				currentCannonTarget = mkr_CannonAttack1_3
			end
			if(w3_lane1Progress == .8) then
				currentCannonTarget = mkr_CannonAttack1_4
			end
			Cmd_Attack(sg_enemyRow3_cannon1, currentCannonTarget, false)
		end
	end
	if(w3_lane1State == w3LaneState.Firing and w3_currentTime > w3_lane1AdvanceTime + 33) then
		w3_lane1State = w3LaneState.Idle
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_cannon1, 1, w3_lane1Progress - cannonProgressOffset, true, true, false, false, true)
	end
	----------
	--Lane 3:
	if(w3_lane3State == w3LaneState.Advancing and w3_currentTime > w3_lane3AdvanceTime + 20) then
		w3_lane3State = w3LaneState.SetupCircle
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_defenders3, 3, w3_lane3Progress - cannonProgressOffset, false, false, true)
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_cannon3, 3, w3_lane3Progress - cannonProgressOffset, true, false)
	end
	if(w3_lane3State == w3LaneState.SetupCircle and w3_currentTime > w3_lane3AdvanceTime + 26) then
		w3_lane3State = w3LaneState.CompleteCircle
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_defenders3, 3, w3_lane3Progress - cannonProgressOffset, false, false, false, true)
	end
	if(w3_lane3State == w3LaneState.CompleteCircle and w3_currentTime > w3_lane3AdvanceTime + 28) then
		w3_lane3State = w3LaneState.Deploying
		Player_ResetAbilityCooldowns(enemyPlayer, ABILITY.DEPLOY_PAVISE_FRE)
		
		if(SGroup_CountSpawned(sg_enemyRow3_defenders3) > 0) then
			for i = 1, SGroup_CountSpawned(sg_enemyRow3_defenders3) do
				local squad = SGroup_GetSquadAt(sg_enemyRow3_defenders3, i)
				if(squad ~= nil) then
					SGroup_Single(sg_single, squad)
					if(SGroup_CountSpawned(sg_single) > 0) then
						local squadPos = Util_GetPosition(sg_single)
						
						Cmd_Ability(sg_single, ABILITY.DEPLOY_PAVISE_FRE, squadPos, nil, true)
					end
				end
			end
		end
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_cannon3, 3, w3_lane3Progress - cannonProgressOffset, true, true, false, false, true)
	end
	if(w3_lane3State == w3LaneState.Deploying and w3_currentTime > w3_lane3AdvanceTime + 30) then
		w3_lane3State = w3LaneState.Firing
		
		if(SGroup_CountSpawned(sg_enemyRow3_cannon3) > 0) then
			local currentCannonTarget = mkr_CannonAttack3_1
			if(w3_lane3Progress == .3) then
				currentCannonTarget = mkr_CannonAttack3_1
			end
			if(w3_lane3Progress == .5) then
				currentCannonTarget = mkr_CannonAttack3_2
			end
			if(w3_lane3Progress == .7) then
				currentCannonTarget = mkr_CannonAttack3_3
			end
			if(w3_lane3Progress == .9) then
				currentCannonTarget = mkr_CannonAttack3_4
			end
			Cmd_Attack(sg_enemyRow3_cannon3, currentCannonTarget, false)
		end
	end
	if(w3_lane3State == w3LaneState.Firing and w3_currentTime > w3_lane3AdvanceTime + 33) then
		w3_lane3State = w3LaneState.Idle
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_cannon3, 3, w3_lane3Progress - cannonProgressOffset, true, true, false, false, true)
	end
	----------
	--Lane 5:
	if(w3_lane5State == w3LaneState.Advancing and w3_currentTime > w3_lane5AdvanceTime + 20) then
		w3_lane5State = w3LaneState.SetupCircle
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_defenders5, 5, w3_lane5Progress - cannonProgressOffset, false, false, true)
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_cannon5, 5, w3_lane5Progress - cannonProgressOffset, true, false)
	end
	if(w3_lane5State == w3LaneState.SetupCircle and w3_currentTime > w3_lane5AdvanceTime + 26) then
		w3_lane5State = w3LaneState.CompleteCircle
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_defenders5, 5, w3_lane5Progress - cannonProgressOffset, false, false, false, true)
	end
	if(w3_lane5State == w3LaneState.CompleteCircle and w3_currentTime > w3_lane5AdvanceTime + 28) then
		w3_lane5State = w3LaneState.Deploying
		Player_ResetAbilityCooldowns(enemyPlayer, ABILITY.DEPLOY_PAVISE_FRE)
		
		if(SGroup_CountSpawned(sg_enemyRow3_defenders5) > 0) then
			for i = 1, SGroup_CountSpawned(sg_enemyRow3_defenders5) do
				local squad = SGroup_GetSquadAt(sg_enemyRow3_defenders5, i)
				if(squad ~= nil) then
					SGroup_Single(sg_single, squad)
					if(SGroup_CountSpawned(sg_single) > 0) then
						local squadPos = Util_GetPosition(sg_single)
						
						Cmd_Ability(sg_single, ABILITY.DEPLOY_PAVISE_FRE, squadPos, nil, true)
					end
				end
			end
		end
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_cannon5, 5, w3_lane5Progress - cannonProgressOffset, true, true, false, false, true)
	end
	if(w3_lane5State == w3LaneState.Deploying and w3_currentTime > w3_lane5AdvanceTime + 30) then
		w3_lane5State = w3LaneState.Firing
		
		if(SGroup_CountSpawned(sg_enemyRow3_cannon5) > 0) then
			local currentCannonTarget = mkr_CannonAttack5_1
			if(w3_lane5Progress == .2) then
				currentCannonTarget = mkr_CannonAttack5_1
			end
			if(w3_lane5Progress == .4) then
				currentCannonTarget = mkr_CannonAttack5_2
			end
			if(w3_lane5Progress == .6) then
				currentCannonTarget = mkr_CannonAttack5_3
			end
			if(w3_lane5Progress == .8) then
				currentCannonTarget = mkr_CannonAttack5_4
			end
			Cmd_Attack(sg_enemyRow3_cannon5, currentCannonTarget, false)
		end
	end
	if(w3_lane5State == w3LaneState.Firing and w3_currentTime > w3_lane5AdvanceTime + 33) then
		w3_lane5State = w3LaneState.Idle
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_cannon5, 5, w3_lane5Progress - cannonProgressOffset, true, true, false, false, true)
	end
	
	
	
	--check for lanes under attack and move them to the Attacking state
	if(w3_lane1State ~= w3LaneState.Attacking) then
		if(SGroup_CountSpawned(sg_enemyRow3_militia1) > 0) then
			if(SGroup_IsUnderAttack(sg_enemyRow3_militia1, ANY, 5)) then
				--split off militia and attack with them
				Cmd_AttackMove(sg_enemyRow3_militia1, mkr_playerBase, true)
				SGroup_Clear(sg_enemyRow3_militia1)
			end
		end
		--activate full attack only if enough defenders have been lost
		if(SGroup_CountSpawned(sg_enemyRow3_defenders1) < 10) then
			--remove oneshot if it is still waiting
			if(Rule_Exists(HC_Agincourt_Wave3_Lane1Attack)) then
				Rule_Remove(HC_Agincourt_Wave3_Lane1Attack)
				--activate attack now
				HC_Agincourt_Wave3_Lane1Attack()
			end
		end
	end
	--
	if(w3_lane3State ~= w3LaneState.Attacking) then
		if(SGroup_CountSpawned(sg_enemyRow3_militia3) > 0) then
			if(SGroup_IsUnderAttack(sg_enemyRow3_militia3, ANY, 5)) then
				--split off militia and attack with them
				Cmd_AttackMove(sg_enemyRow3_militia3, mkr_playerBase, true)
				SGroup_Clear(sg_enemyRow3_militia3)
			end
		end
		--activate full attack only if enough defenders have been lost
		if(SGroup_CountSpawned(sg_enemyRow3_defenders3) < 10) then
			--remove oneshot if it is still waiting
			if(Rule_Exists(HC_Agincourt_Wave3_Lane3Attack)) then
				Rule_Remove(HC_Agincourt_Wave3_Lane3Attack)
				--activate attack now
				HC_Agincourt_Wave3_Lane3Attack()
			end
		end
	end
	--
	if(w3_lane5State ~= w3LaneState.Attacking) then
		if(SGroup_CountSpawned(sg_enemyRow3_militia5) > 0) then
			if(SGroup_IsUnderAttack(sg_enemyRow3_militia5, ANY, 5)) then
				--split off militia and attack with them
				Cmd_AttackMove(sg_enemyRow3_militia5, mkr_playerBase, true)
				SGroup_Clear(sg_enemyRow3_militia5)
			end
		end
		--activate full attack only if enough defenders have been lost
		if(SGroup_CountSpawned(sg_enemyRow3_defenders5) < 10) then
			--remove oneshot if it is still waiting
			if(Rule_Exists(HC_Agincourt_Wave3_Lane5Attack)) then
				Rule_Remove(HC_Agincourt_Wave3_Lane5Attack)
				--activate attack now
				HC_Agincourt_Wave3_Lane5Attack()
			end
		end
	end
	
	
	--if all lanes are set to attack, send an extra attack order to make sure there aren't any missing units
	if(w3_allAttacking == false and w3_lane1State == w3LaneState.Attacking and w3_lane3State == w3LaneState.Attacking and w3_lane5State == w3LaneState.Attacking) then
		Cmd_AttackMove(sg_wave3_AllUnits, mkr_playerBase, true)
		w3_allAttacking = true
	end
	
end

function HC_Agincourt_Wave3_UpdateLeader()
	
	if(SGroup_CountSpawned(sg_enemyRow3_leader) == 0) then
		Rule_RemoveMe()
		return
	end
	
	--the leader will periodically go to the unused lanes (2 and 4) in order to promote a group of militia to men-at-arms
	--this is where we set up the timings when this mechanic occurs by choosing which lane the leader needs to target
	if(World_GetGameTime() - w3_startTime > advanceInterval and w3_leaderPhase == 0) then
		w3_leaderPhase = 1
		w3_leaderTargetLane = 2
		w3_leaderTargetProgress = .3
		SGroup_RemoveGroup(sg_enemyRow3_army3, sg_enemyRow3_militia3)
		SGroup_AddGroup(sg_enemyRow3_militia2, sg_enemyRow3_militia3)
		Rule_AddOneShot(HC_Agincourt_Wave3_StartLeaderPromotion, 5)
	end
	if(World_GetGameTime() - w3_startTime > (advanceInterval * 1.5) and w3_leaderPhase == 1) then
		w3_leaderPhase = 2
		w3_leaderTargetLane = 5
	end
	if(World_GetGameTime() - w3_startTime > (advanceInterval * 2) and w3_leaderPhase == 2) then
		w3_leaderPhase = 3
		w3_leaderTargetLane = 4
		w3_leaderTargetProgress = .5
		SGroup_RemoveGroup(sg_enemyRow3_army5, sg_enemyRow3_militia5)
		SGroup_AddGroup(sg_enemyRow3_militia4, sg_enemyRow3_militia5)
		Rule_AddOneShot(HC_Agincourt_Wave3_StartLeaderPromotion, 5)
	end
	if(World_GetGameTime() - w3_startTime > (advanceInterval * 2.5) and w3_leaderPhase == 3) then
		w3_leaderPhase = 4
		w3_leaderTargetLane = 1
	end
	if(World_GetGameTime() - w3_startTime > (advanceInterval * 3) and w3_leaderPhase == 4) then
		w3_leaderPhase = 5
		w3_leaderTargetLane = 2
		w3_leaderTargetProgress = .7
		SGroup_RemoveGroup(sg_enemyRow3_army1, sg_enemyRow3_militia1)
		SGroup_Clear(sg_enemyRow3_militia2)
		SGroup_AddGroup(sg_enemyRow3_militia2, sg_enemyRow3_militia1)
		Rule_AddOneShot(HC_Agincourt_Wave3_StartLeaderPromotion, 5)
	end
	if(World_GetGameTime() - w3_startTime > (advanceInterval * 3.5) + 10 and w3_leaderPhase == 5) then
		w3_leaderPhase = 6
		w3_leaderTargetLane = 0
		Cmd_AttackMove(sg_enemyRow3_leader, mkr_playerBase, true)
	end
	
	--the following code moves the leader to the correct lane
	if(w3_leaderTargetLane == 1) then
		if(SGroup_ContainsSGroup(sg_enemyRow3_army1, sg_enemyRow3_leader, ALL) == false) then
			SGroup_RemoveGroup(sg_enemyRow3_army3, sg_enemyRow3_leader)
			SGroup_RemoveGroup(sg_enemyRow3_army5, sg_enemyRow3_leader)
			SGroup_AddGroup(sg_enemyRow3_army1, sg_enemyRow3_leader)
			if(SGroup_CountSpawned(sg_enemyRow3_army1) > 0) then
				Cmd_Move(sg_enemyRow3_leader, Util_GetPosition(sg_enemyRow3_army1), false)
			end
		elseif(Util_GetDistance(sg_enemyRow3_army1, sg_enemyRow3_leader) > 10) then
			if(SGroup_CountSpawned(sg_enemyRow3_army1) > 0) then
				Cmd_Move(sg_enemyRow3_leader, Util_GetPosition(sg_enemyRow3_army1), false)
			end
		end
	end
	
	if(w3_leaderTargetLane == 2) then
		SGroup_RemoveGroup(sg_enemyRow3_army1, sg_enemyRow3_leader)
		SGroup_RemoveGroup(sg_enemyRow3_army3, sg_enemyRow3_leader)
		SGroup_RemoveGroup(sg_enemyRow3_army5, sg_enemyRow3_leader)
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_leader, 2, w3_leaderTargetProgress, false, false)
		if(SGroup_CountSpawned(sg_enemyRow3_militia2) > 0) then
			HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_militia2, 2, w3_leaderTargetProgress, false, false)
		end
	end
	
	if(w3_leaderTargetLane == 3) then
		if(SGroup_ContainsSGroup(sg_enemyRow3_army3, sg_enemyRow3_leader, ALL) == false) then
			SGroup_RemoveGroup(sg_enemyRow3_army1, sg_enemyRow3_leader)
			SGroup_RemoveGroup(sg_enemyRow3_army5, sg_enemyRow3_leader)
			SGroup_AddGroup(sg_enemyRow3_army3, sg_enemyRow3_leader)
			if(SGroup_CountSpawned(sg_enemyRow3_army3) > 0) then
				Cmd_Move(sg_enemyRow3_leader, Util_GetPosition(sg_enemyRow3_army3), false)
			end
		elseif(Util_GetDistance(sg_enemyRow3_army3, sg_enemyRow3_leader) > 10) then
			if(SGroup_CountSpawned(sg_enemyRow3_army3) > 0) then
				Cmd_Move(sg_enemyRow3_leader, Util_GetPosition(sg_enemyRow3_army3), false)
			end
		end
	end
	
	if(w3_leaderTargetLane == 4) then
		SGroup_RemoveGroup(sg_enemyRow3_army1, sg_enemyRow3_leader)
		SGroup_RemoveGroup(sg_enemyRow3_army3, sg_enemyRow3_leader)
		SGroup_RemoveGroup(sg_enemyRow3_army5, sg_enemyRow3_leader)
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_leader, 4, w3_leaderTargetProgress, false, false)
		if(SGroup_CountSpawned(sg_enemyRow3_militia4) > 0) then
			HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_militia4, 4, w3_leaderTargetProgress, false, false)
		end
	end
	
	if(w3_leaderTargetLane == 5) then
		if(SGroup_ContainsSGroup(sg_enemyRow3_army5, sg_enemyRow3_leader, ALL) == false) then
			SGroup_RemoveGroup(sg_enemyRow3_army3, sg_enemyRow3_leader)
			SGroup_RemoveGroup(sg_enemyRow3_army1, sg_enemyRow3_leader)
			SGroup_AddGroup(sg_enemyRow3_army5, sg_enemyRow3_leader)
			if(SGroup_CountSpawned(sg_enemyRow3_army5) > 0) then
				Cmd_Move(sg_enemyRow3_leader, Util_GetPosition(sg_enemyRow3_army5), false)
			end
		elseif(Util_GetDistance(sg_enemyRow3_army5, sg_enemyRow3_leader) > 10) then
			if(SGroup_CountSpawned(sg_enemyRow3_army5) > 0) then
				Cmd_Move(sg_enemyRow3_leader, Util_GetPosition(sg_enemyRow3_army5), false)
			end
		end
	end
	
	
	
end

function HC_Agincourt_Wave3_CheckFit()
	
	--ignore groups with less than this many units for tracking progress
	local w1_minGroupCount = 5
	
	if(SGroup_CountSpawned(sg_enemyRow3_army1) >= w1_minGroupCount) then
		w3_lane1_fit = HC_Agincourt_Wave3_CheckLaneFit(SGroup_GetAvgPosition(sg_enemyRow3_army1), 1, SOBJ_Fit1)
	else
		w3_lane1_fit = 0
	end
	
	if(SGroup_CountSpawned(sg_enemyRow3_army3) >= w1_minGroupCount) then
		w3_lane3_fit = HC_Agincourt_Wave3_CheckLaneFit(SGroup_GetAvgPosition(sg_enemyRow3_army3), 3, SOBJ_Fit3)
	else
		w3_lane3_fit = 0
	end
	
	if(SGroup_CountSpawned(sg_enemyRow3_army5) >= w1_minGroupCount) then
		w3_lane5_fit = HC_Agincourt_Wave3_CheckLaneFit(SGroup_GetAvgPosition(sg_enemyRow3_army5), 5, SOBJ_Fit5)
	else
		w3_lane5_fit = 0
	end
	
	
	if(w3_lane1_fit > .5) then
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_army1, 1, nil, true, false)
	end
	if(w3_lane3_fit > .5) then
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_army3, 3, nil, true, false)
	end
	if(w3_lane5_fit > .5) then
		HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_army5, 5, nil, true, false)
	end
	
end

function HC_Agincourt_Wave3_SendBackToLane(sg_LaneSGroup, in_laneNumber, in_avgProgress, in_UseFormation, 
		in_UseAttackMove, in_DefensiveCircle1, in_DefensiveCircle2, in_CreateReticule)
	
	if(in_laneNumber == 1) then
		in_startMarker = mkr_frenchArmyS3_1
		in_endMarker = mkr_ArmyAttack1_3
	elseif(in_laneNumber == 2) then
		in_startMarker = mkr_frenchArmyS3_2
		in_endMarker = mkr_ArmyAttack2_3
	elseif(in_laneNumber == 3) then
		in_startMarker = mkr_frenchArmyS3_3
		in_endMarker = mkr_ArmyAttack3_3
	elseif(in_laneNumber == 4) then
		in_startMarker = mkr_frenchArmyS3_4
		in_endMarker = mkr_ArmyAttack4_3
	elseif(in_laneNumber == 5) then
		in_startMarker = mkr_frenchArmyS3_5
		in_endMarker = mkr_ArmyAttack5_3
	end
	
	if(sg_LaneSGroup ~= nil) then
		if(SGroup_CountSpawned(sg_LaneSGroup) > 0) then
			
			local attackingCount = 0
			for i = 1, SGroup_CountSpawned(sg_LaneSGroup) do
				local squad = SGroup_GetSquadAt(sg_LaneSGroup, i)
				if(Squad_IsAttacking(squad, 5)) then
					attackingCount = attackingCount + 1
				end
			end
			
			local pA = Util_GetPosition(in_startMarker)
			local pB = Util_GetPosition(in_endMarker)
			local distFromStart = Util_GetDistance(sg_LaneSGroup, in_startMarker)
			local distToEnd = Util_GetDistance(in_startMarker, in_endMarker)
			
			if(distFromStart < distToEnd) then
				if(attackingCount < SGroup_CountSpawned(sg_LaneSGroup) * .25) then
					
					--send group back to the average projected position
					local groupAveragePos = SGroup_GetAvgPosition(sg_LaneSGroup)
					local projectedPoint = HC_Agincourt_GetPointOnLane(pA, pB, groupAveragePos)
					
					--if we are given a target progress amount, use it instead of the current average position
					if(in_avgProgress ~= nil) then
						projectedPoint["x"] = (pB["x"] - pA["x"]) * in_avgProgress
						projectedPoint["z"] = (pB["z"] - pA["z"]) * in_avgProgress
						
						projectedPoint["x"] = projectedPoint["x"] + pA["x"]
						projectedPoint["z"] = projectedPoint["z"] + pA["z"]
					end
					
					
					--if either circle parameter is true, set units to a circle formation
					--this is so they can form a defensive circle around the cannon in each lane
					if(in_DefensiveCircle1 == true or in_DefensiveCircle2 == true) then
						--divide units into left and right and send them around so they don't collide with the cannon
						sg_circleHalfLeft = SGroup_CreateIfNotFound("sg_circleHalfLeft")
						SGroup_Clear(sg_circleHalfLeft)
						sg_circleHalfRight = SGroup_CreateIfNotFound("sg_circleHalfRight")
						SGroup_Clear(sg_circleHalfRight)
						
						local leftDividePos = SGroup_GetAvgPosition(sg_LaneSGroup)
						leftDividePos.x = leftDividePos.x + (15 * math.cos((3 * math.pi) / 4))
						leftDividePos.z = leftDividePos.z + (15 * math.sin((3 * math.pi) / 4))
						local rightDividePos = SGroup_GetAvgPosition(sg_LaneSGroup)
						rightDividePos.x = rightDividePos.x + (15 * math.cos((7 * math.pi) / 4))
						rightDividePos.z = rightDividePos.z + (15 * math.sin((7 * math.pi) / 4))
						
						for i = 1, SGroup_CountSpawned(sg_LaneSGroup) do
							local squad = SGroup_GetSquadAt(sg_LaneSGroup, i)
							SGroup_Single(sg_single, squad)
							
							if(Util_GetDistance(squad, leftDividePos) < Util_GetDistance(squad, rightDividePos)) then
								SGroup_Add(sg_circleHalfLeft, squad)
							else
								SGroup_Add(sg_circleHalfRight, squad)
							end
						end
						--in the first stage, we need to divide the sgroup into a left half and a right half
						if(in_DefensiveCircle1 == true) then
							for i = 1, SGroup_CountSpawned(sg_circleHalfLeft) do
								local squad = SGroup_GetSquadAt(sg_circleHalfLeft, i)
								SGroup_Single(sg_single, squad)
								local circleRad = (3 * math.pi) / 4
								local circlePos = Util_GetPosition(projectedPoint)
								circlePos.x = circlePos.x + (8 * math.cos(circleRad))
								circlePos.z = circlePos.z + (8 * math.sin(circleRad))
								
								Cmd_Move(sg_single, circlePos, false)
							end
							for i = 1, SGroup_CountSpawned(sg_circleHalfRight) do
								local squad = SGroup_GetSquadAt(sg_circleHalfRight, i)
								SGroup_Single(sg_single, squad)
								local circleRad = (7 * math.pi) / 4
								local circlePos = Util_GetPosition(projectedPoint)
								circlePos.x = circlePos.x + (8 * math.cos(circleRad))
								circlePos.z = circlePos.z + (8 * math.sin(circleRad))
								
								Cmd_Move(sg_single, circlePos, false)
							end
						end
						
						--modify circle radius based on which stage we're in (the 2nd stage is a larger circle)
						local circleRadius = 4
						if(in_DefensiveCircle2 == true) then
							circleRadius = 5
						end
						
						--set up units in a circle facing outward
						for i = 1, SGroup_CountSpawned(sg_circleHalfLeft) do
							--count is 1 greater than actual number so there's an empty space for unit pathing
							local modifiedCount = SGroup_CountSpawned(sg_circleHalfLeft) + 1
							local squad = SGroup_GetSquadAt(sg_circleHalfLeft, i)
							SGroup_Single(sg_single, squad)
							local circleRad = (((-i + .5) / modifiedCount) * (math.pi)) - (3 * math.pi) / 4
							local circlePos = Util_GetPosition(projectedPoint)
							circlePos.x = circlePos.x + (circleRadius * math.cos(circleRad))
							circlePos.z = circlePos.z + (circleRadius * math.sin(circleRad))
							
							local circlePosFacing = Util_GetPosition(projectedPoint)
							circlePosFacing.x = circlePos.x + (15 * math.cos(circleRad))
							circlePosFacing.z = circlePos.z + (15 * math.sin(circleRad))
							
							Cmd_FormationMove(sg_single, circlePos, true, false, circlePosFacing)
						end
						for i = 1, SGroup_CountSpawned(sg_circleHalfRight) do
							--count is 1 greater than actual number so there's an empty space for unit pathing
							local modifiedCount = SGroup_CountSpawned(sg_circleHalfRight) + 1
							local squad = SGroup_GetSquadAt(sg_circleHalfRight, i)
							SGroup_Single(sg_single, squad)
							local circleRad = (((i - .5) / modifiedCount) * (math.pi)) - (3 * math.pi) / 4
							local circlePos = Util_GetPosition(projectedPoint)
							circlePos.x = circlePos.x + (circleRadius * math.cos(circleRad))
							circlePos.z = circlePos.z + (circleRadius * math.sin(circleRad))
							
							local circlePosFacing = Util_GetPosition(projectedPoint)
							circlePosFacing.x = circlePos.x + (15 * math.cos(circleRad))
							circlePosFacing.z = circlePos.z + (15 * math.sin(circleRad))
							
							Cmd_FormationMove(sg_single, circlePos, true, false, circlePosFacing)
						end
					else
						--regular move orders if no defensive circle is needed
						if(in_UseFormation == true) then
							if(in_UseAttackMove == true) then
								Cmd_FormationAttackMove(sg_LaneSGroup, projectedPoint, false, false, in_endMarker)
							else
								Cmd_FormationMove(sg_LaneSGroup, projectedPoint, false, false, in_endMarker)
							end
						else
							if(in_UseAttackMove == true) then
								Cmd_AttackMove(sg_LaneSGroup, projectedPoint, false, false, in_endMarker)
							else
								Cmd_Move(sg_LaneSGroup, projectedPoint, false, false, in_endMarker)
							end
						end
					end
					
					if(in_CreateReticule == true) then
						--set reticule to mark the circle around the cannon
						local bp_reticule = BP_GetReticuleBlueprint("marquee_subtractive")
						local reticulePos = projectedPoint
						local size = 4.5
						
						if(in_laneNumber == 1) then
							if(cannonReticuleID1 ~= nil) then
								UI_ModalVisual_Destroy(cannonReticuleID1)
							end
							cannonReticuleID1 = UI_ModalVisual_CreateReticule(bp_reticule, size)
							UI_ModalVisual_SetPosition(cannonReticuleID1, reticulePos)
						end
						if(in_laneNumber == 3) then
							if(cannonReticuleID3 ~= nil) then
								UI_ModalVisual_Destroy(cannonReticuleID3)
							end
							cannonReticuleID3 = UI_ModalVisual_CreateReticule(bp_reticule, size)
							UI_ModalVisual_SetPosition(cannonReticuleID3, reticulePos)
						end
						if(in_laneNumber == 5) then
							if(cannonReticuleID5 ~= nil) then
								UI_ModalVisual_Destroy(cannonReticuleID5)
							end
							cannonReticuleID5 = UI_ModalVisual_CreateReticule(bp_reticule, size)
							UI_ModalVisual_SetPosition(cannonReticuleID5, reticulePos)
						end
					end
					----
				end
			end
		end
	end
end



function HC_Agincourt_Wave3_CheckLaneFit(in_Position, in_laneNumber, in_Objective)
	
	local in_startMarker = mkr_frenchArmyS1_1
	local in_endMarker = mkr_ArmyAttack1_4
	
	if(in_laneNumber == 1) then
		in_startMarker = mkr_frenchArmyS3_1
		in_endMarker = mkr_ArmyAttack1_4
	elseif(in_laneNumber == 3) then
		in_startMarker = mkr_frenchArmyS3_3
		in_endMarker = mkr_ArmyAttack3_4
	elseif(in_laneNumber == 5) then
		in_startMarker = mkr_frenchArmyS3_5
		in_endMarker = mkr_ArmyAttack5_4
	end
	
	local pA = Util_GetPosition(in_startMarker)
	local pB = Util_GetPosition(in_endMarker)
	local groupAveragePos = in_Position
	local projectedPoint = HC_Agincourt_GetPointOnLane(pA, pB, groupAveragePos)

	local distFromPath = Util_GetDistance(groupAveragePos, projectedPoint)
	
	if(in_Objective ~= nil) then
		Objective_SetProgressBar(in_Objective, (distFromPath / LANE_MAX_WIDTH))
	end
	return (distFromPath / LANE_MAX_WIDTH)
	
end

----------------------------


--increase size of inner reticule over time
function HC_Agincourt_Wave3_UpdateLeaderReticule()
	
	
	chargeUpTime = World_GetGameTime() - chargeUpStartTime
	if(chargeUpTime < gatherAroundTimeLimit) then
		
		--set reticule
		local bp_reticule = BP_GetReticuleBlueprint("ability_white_standard")
		local reticulePos = w1_leader_rallyPosition
		local size = 8 * (chargeUpTime / gatherAroundTimeLimit)
		
		Obj_SetProgress(SOBJ_W1LeaderRally.ID, (chargeUpTime / gatherAroundTimeLimit))
		
		if(rallyReticuleID2 ~= nil) then
			UI_ModalVisual_Destroy(rallyReticuleID2)
		end
		
		rallyReticuleID2 = UI_ModalVisual_CreateReticule(bp_reticule, size)
		UI_ModalVisual_SetPosition(rallyReticuleID2, reticulePos)
	else
		if(rallyReticuleID2 ~= nil) then
			UI_ModalVisual_Destroy(rallyReticuleID2)
		end
		Obj_SetProgressVisible(SOBJ_W1LeaderRally.ID, false)
		Obj_SetVisible(SOBJ_W1LeaderRally.ID, false)
		if(wave1PromotionLabel ~= nil) then
			Objective_RemoveUIElements(SOBJ_W1LeaderRally, wave1PromotionLabel)
		end
		Rule_RemoveMe()
	end
	
end

--gather units to be promoted around the leader
function HC_Agincourt_Wave3_GatherAroundLeader()
	
	sg_wave1_RallyUnits = SGroup_CreateIfNotFound("sg_wave1_RallyUnits")
	sg_wave1_PromotedUnits = SGroup_CreateIfNotFound("sg_wave1_PromotedUnits")
	
	if(SGroup_CountSpawned(sg_enemyRow3_leader) == 0) then
		Rule_RemoveMe()
		if(rallyReticuleID1 ~= nil) then
			UI_ModalVisual_Destroy(rallyReticuleID1)
		end
		
		return
	end
	
	chargeUpTime = World_GetGameTime() - chargeUpStartTime
	if(chargeUpTime > gatherAroundTimeLimit) then
		if(rallyReticuleID1 ~= nil) then
			UI_ModalVisual_Destroy(rallyReticuleID1)
		end
		Player_GetAllSquadsNearMarker(enemyPlayer, sg_wave1_RallyUnits, w1_leader_rallyPosition, 7)
		SGroup_Filter(sg_wave1_RallyUnits, SBP.FRENCH.UNIT_CHARLES_D_ALBRET_CMP_FRE, FILTER_REMOVE)
		
		--replace militia with men at arms
		sg_enemyRow3_menAtArms = SGroup_CreateIfNotFound("sg_enemyRow3_menAtArms")
		SGroup_Clear(sg_enemyRow3_menAtArms)
		--(iterate backwards so we can remove items)
		for i = SGroup_CountSpawned(sg_wave1_RallyUnits), 1, -1 do 
			local squad = SGroup_GetSquadAt(sg_wave1_RallyUnits, i)
			if(squad ~= nil) then
				local squadPosition = Util_GetPosition(squad)
				local squadFacing = Util_GetDirection(squad)
				Squad_DeSpawn(squad)
				local sbp_manatarms_fre = SBP.FRENCH.UNIT_MANATARMS_3_FRE
				if(conquerorModeActivated == true) then
					sbp_manatarms_fre = SBP.FRENCH.UNIT_MANATARMS_4_FRE
				end
				UnitEntry_DeploySquads(enemyPlayer, sg_enemyRow3_menAtArms, {sbp = sbp_manatarms_fre, numSquads = 1, facing = squadFacing }, squadPosition)
			end
		end
		Cmd_AttackMove(sg_enemyRow3_menAtArms, mkr_playerBase, false)
		
		Rule_RemoveMe()
		return
	end
	
	
	
end

function HC_Agincourt_Wave3_StartLeaderPromotion()
	if(Rule_Exists(HC_Agincourt_Wave3_UpdateLeaderCombat) == false) then
		Rule_AddInterval(HC_Agincourt_Wave3_UpdateLeaderCombat, .5)
	end
end

function HC_Agincourt_Wave3_UpdateLeaderCombat()
	--return if there is no leader
	if(SGroup_CountSpawned(sg_enemyRow3_leader) == 0) then
		Rule_RemoveMe()
		if(rallyReticuleID1 ~= nil) then
			UI_ModalVisual_Destroy(rallyReticuleID1)
		end
		return
	end
	
	w1_leader_rallyPosition = SGroup_GetAvgPosition(sg_enemyRow3_leader)
	--if leader is still moving, get its destination
	local leaderSquad = SGroup_GetSquadAt(sg_enemyRow3_leader, 1)
	if(Squad_HasDestination(leaderSquad) == true) then
		w1_leader_rallyPosition = Squad_GetDestination(leaderSquad)
	end
	
	sg_wave1_RallyUnits = SGroup_CreateIfNotFound("sg_wave1_RallyUnits")
	Player_GetAllSquadsNearMarker(enemyPlayer, sg_wave1_RallyUnits, w1_leader_rallyPosition, 10)
	SGroup_Filter(sg_wave1_RallyUnits, SBP.FRENCH.UNIT_CHARLES_D_ALBRET_CMP_FRE, FILTER_REMOVE)
	
	if(SGroup_CountSpawned(sg_wave1_RallyUnits) > 0) then
		
		--set reticule
		local bp_reticule = BP_GetReticuleBlueprint("marquee_additive")
		local reticulePos = w1_leader_rallyPosition
		local size = 8
		if(rallyReticuleID1 ~= nil) then
			UI_ModalVisual_Destroy(rallyReticuleID1)
		end
		rallyReticuleID1 = UI_ModalVisual_CreateReticule(bp_reticule, size)
		UI_ModalVisual_SetPosition(rallyReticuleID1, reticulePos)
		
		size = 0
		if(rallyReticuleID2 ~= nil) then
			UI_ModalVisual_Destroy(rallyReticuleID2)
		end
		rallyReticuleID2 = UI_ModalVisual_CreateReticule(bp_reticule, size)
		UI_ModalVisual_SetPosition(rallyReticuleID2, reticulePos)
		
		--continue gathering units
		chargeUpStartTime = World_GetGameTime()
		Rule_AddInterval(HC_Agincourt_Wave3_GatherAroundLeader, .5)
		Rule_AddInterval(HC_Agincourt_Wave3_UpdateLeaderReticule, .125)
		
		Obj_SetVisible(SOBJ_W1LeaderRally.ID, true)
		Obj_SetProgressVisible(SOBJ_W1LeaderRally.ID, true)
		wave1PromotionLabel = Objective_AddUIElements(SOBJ_W1LeaderRally, reticulePos, false, "$11268423", true, -5) --Battlefield Promotion
		
		chargeUpStartTime = World_GetGameTime()
		
		Rule_RemoveMe()
		return
	end
	
end

