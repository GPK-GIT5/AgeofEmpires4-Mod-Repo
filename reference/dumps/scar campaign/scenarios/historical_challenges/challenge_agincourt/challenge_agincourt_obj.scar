function HC_Agincourt_InitObjectiveUI()
	
	
	enemyTotalArmyCount = SGroup_CountSpawned(sg_wave1_AllUnits) + SGroup_CountSpawned(sg_wave2_AllUnits) + SGroup_CountSpawned(sg_wave3_AllUnits)
	
end

function HC_Agincourt_InitObjectiveUI2()
	
	--this is called after a slight delay to hide this objective
	Obj_SetProgressVisible(SOBJ_W1LeaderRally.ID, false)
	Obj_SetVisible(SOBJ_W1LeaderRally.ID, false)
	
end

function HC_Agincourt_UpdateObjectiveUI()
	
	--fail medal objectives when too much time has passed
	if(conquerorModeActivated == false and Objective_IsComplete(OBJ_Victory) == false) then
		if(missionTime > GOLD_MEDAL_TIME and Objective_IsStarted(OBJ_GoldMedal) and goldMedalFailed == false) then
			Objective_Fail(OBJ_GoldMedal, true, true)
			Objective_Show(OBJ_GoldMedal, false, false)
			goldMedalFailed = true
			--start next medal objective
			Objective_Register(OBJ_SilverMedal)
			Objective_Start(OBJ_SilverMedal)
		end
		if(missionTime > SILVER_MEDAL_TIME and Objective_IsStarted(OBJ_SilverMedal) and silverMedalFailed == false) then
			Objective_Fail(OBJ_SilverMedal, true, true)
			Objective_Show(OBJ_SilverMedal, false, false)
			silverMedalFailed = true
			--start next medal objective
			Objective_Register(OBJ_BronzeMedal)
			Objective_Start(OBJ_BronzeMedal)
		end
	end
	
	if Objective_IsStarted(OBJ_Conqueror) and enemyTotalArmyCount > 0 then
		
		enemyCurrentArmyCount = SGroup_CountSpawned(sg_wave1_AllUnits) + SGroup_CountSpawned(sg_wave2_AllUnits) + SGroup_CountSpawned(sg_wave3_AllUnits)
	
		enemyRemainingRatio = (enemyCurrentArmyCount / enemyTotalArmyCount)
		--Obj_SetProgress(OBJ_Army.ID, enemyRemainingRatio)
		
	end
	
	if (Objective_IsStarted(OBJ_Conqueror) and conquerorModeActivated == false and conquerorModeFailed == false) then
		if Objective_IsTimerSet(OBJ_Conqueror) then
			if(Objective_GetTimerSeconds(OBJ_Conqueror) <= 0) then
				Sound_Play2D(MUS_STING_NEGATIVE)
				Objective_Fail(OBJ_Conqueror, false, false)
				--reduce the number of units that are promoted in the remainder of wave 1
				wave1RallyUnitMax = wave1RallyUnitMaxConqFailed
				--set bool to prevent this sound from playing repeatedly
				conquerorModeFailed = true
			end
		end
	end
	
	--update tug of war progress bar for vanguard
	if(Objective_IsStarted(SOBJ_AttackWave1Strength)) then
		sg_playerCombatUnits = SGroup_CreateIfNotFound("sg_playerCombatUnits")
		if(SGroup_CountSpawned(sg_wave1_AllUnits) > 0) then
			
			sg_playerCombatUnits = Player_GetSquads(localPlayer)
			SGroup_Filter(sg_playerCombatUnits, "scar_military", FILTER_KEEP)
			if(SGroup_CountSpawned(sg_playerCombatUnits) > 0) then
				local playerCost = SGroup_GetResourceCost(sg_playerCombatUnits)
				local enemyCost = SGroup_GetResourceCost(sg_wave1_AllUnits)
				if(playerCost + enemyCost > 0) then
					local costRatio = playerCost / (playerCost + enemyCost)
					Obj_SetProgress(SOBJ_AttackWave1Strength.ID, costRatio)
				end
			end
		end
	end
	--update tug of war progress bar for main army
	if(Objective_IsStarted(SOBJ_AttackWave2Strength)) then
		sg_playerCombatUnits = SGroup_CreateIfNotFound("sg_playerCombatUnits")
		if(SGroup_CountSpawned(sg_wave2_AllUnits) > 0) then
			
			sg_playerCombatUnits = Player_GetSquads(localPlayer)
			SGroup_Filter(sg_playerCombatUnits, "scar_military", FILTER_KEEP)
			if(SGroup_CountSpawned(sg_playerCombatUnits) > 0) then
				local playerCost = SGroup_GetResourceCost(sg_playerCombatUnits)
				local enemyCost = SGroup_GetResourceCost(sg_wave2_AllUnits)
				if(playerCost + enemyCost > 0) then
					local costRatio = playerCost / (playerCost + enemyCost)
					Obj_SetProgress(SOBJ_AttackWave2Strength.ID, costRatio)
				end
			end
		end
	end
	--update tug of war progress bar for reserves
	if(Objective_IsStarted(SOBJ_AttackWave3Strength)) then
		sg_playerCombatUnits = SGroup_CreateIfNotFound("sg_playerCombatUnits")
		if(SGroup_CountSpawned(sg_wave3_AllUnits) > 0) then
			
			sg_playerCombatUnits = Player_GetSquads(localPlayer)
			SGroup_Filter(sg_playerCombatUnits, "scar_military", FILTER_KEEP)
			if(SGroup_CountSpawned(sg_playerCombatUnits) > 0) then
				local playerCost = SGroup_GetResourceCost(sg_playerCombatUnits)
				local enemyCost = SGroup_GetResourceCost(sg_wave3_AllUnits)
				if(playerCost + enemyCost > 0) then
					local costRatio = playerCost / (playerCost + enemyCost)
					Obj_SetProgress(SOBJ_AttackWave3Strength.ID, costRatio)
				end
			end
		end
	end
	
end


function HC_Agincourt_CheckWave1Ended()
	
	if(SGroup_CountSpawned(sg_wave1_AllUnits) == 0) then
		HC_Agincourt_FinishWave1Attack()
		Rule_RemoveMe()
		return true
	end
	
	
	return false
end

function HC_Agincourt_FinishWave1Attack()
	
	
	UI_ModalVisual_Destroy(wave1Label1)
	UI_ModalVisual_Destroy(wave1Label2)
	UI_ModalVisual_Destroy(wave1Label3)
	UI_ModalVisual_Destroy(wave1Label4)
	UI_ModalVisual_Destroy(wave1Label5)
	
	
	HC_Agincourt_Wave1_Start()
	
	
	Objective_Register(SOBJ_AttackWave2)
	Objective_Start(SOBJ_AttackWave2, true, true)
	
	--remove labels for this wave
	if(wave1Label1 ~= nil) then
		Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label1)
	end
	if(wave1Label2 ~= nil) then
		Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label2)
	end
	if(wave1Label3 ~= nil) then
		Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label3)
	end
	if(wave1Label4 ~= nil) then
		Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label4)
	end
	if(wave1Label5 ~= nil) then
		Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label5)
	end
	
end

function HC_Agincourt_CheckWave2Ended()
	
	--check if wave has been defeated
	if(SGroup_CountSpawned(sg_wave2_AllUnits) == 0) then
		HC_Agincourt_CompleteWave2()
		return true
	end
	
	return false
end

function HC_Agincourt_CompleteWave2()
	
	
	-- Mark Objective as Complete
	Objective_Complete(SOBJ_AttackWave2, false, false)
	UI_ModalVisual_Destroy(wave1Label1)
	UI_ModalVisual_Destroy(wave1Label2)
	UI_ModalVisual_Destroy(wave1Label3)
	UI_ModalVisual_Destroy(wave1Label4)
	UI_ModalVisual_Destroy(wave1Label5)
	
	
	HC_Agincourt_Wave2_Start()
	
	Objective_Register(SOBJ_AttackWave3)
	Objective_Start(SOBJ_AttackWave3, true, true)
	
	
	HC_Agincourt_LaunchWave3Attack()
	
end


function HC_Agincourt_LaunchWave3Attack()
	
	
	UI_ModalVisual_Destroy(wave2Label1)
	UI_ModalVisual_Destroy(wave2Label2)
	UI_ModalVisual_Destroy(wave2Label3)
	UI_ModalVisual_Destroy(wave2Label4)
	UI_ModalVisual_Destroy(wave2Label5)
	
	
	Rule_AddOneShot(HC_Agincourt_Wave3_Start, 0)
	
end

function HC_Agincourt_CheckWave3Ended()
	
	--check if wave has been defeated
	if(SGroup_CountSpawned(sg_wave3_AllUnits) == 0) then
		return true
	end
	
	return false
end


