-- Reinforcements data and functions

import("MissionOMatic/MissionOMatic.scar")		-- this imports the Cardinal scripts as well
import("MissionOMatic/MissionOMatic_utility.scar")

-- This function picks the correct unit table based on the reinforce wave and conqueror mode activation
function Montgisard_ReinforceData(reinforce_n, conqueror_mode)
	
	Montgisard_InitReinforceData()
	
	local table = {
	}
	
	-- Check the reinforce wave number and assign the correct data table
	if reinforce_n == 1 then
		if conqueror_mode == true then
			table = Montgisard_GetConquerorUnits(tableWave1)
		elseif conqueror_mode == false then
			table = tableWave1
		end
	elseif reinforce_n == 2 then
		if conqueror_mode == true then
			table = Montgisard_GetConquerorUnits(tableWave2)
		elseif conqueror_mode == false then
			table = tableWave2
		end
	elseif reinforce_n == 3 then
		if conqueror_mode == true then
			table = Montgisard_GetConquerorUnits(tableWave3)
		elseif conqueror_mode == false then
			table = tableWave3
		end
	elseif reinforce_n == 4 then
		if conqueror_mode == true then
			table = Montgisard_GetConquerorUnits(tableWave4)
		elseif conqueror_mode == false then
			table = tableWave4
		end
	elseif reinforce_n == 5 then
		if conqueror_mode == true then
			table = Montgisard_GetConquerorUnits(tableWave5)
		elseif conqueror_mode == false then
			table = tableWave5
		end
	elseif reinforce_n == 6 then
		if conqueror_mode == true then
			table = Montgisard_GetConquerorUnits(tableWave6)
		elseif conqueror_mode == false then
			table = tableWave6
		end
	end
	
	return table
	
end

-- Get the correct amount of units when conqueror mode is active
function Montgisard_GetConquerorUnits(unitTable)
	
	local table = unitTable
	
	table.fortress1.archers.numSquads = table.fortress1.archers.numSquads*2 -- + math.floor((table.fortress1.archers.numSquads/2)+0.5)
	table.fortress1.infantry.numSquads = table.fortress1.infantry.numSquads*2 -- + math.floor((table.fortress1.infantry.numSquads/2)+0.5)
	table.fortress1.cavalry.numSquads = table.fortress1.cavalry.numSquads*2 -- + math.floor((table.fortress1.cavalry.numSquads/2)+0.5)
	table.fortress1.siege.numSquads = table.fortress1.siege.numSquads*2 -- + math.floor((table.fortress1.siege.numSquads/2)+0.5)
	
	table.fortress2.archers.numSquads = table.fortress2.archers.numSquads*2 -- + math.floor((table.fortress2.archers.numSquads/2)+0.5)
	table.fortress2.infantry.numSquads = table.fortress2.infantry.numSquads*2 -- + math.floor((table.fortress2.infantry.numSquads/2)+0.5)
	table.fortress2.cavalry.numSquads = table.fortress2.cavalry.numSquads*2 -- + math.floor((table.fortress2.cavalry.numSquads/2)+0.5)
	table.fortress2.siege.numSquads = table.fortress2.siege.numSquads*2 -- + math.floor((table.fortress2.siege.numSquads/2)+0.5)
	
	table.fortress3.archers.numSquads = table.fortress3.archers.numSquads*2 -- + math.floor((table.fortress3.archers.numSquads/2)+0.5)
	table.fortress3.infantry.numSquads = table.fortress3.infantry.numSquads*2 -- + math.floor((table.fortress3.infantry.numSquads/2)+0.5)
	table.fortress3.cavalry.numSquads = table.fortress3.cavalry.numSquads*2 -- + math.floor((table.fortress3.cavalry.numSquads/2)+0.5)
	table.fortress3.siege.numSquads = table.fortress3.siege.numSquads*2 -- + math.floor((table.fortress3.siege.numSquads/2)+0.5)
	
	table.fortress4.archers.numSquads = table.fortress4.archers.numSquads*2 -- + math.floor((table.fortress4.archers.numSquads/2)+0.5)
	table.fortress4.infantry.numSquads = table.fortress4.infantry.numSquads*2 -- + math.floor((table.fortress4.infantry.numSquads/2)+0.5)
	table.fortress4.cavalry.numSquads = table.fortress4.cavalry.numSquads*2 -- + math.floor((table.fortress4.cavalry.numSquads/2)+0.5)
	table.fortress4.siege.numSquads = table.fortress4.siege.numSquads*2 -- + math.floor((table.fortress4.siege.numSquads/2)+0.5)
	
	-- Additional units for specific conqueror waves
	if unitTable == tableWave2 then
		table.fortress1.infantry.numSquads = table.fortress1.infantry.numSquads+2
		table.fortress2.archers.numSquads = table.fortress2.archers.numSquads+2
		table.fortress3.archers.numSquads = table.fortress3.archers.numSquads+2
		table.fortress4.infantry.numSquads = table.fortress4.infantry.numSquads+2
		table.fortress4.cavalry.numSquads = table.fortress4.cavalry.numSquads+2
	elseif unitTable == tableWave3 then
		table.fortress1.infantry.numSquads = table.fortress1.infantry.numSquads+2
		table.fortress1.cavalry.numSquads = table.fortress1.cavalry.numSquads+2
		table.fortress2.archers.numSquads = table.fortress2.archers.numSquads+2
		table.fortress2.cavalry.numSquads = table.fortress2.cavalry.numSquads+2
		table.fortress3.archers.numSquads = table.fortress3.archers.numSquads+2
		table.fortress3.cavalry.numSquads = table.fortress3.cavalry.numSquads+2
		table.fortress4.archers.numSquads = table.fortress4.archers.numSquads+2
		table.fortress4.cavalry.numSquads = table.fortress4.cavalry.numSquads+2
	elseif unitTable == tableWave4 then
		table.fortress2.archers.numSquads = table.fortress2.archers.numSquads+2
		table.fortress2.cavalry.numSquads = table.fortress2.cavalry.numSquads+2
		table.fortress3.infantry.numSquads = table.fortress3.infantry.numSquads+2
		table.fortress3.cavalry.numSquads = table.fortress3.cavalry.numSquads+2
		table.fortress4.archers.numSquads = table.fortress4.archers.numSquads+2
		table.fortress4.cavalry.numSquads = table.fortress4.cavalry.numSquads+2
	elseif unitTable == tableWave5 then
		table.fortress2.archers.numSquads = table.fortress2.archers.numSquads+2
		table.fortress3.cavalry.numSquads = table.fortress3.cavalry.numSquads+2
		table.fortress4.infantry.numSquads = table.fortress4.infantry.numSquads+2
	elseif unitTable == tableWave6 then
		table.fortress2.cavalry.numSquads = table.fortress2.cavalry.numSquads+2
		table.fortress3.archers.numSquads = table.fortress3.archers.numSquads+2
		table.fortress4.archers.numSquads = table.fortress4.archers.numSquads+2
		table.fortress4.infantry.numSquads = table.fortress4.infantry.numSquads+2
	end
	------------------------------------------------
	
	return table
	
end

function Montgisard_AddPingAndSound()
	
	UI_CreateEventCue("$11266809", "Enemy Reinforcements", "high_priority_negative", "icons/event_queue_high_priority_large", "sfx_ui_event_queue_high_priority_play", ECV_Title, 10)
	if Util_GetPlayerOwner(eg_SacredSite_1) ~= localPlayer then
		pingID_ss1 = Objective_AddPing(OBJ_SacredSitesPrimary, mkr_sacredsite_1)
		Rule_AddOneShot(Montgisard_RemovePing, 5, {id = pingID_ss1})
	end
	if Util_GetPlayerOwner(eg_SacredSite_2) ~= localPlayer then
		pingID_ss2 = Objective_AddPing(OBJ_SacredSitesPrimary, mkr_sacredsite_2)
		Rule_AddOneShot(Montgisard_RemovePing, 5, {id = pingID_ss2})
	end
	if Util_GetPlayerOwner(eg_SacredSite_3) ~= localPlayer then
		pingID_ss3 = Objective_AddPing(OBJ_SacredSitesPrimary, mkr_sacredsite_3)
		Rule_AddOneShot(Montgisard_RemovePing, 5, {id = pingID_ss3})
	end
	if Util_GetPlayerOwner(eg_SacredSite_4) ~= localPlayer then
		pingID_ss4 = Objective_AddPing(OBJ_SacredSitesPrimary, mkr_sacredsite_4)
		Rule_AddOneShot(Montgisard_RemovePing, 5, {id = pingID_ss4})
	end
	
end

function Montgisard_RemovePing(context, data)
	Objective_RemovePing(OBJ_SacredSitesPrimary, data.id)
end

-- Get the correct blueprint for the appropriate unit tier based on the number of the attack
function Montgisard_GetAttackUnitBP(unitType, attackNumber, attackOrigin)
	
	local unitBP = nil
	local tableWaves = {
		tableWave1,
		tableWave2,
		tableWave3,
		tableWave4,
		tableWave5,
	}
	
	if attackOrigin == mkr_sacredsite_1 then
		for i = 1, 5 do
			if i == attackNumber then
				if unitType == "archers" then
					unitBP = tableWaves[i].fortress1.archers.sbp
				elseif unitType == "infantry" then
					unitBP = tableWaves[i].fortress1.infantry.sbp
				elseif unitType == "cavalry" then
					unitBP = tableWaves[i].fortress1.cavalry.sbp
				elseif unitType == "siege" then
					unitBP = tableWaves[i].fortress1.siege.sbp
				end
			end
		end
	elseif attackOrigin == mkr_sacredsite_2 then
		for i = 1, 5 do
			if i == attackNumber then
				if unitType == "archers" then
					unitBP = tableWaves[i].fortress2.archers.sbp
				elseif unitType == "infantry" then
					unitBP = tableWaves[i].fortress2.infantry.sbp
				elseif unitType == "cavalry" then
					unitBP = tableWaves[i].fortress2.cavalry.sbp
				elseif unitType == "siege" then
					unitBP = tableWaves[i].fortress2.siege.sbp
				end
			end
		end
	elseif attackOrigin == mkr_sacredsite_3 then
		for i = 1, 5 do
			if i == attackNumber then
				if unitType == "archers" then
					unitBP = tableWaves[i].fortress3.archers.sbp
				elseif unitType == "infantry" then
					unitBP = tableWaves[i].fortress3.infantry.sbp
				elseif unitType == "cavalry" then
					unitBP = tableWaves[i].fortress3.cavalry.sbp
				elseif unitType == "siege" then
					unitBP = tableWaves[i].fortress3.siege.sbp
				end
			end
		end
	elseif attackOrigin == mkr_sacredsite_4 then
		for i = 1, 5 do
			if i == attackNumber then
				if unitType == "archers" then
					unitBP = tableWaves[i].fortress4.archers.sbp
				elseif unitType == "infantry" then
					unitBP = tableWaves[i].fortress4.infantry.sbp
				elseif unitType == "cavalry" then
					unitBP = tableWaves[i].fortress4.cavalry.sbp
				elseif unitType == "siege" then
					unitBP = tableWaves[i].fortress4.siege.sbp
				end
			end
		end
	end
	return unitBP
end

-- Get the correct spawn point marker based on unit type and what site the attack originated from
function Montgisard_GetAttackUnitSpawnPoint(unitType, attackOrigin)
	
	local spawnPoint = nil
	
	local fortress1 = {
		mkr_archery_1,
		mkr_barracks_1,
		mkr_stable_1,
		mkr_siege_1,
	}
	local fortress2 = {
		mkr_archery_2,
		mkr_barracks_2,
		mkr_stable_2,
		mkr_siege_2,
	}
	local fortress3 = {
		mkr_archery_3,
		mkr_barracks_3,
		mkr_stable_3,
		mkr_siege_3,
	}
	local fortress4 = {
		mkr_archery_4,
		mkr_barracks_4,
		mkr_stable_4,
		mkr_castle_4,
	}
	
	if attackOrigin == mkr_sacredsite_1 then
		if unitType == "archers" then
			spawnPoint = fortress1[1]
		elseif unitType == "infantry" then
			spawnPoint = fortress1[2]
		elseif unitType == "cavalry" then
			spawnPoint = fortress1[3]
		elseif unitType == "siege" then
			spawnPoint = fortress1[4]
		end
	elseif attackOrigin == mkr_sacredsite_2 then
		if unitType == "archers" then
			spawnPoint = fortress2[1]
		elseif unitType == "infantry" then
			spawnPoint = fortress2[2]
		elseif unitType == "cavalry" then
			spawnPoint = fortress2[3]
		elseif unitType == "siege" then
			spawnPoint = fortress2[4]
		end
	elseif attackOrigin == mkr_sacredsite_3 then
		if unitType == "archers" then
			spawnPoint = fortress3[1]
		elseif unitType == "infantry" then
			spawnPoint = fortress3[2]
		elseif unitType == "cavalry" then
			spawnPoint = fortress3[3]
		elseif unitType == "siege" then
			spawnPoint = fortress3[4]
		end
	elseif attackOrigin == mkr_sacredsite_4 then
		if unitType == "archers" then
			spawnPoint = fortress4[1]
		elseif unitType == "infantry" then
			spawnPoint = fortress4[2]
		elseif unitType == "cavalry" then
			spawnPoint = fortress4[3]
		elseif unitType == "siege" then
			spawnPoint = fortress4[4]
		end
	end
	
	return spawnPoint
	
end

-- Get the correct amount of units based on unit type and the number of the attack
function Montgisard_GetAttackUnitStrength(unitType, attackNumber, attackOrigin, attackTarget)
	
	local totalUnits = {
	}
	
	-- If the target is the player base, spawn less units
	if attackTarget == mkr_player_tc then
		totalUnits = {
			12,
			12,
			16,
			12,
			12,
		}
	else
		totalUnits = {
			20,
			24,
			28,
			20,
			20,
		}
	end
	
	local unitStrength = nil
	
	if attackOrigin == mkr_sacredsite_1 then
		if conquerorActivated == true then
			if unitType == "archers" then
				unitStrength = attackStrenghtCM/4
			elseif unitType == "infantry" then
				unitStrength = attackStrenghtCM/2
			elseif unitType == "cavalry" then
				unitStrength = attackStrenghtCM/4
			elseif unitType == "siege" then
				unitStrength = attackNumber-1
			end
		else
			if attackNumber >= 6 then
				if unitType == "archers" then
					unitStrength = attackStrenghtPostBronze/4
				elseif unitType == "infantry" then
					unitStrength = attackStrenghtPostBronze/2
				elseif unitType == "cavalry" then
					unitStrength = attackStrenghtPostBronze/4
				elseif unitType == "siege" then
					-- If the target is the player tc, do not spawn additional siege
					if attackTarget == mkr_player_tc then
						unitStrength = 0
					else
						unitStrength = 1
					end
				end
			else
				for i = 1, 5 do
					if i == attackNumber then
						if unitType == "archers" then
							unitStrength = totalUnits[i]/4
						elseif unitType == "infantry" then
							unitStrength = totalUnits[i]/2
						elseif unitType == "cavalry" then
							unitStrength = totalUnits[i]/4
						elseif unitType == "siege" then
							-- If the target is the player tc, spawn only 1 siege
							if attackTarget == mkr_player_tc then
								if attackNumber == 1 then
									unitStrength = 0
								else
									unitStrength = 1
								end
							else
								unitStrength = attackNumber-1
							end
						end
					end
				end
			end
		end
	elseif attackOrigin == mkr_sacredsite_2 then
		if conquerorActivated == true then
			if unitType == "archers" then
				unitStrength = attackStrenghtCM/2
			elseif unitType == "infantry" then
				unitStrength = attackStrenghtCM/4
			elseif unitType == "cavalry" then
				unitStrength = attackStrenghtCM/4
			elseif unitType == "siege" then
				unitStrength = attackNumber-1
			end
		else
			if attackNumber >= 6 then
				if unitType == "archers" then
					unitStrength = attackStrenghtPostBronze/2
				elseif unitType == "infantry" then
					unitStrength = attackStrenghtPostBronze/4
				elseif unitType == "cavalry" then
					unitStrength = attackStrenghtPostBronze/4
				elseif unitType == "siege" then
					unitStrength = 1
				end
			else
				for i = 1, 5 do
					if i == attackNumber then
						if unitType == "archers" then
							unitStrength = totalUnits[i]/2
						elseif unitType == "infantry" then
							unitStrength = totalUnits[i]/4
						elseif unitType == "cavalry" then
							unitStrength = totalUnits[i]/4
						elseif unitType == "siege" then
							unitStrength = attackNumber-1
						end
					end
				end
			end
		end
	elseif attackOrigin == mkr_sacredsite_3 then
		if conquerorActivated == true then
			if unitType == "archers" then
				unitStrength = attackStrenghtCM/4
			elseif unitType == "infantry" then
				unitStrength = attackStrenghtCM/4
			elseif unitType == "cavalry" then
				unitStrength = attackStrenghtCM/2
			elseif unitType == "siege" then
				unitStrength = attackNumber-1
			end
		else
			if attackNumber >= 6 then
				if unitType == "archers" then
					unitStrength = attackStrenghtPostBronze/4
				elseif unitType == "infantry" then
					unitStrength = attackStrenghtPostBronze/4
				elseif unitType == "cavalry" then
					unitStrength = attackStrenghtPostBronze/2
				elseif unitType == "siege" then
					unitStrength = 1
				end
			else
				for i = 1, 5 do
					if i == attackNumber then
						if unitType == "archers" then
							unitStrength = totalUnits[i]/4
						elseif unitType == "infantry" then
							unitStrength = totalUnits[i]/4
						elseif unitType == "cavalry" then
							unitStrength = totalUnits[i]/2
						elseif unitType == "siege" then
							unitStrength = attackNumber-1
						end
					end
				end
			end
		end
	elseif attackOrigin == mkr_sacredsite_4 then
		if conquerorActivated == true then
			if unitType == "archers" then
				unitStrength = attackStrenghtCM/4
			elseif unitType == "infantry" then
				unitStrength = attackStrenghtCM/4
			elseif unitType == "cavalry" then
				unitStrength = attackStrenghtCM/2
			elseif unitType == "siege" then
				unitStrength = attackNumber-1
			end
		else
			if attackNumber >= 6 then
				if unitType == "archers" then
					unitStrength = attackStrenghtPostBronze/4
				elseif unitType == "infantry" then
					unitStrength = attackStrenghtPostBronze/4
				elseif unitType == "cavalry" then
					unitStrength = attackStrenghtPostBronze/2
				elseif unitType == "siege" then
					unitStrength = 1
				end
			else
				for i = 1, 5 do
					if i == attackNumber then
						if unitType == "archers" then
							unitStrength = totalUnits[i]/4
						elseif unitType == "infantry" then
							unitStrength = totalUnits[i]/4
						elseif unitType == "cavalry" then
							unitStrength = totalUnits[i]/2
						elseif unitType == "siege" then
							unitStrength = attackNumber-1
						end
					end
				end
			end
		end
	end
	
	return unitStrength
	
end

-- Get the correct marker path based on start and end of the attack
-- Set pathType as 1 if you want to get the actual attack path or set it as 2 if you just want to get the path to spawn the minimap arrows
-- (DEFAULT = 1)
function Montgisard_GetAttackPath(pathType, pathStart, pathEnd)
	
	local path = {	
	}
	
	local attackPath = {
	}
	
	if pathType ~= 2 then
		pathType = 1
	end
	
	if pathStart == mkr_sacredsite_1 and pathEnd == mkr_sacredsite_2 then
		path = { mkr_path12_5, mkr_path12_4, mkr_path12_3, mkr_path12_2, mkr_path12_1 }
		attackPath = {mkr_attackpoint_7, mkr_attackpoint_6, mkr_attackpoint_5, mkr_attackpoint_4, mkr_attackpoint_3, mkr_attackpoint_2, mkr_attackpoint_1 }
		
	elseif pathStart == mkr_sacredsite_2 and pathEnd == mkr_sacredsite_1 then
		path = { mkr_path12_1, mkr_path12_2, mkr_path12_3, mkr_path12_4, mkr_path12_5 }
		attackPath = {mkr_attackpoint_1, mkr_attackpoint_2, mkr_attackpoint_3, mkr_attackpoint_4, mkr_attackpoint_5, mkr_attackpoint_6, mkr_attackpoint_7 }
		
	elseif pathStart == mkr_sacredsite_1 and pathEnd == mkr_sacredsite_3 then
		path = { mkr_path13_6, mkr_path13_5, mkr_path13_4, mkr_path13_3, mkr_path13_2, mkr_path13_1 }
