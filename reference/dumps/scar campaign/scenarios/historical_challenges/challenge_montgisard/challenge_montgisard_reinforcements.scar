	elseif pathStart == mkr_sacredsite_3 and pathEnd == mkr_sacredsite_4 then
		path = { mkr_path34_7, mkr_path34_6, mkr_path34_5, mkr_path34_4, mkr_path34_3, mkr_path34_2, mkr_path34_1 }
		attackPath = {mkr_attackpoint_15, mkr_attackpoint_14, mkr_attackpoint_16, mkr_attackpoint_17, mkr_attackpoint_18, mkr_attackpoint_19, mkr_attackpoint_20, mkr_attackpoint_22, mkr_attackpoint_23, mkr_attackpoint_24, mkr_attackpoint_25 }
		
	elseif pathStart == mkr_sacredsite_4 and pathEnd == mkr_sacredsite_3 then
		path = { mkr_path34_1, mkr_path34_2, mkr_path34_3, mkr_path34_4, mkr_path34_5, mkr_path34_6, mkr_path34_7 }
		attackPath = {mkr_attackpoint_25, mkr_attackpoint_24, mkr_attackpoint_23, mkr_attackpoint_22, mkr_attackpoint_20, mkr_attackpoint_19, mkr_attackpoint_18, mkr_attackpoint_17, mkr_attackpoint_16, mkr_attackpoint_14, mkr_attackpoint_15 }
		
	elseif pathStart == mkr_sacredsite_2 and pathEnd == mkr_sacredsite_4 then
		path = { mkr_path24_6, mkr_path24_5, mkr_path24_4, mkr_path24_3, mkr_path24_2, mkr_path24_1 }
		attackPath = {mkr_attackpoint_1, mkr_attackpoint_2, mkr_attackpoint_3, mkr_attackpoint_4, mkr_attackpoint_5, mkr_attackpoint_21, mkr_attackpoint_20, mkr_attackpoint_22, mkr_attackpoint_23, mkr_attackpoint_24, mkr_attackpoint_25 }
		
	elseif pathStart == mkr_sacredsite_4 and pathEnd == mkr_sacredsite_2 then
		path = { mkr_path24_1, mkr_path24_2, mkr_path24_3, mkr_path24_4, mkr_path24_5, mkr_path24_6 }
		attackPath = {mkr_attackpoint_25, mkr_attackpoint_24, mkr_attackpoint_23, mkr_attackpoint_22, mkr_attackpoint_20, mkr_attackpoint_21, mkr_attackpoint_5, mkr_attackpoint_4, mkr_attackpoint_3, mkr_attackpoint_2, mkr_attackpoint_1 }
		
	elseif pathStart == mkr_sacredsite_1 and pathEnd == mkr_sacredsite_4 then
		path = { mkr_path14_5, mkr_path14_4, mkr_path14_3, mkr_path14_2, mkr_path14_1 }
		attackPath = {mkr_attackpoint_7, mkr_attackpoint_6, mkr_attackpoint_5, mkr_attackpoint_21, mkr_attackpoint_20, mkr_attackpoint_22, mkr_attackpoint_23, mkr_attackpoint_24, mkr_attackpoint_25 }
		
	elseif pathStart == mkr_sacredsite_4 and pathEnd == mkr_sacredsite_1 then
		path = { mkr_path14_1, mkr_path14_2, mkr_path14_3, mkr_path14_4, mkr_path14_5 }
		attackPath = {mkr_attackpoint_25, mkr_attackpoint_24, mkr_attackpoint_23, mkr_attackpoint_22, mkr_attackpoint_20, mkr_attackpoint_21, mkr_attackpoint_5, mkr_attackpoint_6, mkr_attackpoint_7 }
		
	elseif pathStart == mkr_sacredsite_2 and pathEnd == mkr_sacredsite_3 then
		path = { mkr_path23_9, mkr_path23_8, mkr_path23_7, mkr_path23_6, mkr_path23_5, mkr_path23_4, mkr_path23_3, mkr_path23_2, mkr_path23_1 }
		attackPath = {mkr_attackpoint_1, mkr_attackpoint_2, mkr_attackpoint_3, mkr_attackpoint_4, mkr_attackpoint_5, mkr_attackpoint_21, mkr_attackpoint_20, mkr_attackpoint_19, mkr_attackpoint_18, mkr_attackpoint_17, mkr_attackpoint_16, mkr_attackpoint_14, mkr_attackpoint_15 }
		
	elseif pathStart == mkr_sacredsite_3 and pathEnd == mkr_sacredsite_2 then
		path = { mkr_path23_1, mkr_path23_2, mkr_path23_3, mkr_path23_4, mkr_path23_5, mkr_path23_6, mkr_path23_7, mkr_path23_8, mkr_path23_9 }
		attackPath = {mkr_attackpoint_15, mkr_attackpoint_14, mkr_attackpoint_16, mkr_attackpoint_17, mkr_attackpoint_18, mkr_attackpoint_19, mkr_attackpoint_20, mkr_attackpoint_21, mkr_attackpoint_5, mkr_attackpoint_4, mkr_attackpoint_3, mkr_attackpoint_2, mkr_attackpoint_1 }
	
	elseif pathStart == mkr_sacredsite_1 and pathEnd == mkr_player_tc then
		path = { mkr_toBase_1, mkr_toBase_2, mkr_toBase_3 }
		attackPath = { mkr_toBase_rally, mkr_toBase_attack1, mkr_toBase_attack2, mkr_toBase_attack3 }
		
	end
	
	if pathType == 2 then
		return path
	else
		return attackPath
	end
	
end

function Montgisard_InitReinforceGroups()
	
	sg_SS1_archers = SGroup_CreateIfNotFound("sg_SS1_archers")
	sg_SS2_archers = SGroup_CreateIfNotFound("sg_SS2_archers")
	sg_SS3_archers = SGroup_CreateIfNotFound("sg_SS3_archers")
	sg_SS4_archers = SGroup_CreateIfNotFound("sg_SS4_archers")
	
	sg_SS1_infantry = SGroup_CreateIfNotFound("sg_SS1_infantry")
	sg_SS2_infantry = SGroup_CreateIfNotFound("sg_SS2_infantry")
	sg_SS3_infantry = SGroup_CreateIfNotFound("sg_SS3_infantry")
	sg_SS4_infantry = SGroup_CreateIfNotFound("sg_SS4_infantry")
	
	sg_SS1_cavalry = SGroup_CreateIfNotFound("sg_SS1_cavalry")
	sg_SS2_cavalry = SGroup_CreateIfNotFound("sg_SS2_cavalry")
	sg_SS3_cavalry = SGroup_CreateIfNotFound("sg_SS3_cavalry")
	sg_SS4_cavalry = SGroup_CreateIfNotFound("sg_SS4_cavalry")
	
	sg_SS1_siege = SGroup_CreateIfNotFound("sg_SS1_siege")
	sg_SS2_siege = SGroup_CreateIfNotFound("sg_SS2_siege")
	sg_SS3_siege = SGroup_CreateIfNotFound("sg_SS3_siege")
	sg_SS4_siege = SGroup_CreateIfNotFound("sg_SS4_siege")
	
end

