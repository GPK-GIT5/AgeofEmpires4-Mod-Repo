			cavalry = {sbp = SBP.ABBASID_HA_01.UNIT_KNIGHT_4_ABB_HA_01, numSquads = 4, sgroup = sg_SS3_cavalry }, -- [3] Fortress 3 cavalry // 15
			siege = {sbp = SBP.ABBASID_HA_01.UNIT_SPRINGALD_3_ABB_HA_01, numSquads = 1, sgroup = sg_SS3_siege },  -- [4] Fortress 3 siege // 1
		},
		fortress4 = {
			archers = {sbp = SBP.ABBASID_HA_01.UNIT_CROSSBOWMAN_4_ABB_HA_01, numSquads = 3, sgroup = sg_SS4_archers },  -- [1] Fortress 4 archers
			infantry = {sbp = SBP.ABBASID_HA_01.UNIT_SPEARMAN_4_ABB_HA_01, numSquads = 3, sgroup = sg_SS4_infantry },  -- [2] Fortress 4 infantry // 15
			cavalry = {sbp = SBP.ABBASID_HA_01.UNIT_KNIGHT_4_ABB_HA_01, numSquads = 4, sgroup = sg_SS4_cavalry }, -- [3] Fortress 4 cavalry // 15
			siege = {sbp = SBP.ABBASID_HA_01.UNIT_MANGONEL_3_ABB_HA_01, numSquads = 1, sgroup = sg_SS4_siege },  -- [4] Fortress 4 siege // 2
		},
	}
end

-- Given a table of max 2 unit types and a marker path, creates a patrol along that path.
-- Size 1 and 2 are how many units per type to spawn (Default if left empty = 3)
function Montgisard_CreatePatrol(units, sgroup, path, pathReverse, size1, size2)
	
	if size == nil then
		size = 3
	end
	
	if units[2] == nil then
		units[2] = units[1]
	end
	
	local patrol = {
		unitTable = units,
		sgroup = sgroup,
		markers = path,
		markers_r = pathReverse,
		size1 = size1,
		size2 = size2,
		reverse = false,
	}
	
	UnitEntry_DeploySquads(enemyPlayer, patrol.sgroup, {
			{type = patrol.unitTable[1], numSquads = patrol.size1 },
			{type = patrol.unitTable[2], numSquads = patrol.size2 }}, patrol.markers[1])
	
	Modify_UnitSpeedWhenNotInCombat(patrol.sgroup, WALK_SPEED, MUT_Set)
--	Remove_UnitSpeedInCombatModifier()
	
	for i, marker in ipairs(patrol.markers) do
		SGroup_AttackMove(patrol.sgroup, marker, true)
	end
	
	--Track patrol
	Rule_AddInterval(Montgisard_TrackPatrol, 2, { patrol = patrol })
	
end

function  Montgisard_TrackPatrol(context, data)
	
	local patrol = data.patrol

	if SGroup_CountSpawned(patrol.sgroup) > 0 then
		if SGroup_IsIdle(patrol.sgroup, true) then
			--the patrol has reached the end of its route
			patrol.reverse = not patrol.reverse
			if patrol.reverse == false then
				for i, marker in ipairs(patrol.markers) do
					SGroup_AttackMove(patrol.sgroup, marker, true)
				end
			elseif patrol.reverse == true then
				for i, marker in ipairs(patrol.markers_r) do
					SGroup_AttackMove(patrol.sgroup, marker, true)
				end
			end
		end
	else
		--the patrol is dead
		Rule_RemoveMe()
	end
end

-- Bonus units spawn at the starting TC on age up
function Montgisard_BonusUnitsOnAgeUp(context, data)
	
	local sg_ageUpUnits = SGroup_CreateIfNotFound("sg_ageUpUnits")
	local unitsData = {
		sbp = nil,
		numSquads = 10,
		}
	SGroup_Clear(sg_ageUpUnits)
	
	if data.age == AGE_FEUDAL then
		if Player_HasUpgrade(localPlayer, BP_GetUpgradeBlueprint("upgrade_age_dark_com_1_tem")) then
			unitsData.sbp = SBP.TEMPLAR.UNIT_KNIGHT_HOSPITALLER_2_TEM
		elseif Player_HasUpgrade(localPlayer, BP_GetUpgradeBlueprint("upgrade_age_dark_com_2_tem")) then
			unitsData.sbp = SBP.TEMPLAR.UNIT_CHEVALIER_CONFRERE_2_TEM
		elseif Player_HasUpgrade(localPlayer, BP_GetUpgradeBlueprint("upgrade_age_dark_com_3_tem")) then
			unitsData.sbp = SBP.TEMPLAR.UNIT_SERJEANT_2_TEM
		end
	elseif data.age == AGE_CASTLE then
		if Player_HasUpgrade(localPlayer, BP_GetUpgradeBlueprint("upgrade_age_feudal_com_1_tem")) then
			unitsData.sbp = SBP.TEMPLAR.UNIT_HEAVY_SPEARMAN_3_TEM
		elseif Player_HasUpgrade(localPlayer, BP_GetUpgradeBlueprint("upgrade_age_feudal_com_2_tem")) then
			unitsData.sbp = SBP.TEMPLAR.UNIT_GENOESE_CROSSBOW_3_TEM
		elseif Player_HasUpgrade(localPlayer, BP_GetUpgradeBlueprint("upgrade_age_feudal_com_3_tem")) then
			unitsData.sbp = SBP.TEMPLAR.UNIT_GENITOUR_3_TEM
		end
	elseif data.age == AGE_IMPERIAL then
		if Player_HasUpgrade(localPlayer, BP_GetUpgradeBlueprint("upgrade_age_castle_com_1_tem")) then
			unitsData.sbp = SBP.TEMPLAR.UNIT_SZLATCHA_KNIGHT_4_TEM
		elseif Player_HasUpgrade(localPlayer, BP_GetUpgradeBlueprint("upgrade_age_castle_com_2_tem")) then
			unitsData.sbp = SBP.TEMPLAR.UNIT_TEUTONIC_KNIGHT_4_TEM
		elseif Player_HasUpgrade(localPlayer, BP_GetUpgradeBlueprint("upgrade_age_castle_com_3_tem")) then
			unitsData.sbp = SBP.TEMPLAR.UNIT_CONDOTTIERO_4_TEM
		end
	end
	
	UnitEntry_DeploySquads(localPlayer, sg_ageUpUnits, unitsData, mkr_player_tc)
	SGroup_MoveAndFace(sg_ageUpUnits, mkr_player_army2)
	UI_CreateEventCueClickable(-1, 10, 0, 0, "$11269235", Loc_Empty(), "high_priority", "", "sfx_ui_event_queue_high_priority_play", 255, 255, 255, 255, ECV_Queue, __DoNothing)
	UI_CreateMinimapBlip(mkr_player_army2, 15, "general")
			
end

-- Get the correct unit sbps for sacred sites bonuses based on player's current age
function Montgisard_GetUnitSBP(unitType)
	
	local currentAge = Player_GetCurrentAge(localPlayer)
	local unitSBP = nil
	
	if unitType == "scar_archer" then
		if currentAge == AGE_DARK or currentAge == AGE_FEUDAL then
			unitSBP = SBP.TEMPLAR.UNIT_ARCHER_2_TEM
		elseif currentAge == AGE_CASTLE then
			unitSBP = SBP.TEMPLAR.UNIT_ARCHER_3_TEM
		elseif currentAge == AGE_IMPERIAL then
			unitSBP = SBP.TEMPLAR.UNIT_ARCHER_4_TEM
		end
	elseif unitType == "scar_spearman" then
		if currentAge == AGE_DARK then
			unitSBP = SBP.TEMPLAR.UNIT_SPEARMAN_1_TEM
		elseif currentAge == AGE_FEUDAL then
			unitSBP = SBP.TEMPLAR.UNIT_SPEARMAN_2_TEM
		elseif currentAge == AGE_CASTLE then
			unitSBP = SBP.TEMPLAR.UNIT_SPEARMAN_3_TEM
		elseif currentAge == AGE_IMPERIAL then
			unitSBP = SBP.TEMPLAR.UNIT_SPEARMAN_4_TEM
		end
	elseif unitType == "scar_horseman" then
		if currentAge == AGE_DARK or currentAge == AGE_FEUDAL then
			unitSBP = SBP.TEMPLAR.UNIT_HORSEMAN_2_TEM
		elseif currentAge == AGE_CASTLE then
			unitSBP = SBP.TEMPLAR.UNIT_HORSEMAN_3_TEM
		elseif currentAge == AGE_IMPERIAL then
			unitSBP = SBP.TEMPLAR.UNIT_HORSEMAN_4_TEM
		end
	elseif unitType == "scar_knight" then
		if currentAge == AGE_DARK or currentAge == AGE_FEUDAL or currentAge == AGE_CASTLE then
			unitSBP = SBP.TEMPLAR.UNIT_KNIGHT_TEMPLAR_3_TEM
		elseif currentAge == AGE_IMPERIAL then
			unitSBP = SBP.TEMPLAR.UNIT_KNIGHT_TEMPLAR_4_TEM
		end
	-- Commanderies units
	elseif unitType == "scar_hospitaller" then
		if currentAge == AGE_DARK or currentAge == AGE_FEUDAL then
			unitSBP = SBP.TEMPLAR.UNIT_KNIGHT_HOSPITALLER_2_TEM
		elseif currentAge == AGE_CASTLE then
			unitSBP = SBP.TEMPLAR.UNIT_KNIGHT_HOSPITALLER_3_TEM
		elseif currentAge == AGE_IMPERIAL then
			unitSBP = SBP.TEMPLAR.UNIT_KNIGHT_HOSPITALLER_4_TEM
		end
	elseif unitType == "scar_genoese" then
		if currentAge == AGE_DARK or currentAge == AGE_FEUDAL or currentAge == AGE_CASTLE then
			unitSBP = SBP.TEMPLAR.UNIT_GENOESE_CROSSBOW_3_TEM
		elseif currentAge == AGE_IMPERIAL then
			unitSBP = SBP.TEMPLAR.UNIT_GENOESE_CROSSBOW_4_TEM
		end
	elseif unitType == "scar_genitour" then
		if currentAge == AGE_DARK or currentAge == AGE_FEUDAL or currentAge == AGE_CASTLE then
			unitSBP = SBP.TEMPLAR.UNIT_GENITOUR_3_TEM
		elseif currentAge == AGE_IMPERIAL then
			unitSBP = SBP.TEMPLAR.UNIT_GENITOUR_4_TEM
		end
	end
	
	return unitSBP
	
end

-- Setup tents for sacres sites bonuses
function Montgisard_SetSacredSiteBonuses()
	
	local abilityID = BP_GetAbilityBlueprintByPbgID(131480)
	
	for i = 1, 4 do
		EGroup_SetTargetingType(tentGroups[i], Targeting_None)
		EGroup_CallEntityFunction(tentGroups[i], Entity_RemoveAbility, abilityID)
		EGroup_SetInvulnerable(tentGroups[i], true, -1)
	end
	
end

-- Spawn units at the sacred sites tents
function Montgisard_SacredSitesUnits(context, data)
	
	local scarType = nil
	if data.site == 1 then
		scarType = "scar_spearman"
	elseif data.site == 2 then
		scarType = "scar_archer"
	elseif data.site == 3 then
		scarType = "scar_horseman"
	elseif data.site == 4 then
		scarType = "scar_knight"
	end
	
	local sg_units = SGroup_CreateIfNotFound("sg_units")
	local unitsData = {
		sbp = Montgisard_GetUnitSBP(scarType),
		numSquads = data.numSquads,
		}
	SGroup_Clear(sg_units)
	
	local popDiff = (Player_GetCurrentPopulationCap(localPlayer, CT_Personnel) - Player_GetCurrentPopulation(localPlayer, CT_Personnel))
	
	-- Update the number of spawned unit based on player popcap
	if popDiff >= 3 then
		-- spawn the full 3 units
	elseif popDiff == 2 then
		unitsData.numSquads = unitsData.numSquads - 1
	elseif popDiff == 1 then
		unitsData.numSquads = unitsData.numSquads - 2
	elseif popDiff <= 0 then
		unitsData.numSquads = unitsData.numSquads - 3
	end
	
	local rallyPoints = nil -- Table with all rally points set
	local entityID = nil -- Entity reference for tents
	
	local entityID = EGroup_GetEntityAt(tentOnly[data.site], 1)
	local rallyPoints = Entity_GetRallyPointPositions(entityID)
			
	-- Use the rally point of the tent if players has set one, else use a default one
	if rallyPoints.position1 ~= nil then
		data.rally = rallyPoints.position1
	end
	
	if Player_GetTotalPopulation(localPlayer) < 200 then
		UnitEntry_DeploySquads(localPlayer, sg_units, unitsData, data.spawn)
--		SGroup_MoveAndFace(sg_units, data.rally)
		SGroup_Move(sg_units, data.rally)
	end
	
end

-- Updates the sacred sites bonuses by creating/deleting rules for spawning bonus units
function Montgisard_UpdateSacredSitesBonuses()
	
	local currentSites_player = Montgisard_GetCurrentSites(localPlayer)
	local currentSites_enemy = Montgisard_GetCurrentSites(enemyPlayer)
	local currentSites_neutral = Montgisard_GetCurrentSites("neutral")
	local sg_bonusUnits = SGroup_CreateIfNotFound("sg_bonusUnits")
	
	local bonusUnits = {
		Montgisard_GetUnitSBP("scar_hospitaller"),
		Montgisard_GetUnitSBP("scar_genoese"),
		Montgisard_GetUnitSBP("scar_genitour"),
		SBP.TEMPLAR.UNIT_SZLATCHA_KNIGHT_4_TEM,
	}
	
	local bonusAmount = {
		10,
		5,
		5,
		5,
	}
	
	local allSites = {
		mkr_sacredsite_1,
		mkr_sacredsite_2,
		mkr_sacredsite_3,
		mkr_sacredsite_4,
	}
	
	unitSpawn = {
		mkr_SSbonus1_spawn,
		mkr_SSbonus2_spawn,
		mkr_SSbonus3_spawn,
		mkr_SSbonus4_spawn,
	}
	unitRally = {
		mkr_SSbonus1_rally,
		mkr_SSbonus2_rally,
		mkr_SSbonus3_rally,
		mkr_SSbonus4_rally,
	}

	for i = 1, 4 do
		
		if Table_Contains(currentSites_player, allSites[i]) then
			if firstCapture[i] == false then
				SGroup_Clear(sg_bonusUnits)
				UnitEntry_DeploySquads(localPlayer, sg_bonusUnits, {{sbp = bonusUnits[i], numSquads = bonusAmount[i] }}, unitSpawn[i])
				SGroup_MoveAndFace(sg_bonusUnits, unitRally[i])
				firstCapture[i] = true
			end
			if bonusRules[i] == nil then
				bonusRules[i] = Rule_AddInterval(Montgisard_SacredSitesUnits, 90, {site = i, numSquads = 3, spawn = unitSpawn[i], rally = unitRally[i]})
				EGroup_SetPlayerOwner(tentGroups[i], localPlayer)
			end
		elseif Table_Contains(currentSites_enemy, allSites[i]) or Table_Contains(currentSites_neutral, allSites[i]) then
			if bonusRules[i] ~= nil then
				Rule_RemoveWithID(bonusRules[i])
				EGroup_SetWorldOwned(tentGroups[i])
				bonusRules[i] = nil
			end
		end
		
	end
	
end