-- Battle of Montgisard

import("MissionOMatic/MissionOMatic.scar")		-- this imports the Cardinal scripts as well
--import("training/coretraininggoals.scar")
--import("training/campaigntraininggoals.scar")
import("challenge_montgisard_objectives.scar")
import("challenge_montgisard_reinforcements.scar")
import("challenge_montgisard_data.scar")

function Mission_SetupVariables()
	
	-- Initialize data
	Montgisard_InitData()
	Montgisard_InitPatrolPaths()
	Montgisard_AttackGroupsData()
	Montgisard_SetupLocations() -- Get Sacred Sites positions
	
	-- Test
	sg_test = SGroup_CreateIfNotFound("sg_test")
	sg_test2 = SGroup_CreateIfNotFound("sg_test2")
	
end

function Mission_SetupPlayers()
	
	-- Set up Players
	localPlayer = Missionomatic_InitPlayer(1, { name = "$11265367", currentAge = AGE_DARK, maxAge = AGE_IMPERIAL, color = 1 })
	enemyPlayer = Missionomatic_InitPlayer(2, { name = "$11253242", currentAge = AGE_DARK, maxAge = AGE_DARK, color = 2 })
	enemyPlayer_2 = Missionomatic_InitPlayer(3, { name = "$11253242", currentAge = AGE_IMPERIAL, maxAge = AGE_IMPERIAL, color = 2 })
	neutralPlayer = Missionomatic_InitPlayer(4, { name = "$11265367", currentAge = AGE_DARK, maxAge = AGE_CASTLE, color = 3 })
	mapPlayer = Missionomatic_InitPlayer(5, { name = "$11253242", currentAge = AGE_IMPERIAL, maxAge = AGE_IMPERIAL, color = 2 })
	allyPlayer = Missionomatic_InitPlayer(6, { name = "$11265367", currentAge = AGE_IMPERIAL, maxAge = AGE_IMPERIAL, color = 3 })
	
	--Enables campaign AI for enemyPlayer, disable AI for the other players
	AI_Enable(enemyPlayer, true)
	AI_Enable(enemyPlayer_2, true)
	AI_Enable(neutralPlayer, true)
	AI_Enable(mapPlayer, true)
	AI_Enable(allyPlayer, true)
	AI_SetPersonality(enemyPlayer, "default_campaign")
	AI_SetPersonality(enemyPlayer_2, "default_campaign")
	AI_SetPersonality(neutralPlayer, "default_campaign")
	AI_SetPersonality(mapPlayer, "default_campaign")
	AI_SetPersonality(allyPlayer, "default_campaign")
	
	-- Deactivate the condensed objectives by default
	UI_SetPlayerDataContext(localPlayer, { hide_condensed_objectives_override = true})
		
	Montgisard_SetupDiplomacy()
	Montgisard_SetupModifiers()
	
end

function Mission_SetRestrictions()

	Player_SetEntityProductionAvailability(localPlayer, EBP.TEMPLAR.BUILDING_DEFENSE_PALISADE_BASTION_TEM, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(localPlayer, EBP.TEMPLAR.BUILDING_DEFENSE_PALISADE_GATE_TEM, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(localPlayer, EBP.TEMPLAR.BUILDING_DEFENSE_PALISADE_WALL_TEM, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(localPlayer, EBP.TEMPLAR.BUILDING_DEFENSE_STONE_TOWER_TEM, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(localPlayer, EBP.TEMPLAR.BUILDING_DEFENSE_STONE_WALL_BASTION_TEM, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(localPlayer, EBP.TEMPLAR.BUILDING_DEFENSE_STONE_WALL_GATE_TEM, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(localPlayer, EBP.TEMPLAR.BUILDING_DEFENSE_STONE_WALL_TEM, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(localPlayer, EBP.TEMPLAR.BUILDING_DOCK_TEM, ITEM_REMOVED)
	
end


function Mission_PreInit()
	
	Rule_AddGlobalEvent(Montgisard_OnEnemyBuildingDamage, GE_DamageReceived)
	
end

function Mission_Preset()
	
	
end



function Mission_Start()
	
	startTime = World_GetGameTime()
	timeSinceStart = World_GetGameTime()
	
	Montgisard_SetSacredSiteBonuses()
	
	-- Initialize Objectives 
	Rule_AddOneShot(Montgisard_InitObjectives, 1)
	
	-- For testing
--	Rule_AddOneShot(Montgisard_Test, 10)
	
	-- Register callbacks for global events
	Rule_AddInterval(Montgisard_CheckForIdleAroundSS, 30)
	
	-- Reveal a small area around every Sacred Site
	FOW_PlayerRevealArea(localPlayer, sacredSite_position1, 12, -1)
	FOW_PlayerRevealArea(localPlayer, sacredSite_position2, 12, -1)
	FOW_PlayerRevealArea(localPlayer, sacredSite_position3, 12, -1)
	FOW_PlayerRevealArea(localPlayer, sacredSite_position4, 12, -1)
	
end

function Montgisard_SpawnPointsOfInterest()
	
	-- Neutral Rams + Lumber camps
	sg_rams = SGroup_CreateIfNotFound("sg_rams")
