function Montgisard_ConquerorTriggerSite()
	
	FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_extrasite), 20, -1)
	
	EGroup_SetPlayerOwner(eg_extraSite, enemyPlayer)
	EGroup_SetTargetingType(eg_extraSite, Targeting_Automatic)
	EGroup_SetInvulnerable(eg_extraSite, false, -1)
	
	EGroup_CompleteUpgrade(eg_extraTower1, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	SpawnGarrisonsIntoEGroup(eg_extraTower1, enemyPlayer, "scar_archer", 5)
	
	EGroup_CompleteUpgrade(eg_extraTower2, UPG.COMMON.UPGRADE_OUTPOST_SPRINGALD)
	EGroup_CompleteUpgrade(eg_extraTower2, UPG.COMMON.UPGRADE_OUTPOST_STONE)
	
	local sg_spawnedUnits = SGroup_CreateIfNotFound("sg_spawnedUnits")
	
	-- Front enemy group
	UnitEntry_DeploySquads(enemyPlayer, sg_extraSite_units, {{sbp = SBP.ABBASID_HA_01.UNIT_MANATARMS_3_ABB_HA_01, numSquads = extraSite_numSquads.front, sgroup = sg_spawnedUnits }}, mkr_extraTower1)
	Cmd_FormationAttackMove(sg_spawnedUnits, mkr_extra_front, true)
	SGroup_Clear(sg_spawnedUnits)
	
	-- Side enemy groups
	UnitEntry_DeploySquads(enemyPlayer, sg_extraSite_units, {{sbp = SBP.ABBASID_HA_01.UNIT_CROSSBOWMAN_3_ABB_HA_01, numSquads = extraSite_numSquads.side1, sgroup = sg_spawnedUnits }}, mkr_extraTower1)
	Cmd_FormationAttackMove(sg_spawnedUnits, mkr_extra_side1, true)
	SGroup_Clear(sg_spawnedUnits)
	UnitEntry_DeploySquads(enemyPlayer, sg_extraSite_units, {{sbp = SBP.ABBASID_HA_01.UNIT_ARCHER_3_ABB_HA_01, numSquads = extraSite_numSquads.side2, sgroup = sg_spawnedUnits }}, mkr_extraTower2)
	Cmd_FormationAttackMove(sg_spawnedUnits, mkr_extra_side2, true)
	SGroup_Clear(sg_spawnedUnits)
	
	-- Back enemy group
	UnitEntry_DeploySquads(enemyPlayer, sg_extraSite_units, {{sbp = SBP.ABBASID_HA_01.UNIT_SPEARMAN_3_ABB_HA_01, numSquads = extraSite_numSquads.back, sgroup = sg_spawnedUnits }}, mkr_extraTower2)
	Cmd_FormationAttackMove(sg_spawnedUnits, mkr_extra_back, true)
	SGroup_Clear(sg_spawnedUnits)
	
end

function Montgisard_UpdatePointsOfInterest()
	
	-- Check for the rams POI completion criteria
	if ramsComplete == false then
		if SGroup_CountSpawned(sg_rams_defenders) == 0 then
			FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_poi_rams), 25, -1)
			SGroup_SetPlayerOwner(sg_rams, localPlayer)
			SGroup_SetPlayerOwner(sg_neutralVills_Rams, localPlayer)
			EGroup_SetPlayerOwner(eg_neutralCamp_Rams, localPlayer)
			AssignVillagersToWood(sg_onWood, false, true)
			UI_CreateEventCueClickable(-1, 10, 0, 0, "$11266810", Loc_Empty(), "high_priority", "", "sfx_ui_event_queue_high_priority_play", 255, 255, 255, 255, ECV_Title | ECV_Queue, __DoNothing)
			completedPOI = completedPOI + 1
			Objective_SetCounter(OBJ_PointsOfInterest, completedPOI, totalPOI)
			ramsComplete = true
		end
	end
	
	-- Check for the mangonels POI completion criteria [REMOVED]
--	if mangonelsComplete == false then
--		if SGroup_CountSpawned(sg_mangonels_defenders) == 0 then
--			FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_poi_mangonels), 25, -1)
--			SGroup_SetPlayerOwner(sg_mangonels, localPlayer)
--			UI_CreateEventCueClickable(-1, 10, 0, 0, "$11266810", Loc_Empty(), "high_priority", "", "sfx_ui_event_queue_high_priority_play", 255, 255, 255, 255, ECV_Title | ECV_Queue, __DoNothing)
--			completedPOI = completedPOI + 1
--			Objective_SetCounter(OBJ_PointsOfInterest, completedPOI, totalPOI)
--			mangonelsComplete = true
--		end
--	end
	
	-- Check for the monastery POI completion criteria (No longer counted as POI)
	if monasteryComplete == false then
		if  Player_AreSquadsNearMarker(localPlayer, mkr_poi_monastery) == true then
			FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_poi_monastery), 25, -1)
			SGroup_SetPlayerOwner(sg_monastery, localPlayer)
			EGroup_SetPlayerOwner(eg_Monastery, localPlayer)
			Sound_Play2D(MUS_STING_BONUS_OBJ_COMPLETE)
--			UI_CreateEventCueClickable(-1, 10, 0, 0, "$11266810", Loc_Empty(), "high_priority", "", "sfx_ui_event_queue_high_priority_play", 255, 255, 255, 255, ECV_Title | ECV_Queue, __DoNothing)
--			completedPOI = completedPOI + 1
--			Objective_SetCounter(OBJ_PointsOfInterest, completedPOI, totalPOI)
			monasteryComplete = true
		end
	end
	
	-- Check for the fortress POI completion criteria
	if fortressComplete == false then
		if  Player_AreSquadsNearMarker(localPlayer, mkr_poi_fortress) == true then
			FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_poi_fortress), 30, -1)
			if SGroup_CountSpawned(sg_fortress) == 0 then
				EGroup_SetPlayerOwner(eg_Fortress, localPlayer)
				-- Updates the fortress total count on the UI
				local totalFortresses = Player_GetStateModelInt(localPlayer, "total_keep_count")
				Player_SetStateModelInt(localPlayer, "total_keep_count", totalFortresses+1)
				UI_CreateEventCueClickable(-1, 10, 0, 0, "$11266810", Loc_Empty(), "high_priority", "", "sfx_ui_event_queue_high_priority_play", 255, 255, 255, 255, ECV_Title | ECV_Queue, __DoNothing)
				completedPOI = completedPOI + 1
				Objective_SetCounter(OBJ_PointsOfInterest, completedPOI, totalPOI)
				fortressComplete = true
			end
		end
	end
	
	-- Check for the mining camp POI completion criteria
	if miningcampComplete == false then
		if  Player_AreSquadsNearMarker(localPlayer, mkr_poi_miningcamp) == true then
			FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_poi_miningcamp), 25, -1)
			if SGroup_CountSpawned(sg_miningcamp_enemies) == 0 then
				SGroup_SetPlayerOwner(sg_neutralVills, localPlayer)
				EGroup_SetPlayerOwner(eg_neutralCamp, localPlayer)
				AssignVillagersToGold(sg_onGold, false, false)
				AssignVillagersToStone(sg_onStone, false, false)
				UI_CreateEventCueClickable(-1, 10, 0, 0, "$11266810", Loc_Empty(), "high_priority", "", "sfx_ui_event_queue_high_priority_play", 255, 255, 255, 255, ECV_Title | ECV_Queue, __DoNothing)
				completedPOI = completedPOI + 1
				Objective_SetCounter(OBJ_PointsOfInterest, completedPOI, totalPOI)
				miningcampComplete = true
			end
		end
	end
	
	-- Check for the mining camp 2 POI completion criteria [REMOVED]
--	if miningcampComplete_2 == false then
--		if  Player_AreSquadsNearMarker(localPlayer, mkr_poi_miningcamp_2) == true then
--			FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_poi_miningcamp_2), 25, -1)
--			if SGroup_CountSpawned(sg_miningcamp2_enemies) == 0 then
