	-- Sacred Site 3	
	unitsTable = {
		{bp = SBP.ABBASID_HA_01.UNIT_KNIGHT_3_ABB_HA_01, pos = mkr_SS3_spawn1, num = 5},
		{bp = SBP.ABBASID_HA_01.UNIT_ARCHER_3_ABB_HA_01, pos = mkr_SS3_spawn2, num = 10},
