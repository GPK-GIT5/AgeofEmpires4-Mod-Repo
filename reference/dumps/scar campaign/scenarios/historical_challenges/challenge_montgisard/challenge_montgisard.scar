			{sbp = SBP.ABBASID_HA_01.UNIT_ARCHER_2_ABB_HA_01, numSquads = 4, spawn = mkr_poi_ramsDefenders3 },
			{sbp = SBP.ABBASID_HA_01.UNIT_HORSEMAN_4_ABB_HA_01, numSquads = 1, spawn = mkr_poi_ramsDefenders4 }}, mkr_poi_ramsDefenders2)
	UnitEntry_DeploySquads(neutralPlayer, sg_neutralVills_Rams, {
			{sbp = SBP.TEMPLAR.UNIT_VILLAGER_1_TEM, numSquads = 2, sgroup = sg_onWood, spawn = mkr_poi_rams_lumber1 },
