function Montgisard_Test()

end

-- Spawn neutral vills around the map
function Montgisard_SpawnNeutralVills()
	
	local sg_vills = SGroup_CreateIfNotFound("sg_vills")
	local food_modifier = Modifier_Create(MAT_EntityType, "resource_entity_harvest_rate_food", MUT_Multiplication, false, 0, SBP.TEMPLAR.UNIT_VILLAGER_1_TEM)
	Modifier_ApplyToPlayer(food_modifier, neutralPlayer, 0)

	local villsToSpawn = {
		mkr_farm1,
		mkr_farm2,
		mkr_farm3,
		mkr_farm4,
		mkr_farm5,
		mkr_farm6,
		mkr_farm7,
		mkr_farm8,
		mkr_farm9,
		mkr_farm10
	}
	
	for i = 1, #villsToSpawn do
		UnitEntry_DeploySquads(neutralPlayer, sg_vills, {{sbp = SBP.TEMPLAR.UNIT_VILLAGER_1_TEM, numSquads = 1}}, villsToSpawn[i])
		AssignVillagersToFarms(sg_vills, false, true)
		SGroup_Clear(sg_vills)
	end
	
end

-- an enemy building is attacked
function Montgisard_OnEnemyBuildingDamage(context)
	local owner = nil
	if context.victim ~= nil then
		if context.attacker ~= nil then
			--attacker is a squad and victim is a building
			if Entity_IsBuilding(context.attacker) == false and Entity_IsBuilding(context.victim) == true then
				local attacker = Entity_GetSquad(context.attacker)
				local bp = Entity_GetBlueprint(context.attacker)
				if attacker ~= nil and bp == EBP.TEMPLAR.UNIT_TREBUCHET_4_CW_TEM then
					if Entity_GetHealthPercentage(context.victim) > 0 then
						-- proceed only if the entity is not neutral
						if World_OwnsEntity(context.victim) == false then
							owner = Entity_GetPlayerOwner(context.victim)
						end
					end
					-- proceed only if damage is received by the enemy
					if owner == enemyPlayer or owner == enemyPlayer_2 then
						-- Launch an enemy attack to target trebs
						local buildingPos = Entity_GetPosition(context.victim)
						local trebPos = Entity_GetPosition(context.attacker)
						Montgisard_FocusTrebs(buildingPos, trebPos)
					end
				end	
			end	
		end
	end
end

-- The enemy will try and launch small attacks to target the enemy trebuchets when under siege
function Montgisard_FocusTrebs(buildingPosition, trebuchetPosition)
	local time = World_GetGameTime()
	local pos = nil
	local sg_unitsAroundSS = SGroup_CreateIfNotFound("sg_unitsAroundSS")
	local sg_trebAttack = SGroup_CreateIfNotFound("sg_trebAttack")
	local markersToCheck = {
		mkr_checkIdle1,
		mkr_checkIdle2,
		mkr_checkIdle3,
		mkr_checkIdle4
	}
	local unitsToCheck = {
		SBP.ABBASID_HA_01.UNIT_HORSEMAN_2_ABB_HA_01,
		SBP.ABBASID_HA_01.UNIT_HORSEMAN_3_ABB_HA_01,
		SBP.ABBASID_HA_01.UNIT_HORSEMAN_4_ABB_HA_01,
		SBP.AYYUBID_CMP.UNIT_TURKIC_HORSEARCHER_3_AYY,
		SBP.ABBASID_HA_01.UNIT_MAMLUK_3_ABB_HA_01,
		SBP.ABBASID_HA_01.UNIT_KNIGHT_3_ABB_HA_01,
		SBP.ABBASID_HA_01.UNIT_KNIGHT_4_ABB_HA_01
	}
	local unitsToCheck_2 = {
		SBP.ABBASID_HA_01.UNIT_SPEARMAN_1_ABB_HA_01,
		SBP.ABBASID_HA_01.UNIT_SPEARMAN_2_ABB_HA_01,
		SBP.ABBASID_HA_01.UNIT_SPEARMAN_3_ABB_HA_01,
		SBP.ABBASID_HA_01.UNIT_SPEARMAN_4_ABB_HA_01,
		SBP.ABBASID_HA_01.UNIT_MANATARMS_3_ABB_HA_01,
		SBP.ABBASID_HA_01.UNIT_MANATARMS_4_ABB_HA_01
	}
	
	local params = {
		player = enemyPlayer,
		attackMove = false
	}
	local army = Army_Init(params)
	
	-- Makes sure the attacks are not triggered more than one time per 2 minutes
	if (time - timeSinceTrebAttack) >= 120 then
		pos = Util_GetPosition(Util_GetClosestMarker(buildingPosition, markersToCheck))
		SGroup_Clear(sg_unitsAroundSS)
		SGroup_Clear(sg_trebAttack)
		Player_GetAllSquadsNearMarker(enemyPlayer, sg_unitsAroundSS, pos, 40)
		SGroup_Filter(sg_unitsAroundSS, unitsToCheck, FILTER_REMOVE, sg_trebAttack)
		if SGroup_CountSpawned(sg_trebAttack) > 5 then
			Army_AddSGroup(army, SGroup_Split(sg_trebAttack, 3)[1])
			Army_AddTarget(army, trebuchetPosition)
			timeSinceTrebAttack = time
		else
			Player_GetAllSquadsNearMarker(enemyPlayer, sg_unitsAroundSS, pos, 40)
			SGroup_Clear(sg_trebAttack)
			SGroup_Filter(sg_unitsAroundSS, unitsToCheck_2, FILTER_REMOVE, sg_trebAttack)
			if SGroup_CountSpawned(sg_trebAttack) > 5 then
				Army_AddSGroup(army, SGroup_Split(sg_trebAttack, 4)[1])
				Army_AddTarget(army, trebuchetPosition)
				timeSinceTrebAttack = time
			end
		end
	end
		
	
end

-- Starting player units
function Montgisard_StartingUnits()
	
	-- Set player popcap to max
	Player_SetMaxPopulation(localPlayer, CT_Personnel, 200)
	
	--Starting scouts
	UnitEntry_DeploySquads(localPlayer, sg_scout, {{sbp = SBP.TEMPLAR.UNIT_SCOUT_1_TEM, numSquads = 1 }}, mkr_player_scout)
	
	-- Starting villagers on berries
	UnitEntry_DeploySquads(localPlayer, sg_villagers_berries, {{sbp = SBP.TEMPLAR.UNIT_VILLAGER_1_TEM, numSquads = 8 }}, mkr_player_mill)
	AssignVillagersToBerries(sg_villagers_berries, false, false)
	
	-- Starting villagers on farms
	UnitEntry_DeploySquads(localPlayer, sg_villagers_farm, {{sbp = SBP.TEMPLAR.UNIT_VILLAGER_1_TEM, numSquads = 1}}, mkr_player_house3)
	UnitEntry_DeploySquads(localPlayer, sg_villagers_farm, {{sbp = SBP.TEMPLAR.UNIT_VILLAGER_1_TEM, numSquads = 1}}, mkr_player_house4)
	AssignVillagersToFarms(sg_villagers_farm, false, true)
	
	-- Starting villagers on wood
	UnitEntry_DeploySquads(localPlayer, sg_villagers_wood, {{sbp = SBP.TEMPLAR.UNIT_VILLAGER_1_TEM, numSquads = 4 }}, mkr_player_lumber)
	UnitEntry_DeploySquads(localPlayer, sg_villagers_wood, {{sbp = SBP.TEMPLAR.UNIT_VILLAGER_1_TEM, numSquads = 4 }}, mkr_player_lumber_2)
	AssignVillagersToWood(sg_villagers_wood, false, true)
	
	-- Starting villagers on gold
	UnitEntry_DeploySquads(localPlayer, sg_villagers_gold, {{sbp = SBP.TEMPLAR.UNIT_VILLAGER_1_TEM, numSquads = 6 }}, mkr_player_mining)
	AssignVillagersToGold(sg_villagers_gold, false, false)
	
	--Starting army
	UnitEntry_DeploySquads(localPlayer, sg_startingarmy1, {{sbp = SBP.TEMPLAR.UNIT_KNIGHT_TEMPLAR_3_TEM, numSquads = 5 }}, mkr_player_army1)
	UnitEntry_DeploySquads(localPlayer, sg_startingarmy1, {{sbp = SBP.TEMPLAR.UNIT_ARCHER_2_TEM, numSquads = 10 }}, mkr_player_army3)
	UnitEntry_DeploySquads(localPlayer, sg_startingarmy1, {{sbp = SBP.TEMPLAR.UNIT_RAM_3_TEM, numSquads = 1 }}, mkr_player_army4)
	
	-- Upgrade starting outposts
	EGroup_CompleteUpgrade(eg_player_outpost_2, UPG.COMMON.UPGRADE_OUTPOST_SPRINGALD)
	EGroup_CompleteUpgrade(eg_player_outpost_1, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
end

-- Starting enemy units for all sites
function Montgisard_EnemyUnits()
	
	-- Tower upgrades
	EGroup_CompleteUpgrade(eg_springaldTowers, UPG.COMMON.UPGRADE_OUTPOST_SPRINGALD)
	EGroup_CompleteUpgrade(eg_cannonTowers, UPG.COMMON.UPGRADE_OUTPOST_CANNON)
	EGroup_CompleteUpgrade(eg_reinforcedTowers, UPG.COMMON.UPGRADE_OUTPOST_STONE)
	EGroup_CompleteUpgrade(eg_arrowslitsTowers, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	
	--Global upgrades
	
	-- Spawn archer in outpost
	SpawnGarrisonsIntoEGroup(eg_garrisonedTowers, enemyPlayer_2, "scar_archer", 3)
	SpawnGarrisonsIntoEGroup(eg_garrisonedTowers_full, enemyPlayer_2, "scar_archer", 5)
	
	-- Sacred Site 1
	local unitsTable = {
		{bp = SBP.ABBASID_HA_01.UNIT_SPEARMAN_1_ABB_HA_01, pos = mkr_SS1_spawn1, num = 6},
