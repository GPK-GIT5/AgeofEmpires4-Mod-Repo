--				completedPOI = completedPOI + 1
--				Objective_SetCounter(OBJ_PointsOfInterest, completedPOI, totalPOI)
--				miningcampComplete_2 = true
--			end
--		end
--	end
	
	-- Check for the mining camp 3 POI completion criteria [REMOVED]
--	if miningcampComplete_3 == false then
--		if  Player_AreSquadsNearMarker(localPlayer, mkr_poi_miningcamp_3) == true then
--			FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_poi_miningcamp_3), 25, -1)
--			if SGroup_CountSpawned(sg_miningcamp3_enemies) == 0 then
--				SGroup_SetPlayerOwner(sg_neutralVills_3, localPlayer)
--				EGroup_SetPlayerOwner(eg_neutralCamp_3, localPlayer)
--				AssignVillagersToGold(sg_onGold_3, false, false)
--				UI_CreateEventCueClickable(-1, 10, 0, 0, "$11266810", Loc_Empty(), "high_priority", "", "sfx_ui_event_queue_high_priority_play", 255, 255, 255, 255, ECV_Title | ECV_Queue, __DoNothing)
--				completedPOI = completedPOI + 1
--				Objective_SetCounter(OBJ_PointsOfInterest, completedPOI, totalPOI)
--				miningcampComplete_3 = true
--			end
--		end
--	end
	
	-- Check for the mining camp 4 POI completion criteria
	if miningcampComplete_4 == false then
		if  Player_AreSquadsNearMarker(localPlayer, mkr_poi_miningcamp_4) == true then
			FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_poi_miningcamp_4), 25, -1)
			if SGroup_CountSpawned(sg_miningcamp4_enemies) == 0 then
				SGroup_SetPlayerOwner(sg_neutralVills_4, localPlayer)
				EGroup_SetPlayerOwner(eg_neutralCamp_4, localPlayer)
				AssignVillagersToGold(sg_onGold_4, false, false)
				AssignVillagersToStone(sg_onStone_4, false, false)
				UI_CreateEventCueClickable(-1, 10, 0, 0, "$11266810", Loc_Empty(), "high_priority", "", "sfx_ui_event_queue_high_priority_play", 255, 255, 255, 255, ECV_Title | ECV_Queue, __DoNothing)
				completedPOI = completedPOI + 1
				Objective_SetCounter(OBJ_PointsOfInterest, completedPOI, totalPOI)
				miningcampComplete_4 = true
			end
		end
	end
	
	-- Check for the prison POI completion criteria
	if prisonComplete == false then
		if  EGroup_CountSpawned(eg_prisonWalls) ~= n_walls and SGroup_CountSpawned(sg_guards) == 0 then
			SGroup_SetPlayerOwner(sg_prisoners, localPlayer)
			UI_CreateEventCueClickable(-1, 10, 0, 0, "$11266810", Loc_Empty(), "high_priority", "", "sfx_ui_event_queue_high_priority_play", 255, 255, 255, 255, ECV_Title | ECV_Queue, __DoNothing)
			completedPOI = completedPOI + 1
			Objective_SetCounter(OBJ_PointsOfInterest, completedPOI, totalPOI)
			prisonComplete = true
		end
	end
	
	-- Check for the extra site POI completion criteria
	if extraSiteComplete == false then
		-- Spawn treasure chests upon destruction of the individual buildings of this POI
		local pos = nil
		local facing_f = Util_GetPosition(mkr_extraFacing1)
		local facing_r = Util_GetPosition(mkr_extraFacing2)
		local facing_l = Util_GetPosition(mkr_extraFacing3)
		local bp = BP_GetEntityBlueprintByPbgID(2099990)
		local chest = nil
		if campDestroyed == false then
			if EGroup_CountSpawned(eg_extraCamp) == 0 then
--				pos = Util_GetOffsetPosition(mkr_extrasite, OFFSET_FRONT_RIGHT, 3)
--				chest = Entity_CreateFacing(bp, localPlayer, pos, facing_f, true)
--				Entity_Spawn(chest)
				pos = Util_GetOffsetPosition(mkr_extrasite, OFFSET_FRONT_LEFT, 3)
				chest = Entity_CreateFacing(bp, localPlayer, pos, facing_r, true)
				Entity_Spawn(chest)
				pos = Util_GetOffsetPosition(mkr_extrasite, OFFSET_BACK_LEFT, 3)
				chest = Entity_CreateFacing(bp, localPlayer, pos, facing_l, true)
				Entity_Spawn(chest)
				pos = Util_GetOffsetPosition(mkr_extrasite, OFFSET_BACK_RIGHT, 3)
				chest = Entity_CreateFacing(bp, localPlayer, pos, facing_f, true)
				Entity_Spawn(chest)
				campDestroyed = true
			end
		end
		if tower1Destroyed == false then
			if EGroup_CountSpawned(eg_extraTower1) == 0 then
--				pos = Util_GetOffsetPosition(mkr_extraTower1, OFFSET_BACK_RIGHT, 3)
--				chest = Entity_CreateFacing(bp, localPlayer, pos, facing_f, true)
--				Entity_Spawn(chest)
--				pos = Util_GetOffsetPosition(mkr_extraTower1, OFFSET_BACK_LEFT, 3)
--				chest = Entity_CreateFacing(bp, localPlayer, pos, facing_l, true)
--				Entity_Spawn(chest)
				pos = Util_GetOffsetPosition(mkr_extraTower1, OFFSET_FRONT, 3)
				chest = Entity_CreateFacing(bp, localPlayer, pos, facing_r, true)
				Entity_Spawn(chest)
				tower1Destroyed = true
			end
		end
		if tower2Destroyed == false then
			if EGroup_CountSpawned(eg_extraTower2) == 0 then
--				pos = Util_GetOffsetPosition(mkr_extraTower2, OFFSET_FRONT, 3)
--				chest = Entity_CreateFacing(bp, localPlayer, pos, facing_r, true)
--				Entity_Spawn(chest)
				pos = Util_GetOffsetPosition(mkr_extraTower2, OFFSET_LEFT, 3)
				chest = Entity_CreateFacing(bp, localPlayer, pos, facing_f, true)
				Entity_Spawn(chest)
--				pos = Util_GetOffsetPosition(mkr_extraTower2, OFFSET_BACK_RIGHT, 3)
--				chest = Entity_CreateFacing(bp, localPlayer, pos, facing_l, true)
--				Entity_Spawn(chest)
				tower2Destroyed = true
			end
		end
		if  EGroup_CountSpawned(eg_extraSite) == 0 and SGroup_CountSpawned(sg_extraSite_units) == 0 then
			if triggerActivated == true then
				UI_CreateEventCueClickable(-1, 10, 0, 0, "$11266810", Loc_Empty(), "high_priority", "", "sfx_ui_event_queue_high_priority_play", 255, 255, 255, 255, ECV_Queue, __DoNothing)
			else
				UI_CreateEventCueClickable(-1, 10, 0, 0, "$11266810", Loc_Empty(), "high_priority", "", "sfx_ui_event_queue_high_priority_play", 255, 255, 255, 255, ECV_Title | ECV_Queue, __DoNothing)
			end
			completedPOI = completedPOI + 1
			Objective_SetCounter(OBJ_PointsOfInterest, completedPOI, totalPOI)
			extraSiteComplete = true
		end
	end
	
end

function Montgisard_RewardPointsOfInterest()
	-- Reveals the monastery if not already found and gives it to the player
	sg_allyAttack = SGroup_CreateIfNotFound("sg_allyAttack")
	if monasteryComplete == false then
		FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_poi_monastery), 25, -1)
		SGroup_SetPlayerOwner(sg_monastery, localPlayer)
		EGroup_SetPlayerOwner(eg_Monastery, localPlayer)
		Sound_Play2D(MUS_STING_BONUS_OBJ_COMPLETE)
	end
	
	--	Spawns an ally army in waves and uses it to attack an enemy
	Rule_AddOneShot(Montgisard_SpawnAllyArmy, 0, {sbp = SBP.TEMPLAR.UNIT_RAM_3_TEM, numSquads = 3, pos = mkr_poi_allyArmy1})
	Rule_AddOneShot(Montgisard_SpawnAllyArmy, 5, {sbp = SBP.TEMPLAR.UNIT_KNIGHT_TEMPLAR_4_TEM, numSquads = 14, pos = mkr_poi_allyArmy2})
	Rule_AddOneShot(Montgisard_SpawnAllyArmy, 8, {sbp = SBP.TEMPLAR.UNIT_TEUTONIC_KNIGHT_4_TEM, numSquads = 10, pos = mkr_poi_allyArmy3})
	Rule_AddOneShot(Montgisard_SpawnAllyArmy, 10, {sbp = SBP.TEMPLAR.UNIT_ARCHER_4_TEM, numSquads = 10, pos = mkr_poi_allyArmy4})
	
	UI_SetPlayerDataContext(allyPlayer, { PopulationCapOn = false })
	Player_SetMaxPopulation(allyPlayer, CT_Personnel, 200)
	Player_SetResource(allyPlayer, RT_Wood, 800)
	Cmd_InstantUpgrade(allyPlayer, UPG.COMMON.UPGRADE_SIEGE_ENGINEERS)
	
	local enemySites = Montgisard_GetCurrentSites(enemyPlayer)
	local availableTarget = {}
	local attackPosition = nil
	local sg_unitsAroundSS = SGroup_CreateIfNotFound("sg_unitsAroundSS")
	local sg_unitsCloseSS = SGroup_CreateIfNotFound("sg_unitsCloseSS")
	for i = 1, #enemySites do
		Player_GetAllSquadsNearMarker(localPlayer, sg_unitsCloseSS, enemySites[i], 20)
		Player_GetAllSquadsNearMarker(localPlayer, sg_unitsAroundSS, enemySites[i], 40)
		if SGroup_CountSpawned(sg_unitsCloseSS) == 0 and SGroup_CountSpawned(sg_unitsAroundSS) ~= 0 then
			table.insert(availableTarget, enemySites[i])
		end
		
	end
	
	local size = (#availableTarget)
		if size ~= 0 then
			attackPosition = Table_GetRandomItem(availableTarget)
		else
			attackPosition = Table_GetRandomItem(enemySites)
		end
	
	attackParams = {
		    player = allyPlayer,
			name = "ally_army",
		}
	
	ally_army = Army_Init(attackParams)
	Rule_AddOneShot(Montgisard_LaunchAllyArmy, 15, {position = attackPosition})
	timeSinceIdle = World_GetGameTime()
end

function Montgisard_SpawnAllyArmy(context, data)
	
	local sg_tempGroup = SGroup_CreateIfNotFound("sg_tempGroup")
	local facing = Util_GetPosition(data.pos)
	facing.z = facing.z - 1
	UnitEntry_DeploySquads(allyPlayer, sg_tempGroup, {sbp = data.sbp, numSquads = data.numSquads, sgroup = sg_allyAttack}, mkr_poi_monastery)
	Cmd_FormationMove(sg_tempGroup, data.pos, false, false, facing)
	SGroup_Clear(sg_tempGroup)
	
end

function Montgisard_LaunchAllyArmy(context, data)
	
	Army_AddSGroup(ally_army, sg_allyAttack)
	Army_AddTarget(ally_army, data.position)
--	"Our allies have come to help and are launching an attack!"
	EventCues_CallToAction("$11269020", CTA_UNIQUE_CHANGE, nil, nil, mkr_poi_allyArmy2, 15, "icons/cta/illustrations/point_a_to_b")
	timeSinceIdle = World_GetGameTime()
	
end

