end

--Creates a set of minimap paths along a list of markers
function Montgisard_DisplayMinimapPath(path)
	MarkerPaths_GenerateIcons("minimap_path", path, "military_route_enemy", -1) --23
--	MarkerPaths_AnimateArrowPath(path)
end

-- Removes the minimap path
function Montgisard_RemoveMinimapPath()
	MarkerPaths_ClearIcons("minimap_path")
end

-- Function called everytime an enemy attack is triggered
function Montgisard_EnemyAttacks()
	
	local sacredSites_player = Montgisard_GetCurrentSites(localPlayer)
	local sacredSites_neutral = Montgisard_GetCurrentSites("neutral")
	
	local sitesCounter_enemy = Montgisard_GetCurrentSites(enemyPlayer, true)
	local sitesCounter_player = Montgisard_GetCurrentSites(localPlayer, true)
	local sitesCounter_neutral = Montgisard_GetCurrentSites("neutral", true)
	
	totalAttacks = totalAttacks +1
	
	-- This condition is triggered when there are still neutral sites on the map
	-- The enemy will select a random neutral site for their attack in order to recapture it
	if sitesCounter_neutral ~= 0 and sitesCounter_enemy ~= 0 then -- sitesCounter_player == 0 and
		Montgisard_AttackTarget(sacredSites_neutral)
	-- Standard case for enemy attacks, the enemy will select a random player site as the target
	elseif sitesCounter_player ~= 0 and sitesCounter_enemy ~= 0 then
		Montgisard_AttackTarget(sacredSites_player)
	-- If the player doesn't have any site, the attack is carried on the starting base
	elseif sitesCounter_player == 0 and sitesCounter_enemy ~= 0 then
		Montgisard_AttackTarget(mkr_player_tc)
	end
	
	if ruleRam == nil then
		ramRule = Rule_AddInterval(Montgisard_CheckForRams, .5) -- Start checking if rams are the only units remaining in attack groups
	end
	
	-- Play the recapture voice line only on the first enemy attack
	if sitesCounter_player ~= 0 or sitesCounter_neutral ~= 0 then
		if attackVoiceline == false then
			Rule_AddOneShot(Montgisard_RecaptureVoiceline, 15)
			attackVoiceline = true
		end
	end
	
end

function Montgisard_RecaptureVoiceline()
	Util_StartIntel(EVENTS.Enemy_Recapture)
end

-- Reorder enemy units around a site after they recapture one
function Montgisard_GetInFormation(siteRecaptured)
	
	local sg_aroundTheSite = SGroup_CreateIfNotFound("sg_aroundTheSite")
	local sg_sorting = SGroup_CreateIfNotFound("sg_sorting")
	
	local tableTypes = {
		{"scar_archer", "scar_crossbowman", "scar_horsearcher"},
		{"scar_spearman", "scar_manatarms"},
		{"scar_knight", "scar_horseman"},
		{"scar_ram", "scar_mangonel", "scar_scorpion"},
	}
	local rallyPoint = {
	}
	
	if siteRecaptured == mkr_sacredsite_1 then
		rallyPoint = {
			mkr_SS1_reinforce_archers,
			mkr_SS1_reinforce_infantry,
			mkr_SS1_reinforce_cavalry,
			mkr_SS1_reinforce_siege,
		}
	elseif siteRecaptured == mkr_sacredsite_2 then
		rallyPoint = {
			mkr_SS2_reinforce_archers,
			mkr_SS2_reinforce_infantry,
			mkr_SS2_reinforce_cavalry,
			mkr_SS2_reinforce_siege,
		}
	elseif siteRecaptured == mkr_sacredsite_3 then
		rallyPoint = {
			mkr_SS3_reinforce_archers,
			mkr_SS3_reinforce_infantry,
			mkr_SS3_reinforce_cavalry,
			mkr_SS3_reinforce_siege,
		}
	elseif siteRecaptured == mkr_sacredsite_4 then
		rallyPoint = {
			mkr_SS4_reinforce_archers,
			mkr_SS4_reinforce_infantry,
			mkr_SS4_reinforce_cavalry,
			mkr_SS4_reinforce_siege,
		}
	end
	
	local pos = Util_GetPosition(siteRecaptured)
		
	Player_GetAllSquadsNearMarker(enemyPlayer, sg_aroundTheSite, pos, 40)
	if SGroup_CountSpawned(sg_aroundTheSite) > 10 then
		for i = 1, #tableTypes do
			SGroup_Clear(sg_sorting)
			SGroup_Filter(sg_aroundTheSite, tableTypes[i], FILTER_REMOVE, sg_sorting)
			Cmd_FormationAttackMove(sg_sorting, rallyPoint[i], true)
		end
	end
	
end

function Montgisard_LaunchAttack()

	local minimapPath = {
	}
	
	local siegeMarkers = {
		mkr_siege_1,
		mkr_siege_2,
		mkr_siege_3,
		mkr_castle_4,
	}
	
	-- If conqueror is active, always take the unit BPs from the 5th enemy wave from the 6th attack onward.
	-- If not active, get the BPs for the normal 5 attacks from the respective 5 enemy waves.
	if conquerorActivated == true then
		if totalAttacks >= 6 then
			attackTable = {
				{bp = Montgisard_GetAttackUnitBP("archers", 5, attackStart), pos = Montgisard_GetAttackUnitSpawnPoint("archers", attackStart), num = Montgisard_GetAttackUnitStrength("archers", totalAttacks, attackStart, attackEnd)},
				{bp = Montgisard_GetAttackUnitBP("infantry", 5, attackStart), pos = Montgisard_GetAttackUnitSpawnPoint("infantry", attackStart), num = Montgisard_GetAttackUnitStrength("infantry", totalAttacks, attackStart, attackEnd)},
				{bp = Montgisard_GetAttackUnitBP("cavalry", 5, attackStart), pos = Montgisard_GetAttackUnitSpawnPoint("cavalry", attackStart), num = Montgisard_GetAttackUnitStrength("cavalry", totalAttacks, attackStart, attackEnd)},
				{bp = Montgisard_GetAttackUnitBP("siege", 5, attackStart), pos = Montgisard_GetAttackUnitSpawnPoint("siege", attackStart), num = Montgisard_GetAttackUnitStrength("siege", totalAttacks, attackStart, attackEnd)},
			}
		else
			attackTable = {
				{bp = Montgisard_GetAttackUnitBP("archers", totalAttacks, attackStart), pos = Montgisard_GetAttackUnitSpawnPoint("archers", attackStart), num = Montgisard_GetAttackUnitStrength("archers", totalAttacks, attackStart, attackEnd)},
				{bp = Montgisard_GetAttackUnitBP("infantry", totalAttacks, attackStart), pos = Montgisard_GetAttackUnitSpawnPoint("infantry", attackStart), num = Montgisard_GetAttackUnitStrength("infantry", totalAttacks, attackStart, attackEnd)},
				{bp = Montgisard_GetAttackUnitBP("cavalry", totalAttacks, attackStart), pos = Montgisard_GetAttackUnitSpawnPoint("cavalry", attackStart), num = Montgisard_GetAttackUnitStrength("cavalry", totalAttacks, attackStart, attackEnd)},
				{bp = Montgisard_GetAttackUnitBP("siege", totalAttacks, attackStart), pos = Montgisard_GetAttackUnitSpawnPoint("siege", attackStart), num = Montgisard_GetAttackUnitStrength("siege", totalAttacks, attackStart, attackEnd)},
			}
		end
	else
		if totalAttacks >= 6 then
			attackTable = {
				{bp = Montgisard_GetAttackUnitBP("archers", 4, attackStart), pos = Montgisard_GetAttackUnitSpawnPoint("archers", attackStart), num = Montgisard_GetAttackUnitStrength("archers", totalAttacks, attackStart, attackEnd)},
				{bp = Montgisard_GetAttackUnitBP("infantry", 4, attackStart), pos = Montgisard_GetAttackUnitSpawnPoint("infantry", attackStart), num = Montgisard_GetAttackUnitStrength("infantry", totalAttacks, attackStart, attackEnd)},
				{bp = Montgisard_GetAttackUnitBP("cavalry", 4, attackStart), pos = Montgisard_GetAttackUnitSpawnPoint("cavalry", attackStart), num = Montgisard_GetAttackUnitStrength("cavalry", totalAttacks, attackStart, attackEnd)},
				{bp = Montgisard_GetAttackUnitBP("siege", 4, attackStart), pos = Montgisard_GetAttackUnitSpawnPoint("siege", attackStart), num = Montgisard_GetAttackUnitStrength("siege", 1, attackStart, attackEnd)},
			}
		else
			attackTable = {
				{bp = Montgisard_GetAttackUnitBP("archers", totalAttacks, attackStart), pos = Montgisard_GetAttackUnitSpawnPoint("archers", attackStart), num = Montgisard_GetAttackUnitStrength("archers", totalAttacks, attackStart, attackEnd)},
				{bp = Montgisard_GetAttackUnitBP("infantry", totalAttacks, attackStart), pos = Montgisard_GetAttackUnitSpawnPoint("infantry", attackStart), num = Montgisard_GetAttackUnitStrength("infantry", totalAttacks, attackStart, attackEnd)},
				{bp = Montgisard_GetAttackUnitBP("cavalry", totalAttacks, attackStart), pos = Montgisard_GetAttackUnitSpawnPoint("cavalry", attackStart), num = Montgisard_GetAttackUnitStrength("cavalry", totalAttacks, attackStart, attackEnd)},
				{bp = Montgisard_GetAttackUnitBP("siege", totalAttacks, attackStart), pos = Montgisard_GetAttackUnitSpawnPoint("siege", attackStart), num = Montgisard_GetAttackUnitStrength("siege", totalAttacks, attackStart, attackEnd)},
			}
		end
	end
	
	for i = 1, #attackTable do
		UnitEntry_DeploySquads(enemyPlayer, sg_attackGroup, {{sbp = attackTable[i].bp, numSquads = attackTable[i].num }}, attackTable[i].pos)
	end
	
	local numRams = 0
	
	if conquerorActivated == true then
		numRams = totalAttacks
	else
		if totalAttacks >= 6 then
			numRams = 2
		else
			numRams = totalAttacks - 1
		end
	end
	
	UnitEntry_DeploySquads(enemyPlayer, sg_attackGroup, {{sbp = SBP.ABBASID_HA_01.UNIT_RAM_3_ABB_HA_01, numSquads = numRams }}, Util_GetClosestMarker(attackStart, siegeMarkers))
	Util_ApplyModifier(sg_attackGroup, "capture_rate_squad_modifier", true, 10, MUT_Addition, MAT_Squad, true, nil)
	--------------------------
	
	attackPath = Montgisard_GetAttackPath(1, attackStart, attackEnd)
	minimapPath = Montgisard_GetAttackPath(2, attackStart, attackEnd)
	Montgisard_DisplayMinimapPath(minimapPath)
	Rule_AddOneShot(Montgisard_RemoveMinimapPath, 120)
	EventCues_CallToAction("$11266823", CTA_ALARM, nil, nil, attackStart, 10, "icons/cta/illustrations/player_reinforcement_arrived")
	Sound_Play2D("sfx_campaign_scripted_attack_horn_under_attack_high")
	
	-- Set sgroup to attack move through the path
	table.insert(attackPath, attackEnd)
	targetRoute = {
		marker = attackPath,
		targetOrder = TARGET_ORDER_LINEAR,
	    combatRange = 40,
		combatRangeEnRoute = 20,
	    combatRangeAtTarget = 25,
	    attackMove = true
	}
	attackParams = {
    	player = enemyPlayer,
		targets = attackPath,
		targetOrder = TARGET_ORDER_LINEAR,
	    combatRange = 40,
		combatRangeEnRoute = 20,
	    combatRangeAtTarget = 25,
	    attackMove = true,
		idleTime = 0
	}
	attackArmy = Army_Init(attackParams)
	Army_AddSGroup(attackArmy, sg_attackGroup)
	
	-- Add attack group to a table to check and destroy the rams if they are the only remaining units
	if totalAttacks <= 5 then
		SGroup_AddGroup(attackSGroups[totalAttacks], sg_attackGroup)
	end
	
end

-- Builds an enemy group and attacks the specified target.
function Montgisard_AttackTarget(target)
	
	attackStart = nil
	attackEnd = nil

	sg_attackGroup = SGroup_CreateIfNotFound("sg_attackGroup")
	
	attackPath = {
	}
	
	--------------------------
	attackTable = {
	}
	attackParams = {
	}
	attackArmy = nil
	
	SGroup_Clear(sg_attackGroup)
	
	-- If the target is the player base, always attack from the sacred site #1.
	-- Else, choose an available enemy site to attack from.
	if target == mkr_player_tc then
		attackStart = mkr_sacredsite_1
	else
		attackStart = Montgisard_GetAvailableSiteForAttack()
	end
	-- If the target is the player base, choose the player tc as the final marker for enemy units.
	-- Else, choose a random player site as the target for the enemy attack.
	if target == mkr_player_tc then
		attackEnd = mkr_player_tc
	else
		attackEnd = Table_GetRandomItem(target)
	end
	
	-- Change number of total enemy units based on Conqueror Mode activation
	if conquerorActivated == true then
		attackStrenghtCM = attackStrenghtCM + 4
	end
	
	-- Reduce enemy total strenght after the 5th attack, when players are in the bronze range
	if totalAttacks >= 6 then
		if attackStrenghtPostBronze > 8 then
			attackStrenghtPostBronze = attackStrenghtPostBronze - 4
		end
	end
	
	-- Spawn the attack warning UI if players are within a certain range from the site enemies area attacking from
	local unitInRange = SGroup_CreateIfNotFound("unitInRange")
	local buildingInRange = EGroup_CreateIfNotFound("buildingInRange")
	
	local checkPos = Util_GetPosition(Util_GetClosestMarker(attackStart, warningMarkers))
	Player_GetAllSquadsNearMarker(localPlayer, unitInRange, checkPos, 90)
	Player_GetAllEntitiesNearMarker(localPlayer, buildingInRange, checkPos, 90)
	
	if SGroup_CountSpawned(unitInRange) > 0  or EGroup_CountSpawned(buildingInRange) > 0 then
		Montgisard_AttackWarning(attackStart)
	end
	
	-- Launch the attack
	Rule_AddOneShot(Montgisard_LaunchAttack, 15)
	
end

function Montgisard_SetupAttackRuleForConqueror()
	--Spawn one reinforcements immediately and then every 5 minutes
	Montgisard_EnemyAttacks()
	attackRule = Rule_AddInterval(Montgisard_EnemyAttacks, 300)
end

function Montgisard_SetupReinforceRuleForConqueror()
	--Spawn one reinforcements immediately and then every 5 minutes
	Montgisard_EnemyReinforcements()
	reinforceRule = Rule_AddInterval(Montgisard_EnemyReinforcements, 300)
end

function Montgisard_AttackWarning(origin)
	
	local bp_outer = BP_GetReticuleBlueprint("marquee")
	local bp_inner = BP_GetReticuleBlueprint("capture_enemy")

	reticuleCurrentSize = 0
	hintpointsPos = {
		
	}
	local lenght = nil
	
	if origin == mkr_sacredsite_1 then
		lenght = 4
		for i = 1, 4 do
			table.insert(hintpointsPos, site_1[i])
		end
	elseif origin == mkr_sacredsite_2 then
		lenght = 3
		for i = 1, 3 do
			table.insert(hintpointsPos, site_2[i])
		end
	elseif origin == mkr_sacredsite_3 then
		lenght = 4
		for i = 1, 4 do
			table.insert(hintpointsPos, site_3[i])
		end
	elseif origin == mkr_sacredsite_4 then
		lenght = 3
		for i = 1, 3 do
			table.insert(hintpointsPos, site_4[i])
		end
	end
		
	for i = 1, #hintpointsPos do
		warningHintpoints[i] = HintPoint_Add(hintpointsPos[i], true, "$11266823", 5)
		reticulesOuter[i] = UI_ModalVisual_CreateReticule(bp_outer, 10) -- Outer reticule
		UI_ModalVisual_SetPosition(reticulesOuter[i], hintpointsPos[i])
		reticulesInner[i] = UI_ModalVisual_CreateReticule(bp_inner, 0) -- Inner reticule
		UI_ModalVisual_SetPosition(reticulesInner[i], hintpointsPos[i])
	end
	Rule_AddInterval(Montgisard_AttackWarningUpdate, .125, {site = lenght})
end

function Montgisard_AttackWarningUpdate(context, data)
	
	local bp_inner = BP_GetReticuleBlueprint("capture_enemy")
	
	reticuleCurrentSize = reticuleCurrentSize + 0.083 --0.125
	
	-- Check if the reticule has reached the desired size
	for i = 1, data.site do
		if reticuleCurrentSize < 10 then
			if reticulesOuter[i] ~= nil and reticulesInner[i] ~= nil and hintpointsPos[i] ~= nil then
				UI_ModalVisual_Destroy(reticulesInner[i])
				reticulesInner[i] = UI_ModalVisual_CreateReticule(bp_inner, reticuleCurrentSize)
				UI_ModalVisual_SetPosition(reticulesInner[i], hintpointsPos[i])
			end
		else
			-- Remove all hintpoints and reset all variables for the next attack
			for i = 1, data.site do
				if warningHintpoints[i] ~= nil then
					HintPoint_Remove(warningHintpoints[i])
				end
				if reticulesOuter[i] ~= nil then
					UI_ModalVisual_Destroy(reticulesOuter[i])
				end
				if reticulesInner[i] ~= nil then
					UI_ModalVisual_Destroy(reticulesInner[i])
				end
				
			end
			
			hintpoint_warning1 = nil
			hintpoint_warning2 = nil
			hintpoint_warning3 = nil
			hintpoint_warning4 = nil
			
			outer1 = nil
			outer2 = nil
			outer3 = nil
			outer4 = nil
			
			inner1 = nil
			inner2 = nil
			inner3 = nil
			inner4 = nil
			
			Rule_RemoveMe()
		end
	end
	
	
end

function Montgisard_CheckForRams()
	
	local sg_groupToCheck = SGroup_CreateIfNotFound("sg_groupToCheck")
	local sg_groupRams = SGroup_CreateIfNotFound("sg_groupRams")
	SGroup_Clear(sg_groupToCheck)
	SGroup_Clear(sg_groupRams)
	
	for i = 1, #attackSGroups do
		if SGroup_IsEmpty(attackSGroups[i]) == false then
			SGroup_Clear(sg_groupToCheck)
			SGroup_Clear(sg_groupRams)
			SGroup_AddGroup(sg_groupToCheck, attackSGroups[i])
			SGroup_Filter(sg_groupToCheck, SBP.ABBASID_HA_01.UNIT_RAM_3_ABB_HA_01, FILTER_REMOVE, sg_groupRams)
			if SGroup_IsEmpty(sg_groupToCheck) then
				SGroup_Kill(sg_groupRams)
			end
		end	
	end
	
end

