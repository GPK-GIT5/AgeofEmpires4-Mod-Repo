		}
		fortress4_army = Army_Init(params)
		SGroup_AddGroup(sg_fortress4_starting, Army_GetSGroup(fortress4_army))
	end
	
	-- Add capture modifiers to enemy starting groups
	Util_ApplyModifier(sg_fortress1_starting, "capture_rate_squad_modifier", true, 10, MUT_Addition, MAT_Squad, true, nil)
	Util_ApplyModifier(sg_fortress2_starting, "capture_rate_squad_modifier", true, 10, MUT_Addition, MAT_Squad, true, nil)
	Util_ApplyModifier(sg_fortress3_starting, "capture_rate_squad_modifier", true, 10, MUT_Addition, MAT_Squad, true, nil)
	Util_ApplyModifier(sg_fortress4_starting, "capture_rate_squad_modifier", true, 10, MUT_Addition, MAT_Squad, true, nil)
	
end

-- Function called everytime a reinforcement is triggered
function Montgisard_EnemyReinforcements()
	
	local sg_fortress1_reinforce = SGroup_CreateIfNotFound("sg_fortress1_reinforce")
	local sg_fortress2_reinforce = SGroup_CreateIfNotFound("sg_fortress2_reinforce")
	local sg_fortress3_reinforce = SGroup_CreateIfNotFound("sg_fortress3_reinforce")
	local sg_fortress4_reinforce = SGroup_CreateIfNotFound("sg_fortress4_reinforce")
	
	SGroup_Clear(sg_fortress1_reinforce)
	SGroup_Clear(sg_fortress2_reinforce)
	SGroup_Clear(sg_fortress3_reinforce)
	SGroup_Clear(sg_fortress4_reinforce)
	
	local currentTable = {	
	}
	
	totalReinforces = totalReinforces +1
	
	currentTable = Montgisard_ReinforceData(totalReinforces, conquerorActivated)
	
	-- Fortress 1
	if Util_GetPlayerOwner(eg_SacredSite_1) == enemyPlayer or World_OwnsEGroup(eg_SacredSite_1, true) == true then
		if EGroup_IsEmpty(eg_archery_1) == false then
			UnitEntry_DeploySquads(enemyPlayer, sg_fortress1_reinforce, {currentTable.fortress1.archers}, mkr_archery_1)
		end
		if EGroup_IsEmpty(eg_barracks_1) == false then
			UnitEntry_DeploySquads(enemyPlayer, sg_fortress1_reinforce, {currentTable.fortress1.infantry}, mkr_barracks_1)
		end
		if EGroup_IsEmpty(eg_stable_1) == false then
			UnitEntry_DeploySquads(enemyPlayer, sg_fortress1_reinforce, {currentTable.fortress1.cavalry}, mkr_stable_1)
		end
		if EGroup_IsEmpty(eg_siege_1) == false then
			UnitEntry_DeploySquads(enemyPlayer, sg_fortress1_reinforce, {currentTable.fortress1.siege}, mkr_siege_1)
		end	
	end
	
	local facing = Util_GetPosition(mkr_SS1_reinforce_archers)
	facing.x = facing.x - 1
	facing.z = facing.z + 1
	Cmd_FormationMove(sg_SS1_archers, mkr_SS1_reinforce_archers, false, false, facing)
	facing = Util_GetPosition(mkr_SS1_reinforce_infantry)
	facing.x = facing.x - 1
	Cmd_FormationMove(sg_SS1_infantry, mkr_SS1_reinforce_infantry, false, false, facing)
	facing = Util_GetPosition(mkr_SS1_reinforce_cavalry)
	facing.x = facing.x + 1
	facing.z = facing.z - 1
	Cmd_FormationMove(sg_SS1_cavalry, mkr_SS1_reinforce_cavalry, false, false, facing)
	facing = Util_GetPosition(mkr_SS1_reinforce_siege)
	facing.x = facing.x - 1
	Cmd_FormationMove(sg_SS1_siege, mkr_SS1_reinforce_siege, false, false, facing)

	if Util_GetPlayerOwner(eg_SacredSite_1) ~= enemyPlayer then
		Cmd_FormationAttackMove(sg_fortress1_reinforce, eg_SacredSite_1, true)
	end
	
	-- Fortress 2
	if Util_GetPlayerOwner(eg_SacredSite_2) == enemyPlayer or World_OwnsEGroup(eg_SacredSite_2, true) == true then
		if EGroup_IsEmpty(eg_archery_2) == false then
			UnitEntry_DeploySquads(enemyPlayer, sg_fortress2_reinforce, {currentTable.fortress2.archers}, mkr_archery_2)
		end
		if EGroup_IsEmpty(eg_barracks_2) == false then
			UnitEntry_DeploySquads(enemyPlayer, sg_fortress2_reinforce, {currentTable.fortress2.infantry}, mkr_barracks_2)
		end
		if EGroup_IsEmpty(eg_stable_2) == false then
			UnitEntry_DeploySquads(enemyPlayer, sg_fortress2_reinforce, {currentTable.fortress2.cavalry}, mkr_stable_2)
		end
	end
	
	facing = Util_GetPosition(mkr_SS2_reinforce_archers)
	facing.x = facing.x + 1
	Cmd_FormationMove(sg_SS2_archers, mkr_SS2_reinforce_archers, false, false, facing)
	facing = Util_GetPosition(mkr_SS2_reinforce_infantry)
	facing.x = facing.x + 1
	facing.z = facing.z - 1
	Cmd_FormationMove(sg_SS2_infantry, mkr_SS2_reinforce_infantry, false, false, facing)
	facing = Util_GetPosition(mkr_SS2_reinforce_cavalry)
	facing.z = facing.z - 1
	Cmd_FormationMove(sg_SS2_cavalry, mkr_SS2_reinforce_cavalry, false, false, facing)
	facing = Util_GetPosition(mkr_SS2_reinforce_siege)
	facing.x = facing.x - 1
	facing.z = facing.z + 1
	Cmd_FormationMove(sg_SS2_siege, mkr_SS2_reinforce_siege, false, false, facing)

	if Util_GetPlayerOwner(eg_SacredSite_2) ~= enemyPlayer then
		Cmd_FormationAttackMove(sg_fortress2_reinforce, eg_SacredSite_2, true)
	end
	
	-- Fortress 3
	if Util_GetPlayerOwner(eg_SacredSite_3) == enemyPlayer or World_OwnsEGroup(eg_SacredSite_3, true) == true then
		if EGroup_IsEmpty(eg_archery_3) == false then
			UnitEntry_DeploySquads(enemyPlayer, sg_fortress3_reinforce, {currentTable.fortress3.archers}, mkr_archery_3)
		end
		if EGroup_IsEmpty(eg_barracks_3) == false then
			UnitEntry_DeploySquads(enemyPlayer, sg_fortress3_reinforce, {currentTable.fortress3.infantry}, mkr_barracks_3)
		end
		if EGroup_IsEmpty(eg_stable_3) == false then
			UnitEntry_DeploySquads(enemyPlayer, sg_fortress3_reinforce, {currentTable.fortress3.cavalry}, mkr_stable_3)
		end
		if EGroup_IsEmpty(eg_siege_3) == false then
			UnitEntry_DeploySquads(enemyPlayer, sg_fortress3_reinforce, {currentTable.fortress3.siege}, mkr_siege_3)
		end
	end
	
	facing = Util_GetPosition(mkr_SS3_reinforce_archers)
	facing.z = facing.z - 1
	Cmd_FormationMove(sg_SS3_archers, mkr_SS3_reinforce_archers, false, false, facing)
	facing = Util_GetPosition(mkr_SS3_reinforce_infantry)
	facing.x = facing.x + 1
	facing.z = facing.z + 1
	Cmd_FormationMove(sg_SS3_infantry, mkr_SS3_reinforce_infantry, false, false, facing)
	facing = Util_GetPosition(mkr_SS3_reinforce_cavalry)
	facing.z = facing.z + 1
	Cmd_FormationMove(sg_SS3_cavalry, mkr_SS3_reinforce_cavalry, false, false, facing)
	facing = Util_GetPosition(mkr_SS3_reinforce_siege)
	facing.x = facing.x - 1
	facing.z = facing.z + 1
	Cmd_FormationMove(sg_SS3_siege, mkr_SS3_reinforce_siege, false, false, facing)

	if Util_GetPlayerOwner(eg_SacredSite_3) ~= enemyPlayer then
		Cmd_FormationAttackMove(sg_fortress3_reinforce, eg_SacredSite_3, true)
	end
	
	-- Fortress 4
	if Util_GetPlayerOwner(eg_SacredSite_4) == enemyPlayer or World_OwnsEGroup(eg_SacredSite_4, true) == true then
		if EGroup_IsEmpty(eg_archery_4) == false then
			UnitEntry_DeploySquads(enemyPlayer, sg_fortress4_reinforce, {currentTable.fortress4.archers}, mkr_archery_4)
		end
		if EGroup_IsEmpty(eg_barracks_4) == false then
			UnitEntry_DeploySquads(enemyPlayer, sg_fortress4_reinforce, {currentTable.fortress4.infantry}, mkr_barracks_4)
		end
		if EGroup_IsEmpty(eg_stable_4) == false then
			UnitEntry_DeploySquads(enemyPlayer, sg_fortress4_reinforce, {currentTable.fortress4.cavalry}, mkr_stable_4)
		end
		if EGroup_IsEmpty(eg_siege_4) == false then
			UnitEntry_DeploySquads(enemyPlayer, sg_fortress4_reinforce, {currentTable.fortress4.siege}, mkr_castle_4)
		end	
	end
	
	facing = Util_GetPosition(mkr_SS4_reinforce_archers)
	facing.x = facing.x + 1
	facing.z = facing.z - 1
	Cmd_FormationMove(sg_SS4_archers, mkr_SS4_reinforce_archers, false, false, facing)
	facing = Util_GetPosition(mkr_SS4_reinforce_infantry)
	facing.x = facing.x + 1
	facing.z = facing.z + 1
	Cmd_FormationMove(sg_SS4_infantry, mkr_SS4_reinforce_infantry, false, false, facing)
	facing = Util_GetPosition(mkr_SS4_reinforce_cavalry)
	facing.x = facing.x + 1
	facing.z = facing.z + 1
	Cmd_FormationMove(sg_SS4_cavalry, mkr_SS4_reinforce_cavalry, false, false, facing)
	facing = Util_GetPosition(mkr_SS4_reinforce_siege)
	facing.x = facing.x - 1
	facing.z = facing.z + 1
	Cmd_FormationMove(sg_SS4_siege, mkr_SS4_reinforce_siege, false, false, facing)

	if Util_GetPlayerOwner(eg_SacredSite_4) ~= enemyPlayer then
		Cmd_FormationAttackMove(sg_fortress4_reinforce, eg_SacredSite_4, true)
	end
	
	-- Apply capture modifiers to reinforcements groups
	Util_ApplyModifier(sg_fortress1_reinforce, "capture_rate_squad_modifier", true, 10, MUT_Addition, MAT_Squad, true, nil)
	Util_ApplyModifier(sg_fortress2_reinforce, "capture_rate_squad_modifier", true, 10, MUT_Addition, MAT_Squad, true, nil)
	Util_ApplyModifier(sg_fortress3_reinforce, "capture_rate_squad_modifier", true, 10, MUT_Addition, MAT_Squad, true, nil)
	Util_ApplyModifier(sg_fortress4_reinforce, "capture_rate_squad_modifier", true, 10, MUT_Addition, MAT_Squad, true, nil)
	
	-- Ping the enemy site on the minimap
	Montgisard_AddPingAndSound()
	
	-- Play a voice line for the first enemy reonforcement
	if reinforceVoiceline == false then
		Util_StartIntel(EVENTS.Enemy_Reinforcements)
		reinforceVoiceline = true
	end
	
	-- Remove the reinforce rule if conqueror mode is not active
	if totalReinforces == 6 then
		if reinforceRule ~= nil then
			Rule_RemoveWithID(reinforceRule)
		end
	end

end

