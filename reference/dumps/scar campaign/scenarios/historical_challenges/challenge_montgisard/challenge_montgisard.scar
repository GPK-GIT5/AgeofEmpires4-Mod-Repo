	local recipe = {
		
		audioSettings = {
			campaignName = "tem",
			missionName = "rts_montgisard",
		},		
		
		introNIS = EVENTS.Camera_Intro,
	
		locations = {
		},
		
		modules = {
		},

		onWin = {
		},
		
		onLose = {
		},
	}
	
	return recipe
end

-- Updates sacred sites UI by adding/removing minimap objective icons
function Montgisard_UpdateSacredSitesUI()
	
	site1Owner = Util_GetPlayerOwner(eg_SacredSite_1)
	site2Owner = Util_GetPlayerOwner(eg_SacredSite_2)
	site3Owner = Util_GetPlayerOwner(eg_SacredSite_3)
	site4Owner = Util_GetPlayerOwner(eg_SacredSite_4)
	
	if site1Owner ~= previousSite1Owner then
		if site1Owner == localPlayer and previousSite1Owner == nil then
			if hpid_ss1 ~= nil then
				Objective_RemoveUIElements(OBJ_SacredSitesPrimary, hpid_ss1)
				hpid_ss1 = nil
				Sound_Play2D(MUS_STING_TRIUMPHANT) -- Add sound on player capture
				lastCapturedSite = mkr_sacredsite_1 -- Updated the latest captured site
			end
		elseif site1Owner == enemyPlayer and previousSite1Owner == nil then
			-- Nothing
			Montgisard_GetInFormation(mkr_sacredsite_1)
		elseif site1Owner == nil and previousSite1Owner == localPlayer then
			if hpid_ss1 == nil then 
				hpid_ss1 = Objective_AddUIElements(OBJ_SacredSitesPrimary, sacredSite_position1, true, nil, false, nil, nil, nil, "icons/objectives/objectives_holy_site")
			end
		elseif site1Owner == nil and previousSite1Owner == enemyPlayer then
			-- Nothing
		end	
	end
	
	if site2Owner ~= previousSite2Owner then
		if site2Owner == localPlayer and previousSite2Owner == nil then
			if hpid_ss2 ~= nil then
				Objective_RemoveUIElements(OBJ_SacredSitesPrimary, hpid_ss2)
				hpid_ss2 = nil
				Sound_Play2D(MUS_STING_TRIUMPHANT) -- Add sound on player capture
				lastCapturedSite = mkr_sacredsite_2 -- Updated the latest captured site
			end
		elseif site2Owner == enemyPlayer and previousSite2Owner == nil then
			-- Nothing
			Montgisard_GetInFormation(mkr_sacredsite_2)
		elseif site2Owner == nil and previousSite2Owner == localPlayer then
			if hpid_ss2 == nil then
				hpid_ss2 = Objective_AddUIElements(OBJ_SacredSitesPrimary, sacredSite_position2, true, nil, false, nil, nil, nil, "icons/objectives/objectives_holy_site")
			end
		elseif site2Owner == nil and previousSite2Owner == enemyPlayer then
			-- Nothing
		end	
	end
	
	if site3Owner ~= previousSite3Owner then
		if site3Owner == localPlayer and previousSite3Owner == nil then
			if hpid_ss3 ~= nil then
				Objective_RemoveUIElements(OBJ_SacredSitesPrimary, hpid_ss3)
				hpid_ss3 = nil
				Sound_Play2D(MUS_STING_TRIUMPHANT) -- Add sound on player capture
				lastCapturedSite = mkr_sacredsite_3 -- Updated the latest captured site
			end
		elseif site3Owner == enemyPlayer and previousSite3Owner == nil then
			-- Nothing
			Montgisard_GetInFormation(mkr_sacredsite_3)
		elseif site3Owner == nil and previousSite3Owner == localPlayer then
			if hpid_ss3 == nil then
				hpid_ss3 = Objective_AddUIElements(OBJ_SacredSitesPrimary, sacredSite_position3, true, nil, false, nil, nil, nil, "icons/objectives/objectives_holy_site")
			end
		elseif site3Owner == nil and previousSite3Owner == enemyPlayer then
			-- Nothing
		end	
	end
	
	if site4Owner ~= previousSite4Owner then
		if site4Owner == localPlayer and previousSite4Owner == nil then
			if hpid_ss4 ~= nil then
				Objective_RemoveUIElements(OBJ_SacredSitesPrimary, hpid_ss4)
				hpid_ss4 = nil
				Sound_Play2D(MUS_STING_TRIUMPHANT) -- Add sound on player capture
				lastCapturedSite = mkr_sacredsite_4 -- Updated the latest captured site
			end
		elseif site4Owner == enemyPlayer and previousSite4Owner == nil then
			-- Nothing
			Montgisard_GetInFormation(mkr_sacredsite_4)
		elseif site4Owner == nil and previousSite4Owner == localPlayer then
			if hpid_ss4 == nil then
				hpid_ss4 = Objective_AddUIElements(OBJ_SacredSitesPrimary, sacredSite_position4, true, nil, false, nil, nil, nil, "icons/objectives/objectives_holy_site")
			end
		elseif site4Owner == nil and previousSite4Owner == enemyPlayer then
			-- Nothing
		end	
	end
	
	previousSite1Owner = site1Owner
	previousSite2Owner = site2Owner
	previousSite3Owner = site3Owner
	previousSite4Owner = site4Owner
	
end

-- Main update function that checks for different trigger conditions
function Montgisard_TrackSacredSites()
	
	local timeElapsed = World_GetGameTime() - startTime
	local timeSinceUpdate = timeElapsed - lastVictoryUpdateTime
	if(timeSinceUpdate == 0) then
		--set to default update time for first update
		lastVictoryUpdateTime = .125
	end
	lastVictoryUpdateTime = timeElapsed
	
	-- Update the mission time only if the main objective has not been completed yet
	if Objective_IsComplete(OBJ_SacredSitesPrimary) == false then
		missionTime = World_GetGameTime() - startTime
	end
	
	playerSitesHeld = 0
	enemySitesHeld = 0
	
------- Check the ownership of the Sacred Sites ------------------------------------------------------------------------------------
	for i = 1, 4 do
		
		local siteOwner = Util_GetPlayerOwner(eg_SacredSite_1)
		
		if(i == 2) then
			siteOwner = Util_GetPlayerOwner(eg_SacredSite_2)
		elseif(i == 3) then
			siteOwner = Util_GetPlayerOwner(eg_SacredSite_3)
		elseif(i == 4) then
			siteOwner = Util_GetPlayerOwner(eg_SacredSite_4)
		end
		
		if siteOwner == localPlayer then
			playerSitesHeld = playerSitesHeld + 1
		elseif siteOwner == enemyPlayer then
			enemySitesHeld = enemySitesHeld + 1
		end
	end
	
------- Only called when the number of Sacred Sites the player has changed ---------------------------------------------------------
	if previousSitesHeld ~= playerSitesHeld or previousSitesHeld_enemy ~= enemySitesHeld then	
		Montgisard_UpdateSacredSitesUI()
		Montgisard_UpdateSacredSitesBonuses()
		-- Updated the counter for the main objective
		Objective_SetCounter(OBJ_SacredSitesPrimary, playerSitesHeld, 4)
	end
	
------- Create cue when an enemy capture a site ------------------------------------------------------------------------------------
	if previousSitesHeld_enemy < enemySitesHeld then
		UI_CreateEventCue("$11266813", Loc_Empty(), "high_priority", "icons/event_queue_high_priority", "sfx_ui_event_queue_high_priority_play", ECV_Queue, 10)
	end
	
------- Updates current sites held ---------------------------------------------------------------------------------------------	
	previousSitesHeld = playerSitesHeld
	previousSitesHeld_enemy = enemySitesHeld
	
------- Check for victory and defeat conditions --------------------------------------------------------------------------------
	if conquerorActivated == true then
		if (playerSitesHeld == 4) and Objective_IsFailed(OBJ_DefendTC) == false and Objective_IsFailed(OBJ_ConquerorMedal) == false then
			Objective_Complete(OBJ_SacredSitesPrimary, false, true)
		end
	else
		if (playerSitesHeld == 4) and Objective_IsFailed(OBJ_DefendTC) == false then
			Objective_Complete(OBJ_SacredSitesPrimary, false, true)
		end
	end
	
	if conquerorActivated == true then
		if EGroup_GetTotalHealth(eg_starting_tc) == 0 and Objective_IsComplete(OBJ_SacredSitesPrimary) == false and Objective_IsFailed(OBJ_ConquerorMedal) == false then
			Objective_Fail(OBJ_DefendTC, true, false)
		end
	else
		if EGroup_GetTotalHealth(eg_starting_tc) == 0 and Objective_IsComplete(OBJ_SacredSitesPrimary) == false then
			Objective_Fail(OBJ_DefendTC, true, false)
		end
	end
	-- Only for Conqueror Mode
	if conquerorActivated == true and Objective_IsComplete(OBJ_SacredSitesPrimary) == false then
		if Objective_IsTimerSet(OBJ_ConquerorMedal) == true then
			if Objective_GetTimerSeconds(OBJ_ConquerorMedal) <= 0 then
				Objective_Fail(OBJ_ConquerorMedal, true, false)
			end
		end
	end
	
------- Check when to spawn bonus units on age up ------------------------------------------------------------------------------
	local currentAge = Player_GetCurrentAge(localPlayer)
	
	if darkBonus == false then
		if currentAge == AGE_FEUDAL then
			Rule_AddOneShot(Montgisard_BonusUnitsOnAgeUp, 0, {age = currentAge})
			darkBonus = true
		end
	elseif feudalBonus == false then
		if currentAge == AGE_CASTLE then
			Rule_AddOneShot(Montgisard_BonusUnitsOnAgeUp, 0, {age = currentAge})
			feudalBonus = true
		end
	elseif castleBonus == false then
		if currentAge == AGE_IMPERIAL then
			Rule_AddOneShot(Montgisard_BonusUnitsOnAgeUp, 0, {age = currentAge})
			castleBonus = true
		end
	end

------- Check when to spawn bonus reinforcements units for the player ----------------------------------------------------------
	if conquerorActivated == false then
		-- Add archers 30 seconds after gold time
		if playerReinforce_1 == false and missionTime > (goldTime*60) + 30 then
			sg_playerReinforcements1 = SGroup_CreateIfNotFound("sg_playerReinforcements1")
			UnitEntry_DeploySquads(localPlayer, sg_playerReinforcements1, {
					{sbp = SBP.TEMPLAR.UNIT_ARCHER_3_TEM, numSquads = 10 }}, mkr_player_tc)
			Cmd_FormationAttackMove(sg_playerReinforcements1, mkr_player_reinforce, true)
			EventCues_CallToAction("$11268460", CTA_CELEBRATE, nil, nil, mkr_player_reinforce, 20, "icons/cta/illustrations/player_reinforcement_arrived")
			playerReinforce_1 = true
		end
		
		-- Add men at arms and trebuchets 3 minute before silver time
		if playerReinforce_2 == false and missionTime > (silverTime*60) - 180 then
			sg_playerReinforcements2 = SGroup_CreateIfNotFound("sg_playerReinforcements2")
			UnitEntry_DeploySquads(localPlayer, sg_playerReinforcements2, {
					{sbp = SBP.TEMPLAR.UNIT_MANATARMS_4_TEM, numSquads = 12 },
					{sbp = SBP.TEMPLAR.UNIT_TREBUCHET_4_CW_TEM, numSquads = 2 }}, mkr_player_tc)
			Cmd_FormationAttackMove(sg_playerReinforcements2, mkr_player_reinforce, true)
			EventCues_CallToAction("$11268460", CTA_CELEBRATE, nil, nil, mkr_player_reinforce, 20, "icons/cta/illustrations/player_reinforcement_arrived")
			playerReinforce_2 = true
		end
		
		-- Add knights and springalds 3 minutes after silver time
		if playerReinforce_3 == false and missionTime > (silverTime*60) + 120 then
			sg_playerReinforcements3 = SGroup_CreateIfNotFound("sg_playerReinforcements3")
			UnitEntry_DeploySquads(localPlayer, sg_playerReinforcements3, {
					{sbp = SBP.TEMPLAR.UNIT_KNIGHT_TEMPLAR_4_TEM, numSquads = 14 },
					{sbp = SBP.TEMPLAR.UNIT_SPRINGALD_3_TEM, numSquads = 3 }}, mkr_player_tc)
			Cmd_FormationAttackMove(sg_playerReinforcements3, mkr_player_reinforce, true)
			EventCues_CallToAction("$11268460", CTA_CELEBRATE, nil, nil, mkr_player_reinforce, 20, "icons/cta/illustrations/player_reinforcement_arrived")
			playerReinforce_3 = true
		end
		
		-- Add knights, crossbows and mangonels at the 40 minute mark
		if playerReinforce_4 == false and missionTime > (bronzeTime*60) - 1200 then
			sg_playerReinforcements4 = SGroup_CreateIfNotFound("sg_playerReinforcements4")
			UnitEntry_DeploySquads(localPlayer, sg_playerReinforcements4, {
					{sbp = SBP.TEMPLAR.UNIT_KNIGHT_TEMPLAR_4_TEM, numSquads = 12 },
					{sbp = SBP.TEMPLAR.UNIT_CROSSBOWMAN_4_TEM, numSquads = 12 },
					{sbp = SBP.TEMPLAR.UNIT_MANGONEL_3_TEM, numSquads = 3 }}, mkr_player_tc)
			Cmd_FormationAttackMove(sg_playerReinforcements4, mkr_player_reinforce, true)
			EventCues_CallToAction("$11268460", CTA_CELEBRATE, nil, nil, mkr_player_reinforce, 20, "icons/cta/illustrations/player_reinforcement_arrived")
			playerReinforce_4 = true
		end
		
		
		
	end
	
------ Plays the pushback voice line at 20 minutes --------------------------------------------------------------------------
	
	if pushbackVoiceline == false then
		if(missionTime >= 20*60) then
			Util_StartIntel(EVENTS.Push_Back)
			pushbackVoiceline = true
		end
	end
	
------- Activating Conqueror Mode --------------------------------------------------------------------------------------------
	-- First Phase: Updates the Conqueror Mode objectives triggering the second phase if the requirements are met
	if triggerActivated == false and conquerorExpired == false then
		-- Check if requirements for first phase are met
		if Util_GetPlayerOwner(eg_SacredSite_1) == localPlayer and Objective_GetTimerSeconds(OBJ_ConquerorMode) > 0 then
			-- Spawn extra site
			Rule_AddOneShot(Montgisard_ConquerorTriggerSite)
			-- Updated Conqueror Mode objective
			Objective_RemoveUIElements(OBJ_ConquerorMode, worldArrow)
			worldArrow_2 = Objective_AddUIElements(OBJ_ConquerorMode, mkr_extrasite, false, "$11266814", true, 14)
			hpid_extra = Objective_AddUIElements(OBJ_ConquerorMode, mkr_extrasite, true, nil, false, nil, nil, nil, "icons/objectives/objectives_holy_site")
			Objective_StopTimer(OBJ_ConquerorMode)
			Objective_UpdateText(OBJ_ConquerorMode, "$11266815", nil, true, false) --Destroy the enemy camp to activate Conqueror Mode
			Objective_StartTimer(OBJ_ConquerorMode, COUNT_DOWN, 60 * 3)
			Objective_SetProgressBar(OBJ_ConquerorMode, 0)
			
			triggerActivated = true
		elseif Objective_GetTimerSeconds(OBJ_ConquerorMode) == 0 then
			Sound_Play2D(MUS_STING_NEGATIVE)
			Objective_Fail(OBJ_ConquerorMode, false, false) -- true, true
			Objective_Show(OBJ_ConquerorMode, false, false)
			conquerorExpired = true
		end
	end
	
	-- Second Phase: Activates Conqueror Mode when this conditions are met
	if conquerorExpired == false and conquerorActivated == false and triggerActivated == true then
		-- Updates UI on units killed and buildings destroyed for the second phase of triggering Conqueror Mode
		if SGroup_IsEmpty(sg_extraSite_units) == false or unitsKilled_extraSite == 23 then
			unitsKilled_extraSite = 24 - SGroup_CountSpawned(sg_extraSite_units)
		end
		buildingsDestroyed_extraSite = 3 - EGroup_CountSpawned(eg_extraSite)
		local campCleared = unitsKilled_extraSite + buildingsDestroyed_extraSite
		campClearedPercent = (campCleared / extraSite_totalUnits)
		
		Objective_SetProgressBar(OBJ_ConquerorMode, campClearedPercent)
		
		-- Check if requirements for second phase are met
		if SGroup_IsEmpty(sg_extraSite_units) and EGroup_IsEmpty(eg_extraSite) and Objective_GetTimerSeconds(OBJ_ConquerorMode) > 0 then
	
			conquerorPos = Util_GetPosition(mkr_extrasite)
			
			-- Start Conqueror Medal objective
			Objective_Complete(OBJ_GoldMedal, false, false)
			Objective_Show(OBJ_GoldMedal, false, false)
			Objective_Register(OBJ_ConquerorMedal)
			Objective_Start(OBJ_ConquerorMedal)
			
			-- Spawn enemy leaders
			if Util_GetPlayerOwner(eg_SacredSite_1) == enemyPlayer then
				UnitEntry_DeploySquads(enemyPlayer, sg_SS1_leader, {{sbp = SBP.AYYUBID_CMP.UNIT_LEADER_COMMANDER_AYY, numSquads = 1 }}, mkr_stable_1)
				Util_ApplyModifier(sg_SS1_leader, "capture_rate_squad_modifier", true, 10, MUT_Addition, MAT_Squad, true, nil)
				Cmd_FormationMove(sg_SS1_leader, mkr_SS1_leader, false, false, mkr_SS1_leader_facing)
			end
			
			if Util_GetPlayerOwner(eg_SacredSite_2) == enemyPlayer then
				UnitEntry_DeploySquads(enemyPlayer, sg_SS2_leader, {{sbp = SBP.AYYUBID_CMP.UNIT_LEADER_COMMANDER_AYY, numSquads = 1 }}, mkr_stable_2)
				Util_ApplyModifier(sg_SS2_leader, "capture_rate_squad_modifier", true, 10, MUT_Addition, MAT_Squad, true, nil)
				Cmd_FormationMove(sg_SS2_leader, mkr_SS2_leader, false, false, mkr_SS2_leader_facing)
			end
			
			if Util_GetPlayerOwner(eg_SacredSite_3) == enemyPlayer then
				UnitEntry_DeploySquads(enemyPlayer, sg_SS3_leader, {{sbp = SBP.AYYUBID_CMP.UNIT_LEADER_COMMANDER_AYY, numSquads = 1 }}, mkr_stable_3)
				Util_ApplyModifier(sg_SS3_leader, "capture_rate_squad_modifier", true, 10, MUT_Addition, MAT_Squad, true, nil)
				Cmd_FormationMove(sg_SS3_leader, mkr_SS3_leader, false, false, mkr_SS3_leader_facing)
			end
			
			if Util_GetPlayerOwner(eg_SacredSite_4) == enemyPlayer then
				UnitEntry_DeploySquads(enemyPlayer, sg_SS4_leader, {{sbp = SBP.AYYUBID_CMP.UNIT_LEADER_SALADIN_KNIGHT_AYY, numSquads = 1 }}, mkr_castle_4)
				Util_ApplyModifier(sg_SS4_leader, "capture_rate_squad_modifier", true, 10, MUT_Addition, MAT_Squad, true, nil)
				Cmd_FormationMove(sg_SS4_leader, mkr_SS4_leader, false, false, mkr_SS4_leader_facing)
			end
			
			conquerorActivated = true
			
			-- Start the Conqueror timer
			Objective_StartTimer(OBJ_ConquerorMedal, COUNT_DOWN, conquerorCountdown*60)
			
			--inform game code that the conqueror mode was activated during the mission
			Game_StoreTableData("conquerorMode", {activated = true})
			
			-- Remove the normal rules for reinforcements and attacks
			if reinforceRule ~= nil then
				Rule_RemoveWithID(reinforceRule)
			end
			if attackRule ~= nil then
				Rule_RemoveWithID(attackRule)
			end
			-- Setup the right timings for enemy reinforces and attack when CM is triggered
			Rule_AddOneShot(Montgisard_SetupReinforceRuleForConqueror, 60)
			Rule_AddOneShot(Montgisard_SetupAttackRuleForConqueror, 120)
			Util_StartIntel(EVENTS.Conqueror_Unlock)
			
		elseif Objective_GetTimerSeconds(OBJ_ConquerorMode) == 0 then
			Sound_Play2D(MUS_STING_NEGATIVE)
			Objective_Fail(OBJ_ConquerorMode, false, false) -- true, true
			Objective_Show(OBJ_ConquerorMode, false, false)
			conquerorExpired = true
		end	
		
	end
	
	Montgisard_UpdatePointsOfInterest()
	----------------------------------------------------------------
	-- Spawn points of interest final reward upon completing all POI
	if rewardPOI == false then
		if completedPOI == totalPOI then
			Montgisard_RewardPointsOfInterest()
			rewardPOI = true
		end
	end
	-- Track the allied attack (POI reward) and give the units to the player when the attack is completed
	if TrackAlliedAttack == false and rewardPOI == true then
			if SGroup_IsIdle(sg_allyAttack, true) == false then
				timeSinceIdle = World_GetGameTime()
			else
				if World_GetGameTime() - timeSinceIdle >= 20 then
					if SGroup_CountSpawned(sg_allyAttack) ~= 0 then
						Army_Dissolve(ally_army)
						SGroup_SetPlayerOwner(sg_allyAttack, localPlayer)
	--					"Allied units have joined your army"
						EventCues_CallToAction("$11269021", CTA_UNIQUE_CHANGE, nil, nil, SGroup_GetPosition(sg_allyAttack), 15, "icons/cta/illustrations/02_celebration")
						TrackAlliedAttack = true
					else
						TrackAlliedAttack = true
					end
				end
			end
	end
	----------------------------------------------------------------
	-- Updates medals
	if conquerorActivated == false and Objective_IsComplete(OBJ_SacredSitesPrimary) == false then
		-- Gold Medal
		if(Objective_IsStarted(OBJ_GoldMedal)) and goldMedalFailed == false then
			if Objective_GetTimerSeconds(OBJ_GoldMedal) >= goldTime*60  then
				Sound_Play2D(MUS_STING_NEGATIVE)
				goldMedalFailed = true
				Objective_Fail(OBJ_GoldMedal, true, true)
				Objective_Show(OBJ_GoldMedal, false, false)

				Objective_Register(OBJ_SilverMedal)
				Objective_Start(OBJ_SilverMedal)
				Objective_StartTimer(OBJ_SilverMedal, COUNT_UP, timeSinceStart)
			end
		end
		-- Silver Medal
		if(Objective_IsStarted(OBJ_SilverMedal)) and silverMedalFailed == false then
			if Objective_GetTimerSeconds(OBJ_SilverMedal) >= silverTime*60 then
				Sound_Play2D(MUS_STING_NEGATIVE)
				silverMedalFailed = true
				Objective_Fail(OBJ_SilverMedal, true, true)
				Objective_Show(OBJ_SilverMedal, false, false)
				
				Objective_Register(OBJ_BronzeMedal)
				Objective_Start(OBJ_BronzeMedal)
				Objective_StartTimer(OBJ_BronzeMedal, COUNT_UP, timeSinceStart)
				-- Deactivates rule that focus enemy attacks on the player's trebuchets for Bronze medal
				Rule_RemoveGlobalEvent(Montgisard_OnEnemyBuildingDamage)
			end
		end
		-- Bronze Medal
		if(Objective_IsStarted(OBJ_BronzeMedal)) and bronzeMedalFailed == false then
			if Objective_GetTimerSeconds(OBJ_BronzeMedal) >= bronzeTime*60 then
				Sound_Play2D(MUS_STING_NEGATIVE)
				bronzeMedalFailed = true
				Objective_Fail(OBJ_BronzeMedal, false, false) -- true, true
				Objective_Show(OBJ_BronzeMedal, false, false)
			end
		end
	end
	
	timeSinceStart = timeElapsed
	-----------------------------------
	-- Tracking Conqueror Mode NOT USED
	if conquerorActivated == true then
		
	end
	
end

-- Used by enemy units to recapture neutral/player sites if they are idling near one of the site
function Montgisard_CheckForIdleAroundSS()
	local nearSite = false
	local sg_unitsAroundSS = SGroup_CreateIfNotFound("sg_unitsAroundSS")
	local allSites = {
		eg_SacredSite_1,
		eg_SacredSite_2,
		eg_SacredSite_3,
		eg_SacredSite_4
	}
	local markersToCheck = {
		mkr_checkIdle1,
		mkr_checkIdle2,
		mkr_checkIdle3,
		mkr_checkIdle4
	}
	local pos = nil
	for i = 1, 4 do
		pos = Util_GetPosition(markersToCheck[i])
		Player_GetAllSquadsNearMarker(enemyPlayer, sg_unitsAroundSS, pos, 40)
		if SGroup_CountSpawned(sg_unitsAroundSS) > 0 then
			if Util_GetPlayerOwner(allSites[i]) ~= enemyPlayer and SGroup_IsIdle(sg_unitsAroundSS, false) == true then
				SGroup_AttackMove(SGroup_Split(sg_unitsAroundSS, 4)[1], Util_GetPosition(allSites[i]))
			end
		end
	end
end

-- Look for an available site to launch an attack from, returns a position (marker)
function Montgisard_GetAvailableSiteForAttack()
	
	local enemyTable = Montgisard_GetCurrentSites(enemyPlayer)
	local currentTable = {
	}
	local sg_unitsAroundSS = SGroup_CreateIfNotFound("sg_unitsAroundSS")
	SGroup_Clear(sg_unitsAroundSS)

	if Table_Contains(enemyTable, mkr_sacredsite_1) then
		SGroup_Clear(sg_unitsAroundSS)
		Player_GetAllSquadsNearMarker(localPlayer, sg_unitsAroundSS, mkr_checkIdle1, 40)
		if SGroup_CountSpawned(sg_unitsAroundSS) == 0 then
			table.insert(currentTable, mkr_sacredsite_1)
		end
	end
	if Table_Contains(enemyTable, mkr_sacredsite_2) then
		SGroup_Clear(sg_unitsAroundSS)
		Player_GetAllSquadsNearMarker(localPlayer, sg_unitsAroundSS, mkr_checkIdle2, 40)
		if SGroup_CountSpawned(sg_unitsAroundSS) == 0 then
			table.insert(currentTable, mkr_sacredsite_2)
		end
	end
	if Table_Contains(enemyTable, mkr_sacredsite_3) then
		SGroup_Clear(sg_unitsAroundSS)
		Player_GetAllSquadsNearMarker(localPlayer, sg_unitsAroundSS, mkr_checkIdle3, 40)
		if SGroup_CountSpawned(sg_unitsAroundSS) == 0 then
			table.insert(currentTable, mkr_sacredsite_3)
		end
	end
	if Table_Contains(enemyTable, mkr_sacredsite_4) then
		SGroup_Clear(sg_unitsAroundSS)
		Player_GetAllSquadsNearMarker(localPlayer, sg_unitsAroundSS, mkr_checkIdle4, 40)
		if SGroup_CountSpawned(sg_unitsAroundSS) == 0 then
			table.insert(currentTable, mkr_sacredsite_4)
		end
	end
	local size = (#currentTable)
	if size ~= 0 then
		local availableSite = Table_GetRandomItem(currentTable)
		return availableSite
	else
		local backupSite = Table_GetRandomItem(enemyTable)
		return backupSite
	end
end

function HC_Montgisard_IntroSetup()
	
	Montgisard_StartingUnits()
	Montgisard_EnemyUnits()
	Montgisard_EnemyPatrols()
	Montgisard_SpawnPointsOfInterest()
	Montgisard_SpawnNeutralVills()
	
	--Also start some intro-specific units
	sg_intro_units = SGroup_CreateIfNotFound("sg_intro_units")
	sg_intro_patrol_1 = SGroup_CreateIfNotFound("sg_intro_patrol_1")
	sg_intro_patrol_2 = SGroup_CreateIfNotFound("sg_intro_patrol_2")
	sg_intro_patrol_3 = SGroup_CreateIfNotFound("sg_intro_patrol_3")
	sg_intro_patrol_4 = SGroup_CreateIfNotFound("sg_intro_patrol_4")
	
	UnitEntry_DeploySquads(
		enemyPlayer,
		sg_intro_units,
		{
			{ type = "scar_spearman", numSquads = 12, spawn = mkr_intro_1, sgroup = sg_intro_patrol_1 },
			
			{ type = "scar_spearman", numSquads = 12, spawn = mkr_intro_5, sgroup = sg_intro_patrol_2 },
			
			{ type = "scar_spearman", numSquads = 12, spawn = mkr_intro_6, sgroup = sg_intro_patrol_3 },
			
			{ type = "scar_spearman", numSquads = 12, spawn = mkr_intro_9, sgroup = sg_intro_patrol_4 },
		}
	)
	
	sg_intro_raiders = SGroup_CreateIfNotFound("sg_intro_raiders")
	SGroup_AddGroup(sg_intro_raiders, sg_temp)
	
	Cmd_Move(sg_intro_patrol_1, mkr_intro_2, true)
	Cmd_Move(sg_intro_patrol_1, mkr_intro_3, true)
	Cmd_Move(sg_intro_patrol_1, mkr_intro_4, true)
	Cmd_Move(sg_intro_patrol_1, mkr_intro_5, true)
	Cmd_Move(sg_intro_patrol_1, mkr_intro_6, true)
	Cmd_Move(sg_intro_patrol_1, mkr_intro_7, true)
	Cmd_Move(sg_intro_patrol_1, mkr_intro_8, true)
	
	Cmd_Move(sg_intro_patrol_2, mkr_intro_6, true)
	Cmd_Move(sg_intro_patrol_2, mkr_intro_7, true)
	Cmd_Move(sg_intro_patrol_2, mkr_intro_8, true)
	
	Cmd_Move(sg_intro_patrol_3, mkr_intro_9, true)
	Cmd_Move(sg_intro_patrol_3, mkr_intro_12, true)
	Cmd_Move(sg_intro_patrol_3, mkr_intro_13, true)
	
	Cmd_Move(sg_intro_patrol_4, mkr_intro_10, true)
	Cmd_Move(sg_intro_patrol_4, mkr_intro_11, true)
	
end

function HC_Montgisard_IntroTeardown()
	
	SGroup_DestroyAllSquads(sg_intro_units)
	SGroup_Destroy(sg_intro_units)
	
	--Now create patrol 4, which otherwise would have gotten in the way of the intro units
	local units = {
		"scar_spearman",
		"scar_archer",
	}
	Montgisard_CreatePatrol(units, sg_enemyPatrol_04, path04, path04_reverse, 3, 3)
	
end