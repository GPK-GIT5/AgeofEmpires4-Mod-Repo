	sg_neutralVills_Rams = SGroup_CreateIfNotFound("sg_neutralVills_Rams")
	sg_onWood = SGroup_CreateIfNotFound("sg_onWood")
	
	UnitEntry_DeploySquads(neutralPlayer, sg_rams, {
			{sbp = SBP.TEMPLAR.UNIT_RAM_3_TEM, numSquads = 1, spawn = mkr_poi_rams_spawn1 },
			{sbp = SBP.TEMPLAR.UNIT_RAM_3_TEM, numSquads = 1, spawn = mkr_poi_rams_spawn2 },
