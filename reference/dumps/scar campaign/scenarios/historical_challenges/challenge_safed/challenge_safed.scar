-- This is called very early on in the mission's initialization. So early, in fact, that there 
-- is very little you can do. You can, however, use it to do simple stuff like gathering player IDs
function Mission_SetupPlayers()
	
	PlayerColour_Enable() --turn on custom colour configuration for this session
	
	--You as the player, Knights Templar (blue)
	player1 = Missionomatic_InitPlayer(1, { name = "$11265367", currentAge = AGE_CASTLE, maxAge = AGE_CASTLE })
	
	--Enemy AI, Mamluck Sultanate (red)
	player2 = Missionomatic_InitPlayer(2, { name = "$11253300", currentAge = AGE_CASTLE, maxAge = AGE_CASTLE })
	
	--Ally fortress repair, Knights Templar (yellow)
	player3 = Missionomatic_InitPlayer(3, { name = "$11172342", currentAge = AGE_CASTLE, maxAge = AGE_CASTLE })
	World_EnableSharedLineOfSight(player1, player3, false)
	AI_Enable(player3, false) --disable AI for ally, player3 only repairs the fortress
	
	--Neutral acting as world. This is to prevent enemy player from attacking neutral buildings (yellow)
	player4 = Missionomatic_InitPlayer(4, { name = "$11172025", currentAge = AGE_CASTLE, maxAge = AGE_CASTLE })
	World_EnableSharedLineOfSight(player1, player4, false)
	AI_Enable(player4, false) --disable AI for ally, player4 acts as a neutral e.g. town villager life
	
	--Fortress building is only assigned to this team. This is so event "player attack" alerts do not trigger
	player5 = Missionomatic_InitPlayer(5, { name = "$11265367", currentAge = AGE_CASTLE, maxAge = AGE_CASTLE })
	
	Player_SetRelationship(player1, player2, R_ENEMY)
	Player_SetRelationship(player1, player3, R_ALLY)
	Player_SetRelationship(player1, player4, R_ALLY)
	Player_SetRelationship(player1, player5, R_ALLY)
	Player_SetRelationship(player2, player1, R_ENEMY)
	Player_SetRelationship(player2, player3, R_ENEMY)
	Player_SetRelationship(player2, player4, R_ALLY)
	Player_SetRelationship(player2, player5, R_ENEMY)
	Player_SetRelationship(player3, player1, R_ALLY)
	Player_SetRelationship(player3, player2, R_ENEMY)
	Player_SetRelationship(player3, player4, R_ALLY)
	Player_SetRelationship(player3, player5, R_ALLY)
	Player_SetRelationship(player4, player1, R_ALLY)
	Player_SetRelationship(player4, player2, R_ALLY)
	Player_SetRelationship(player4, player3, R_ALLY)
	Player_SetRelationship(player4, player5, R_ALLY)
	
	Game_SetPlayerUISlotColour(player1, COLOR_BLUE)
	Game_SetPlayerUISlotColour(player2, COLOR_RED)
	Game_SetPlayerUISlotColour(player3, COLOR_YELLOW)
	Game_SetPlayerUISlotColour(player4, COLOR_YELLOW)
	Game_SetPlayerUISlotColour(player5, COLOR_BLUE)
	
end




-- This is a good place to initialize all of your global variables. For example, creating any 
-- SGroups or EGroups you want to use in the mission, any tables of data, etc
function Mission_SetupVariables()
	
	SAFED_PLAYER_VILLAGERS_TOTAL_COUNT = 7 --the number of starting villagers player1 is given
	
	--EGroups, SGroups
	Safed_Init_ESG_Data()
	
	--main gameplay loop settings
	SAFED_FORTRESS_DAMAGE_RECEIVED_SCALE = 0.145 --multiplier on fortress damage received
	SAFED_FORTRESS_DAMAGE_RECEIVED_SCALE_ENDING = 0.5 --after mining stone 4, lower damage by percentage amount to accommodate travel time to final siege camp
	SAFED_FORTRESS_DAMAGE_EMPATHY_THRESHOLD = 0.35 --fortress health percent when the empathy damage kicks in
	SAFED_FORTRESS_DAMAGE_RECEIVED_SCALE_EMPATHY = 0.5 --empathy damage, lower damage by this percentage if fortress health is in bronze medal range
	SAFED_FORTRESS_ENTITY = EGroup_GetSpawnedEntityAt(eg_fortress, 1)
	SAFED_FORTRESS_HEALTH = Entity_GetHealthPercentage(SAFED_FORTRESS_ENTITY)
	SAFED_FORTRESS_HEALTH_INT = math.floor(SAFED_FORTRESS_HEALTH * 100 + 0.5) --rounded to whole number and used with loc
	SAFED_FORTRESS_NOTIFY_THRESHOLDS = {
		{ value = 0.5, notified = false, sfx = { MUS_STINGER_WARNING, SFX_VICTORY_TIMER_FIRST }, cooldown_end = 0 },
		{ value = 0.3, notified = false, sfx = { MUS_STING_NEGATIVE, SFX_VICTORY_TIMER_SECOND }, cooldown_end = 0 },
		{ value = 0.1, notified = false, sfx = { MUS_STINGER_ALERT, SFX_VICTORY_TIMER_FINAL }, cooldown_end = 0 },
	}
	SAFED_FORTRESS_NOTIFICATION_COOLDOWN = 120 --cooldown time of percentage health notifier
	SAFED_STONE_CARRY_CAPACTIY_SCALE = 2 --multiplier on villager carry capacity
	SAFED_STONE_HARVEST_RATE = 6 --villager harvest rate on stone
	SAFED_STONE_REPAIR_COST = 7 --stone repair cost per second to repair the fortress
	SAFED_STONE_NODE_AMOUNT = 900 --total stone amount each node contains
	SAFED_STONE_NODE_COUNT = EGroup_Count(eg_stone_deposit) --number of stone nodes
	SAFED_STONE_DEPLETED_COUNT = 0 --number of stone nodes that are depleted
	SAFED_STONE_NOTIFY_INTERVAL = 7 * 60 --timed interval to show no stone event cue notification since last depleted
	SAFED_STONE_NOTIFY_LAST_TRIGGER_TIME = 0 --tracking the time the last no stone event cue notification appeared
	SAFED_REPAIR_RATE = 0.3 --player3 repair rate on the fortress
	SAFED_MILITARY_PRODUCTION_RATE = 20 --multiplier on player1 military production rate
	
	SAFED_TREB_SPAWNS = Marker_GetSequence("mkr_enemy_trebuchet", "")
	SAFED_TREB_MOVE_TOS = Marker_GetSequence("mkr_enemy_trebuchet_move", "")
	SAFED_TREB_SPAWN_INTERVAL = 8 --spawn interval for each treb
	SAFED_TREB_ATTACK_INTERVAL = 2.75 --attack speed interval
	
	SAFED_RAM_MODIFY_DAMAGE_WALL = 0.175 --multiplier for ram damage against stone wall
	SAFED_RAM_MODIFY_DAMAGE_FORTRESS = 2.5 --multiplier for ram damage against the fortress
		
	SAFED_MINE_TOWN_MARKERS = Marker_GetSequence("mkr_mine_town", "") --table of mine town markers found
	SAFED_MINE_TOWN_CURRENT_WAVE = nil --the current enemy wave at mine town
	SAFED_LAST_STONE_MINE_UI_OBJECTIVE = nil --the last stone mine UI objective that appears
	
	--resouces gifted on each successful depletion of a stone mine
	SAFED_GIFTED_RESOURCES1 = { food = 850, wood = 200, gold = 150 }
	SAFED_GIFTED_RESOURCES2 = { food = 1300, wood = 880, gold = 530 }
	SAFED_GIFTED_RESOURCES3 = { food = 1320, wood = 410, gold = 550 }
	SAFED_GIFTED_RESOURCES4 = { food = 3220, wood = 1880, gold = 2000 }
	
	--resource chest pickup amounts
	SAFED_RESOURCE_PICKUP_WOOD_AMOUNT = 50
	SAFED_RESOURCE_PICKUP_FOOD_AMOUNT = 100
	SAFED_RESOURCE_PICKUP_GOLD_AMOUNT = 100
	SAFED_RESOURCE_PICKUP_STONE_AMOUNT = 100
	
	SAFED_CM_ACTIVATED = false --conqueror mode
	SAFED_CM_ACTIVATE_TIME = math.ceil(5 * 60) --5:00 time in seconds game checks if conqueror mode will activate
	SAFED_CM_VILLAGER_COUNT = 7 --number of alive villagers or greater required at activation time
	SAFED_CM_TREB_SPAWNS = Marker_GetSequence("mkr_cm_enemy_trebuchet", "") --conqueror mode additional trebs
	SAFED_CM_TREB_MOVE_TOS = Marker_GetSequence("mkr_cm_enemy_trebuchet_move", "")
	
	SAFED_UNITS_COST = Safed_Unit_Cost_Init() --player1 table of units utilized in mission and the cost of each one
	
end




--Returns the recipe for this mission
function GetRecipe()
	
	local recipe = {
		introNIS = EVENTS.Camera_Intro,
		audioSettings = {
			campaignName = "tem",
			missionName = "rts_safed",
		},	
		locations = {
			{
				descriptor = "safed",
				marker = mkr_safed,
				player = player3
			},
			{
				descriptor = "mine_town1",
				marker = SAFED_MINE_TOWN_MARKERS[1],
				player = player3
			},
			{
				descriptor = "mine_town2",
				marker = SAFED_MINE_TOWN_MARKERS[2],
				player = player3
			},
			{
				descriptor = "mine_town3",
				marker = SAFED_MINE_TOWN_MARKERS[3],
				player = player3
			},
			{
				descriptor = "mine_town4",
				marker = SAFED_MINE_TOWN_MARKERS[4],
				player = player3
			},
			{
				descriptor = "siege_camp",
				marker = mkr_siege_camp,
				player = player2,
				sgroup_defenders = { 
					sg_enemy_siege_camp,
					sg_enemy_trebuchets
				},
			},
		},
		onWin = {},
		onLose = {},
	}
	
	return recipe

end




