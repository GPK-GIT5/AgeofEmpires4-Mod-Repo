function Sgroup_FilterUnfinishedRams(targetSgroup)
	local _IsBuilt = function(gid, index, sid)
		if Squad_IsOfType(sid, "scar_ram") then
			if Entity_GetBuildingProgress(Squad_GetFirstEntity(sid)) < 1 then
				SGroup_Remove(targetSgroup, sid)
			end
		end
	end
	SGroup_ForEach(targetSgroup, _IsBuilt)
end