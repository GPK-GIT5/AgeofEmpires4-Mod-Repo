			displayName = 11180227, -- Troitskoy
			buttontext = 11180303, --Archers
			tooltip = 11182404, --%1AMOUNT% Archers
			aidAmount = aid_Archers, 
			income = 40,
			purchased = false,
			spawn = mkr_vassal_forces,
			units = {{ type = "scar_archer", numSquads = aid_Archers},},
		},
		{
			id = "settlement3",
			displayName = 11180228, -- Pereslaw
			buttontext = 11180305, --Infantry
			tooltip = 11182405, --%1AMOUNT% Men-at-arms and -%2AMOUNT% Spearmen
			aidAmount = aid_Menatarms, 
			aidAmount_2 = aid_Spearman_1,
			income = 50,
			purchased = false,
			spawn = mkr_vassal_forces,
			units = {{ type = "scar_manatarms", numSquads = aid_Menatarms}, { type = "scar_spearman", numSquads = aid_Spearman_1}},
		},
		{
