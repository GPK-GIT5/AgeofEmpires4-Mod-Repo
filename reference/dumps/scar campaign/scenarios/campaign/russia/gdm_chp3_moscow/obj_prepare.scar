-- 2. save this template as a new file in the same directory as your mission script - use "obj_<prefix>.scar" for the name 
-- 3. import this file into your main mission script with import("obj_<prefix>.scar")
-- 4. call the <prefix>_InitObjectives function from inside you main mission script's Mission_SetupVariables function
--


function Prepare_InitObjectives()		-- rename this function to use your prefix for this part of the mission

	OBJ_Prepare = {
	
		Title = 11176786, --Prepare for Mongol retribution
		Type = OT_Primary,
		--PreStart = Prepare_PreStart,
		OnStart = Prepare_OnStart,
		SetupUI = function()
			UI_ReinforcePanel_UpdateData()
			Rule_AddInterval(UI_ReinforcePanel_UpdateData, 1)		
		end,
		Intel_Start = EVENTS.PrepareDefenses,
		--IsComplete = Prepare_IsComplete,
		OnComplete = Prepare_OnComplete,
		Sound_Play2D("sfx_campaign_scripted_small_group_celebrate")
		--IsFailed = Prepare_IsFailed,
		--OnFail = Prepare_OnFail,
	}
	
	SOBJ_Attack = {
	
		Title = 11182665, --Prepare for Mongol retribution
		Type = OT_Secondary,
		Parent = OBJ_Prepare,
		OnStart = Attack_OnStart,
		StartAlongsideParent = true,
	}
		
	Objective_Register(OBJ_Prepare)
	Objective_Register(SOBJ_Attack)
	
	t_reinforcementData = {
