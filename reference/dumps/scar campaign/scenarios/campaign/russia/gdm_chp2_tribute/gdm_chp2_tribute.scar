--
-- Tribute, Moscow 1375 
--
-- Russian campaign, chapter 2
--

import("MissionOMatic/MissionOMatic.scar")		-- this imports the Cardinal scripts as well

import("obj_PayTheMongols.scar")
import("obj_CollectTaxes.scar")
import("obj_BuySettlements.scar")
import("obj_BuildCabins.scar")
import("obj_BanditCamps.scar")

import("Diplomacy_Tribute.scar")		-- mission-specific version of the diplomacy panel, which here also contains the Buy Settlements panel
import("Training_Tribute.scar")


function Mission_OnGameSetup()
	
	player1 = World_GetPlayerAt(1) 
	player2 = World_GetPlayerAt(2)
	player3 = World_GetPlayerAt(3)
	player4 = World_GetPlayerAt(4)	-- unused, but I need to remove them from the tribute menu 
	
	Setup_SetPlayerName(player1, "$11180222")	-- Muscovites
	Setup_SetPlayerName(player2, "$11180223")	-- Bandits
	Setup_SetPlayerName(player3, "$11180224") 	-- Mongols
	Setup_SetPlayerName(player4, "$11180222")	-- Muscovites
	
end

function Mission_SetupPlayers()

	-- player 1 - Muscovites
	Player_SetCurrentAge(player1, AGE_FEUDAL)
	Player_SetMaximumAge(player1, AGE_FEUDAL)
	
	-- player 2 - Bandits
	Player_SetCurrentAge(player2, AGE_FEUDAL)
	Player_SetMaximumAge(player2, AGE_FEUDAL)
	
	-- player 3 - Mongols
	Player_SetCurrentAge(player3, AGE_FEUDAL)
	Player_SetMaximumAge(player3, AGE_FEUDAL)
	
	-- player 4 - Dmitry (downed state)
	Player_SetCurrentAge(player4, AGE_FEUDAL)
	Player_SetMaximumAge(player4, AGE_FEUDAL)
	
	--
	-- set player relationships	
	--
		
	Player_SetRelationship(player2, player3, R_ALLY)		-- these two are on a team only to make them ignore each other, 
	Player_SetRelationship(player3, player2, R_ALLY)		-- because we don't want rushing Mongols to get caught up on the Bandits

	Player_SetRelationship(player1, player4, R_ALLY)	 	-- player 4 is for Dmitry's downed state, so it needs to be allied
	Player_SetRelationship(player4, player1, R_ALLY)
	
	Player_SetRelationship(player2, player4, R_NEUTRAL)
	Player_SetRelationship(player4, player2, R_NEUTRAL)
	
	Player_SetRelationship(player3, player4, R_NEUTRAL)
	Player_SetRelationship(player4, player3, R_NEUTRAL)	
	
	--
	-- set player colours
	--
	
	PlayerColour_Enable()									-- turn on custom colour configuration for this session
	
	Game_SetPlayerSlotColour(player1, 1) 			-- Player	(paint scheme)
	Game_SetPlayerUISlotColour(player1, 1)			--			(ui colour)
	
	Game_SetPlayerSlotColour(player2, 2) 			-- Bandits
	Game_SetPlayerUISlotColour(player2, 2)

	Game_SetPlayerSlotColour(player3, 2) 			-- Mongols
	Game_SetPlayerUISlotColour(player3, 2)

	Game_SetPlayerSlotColour(player4, 1) 		-- Muscovites & leader holder
	Game_SetPlayerUISlotColour(player4, 1)
	
	--
	-- set player upgrades
	--
	
	PlayerUpgrades_Auto(player1)
	PlayerUpgrades_Auto(player2)
	PlayerUpgrades_Auto(player3)
	PlayerUpgrades_Auto(player4)
	
	--
	-- Turn off AI for downed leader player 
	--
	
	AI_Enable(player4, false)
	
	
end


