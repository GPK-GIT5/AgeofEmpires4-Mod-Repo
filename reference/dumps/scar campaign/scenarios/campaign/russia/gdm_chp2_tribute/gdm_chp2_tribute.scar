--- intro helper functions moved from .events file for better error reporting

function Mission_SendIntroTradeCart()
	local cart7_squad = SGroup_GetSpawnedSquadAt(sg_tradecart_settlement7, 1)
	local cart7_entity = Squad_GetFirstEntity(cart7_squad)
	
	Entity_SetAnimatorState(cart7_entity, "trade_cart_carry_resource", "gold")
	Cmd_FormationMove(sg_tradecart_settlement7, mkr_tradecart_settlement7_dest1, false)	
	Cmd_FormationMove(sg_tradecart_settlement7, mkr_tradecart_settlement7_dest2, true)	
	Cmd_FormationMove(sg_tradecart_settlement7, mkr_tradecart_settlement7_dest3, true)	
	Cmd_FormationMove(sg_tradecart_settlement7, mkr_tradecart_settlement7_dest4, true)	
	Cmd_FormationMove(sg_tradecart_settlement7, mkr_tradecart_settlement7_dest5, true)	
	Cmd_FormationMove(sg_tradecart_settlement7, mkr_tradecart_settlement7_dest6, true)	
	Cmd_FormationMove(sg_tradecart_settlement7, mkr_common_market, true)	
	Rule_Add(TributeIntro_FakeTradeCartDropOffGold)
	
	UnitEntry_DeploySquads(player1, sg_intro_shenanigans, {type= "scar_villager", destination = mkr_intro_shenanigans}, mkr_tradecart_settlement7_dest4)
	
	Rule_Add(IntroShenanigans)
end

function IntroShenanigans()
	
	if Prox_AreSquadsNearMarker(sg_tradecart_settlement7, mkr_intro_shenanigans, ANY, 3) or Event_IsAnyRunning() == false then
		Rule_RemoveMe()
		SGroup_DestroyAllSquads(sg_intro_shenanigans)
	end
end

function TributeIntro_FakeTradeCartDropOffGold()

	if SGroup_IsMoving(sg_tradecart_settlement7, ANY) == false and Util_GetDistance(sg_tradecart_settlement7, mkr_common_market) <= 10 or Event_IsAnyRunning() == false then 
		
		local cart7_squad = SGroup_GetSpawnedSquadAt(sg_tradecart_settlement7, 1)
		local cart7_entity = Squad_GetFirstEntity(cart7_squad)
		Entity_SetAnimatorState(cart7_entity, "trade_cart_carry_resource", "none")
		AssignTradeCartToSettlement(sg_tradecart_settlement7, eg_settlement7)
		
		Rule_RemoveMe()
		
	end
	
end

function Tribute_FancyAtmosphere(context, data)
	
	-- Cycle the target atmosphere
	g_atmosphereIdx = g_atmosphereIdx + 1
	if g_atmosphereIdx > #g_atmosphereNames then
		g_atmosphereIdx = 1
	end
	
	-- Start the appropriate transition
	local nextAtmo = g_atmosphereNames[g_atmosphereIdx]
	Game_TransitionToState(nextAtmo, g_atmosphereTransition)
	
	-- Kick off another rule to do this again in a while
	Rule_AddOneShot(Tribute_FancyAtmosphere, g_atmosphereTransition + g_atmosphereStable)
	
end