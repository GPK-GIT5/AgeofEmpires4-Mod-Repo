		{sbp = SBP.RUS.UNIT_KNIGHT_2_RUS, numSquads = 1, spawn = mkr_outro_extras1_spawn, destination = mkr_outro_extras1_dest},
		{sbp = SBP.RUS.UNIT_KNIGHT_2_RUS, numSquads = 1, spawn = mkr_outro_extras2_spawn, destination = mkr_outro_extras2_dest},
		{sbp = SBP.RUS.UNIT_KNIGHT_2_RUS, numSquads = 1, spawn = mkr_outro_extras3_spawn, destination = mkr_outro_extras3_dest},
		{sbp = SBP.RUS.UNIT_KNIGHT_2_RUS, numSquads = 1, spawn = mkr_outro_extras4_spawn, destination = mkr_outro_extras4_dest},
		{sbp = SBP.RUS.UNIT_KNIGHT_2_RUS, numSquads = 1, spawn = mkr_outro_extras5_spawn, destination = mkr_outro_extras5_dest},
		{sbp = SBP.RUS.UNIT_KNIGHT_2_RUS, numSquads = 1, spawn = mkr_outro_extras6_spawn, destination = mkr_outro_extras6_dest},
		{sbp = SBP.RUS.UNIT_KNIGHT_2_RUS, numSquads = 1, spawn = mkr_outro_extras7_spawn, destination = mkr_outro_extras7_dest},
		{sbp = SBP.RUS.UNIT_KNIGHT_2_RUS, numSquads = 1, spawn = mkr_outro_extras8_spawn, destination = mkr_outro_extras8_dest},

	}
	
	local parade_markers = {
		mkr_tradecart_settlement7_dest5,
		mkr_tradecart_settlement7_dest4,
