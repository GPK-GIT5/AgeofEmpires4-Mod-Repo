function Mission_Start()
	
	if UI_IsXboxControllerUI() then
		MissionTutorial_AddHintToDmitry_Xbox()
	else
		MissionTutorial_AddHintToDmitry()
	end
	
	PayTheMongols_StartObjective()
	Rule_AddOneShot(Mission_Start_PartB, 10)	
	
	-- Configure diplomacy UI to only show the Mongols
	Diplomacy_OverrideSettings(true, false, false, false)
	Diplomacy_OverridePlayerSettings(player1, false)										-- don't show yourself
	Diplomacy_OverridePlayerSettings(player2, false)										-- don't show the bandits
	Diplomacy_OverridePlayerSettings(player3, true, true, false, false, true, false)		-- mongols - only show tribute / gold
	Diplomacy_OverridePlayerSettings(player4, false)										-- don't show placeholder player
	Diplomacy_SetTaxRate(player1, 0.0)	
	Diplomacy_ShowUI(true)
	
	-- Start up the script that keeps the custom UI updated
	UI_BuySettlementsPanel_UpdateData()
	Rule_AddInterval(UI_BuySettlementsPanel_UpdateData, 1)	-- and update it every second from now on
	
	-- Start the atmosphere cycling
	Rule_AddOneShot(Tribute_FancyAtmosphere, g_atmosphereStable)
	
end

function Mission_Start_PartB()

	Objective_Start(OBJ_CollectTaxes)
	Objective_Start(OBJ_TipTradeRouteLengths)
	
	Rule_AddOneShot(BuildCabins_TriggerObjective, 60)				-- only triggers on EASY difficulty	
	
	Rule_AddInterval(Mission_CheckForFail, 1)
	
end




function Mission_CheckForFail()
	
	if Objective_IsFailed(OBJ_PayTheMongols) or Objective_IsComplete(OBJ_BuySettlements) then 
		
		-- mission is ending, stop checking for fail by TC/Landmark
		Rule_RemoveMe()									
		
	else
		
		-- check for mission fail
		if EGroup_CountSpawned(eg_importantBuildings) == 0 then 	
			Rule_RemoveMe()
			Mission_Fail()
		end
		
	end
	
end


function Mission_AdjustPlayerMaxPopCap(player, adjustment)
	
	local playerIndex = World_GetPlayerIndex(player)
	if g_maxPopCapData == nil then 
		g_maxPopCapData = {}
	end
	if g_maxPopCapData[playerIndex] == nil then 
		g_maxPopCapData[playerIndex] = {
			adjustment = 0,
		}
	end

	local playerData = g_maxPopCapData[playerIndex]

	if playerData.modid ~= nil then 	
		Modifier_Remove(playerData.modid)															-- remove prior modifier
		playerData.modid = nil
	end
	
	playerData.adjustment = playerData.adjustment + adjustment										-- calculate new adjustment amount

	if playerData.adjustment > 0 then 
		playerData.adjustment = 0 
	end
	
	if playerData.adjustment ~= 0 then 
		playerData.modid = Modify_PlayerMaxPopCap(player1, playerData.adjustment, MUT_Addition)		-- apply new modifier
	end
	
end
	


function Mission_PrepareForOutro()
	
	sg_outro = SGroup_CreateIfNotFound("sg_outro")
	sg_dmitri_outro = SGroup_CreateIfNotFound("sg_dmitri_outro")
	sg_outro_cavalry = SGroup_CreateIfNotFound("sg_outro_cavalry")
	sg_outro_infantry = SGroup_CreateIfNotFound("sg_outro_infantry")
	
	-- spawn static outro units
	local units = {
		{sbp = SBP.RUS.UNIT_PRINCE_DMITRI_CMP_RUS, spawn = mkr_outro_dmitry_spawn, sgroup = sg_dmitri_outro}, 
		{type = "scar_scout", numSquads = 2, spawn = mkr_outro_dmitry_spawn},		
		{type = "scar_spearman", numSquads = 1, spawn = mkr_outro_gate_guard1}, -- Guard to keep the gate open
		
		{type = "scar_spearman", numSquads = 4, spawn = mkr_outro_infantry1, facing = Marker_GetPosition(mkr_outro_infantry2), sgroup = sg_outro_infantry},
		{type = "scar_spearman", numSquads = 4, spawn = mkr_outro_infantry2, facing = Marker_GetPosition(mkr_outro_infantry1), sgroup = sg_outro_infantry},
		{type = "scar_archer", numSquads = 4, spawn = mkr_outro_infantry3, facing = Marker_GetPosition(mkr_outro_infantry4), sgroup = sg_outro_infantry},
		{type = "scar_archer", numSquads = 4, spawn = mkr_outro_infantry4, facing = Marker_GetPosition(mkr_outro_infantry3), sgroup = sg_outro_infantry},

		{type = "scar_archer", numSquads = 2, spawn = mkr_outro_walls1, facing = Marker_GetPosition(mkr_outro_dmitry_spawn), sgroup = sg_outro_infantry},
		{type = "scar_spearman", numSquads = 2, spawn = mkr_outro_walls2, facing = Marker_GetPosition(mkr_outro_dmitry_spawn), sgroup = sg_outro_infantry},
		{type = "scar_spearman", numSquads = 2, spawn = mkr_outro_walls3, facing = Marker_GetPosition(mkr_outro_dmitry_spawn), sgroup = sg_outro_infantry},
		{type = "scar_archer", numSquads = 2, spawn = mkr_outro_walls4, facing = Marker_GetPosition(mkr_outro_dmitry_spawn), sgroup = sg_outro_infantry},
	}
	UnitEntry_DeploySquads(player1, sg_outro, units, mkr_outro_camera)

	-- cavalry parade 	
