	BuySettlements_InitObjectives()	
	BuildCabins_InitObjectives()	
	BanditCamps_InitObjectives()	
	Tips_InitObjectives()

	
end


function Mission_SetDifficulty()
	
	t_difficulty = {
		
		-- bandits 
		bandits_GlobalCreationFrequency = 			Util_DifVar({45, 35, 30, 25}),			-- how many seconds it will be after a group of bandits is created before it will create another, globally across all groups
		bandits_ZoneCreationFrequency = 			Util_DifVar({90, 90, 75, 55}),			-- this is how long it will be for a single zone, between when a new group is required and when it spawns
		bandits_CreationFrequency_CampBonus =		Util_DifVar({10, 10, 10, 10}),			-- addition to these frequencies for each bandit camp destroyed
		bandits_PauseReleaseTimer = 				Util_DifVar({25, 25, 15, 15}),			-- when the player engages some bandits, all other bandit groups on the map pause at their next waypoint; this is how many seconds after combat has finished they get released
		bandits_SettlementsModifier =				Util_DifVar({-1, 0, 1, 2}),				-- increases the "value" assigned to settlements (which change the bandits according to thresholds)
		bandits_WanderersModifier = 				Util_DifVar({-2, -1, 0, 1}),			-- number of groups of wandering bandits (which increases as you buy more settlements), is modified by this value
		bandits_NumCamps = 							Util_DifVar({6, 6, 6, 6}),				-- number of bandit camps hidden amongst the map
		bandits_CampDestructionBonusModifier =		Util_DifVar({-2, -1, -1, -1}),			-- modifies the strength associated with settlements for a period after destroying a bandit camp  
		bandits_CampDestructionBonusPeriod =		Util_DifVar({150, 150, 120, 90}),		-- how long the bonus for desroying a bandit camp lasts

		
		-- amount of gold demanded by the Mongols per pay cycle
		payTheMongols_BaseAmount = 					Util_DifVar({1300, 1300, 1500, 1700}),	-- Initial demand from the Mongols (Note: Currently you have around 1650 gold by the end of the first pay period)
		payTheMongols_ExtraAmountPerCycle =			Util_DifVar({100, 200, 200, 300}),		-- Extra amount per cycle for the third pay cycle onwards
		
		-- buying settlements
		buySettlements_TradeAmountNeededToBuy =		Util_DifVar({500, 500, 750, 1000}),		-- how much gold you needed to have received from this settlement before you can buy it 
		buySettlements_PurchasePrice =				Util_DifVar({300, 300, 500, 700}),		-- price (in gold) of buying a settlement
		buySettlements_NumSettlementsNeeded = 		Util_DifVar({3, 3, 4, 5}),				-- how many settlements you need to buy to complete the mission
		
		-- misc 
		findSettlements_NearbyDistance = 			Util_DifVar({125, 125, 75, 0}),			-- how close you need to be to a settlement to get a hint as to it's location		

	}
	
end


function Mission_PreInit()
	
	-- prep the tribute menu for this mission (will be enabled later on)
	Core_CallDelegateFunctions("DiplomacyEnabled", false)
	Diplomacy_ShowUI(false)
	
end

function Mission_OnInit()
		
	-- apply a health modifier to all player trade carts in this mission
	local modifier = Modifier_Create(MAT_EntityType, "health_maximum_modifier", MUT_Multiplication, false, 2, EBP.RUS.UNIT_TRADE_CART_RUS)
	Modifier_ApplyToPlayer(modifier, player1, 0)

end

function Mission_Preset()
	
	-- player's upgrades
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_SCOUT_FORESTER)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_2)

	-- bandit's upgrades
	Player_CompleteUpgrade(player2, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_2)
	
	-- mongol's upgrades
	Player_CompleteUpgrade(player3, UPG.MONGOL.UPGRADE_UNIT_SPEARMAN_2_MON)
	Player_CompleteUpgrade(player3, UPG.MONGOL.UPGRADE_UNIT_HORSEMAN_2_MON)
	
	Player_SetEntityProductionAvailability(player1, BP_GetEntityBlueprint("building_defense_wall_rus"), ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, BP_GetEntityBlueprint("building_defense_wall_gate_rus"), ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, BP_GetEntityBlueprint("building_defense_tower_rus"), ITEM_REMOVED)
	
	
	-- add a villager or two around every resource drop-off point
	AssignVillagersToWood(sg_villagers_wood)
	AssignVillagersToFarms(sg_villagers_food)

	-- mark these two settlements as 'seen' right from the start (and add hintpoints), as you're already trading with them
	CollectTaxes_MarkSettlementAsSeen("settlement2")
	CollectTaxes_MarkSettlementAsSeen("settlement7")
	
	-- add some gold (on story mode only)
	if Game_GetSPDifficulty() == GD_EASY then 
		Player_AddResource(player1, RT_Gold, 500)
	end
	
	-- reduce the player's max cap to allow for spawning of the free villagers
	local freeVillagers = (t_difficulty.buySettlements_NumSettlementsNeeded - 1) * Util_DifVar({2, 2, 2, 0})
	Mission_AdjustPlayerMaxPopCap(player1, -freeVillagers)

	-- add a unit inside every wooden fort to make it shoot
	Player_GetAll(player1)
	EGroup_Filter(eg_allentities, EBP.RUS.BUILDING_DEFENSE_WOODEN_FORT_RUS, FILTER_KEEP)
	local _AddSquadToFort = function(gid, idx, eid)
		EGroup_Single(eg_single, eid)
		local units = {
			{type = "scar_spearman", spawn = eg_single},
		}
		UnitEntry_DeploySquads(player1, sg_blah, units)
	end
	EGroup_ForEach(eg_allentities, _AddSquadToFort)
	
	
	-- init several subsystems 
	Bandits_Init()
	BanditCamps_Init()
	
	
	--music preset
	
	-- Audio considerations
	if Music_UnlockIntensity then
		Sound_SetForceMusic(false)
	else
		Sound_SetForceMusic(true)
	end
	
      
	
	
end

function AssignTradeCartToSettlement(tradecart, settlement)
	
	LocalCommand_SquadEntity(player1, tradecart, SCMD_Trade, settlement, false)
	
end


