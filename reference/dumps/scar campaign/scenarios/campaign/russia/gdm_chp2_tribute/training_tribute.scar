function MissionTutorial_AddHintToBuildTraders_Xbox()

	Player_GetAll(player1)
	EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
	EGroup_Filter(eg_allentities, EBP.RUS.BUILDING_ECON_MARKET_CONTROL_RUS, FILTER_KEEP)
	
	if EGroup_CountSpawned(eg_allentities) >= 1 then 
		
		local entity = Entity_GetID(EGroup_GetSpawnedEntityAt(eg_allentities, 1))
		
		local GoalSelectMarket = Training_Goal(
			entity, 
			{
				ID = "Build more Traders at the Market. More trade routes active equals more income.", 
				Message = "$11192286",
				DataTemplate = "GenericTrainingDataTemplate",
			}, 
			Predicate_UserHasSelectedAMarket
			)
		
		local GoalOnOpenRadial = Training_Goal(
			entity,
			{
				ID = "Hold RT to open the radial menu.",
				Message = "$1000968",
				DataTemplate = "GenericTrainingDataTemplate",
			},
			UserHasOpenedContextualRadial
		)
		
		local GoalBuildTrader = Training_Goal(
			SBP.RUS.UNIT_TRADE_CART_RUS, 
			{
				ID = "Select this option to produce a Trader.", 
				Message = "$11249923", 
				DataTemplate = "RadialTrainingDataTemplate",
			},
			Predicate_UserHasLookedAtBuildTraderButton
		)
		
		local GoalSequenceBuildTraders = Training_GoalSequence(
			goal_sequence_buildtraders, 						-- id
			1, 													-- repeatMax
			0, 													-- remindMax
			AModeratePeriodOfTimeHasPassed, 					-- trigger
			Ignore_IfMarketIsDestroyed, 						-- ignore
			nil,										 		-- remind
			nil, 												-- bypass
			true, 												-- canRegress
			{GoalSelectMarket, GoalOnOpenRadial, GoalBuildTrader}					-- goals
			)
		Training_AddGoalSequence(GoalSequenceBuildTraders)
		
		Training_EnableGoalSequenceByID(goal_sequence_buildtraders, true)
		
	end
	
end

