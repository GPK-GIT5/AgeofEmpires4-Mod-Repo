function MissionTutorial_AddHintToBuildDefencesAroundSettlement(settlement)
	
	t_hint_settlement = settlement 
	
	local GoalBuildDefences = Training_Goal(
		Util_GetPosition(settlement.marker), 
		{
			ID = "Construct some defences around your new settlement.", 
			Message = "$11192290", 
			DataTemplate = "GenericTrainingDataTemplate",
		},
		Predicate_UserHasBuiltDefences
	)
	
	local GoalSequenceDefendSettlement = Training_GoalSequence(
		goal_sequence_defendsettlement, 					-- id
		1, 													-- repeatMax
		0, 													-- remindMax
		ABriefPeriodOfTimeHasPassed, 						-- trigger
		CampaignTraining_TimeoutIgnorePredicate, 			-- ignore
		nil,										 		-- remind
		nil,							 					-- bypass
		false, 												-- canRegress
		{GoalBuildDefences}									-- goals
	)
	Training_AddGoalSequence(GoalSequenceDefendSettlement)
	
	Training_EnableGoalSequenceByID(goal_sequence_defendsettlement, true)
			
end

function Predicate_UserHasBuiltDefences()
	
	Player_GetAllEntitiesNearMarker(player1, eg_temp, t_hint_settlement.marker, Marker_GetProximityRadiusOrDefault(t_hint_settlement.marker, 0) * 2)
	EGroup_Filter(eg_temp, {EBP.RUS.BUILDING_DEFENSE_WOODEN_FORT_RUS, EBP.RUS.BUILDING_DEFENSE_PALISADE_RUS, EBP.RUS.BUILDING_DEFENSE_WALL_RUS}, FILTER_KEEP)
	
	if EGroup_CountSpawned(eg_temp) >= 1 then 
		return true 
	end

end



function Tips_InitObjectives()
	
	OBJ_TipTradeRouteLengths = {
	
		Title = "$11192283",			-- Tip: Longer trade routes generate more gold for each trip
		Type = ObjectiveType_Tip,
		Parent = OBJ_CollectTaxes,
		
		showTitle = false,
		
	}	
	
	OBJ_TipManageGold = {
	
		Title = "$11201547",			-- Tip: Manage your Gold to both buy settlements and pay the Mongols
		Type = ObjectiveType_Tip,
		Parent = OBJ_CollectTaxes,
		
		showTitle = false,
		
	}

	Objective_Register(OBJ_TipTradeRouteLengths)
	Objective_Register(OBJ_TipManageGold)
	
end
