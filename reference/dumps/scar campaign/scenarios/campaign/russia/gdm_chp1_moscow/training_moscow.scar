function Trigger_GoldGenHuntingCabinIsOnScreen(goalSequence)
	
	if AShortPeriodOfTimeHasPassed(goalSequence) == false then 
		return false 
	end
	
	if EGroup_CountSpawned(eg_forestHouses) >= 1 then 
		
		local onScreenCabin = nil 
		
		local _CheckEntity = function(gid, idx, eid)
			if Player_OwnsEntity(player1, eid) and Misc_IsEntityOnScreen(eid, 0.8) then 
				onScreenCabin = eid
				return true		-- breaks ForEach loop
			end
		end
		EGroup_ForEach(eg_forestHouses, _CheckEntity)
		
		if onScreenCabin ~= nil then 
			goalSequence.goals[1].key = onScreenCabin
			return true 
		end
	end		
	
end

function Predicate_UserHasSelectedGoldGenHuntingCabin(goal)
	return Misc_IsEGroupSelected(eg_forestHouses, ANY)
end




--
-- Build scouts to search for villagers
--

function MissionTutorial_AddHintToBuildScouts()

	if EGroup_CountSpawned(eg_townCenter) >= 1 then 
		
		local GoalBuildScout = Training_Goal(
			EGroup_GetSpawnedEntityAt(eg_townCenter, 1),		-- key
			{	
				ID = "Build a scout from your Town Center or a Hunting Cabin in order to search the forests for villagers.", 
				Message = "$11201990", 
				DataTemplate = "GenericTrainingDataTemplate"
			}, 
			Predicate_UserHasSelectedScoutProductionBuilding		-- isComplete
			)
		
		local GoalSequenceBuildScout = Training_GoalSequence(
			goal_sequence_buildscout,							-- id
			1, 													-- repeatMax
			0, 													-- remindMax
			Trigger_ScoutProductionBuildingIsOnScreen, 			-- trigger
			CampaignTraining_TimeoutIgnorePredicate, 			-- ignore
			nil,										 		-- remind
			Predicate_UserHasSelectedScoutProductionBuilding, 	-- bypass
			false, 												-- canRegress
			{GoalBuildScout}									-- goals
			)
		Training_AddGoalSequence(GoalSequenceBuildScout)
		
		Training_EnableGoalSequenceByID(goal_sequence_buildscout, true)
	
	end
	
end


function Trigger_ScoutProductionBuildingIsOnScreen(goalSequence)
	
	if AShortPeriodOfTimeHasPassed(goalSequence) == false then 
		return false 
	end
	
	Player_GetAll(player1)
	EGroup_Filter(eg_allentities, {EBP.RUS.BUILDING_TOWN_CENTER_CAPITAL_RUS, EBP.RUS.BUILDING_HUNTING_CABIN_RUS}, FILTER_KEEP)
	
	local onScreenEntity 
	
	local _FindEntityOnScreen = function(gid, idx, eid)
		if Misc_IsEntityOnScreen(eid, 0.8) then 
			onScreenEntity = eid 
			return true 		-- breaks ForEach loop
		end
	end
	EGroup_ForEach(eg_allentities, _FindEntityOnScreen)
	
	if onScreenEntity ~= nil then 
		goalSequence.goals[1].key = onScreenEntity 
		return true 
	end
	
end

function Predicate_UserHasSelectedScoutProductionBuilding(goal)

	Player_GetAll(player1)
	EGroup_Filter(eg_allentities, {EBP.RUS.BUILDING_TOWN_CENTER_CAPITAL_RUS, EBP.RUS.BUILDING_HUNTING_CABIN_RUS}, FILTER_KEEP)

	return Misc_IsEGroupSelected(eg_allentities, ANY)
	
end






--
-- Garrison Outpost (Wooden Fortress for the Rus)
--

function MissionTutorial_AddHintToGarrisonOutposts()
	
	local GoalGarrisonOutpost = Training_Goal(
		entity, 											-- key
		{	
			ID = "Select a unit and RIGHT-CLICK on this Wooden Fortress to garrison them inside, where they will be able to shoot at nearby enemies.", 
			Message = UI_PickIDForInputMode(11192282, 11248503),
			DataTemplate = "RightClickTrainingDataTemplate"
		}, 
		Predicate_UserHasGarrisonedOutpost					-- isComplete
	)

	local GoalSequenceGarrisonOutpost = Training_GoalSequence(
		goal_sequence_garrisonoutposts, 					-- id
		1, 													-- repeatMax
		0, 													-- remindMax
		Trigger_OutpostAndUnitIsOnScreen, 					-- trigger
		CampaignTraining_TimeoutIgnorePredicate, 			-- ignore
		nil,										 		-- remind
		Predicate_UserHasGarrisonedOutpost, 				-- bypass
		true, 												-- canRegress
		{GoalGarrisonOutpost}								-- goals
	)
	Training_AddGoalSequence(GoalSequenceGarrisonOutpost)
		
	Training_EnableGoalSequenceByID(goal_sequence_garrisonoutposts, true)	
	
end


function Trigger_OutpostAndUnitIsOnScreen(goalSequence)
	
	if AShortPeriodOfTimeHasPassed(goalSequence) == false then 
		return false 
	end
	
	local egroup = EGroup_CreateUnique("")
	EGroup_Duplicate(eg_constructDefences, egroup)
	EGroup_FilterUnderConstruction(egroup, FILTER_REMOVE)
	
	if EGroup_CountSpawned(egroup) >= 1 then 
		
		local onScreenOutpost = nil 
		
		local _CheckEntity = function(gid, idx, eid)
			if Misc_IsEntityOnScreen(eid, 0.8) then 

				Player_GetAllSquadsNearMarker(player1, sg_temp, Util_GetPosition(eid), 20)
				
				local _CheckSquad = function(gid, idx, sid)
					return Misc_IsSquadOnScreen(sid, 0.8) 
				end
				
				if SGroup_ForEachAllOrAny(sg_temp, ANY, _CheckSquad) == true then 
					onScreenOutpost = eid
					return true		-- breaks EGroup_ForEach loop
				end
				
			end
		end
		EGroup_ForEach(egroup, _CheckEntity)
		
		if onScreenOutpost ~= nil then 
			goalSequence.goals[1].key = Entity_GetID(onScreenOutpost)
			return true 
		end
	end		
	
end

function Predicate_UserHasGarrisonedOutpost(goal)	-- do any of the outposts have units in them?
	
	Player_GetAll(player1)
	EGroup_Filter(eg_allentities, EBP.RUS.BUILDING_DEFENSE_WOODEN_FORT_RUS, FILTER_KEEP)
	EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)

	return EGroup_IsHoldingAny(eg_allentities)
	
end

