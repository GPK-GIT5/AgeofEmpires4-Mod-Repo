		goal_sequence_huntingcabins_goldgen,				-- id
		1, 													-- repeatMax
		0, 													-- remindMax
		Trigger_GoldGenHuntingCabinIsOnScreen, 				-- trigger
		CampaignTraining_TimeoutIgnorePredicate, 			-- ignore
		nil,										 		-- remind
		Predicate_UserHasSelectedGoldGenHuntingCabin, 		-- bypass
