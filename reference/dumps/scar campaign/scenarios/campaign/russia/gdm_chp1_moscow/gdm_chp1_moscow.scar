--
-- Moscow 1238
--
-- Russian campaign, chapter 1
--

import("MissionOMatic/MissionOMatic.scar")		-- this imports the Cardinal scripts as well

import("obj_ProtectMoscow.scar")
import("obj_RebuildMoscow.scar")
import("obj_ExpandMoscow.scar")
import("obj_FindVillagers.scar")
import("obj_BuildDefences.scar")
import("obj_MongolAttacks.scar")

import("training_moscow.scar")



function Mission_SetupPlayers()
	
	--
	-- get player IDs for each player
	-- 
	
	player1 = World_GetPlayerAt(1) -- Player
	player2 = World_GetPlayerAt(2) -- Mongols
	player3 = World_GetPlayerAt(3) -- Villagers

	
	-- player 1 - Player
	Setup_SetPlayerName(player1, "$11180184") -- Muscovites
	Player_SetCurrentAge(player1, AGE_DARK)
	Player_SetMaximumAge(player1, AGE_FEUDAL)

	-- player 2 - Mongols
	Setup_SetPlayerName(player2, "$11180185") -- Golden Horde 
	Player_SetCurrentAge(player2, AGE_FEUDAL)
	Player_SetMaximumAge(player2, AGE_FEUDAL)

	-- player 3 - Villagers
	Setup_SetPlayerName(player3, "$11180186") -- Villagers
	Player_SetCurrentAge(player3, AGE_DARK)
	Player_SetMaximumAge(player3, AGE_FEUDAL)


	--
	-- set player relationships	
	--
	
	Player_SetRelationship(player1, player3, R_ALLY)		-- make sure you set relationships both ways
	Player_SetRelationship(player3, player1, R_ALLY)

	Player_SetRelationship(player2, player3, R_NEUTRAL)
	Player_SetRelationship(player3, player2, R_NEUTRAL)
	
	World_EnableSharedLineOfSight(player1, player3, false)
	World_EnableSharedLineOfSight(player3, player1, false)
	
	
	--
	-- set player colours
	--
	
	PlayerColour_Enable()									-- turn on custom colour configuration for this session
	
	Game_SetPlayerSlotColour(player1, 1) 			-- Player	(paint scheme)
	Game_SetPlayerUISlotColour(player1, 1)			--			(ui colour)
	
	Game_SetPlayerSlotColour(player2, 2) 			-- Mongols
	Game_SetPlayerUISlotColour(player2, 2)

	Game_SetPlayerSlotColour(player3, 9) 			-- Villagers
	Game_SetPlayerUISlotColour(player3, 9)
	

	--
	-- perform upgrades
	-- 
	
	PlayerUpgrades_Auto(player1)
	PlayerUpgrades_Auto(player2)
	PlayerUpgrades_Auto(player3)
		
	
	
end


