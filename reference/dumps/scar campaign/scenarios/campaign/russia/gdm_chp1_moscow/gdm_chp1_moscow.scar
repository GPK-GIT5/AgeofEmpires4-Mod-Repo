function Mission_Start()
	
	Objective_Start(OBJ_ProtectMoscow)
	
	Player_GetAll(player1)									-- remove the invulnerability 
	SGroup_SetInvulnerable(sg_allsquads, false)
	Player_GetAll(player2)
	SGroup_SetInvulnerable(sg_allsquads, false)	
	
	-- add function to add / restock wolves to the forests over time
	Rule_AddInterval(Mission_AddMoreWolves, 30)
	
	MissionTutorial_Init()
	
end

function MissionStart_SetMoscowOnFire()
	

	local wallDestroyMarkers = {
		mkr_wall_destroy1,
		mkr_wall_destroy2,
	}
	local wallFireMarkers = {
		mkr_wall_fire1,
		mkr_wall_fire2,
		mkr_wall_fire3,
	}
	
	local location = LOCATION("InnerCity")	
	modid_fireThreshold = Modify_OnFireHealthPercentage(location.egroup, MUT_Addition, t_difficulty.fireThreshold)
	
	-- destroy wall sections
	for index, marker in pairs(wallDestroyMarkers) do 
		Player_GetAllEntitiesNearMarker(player1, eg_temp, marker)
		EGroup_Filter(eg_temp, "wall", FILTER_KEEP)
		EGroup_AddEGroup(eg_start_wallToDestroy, eg_temp)
		
		Player_GetAllEntitiesNearMarker(player1, eg_temp, marker, Marker_GetProximityRadiusOrDefault(marker, 0) + 3)
		EGroup_Filter(eg_temp, "wall", FILTER_KEEP)
		EGroup_AddEGroup(eg_startOnFire, eg_temp)		
	end
	EGroup_RemoveGroup(eg_startOnFire, eg_start_wallToDestroy)
	
	-- add wall sections to the 'start on fire' egroup
	for index, marker in pairs(wallFireMarkers) do 
		Player_GetAllEntitiesNearMarker(player1, eg_temp, marker)
		EGroup_Filter(eg_temp, "wall", FILTER_KEEP)
		EGroup_AddEGroup(eg_startOnFire, eg_temp)
	end
	
	
	-- set buildings on fire, but reduce fire damage speed
	local _SetOnFire = function(gid, idx, eid)
		local desiredHealth = World_GetRand(60, 74) / 100		-- randomize the health so things don't all burn down in sync
		if Entity_IsOfType(eid, "wall") then 
			desiredHealth = desiredHealth - 0.4					-- (lower this value even more if it's a wall)
		end
		
		Entity_SetHealth(eid, desiredHealth)
		Entity_SetOnFire(eid)
	end
	EGroup_ForEach(eg_startOnFire, _SetOnFire)

	local _DestroyDuringIntro = function(gid, idx, eid)
		Entity_SetHealth(eid, World_GetRand(15, 25) / 100)		-- randomize the health so things don't all burn down in sync
		Entity_SetOnFire(eid)
	end
	EGroup_ForEach(eg_destroyDuringIntro, _DestroyDuringIntro)
	
	Rule_AddOneShot(MissionStart_SetMoscowOnFire_PartB, 0.125)
	
end
function MissionStart_SetMoscowOnFire_PartB()

	EGroup_Kill(eg_start_wallToDestroy)	

	Player_GetAll(player1)
	EGroup_RemoveGroup(eg_allentities, eg_start_wallToDestroy)	
	EGroup_RemoveGroup(eg_allentities, eg_destroyDuringIntro)	
	modid_fireDamageRate = Modify_OnFireDamagePerTick(eg_allentities, MUT_Multiplication, 0)	-- this means no damage occurs during the intro, a different modifier is applied after the game starts
	
	Rule_AddInterval(MissionStart_SetMoscowOnFire_PartC, 1)
	
end

function Mission_CheckForFail()

	if Objective_IsStarted(OBJ_MongolAttacks) then -- this objective has it's own check, which will fail the objective before failing the mission, so let it take over
		Rule_RemoveMe()
		return
	end
	
		
	-- check for mission fail
	Player_GetAll(player1)
	EGroup_Filter(eg_allentities, {EBP.RUS.BUILDING_TOWN_CENTER_CAPITAL_RUS, EBP.RUS.BUILDING_LANDMARK_AGE1_NOVGOROD_KREMLIN_CONTROL_RUS}, FILTER_KEEP)
	EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
	
	if EGroup_Count(eg_allentities) == 0 then 
		Rule_RemoveMe()
		Mission_Fail()
	end
		
	
end

function MissionStart_SetMoscowOnFire_PartC()
	
	if 	Objective_IsStarted(OBJ_ProtectMoscow) == true then 
		
		Rule_RemoveMe()
		
		if modid_fireDamageRate ~= nil then 
			Modifier_Remove(modid_fireDamageRate)
		end
		
		modid_fireDamageRate = Modify_OnFireDamagePerTick(eg_importantBuildings, MUT_Multiplication, t_difficulty.fireDamageRate)	
		
	end
	
end



function Mission_AddMoreWolves()
	
	if SGroup_CountSpawned(sg_wolves) < t_difficulty.maximumNumberOfWolves then 

		SGroup_Clear(sg_temp)

		-- pick a random destination (will be further randomized in a bit)
		local destinationPos = Table_GetRandomItem(t_wolfDestinationMarkers)
		local spawnPos = Util_GetClosestMarker(destinationPos, t_wolfSpawnMarkers)
		
		-- spawn a wolf
		local units = {sbp = SBP.GAIA.GAIA_HUNTABLE_WOLF}
		UnitEntry_DeploySquads(player1, {sg_wolves, sg_gaia, sg_temp}, units, spawnPos)
		SGroup_SetWorldOwned(sg_temp)
					
		if SGroup_CountSpawned(sg_temp) >= 1 then 
			local squad = SGroup_GetSpawnedSquadAt(sg_temp, 1)
			if Squad_Count(squad) >= 1 then 
				local entity = Squad_GetFirstEntity(squad)
				
				-- pick a hidden position to move it to
				
				local randomPosition = World_GetSpawnablePosition(Util_GetRandomPosition(destinationPos), entity)
				local hiddenPosition = World_GetHiddenPositionOnPath(player1, spawnPos, randomPosition, CHECK_IN_FOW)
				
				if scartype(hiddenPosition) == ST_SCARPOS then
					
					Squad_SetPosition(squad, hiddenPosition, Util_GetPosition(mkr_location_moscow))
					Entity_SetPosition(entity, hiddenPosition)
					--Squad_WarpToPos(squad, hiddenPosition)
					
				else
					
					print("Warning - Could not find a hidden position to move the wolf to")
					Squad_Destroy(squad)
					
				end
			end
		end
	end
	
end



function Mission_AdjustPlayerMaxPopCap(player, adjustment)
	
	local playerIndex = World_GetPlayerIndex(player)
	if g_maxPopCapData == nil then 
		g_maxPopCapData = {}
	end
	if g_maxPopCapData[playerIndex] == nil then 
		g_maxPopCapData[playerIndex] = {
			adjustment = 0,
		}
	end

	local playerData = g_maxPopCapData[playerIndex]
	
	if playerData.modid ~= nil then 	
		Modifier_Remove(playerData.modid)															-- remove prior modifier
		playerData.modid = nil
	end
	
	playerData.adjustment = playerData.adjustment + adjustment										-- calculate new adjustment amount

	if playerData.adjustment ~= 0 then 
		playerData.modid = Modify_PlayerMaxPopCap(player1, playerData.adjustment, MUT_Addition)		-- apply new modifier
	end
	
end
	



function Mission_SetupCheatForOutroCamera()
	
	OBJ_DebugComplete = {
        Title = LOC("Debug Complete"),
        Type = OT_Primary,
        showTitle = false,
        Cheat = function()
			Rule_RemoveAll()
			Mission_Complete()
		end,
	}

    Objective_Register(OBJ_DebugComplete)	
	
end

function Mission_PrepareForOutro()
	
	-- delete existing units 
	Player_GetAll(player1)						-- player
	SGroup_DestroyAllSquads(sg_allsquads)
	
	Player_GetAll(player2)						-- enemies
	SGroup_DestroyAllSquads(sg_allsquads)

	Player_GetAll(player3)						-- scared villagers
	SGroup_DestroyAllSquads(sg_allsquads)
	
	-- add the kremlin and the market if they don't already exist (i.e. debug triggering the outro early)
	Player_GetAll(player1, sg_outro, eg_allentities)
	if EGroup_HasBlueprint(eg_allentities, EBP.RUS.BUILDING_LANDMARK_AGE1_NOVGOROD_KREMLIN_CONTROL_RUS, ANY) == false then 
		Util_CreateEntities(player1, eg_blah, EBP.RUS.BUILDING_LANDMARK_AGE1_NOVGOROD_KREMLIN_CONTROL_RUS, mkr_common_kremlin_landmark, 1, Util_GetOffsetPosition(mkr_common_kremlin_landmark, OFFSET_LEFT, 10))
	end
	if EGroup_HasBlueprint(eg_allentities, EBP.RUS.BUILDING_ECON_MARKET_CONTROL_RUS, ANY) == false then 
		Util_CreateEntities(player1, eg_blah, EBP.RUS.BUILDING_ECON_MARKET_CONTROL_RUS, mkr_common_market, 1, Util_GetOffsetPosition(mkr_common_market, OFFSET_LEFT, 10))
	end
	
	-- spawn units around the Kremlin
	local units = {
		{type = "scar_villager", spawn = mkr_outro_villagers1, numSquads = 3, facing = Marker_GetPosition (mkr_common_kremlin_landmark)},
		{type = "scar_villager", spawn = mkr_outro_villagers2, numSquads = 2, facing = Marker_GetPosition (mkr_common_kremlin_landmark)},
		{type = "scar_villager", spawn = mkr_outro_villagers3, numSquads = 2, facing = Marker_GetPosition (mkr_common_kremlin_landmark)},
		{type = "scar_villager", spawn = mkr_outro_villagers4, numSquads = 1, facing = Marker_GetPosition (mkr_common_kremlin_landmark)},
		{type = "scar_villager", spawn = mkr_outro_villagers5, numSquads = 2, facing = Marker_GetPosition (mkr_common_kremlin_landmark)},
		{type = "scar_spearman", spawn = mkr_outro_units1, numSquads = 5, facing = Marker_GetPosition (mkr_common_kremlin_landmark)},		
	}
	UnitEntry_DeploySquads(player1, sg_outro, units, mkr_outro_camera)
	
	
end

