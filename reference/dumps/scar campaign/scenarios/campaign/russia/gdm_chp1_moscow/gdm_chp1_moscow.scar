function Mission_SetDifficulty()
		
	t_difficulty = {
		
		-- general 
		maximumNumberOfWolves = 		Util_DifVar({10, 15, 20, 30}),			-- how many wolves we want patrolling the map 
		findVillagers_NearbyDistance = 	Util_DifVar({75, 75, 50, 0}),			-- how close you need to be to a hunting cabin to get a hint as to it's location
		
		-- defend moscow
		fireDamageRate = 				Util_DifVar({0.35, 0.4, 0.7, 1.0}),
		fireThreshold = 				Util_DifVar({0.5, 0.5, 0.55, 0.6}),
		
		-- find villagers
		numberOfScaredVillagers = 		Util_DifVar({6, 6, 5, 3}),				-- how many sets of villagers (and therefore pre-placed hunting cabins) that can be found
		
		-- mongol attack objective
		mongolAttackDelay = 			Util_DifVar({10, 10, 8, 5}),			-- how many minutes before the mongol attacks objective starts
		
		-- probing attacks
		probingAttackFrequency = 		Util_DifVar({2, 2, 1.6, 1.2}),			-- frequency of probing attacks (in mins, and a random 0-30 secs added on top)
		probingAttackLevelAdjustment = 	Util_DifVar({0, 0, 1, 2}),				-- adjust the level of the probing attacks (escalates from lone scouts to very small skirmish parties)
		
	}	
	
end


function Mission_SetRestrictions()

	Player_SetSquadProductionAvailability(player1, SBP.RUS.UNIT_TRADE_CART_RUS, ITEM_REMOVED)	-- no trade posts to trade with on this mission

end



function Mission_Preset()

	MongolCountdown_InitObjectives()
	ProtectMoscow_InitObjectives()
	RebuildMoscow_InitObjectives()
	ExpandMoscow_InitObjectives()
	BuildDefences_InitObjectives()
	MongolAttacks_InitObjectives()
	FindVillagers_InitObjectives()
	
	MissionStart_SetMoscowOnFire()
	
	Mission_SetupCheatForOutroCamera()
	
	--Music_LockIntensity(MUSIC_COMBAT)						-- game starts with intense combat music with the Mongols in your city
	
	Sound_ResetMusicIntensityMapping()
	Sound_AddMusicIntensityMappingPoint(60, 550) 			-- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(450, 4000) 			-- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(900, 9999) 			-- raw value max to scaled value max 
	
	-- extra starting resources
	Player_AddResource(player1, RT_Wood, 300)	

	-- intro shenanigans
	Player_GetAll(player1)									-- make the mongols and player villagers invulnerable during the intro 
	SGroup_SetInvulnerable(sg_allsquads, true)
	Player_GetAll(player2)
	SGroup_SetInvulnerable(sg_allsquads, true)	
	
end



