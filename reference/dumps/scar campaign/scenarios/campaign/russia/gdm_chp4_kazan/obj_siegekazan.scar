--
-- Siege of Kazan
--

function SiegeKazan_InitObjectives()
	
	OBJ_SiegeKazan = {
		Title = "$11180271", -- Siege Kazan
		Type = ObjectiveType_Primary,
		
		OnStart = function()
			Music_RestartAfterObjective(1) 
			--Objective_Start(SOBJ_BreachOuter)
			Rule_AddInterval (Kazan_ProxForSpeech, 5)
			Rule_AddInterval(Kazan_AutoSaveLoop, 900)
		end,
		
		IsComplete = function()
			return Objective_IsComplete(SOBJ_KillKhanGuards)
		end,
		
		OnComplete = function()
			-- ACHIEVEMENT - Check for requirements
          	Achievement_CheckAnnihilation()			
			Mission_Complete()
		end,
	}
	
	SOBJ_BreachOuter = {
		Title = "$11180272", -- Breach Kazan's Outer Wall
		Type = ObjectiveType_Primary,
		Parent = OBJ_SiegeKazan,
		StartAlongsideParent = true,
		Intel_Complete = EVENTS.Breach_Outer,
		
		OnStart = function()
			hint_KazanWallNorth = Objective_AddUIElements(SOBJ_BreachOuter, mkr_kazandefnorthgate, true, 11180276, true, nil, nil, nil, "icons/races/mongols/abilities/unpack" ) -- Kazan Outer Wall
			hint_KazanWallSouth = Objective_AddUIElements(SOBJ_BreachOuter, mkr_kazandefsouthgate, true, 11180276, true, nil, nil, nil, "icons/races/mongols/abilities/unpack" ) -- Kazan Outer Wall
			
			
			Rule_AddEGroupEvent(Kazan_OuterWallBreached, eg_mon_outerwalls, GE_EntityKilled)
			Rule_AddEGroupEvent(Kazan_InnerWallBreached, eg_mon_innerwalls, GE_EntityKilled)
			
		end,
		
		OnComplete = function()
			Game_TransitionToState("taiga_morning", 30)
			kazan_intensity = kazan_intensity + 1
			Objective_RemoveUIElements(SOBJ_BreachOuter, hint_KazanWallNorth)
			Objective_RemoveUIElements(SOBJ_BreachOuter, hint_KazanWallSouth)
			-- start the inner wall objective unless something else has already triggered it
			if not Objective_IsStarted(SOBJ_BreachInner) then
				Objective_Start(SOBJ_BreachInner)
			end
		end,

		IsFailed = function()
		end,
		
		OnFail = function()
		end,
	}
	
	SOBJ_BreachInner = {
		Title = 11180273, -- Breach Kazan's Inner Wall
		Type = ObjectiveType_Primary,
		Parent = OBJ_SiegeKazan,
		Intel_Complete = EVENTS.Breach_Inner,
		
		OnStart = function()
			hint_KazanWallInner = Objective_AddUIElements(SOBJ_BreachInner, mkr_innerkazangate, true, 11180277, true, nil, nil, nil, "icons/races/mongols/abilities/unpack" ) -- Kazan Inner Wall
			Kazan_SpawnKazanDefenders()
		end,
		
		OnComplete = function()
			Kazan_FallbackToInnerDefense()
			HintPoint_RemoveAll()
			Objective_Start(SOBJ_KillKhanGuards)
		end,
		
		IsFailed = function()
		end,
		
		OnFail = function()
		end,
	}
	
	SOBJ_KillKhanGuards = {
		Title = 11180274, -- Defeat Khan's Guards
		Type = ObjectiveType_Primary,
		Parent = OBJ_SiegeKazan,
		
		OnStart = function()
			Music_LockIntensity(MUSIC_TENSE_COMBAT_RARE, 120)
			Obj_SetProgressVisible(SOBJ_KillKhanGuards.ID, true)
			Obj_SetProgress(SOBJ_KillKhanGuards.ID, ((khan_guard_max - SGroup_Count(sg_mon_kazan_elite)) / khan_guard_max))
			Rule_AddInterval(Kazan_GuardSpotted, 1)
		end,
		
		IsComplete = function()
			Obj_SetProgress(SOBJ_KillKhanGuards.ID, (khan_guard_max - SGroup_Count(sg_mon_kazan_elite)) / khan_guard_max)
			if (SGroup_IsEmpty(sg_mon_kazan_elite)) then
				return true
			else
				return false
			end
		end,
		
		OnComplete = function()
		end,
		
		IsFailed = function()
		end,
		
		OnFail = function()
		end,
	}
	
	OBJ_Failure = {
		Title = 11180271, -- Siege Kazan
		Type = ObjectiveType_Primary,
				
		IsComplete = function()
			return Objective_IsComplete(SOBJ_KillKhanGuards)
		end,
		
		OnComplete = function()
			Util_StartIntel(EVENTS.Kazan_Outro_Camera)
		end,
		
		IsFailed = function()
		end,
		
		OnFail = function()
		end,
	}
	
	OBJ_DebugComplete = {
		Title = LOC("Debug Complete"),
		Type = ObjectiveType_Primary,
		showTitle = false,
		Cheat = function()
			Mission_Complete()
		end,
	}
	
	Objective_Register(OBJ_SiegeKazan)
	Objective_Register(SOBJ_BreachOuter)
	Objective_Register(SOBJ_BreachInner)
	Objective_Register(SOBJ_KillKhanGuards)
	Objective_Register(OBJ_DebugComplete)
end


function Kazan_OuterWallBreached(context)
			
	if context.victim ~= nil then
		Sound_Play2D(MUS_STING_TRIUMPHANT)
		local pos = Util_GetPosition(context.victim)
		Player_GetAllSquadsNearMarker(player1, sg_temp, pos, 30) 
		print ("Outer wall walla with groupsize "..SGroup_CountSpawned(sg_temp))
		if SGroup_CountSpawned(sg_temp) > 0 then
			Sound_PlayWallaCelebrateOnSGroup(sg_temp)
		else
			Sound_Play3D(WALLA_CAMP_CELEBRATE_MEDIUM, context.victim)
		end
		Objective_Complete(SOBJ_BreachOuter)
		Rule_RemoveEGroupEvent(Kazan_OuterWallBreached, eg_mon_outerwalls)		
	end 
end


function Kazan_InnerWallBreached(context)
	
	if context.victim ~= nil then
		Sound_Play2D(MUS_STING_TRIUMPHANT)
		local pos = Util_GetPosition(context.victim)
		Player_GetAllSquadsNearMarker(player1, sg_temp, pos, 30) 
		print ("Inner wall walla with groupsize "..SGroup_CountSpawned(sg_temp))
		if SGroup_CountSpawned(sg_temp) > 0 then
			Sound_PlayWallaCelebrateOnSGroup(sg_temp)
		else
			Sound_Play3D(WALLA_CAMP_CELEBRATE_MEDIUM, context.victim)
		end
	end	
	
	-- flow if we go straight to the inner walls (bypassing the outer city & walls)
	if not Objective_IsStarted(SOBJ_BreachInner) then
		Objective_Start (SOBJ_BreachInner, false, false)
		Objective_Complete(SOBJ_BreachOuter, false, false)
		if Rule_Exists(Kazan_OuterWallBreached) then
			Rule_RemoveEGroupEvent(Kazan_OuterWallBreached, eg_mon_outerwalls)
		end
	end
		
	Objective_Complete (SOBJ_BreachInner)
	Rule_RemoveEGroupEvent(Kazan_InnerWallBreached, eg_mon_innerwalls)		
end

function Kazan_GuardSpotted()
	
	if Player_CanSeeSGroup(player1, sg_mon_kazan_elite, ANY) then
		Rule_RemoveMe()
		Sound_PlayWallaChargeOnSGroup(sg_mon_kazan_elite)
		Util_StartIntel(EVENTS.Guard_Attack)
	end
	
	
end

function CheckMarkerForUnits(marker)
	Player_GetAllSquadsNearMarker(player1, sg_temp, marker)
	if SGroup_CountSpawned(sg_temp) > 0 then
		return true
	else
		return false
	end
end

function Kazan_CheckDefendNorthOutpostKilled()
	if SGroup_IsEmpty(MissionOMatic_FindModule("DefendNorthOutpost1").sgroup) and SGroup_IsEmpty(MissionOMatic_FindModule("DefendNorthOutpost2").sgroup) and SGroup_IsEmpty(MissionOMatic_FindModule("DefendNorthOutpost3").sgroup) then
		kazan_intensity = kazan_intensity + 1
		Rule_RemoveMe()
	end
end

function Kazan_CheckDefendFieldGateKilled()
	if SGroup_IsEmpty(MissionOMatic_FindModule("DefendFieldGate1").sgroup) and SGroup_IsEmpty(MissionOMatic_FindModule("DefendFieldGate2").sgroup) and SGroup_IsEmpty(MissionOMatic_FindModule("DefendFieldGate3").sgroup) then
		kazan_intensity = kazan_intensity + 1
		Rule_RemoveMe()
	end
end

