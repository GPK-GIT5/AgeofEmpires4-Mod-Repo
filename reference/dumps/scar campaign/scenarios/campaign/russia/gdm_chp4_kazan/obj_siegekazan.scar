function Kazan_OutroCavLoop()
	if outroCavCount == outroCavTarget then
		Rule_RemoveMe()
	else
		local sgroup = SGroup_CreateUnique("outrocav_")
		UnitEntry_DeploySquads(player1, sgroup, { type = "scar_knight", numSquads = 2 }, mkr_outrocamcavspawn)
		Rule_AddOneShot(Kazan_SendOutroCav, 0.1, { sgroup = sgroup } )
	end
	outroCavCount = outroCavCount + 1
end

function Kazan_SendOutroCav(context, data)
	local markerList = {  
			mkr_outrocamcavpath1,
			mkr_outrocamcavpath2,
			mkr_outrocamcavpath3,
			mkr_outrocamcavpath4,
			mkr_outrocamcavpath5,
			mkr_outrocamcavpath6,
			mkr_outrocamcavpath7,
			mkr_outrocamcavpath8,
		}
	-- Add the others as waypoints
	for index, marker in pairs(markerList) do
		
		if scartype(marker) == ST_MARKER then
			if index < #markerList then
				Cmd_FormationMove(data.sgroup, marker, true)
			end
		end
	end
end

function Kazan_HasPlayerReachedCity()
	local marker1 = CheckMarkerForUnits(mkr_kazancity)
	
	if marker1 then 
		Kazan_SpawnKazanDefenders()
		Rule_RemoveMe()
	end 
end

