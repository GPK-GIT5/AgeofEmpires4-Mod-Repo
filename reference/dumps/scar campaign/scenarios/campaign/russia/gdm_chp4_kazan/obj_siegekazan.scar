function Kazan_FallbackToInnerDefense()
	local function _SGroupRetreatFraction(module, numToOne)
		local i = 0
		local sgroup = module.sgroup
		local _RandomRetreat = function(gid, idx, sid)
			if i >= numToOne or Squad_IsOfType(sid, "villager") then
				local retreatMarker = Table_GetRandomItem({ mkr_kazanretreat1, mkr_kazanretreat2, mkr_kazanretreat3, mkr_kazanretreat4 })
				i = 0
				SGroup_Single(sg_single, sid)
				Defend_RemoveSGroup(module, sg_single)
				Cmd_MoveToAndDestroy(sg_single, retreatMarker)
			else
				i = i + 1
			end
		end
		SGroup_ForEach(sgroup, _RandomRetreat)
	end
	
	local moduleTable = {
		"NorthGate",
		"SouthGate",
		"NorthWall",
		"SouthWall",
		"EastWall",
		"Central",		
		"KazanOuterWall1",
		"KazanOuterWall2",
		"KazanOuterWall3",
		"KazanOuterWall4",
		"KazanOuterWall5",
		"KazanOuterWall6",
		"KazanOuterWall7",
		"KazanOuterWall8",
		"KazanOuterWall9",
		"KazanOuterWall10",
		"KazanOuterWall11",
		"KazanOuterWall12"
	}
	
	for i,v in pairs(moduleTable) do
		local module = MissionOMatic_FindModule(v)
		module.reinforcements.enabled = false
		_SGroupRetreatFraction(module, 2)
	end
	
	TransferModuleIntoModule("NorthGate","KazanInnerDefense")
	TransferModuleIntoModule("SouthGate","KazanInnerDefense")
	TransferModuleIntoModule("NorthWall","KazanInnerDefense")
	TransferModuleIntoModule("SouthWall","KazanInnerDefense")
	TransferModuleIntoModule("EastWall","KazanInnerDefense")
	TransferModuleIntoModule("Central","KazanInnerDefense")

	TransferModuleIntoModule("KazanOuterWall1","KazanInnerWall1")
	TransferModuleIntoModule("KazanOuterWall2","KazanInnerWall1")
	TransferModuleIntoModule("KazanOuterWall3","KazanInnerWall2")
	TransferModuleIntoModule("KazanOuterWall4","KazanInnerWall2")
	TransferModuleIntoModule("KazanOuterWall5","KazanInnerWall3")
	TransferModuleIntoModule("KazanOuterWall6","KazanInnerWall3")
	TransferModuleIntoModule("KazanOuterWall7","KazanInnerWall4")
	TransferModuleIntoModule("KazanOuterWall8","KazanInnerWall4")
	TransferModuleIntoModule("KazanOuterWall9","KazanInnerWall5")
	TransferModuleIntoModule("KazanOuterWall10","KazanInnerWall5")
	TransferModuleIntoModule("KazanOuterWall11","KazanInnerWall6")
	TransferModuleIntoModule("KazanOuterWall12","KazanInnerWall6")
	
	Cmd_AttackMove(sg_mon_kazan_inner, mkr_innerkazan)
end

function Kazan_AutoSaveLoop()
	Util_AutoSave(true, true)
end


function Kazan_ProxForSpeech()
	
	
	if not b_VolgaIntelPlayed then
		
		local volga1 = CheckMarkerForUnits(mkr_northford)
		local volga2 = CheckMarkerForUnits(mkr_westford)
		local volga3 = CheckMarkerForUnits(mkr_kazansouthford)
		
		if volga1 or volga2 or volga3 then
			Util_StartIntel(EVENTS.Cross_Volga)
			b_VolgaIntelPlayed = true
		end	
	else
		if not b_PastureIntelPlayed then
			if CheckMarkerForUnits(mkr_fieldgate) then
				Util_StartIntel(EVENTS.Pastures)
				b_PastureIntelPlayed = true
			end
		end
		
		if not b_WallsSightedIntelPlayed then
			
			if Player_CanSeeEGroup(player1, eg_mon_outerwalls, ANY) then
				Util_StartIntel(EVENTS.See_Walls)
				b_WallsSightedIntelPlayed = true
				Rule_RemoveMe()
			end
			
		end
	end
	
end