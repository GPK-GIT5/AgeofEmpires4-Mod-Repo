-----------------------------------------------------------------------------------------------------------------------------------------------
--															WAVE SPAWNING FUNCTIONS
-----------------------------------------------------------------------------------------------------------------------------------------------

function MongolWaves_SetupWave(data)
	
	--Play the appropriate mongol drums for the incoming wave type
	if wave_stats[current_wave].unit_type == "infantry" then
		Music_PlayStinger("mus_camp_kulikovo_mongol_drum_infantry")
		--Music_SetIntensityAfterObjective(25, MUSIC_TENSE_COMBAT, 15)
		
	elseif wave_stats[current_wave].unit_type == "cavalry" then
		Music_PlayStinger("mus_camp_kulikovo_mongol_drum_cavalry")
		--Music_SetIntensityAfterObjective(23, MUSIC_TENSE_COMBAT, 15)
		
	elseif wave_stats[current_wave].unit_type == "hybrid" then
		Music_PlayStinger("mus_camp_kulikovo_mongol_drum_finalbattle")
		--Music_SetIntensityAfterObjective(27, MUSIC_COMBAT_RARE, 30)
	end
	
	--Create an initial threat group at the desired location, then replace it once the actual unit has been spawned
	MongolWaves_GenerateThreatArrow()
	
	-- Spawns the units after a short delay to match mongol drum timing. Focused attack timing is overridden externally.
	local _default_delay = 14
	local _left_delay = data.left_focus or _default_delay
	local _center_delay = data.center_focus or _default_delay
	local _right_delay = data.right_focus or _default_delay
	
	Rule_AddOneShot(MongolWaves_SpawnWave, _left_delay, {units = mongol_waves[current_wave], lane_name = "left"})
	Rule_AddOneShot(MongolWaves_SpawnWave, _center_delay, {units = mongol_waves[current_wave], lane_name = "center"})
	Rule_AddOneShot(MongolWaves_SpawnWave, _right_delay, {units = mongol_waves[current_wave], lane_name = "right"})
	
	Rule_AddInterval(MongolWaves_CountAlive, {delay = _default_delay, interval = 1}, {objective = wave_stats[current_wave].objective, wave = current_wave, expectedWave = _expectedWave})
	
end

function MongolWaves_SpawnWave(context, data)
	
	local leftmarker, centermarker, rightmarker
	
	--Generate the shortcut destination
	if holdStatus[LOCATION_LASTLINE] then
		leftmarker = mkr_shortcut_left_last
		centermarker = mkr_shortcut_center_last
		rightmarker = mkr_shortcut_right_last
	elseif holdStatus[LOCATION_MAINLINE] then
		leftmarker = mkr_shortcut_left_main
		centermarker = mkr_shortcut_center_main
		rightmarker = mkr_shortcut_right_main
	else
		leftmarker = mkr_shortcut_left_ford
		centermarker = mkr_shortcut_center_ford
		rightmarker = mkr_shortcut_right_ford
	end
	
	if data.lane_name == "left" then data.spawnLocation = Util_FindHiddenSpawn(mkr_mongol_left_spawn, leftmarker, true) end
	if data.lane_name == "center" then data.spawnLocation = Util_FindHiddenSpawn(mkr_mongol_center_spawn, centermarker, true) end
	if data.lane_name == "right" then data.spawnLocation = Util_FindHiddenSpawn(mkr_mongol_right_spawn, rightmarker, true) end
	
	--Spin up a new RovingArmy module
	MongolWaves_GenerateModule(data)
	
	--Dissolve the main mongol army into the newly spawned modules (only once per module)
	if current_wave == 10 then
		if data.lane_name == "left" then
			DissolveModuleIntoModule("MongolLeftArmy", "roving_left_10")
		elseif data.lane_name == "center" then
			DissolveModuleIntoModule("MongolCenterArmy", "roving_center_10")
		elseif data.lane_name == "right" then
			DissolveModuleIntoModule("MongolRightArmy", "roving_right_10")
		end
	end
	
	local _expectedWave = current_wave
	
end

function MongolWaves_GenerateModule(data)
	
	local targetTable = {}
	
	--Creates a reference to the opposite lane
	if data.lane_name == "left" then oppositeLane = "right" end
	
	--Generate the list of targets
	if not Objective_IsComplete(SOBJ_HoldFords) and not Objective_IsFailed(SOBJ_HoldFords) then
		MongolWaves_GenerateRowOfTargets(targetTable, data.lane_name, "mkr_ford") end -- Check if fords are done
	
	if not Objective_IsComplete(SOBJ_HoldMainline) and not Objective_IsFailed(SOBJ_HoldMainline) then
		MongolWaves_GenerateRowOfTargets(targetTable, data.lane_name, "mkr_mainline") end -- Check if hill is done
	
	if not Objective_IsFailed(SOBJ_HoldLast) then
		MongolWaves_GenerateRowOfTargets(targetTable, data.lane_name, "mkr_last_stand") end -- Check whether Don crossing has failed
	
	--Generate the SGroup
	local _sgroup = SGroup_CreateIfNotFound("sg_roving_"..data.lane_name.."_"..current_wave)
	
	--Generate the Roving Army
	local _units = Table_Copy(data.units)
	
	--Determine whether this is the focused wave, and increase the amount of attackers to compensate
	if wave_stats[current_wave].focus == data.lane_name then
		local modifier = wave_stats[current_wave].modifier
		print("Modifying "..data.lane_name.." with a modifier of "..modifier)
		for i in pairs(_units) do
			_units[i].numSquads = _units[i].numSquads * modifier
		end
	end
	
	local rovingArmy = {
		type = "RovingArmy",
		descriptor = "roving_"..data.lane_name.."_"..current_wave,
		player = player2,
		targets = targetTable,
		sgroup = _sgroup,
		units = _units,
		spawnLocation = data.spawnLocation,
		onDeathDissolve = true,
	}
	
	RovingArmy_Init(rovingArmy)
	
	--Updates threat arrow to attach to the focused mongol attack
	if data.lane_name == wave_stats[current_wave].focus then
		MongolWaves_GenerateThreatArrow(_sgroup)
	end

end

function MongolWaves_CountAlive(context, data)
	
	if current_wave == 10 then mongol_wave_threshold = mongol_final_wave_threshold end
	
	if "sg_roving_left_"..data.wave == nil or "sg_roving_center_"..data.wave == nil or "sg_roving_right_"..data.wave == nil then
		cardinal_alert("A new wave has started unexpectedly which has multiple waves active at once.")
		Rule_RemoveMe()
	else
		if (SGroup_CountSpawned("sg_roving_left_"..data.wave) + SGroup_CountSpawned("sg_roving_center_"..data.wave) + SGroup_CountSpawned("sg_roving_right_"..data.wave)) <= mongol_wave_threshold then
			if Objective_IsVisible(data.objective) then
				Objective_Complete(data.objective, false)
				Player_GetAll(player1, sg_temp)
				Sound_PlayWallaCelebrateOnSGroup(sg_temp)
				--insert counter music here for objectives
			end
			Rule_RemoveMe()
		end
	end
end

function MongolWaves_GenerateThreatArrow(sgroup)
	ThreatArrow_DestroyAllGroups()
	if sgroup ~= nil then
		--Generate the threat arrow on the provided squad
		ThreatArrow_CreateGroup("enemy squad", sgroup)
	else
		--Generate the threat arrow at a predetermined position temporarily until a more accurate threat can be tagged
		local direction = wave_stats[current_wave].focus
		
		local row
		if current_wave >= 1 and current_wave <= 3 then
			row = "ford"
		elseif current_wave >= 4 and current_wave <= 7 then
			row = "main"
		else
			row = "last"
		end
		
		local marker = Marker_FromName("mkr_shortcut_"..direction.."_"..row, "")
		ThreatArrow_CreateGroup("enemy movement", marker)
	end
end

function MongolWaves_GenerateMinimapBlip(opt_leftLane, opt_centerLane, opt_rightLane)
	b_leftLane = b_leftLane or false
	b_centerLane = b_centerLane or false
	b_rightLane = b_rightLane or false
	
	if holdStatus[LOCATION_FORDS] then
		if opt_leftLane then
			UI_CreateMinimapBlip(mkr_shortcut_left_ford, 40, "threat_group")
		elseif opt_centerLane then
			UI_CreateMinimapBlip(mkr_shortcut_center_ford, 40, "threat_group")
		elseif opt_rightLane then
			UI_CreateMinimapBlip(mkr_shortcut_right_ford, 40, "threat_group")
		end
	elseif holdStatus[LOCATION_MAINLINE] then
		if opt_leftLane then
			UI_CreateMinimapBlip(mkr_shortcut_left_main, 40, "threat_group")
		elseif opt_centerLane then
			UI_CreateMinimapBlip(mkr_shortcut_center_main, 40, "threat_group")
		elseif opt_rightLane then
			UI_CreateMinimapBlip(mkr_shortcut_right_main, 40, "threat_group")
		end
	else
		if opt_leftLane then
			UI_CreateMinimapBlip(mkr_shortcut_left_last, 40, "threat_group")
		elseif opt_centerLane then
			UI_CreateMinimapBlip(mkr_shortcut_center_last, 40, "threat_group")
		elseif opt_rightLane then
			UI_CreateMinimapBlip(mkr_shortcut_right_last, 40, "threat_group")
		end
	end
end

-----------------------------------------------------------------------------------------------------------------------------------------------
--															OBJECTIVE FUNCTIONS
-----------------------------------------------------------------------------------------------------------------------------------------------

function MongolWaves_MonitorDefenselineStatus()
	print("Checking for a held defense line")
	--Check if there is a held defense line, and start the next wave if there is
	if holdStatus[LOCATION_FORDS] or holdStatus[LOCATION_MAINLINE] or holdStatus[LOCATION_LASTLINE] then
		print("A defense line is held. Send those mongols!")
		MongolWaves_StartNextWave()
		Rule_RemoveMe()
	end
	
end

function MongolWaves_StartNextWave()
	print("Stopping the current wave objective and starting the next one.")
	if current_wave < 10 then
		Objective_Stop(wave_stats[current_wave].objective)
		Objective_Start(wave_stats[current_wave + 1].objective, true)
	end
end

function MongolWaves_GenerateRowOfTargets(targets, lane_name, defense_line)

	if lane_name == "center" then
		table.insert(targets, Marker_FromName(defense_line.."_center", ""))
		table.insert(targets, Marker_FromName(defense_line.."_left", "")) 
		table.insert(targets, Marker_FromName(defense_line.."_right", "")) 
	elseif lane_name == "left" then
		table.insert(targets, Marker_FromName(defense_line.."_left", ""))
		table.insert(targets, Marker_FromName(defense_line.."_center", "")) 
		table.insert(targets, Marker_FromName(defense_line.."_right", "")) 
	elseif lane_name == "right" then
		table.insert(targets, Marker_FromName(defense_line.."_right", ""))
		table.insert(targets, Marker_FromName(defense_line.."_center", "")) 
		table.insert(targets, Marker_FromName(defense_line.."_left", "")) 
	end
	
end

function MongolWaves_InitializeWaveStats()
	
	--Sets up references to wave_stats, called just after the objectives are registered
	wave_stats = {
		--Smolka River fords
		{ focus = "center", modifier = 3, 	unit_type = "infantry",	objective = SOBJ_Wave1 },
		{ focus = "right", 	modifier = 3, 	unit_type = "cavalry",	objective = SOBJ_Wave2 },
		{ focus = "left", 	modifier = 3, 	unit_type = "infantry",	objective = SOBJ_Wave3 },
		
		--Hill
		{ focus = "right", 	modifier = 2, 	unit_type = "cavalry",	objective = SOBJ_Wave4 },
		{ focus = "center", modifier = 2, 	unit_type = "cavalry",	objective = SOBJ_Wave5 },
		{ focus = "left", 	modifier = 2, 	unit_type = "infantry",	objective = SOBJ_Wave6 },
		{ focus = "right", 	modifier = 2, 	unit_type = "cavalry",	objective = SOBJ_Wave7 },
	
		--Don River crossing
		{ focus = "left", 	modifier = 2, 	unit_type = "infantry",	objective = SOBJ_Wave8 },
		{ focus = "right", 	modifier = 2, 	unit_type = "infantry",	objective = SOBJ_Wave9 },
		{ focus = "center", modifier = 2, 	unit_type = "hybrid",	objective = SOBJ_Wave10 },
	}
	
end

function MongolWaves_UpdateModuleTargets()
	
	local marker_left = mkr_ford_left
	local marker_center = mkr_ford_center
	local marker_right = mkr_ford_right
	
	--Loop through all potentially spawned waves and find whatever modules are possible within each iteration
	local _setModules = function()
		for i = 1, current_wave, 1 do
			local module_left = MissionOMatic_FindModule("roving_left_"..i)
			local module_center = MissionOMatic_FindModule("roving_center_"..i)
			local module_right = MissionOMatic_FindModule("roving_right_"..i)
			
			--Set the new targets for any valid modules
			if module_left ~= nil then
				RovingArmy_SetTarget(module_left, marker_left)
			end
			if module_center ~= nil then
				RovingArmy_SetTarget(module_center, marker_center)
			end
			if module_right ~= nil then
				RovingArmy_SetTarget(module_right, marker_right)
			end
			
		end
	end
	
	--Updates all existing modules to now attack the new defense line
	if holdStatus[LOCATION_FORDS] then
		_setModules()
	elseif holdStatus[LOCATION_MAINLINE] then
		marker_left = mkr_mainline_left
		marker_center = mkr_mainline_center
		marker_right = mkr_mainline_right
		_setModules()
	elseif holdStatus[LOCATION_LASTLINE] then
		marker_left = mkr_last_stand_left
		marker_center = mkr_last_stand_center
		marker_right = mkr_last_stand_right
		_setModules()
	end
end

function MongolWaves_TimedDelayCTA(context, data)
	EventCues_CallToAction(data.message, CTA_ALARM, nil, nil, data.marker, 20, "icons/cta/illustrations/12_mongols_charging")
	Sound_Play2D("mus_stinger_campaign_alert")
	Sound_Play2D("sfx_campaign_scripted_medium_group_engage")
end