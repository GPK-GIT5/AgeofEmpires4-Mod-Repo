function Outro_Ivan_Parade()
	
	Cmd_FormationMove(g_leaderIvan.sgroup, mkr_ivan_destination)
	Cmd_FormationMove(sg_ivan_guards, mkr_ivan_destination)
	Cmd_FormationMove(sg_ivan_scout, mkr_ivan_destination)
	
	Cmd_FormationMove(sg_background, mkr_parade_mid01, false)
	Cmd_FormationMove(sg_background, mkr_parade_mid02, true)
	Cmd_FormationMove(sg_background, mkr_parade_mid03, true)
	
	Modify_UnitSpeed(g_leaderIvan.sgroup, 0.4)
	Modify_UnitSpeed(sg_ivan_guards, 0.4)
	Modify_UnitSpeed(sg_ivan_scout, 0.3)
	Modify_UnitSpeed(sg_background, 0.45)
	
end
		
function Ugra_GetRandomRetreatPoint()
	
	local chosenOptions = World_GetRand(1,4)
	local markerOptions = {
		mkr_retreat_nw,
		mkr_retreat_s,
		mkr_retreat_se,
		mkr_retreat_sw
	}
	
	return markerOptions[chosenOptions]
end


function Ugra_SpawnExtraMongols()
	
	UnitEntry_DeploySquads(player2, sg_mon_outro_south, {{ type = "scar_horseman", numSquads = 8 }, { type = "scar_horsearcher", numSquads = 4 }}, mkr_mon_river4 )
	
	
end
