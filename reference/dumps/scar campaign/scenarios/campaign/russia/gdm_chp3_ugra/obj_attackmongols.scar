	--Cmd_InstantSetupTeamWeapon(sg_outro_cannon)

	Cmd_Attack(sg_outro_cannon, mkr_cannon_target, true)
	
	Cmd_Attack(sg_rus_outro, mkr_streltsy_target, true)
	
	--Rule_AddOneShot(Cannon_Fire_Stop, 4)
	
end

