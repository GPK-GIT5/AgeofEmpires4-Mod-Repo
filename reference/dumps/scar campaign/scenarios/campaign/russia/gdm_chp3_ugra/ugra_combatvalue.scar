
--Resource Values
value_food = 1
value_wood = 1.1
value_gold = 1.2
value_stone = 1.2 


unitTypeList = {
	spearman = 		{ scar = "scar_spearman", 		bp = EBP.RUS.UNIT_SPEARMAN_3_RUS, 		value = 0 },
	manatarms = 	{ scar = "scar_manatarms",		bp = EBP.RUS.UNIT_MANATARMS_3_RUS, 		value = 0 },
	archer = 		{ scar = "scar_archer",			bp = EBP.RUS.UNIT_ARCHER_3_RUS, 		value = 0 },
	crossbowman = 	{ scar = "scar_crossbowman",	bp = EBP.RUS.UNIT_CROSSBOWMAN_3_RUS, 	value = 0 },
	handcannon = 	{ scar = "scar_handcannon",		bp = EBP.RUS.UNIT_HANDCANNON_4_RUS, 	value = 0 },
	horseman = 		{ scar = "scar_horseman",		bp = EBP.RUS.UNIT_HORSEMAN_3_RUS, 		value = 0 },
	knight = 		{ scar = "scar_knight",			bp = EBP.RUS.UNIT_KNIGHT_3_RUS, 		value = 0 },
	horsearcher = 	{ scar = "scar_horsearcher",	bp = EBP.RUS.UNIT_HORSEARCHER_3_RUS, 	value = 0 },
	mangonel = 		{ scar = "scar_mangonel",		bp = EBP.RUS.UNIT_MANGONEL_3_RUS, 		value = 0 },
	springald = 	{ scar = "scar_springald",		bp = EBP.RUS.UNIT_SPRINGALD_3_RUS, 		value = 0 },
	scout = 		{ scar = "scar_scout",			bp = EBP.RUS.UNIT_SCOUT_1_RUS, 			value = 0 },
	monk =		 	{ scar = "scar_monk",			bp = EBP.RUS.UNIT_MONK_3_RUS,	 		value = 0 },
	trebuchet =		{ scar = "scar_trebuchet_traction",		bp = EBP.RUS.UNIT_TREBUCHET_4_TR_RUS,	 	value = 0 },
	cannon =		{ scar = "scar_cannon",			bp = EBP.RUS.UNIT_CANNON_4_RUS,	 		value = 0 },
}

function Ugra_InitializeUnitValues()
	for i,v in pairs(unitTypeList) do
		local cost = Player_GetEntityBPCost(player1, v.bp)
		local newValue = value_food*cost.food + value_wood*cost.wood + value_gold*cost.gold + value_stone*cost.stone
		unitTypeList[i].value = newValue
	end
end