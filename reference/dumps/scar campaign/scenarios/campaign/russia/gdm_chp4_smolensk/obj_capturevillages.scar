function CaptureVillages_InitLandmarks()
	OBJ_ProtectLandmarks = {
		Title = "$11191835",
		Type = ObjectiveType_Information,
		
		IsFailed = function()
			
			if Objective_IsComplete(SOBJ_CaptureRoslavl) or Objective_IsComplete(SOBJ_CaptureYelnya) or Objective_IsComplete(SOBJ_CaptureVyazma) then
				if EGroup_IsEmpty(eg_player_landmarks) then
					print("Player has no landmarks. Failing out.")
					return true
				end
			end

			return false
		end,
		
		OnFail = function()
			Mission_Fail()
		end,
	}
	
	Objective_Register(OBJ_ProtectLandmarks)
end

