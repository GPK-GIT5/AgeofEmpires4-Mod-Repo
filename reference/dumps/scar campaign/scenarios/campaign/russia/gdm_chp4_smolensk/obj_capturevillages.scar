--This function has been commented out in an attempt to speed up the beginning half of the mission (Spawns extra villagers
function CaptureVillages_ReinforceVillages()
	
	local units = {
		{type = "scar_manatarms", numSquads = 4},
		{type = "scar_archer", numSquads = 4},
		--{sbp = SBP.HRE.UNIT_CROSSBOWMAN_4_HRE, numSquads = 4},
	}
	
	--local unitCount = UnitTable_CountUnits(units)
	
	if not Objective_IsComplete(SOBJ_CaptureRoslavl) then
		SpawnUnitsToModule(units, "roslavl_defend", mkr_roslavl_s3)
		--Location_IncreaseDefenderCount(LOCATION("roslavl"), unitCount)
	end
	
	if not Objective_IsComplete(SOBJ_CaptureYelnya) then
		SpawnUnitsToModule(units, "yelnya_defend", mkr_yelnya_s3)
		--Location_IncreaseDefenderCount(LOCATION("yelnya"), unitCount)
	end
	
	if not Objective_IsComplete(SOBJ_CaptureVyazma) then
		SpawnUnitsToModule(units, "vyazma_defend", mkr_vyazma_s3)
		--Location_IncreaseDefenderCount(LOCATION("vyazma"), unitCount)
	end
	
end 

--Spawns villagers for the player
function CaptureVillages_OnComplete(village_marker, villager_destination, sgroup)
	
	--CaptureVillages_ReinforceVillages() --Temporarily disabling this to see if I can speed up the beginning parts
	villages_captured = villages_captured + 1
	local villagerLifeName = nil
	
	if village_marker == mkr_roslavl then
		hpid_roslavl = HintPoint_Add(eg_roslavl_tc, true, "$11172368", LOCATION_LABEL_HEIGHT)
		villagerLifeName = villagerlife_roslavl
	elseif village_marker == mkr_yelnya then
		hpid_yelnya = HintPoint_Add(eg_yelnya_tc, true, "$11172373", LOCATION_LABEL_HEIGHT)
		villagerLifeName = villagerlife_yelnya
	elseif village_marker == mkr_vyazma then
		hpid_vyazma = HintPoint_Add(eg_vyazma_tc, true, "$11172376", LOCATION_LABEL_HEIGHT)
		villagerLifeName = villagerlife_vyazma
	end
	
	--Spawning villagers
	local squadSpawnCount = 3
	if villages_captured == 1 then
		--Bump up villagers to 14 (9+5) and re-enable popcap
		squadSpawnCount = 9 
		UI_SetPlayerDataContext(player1, {PopulationCapOn = true})
		Modify_PlayerMaxPopCap(player1, 20, MUT_Addition)
		-- on console, restore the VPS at this point
		if UI_IsXboxControllerUI() then
			Game_SetVisibility (VF_XboxUIVillagerPriorities, true)
		end				
		
	elseif villages_captured == 2 then
		Modify_PlayerMaxPopCap(player1, 20, MUT_Addition)
		
	elseif villages_captured == 3 then
		Modify_PlayerMaxPopCap(player1, 20, MUT_Addition)
	end
	
	--Takes the villagers that were in the villager life and respawns them as player villagers.
	ConvertVillagers_OnCapture(villagerLifeName, squadSpawnCount)
	
	--Spawn remaining villagers after subtracting any converted villagers that survived the capture
	--SGroup_Clear(sg_player_villager_farmers)
	--SGroup_Clear(sg_player_villagers)
	--UnitEntry_DeploySquads(player1, sg_player_villager_farmers, {{type = "scar_villager", numSquads = 5, squadSpawnCount, spawn = village_marker}})
	--UnitEntry_DeploySquads(player1, sg_player_villagers, {{type = "scar_villager", numSquads = squadSpawnCount, spawn = village_marker}})
	
	--AssignVillagersToFarms(sg_player_villager_farmers)
	--AssignVillagersToWood(sg_player_villagers)
	
	--Adding bonus resources for capturing
	Smolensk_AddResources()
	
	--If this is the first village captured, spool up self-spawning raids from the other villages to attack on a RANDOM timer
	if not villagesAttacking then
		villagesAttacking = true
		
		local time_1 = World_GetRand(village_attack_timings.cavalry_min, village_attack_timings.cavalry_max)
		local time_2 = World_GetRand(village_attack_timings.ranged_min, village_attack_timings.ranged_max)
		local time_3 = World_GetRand(village_attack_timings.melee_min, village_attack_timings.melee_max)
		Rule_AddOneShot(CaptureVillages_Roslavl, time_1, {time = time_1})
		Rule_AddOneShot(CaptureVillages_Yelnya, time_2, {time = time_2})
		Rule_AddOneShot(CaptureVillages_Vyazma, time_3, {time = time_3})
	end
	
end

--Tells villagers of the captured village to flee to Smolensk (Doesn't really do anything anymore since the villagers are converted to the player. Probably worth removing.)
function CaptureVillages_ContinueObjectiveFlow(marker)
	
	Player_GetAllSquadsNearMarker(player2, sg_temp, marker)
	SGroup_Filter(sg_temp, SBP.HRE.UNIT_VILLAGER_1_HRE, FILTER_KEEP)
	Cmd_Move(sg_temp, mkr_smolensk)
	
end

--Plays village capture VO in the correct order, regardless of which village has been captured
function CaptureVillages_PlayIntel()
	
	if villages_captured == 1 then
		Util_StartIntel(EVENTS.First_Village)
		--Objective_Start(OBJ_ProtectLandmarks)
	elseif villages_captured == 2 then
		Util_StartIntel(EVENTS.Second_Village)
	end
	
end

--Checks player-owned landmarks 
function CaptureVillages_TrackLandmarks(context, data)
	local isLandmarkDamaged = false
	local _checkHP = function(gid, idx, eid)
		if Entity_GetHealthPercentage(eid) <= 0.6 then
			if not isLandmarkDamaged then
				isLandmarkDamaged = true
				return true
			end
		end
	end
	

	EGroup_ForEach(eg_player_landmarks, _checkHP)
	EGroup_ForEach(eg_landmarks, _checkHP)

	if isLandmarkDamaged then
		Objective_Start(OBJ_ProtectLandmarks)
		Rule_RemoveMe()
	end
end

function CaptureVillages_WatchForPlayerLandmarks(context, data)
	Player_GetAll(player1, sg_temp, eg_temp)
	EGroup_Filter(eg_temp, {EBP.RUS.BUILDING_LANDMARK_AGE3_KREMLIN_ARMOURY_RUS, EBP.RUS.BUILDING_LANDMARK_AGE3_SPASSAKAYA_TOWER_CONTROL_RUS}, FILTER_KEEP)
	EGroup_FilterUnderConstruction(eg_temp, FILTER_REMOVE)
	if EGroup_Count(eg_temp) > 0 then
		EGroup_AddEGroup(eg_player_landmarks, eg_temp)
		EGroup_AddEGroup(eg_player_built_landmark, eg_temp)
		Rule_RemoveMe()
	end
end

------------------------------------------------------------------------------------------------------------------------------------------
--															ATTACKS FROM VILLAGES
------------------------------------------------------------------------------------------------------------------------------------------

--? @shortdesc Spawns attacks from Roslavl (Cavalry village)
function CaptureVillages_Roslavl(context, data)
	
	--print("Attempting a spawn from Roslavl after being delayed for: "..data.time)
	
	--ATTACKS FROM ROSLAVL
	if not Objective_IsComplete(SOBJ_CaptureRoslavl) then
		Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_attack_src_roslavl, 60)
		if SGroup_CountSpawned(sg_temp) == 0 then
			local targets = {}
			local _units = {
				{
					{ type = "scar_horseman", numSquads = Util_DifVar({8, 8, 8, 8}) },
				},
				{
					{ type = "scar_knight", numSquads = Util_DifVar({6, 6, 6, 8}) },
				},
			}
			
			local units = _units[World_GetRand(1, 2)]
			
			--Check whether the other villages have been captured, and use it to send an attack there and any others that have been captured
			local first_obj = Objective_IsComplete(SOBJ_CaptureYelnya)
			local second_obj = Objective_IsComplete(SOBJ_CaptureVyazma)
			
			targets = {}
			if first_obj then 
				table.insert(targets, mkr_village_attack_routing)
				table.insert(targets, mkr_yelnya)
				if second_obj then
					table.insert(targets, mkr_village_attack_routing)
					table.insert(targets, mkr_vyazma) 
				end
				table.insert(targets, mkr_roslavl)
				Smolensk_SendAttack(units, mkr_attack_src_roslavl, targets, mkr_roslavl, "gather_left")
			end
			
			targets = {}
			if second_obj then 
				table.insert(targets, mkr_village_attack_routing)
				table.insert(targets, mkr_vyazma) 
				if first_obj then 
					table.insert(targets, mkr_village_attack_routing)
					table.insert(targets, mkr_yelnya) 
				end
				table.insert(targets, mkr_roslavl)
				Smolensk_SendAttack(units, mkr_attack_src_roslavl, targets, mkr_roslavl, "gather_left")
			end
			
			print("Sending attacks from Roslavl")
			
		else
			print("Spawning is blocked by players being too close to Roslavl")
		end
		
		--Since the objective is still active, queue up an attempt to spawn another wave later
		local time_delay = World_GetRand(village_attack_timings.cavalry_min, village_attack_timings.cavalry_max)
		Rule_AddOneShot(CaptureVillages_Roslavl, time_delay, {time = time_delay})
	else
		Rule_RemoveMe()
	end
	
end

