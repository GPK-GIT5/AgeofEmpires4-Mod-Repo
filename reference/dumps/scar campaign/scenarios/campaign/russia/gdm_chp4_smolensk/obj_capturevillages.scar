			if second_obj then 
				table.insert(targets, mkr_village_attack_routing)
				table.insert(targets, mkr_yelnya) 
				if first_obj then 
					table.insert(targets, mkr_village_attack_routing)
					table.insert(targets, mkr_roslavl) 
				end
				table.insert(targets, mkr_vyazma)
				Smolensk_SendAttack(units, mkr_attack_src_vyazma, targets, mkr_vyazma, "gather_right")
			end
			
			print("Sending attacks from Vyazma")
			
		else
			print("Spawning is blocked by players being too close to Vyazma")
		end
		
		--Since the objective is still active, queue up an attempt to spawn another wave later
		local time_delay = World_GetRand(village_attack_timings.melee_min, village_attack_timings.melee_max)
		Rule_AddOneShot(CaptureVillages_Vyazma, time_delay, {time = time_delay})
	else
		Rule_RemoveMe()
	end
	
end

--Breach audio stinger and wallas for locations. 
--The Smolensk wall breach is in obj_besiegesmolensk.scar
function CaptureVillages_Breach(context)
	
	if context.victim ~= nil then
		
		if not b_roslavl_breached and roslavl_wall_count > EGroup_CountSpawned(eg_roslavl_wall) then
			b_roslavl_breached = true
			Rule_AddOneShot(Smolensk_DelayedAudioStinger, 1, {position = Util_GetPosition(context.victim)})
		elseif not b_yelnya_breached and yelnya_wall_count > EGroup_CountSpawned(eg_yelnya_wall) then
			b_yelnya_breached = true
			Rule_AddOneShot(Smolensk_DelayedAudioStinger, 1, {position = Util_GetPosition(context.victim)})
		elseif not b_vyazma_breached and vyazma_wall_count > EGroup_CountSpawned(eg_vyazma_wall) then
			b_vyazma_breached = true
			Rule_AddOneShot(Smolensk_DelayedAudioStinger, 1, {position = Util_GetPosition(context.victim)})
		end
		
		if (b_roslavl_breached) and (b_vyazma_breached) and (b_yelnya_breached) then
			Rule_RemoveEGroupEvent(CaptureVillages_Breach, eg_village_walls)
		end
		
	end
	
end

function CaptureVillages_OutpostBreach(context)
	
	if context.victim ~= nil then
	
		if not b_west_outpost_breached and west_outpost_wall_count > EGroup_CountSpawned(eg_west_outpost_wall) then
			b_west_outpost_breached = true
			Rule_AddOneShot(Smolensk_DelayedAudioStinger, 1, {position = Util_GetPosition(context.victim)})
		elseif not b_east_outpost_breached and east_outpost_wall_count > EGroup_CountSpawned(eg_east_outpost_wall) then
			b_east_outpost_breached = true
			Rule_AddOneShot(Smolensk_DelayedAudioStinger, 1, {position = Util_GetPosition(context.victim)})
		end
		
		if b_west_outpost_breached and b_east_outpost_breached then
			Rule_RemoveEGroupEvent(CaptureVillages_OutpostBreach, eg_outpost_walls)
		end
		
	end
	
end

function ConvertVillagers_OnCapture(villagerLife, maxBonusVillagers)
	
	villager_RespawnLocation = villagerLife.mkr_flee
	local transfer_WanderToTrees = 0
	local newWanderCount = 0
	
	SGroup_Clear(sg_temp)
	
	if maxBonusVillagers > 2 then
		transfer_WanderToTrees = maxBonusVillagers-2
		newWanderCount = 2
	else
		newWanderCount = 2
	end
	
	UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = newWanderCount},villager_RespawnLocation)
	Cmd_Move(sg_temp, villagerLife.location_mkr)
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerLife.food_count}, villager_RespawnLocation)
	AssignVillagersToFarms(sg_temp)
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerLife.wood_count+transfer_WanderToTrees}, villager_RespawnLocation)
	AssignVillagersToWood(sg_temp)
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerLife.stone_count}, villager_RespawnLocation)
	AssignVillagersToStone(sg_temp)
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerLife.gold_count}, villager_RespawnLocation)
	AssignVillagersToGold(sg_temp)
	
end