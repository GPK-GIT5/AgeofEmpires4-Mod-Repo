--
-- Moscow vs Lithuania 1514 - Capture Villages
--

function CaptureVillages_Init()
	OBJ_CaptureVillages = {
		Title = "$11172361", --Capture the villages surrounding Smolensk
		Type = ObjectiveType_Capture,
		
		Intel_Start = EVENTS.Outlying_Villages,
		
		PreStart = function()
			roslavl_wall_count = EGroup_CountSpawned(eg_roslavl_wall)
			yelnya_wall_count = EGroup_CountSpawned(eg_yelnya_wall)
			vyazma_wall_count = EGroup_CountSpawned(eg_vyazma_wall)
			west_outpost_wall_count = EGroup_CountSpawned(eg_west_outpost_wall)
			east_outpost_wall_count = EGroup_CountSpawned(eg_east_outpost_wall)
			Rule_AddEGroupEvent(CaptureVillages_Breach, eg_village_walls, GE_EntityKilled)
			Rule_AddEGroupEvent(CaptureVillages_OutpostBreach, eg_outpost_walls, GE_EntityKilled)
		end,
		
		OnStart = function()
			FOW_PlayerRevealArea(player2, Marker_GetPosition(mkr_roslavl), Marker_GetProximityRadiusOrDefault(mkr_roslavl, 0), -1)
			FOW_PlayerRevealArea(player2, Marker_GetPosition(mkr_yelnya), Marker_GetProximityRadiusOrDefault(mkr_yelnya, 0), -1)
			FOW_PlayerRevealArea(player2, Marker_GetPosition(mkr_vyazma), Marker_GetProximityRadiusOrDefault(mkr_vyazma, 0), -1)
			
			-- Setting minimum combat intensity now that the first objective has been started
			Sound_SetMinimumMusicCombatIntensity(801,0)
			
			Rule_AddInterval(BesiegeSmolensk_CheckNearbyKrasny, 1) --Krasny nearby proximity trigger
		end,
		
		IsFailed = function()
			
			if not Objective_AreSubObjectivesComplete(OBJ_CaptureVillages, ANY) then
				Player_GetAll(player1, sg_temp)
				SGroup_Filter(sg_temp, "gaia", FILTER_REMOVE)
				return SGroup_IsEmpty(sg_temp)
			end
			
			--Player hasn't captured a village yet, check if the player has no resources or units
			return Smolensk_IsPlayerEconomyTrapped()
		end,
		OnFail = function()
			Mission_Fail()
		end,
		
		IsComplete = function()
			return Objective_AreSubObjectivesComplete(OBJ_CaptureVillages, ALL)
		end,
		PreComplete = function()
			--Music_StopAfterObjective()
			Music_StopMedium()
		end,
		OnComplete = function()
			Util_StartIntel(EVENTS.Third_Village)
			if last_village_vo == "Roslavl" then 
				Util_StartIntel(EVENTS.Roslavl)
			elseif last_village_vo == "Yelnya" then
				Util_StartIntel(EVENTS.Yelnya)
			elseif last_village_vo == "Vyazma" then
				Util_StartIntel(EVENTS.Vyazma)
			end
			
			Objective_Start(OBJ_BesiegeSmolensk)
			--Sound_SetMinimumMusicCombatIntensity(0, 0)
		end,
	}
	
	Objective_Register(OBJ_CaptureVillages)
end

function CaptureVillages_InitRoslavl()

	local location = LOCATION("roslavl")
	
	SOBJ_CaptureRoslavl = {
		Title = "$11172362", --Capture Roslavl - (Cavalry)
		Type = ObjectiveType_Capture,
		Parent = OBJ_CaptureVillages,
		StartAlongsideParent = true,
		
		SetupUI = function()
			Location_SetCapturable(LOCATION("roslavl"), true)
			AudioTrigger_InitAreaTrigger({
				marker = mkr_roslavl,
				audioCue = MUSIC_COMBAT,
				triggeringPlayer = player1,
				startAboveUnitCount = 5,
				duration = 30
			})
		end,
		
		PreComplete = function()
			Sound_Play2D("sfx_campaign_scripted_medium_group_celebrate")
			Player_SetEntityProductionAvailability(player1, EBP.RUS.BUILDING_UNIT_CAVALRY_CONTROL_RUS, ITEM_UNLOCKED)
			CaptureVillages_OnComplete(mkr_roslavl, mkr_roslavl_s2, sg_roslavl_villagers)
			
			EGroup_AddEGroup(eg_player_landmarks, eg_landmark_left)
			Entity_SetInvulnerableMinCap(EGroup_GetEntityAt(eg_landmark_left, 1), 0, 0)
		end,
		
		OnComplete = function()
			CaptureVillages_ContinueObjectiveFlow(mkr_roslavl)
			
			if villages_captured == 3 then
				last_village_vo = "Roslavl"
			else			
				CaptureVillages_PlayIntel()
				Util_StartIntel(EVENTS.Roslavl)
			end
			
			Util_AutoSave()
		end,
	}
	
	SOBJ_DefeatRoslavlResistance = {
		Title = "$11172366", --Defeat Roslavl resistance
		Type = ObjectiveType_Battle,
		Parent = OBJ_CaptureVillages,
		
		PreStart = function()
			Music_LockIntensity(MUSIC_COMBAT, 15)
		end,
	}
	
	SOBJ_LocationRoslavl = {
		Title = "$11172368", --Roslavl
		Type = ObjectiveType_Capture,
		Parent = OBJ_CaptureVillages,
	}
	
	Objective_Register(SOBJ_CaptureRoslavl)
	Objective_Register(SOBJ_DefeatRoslavlResistance)
	Objective_Register(SOBJ_LocationRoslavl)
	
	location.objectiveMaster = OBJ_CaptureVillages
	location.objectivePrimary = SOBJ_CaptureRoslavl
	location.objectiveSecondary = SOBJ_DefeatRoslavlResistance
	location.objectiveCapture = SOBJ_LocationRoslavl
	
end

