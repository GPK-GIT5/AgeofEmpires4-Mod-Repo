--Uses the time scale function in the smolensk.scar script to scale the table by up to 3x the original amount
function BesiegeSmolensk_TimeScaleUnitTable(table)
	for index, unit_values in pairs(table) do
		unit_values.numSquads = Smolensk_GetTimeScaledAmount(unit_values.numSquads, unit_values.numSquads * 3)
	end
end