--? @shortdesc RovingArmy template used to spawn attacks to specified targets
function Smolensk_SendAttack(units, sourceMarker, targetMarkers, spawn_area, staging)
	attack_wave = attack_wave or 1
	
	--Creating the RovingArmy Module
	local assault_module_descriptor = "roving_attack_"..attack_wave
	local rovingArmy = {
		type = "RovingArmy",
		descriptor = assault_module_descriptor,
		player = player2,
		units = {},
		spawnLocation = sourceMarker,
		targets = targetMarkers,
		targetingType = ARMY_TARGETING_CYCLE,
		onDeathDissolve = true,
		attackMove = attackMoveStyle_aggressive,
	}
	RovingArmy_Init(rovingArmy)
	
	--Creating the wave setup
	local wave_data = {
		descriptor = "wave_"..attack_wave,
		player = player2,
		use_separate_spawns = true,
		spawn = spawn_area,
		units = units,
		staging_module = staging,
		assault_module = assault_module_descriptor,
		auto_launch = true,
	}
	
	local wave_attack = Wave_New(wave_data)
	Wave_Prepare(wave_attack)
	
	attack_wave = attack_wave + 1
end

