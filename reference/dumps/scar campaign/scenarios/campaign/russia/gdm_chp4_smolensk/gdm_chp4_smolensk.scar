--
-- Moscow vs Lithuania 1514
--
-- The Rise of Moscow, Mission 7
--

import("MissionOMatic/MissionOMatic.scar")		-- this imports the Cardinal scripts as well
import("obj_capturevillages.scar") -- Capture Village Objectives
import("obj_besiegesmolensk.scar") -- Besiege Smolensk Objectives
--import("obj_capturesmolensk.scar") -- Capture Smolensk Objectives
import("obj_surrenderui.scar") -- Smolensk surrender UI

-- Training
--import("training/coretraininggoals.scar")
--import("training/campaigntraininggoals.scar")

function Mission_SetupPlayers()
	
	--
	-- get player IDs for each player
	--
	
	player1 = World_GetPlayerAt(1) -- Moscow
	player2 = World_GetPlayerAt(2) -- Lithuanians
	player3 = World_GetPlayerAt(3) -- Neutrals
	
	-- player 1 - Moscow
	Setup_SetPlayerName(player1, "$11172357") --Grand Duchy of Moscow
	Player_SetCurrentAge(player1, AGE_CASTLE)
	Player_SetMaximumAge(player1, AGE_IMPERIAL)
	
	-- player 2 - Lithuanians
	Setup_SetPlayerName(player2, "$11172359") --Lithuanians
	Player_SetCurrentAge(player2, AGE_IMPERIAL)
	--Player_SetMaximumAge(player2, AGE_IMPERIAL)
	
	-- player 3 - Neutrals
	Setup_SetPlayerName(player3, "$11172360") --Neutral
	Player_SetCurrentAge(player3, AGE_CASTLE)
	Player_SetMaximumAge(player3, AGE_CASTLE)
	
	--
	-- set player relationships
	--
	
	Player_SetRelationship(player1, player3, R_ALLY)		-- make sure you set relationships both ways
	Player_SetRelationship(player3, player1, R_ALLY)
	
	Player_SetRelationship(player2, player3, R_NEUTRAL)
	Player_SetRelationship(player3, player2, R_NEUTRAL)
	
	World_EnableSharedLineOfSight(player1, player3, false)
	
	--
	-- Set Player Colours
	--
	
	PlayerColour_Enable()
	Game_SetPlayerColour(player1, COLOR_BLUE)
	Game_SetPlayerColour(player2, COLOR_RED)
	Game_SetPlayerColour(player3, COLOR_GREY)
	
end -- Mission_SetupPlayers()

function Mission_SetupVariables()
	
	-- EGROUPS
	eg_player_structures = EGroup_CreateIfNotFound("sg_player_structures")
	eg_player_landmarks = EGroup_CreateIfNotFound("eg_player_landmarks")
	eg_player_built_landmark = EGroup_CreateIfNotFound("eg_player_built_landmark")
	
	eg_outposts = EGroup_CreateIfNotFound("eg_outposts")
	eg_roslavl = EGroup_CreateIfNotFound("eg_roslavl")
	eg_yelnya = EGroup_CreateIfNotFound("eg_yelnya")
	eg_vyazma = EGroup_CreateIfNotFound("eg_vyazma")
	eg_krasny = EGroup_CreateIfNotFound("eg_krasny")
	eg_smolensk = EGroup_CreateIfNotFound("eg_smolensk")
	eg_west_outpost = EGroup_CreateIfNotFound("eg_west_outpost")
	eg_east_outpost = EGroup_CreateIfNotFound("eg_east_outpost")
	
	-- SGROUPS
	
	-- PLAYER
	sg_player_army = SGroup_CreateIfNotFound("sg_player_army")
	sg_player_villagers = SGroup_CreateIfNotFound("sg_player_villagers")
	sg_player_villager_farmers = SGroup_CreateIfNotFound("sg_player_villager_farmers")
	sg_player_outro = SGroup_CreateIfNotFound("sg_player_outro")
	
	-- VILLAGES
	sg_roslavl_defend = SGroup_CreateIfNotFound("sg_roslavl_defend")
	sg_roslavl_attack = SGroup_CreateIfNotFound("sg_roslavl_attack")
	sg_roslavl_villagers = SGroup_CreateIfNotFound("sg_roslavl_villagers")
	
	sg_yelnya_defend = SGroup_CreateIfNotFound("sg_yelnya_defend")
	sg_yelnya_attack = SGroup_CreateIfNotFound("sg_yelnya_attack")
	sg_yelnya_villagers = SGroup_CreateIfNotFound("sg_yelnya_villagers")
	
	sg_vyazma_defend = SGroup_CreateIfNotFound("sg_vyazma_defend")
	sg_vyazma_attack = SGroup_CreateIfNotFound("sg_vyazma_attack")
