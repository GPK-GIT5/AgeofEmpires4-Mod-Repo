function Mission_SetRestrictions()
	
	--POP CAP
	Modify_PlayerMaxPopCap(player1, -80, MUT_Addition)
	
	PlayerUpgrades_Auto(player1, true)
	PlayerUpgrades_Auto(player2)
	PlayerUpgrades_Auto(player3)
	
	--Player 1 Landmarks & Structures
	Player_SetEntityProductionAvailability(player1, EBP.RUS.BUILDING_TOWN_CENTER_RUS, ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.RUS.BUILDING_TOWN_CENTER_CAPITAL_RUS, ITEM_REMOVED)
	Player_SetStateModelBool(player1, "player_can_construct_structures", true)
	
	Player_SetEntityProductionAvailability(player1, EBP.RUS.BUILDING_UNIT_INFANTRY_CONTROL_RUS, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.RUS.BUILDING_UNIT_RANGED_CONTROL_RUS, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.RUS.BUILDING_UNIT_CAVALRY_CONTROL_RUS, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.RUS.BUILDING_TECH_UNIVERSITY_CONTROL_RUS, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.RUS.BUILDING_UNIT_NAVAL_RUS, ITEM_REMOVED)
	
	--Player 2 Landmarks
	Player_SetEntityProductionAvailability(player2, EBP.HRE.BUILDING_LANDMARK_AGE1_IMPERIAL_PALACE_OF_PADERBORN_HRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player2, EBP.HRE.BUILDING_LANDMARK_AGE1_PALANTINE_CHAPEL_HRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player2, EBP.HRE.BUILDING_LANDMARK_AGE2_BAMBERG_CATHEDRAL_HRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player2, EBP.HRE.BUILDING_LANDMARK_AGE2_NUREMBERG_CASTLE_HRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player2, EBP.HRE.BUILDING_LANDMARK_AGE3_ELTZ_CASTLE_HRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player2, EBP.HRE.BUILDING_LANDMARK_AGE3_HOHENZOLLERN_CASTLE_HRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player2, EBP.HRE.BUILDING_TOWN_CENTER_CAPITAL_HRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player2, EBP.HRE.BUILDING_DEFENSE_OUTPOST_HRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player2, EBP.HRE.BUILDING_DEFENSE_KEEP_HRE, ITEM_REMOVED)
	
	Player_CompleteUpgrade(player2, UPG.COMMON.UPGRADE_SIEGE_ENGINEERS)
	Action_SetResources_Do({ player = player2, resources = { food = 1000, wood = 30000, stone = 1000, gold = 1000 } }) --extra wood for rams
	
	--Upgrade all outposts to arrowslits
	Cmd_Upgrade(eg_outposts, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS, 1, true)
	
	--Upgrade all armed outposts to the dangerous weapons and make them out of stone
	Cmd_Upgrade(eg_outposts_armed, UPG.COMMON.UPGRADE_OUTPOST_STONE, 1, true)
	Cmd_Upgrade(eg_outposts_armed, UPG.COMMON.UPGRADE_OUTPOST_SPRINGALD, 1, true) 
	
	--Upgrade all towers to dangerous weapons
	eg_smolensk_towers = EGroup_CreateIfNotFound("eg_smolensk_towers")
	Player_GetAll(player2, eg_smolensk_towers)
	EGroup_Filter(eg_smolensk_towers, EBP.HRE.BUILDING_DEFENSE_TOWER_HRE, FILTER_KEEP)
	
	if difficulty >= GD_HARD then
		Cmd_Upgrade(eg_smolensk_towers, UPG.COMMON.UPGRADE_TOWER_CANNON, 1, true)
	else
		Cmd_Upgrade(eg_smolensk_towers, UPG.COMMON.UPGRADE_TOWER_SPRINGALD, 1, true)
	end
	
	--Set player's popcap initially before villages are captured
	UI_SetPlayerDataContext(player1, {PopulationCapOn = false})
	
end -- Mission_SetRestrictions()

function Mission_Preset() -- any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)
	
	PlayerColour_Enable()
	
	-- OBJECTIVES
	CaptureVillages_InitLandmarks()
	CaptureVillages_Init()
	CaptureVillages_InitRoslavl()
	CaptureVillages_InitYelnya()
	CaptureVillages_InitVyazma()
	BesiegeSmolensk_InitObjectives()
	BesiegeSmolensk_InitKrasny()
	
	--Smolensk waves
	BesiegeSmolensk_SetUpWaves()

	Music_PersistentStop()
	--Music_LockIntensity(MUSIC_TENSE, 30)
	--Sound_SetMinimumMusicCombatIntensity(801, 0)
	
	-- Add extra villagers on Story
	if Game_GetSPDifficulty() <= GD_EASY then
		
		local villagerlife = VillagerLife_Find("villagerlife_roslavl")
		SGroup_Clear(sg_temp)
		UnitEntry_DeploySquads(player1, sg_temp, {sbp = SBP.RUS.UNIT_VILLAGER_1_RUS, numSquads = 2}, villagerlife.mkr_home)
		VillagerLife_AddSGroup(villagerlife, sg_temp)
		
		villagerlife = VillagerLife_Find("villagerlife_yelnya")
		SGroup_Clear(sg_temp)
		UnitEntry_DeploySquads(player1, sg_temp, {sbp = SBP.RUS.UNIT_VILLAGER_1_RUS, numSquads = 1}, villagerlife.mkr_home)
		VillagerLife_AddSGroup(villagerlife, sg_temp)
		
		villagerlife = VillagerLife_Find("villagerlife_vyazma")
		SGroup_Clear(sg_temp)
		UnitEntry_DeploySquads(player1, sg_temp, {sbp = SBP.RUS.UNIT_VILLAGER_1_RUS, numSquads = 1}, villagerlife.mkr_home)
		VillagerLife_AddSGroup(villagerlife, sg_temp)
		
	end
	
end -- Mission_Preset()

function Mission_Start() -- this is triggered after the intro, just as control is passed to the player
	
	-- on console don't restore econ-related HUD elements at first
	Cardinal_EnablePartialXboxUI(true, {VF_XboxUIVillagerPriorities})

	-- start the opening objectives (if you're using ObjectiveTable style objectives)	
	--Util_StartIntel(EVENTS.Outlying_Villages)
	Music_UnlockIntensity()
	Objective_Start(OBJ_CaptureVillages)
	--Util_StartIntel(EVENTS.Outlying_Villages)
	
	--Rule_AddInterval(Smolensk_KrasnyProximityChecker, 1)
	Rule_AddInterval(Smolensk_CheckNearWestOutpost, 1)
	Rule_AddInterval(Smolensk_CheckNearEastOutpost, 1)
	
	--Module References
	west_outpost_defend = MissionOMatic_FindModule("west_outpost_defend")
	west_outpost_inner_defend = MissionOMatic_FindModule("west_outpost_inner_defend")
	--west_outpost_cannons_defend = MissionOMatic_FindModule("west_outpost_cannons_defend")
	west_outpost_gate_defend = MissionOMatic_FindModule("west_outpost_gate_defend")
	
	east_outpost_defend = MissionOMatic_FindModule("east_outpost_defend")
	
	--Landmark initial invincibility
	Entity_SetInvulnerableMinCap(EGroup_GetEntityAt(eg_landmark_left, 1), 0.05, 0.0)
	Entity_SetInvulnerableMinCap(EGroup_GetEntityAt(eg_landmark_center, 1), 0.05, 0.0)
	Entity_SetInvulnerableMinCap(EGroup_GetEntityAt(eg_landmark_right, 1), 0.05, 0.0)
	
	sg_all_west_outpost_defenders = SGroup_CreateIfNotFound("sg_all_west_outpost_defenders")
	SGroup_AddGroups(sg_all_west_outpost_defenders, {sg_west_outpost_defend, sg_west_outpost_inner_defend, sg_west_outpost_cannons, sg_west_outpost_gate_defend})
	
	EGroup_AddEGroup(eg_roslavl, eg_roslavl_forge)
	
	Rule_AddInterval(Smolensk_OutpostCaptureCheck, 1, {sgroup = sg_all_west_outpost_defenders, egroup = eg_west_outpost})
	Rule_AddInterval(Smolensk_OutpostCaptureCheck, 1, {sgroup = sg_east_outpost_defend, egroup = eg_east_outpost})
	
	SpawnGarrisonsIntoEGroup(eg_outposts_armed, player2)
	
	Rule_AddInterval(CaptureVillages_TrackLandmarks, 1)
	Rule_AddInterval(CaptureVillages_WatchForPlayerLandmarks, 1)
	Rule_AddInterval(Smolensk_ProximityCallFunction, 1, {marker = mkr_krasny, range = 120, function_name = Smolensk_SpawnKrasnyVillagerLife})
	
	Game_TransitionToState("taiga_sunset", 600)
	
end -- Mission_Start()

