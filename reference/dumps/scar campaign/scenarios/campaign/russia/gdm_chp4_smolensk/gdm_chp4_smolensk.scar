function Smolensk_IsPlayerEconomyTrapped()
	Player_GetAll(player1, sg_temp, eg_temp)
	SGroup_Filter(sg_temp, "gaia", FILTER_REMOVE)
	return SGroup_IsEmpty(sg_temp) and Player_GetResource(player1, RT_Food) < 50 and not EGroup_IsProducingSquads(eg_temp, ANY)
end

function Smolensk_KillVillages()
	SGroup_Kill(sg_vyazma_defend)
	SGroup_Kill(sg_roslavl_defend)
	SGroup_Kill(sg_yelnya_defend)
end

function Smolensk_AddResources()
	Player_AddResource(player1, RT_Food, 500)
	Player_AddResource(player1, RT_Wood, 800)
	Player_AddResource(player1, RT_Gold, 500)
	Player_AddResource(player1, RT_Stone, 500)
end

function Smolensk_KrasnyProximityChecker()
	Player_GetAllSquadsNearMarker(player1, sg_temp, Marker_GetPosition(mkr_krasny), 100)
	SGroup_Filter(sg_temp, "gaia", FILTER_REMOVE)
	
	if SGroup_CountSpawned(sg_temp) > 0 then
		Objective_Start(OBJ_CaptureKrasny)
		Rule_RemoveMe()
	end
	SGroup_Clear(sg_temp)
end

--? @shortdesc Checks to see if player1 has a unit close enough, and spawns units into the desired module
--? @args units, module, marker, radiusOffset
function Smolensk_ProximitySpawner(context, data)
	
	local spawn = data.spawn or data.marker
	local radiusOffset = data.radiusOffset or 0
	
	Player_GetAllSquadsNearMarker(player1, sg_temp, Marker_GetPosition(data.marker), Marker_GetProximityRadiusOrDefault(data.marker, 0) + radiusOffset)
	
	if SGroup_CountSpawned(sg_temp) > 0 then
		SpawnUnitsToModule(data.units, data.location.."_defend", spawn)
		
		--if data.count ~= nil then
			--Location_IncreaseDefenderCount(LOCATION(data.location), data.count)
		--end
		
		Rule_RemoveMe()
	end
	
end

function Smolensk_OverrideBuildTimes()
	Wave_OverrideUnitBuildTime("scar_manatarms", 1)
	Wave_OverrideUnitBuildTime("scar_crossbowman", 1)
	Wave_OverrideUnitBuildTime("scar_spearman", 1)
	Wave_OverrideUnitBuildTime("scar_archer", 1)
	Wave_OverrideUnitBuildTime("scar_landsknecht", 1)
	Wave_OverrideUnitBuildTime("scar_horseman", 1)
	Wave_OverrideUnitBuildTime("scar_knight", 1)
	Wave_OverrideUnitBuildTime("scar_handcannon", 1)
	Wave_OverrideUnitBuildTime("scar_scout", 1)
	Wave_OverrideUnitBuildTime("scar_villager", 1)
end

--? @shortdesc Checks if the outpost has been conquered, and then converts ownership to the player
function Smolensk_OutpostCaptureCheck(context, data)
	
	if SGroup_CountSpawned(data.sgroup) == 0 then
		
		EGroup_Duplicate(data.egroup, eg_temp)
		EGroup_Filter(eg_temp, "wall", FILTER_REMOVE)
		
		if EGroup_CountSpawned(eg_temp) == 0 then
			
			print("Outpost has been captured. Converting walls and stopping this rule check.")
			EGroup_SetPlayerOwner(data.egroup, player1)
			
			local typesToConvert = {
				"palisade_wall_section",
				"palisade_wall_bastion",
				"palisade_gate",
			}
			local eg_wallEntities = EGroup_CreateUniqueWithPrefix("")
			local _SwapBlueprint = function(gid, idx, eid)
				if not World_OwnsEntity(eid) then
					for index, buildingType in pairs(typesToConvert) do 
						if Entity_IsOfType(eid, buildingType) then
							--Add any wall entities to our walls egroup
							if Entity_RequiresSlottedSplineUpdateAfterBlueprintConversion(eid) then
								EGroup_Add(eg_wallEntities, eid)
								--break
							end
							
							local newBlueprint = Cardinal_ConvertTypeToEntityBlueprint(buildingType, player1, false)
							if newBlueprint ~= nil then
								Entity_ConvertBlueprint(eid, newBlueprint)
								return
							else
								print("WARNING: Trying to convert a location but could not find a suitable ebp with the type "..buildingType.." for the race "..Player_GetRaceName(player1))
							end
						end
					end
				end
			end
			
			EGroup_ForEach(data.egroup, _SwapBlueprint)
			Misc_UpdateSlottedSplinesContainingEGroupAfterBlueprintConversion(eg_wallEntities)
			EGroup_Destroy(eg_wallEntities)
			
			Rule_RemoveMe()
		end
	end
	
end

--? @shortdesc Returns a game time-scaled amount between min and max. Time scaling starts after this function is called for the first time.
function Smolensk_GetTimeScaledAmount(min, max)
	starting_time = starting_time or World_GetGameTime()
	
	local value_to_add = World_GetGameTime() - starting_time
	local scaled_amount = min + (1/4) * (value_to_add / 60) + (1/1000000000) * (value_to_add / 60) ^ 6
	
	--Check it against the maximum allowable amount, or round number down to an integer for spawning
	if scaled_amount > max then
		scaled_amount = max
	else
		scaled_amount = math.floor(scaled_amount)
	end
	
	return scaled_amount
	
end

function Smolensk_CheckWestOutpostTrigger()
	
	Player_GetAll(player1)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_west_outpost_trigger, ANY, 20) then
		
		Cmd_FormationAttackMove(sg_west_outpost_cannon1, mkr_west_outpost_cannon_dest1)
		Cmd_FormationAttackMove(sg_west_outpost_cannon2, mkr_west_outpost_cannon_dest2)
		Rule_RemoveMe()
	end
	
end

function Smolensk_CheckNearWestOutpost()	
	Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_west_outpost, Marker_GetProximityRadiusOrDefault(mkr_west_outpost, 0) + 50)
	
	if SGroup_CountSpawned(sg_temp) > 0 then
		local west_outpost_units = {
			{ type = "scar_spearman", 	numSquads = Util_DifVar({2, 4, 4, 8}), 	spawn = mkr_west_outpost_s1 },
			{ type = "scar_manatarms", 	numSquads = Util_DifVar({2, 4, 4, 6}), 	spawn = mkr_west_outpost_s1 },
			{ type = "scar_spearman", 	numSquads = Util_DifVar({2, 4, 4, 8}), 	spawn = mkr_west_outpost_s2 },
			{ type = "scar_manatarms", 	numSquads = Util_DifVar({2, 4, 4, 6}), 	spawn = mkr_west_outpost_s2 }}
		SpawnUnitsToModule(west_outpost_units, west_outpost_defend)
		
		local west_outpost_inner_defend_units = {
			{ type = "scar_spearman", numSquads = 8, spawn = mkr_west_inner_outpost },
			{ type = "scar_manatarms", numSquads = 8, spawn = mkr_west_inner_outpost }}
		SpawnUnitsToModule(west_outpost_inner_defend_units, west_outpost_inner_defend)
		
		--spawn cannons
		local west_outpost_cannons_defend_units = {
			{ type = "scar_cannon", numSquads = 1 }, 
			{ type = "scar_spearman", numSquads = 4 },
			{ type = "scar_manatarms", numSquads = 2 },
		}
		UnitEntry_DeploySquads(player2, sg_west_outpost_cannon1, west_outpost_cannons_defend_units, mkr_west_outpost_cannon1)
		UnitEntry_DeploySquads(player2, sg_west_outpost_cannon2, west_outpost_cannons_defend_units, mkr_west_outpost_cannon2)
		Rule_AddInterval(Smolensk_CheckWestOutpostTrigger, 1)
		
		--SpawnUnitsToModule(west_outpost_cannons_defend_units, west_outpost_cannons_defend)
		
		local west_outpost_gate_defend_units = {
			{ type = "scar_spearman", numSquads = 6, spawn = mkr_west_outpost_gate_s1 },
			{ type = "scar_spearman", numSquads = 6, spawn = mkr_west_outpost_gate_s2 }}
		SpawnUnitsToModule(west_outpost_gate_defend_units, west_outpost_gate_defend)
		
		SGroup_AddGroups(sg_all_west_outpost_defenders, {sg_west_outpost_defend, sg_west_outpost_inner_defend, sg_west_outpost_cannons, sg_west_outpost_gate_defend})
		
		Rule_RemoveMe()
	end
	
end
function Smolensk_CheckNearEastOutpost()
	Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_east_outpost, Marker_GetProximityRadiusOrDefault(mkr_east_outpost, 0) + 50)
	
	if SGroup_CountSpawned(sg_temp) > 0 then
		local east_outpost_units = {
			{ type = "scar_spearman", 		numSquads = Util_DifVar({6, 8, 8, 12}), 	spawn = mkr_east_outpost_s1 },
			{ type = "scar_manatarms", 		numSquads = Util_DifVar({4, 6, 6, 8}), 	spawn = mkr_east_outpost_s1 },
			{ type = "scar_archer", 		numSquads = Util_DifVar({6, 8, 8, 12}), 	spawn = mkr_east_outpost_s2 },
			{ type = "scar_crossbowman", 	numSquads = Util_DifVar({4, 6, 6, 8}), 	spawn = mkr_east_outpost_s2 }}
		SpawnUnitsToModule(east_outpost_units, east_outpost_defend)
		
		Rule_RemoveMe()
	end
end

--Audio walla call after a delay
function Smolensk_DelayedAudioStinger(context, data)
	--Choir stinger
	Sound_Play2D(MUS_STING_TRIUMPHANT)
	
	--Walla celebrate from nearby units
	SGroup_Clear(sg_temp)
	Player_GetAllSquadsNearMarker(player1, sg_temp, data.position, 30) 
	Sound_PlayWallaCelebrateOnSGroup(sg_temp)
end

