function Smolensk_ProximityCallFunction(context, data)
	if Prox_ArePlayersNearMarker(player1, data.marker, ANY, data.range) then
		data.function_name()
		Rule_RemoveMe()
	end
end

function Smolensk_SpawnSmolenskVillagerLife()
	
	smolensk_villagerlife = VillagerLife_Find("villagerlife_smolensk")
	
	--Roaming
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player2, sg_temp, {type = "scar_villager", numSquads = 12}, smolensk_villagerlife.mkr_home)
	VillagerLife_AddSGroup(smolensk_villagerlife, sg_temp)
	
	--Food
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player2, sg_temp, {type = "scar_villager", numSquads = 11}, smolensk_villagerlife.mkr_home)
	VillagerLife_AddSGroup(smolensk_villagerlife, sg_temp, "food")
	
end

function Smolensk_SpawnKrasnyVillagerLife()
	
	krasny_villagerlife = VillagerLife_Find("villagerlife_krasny")
	
	--Roaming
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player3, sg_temp, {type = "scar_villager", numSquads = 4}, krasny_villagerlife.mkr_home)
	VillagerLife_AddSGroup(krasny_villagerlife, sg_temp)
	
	--Food
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player3, sg_temp, {type = "scar_villager", numSquads = 7}, krasny_villagerlife.mkr_home)
	VillagerLife_AddSGroup(krasny_villagerlife, sg_temp, "food")
	
end

