function CaptureCressenville_InitObjectives()
	
    
    local location = LOCATION("Cressenville")
     
    SOBJ_CaptureCressenville = {
         
        Title = "$11178828", --Capture Cressenville
        Type = ObjectiveType_Capture,
		--Parent = OBJ_Recapture,
     --   Icon = "icons/objectives/capture_objective",
        OnStart = CaptureCressenville_Start,
		PreComplete = CaptureCressenville_PreComplete,
        OnComplete = CaptureCressenville_Complete,
    }
    SOBJ_DefeatCressenvilleRebels = {
         
        Title = "$11178829", --Push the French out of Cressenville
        Type = ObjectiveType_Capture,
        Parent = SOBJ_CaptureCressenville,
        OnStart = DefeatCressenvilleRebels_Start,
    }
    SOBJ_LocationCressenville = {
        Title = "$11179196", --Cressenville
        Type = ObjectiveType_Capture,
        Parent = SOBJ_CaptureCressenville,
    }
     
    Objective_Register(SOBJ_CaptureCressenville)
    Objective_Register(SOBJ_DefeatCressenvilleRebels)
    Objective_Register(SOBJ_LocationCressenville)
     
    location.objectivePrimary = SOBJ_CaptureCressenville
    location.objectiveSecondary = SOBJ_DefeatCressenvilleRebels
    location.objectiveCapture = SOBJ_LocationCressenville
     
end
 
function CaptureCressenville_Start()
    Location_SetCapturable(LOCATION("Cressenville"), true)
	Sound_SetMinimumMusicCombatIntensity(801, 0)
	Init_VillagerLife_Cressenville()
end

function CaptureCressenville_PreComplete()
	--Sound_SetMinimumMusicCombatIntensity(801, 0)
	AudOnFromPoint(player1, mkr_village_cressenville, "WALLA_CAMP_CELEBRATE_")
	Sound_Play2D(MUS_STING_POSITIVE)
	
	EGroup_SetTargetingType(eg_village_cressenville, Targeting_None)
	Rule_AddOneShot(Toggle_BuildingCombatOn_Cressenville, 45)
end
 
function CaptureCressenville_Complete()	
	--FOW_UnRevealMarker(mkr_village_cressenville)
	HintPoint_SetVisible(hint_cressenville, false)
	b_CressenvilleFrench = false
	
	Util_AutoSave()
	
	RecaptureEvent()	
	
	if (Player_GetCurrentPopulationCap(player1, CT_Personnel) - Player_GetCurrentPopulation(player1, CT_Personnel)) >= 2 then
		UnitEntry_DeploySquads(player1, sg_blah, {type = "scar_monk", numSquads = amount}, mkr_village_cressenville_spawn)
		if (Player_GetCurrentPopulationCap(player1, CT_Personnel) - Player_GetCurrentPopulation(player1, CT_Personnel)) >= 5 then
			VillagersReinforce(5, mkr_village_cressenville_spawn)
		end
	end
	
	Rule_AddOneShot(Cressenville_Delayed_Counterattack, 60)
	--Transfer_Defenders("LouisRetinue", "FrenchCressenville", 0.25, sg_louis_retinue)
	--Transfer_Defenders("FrenchArmy2", "FrenchCressenville", 0.33, sg_louis_retinue)
	
end

function Cressenville_Delayed_Counterattack()
	SpinUp_CounterAttack("Cressenville_Counterattack", mkr_village_cressenville, 0.25)
end
 
function DefeatCressenvilleRebels_Start()
	Sound_SetMinimumMusicCombatIntensity(801, 0)
	--FOW_RevealMarker(mkr_village_cressenville, -1)
end