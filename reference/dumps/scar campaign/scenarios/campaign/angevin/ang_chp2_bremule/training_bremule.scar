-- after a timer, remove hint about blacksmith upgrades
function UserHasViewedBarracksBuilding(goal)
	if _g_BarracksBuildingTimer == nil then
		_g_BarracksBuildingTimer = Training_GetNewTimerID()
		Timer_Start(_g_BarracksBuildingTimer, 20)
	else
		local currentTime = Timer_GetRemaining(_g_BarracksBuildingTimer)
		if currentTime <= 0 then
			Timer_End(_g_BarracksBuildingTimer)
			_g_BarracksBuildingTimer = nil
			return true	
		end
	end
end


-----------------------------------------------

function Healing_TriggerPredicate(goalSequence)
	sg_monks = SGroup_CreateIfNotFound("sg_monks")
	Player_GetAll(player1, sg_monks)
	SGroup_Filter(sg_monks, "scar_monk", FILTER_KEEP)
		
	if SGroup_CountSpawned(sg_monks) > 0 then
		goalSequence.goals[1].key = SGroup_GetSquadAt(sg_monks, 1)
		goalSequence.goals[2].key = BP_GetAbilityBlueprint("monk_heal_target")
		local woundedBool, woundedTarget = FindWounded()
		if woundedTarget ~= nil and woundedBool == true then
			goalSequence.goals[3].key = woundedTarget
			return true
		end
	end	
	
end

function Healing_MonkIsSelected(goal)
	Misc_GetSelectedSquads(sg_currentSelection, true)
	SGroup_Filter(sg_currentSelection, "scar_monk", FILTER_KEEP)
	if SGroup_CountSpawned(sg_currentSelection) > 0 then
		return true
	end
	
	return false
end

function Healing_UseHeal(goal)
	return training_currentAbilityBlueprint == BP_GetAbilityBlueprint("monk_heal_target")
end

function Healing_TargetWounded(goal)
	if goal.key ~= nil then
		return Squad_GetHealthPercentage(goal.key, false) >= 1.0
	else
		local woundedBool, woundedTarget = FindWounded()
		goal.key = woundedTarget
	end
	
end

function FindWounded()
	
	local squadID = nil
	
	local _IsCanidate = function(gid, index, sid)
		if Squad_GetHealthPercentage(sid, false) < 1.0 then
			if Squad_IsUnderAttack(sid, 3) == false and Squad_IsAttacking(sid, 3) == false then
				squadID = sid
				return true
			end
		end
	end
	
	Player_GetAll(player1)
	return SGroup_ForEachAllOrAny(sg_allsquads, ANY, _IsCanidate), squadID
end