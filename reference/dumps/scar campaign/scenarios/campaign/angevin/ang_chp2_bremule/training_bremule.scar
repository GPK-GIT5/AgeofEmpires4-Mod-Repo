	--Misc_GetSelectedEntities(eg_currentSelection, true)
	--EGroup_Filter(eg_currentSelection, "blacksmith", FILTER_KEEP)
	--if EGroup_CountSpawned(eg_currentSelection) > 0 then
		--return true
	--end
	
	--return false
--end

-- after a timer, remove hint about blacksmith upgrades
function UserHasViewedBlacksmithBuilding(goal)
	if _g_BlacksmithBuildingTimer == nil then
		_g_BlacksmithBuildingTimer = Training_GetNewTimerID()
		Timer_Start(_g_BlacksmithBuildingTimer, 20)
	else
		local currentTime = Timer_GetRemaining(_g_BlacksmithBuildingTimer)
		if currentTime <= 0 then
			Timer_End(_g_BlacksmithBuildingTimer)
			_g_BlacksmithBuildingTimer = nil
			return true	
		end
	end
end

--------------------------------------------------------------
-- Unit Upgrades training hints
--------------------------------------------------------------

function MissionTutorial_UnitUpgrade()
	
	--local selectBarracks = Training_Goal("Entity", {Message="LEFT CLICK to select the barracks", DataTemplate="LeftClickTrainingDataTemplate"}, UnitUpgrade_BarracksIsSelected)
	local hoverInfo = Training_Goal("Entity", {Message = "$11191768", DataTemplate="GenericTrainingDataTemplate"}, UserHasViewedBarracksBuilding) --"You can upgrade your units to more advanced version at their production buildings."

	unitUpgradeSequence = Training_GoalSequence(goal_unitupgrade, 1, 0, UnitUpgrade_TriggerPredicate, CampaignTraining_TimeoutIgnorePredicate, nil, UnitUpgrade_BypassPredicate, false, {hoverInfo})
	
	Training_AddGoalSequence(unitUpgradeSequence)
	Training_EnableGoalSequenceByID(unitUpgradeSequence, true)
end

function UnitUpgrade_TriggerPredicate(goalSequence)
	--if Player_CanConstruct(player1, BP_GetUpgradeBlueprint("upgrade_unit_spearman_3_eng"))
		--or Player_CanConstruct(player1, BP_GetUpgradeBlueprint("upgrade_unit_manatarms_3_eng")) then
	
	Player_GetAll(player1)
	EGroup_Filter(eg_allentities, "barracks", FILTER_KEEP)
	if EGroup_CountSpawned(eg_allentities) > 0 and
		Player_GetResource(player1, RT_Gold) > 100 and
			Player_GetResource(player1, RT_Food) > 25 then
		goalSequence.goals[1].key = EGroup_GetEntityAt(eg_allentities, 1)
		return true
	end
end

function UnitUpgrade_BypassPredicate(goalSequence)
	if Player_HasUpgrade(player1, UPG.ENGLISH.UPGRADE_UNIT_MANATARMS_2_ENG) or Player_HasUpgrade(player1, UPG.ENGLISH.UPGRADE_UNIT_SPEARMAN_3_ENG) or Player_HasUpgrade(player1, UPG.ENGLISH.UPGRADE_UNIT_ARCHER_3_ENG) or Player_HasUpgrade(player1, UPG.COMMON.UPGRADE_UNIT_HORSEMAN_3) then
		return true
	else
		return false
	end
end

