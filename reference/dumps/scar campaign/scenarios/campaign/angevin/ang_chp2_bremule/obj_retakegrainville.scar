function CaptureGrainville_InitObjectives()
     
    local location = LOCATION("Grainville")
     
    SOBJ_CaptureGrainville = {
         
        Title = "$11178830", --Capture Grainville
        Type = ObjectiveType_Capture,
		--Parent = OBJ_Recapture,
        OnStart = CaptureGrainville_Start,
        OnComplete = CaptureGrainville_Complete,
		PreComplete = CaptureGrainville_PreComplete,
    }
    SOBJ_DefeatGrainvilleRebels = {
         
        Title = "$11178831", --Push the French out of Grainville
        Type = ObjectiveType_Capture,
        Parent = SOBJ_CaptureGrainville,
        OnStart = DefeatGrainvilleRebels_Start,
    }
    SOBJ_LocationGrainville = {
        Title = "$11178836",
        Type = ObjectiveType_Capture,
        Parent = SOBJ_CaptureGrainville,
    }
     
    Objective_Register(SOBJ_CaptureGrainville)
    Objective_Register(SOBJ_DefeatGrainvilleRebels)
    Objective_Register(SOBJ_LocationGrainville)
     
    location.objectivePrimary = SOBJ_CaptureGrainville
    location.objectiveSecondary = SOBJ_DefeatGrainvilleRebels
    location.objectiveCapture = SOBJ_LocationGrainville
     
end
 
function CaptureGrainville_Start()
    Location_SetCapturable(LOCATION("Grainville"), true)
	Init_VillagerLife_Grainville()
end
 
function CaptureGrainville_PreComplete()

	AudOnFromPoint(player1, mkr_village_grainville, "WALLA_CAMP_CELEBRATE_")
	Sound_Play2D(MUS_STING_POSITIVE)
	
	EGroup_SetTargetingType(eg_village_grainville, Targeting_None)
	Rule_AddOneShot(Toggle_BuildingCombatOn_Grainville, 45)
end

function CaptureGrainville_Complete()

	HintPoint_SetVisible(hint_grainville, true)
	b_GrainvilleFrench = false
	
	Util_AutoSave()
	
	RecaptureEvent()

	--adding for Event Challenge S04 E01 Challenge 01
	Game_SendCustomChallengeEvent(player1, CE_GRAINVILLECONQUERED, 1)
	
	if (Player_GetCurrentPopulationCap(player1, CT_Personnel) - Player_GetCurrentPopulation(player1, CT_Personnel)) >= 5 then
		VillagersReinforce(5, mkr_village_grainville_spawn)
	end
	
	Rule_AddOneShot(Grainville_Delayed_Counterattack, 60)
	
end

function Grainville_Delayed_Counterattack()
	SpinUp_CounterAttack("Grainville_Counterattack", mkr_village_grainville, 0.25)
end

function DefeatGrainvilleRebels_Start()
	Sound_SetMinimumMusicCombatIntensity(801, 0)
end