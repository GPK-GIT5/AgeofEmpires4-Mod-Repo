		{ type = "scar_horseman", numSquads = 5, sgroup = {sg_french_horseman_3_1, sg_french_army}, spawn = mkr_intro_horseman_3_1},
		{ type = "scar_horseman", numSquads = 5, sgroup = {sg_french_horseman_3_2, sg_french_army}, spawn = mkr_intro_horseman_3_2},
		{ type = "scar_horseman", numSquads = 5, sgroup = {sg_french_horseman_3_3, sg_french_army}, spawn = mkr_intro_horseman_3_3},
	}
	
	local parade_horsemen_mkr = {
		mkr_intro_horseman_3_3_target,
		mkr_intro_horseman_3_2_target,
		mkr_intro_horseman_3_1_target,
		mkr_intro_horseman_3_target,
	}
	
	Util_UnitParade(parade_horsemen_mkr, parade_horsemen, nil, nil, player2)
	french_horseman_speed_3 = Modify_UnitSpeed(sg_french_horseman_3, 0.5)
	french_horseman_speed_3_1 = Modify_UnitSpeed(sg_french_horseman_3_1, 0.5)
	french_horseman_speed_3_2 = Modify_UnitSpeed(sg_french_horseman_3_2, 0.5)
	french_horseman_speed_3_3 = Modify_UnitSpeed(sg_french_horseman_3_3, 0.5)
	
	Cmd_HoldPosition(sg_french_horseman_3, true)
	Cmd_HoldPosition(sg_french_horseman_3_1, true)
	Cmd_HoldPosition(sg_french_horseman_3_2, true)
	Cmd_HoldPosition(sg_french_horseman_3_3, true)
	
end

