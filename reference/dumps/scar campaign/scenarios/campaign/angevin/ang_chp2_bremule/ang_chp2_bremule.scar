function Mission_SetDifficulty()

	t_difficulty = 
	{
		scoutsAmount = Util_DifVar({4, 4, 8, 12}),
		invasionScale = Util_DifVar({0.18, 0.5, .75, 1}),
		attackWaveScale = Util_DifVar({0, 0, 1, 2}),
		attackWaveFrequency = Util_DifVar({15, 15, 10, 5}), --Minutes
		ramWaveFrequency = Util_DifVar({10, 10, 5, 5}), --Minutes
		storyStartingVillagers = Util_DifVar({2, 0, 0, 0}), --Adds 2 villagers to gold and food each in Fluery
		matchUpSimplify = 
		{
			ranged = Util_DifVar({0, 0, 1, 1}),
			infantry = Util_DifVar({2, 2, 1, 1}),
		},
		enemyStartsMaxed = Util_DifVar({false, false, false, true}),
		t_frenchScoutCamps = Util_DifVar({
				{ --Story
					mkr_scout_waypoint_1,
					mkr_scout_waypoint_2,
					mkr_scout_waypoint_3,
					mkr_scout_waypoint_4,
				},
				{ --Easy
					mkr_scout_waypoint_1,
					mkr_scout_waypoint_2,
