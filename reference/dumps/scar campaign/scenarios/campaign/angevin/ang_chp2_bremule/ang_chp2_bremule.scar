	--local defaultOffset = Util_GetOffsetPosition(mkr_intro_horseman_4, OFFSET_FRONT, 1)
	--LocalCommand_PlayerSquadConstructBuilding(player2, sg_french_grunts, BP_GetEntityBlueprint("military_tent_a_eng"), Util_GetPosition(mkr_intro_horseman_4), defaultOffset, false)
