--Gets a list of targets based on player ownership
function SetPriorityTargets()
	local town_targets = {}
	
	if b_CressenvilleFrench == false then table.insert(town_targets, mkr_village_cressenville) end
	if b_GrainvilleFrench == false then table.insert(town_targets, mkr_village_grainville) end
	table.insert(town_targets, mkr_village_fleury_attacktarget)

	return town_targets
end


--Play Nar and Adjust the game once the player start to retake ground
function EnglishPushBack()
	if Objective_IsComplete(SOBJ_CaptureGrainville) or Objective_IsComplete(SOBJ_CaptureCressenville) then
		Rule_RemoveMe()
		Util_StartIntel(EVENTS.EnglishPush)
	end
end

--Spawns some villagers where we need them
function VillagersReinforce(amount, area)
	local units = {{type = "scar_villager", numSquads = amount}}
	
 	UnitEntry_DeploySquads(player1, sg_temp, units, area)
end

--Locks out the AI performing its own upgrades
function LockAllUpgrades(player)
	for index, upgradeID in pairs(UPG.COMMON) do
		if scartype(upgradeID) == ST_PBG then
			Player_SetUpgradeAvailability(player, upgradeID, ITEM_LOCKED)
		end
	end

	for index, upgradeID in pairs(UPG.ENGLISH) do
		if scartype(upgradeID) == ST_PBG then
			Player_SetUpgradeAvailability(player, upgradeID, ITEM_LOCKED)
		end
	end
end

function Build_LocationTable(egroup)
		
	local completeTable = {}
		
	local _BuildTable = function(gid, index, item)
		table.insert(completeTable, index, {
			entity = Entity_GetID(item), 
			bp = Entity_GetBlueprint(item), 
			pos = Entity_GetPosition(item),
			facing = Util_GetFacingFromDirection(Entity_GetPosition(item), Entity_GetHeading(item)),
				
		})
	end
		
	EGroup_ForEach(egroup, _BuildTable)
	return completeTable
end

function Rebuild_Location(locationTable, rebuilderGroup, locationToRebuild)
	Rule_AddOneShot(Rebuild_Location_Delayed, 0.125, {locationTable = locationTable, rebuilderGroup = rebuilderGroup, locationToRebuild = locationToRebuild})
end

function Rebuild_Location_Delayed(context, data) --Delayed to allow FOG of war to enable.
	local locationTable = data.locationTable 
	local rebuilderGroup = data.rebuilderGroup 
	local locationToRebuild = data.locationToRebuild
	
		local typesToConvert = {
			"scar_arsenal",
			"scar_house",
			"scar_barracks",
			"scar_archeryrange",
			"scar_stable",
			"scar_blacksmith",
			"scar_archeryrange",
			"farm",
			"scar_lumbercamp",
			"scar_miningcamp",
			"scar_gristmill",
			"scar_market",
			"scar_outpost",
			"scar_monastery",
		}
	
	local spawnPoint = World_GetHiddenPositionOnPath(player1, mkr_french_army_spawn, locationToRebuild, CHECK_BOTH)
	if spawnPoint == nil then
		spawnPoint = locationToRebuild
	end	
	UnitEntry_DeploySquads(player2, rebuilderGroup, {type = "scar_villager", numSquads = 3,}, spawnPoint)
	for index, building in ipairs(locationTable) do
		if Entity_IsValid(building.entity) then
			local entity = Entity_FromID(building.entity)
			if Entity_IsAlive(entity) ~= true then
				for typeIndex, buildingType in pairs(typesToConvert) do 
					if Entity_IsOfType(entity, buildingType) then
						building.bp = Cardinal_ConvertTypeToEntityBlueprint(buildingType, player2, false)
						Player_SetEntityProductionAvailability(player2, building.bp, ITEM_UNLOCKED)
						LocalCommand_PlayerSquadConstructBuilding(player2, rebuilderGroup, building.bp, building.pos, building.facing, true)
					end
				end
			end
		end
	end
	
	Cmd_MoveToAndDestroy(rebuilderGroup, mkr_french_army_spawn, true)
end

