--RAM WAVES--
----------------------------

function Init_Ram_RovingArmy()
	local moduleData = 
	{
		descriptor = "FrenchArmy_Ram",
		
		type = "RovingArmy",
		player = player2,
		sgroup = sg_french_ram,
		units =  ConstructWave(),
		
		spawnLocation = Siege_LaunchPoint(),
		
		--fallbacks = {{marker = mkr_crossroads,}},
		onDeathFunction = StartRamTimer,
		targetingType = ARMY_TARGETING_DISCARD,
		targets = Siege_Targets(),
		attackMove = attackMoveStyle_attackEverything,
	}
	
	local ramModule = RovingArmy_Init(moduleData)
	Hunting_Intel() -- Plays intel the first time this group is launched
end

function StartRamTimer()
	Rule_AddOneShot(Reset_RamWave, SiegeCamp_TimerMod()*(t_difficulty.ramWaveFrequency*60))
end

function SiegeCamp_TimerMod()
	if eg_ambushtents ~= nil and EGroup_CountSpawned(eg_ambushtents) > 0 then
		return 0.3
	else
		return 1
	end		
end

function ConstructWave()
	--Wave Init
	local gameTime = World_GetGameTime()
	gameTime = gameTime/60
	waveTest = waveTest or nil
	if waveTest ~= nil then 
		gameTime = waveTest
	end
	
	if gameTime <= 50 then
		local quarterTime = gameTime/4
		--local billionthTime = (1/1000000000)*gameTime
		local exponentTime = (gameTime^6)/1000000000
		
		wavePower = quarterTime + exponentTime
	else
		wavePower = 51
	end
	
	if t_difficulty.attackWaveScale == 0 then
		wavePower = 1		
	elseif t_difficulty.attackWaveScale == 2 and wavePower < 10 then
		wavePower = 10	
	else
		wavePower = wavePower
	end
	
	waveDiffModded = math.floor(math.min(wavePower, 50))
	
	local waveunits = {} --Changes attack wave composition based on game time
	waveunits = 
	{ 		
		{ type = "scar_spearman", numSquads = 12+waveDiffModded},
		{ type = "scar_manatarms", numSquads = math.floor(waveDiffModded/2)},
		{ type = "scar_ram", numSquads = 1+(waveDiffModded/5)},
	}
	
	local randunits = {
		{ type = "scar_ram", numSquads = World_GetRand(1,2)}, 
		{ type = "scar_horseman", numSquads = World_GetRand(1,5)}, 
		{ type = "scar_archer", numSquads = World_GetRand(1,5)}, 
		{ type = "scar_scout", numSquads = World_GetRand(1,3)}, 
		{ type = "scar_knight", numSquads = World_GetRand(1,2)}
	}
	for i = 1, math.min(math.floor(waveDiffModded/5), 4) do
		table.insert(waveunits, Table_GetRandomItem(randunits))
	end
	
	return waveunits
end

function Reset_RamWave()
	if b_endGame == false then
		waveNumber = waveNumber or 1
		local ramModule = MissionOMatic_FindModule("FrenchArmy_Ram")
		local units = ConstructWave()
		
		local targets = Siege_Targets()
		SpawnUnitsToModule(units, ramModule, Siege_LaunchPoint())
		if SGroup_CountSpawned(ramModule.sgroup) > 0 then
			RovingArmy_SetTargets(ramModule, targets)
		end
		waveNumber = waveNumber+1
	end
end

function Siege_LaunchPoint()
	Player_GetAll(player1)
	if eg_ambushtents ~= nil and EGroup_CountSpawned(eg_ambushtents) > 0 and Prox_AreSquadsNearMarker(sg_allsquads, mkr_hill_ambush, ANY, 60) == false then --Player_CanSeePosition(player1, Util_GetPosition(mkr_hill_ambush)) ~= true then
		return mkr_hill_ambush
	elseif b_GrainvilleFrench == true and Prox_AreSquadsNearMarker(sg_allsquads, mkr_village_grainville_spawn, ANY, 60) == false then--Player_CanSeePosition(player1, Util_GetPosition(mkr_village_grainville_spawn)) ~= true then
		return mkr_village_grainville_spawn
	elseif b_CressenvilleFrench == true and Prox_AreSquadsNearMarker(sg_allsquads, mkr_village_cressenville_spawn, ANY, 60) == false then--Player_CanSeePosition(player1, Util_GetPosition(mkr_village_cressenville_spawn)) ~= true then
		return mkr_village_cressenville_spawn
	else
		return mkr_french_army_spawn
	end
end

function Siege_Targets()
	local targets = {}
	
	if Game_GetSPDifficulty() > GD_EASY then
		if b_CressenvilleFrench ~= true then
			targets = {mkr_village_cressenville, mkr_village_grainville, mkr_village_fleury_attacktarget}
		elseif b_GrainvilleFrench ~= true then
			targets = {mkr_village_grainville, mkr_village_fleury_attacktarget}
		elseif eg_ambushtents ~= nil and EGroup_CountSpawned(eg_ambushtents) > 0 then
			targets = {mkr_village_fleury_attacktarget}
		else
			targets = {mkr_village_cressenville, mkr_village_grainville, mkr_village_fleury_attacktarget}
		end
	else
		targets = {mkr_village_cressenville, mkr_village_grainville}
	end
	
	return targets
end

