end

function LiquidateLouisArmy()
		sg_louisholdingarmy = SGroup_CreateIfNotFound("sg_louisholdingarmy")
		SGroup_AddGroup(sg_louis_army, sg_louis_reup)
		Prefab_DoAction(MissionOMatic_FindModule("LouisReUp"), "Disband")
		SGroup_Duplicate(sg_louis_army, sg_louisholdingarmy)
		Prefab_DoAction(MissionOMatic_FindModule("LouisRetinue"), "Disband")
		sg_louis_army = SGroup_CreateIfNotFound("sg_louis_army")
		SGroup_AddGroup(sg_louis_army, sg_louisholdingarmy)
		Rule_AddInterval(EnsureCampArrival, 20)
		Rule_EnterProximity(Pre_BreakForCamp, ALL, sg_louis_army, mkr_village_bremule, 60, false, {})
end

function EnsureCampArrival()
	if SGroup_CountSpawned(sg_louis_army) > 0 then
		Cmd_FormationMove(sg_louis_army, mkr_village_bremule, false, false, Util_GetFacingFromDirection(Util_GetPosition(mkr_village_bremule), Util_GetDirectionFromAtoB(mkr_village_bremule, mkr_village_cressenville)))
	end
	if SGroup_CountSpawned(sg_louis_reup) > 0 then
		Cmd_FormationMove(sg_louis_reup, mkr_village_bremule, false, false, Util_GetFacingFromDirection(Util_GetPosition(mkr_village_bremule), Util_GetDirectionFromAtoB(mkr_village_bremule, mkr_village_cressenville)))
	end
end

function Pre_BreakForCamp()
	Rule_Remove(EnsureCampArrival)
	Rule_AddOneShot(DelaySetUpTent, 10)
end

function DelaySetUpTent()
	sg_louisholdingarmy = SGroup_CreateIfNotFound("sg_louisholdingarmy")
	SGroup_Duplicate(sg_louis_army, sg_louisholdingarmy)
	Prefab_DoAction(MissionOMatic_FindModule("LouisRetinue"), "Disband")
	sg_louis_army = SGroup_CreateIfNotFound("sg_louis_army")
	SGroup_AddGroup(sg_louis_army, sg_louisholdingarmy)
	Rule_AddOneShot(SetUpTent, 10)
end


function SetUpTent()
	louisCamps = AllMarkers_FromName("mkr_louis_camp", "")
	sg_louis_dup = SGroup_CreateIfNotFound("sg_louis_dup")
	sg_louis_knights = SGroup_CreateIfNotFound("sg_louis_knights")
	sg_louis_horseman = SGroup_CreateIfNotFound("sg_louis_horseman")
	sg_temp_campgroup = SGroup_CreateIfNotFound("sg_temp_campgroup")
	SGroup_Duplicate(sg_louis_army, sg_louis_dup)
	SGroup_Filter(sg_louis_dup, "cavalry", FILTER_REMOVE, sg_louis_knights)
	--SGroup_Filter(sg_louis_knights, "scar_horseman", FILTER_REMOVE, sg_louis_horseman)
	for index, camp in pairs(louisCamps) do
		SGroup_Duplicate(sg_louis_dup, sg_temp_campgroup)
		SGroup_Clear(sg_louis_dup)
		SGroup_FilterCount(sg_temp_campgroup, World_GetRand(4,9), sg_louis_dup)
		HangOut(sg_temp_campgroup, camp)
		if b_CampBuilt == false then
			Util_CreateEntities(player2, eg_blah, BP_GetEntityBlueprint("ang_chp2_bremule_camp_a"), camp, 1, nil, true, true, true)
		end
	end	
	b_CampBuilt = true
	
	--if t_campPatrols ~= nil and #t_campPatrols > 0 then
		--for index, sgroup in pairs(sgroupTable) do
			--SGroup_Destroy(sgroup)
		--end
	--end
	t_campPatrols = {}
	local i_campSet = 0
	local _PatrolGroup = function(gid, index, sid)
		if SGroup_Exists("sg_camppatrol_"..i_campSet) == false then
			_G["sg_camppatrol_"..i_campSet] = SGroup_CreateIfNotFound("sg_camppatrol_"..i_campSet)
			SGroup_Add(_G["sg_camppatrol_"..i_campSet], sid)
			table.insert(t_campPatrols, _G["sg_camppatrol_"..i_campSet])
		elseif SGroup_CountSpawned(_G["sg_camppatrol_"..i_campSet]) < 2 then
			SGroup_Add(_G["sg_camppatrol_"..i_campSet], sid)
		else
			i_campSet = i_campSet+1
			_G["sg_camppatrol_"..i_campSet] = SGroup_CreateIfNotFound("sg_camppatrol_"..i_campSet)
			SGroup_Add(_G["sg_camppatrol_"..i_campSet], sid)
			table.insert(t_campPatrols, _G["sg_camppatrol_"..i_campSet])
		end			
	end	
	SGroup_ForEach(sg_louis_dup, _PatrolGroup)
	
	if campSpeed ~= nil then
		Modifier_Remove(campSpeed)
	end
	campSpeed = Modify_UnitSpeed(sg_louis_army, 0.35)
	if Rule_Exists(PatrolCamp) ~= true then
		Rule_AddInterval(PatrolCamp, 10, {sgroupTable = t_campPatrols, poiTable = louisCamps})
	end
	if Rule_Exists(CombatWatch) ~= true then
		Rule_AddInterval(CombatWatch, 2)
	end
	StandPretty(sg_louis_knights)
	--Rule_Remove(PatrolCamp)
	--Rule_Remove(CombatWatch)
	--Modifier_RemoveAllFromSGroup(sg_louis_army)
	--eg_tents = EGroup_CreateIfNotFound("eg_tents")
	--Util_CreateEntities(player2, eg_tents, BP_GetEntityBlueprint("military_tent_a_eng"), mkr_intro_horseman_4, 1, nil, true, false, true)
end

function PatrolCamp(context, data)
	sgroupTable = data.sgroupTable
	poiTable = data.poiTable
	
	for index, sgroup in pairs(sgroupTable) do
		if SGroup_CountSpawned(sgroup) > 0 and SGroup_IsMoving(sgroup, ALL) == false then
			local rand_NextMoveTo = Util_GetPosition(Table_GetRandomItem(poiTable))
			local offset_NextMoveTo = World_GetOffsetPositionRelativeToFacingTarget(rand_NextMoveTo, Util_GetPosition(sgroup), 3)
			Cmd_FormationMove(sgroup, offset_NextMoveTo)
		end
	end
end

function CombatWatch()
	if SGroup_CountSpawned(sg_louis_army) > 0 then
		Player_GetAllSquadsNearMarker(player1, sg_player_louisthreats, mkr_village_bremule, 80)
		if SGroup_CountSpawned(sg_player_louisthreats) > 0 then
				Rule_RemoveMe()
				CampShutDown(campSpeed, t_campPatrols, PatrolCamp)
			end
	else
		Rule_RemoveMe()
		CampShutDown(campSpeed, t_campPatrols, PatrolCamp)
	end
end

function RestartCamp()
	if SGroup_CountSpawned(sg_louis_army) > 0 then
		Player_GetAllSquadsNearMarker(player1, sg_player_louisthreats, mkr_village_bremule, 80)
		if SGroup_IsUnderAttack(sg_louis_army, ANY, 15) ~= true and SGroup_CountSpawned(sg_player_louisthreats) <= 0 then
			Rule_RemoveMe()
			--Encounter_Stop(Camp_Defense_Encounter, true)
			SetUpTent()
		else
			Init_Camp_Defense_Encounter()
		end
	else
		Rule_RemoveMe()
	end
end

function CampShutDown(modifier, sgroupTable, rule)
	Modifier_Remove(modifier)
	
	Rule_Remove(rule)
	for index, sgroup in pairs(sgroupTable) do
		SGroup_Destroy(sgroup)
	end
	Init_Camp_Defense_Encounter()
	--Player_GetAllSquadsNearMarker(player1, sg_player_louisthreats, mkr_village_bremule, 90)
	--if SGroup_CountSpawned(sg_louis_army) > 0 and SGroup_CountSpawned(sg_player_louisthreats) > 0 then
		--Init_Camp_Defense_Encounter()
		----Cmd_FormationMove(sg_louis_army, mkr_village_bremule, false, false, Util_GetFacingFromDirection(Util_GetPosition(mkr_village_bremule), Util_GetDirectionFromAtoB(mkr_village_bremule, sg_player_louisthreats)))
	--end
end

function HangOut(sgroup, marker)
	if SGroup_CountSpawned(sgroup) > 0 then
		local unit_count = SGroup_CountSpawned(sgroup)
		local spacingAmount = math.max(0.3*unit_count, 2)
		if SGroup_HasSquadBlueprint(sgroup, "cavalry", ANY) then
			spacingAmount = math.max(0.5*unit_count, 4)
		end
		local degreeSeperation = 360/unit_count
		local _ArrangeUnits = function(gid, index, sid)
			local i_offset = index+1
			local offset_cos = math.cos(degreeSeperation*i_offset)
			local offset_sin = math.sin(degreeSeperation*i_offset)
			SGroup_Single(sg_single, sid)
			local offsetLocation = PositionWithOffset(Util_GetPosition(marker), spacingAmount*offset_sin, spacingAmount*offset_cos)
			Cmd_FormationMove(sg_single, offsetLocation, false, false, Util_GetFacingFromDirection(Util_GetPosition(marker), Util_GetDirectionFromAtoB(offsetLocation, marker)))
		end
		SGroup_ForEach(sgroup, _ArrangeUnits)
	end
end

function Init_Camp_Defense_Encounter()
	if Camp_Defense_Encounter == nil or Encounter_IsActive(Camp_Defense_Encounter) ~= true then
		local goal = { 
			plan = "Attack",
			target = mkr_village_bremule,
			combatRange = 90,
			leashRange = 160,
			attackMove = attackMoveStyle_attackEverything,
			callbacks = {
				success = Reset_Camp,
			},
		}	
		Camp_Defense_Encounter = Encounter_Create(player2, sg_louis_army, goal, "Camp_Defense_Encounter")
	end
end

function Reset_Camp()
	if Rule_Exists(RestartCamp) ~= true then
		Rule_AddInterval(RestartCamp, 5)
	end
end

function AmbushCamp()
