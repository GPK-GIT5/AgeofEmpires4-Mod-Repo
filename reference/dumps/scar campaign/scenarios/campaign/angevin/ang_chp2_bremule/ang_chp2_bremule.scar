--Sets up the Hunting rovingarmy module
function Init_Hunting_RovingArmy()
	local moduleData = 
	{
		descriptor = "FrenchArmy_Hunting",
		
		type = "RovingArmy",
		player = player2,
		sgroup = sg_french_huntingarmy,
		
		spawnLocation = mkr_french_army_spawn,

		
		--fallbacks = {{marker = mkr_crossroads,}},
		onDeathFunction = Set_HuntingReinforcements,
		targetingType = ARMY_TARGETING_DISCARD,
		targets = {mkr_crossroads},
		--attackMove = attackMoveStyle_attackEverything,
	}
	
	local huntModule = RovingArmy_Init(moduleData)	
end

--Sets up the waves for the hunting army
function Init_FrenchWaves()
	wave_data_1 = {
		descriptor = "wave_1",
		player = player2,
		use_separate_spawns = false,
		spawn = mkr_french_army_spawn,
		units = {
			{ type = "scar_horseman", numSquads = 10 },
			{ type = "scar_knight", numSquads = 5 },
			{ type = "scar_scout", numSquads = 1 },
		},
		staging_module = nil,
		assault_module = "FrenchArmy_Hunting",
		ignore_build_times = true,
		--attackMove = attackMoveStyle_normal,
	}
	wave_1 = Wave_New(wave_data_1)
	Wave_Prepare(wave_1)
	Rule_AddInterval(ThreatArrow_SpottedHuntingArmy, 1)
end

function ThreatArrow_SpottedHuntingArmy()
	if SGroup_CountSpawned(sg_french_huntingarmy) > 0 then
		local huntingModule = MissionOMatic_FindModule("FrenchArmy_Hunting")
		local currentHuntingTarget = huntingModule.targets[huntingModule.targetIndex]
		if currentHuntingTarget ~= nil and currentHuntingTarget ~= mkr_crossroads then
			if b_hunterArrow_On == false then
				huntingArmy_threatArrow = ThreatArrow_CreateGroup("huntingArmy", sg_french_huntingarmy)
				UI_CreateMinimapBlip(sg_french_huntingarmy, 10, "threat_group")
				b_hunterArrow_On = true
			end
		else
			if b_hunterArrow_On == true then
				b_hunterArrow_On = false
				ThreatArrow_DestroyGroup(huntingArmy_threatArrow)
			end
		end
	else
		if b_hunterArrow_On == true then
			b_hunterArrow_On = false
			ThreatArrow_DestroyGroup(huntingArmy_threatArrow)
		end		
	end
end

function HuntingArrow_On()
	if b_hunterArrow_On == false then
		huntingArmy_threatArrow = ThreatArrow_CreateGroup("huntingArmy", sg_french_huntingarmy)
		UI_CreateMinimapBlip(sg_french_huntingarmy, 10, "threat_group")
		b_hunterArrow_On = true
	end
end

function HuntingArrow_Off()
	if b_hunterArrow_On == true then
		b_hunterArrow_On = false
		ThreatArrow_DestroyGroup(huntingArmy_threatArrow)
	end
end

function UpdateWaveTarget()
	local huntModule = MissionOMatic_FindModule("FrenchArmy_Hunting")
	--If the hunt module exists and has units spawned in it, continue
	if huntModule ~= nil and SGroup_CountSpawned(huntModule.sgroup) > 0 then
		local newTarget = nil 
		local huntModule_CurrentTarget = huntModule.targets[huntModule.targetIndex]
		--Get all the player units and remove any inside the safezone marker
		Player_GetAll(player1)
		Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_player_safezone)
		SGroup_RemoveGroup(sg_allsquads, sg_temp)
		
		--If there are any units left outside the safezone marker then check if any of those units can be see, or else remove them
		if SGroup_CountSpawned(sg_allsquads) > 1 then		
			local _SpottedTargets = function(gid, idx, sid)
				if Player_CanSeeSquad(player2, sid, ANY) ~= true then
					SGroup_Remove(gid, sid)
				end
			end
			SGroup_ForEach(sg_allsquads, _SpottedTargets)
			
			--If there are any valid units left that are outside the safezone marker and can be seen by player 2, guage their distance priority
			if SGroup_CountSpawned(sg_allsquads) >= 1 then
				local targetRange = nil
				local squadTarget = nil
				local bestTarget = {targetRange, squadTarget}
				local dist_SameTarget = 0
				local _BestTarget = function(gid, idx, sid)
					local dist_WaveFromTarget = Util_GetDistance(huntModule.sgroup, sid)
					--local dist_PlayerToSpawn = Util_GetDistance(sid, mkr_french_army_spawn)
					local dist_WaveToBase = 9999
					if huntModule_CurrentTarget ~= nil and huntModule_CurrentTarget ~= mkr_crossroads then
						dist_WaveToBase = Util_GetDistance(huntModule.sgroup, huntModule_CurrentTarget.position)
					end
					
					if dist_WaveToBase >= dist_WaveFromTarget then
						if bestTarget.squadTarget == nil then
							bestTarget.squadTarget = sid
							bestTarget.targetRange = dist_WaveFromTarget
						elseif dist_WaveFromTarget < bestTarget.targetRange then
							bestTarget.squadTarget = sid
							bestTarget.targetRange = dist_WaveFromTarget
						end	
					end
					
					newTarget = bestTarget.squadTarget
				end
				SGroup_ForEach(sg_allsquads, _BestTarget)
				
				if newTarget ~= nil then
					if huntModule_CurrentTarget ~= nil and huntModule_CurrentTarget.position ~= nil then
						dist_SameTarget = Util_GetDistance(huntModule_CurrentTarget.position, Util_GetPosition(newTarget))
						if dist_SameTarget > 30 then
							print("Enemy in range, changing target to "..tostring(newTarget))
							if newTarget then 
								RovingArmy_SetTarget(huntModule, Util_GetPosition(newTarget), 10) 
								RovingArmy_AddTarget(huntModule, mkr_crossroads)
							end
						end
					else
						print("Current target invalid, changing target to "..tostring(newTarget))
						if newTarget then 
							RovingArmy_SetTarget(huntModule, Util_GetPosition(newTarget), 10) 
							RovingArmy_AddTarget(huntModule, mkr_crossroads)
						end
					end
				end
			end
		end
		
		if huntModule_CurrentTarget ~= nil and huntModule_CurrentTarget.marker ~= nil then
			Rule_AddOneShot(UpdateWaveTarget, 3)
		else
			Rule_AddOneShot(UpdateWaveTarget, 10)
		end
	else
		Rule_AddOneShot(UpdateWaveTarget, 1)
	end	
end

function Set_HuntingReinforcements()
	AudOnFromPoint(player1, roving_LastPos, "WALLA_CAMP_CELEBRATE_")
	Sound_Play2D(MUS_STING_POSITIVE)
	
	huntingScale = huntingScale or 0
	huntingScale = huntingScale+(2*t_difficulty.attackWaveScale)
			
	Rule_AddOneShot(Spawn_HuntingReinforcements, (60*t_difficulty.attackWaveFrequency))
end

function Spawn_HuntingReinforcements()
	if b_endGame == false then
		local units =
		{
			{type = "scar_scout", numSquads = 2,},
			{type = "scar_knight", numSquads = (math.floor(huntingScale*0.25)),},
			{type = "scar_horseman", numSquads = 10,},
		}
		--local hunters = MissionOMatic_FindModule("FrenchArmy_Hunting")
		Wave_SetUnits(wave_1, units)
		Wave_Prepare(wave_1)
		--RovingArmy_SetTargets(hunters, SetPriorityTargets())
		Rule_AddInterval(Reset_HuntingTargets, 3)
	end
end

function Reset_HuntingTargets()
	local hunters = MissionOMatic_FindModule("FrenchArmy_Hunting")
	if SGroup_CountSpawned(hunters.sgroup) > 0 then
		Rule_RemoveMe()
		RovingArmy_SetTarget(hunters, mkr_crossroads)
	end
end

function Hunting_Intel()
	if b_frenchHuntersLaunched == false then 
		b_frenchHuntersLaunched = true
		Util_StartIntel(EVENTS.PlayerUnits_Harassed)	
	end
end

function RovingLastPosition()
	if SGroup_CountSpawned(sg_french_huntingarmy) > 0 then
		roving_LastPos = Util_GetPosition(sg_french_huntingarmy)
	end
end
	

