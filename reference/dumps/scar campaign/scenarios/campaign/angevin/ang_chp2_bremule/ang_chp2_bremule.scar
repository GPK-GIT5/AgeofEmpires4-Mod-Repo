end

function Mission_SetRestrictions()	-- set up any restrictions (i.e. locking out units, etc) in here
	
	Player_SetSquadProductionAvailability(player1, SBP.ENGLISH.UNIT_TRADE_CART_ENG, ITEM_REMOVED)
	
	Player_SetEntityProductionAvailability(player2, EBP.FRENCH.BUILDING_TECH_UNIT_RANGED_CONTROL_FRE, ITEM_UNLOCKED)

end

function Mission_Preset()	-- any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)
		
	--Player Upgrades
	Player_GetAll(player1)
	EGroup_Filter(eg_allentities, EBP.ENGLISH.BUILDING_DEFENSE_OUTPOST_ENG, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)

	
	-- set music race to french
	Sound_SetMusicRaceCode("french")
		
	FrenchAdvance_InitObjectives()
	DefeatTheFrench_InitObjectives()
	Recapture_InitObjectives()
	CaptureGrainville_InitObjectives()
	CaptureCressenville_InitObjectives()
	
	if UI_IsXboxControllerUI() then
		FuncKeys_InitObjectives_Xbox()
	else
		FuncKeys_InitObjectives()
	end

	EGroup_SetInvulnerable(eg_burningbarn, 0.5, -1)
	EGroup_SetInvulnerable(eg_farm_burn01, 0.25, -1)
	EGroup_SetInvulnerable(eg_farm_burn02, 0.25, -1)
	
	-- Set up AI cached paths between specific markers to aid AI pathfinding to
	-- detect and break through blocking walls.
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(player2, mkr_fleury_formup, Util_GetPosition(mkr_village_grainville), 5.0)
end

-- This is triggered after the intro, just as control is passed to the player
function Mission_Start()
	
	----Start the intro camera
	--Util_StartIntel(EVENTS.Intro)
	
	VillagerSetup()	
	Objective_Start(OBJ_FrenchAdvance)
	-- start the opening objectives (if you're using ObjectiveTable style objectives)
	
	cressenville_EntityTable = Build_LocationTable(eg_village_cressenville)
	grainville_EntityTable = Build_LocationTable(eg_village_grainville)
		
	Rule_AddInterval(PlayerDeath, 1)

	--extra wood for rams	
	Action_SetResources_Do({ player = player2, resources = { food = 99999, wood = 99999, stone = 99999, gold = 99999 } })
	FOW_PlayerRevealArea(player2, Marker_GetPosition(mkr_village_grainville), Marker_GetProximityRadius(mkr_village_grainville), -1)
end

