function AudOnFromPoint(player, pos, audString)
	local size = ""
	
	SGroup_Clear(sg_temp)
	
	Player_GetAllSquadsNearMarker(player, sg_temp, pos, 50)
	
	unitCount = SGroup_CountSpawned(sg_temp)
	
	if unitCount <= 5 then
		return
	else
		if unitCount > 5 and unitCount <= 10 then
			size = "SMALL"
		elseif unitCount > 10 and unitCount <= 20 then
			size = "MEDIUM"
		else
			size = "LARGE"
		end
		Sound_PlayOnSquad(_G[audString..size], sg_temp)
	end
end

function Louis_Weakened()
	if SGroup_GetAvgHealth(g_leaderLouis.sgroup) <= 0.15 then
		Rule_RemoveMe()
		Modify_WeaponDamage(g_leaderLouis.sgroup, "hardpoint_1", 0.1)
		Entity_SetTargetingType(Squad_GetFirstEntity(SGroup_GetSquadAt(g_leaderLouis.sgroup, 1)), Targeting_None)
		--SGroup_RemoveAbility(g_leaderLouis.sgroup, BP_GetAbilityBlueprint("general_aura_combat"))
		Player_SetAbilityAvailability(player2, BP_GetAbilityBlueprint("general_aura_combat"), ITEM_REMOVED)
	end
end

