--Spawns some attackers to lie in wait at the top of the switchback hill
function AmbushSpawn() --Spawns a defense group to wait at the top of the switchback and jump the player army.
	local moduleData = 
		{
			descriptor = "French_HillAmbush",
			
			type = "RovingArmy",
			player = player2,
			sgroup = sg_french_ambush,
			onDeathDissolve = true,
			targetingType = ARMY_TARGETING_DISCARD,
			targets = {	mkr_hill_ambush,},
		}
	
	local units = 
		{
			{ type = "scar_archer", numSquads = (12*t_difficulty.invasionScale)*t_difficulty.matchUpSimplify.ranged},
			{ type = "scar_spearman", numSquads = (12*t_difficulty.invasionScale)*t_difficulty.matchUpSimplify.infantry},
		}
	
	local myNewModule = RovingArmy_Init(moduleData)
	SpawnUnitsToModule(units, myNewModule, Siege_LaunchPoint()) 
	Rule_EnterProximity(AmbushCamp, ANY, sg_french_ambush, mkr_hill_ambush, 3, false, {})
end

