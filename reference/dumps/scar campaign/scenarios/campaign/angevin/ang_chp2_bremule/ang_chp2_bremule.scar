--Defines the game over conditions
function GameOver()
	Player_GetAll(player1)
	EGroup_Filter(eg_allentities,"town_center", FILTER_KEEP)
	local i_townCenterCount = EGroup_Count(eg_allentities)
	
	if i_townCenterCount <= 0 then
		Mission_Fail()
	else
		return false
	end
end

function Unusual_Discovery()
	if Player_CanSeeSGroup(player1, sg_lupin, ANY) then
		Rule_RemoveMe()
		Modify_UnitSpeed(sg_lupin, 1.25)
		Modify_EntityMaxHealth(sg_lupin, 5, MUT_Multiplication)
		Cmd_MoveToAndDestroy(sg_lupin, mkr_lupin)
	end
end

function Discovery_Result()
	if SGroup_CountSpawned(sg_lupin) < 1 then
		Rule_RemoveMe()
		UnitEntry_DeploySquads(player2, sg_lupin, {sbp = SBP.GAIA.GAIA_HUNTABLE_WOLF, numSquads = 1}, mkr_lupin_spawn)
		Modify_UnitSpeed(sg_lupin, 1.5)
		Modify_EntityMaxHealth(sg_lupin, 5, MUT_Multiplication)
	end
end