--Creates a new name for a scout group
function NewScoutsDescriptor()
	local myreturnstring = "French_Scout_"..g_frenchScoutIndex
	return myreturnstring
end

--Spins up a new scout group
function NewScoutGroup()
	for index, camp in pairs(t_difficulty.t_frenchScoutCamps) do
		eg_scoutcamps = EGroup_CreateIfNotFound("eg_scoutcamps")
		sg_frenchscouts = SGroup_CreateIfNotFound("sg_frenchscouts")
		if Player_CanSeePosition(player1, Util_GetPosition(camp)) ~= true then
			Util_CreateEntities(player2, eg_scoutcamps, EBP.FRENCH.BUILDING_UNIT_CAVALRY_CONTROL_FRE, PositionWithOffset(Util_GetPosition(camp), 0, -12), 1, nil, true, false, true)
			Util_CreateEntities(player2, eg_blah, BP_GetEntityBlueprint("military_tent_a_eng"), PositionWithOffset(Util_GetPosition(camp), 4, 0), 1, nil, true, false, true)
			Util_CreateEntities(player2, eg_blah, BP_GetEntityBlueprint("ang_chp2_bremule_camp_a"), camp, 1, nil, true, true, true)
			g_frenchScoutIndex = g_frenchScoutIndex or 1
			local moduleData = {
				descriptor = NewScoutsDescriptor(), 				
				type = "RovingArmy",
				player = player2,
				
				--attackMove = false,
				targetingType = ARMY_TARGETING_RANDOM,
				onDeathFunction = Delay_ScoutSpawn,
				targets = {
					mkr_crossroads,
					mkr_french_army_spawn,
					mkr_scout_waypoint_1,
					mkr_scout_waypoint_2,
					mkr_scout_waypoint_3,
					mkr_scout_waypoint_4,
					mkr_scout_waypoint_5,
					mkr_scout_waypoint_6,
					mkr_scout_waypoint_7,
					mkr_scout_waypoint_8,
				},
			}
			
			local myNewModule = RovingArmy_Init(moduleData)
			local units = {{ type = "scar_scout", numSquads = 1, sgroup = sg_frenchscouts },}
			
			SpawnUnitsToModule(units, myNewModule, mkr_french_army_spawn)
			g_frenchScoutIndex = g_frenchScoutIndex+1
		end
	end
end

function Delay_ScoutSpawn()
	Rule_AddOneShot(NewSingleScout, 8)
end

--If scout spawning is still active this spins up a new scout on the death of a previous scout
function NewSingleScout()
	if b_endGame == false and SGroup_CountSpawned(sg_frenchscouts) <= EGroup_CountSpawned(eg_scoutcamps) then
		g_frenchScoutIndex = g_frenchScoutIndex or 1
		local moduleData = {
			descriptor = NewScoutsDescriptor(), 				
			type = "RovingArmy",
			player = player2,
			withdrawThreshold = 0,
			--attackMove = false,
			targetingType = ARMY_TARGETING_RANDOM,
			onDeathFunction = Delay_ScoutSpawn,
			targets = {
				mkr_crossroads,
				mkr_french_army_spawn,
				mkr_scout_waypoint_1,
				mkr_scout_waypoint_2,
				mkr_scout_waypoint_3,
				mkr_scout_waypoint_4,
				mkr_scout_waypoint_5,
				mkr_scout_waypoint_6,
				mkr_scout_waypoint_7,
				mkr_scout_waypoint_8,
			},
		}
		
		local myNewModule = RovingArmy_Init(moduleData)
		local units = {{ type = "scar_scout", numSquads = 1, sgroup = sg_frenchscouts },}
		
		SpawnUnitsToModule(units, myNewModule, Util_GetPosition(EGroup_GetRandomSpawnedEntity(eg_scoutcamps)))
		g_frenchScoutIndex = g_frenchScoutIndex+1
	end
end

