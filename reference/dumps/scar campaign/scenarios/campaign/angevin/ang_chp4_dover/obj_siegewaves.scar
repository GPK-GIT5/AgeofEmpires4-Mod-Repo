function Dover_InitOutro()
	
	sg_eng_outroarchers_cheer = SGroup_CreateIfNotFound("sg_eng_outroarchers_cheer")
	sg_eng_outroarchers1_cheer = SGroup_CreateIfNotFound("sg_eng_outroarchers1_cheer")
	sg_eng_outroarchers2_cheer = SGroup_CreateIfNotFound("sg_eng_outroarchers2_cheer")
	sg_eng_willikins_archers_cheer = SGroup_CreateIfNotFound("sg_eng_willikins_archers_cheer")
	sg_eng_willikins_archers_cheer2 = SGroup_CreateIfNotFound("sg_eng_willikins_archers_cheer2")
	sg_eng_outro01 = SGroup_CreateIfNotFound("sg_eng_outro01")
	sg_eng_outro02 = SGroup_CreateIfNotFound("sg_eng_outro02")
	sg_eng_outro03 = SGroup_CreateIfNotFound("sg_eng_outro03")
	sg_eng_outro04 = SGroup_CreateIfNotFound("sg_eng_outro04")
	
	local unitList = {
		{ type = "scar_horseman", 		numSquads = 5, spawn = mkr_enemyspawn1, },
		{ type = "scar_spearman", 		numSquads = 5, spawn = mkr_enemyspawn2, },
		{ type = "scar_manatarms", 		numSquads = 6, spawn = mkr_enemyspawn3, },
		{ type = "scar_archer", 		numSquads = 4, spawn = mkr_enemyspawn5, },
		{ type = "scar_crossbowman",	numSquads = 6, spawn = mkr_enemyspawn7, },
		{ type = "scar_archer", 		numSquads = 5, spawn = mkr_enemyspawn8, },
	}
	
	UnitEntry_DeploySquads(g_playerFrench, sg_fre_outro1, unitList, mkr_enemyspawn1 )
	Cmd_FormationMove(sg_fre_outro1, mkr_enemyretreat)

	
	SGroup_Destroy(sg_local_willikin)
	SGroup_Destroy(sg_local_archer_north)
	SGroup_Destroy(sg_local_archer_dover)
	SGroup_Destroy(sg_local_archer_west)
	Player_SetRelationship(g_playerOutro, g_playerFrench, R_ALLY)
	UnitEntry_DeploySquads(g_playerNorman, sg_eng_outroWillikin, { sbp = BP_GetSquadBlueprint("unit_willikin_cmp_eng"), numSquads = 1  }, mkr_willikinspawn1 )
	UnitEntry_DeploySquads(g_playerOutro, sg_eng_outroarchers_cheer, { type = "scar_spearman", numSquads = 4, }, mkr_outro_archers_cheer )
	UnitEntry_DeploySquads(g_playerOutro, sg_eng_outroarchers2_cheer, { type = "scar_archer", numSquads = 3, }, mkr_outro_archers2_cheer )
	UnitEntry_DeploySquads(g_playerOutro, sg_eng_outroarchers1_cheer, { type = "scar_crossbowman", numSquads = 3, }, mkr_outro_archers1_cheer )
	UnitEntry_DeploySquads(g_playerNorman, sg_eng_willikins_archers_cheer, { type = "scar_archer", numSquads = 4, }, mkr_willikins_archers_outro )
	UnitEntry_DeploySquads(g_playerOutro, sg_eng_willikins_archers_cheer2, { type = "scar_archer", numSquads = 12, }, mkr_willikins_archerscheer_outro )
	
	Cmd_HoldPosition(sg_eng_outroWillikin)
	Cmd_HoldPosition(sg_eng_outroarchers2_cheer)
	Cmd_HoldPosition(sg_eng_willikins_archers_cheer)
	Cmd_HoldPosition(sg_eng_willikins_archers_cheer2)
	
end