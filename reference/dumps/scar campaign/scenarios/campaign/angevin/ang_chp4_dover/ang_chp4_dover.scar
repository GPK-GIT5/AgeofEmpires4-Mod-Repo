	Rule_AddOneShot(Dover_AssignStartingUnits, 15)
	
	SGroup_AddGroups(sg_fre_introattack, {
			sg_fre_introattackmanatarms, 
			sg_fre_introattackspearman, 
			sg_fre_introattackarchers, 
			sg_fre_introdefendnorth1,
			sg_fre_introdefendnorth2
	})
	
	introKillCount = SGroup_Count(sg_fre_introattackmanatarms) + SGroup_Count(sg_fre_introattackspearman)
	
	Modify_SquadMaxHealth(sg_fre_introattackmanatarms, 0.5)
	Modify_SquadMaxHealth(sg_fre_introattackspearman, 0.5)
	
	RovingArmy_AddSGroup(MissionOMatic_FindModule("AttackNorth"), sg_fre_introattackmanatarms)
	RovingArmy_AddSGroup(MissionOMatic_FindModule("AttackNorth"), sg_fre_introattackspearman)

end

function Dover_WeakenPalisadeGates()
	
	eg_gate = EGroup_CreateUnique("gate")
	EGroup_Filter(eg_palisade, "palisade_gate", FILTER_REMOVE, eg_gate)
	
	if EGroup_CountSpawned(eg_gate) > 0 then
		EGroup_SetAvgHealth(eg_gate, 0.01)
	end
end

function Dover_InitPlayerUnits()	
	
	for i = 1, 11 do
		local sgroup = SGroup_FromName("sg_eng_intro"..tostring(i))
		UnitEntry_DeploySquads(g_playerNorman, sgroup, { type = "scar_archer", numSquads = 2 }, castle_spawn_west )
	end
	
	for i = 1, 9 do
		local sgroup = SGroup_FromName("sg_eng_intro"..tostring(i+11))
		UnitEntry_DeploySquads(g_playerNorman, sgroup, { type = "scar_archer", numSquads = 2 }, castle_spawn_east )
	end

	UnitEntry_DeploySquads(g_playerNorman, sg_eng_introcav, { type = "scar_horseman", numSquads = 10 }, castle_army_cav )
	
	if Game_GetSPDifficulty() == GD_EASY then
		UnitEntry_DeploySquads(g_playerNorman, nil, { type = "scar_villager", numSquads = 4 }, mkr_castle_farmers )
	end
	
	Cmd_FormationMove(sg_fre_intro10, mkr_fre_intro_target)
end

function Dover_StartWillikinPhase()
	
	World_EnableSharedLineOfSight(g_playerNorman, g_playerLocals, true)
	
	EGroup_SetPlayerOwner(eg_south_village, player1)
	EGroup_SetPlayerOwner(eg_south_market, player1)
	EGroup_SetPlayerOwner(eg_south_outposts, player1)

	UnitEntry_DeploySquads(g_playerNorman, g_leaderWillikin.sgroup, {{ sbp = BP_GetSquadBlueprint("unit_willikin_cmp_eng"), numSquads = 1  }}, mkr_willikin_start )
	UnitEntry_DeploySquads(g_playerNorman, sg_local_willikin, { type = "scar_archer", numSquads = 4, }, mkr_willikin_army_start )
	
	UnitEntry_DeploySquads(g_playerNorman, sg_eng_trader1, { type = "scar_trade_cart", numSquads = 1, creator = eg_south_market }, mkr_trader_spawn1 )
	UnitEntry_DeploySquads(g_playerNorman, sg_eng_trader2, { type = "scar_trade_cart", numSquads = 1, creator = eg_south_market }, mkr_trader_spawn2 )
	UnitEntry_DeploySquads(g_playerNorman, sg_eng_trader3, { type = "scar_trade_cart", numSquads = 1, creator = eg_south_market }, mkr_trader_spawn3 )
	
	SGroup_AddGroups(sg_eng_traders, {sg_eng_trader1, sg_eng_trader2, sg_eng_trader3})
	
	UnitEntry_DeploySquads(g_playerNorman, sg_eng_willikin_villagers_farm, {{ type = "scar_villager", numSquads = 3 }}, mkr_willikin_villagers_food )
	UnitEntry_DeploySquads(g_playerNorman, sg_eng_willikin_villagers_wood, {{ type = "scar_villager", numSquads = 4 }}, mkr_willikin_villagers_wood )
	
	Rule_AddOneShot(Dover_MoveWillikinUnits, 1)
	Rule_AddInterval(Dover_CheckWoodVillagerProx, 2)
	
	Dover_ResetCartKillCount()
	
end

function Dover_MoveWillikinUnits()
	
	Cmd_FormationMove(sg_local_willikin, mkr_willikin_army_dest)
	
	Cmd_FormationMove(sg_eng_trader1, mkr_traders_dest)
	Cmd_FormationMove(sg_eng_trader2, mkr_traders_dest)
	Cmd_FormationMove(sg_eng_trader3, mkr_traders_dest)
	
	Cmd_Move(g_leaderWillikin.sgroup, mkr_willikin_dest)
	
	AssignVillagersToFarms(sg_eng_willikin_villagers_farm)
	Cmd_FormationMove(sg_eng_willikin_villagers_wood, mkr_wood_dest)
end

function Dover_CheckWoodVillagerProx()
	
	if Prox_AreSquadsNearMarker(sg_eng_willikin_villagers_wood, mkr_wood_dest, ANY, 15) then
		AssignVillagersToWood(sg_eng_willikin_villagers_wood)
		Rule_RemoveMe()
	end
end

function Dover_AssignStartingUnits()
	Defend_AddSGroup(MissionOMatic_FindModule("SiegeNorth1"), sg_fre_introdefendmanatarms)
	Defend_AddSGroup(MissionOMatic_FindModule("SiegeNorth2"), sg_fre_introdefendspearman)
	Defend_AddSGroup(MissionOMatic_FindModule("SiegeNorth1"), sg_fre_introdefendarchers)
	Defend_AddSGroup(MissionOMatic_FindModule("SiegeNorth2"), sg_fre_introdefendmangonel)
	Defend_AddSGroup(MissionOMatic_FindModule("SiegeNorth2"), sg_fre_intro1,  true)
	Defend_AddSGroup(MissionOMatic_FindModule("SiegeNorth2"), sg_fre_intro2,  true)
	Defend_AddSGroup(MissionOMatic_FindModule("SiegeNorth1"), sg_fre_intro3,  true)
	Defend_AddSGroup(MissionOMatic_FindModule("SiegeNorth1"), sg_fre_intro4,  true)
	Defend_AddSGroup(MissionOMatic_FindModule("SiegeNorth1"), sg_fre_intro5,  true)
	Defend_AddSGroup(MissionOMatic_FindModule("SiegeNorth2"), sg_fre_intro6,  true)
	Defend_AddSGroup(MissionOMatic_FindModule("SiegeNorth1"), sg_fre_intro7,  true)
	Defend_AddSGroup(MissionOMatic_FindModule("SiegeNorth2"), sg_fre_intro8,  true)
	Defend_AddSGroup(MissionOMatic_FindModule("SiegeNorth2"), sg_fre_intro9,  true)
	Defend_AddSGroup(MissionOMatic_FindModule("SiegeNorth1"), sg_fre_intro10, true)
	Defend_AddSGroup(MissionOMatic_FindModule("SiegeNorth2"), sg_fre_intro11, true)	
end

function Dover_SendWallArchers()
	
	for i = 1, 10 do
		local sg_west = SGroup_FromName("sg_eng_intro"..tostring(i))
		local sg_east = SGroup_FromName("sg_eng_intro"..tostring(i+10))
		local marker_west = Marker_FromName("castle_army_wallswest"..tostring(i), "")
		local marker_east = Marker_FromName("castle_army_wallseast"..tostring(i), "")
		Cmd_FormationMove(sg_west, marker_west)
		Cmd_FormationMove(sg_east, marker_east)
	end
	Cmd_FormationMove(sg_eng_introcav, castle_army_cav3, false)
	
	Cmd_FormationMove(sg_eng_introcav, castle_army_cav_dest, true, false, Util_GetFacingFromDirection(Marker_GetPosition(castle_army_cav_dest), Marker_GetDirection(castle_army_cav_dest)))
	
end

function Dover_WallArchersHoldPosition()
	local sgroups = {
		sg_eng_intro1, 
		sg_eng_intro2, 
		sg_eng_intro3, 
		sg_eng_intro4, 
		sg_eng_intro5, 
		sg_eng_intro6, 
		sg_eng_intro7, 
		sg_eng_intro8, 
		sg_eng_intro9, 
		sg_eng_intro10,
		sg_eng_intro11,
		sg_eng_intro12,
		sg_eng_intro13,
		sg_eng_intro14,
		sg_eng_intro15,
		sg_eng_intro16,
		sg_eng_intro17,
		sg_eng_intro18,
		sg_eng_intro19,
		sg_eng_intro20,
	}
	
	for i,v in ipairs(sgroups) do 
		Cmd_HoldPosition(v, true)
	end
end

function Dover_SendIntroUnits(context, data)
	
	-- Add the others as waypoints
	for index, marker in pairs(data.markerList) do
		
		if scartype(marker) == ST_MARKER then
			if index <= #data.markerList then
				Cmd_FormationMove(data.sgroup, marker, true)
			end
		end
	end
	
	if data.destination ~= nil then
		Cmd_FormationMove(data.sgroup, data.destination, true)
	end
end

function Dover_SpawnWave(table, index, moduleName, sourceMarker, targetMarker)
	if index <= #table then
		SGroup_Clear(sg_temp)
		local options = {dynamicSpawnType = DST_FURTHEST_HIDDEN, destination = targetMarker}
		UnitEntry_DeploySquads(g_playerFrench, sg_temp, table[index], sourceMarker, nil, nil, options)
		Prefab_DoAction(MissionOMatic_FindModule(moduleName), "AddSGroup", sg_temp)
	end
end

function Dover_SpawnRangedSiegeNorth()
	
	local units = { type = t_difficulty.reserve_siegeType, numSquads = 1 }
	SGroup_Clear(sg_temp)
	local options = {dynamicSpawnType = DST_FURTHEST_HIDDEN, destination = french_attack_north}
	UnitEntry_DeploySquads(g_playerFrench, sg_temp, units, mkr_french_reserve, nil, nil, options)
	Prefab_DoAction(MissionOMatic_FindModule("RangedSiegeNorth"), "AddSGroup", sg_temp)
end

function Dover_SpawnRangedSiegeSouth()
	
	local units = { type = t_difficulty.reserve_siegeType, numSquads = 1 }
	SGroup_Clear(sg_temp)
	local options = {dynamicSpawnType = DST_FURTHEST_HIDDEN, destination = french_attack_south}
	UnitEntry_DeploySquads(g_playerFrench, sg_temp, units, french_main_rally, nil, nil, options)
	Prefab_DoAction(MissionOMatic_FindModule("RangedSiegeSouth"), "AddSGroup", sg_temp)
end

function Dover_CheckFrenchCampStatus()
	
	Player_GetAll(player1)
	
	if Prox_AreSquadsNearMarker(sg_allsquads, french_main, ANY, 38) then
		
		if not Objective_IsStarted(OBJ_DestroySiegeCamp) then
			Objective_Start(OBJ_DestroySiegeCamp)
			Rule_RemoveMe()
		end
	end
	
end

function Dover_CheckFailCondition()
	
	if EGroup_IsEmpty(eg_eng_keep) then
		Mission_Fail()
		Rule_RemoveMe()
	end
end