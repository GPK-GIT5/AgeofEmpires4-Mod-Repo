function DestroyTheArcheryRange_Monitor()

	if EGroup_CountSpawned(eg_archery_encampment) == 0 then
		Objective_Complete(SOBJ_DestroyTheArcheryEncampment)
		Rule_RemoveMe()
	end

	
end


function DestroyTheArcheryEncampment_OnComplete()
end


function AttackArchersEncampment_OnComplete()
	Objective_Start(OBJ_AttackInfantryEncampment)
end
