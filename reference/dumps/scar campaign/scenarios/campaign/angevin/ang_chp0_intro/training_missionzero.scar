	)

	
	
	local GoalSequencehighlightMillIcon = Training_GoalSequence(
		goal_sequence_highlightMill, 					-- id
		2, 													-- repeatMax
		2, 													-- remindMax
		MissionZero_MillLessonTrigger, 			-- trigger
		IgnorePredicate_MillBuilt, 												-- ignore
		nil,										 		-- remind
		IgnorePredicate_MillBuilt, 				      		-- bypass
		true, 												-- canRegress
		{GoalSelectVillagerForMill, GoalHighlightMillIcon, GoalPlaceMill}								-- goals
	)
	Training_AddGoalSequence(GoalSequencehighlightMillIcon)
	
	Training_EnableGoalSequenceByID(goal_sequence_highlightMill, true)
	
end

function MissionZero_MillLessonTrigger(goalSequence)
	
	if Timer_GetElapsed(goalSequence.timerID) >= g_training_timers.short then
		goalSequence.goals[1].key = MissionZero_PickConvenientVillager()
		goalSequence.goals[2].key = Cardinal_ConvertTypeToEntityBlueprint("mill", player1)
		goalSequence.goals[3].key = Util_GetPosition(mkr_mill_hint) 
		return true
	end
end

function Predicate_MillPlaced(goal)
	if (g_training_log.phase == "issued phase") and (g_training_log.BP == 	EBP.ENGLISH.BUILDING_ECON_FOOD_CONTROL_ENG) then
		return true
	end
end

function IgnorePredicate_MillBuilt(goalSequence)
	
	if Player_IsConstructingEntity("mill") or Objective_IsComplete(SOBJ_BuildMill) then
		Training_EndGoalSequence(goalSequence, true)
		return true
	else
		Player_GetAll(player1)
		EGroup_Filter(eg_allentities, "mill", FILTER_KEEP)
		if EGroup_Count(eg_allentities) > 0 then
			Training_EndGoalSequence(goalSequence, true)
			return true
		end
	end
	
	return false
end

