	return Objective_IsComplete(SOBJ_AgeUpCastle)
	
end

function IgnorePredicate_AgeUpCastleBuilt(goalSequence)
	
	if castleAgeStartedConstruction then --Objective_IsComplete(SOBJ_AgeUpCastle) then
		Training_EndGoalSequence(goalSequence, true)
		return true
	end
	
	return false
end

---------------------------------------------------------
---------------TUTORIAL HELPER FUNCTIONS----------------
---------------------------------------------------------


--COMMON--

function MissionZero_Predicate_VillagerSelected(goal)
	--print("MissionZero_Predicate_VillagerSelected")
	
	return Squad_IsSelected("scar_villager")

end




function MissionZero_TrainingContructionCallback(blueprint, phase, queueCount)
	
		
	if phase == TP_Position then
		g_training_log.phase = "position phase"
		g_training_log.BP = blueprint
		g_training_log.blueprint_name = BP_GetName(blueprint)
	elseif phase == TP_Facing then
		g_training_log.phase = "facing phase"
		g_training_log.BP = blueprint
		g_training_log.blueprint_name = BP_GetName(blueprint)
	elseif phase == TP_Issued then
		g_training_log.phase = "issued phase"
		g_training_log.BP = blueprint
		g_training_log.blueprint_name = BP_GetName(blueprint)
	elseif phase == TP_Cancelled then
		g_training_log.phase = "cancelled phase"
		g_training_log.BP = "none"
		g_training_log.blueprint_name = "none"
	else
		g_training_log.phase = "unknown phase"
		g_training_log.BP = blueprint
		g_training_log.blueprint_name = BP_GetName(blueprint)
	end
	
	--if Misc_IsCommandLineOptionSet("dev") then
		
		--view (g_training_log)
		
	--end
	
end

function MissionZero_PickConvenientVillager(mustBeIdle)
	
	mustBeIdle = mustBeIdle or false
	local bestSquad = nil
	
	Player_GetAll(player1)
	SGroup_Filter (sg_allsquads, "scar_villager", FILTER_KEEP)
	
	if mustBeIdle then
		--filter for idle only
	end
	
	
	for i = 1, SGroup_Count(sg_allsquads) do
		local squad = SGroup_GetSquadAt(sg_allsquads, i)
		local isIdle =  Squad_IsIdle(squad)
		local isOnScreen = Misc_IsSquadOnScreen(squad, 1)
		if isIdle and isOnScreen then
			return squad
		elseif isIdle then
			bestSquad = squad
		elseif isOnScreen and not mustBeIdle then
			bestSquad = bestSquad or squad
		end
	end
	
	return bestSquad	
	
end


-- this function returns true if the player is in the placing modal for constructing the ebp defined as the goal's key
function Predicate_KeyEntityBeingPlaced (goal)
	--print("Predicate_KeyEntityBeingPlaced")
	if (g_training_log.phase == "position phase") and (g_training_log.BP == goal.key) then
		
		return true
	else
		--view (goal)
		return false
	end

end

function Predicate_UserHasSelectedTC(goal)
	
	return Entity_IsSelected("town_center")
	
end


function MissionZero_ObjectiveIsActive (objective)
	
	return Objective_IsStarted(objective) and not Objective_IsComplete(objective)
	
end



function Entity_IsSelected(entityType)
	
	local localPlayer = Game_GetLocalPlayer()
	local eg_currentSelection = EGroup_CreateIfNotFound("eg_currentSelection")
	Misc_GetSelectedEntities(eg_currentSelection,false)
	
	if scartype(entityType) == ST_STRING then
		for i = 1, EGroup_Count(eg_currentSelection) do
		local entity = EGroup_GetEntityAt(eg_currentSelection, i)
			if entity ~= nil and Entity_IsOfType(entity, entityType) then
				return true
			end
		end
	elseif scartype(entityType) == ST_ENTITY then
		for i = 1, EGroup_Count(eg_currentSelection) do
		local entity = EGroup_GetEntityAt(eg_currentSelection, i)
			if entity ~= nil and entity == entityType then
				return true
			end
		end
	else
		assert(false, "entityType: "..entityType.." is of unknown type. Must be a string or an entity.")
	end
	
	return false
end

function Squad_IsSelected(squadType)
	
	local localPlayer = Game_GetLocalPlayer()
	local sg_currentSelection = SGroup_CreateIfNotFound("sg_currentSelection")
	Misc_GetSelectedSquads(sg_currentSelection, false)
	
	if scartype(squadType) == ST_STRING then
		for i = 1, SGroup_Count(sg_currentSelection) do
		local squad = SGroup_GetSquadAt(sg_currentSelection, i)
			if squad ~= nil and Squad_IsOfType(squad, squadType) then
				return true
			end
		end
	elseif scartype(squadType) == ST_SQUAD then
		for i = 1, SGroup_Count(sg_currentSelection) do
		local squad = SGroup_GetSquadAt(sg_currentSelection, i)
			if squad ~= nil and squad == squadType then
				return true
			end
		end
	else
		assert(false, "squadType: "..squadType.." is of unknown type. Must be a string or a squad.")
	end
	
	return false
end

function Player_IsConstructingEntity(string_entityType)
	Player_GetAll(Game_GetLocalPlayer())
	
	-- we only want entities that are in process of being built
	EGroup_FilterUnderConstruction(eg_allentities, FILTER_KEEP)
	
	local _IsType = function(gid, index, eid)
		return Entity_IsOfType(eid, string_entityType)
	end
	
	return EGroup_ForEachAllOrAny(eg_allentities, ANY, _IsType)
end

function Player_IsProducingSquad(string_squadType)
	local localPlayer = Game_GetLocalPlayer()
	Player_GetAll(localPlayer)
	local squadBP = Cardinal_ConvertTypeToSquadBlueprint(string_squadType, localPlayer)
	
	local _IsProducingType = function(gid, index, eid)
		return Entity_IsProducingSquad(eid, squadBP)
	end
	
	return EGroup_ForEachAllOrAny(eg_allentities, ANY, _IsProducingType)
	
end


