		{
			ID = "SelectVillagerForPopCap",					-- unique ID string
			Message = "$11199555", 							-- LOCID of text to display
			DataTemplate="LeftClickTrainingDataTemplate",	-- LeftClickTrainingDataTemplate, GenericTrainingDataTemplate, RightClickTrainingDataTemplate
		},
		MissionZero_Predicate_VillagerSelected							-- function that returns true to complete this goal
	)

	local GoalHighlightHouseIconForPopCap = Training_Goal(
		"PBG", 
		{
			ID = "HouseHighlightForPopCap",
			Message= "$11199556", --"House
			DataTemplate="LeftClickTrainingDataTemplate",
		},
		Predicate_KeyEntityBeingPlaced
	)
	
	local GoalPlaceHouseForPopCap = Training_Goal(
		"Cursor",											-- target type: "Squad", "Entity", "PBG" (for buttton), "Position"
		{
			ID = "PlaceHouseForPopCap",					-- unique ID string
			Message = "$11180975", 							-- LOCID of text to display
			DataTemplate="LeftClickTrainingDataTemplate",	-- LeftClickTrainingDataTemplate, GenericTrainingDataTemplate, RightClickTrainingDataTemplate
		},
		Predicate_HousePlaced							-- function that returns true to complete this goal
	)
			
	local GoalSequencePopCap = Training_GoalSequence(
		goal_sequence_popcap, 								-- id
		2, 													-- repeatMax
		2, 													-- remindMax
		MissionZero_PopCapTrigger, 			-- trigger
		nil, 												-- ignore
		nil,										 		-- remind
		nil, 				        -- bypass
		true, 												-- canRegress
		{GoalSelectVillagerForPopCap, GoalHighlightHouseIconForPopCap, GoalPlaceHouseForPopCap  }										-- goals
	)
	Training_AddGoalSequence(GoalSequencePopCap)
	
	Training_EnableGoalSequenceByID(goal_sequence_popcap, true)
	
end


function MissionZero_PopCapTrigger(goalSequence)
	if Timer_GetElapsed(goalSequence.timerID) >= g_training_timers.very_short and Player_GetPopulationPercentage(player1) >= 0.9 then

		-- if we're at 200 pop just abort 
		if Player_GetCurrentPopulationCap(player1, CT_Personnel) >= 200 then
			print("MissionZero_PopCapTrigger aborting. Max pop is 200.")
			Training_EndGoalSequence(goalSequence, false)
			return false
		end
		
		Player_GetAll(player1)
		EGroup_Filter(eg_allentities, EBP.ENGLISH.BUILDING_HOUSE_CONTROL_ENG, FILTER_KEEP)
		EGroup_FilterUnderConstruction(eg_allentities, FILTER_KEEP)
	
		if EGroup_Count(eg_allentities) > 0 then
			return false
		end

		
		goalSequence.goals[1].key = MissionZero_PickConvenientVillager()
		goalSequence.goals[2].key = EBP.ENGLISH.BUILDING_HOUSE_CONTROL_ENG
		--goalSequence.goals[4].key = EBP.ENGLISH.BUILDING_HOUSE_CONTROL_ENG
		return true
	end
end

function Predicate_HasEnoughPopCap(goal)
	
	if Player_GetCurrentPopulationCap(player1, CT_Personnel) == 200 then
		return true
	else
		if Player_GetPopulationPercentage(player1) < 1 then
			return true
		end
	end
end

function IgnorePredicate_PopCapLessonLearned(goalSequence)
	
	if Player_GetCurrentPopulationCap (player1, CT_Personnel) >= 70 then
		Training_EndGoalSequence(goalSequence, true)
		return true
	end	
end

