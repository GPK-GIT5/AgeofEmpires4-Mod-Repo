	if Timer_GetElapsed(goalSequence.timerID) >= g_training_timers.short then
		goalSequence.goals[1].key = MissionZero_PickConvenientVillager()
		goalSequence.goals[2].key = EBP.ENGLISH.BUILDING_HOUSE_CONTROL_ENG

		return true
	end
end

function Predicate_HousePlaced(goal)
	if (g_training_log.phase == "issued phase") and (g_training_log.BP == 	EBP.ENGLISH.BUILDING_HOUSE_CONTROL_ENG) then
		return true
	else
		-- the above callback check doesn't handle queued construction very well, 
		-- so this serves as a fallback in that case
		return Player_IsConstructingEntity("house")
	end
end


function IgnorePredicate_HousesBuilt(goalSequence)
	
	if Objective_IsComplete(SOBJ_BuildHouses) then
		Training_EndGoalSequence(goalSequence, true)
		return true
	elseif Player_IsConstructingEntity("house")  then
		return true
	else
		Player_GetAll(player1)
		EGroup_Filter(eg_allentities, "house", FILTER_KEEP)
		if EGroup_Count(eg_allentities) > 2 then
			Training_EndGoalSequence(goalSequence, true)
			return true
		end
	end
	
	return false
end

