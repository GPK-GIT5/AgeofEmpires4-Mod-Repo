-- -- LESSON: CONTROL GROUPS
-----

function Tutorials_MissionZero_ControlGroups()
	
	-- Create squad/entity groups if they do not exist

	
	local goal_sequence_ControlGroups = "ControlGroupsSequence"
	
	-- step 1 select all your spearmen

	local GoalSpearmanSelected = Training_Goal(
		"Squad", 
		{
			ID = "SelectSpearmen",
			Message ="$11195535", -- double click spearmen
			DataTemplate = "LeftClickTrainingDataTemplate",
		}, 
		Predicate_SpearmenSelected
	)	
	
	-- step 2 place in control group
	
	local GoalPutInControlGroup = Training_Goal(
		"Cursor", 
		{
			ID = "ControlGroupCreate",
			Message= "$11184867", 
			DataTemplate="GenericTrainingDataTemplate",
		}, 
		Predicate_ControlGroup1IsPopulated
	)

		-- step 3 select control group
	
	local GoalSelectControlGroup = Training_Goal(
		"PBG", 
		{
			ID = "ControlGroupSelect",
			Message= "$11191463", 
			DataTemplate="LeftClickTrainingDataTemplate",
		}, 
		Predicate_ControlGroup1Clicked
	)


	local GoalSequenceControlGroups = Training_GoalSequence(
		goal_sequence_ControlGroups, 					-- id
		2, 													-- repeatMax
		2, 													-- remindMax
		MissionZero_ControlGroups_Trigger, 			-- trigger
		IgnorePredicate_ControlGroupsLessonComplete, 			-- ignore							
		nil,										 		-- remind
		nil, 				      		-- bypass
		true, 												-- canRegress
		{GoalSpearmanSelected, GoalPutInControlGroup, GoalSelectControlGroup}								-- goals
	)
	Training_AddGoalSequence(GoalSequenceControlGroups)
	
	Training_EnableGoalSequenceByID(goal_sequence_ControlGroups, true)
	
end



function MissionZero_ControlGroups_Trigger(goalSequence)
	
	print ("MissionZero_ControlGroups_Trigger check")
	
	
	-- first we check if the player already has control groups
	-- if so we will shortcircuit this whole thing
	-- NOTE: This is doing the job usually done by the bypass function,
	-- because the condition to check for (if the player has any control groups)
	-- becomes true midway throught he lesson (so the standard bypass would break the lesson flow)
	
	if MissionZero_DoesUserHaveControlGroup() == true then
		Training_EndGoalSequence(goalSequence, true)
		return
	end

	
	-- if we pass the above check, then we wait for the player to have their at least a few spearmen on screen
	-- and a bit of time to pass
	
	if Timer_GetElapsed(goalSequence.timerID) >= g_training_timers.short then
		
		Player_GetAll(player1)
		SGroup_Filter(sg_allsquads, "scar_spearman", FILTER_KEEP)
		
		local n_OnScreen = 0
		local targetSquad = nil
		local function _CountOnScreen(group, index, squad)
			if Misc_IsSquadOnScreen(squad, 0.85) then
				n_OnScreen = n_OnScreen + 1
				if targetSquad == nil then
					targetSquad = squad
				end
			end
		end
		
		if SGroup_CountSpawned(sg_allsquads) > 0 then
			SGroup_ForEach(sg_allsquads, _CountOnScreen)
			
			if n_OnScreen > 2 then
				goalSequence.goals[1].key = targetSquad
				goalSequence.goals[3].key = "ControlGroupButton1Tag"
				-- Create a callback that listens for control group selection
				UI_SetControlGroupSelectedCallback(MissionZero_ControlGroupSelectedCallback)
				return true
			end
		end
	end	
	return false
	
end

function MissionZero_ControlGroupSelectedCallback(controlGroupIndex)
	--If control group that was selected was 1
	if controlGroupIndex == 1 then
		user_has_selected_control_group_1 = true
		--Removes callback that listens for control group selection (perf)
		UI_ClearControlGroupSelectedCallback()		
	end
	
end



function Predicate_ControlGroup1IsPopulated(goal)
	return MissionZero_DoesUserHaveControlGroup(1)
end

function Predicate_ControlGroup1Clicked(goal)
	return user_has_selected_control_group_1
end

function IgnorePredicate_ControlGroupsLessonComplete(goalSequence)
	if CampaignTraining_TimeoutIgnorePredicate(goalSequence) then
		return true
	end
	if user_has_selected_control_group_1 then
		Training_EndGoalSequence(goalSequence, true)
	end
	
end

-- helper function that does a simple check to see if a control group (or any control group) exists
function MissionZero_DoesUserHaveControlGroup(index)
	
	
	SGroup_Clear(sg_control_group)
	EGroup_Clear(eg_control_group)
	
	
	local count = 0
	-- if index isn't nil we check the specific group
	if index ~=nil then
		Misc_GetControlGroupContents(index,sg_control_group, eg_control_group)
		count = SGroup_Count(sg_control_group) + EGroup_Count(eg_control_group)
	else
		-- if it is nil we iterate through all ten possible groups
		for i = 0,9 do
			Misc_GetControlGroupContents(i, sg_control_group, eg_control_group)
			count = count + SGroup_Count(sg_control_group) + EGroup_Count(eg_control_group)
		end
	end
		
	return count > 0
end



