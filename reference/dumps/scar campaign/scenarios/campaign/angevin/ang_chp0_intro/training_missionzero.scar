		Rule_AddEGroupEvent(ListenForRallyPoint, eg_stablesForTutorial, GE_EntityCommandIssued)
	end
	-- step 1 : select all Stables
	local GoalSelectStables = Training_Goal(
		"Entity",
		{
			ID = "SelectAllStables",
			Message= 11197313, --"select stable
			DataTemplate="LeftClickTrainingDataTemplate",
		},
		UserHasStablesSelected
		)
	
	-- step 2 : set rally point
	local GoalSetRally = Training_Goal(
		"Position",
		{
			ID = "SetRallyPoint",
			Message= 11197314, --"set rally
			DataTemplate="RightClickTrainingDataTemplate",
		},
		UserHasSetRallyPoint
		)
	
	-- step 3: queue horsemen
	local GoalQueueHorsemen = Training_Goal(
		"PBG",
		{
			ID = "QueueHorsemen",
			Message= 11197315, --build horsemen
			DataTemplate="LeftClickTrainingDataTemplate",
		},
		UserHasQueuedAcrossStables
		)
	
	
	local GoalSequenceCavalry = Training_GoalSequence(
		goal_sequence_cavalry, --id
		2, 													-- repeatMax
		2, 													-- remindMax
		UserHasStablesOnScreen, 			-- trigger
		IgnoreAllHorsemenBuilt, 												-- ignore
		nil,										 		-- remind
		UserHasQueuedAcrossStables, 				      		-- bypass
		true, 												-- canRegress
		{GoalSelectStables, GoalSetRally, GoalQueueHorsemen}								-- goals
	)
	Training_AddGoalSequence(GoalSequenceCavalry)
	
	Training_EnableGoalSequenceByID(goal_sequence_cavalry, true)

	
end

function UserHasStablesSelected(goal)
	
	return Misc_IsEGroupSelected (eg_stablesForTutorial, ALL)
end

function ListenForRallyPoint (context)
	
	--view(context)
	
	if context.command == CMD_RallyPoint then
		b_rallySet = true
		Rule_RemoveMe()
	end
end

function UserHasSetRallyPoint(goal)
	-- we check both if the rally point is set and the egroup is still selected
	-- so we can properly fallback to the first step if need be
	return b_rallySet and Misc_IsEGroupSelected (eg_stablesForTutorial, ALL)
	
end

function UserHasQueuedAcrossStables(goal)
	
	return EGroup_IsProducingSquads (eg_stablesForTutorial, ALL)
	
end


function UserHasStablesOnScreen(goalSequence)
	
	if EGroup_Count(eg_stablesForTutorial) > 0 then
		
		if Misc_IsEGroupOnScreen(eg_stablesForTutorial, 0.85, ALL) then
			
			goalSequence.goals[1].key = EGroup_GetEntityAt(eg_stablesForTutorial, 1)
			goalSequence.goals[2].key = Util_GetPosition(mkr_training_rally)
			goalSequence.goals[3].key = Cardinal_ConvertTypeToSquadBlueprint("scar_horseman", player1)
			
			return true
			
		end
	end
	
	
end


function IgnoreAllHorsemenBuilt (goalSequence)
	
	if Objective_IsComplete(SOBJ_ProduceHorsemen) then
		
		Training_EndGoalSequence(goalSequence, true)
		
		return true
	end
	
	return false
end


