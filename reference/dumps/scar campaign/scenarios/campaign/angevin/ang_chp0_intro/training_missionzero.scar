-- ENABLING SELECT CORE HINTS

function Disable_CoreTutorials_MinusExceptions()

	local goal_single_selection = "single_selection"
	local goal_move_unit = "move_unit"
	local goal_pan_camera = "pan_camera"
	local goal_bandbox_selection = "bandbox_selection"
	local goal_control_group = "control_group"
	local goal_select_control_group = "select_control_group"
	local goal_attack_action = "attack_action"
	local goal_attack_move = "attack_move"
	local goal_setup_siege = "setup_siege"
	local goal_rotate_camera = "rotate_camera"
	local goal_shift_queue = "shift_queue"
	
	local mzero_training_goals_core_controls =
	{
		--goal_single_selection,
		--goal_move_unit,
		goal_rotate_camera,
		goal_shift_queue,
		--goal_pan_camera,
		goal_bandbox_selection,
		goal_control_group,
		goal_select_control_group,
		goal_attack_action,
		goal_attack_move,
		goal_setup_siege
	}
		
	local goal_gather = "gather"
	local goal_build_villager = "build_villager"
	local goal_build_house = "build_house"
	local goal_build_towards_wonder = "build_towards_wonder"
	local goal_build_wonder = "build_wonder"
	local goal_scout_returns_sheep = "scout_returns_sheep"
	local goal_build_drop_off = "build_drop_off"
	local goal_next_idle = "goal_next_idle"
	local goal_scout_hunts_deer = "goal_scout_hunts_deer"
	local goal_scout_drops_off_deer = "goal_scout_drops_off_deer"
	local goal_build_farm = "goal_build_farm"
	local goal_scout_reveal_fow = "goal_scout_reveal_fow"

	local mzero_training_goals_core_econ =
	{
		goal_gather,
		goal_build_villager,
		goal_build_house,
		goal_build_towards_wonder,
		goal_build_wonder,
		goal_scout_returns_sheep,
		goal_build_drop_off,
		goal_next_idle,
		goal_scout_hunts_deer,
		goal_scout_drops_off_deer,
		goal_build_farm,
		goal_scout_reveal_fow
	}

	for i, goalSequenceID in ipairs(mzero_training_goals_core_controls) do
		Training_EnableGoalSequenceByID(goalSequenceID, false)
	end

	for i, goalSequenceID in ipairs(mzero_training_goals_core_econ) do
		Training_EnableGoalSequenceByID(goalSequenceID, false)
	end
end

-- LESSON: GATHER FOOD

function Tutorials_MissionZero_GatherFood()
	
	local goal_sequence_gatherfood = "GatherFood"
	
	local GoalSelectVillagerForFood = Training_Goal(
		"Squad",											-- target type: "Squad", "Entity", "PBG" (for buttton), "Position"
		{
			ID = "SelectVillagerForFood",					-- unique ID string
			Message = "$11199514", 							-- LOCID of text to display
			DataTemplate="LeftClickTrainingDataTemplate",	-- LeftClickTrainingDataTemplate, GenericTrainingDataTemplate, RightClickTrainingDataTemplate
		},
		MissionZero_Predicate_VillagerSelected							-- function that returns true to complete this goal
	)

	local GoalRightClickOnFood = Training_Goal(
		"Position", 
		{
			ID = "Food",
			Message= "$11199515", 
			DataTemplate="RightClickTrainingDataTemplate",
		},
		Predicate_AVillagerIsGatheringFood
	)
	
	
	local GoalSequenceGatherFood = Training_GoalSequence(
		goal_sequence_gatherfood, 					-- id
		2, 													-- repeatMax
		2, 													-- remindMax
		MissionZero_GatherFoodTrigger, 			-- trigger
		IgnorePredicate_FoodGathered, 												-- ignore
		nil,										 		-- remind
		IgnorePredicate_FoodGathered, 				      		-- bypass
		true, 												-- canRegress
		{GoalSelectVillagerForFood, GoalRightClickOnFood}								-- goals
	)
	Training_AddGoalSequence(GoalSequenceGatherFood)
	
	Training_EnableGoalSequenceByID(goal_sequence_gatherfood, true)
	
end

function MissionZero_GatherFoodTrigger(goalSequence)
	
	if Timer_GetElapsed(goalSequence.timerID) >= g_training_timers.short then
		
		goalSequence.goals[1].key = MissionZero_PickConvenientVillager()
		goalSequence.goals[2].key = Util_GetPosition(mkr_berries_obj) 
		return true
	end

end

function Predicate_AVillagerIsGatheringFood(goal)
	return Player_GetNumGatheringSquads(player1, RT_Food) > 0
end

function IgnorePredicate_FoodGathered(goalSequence)
	if (Player_GetNumGatheringSquads(player1, RT_Food) > 0) or (Player_GetResource(player1, RT_Food) > 250) or (Objective_IsComplete(SOBJ_GatherFood))then
		Training_EndGoalSequence(goalSequence, true)
		return true
	end
end

-- LESSON: BANDBOX
function Tutorials_MissionZero_SelectDragUnits()
	-- Bandbox Select
	local goal_MissionZero_bandbox_selection = "bandbox_selectionMZ"
	
	local MissionZero_bandBoxSelectGoal = Training_Goal(
		"Squad", 
		{
			ID= "MZ_Bandbox", 
			Message= "$11184866", 
			DataTemplate="LeftClickTrainingDataTemplate"
		}, 
		MissionZero_UserHasMultiselected)
	local MissionZero_bandBoxSelectGoalSequence = Training_GoalSequence
		(goal_MissionZero_bandbox_selection,
		2, 
		2, 
		MissionZero_BandboxTrigger,
		MissionZero_UserHasMultiselected, 
		nil, 
		MissionZero_UserHasMultiselected,
		false, 
		{MissionZero_bandBoxSelectGoal})
	Training_AddGoalSequence(MissionZero_bandBoxSelectGoalSequence)
	Training_EnableGoalSequenceByID(goal_MissionZero_bandbox_selection, true)

end

function MissionZero_BandboxTrigger(goalSequence)
	if Timer_GetElapsed(goalSequence.timerID) >= g_training_timers.mid then
		
		local keySquad = nil
		local onScreenCount = 0
		
		Player_GetAll(player1)
		
		if SGroup_Count(sg_allsquads) == 0 then
			return false
		end
				
		local function _findOnScreenAndCount(group, index, squad) 
			if Misc_IsSquadOnScreen(squad, 0.85) then
				onScreenCount = onScreenCount + 1
				if keySquad == nil then
					Player_GetAllSquadsNearMarker(player1, sg_temp, Squad_GetPosition(squad),5)
					if SGroup_Count(sg_temp) > 1 then		
						keySquad = squad
					end
				end
			end
		end
		
		SGroup_ForEach(sg_allsquads, _findOnScreenAndCount)
		
		if keySquad ~= nil and onScreenCount > 1 then
			goalSequence.goals[1].key = keySquad
			return true
		end		
	end
end

function MissionZero_UserHasMultiselected(goal)
	Misc_GetSelectedSquads(sg_temp, false)
	return SGroup_Count (sg_temp) > 1
end


-- LESSON: PRODUCE VILLAGERS

function Tutorials_MissionZero_HighlightVillagers()
	
	local goal_sequence_highlightVillagers = "HighlightVillagersIcon"
	
	local GoalSelectTCforVillagers = Training_Goal(
		"Squad",											-- target type: "Squad", "Entity", "PBG" (for buttton), "Position"
		{
			ID = "SelectTCforVillagers",					-- unique ID string
			Message = "$11199476", 							-- LOCID of text to display
			DataTemplate="LeftClickTrainingDataTemplate",	-- LeftClickTrainingDataTemplate, GenericTrainingDataTemplate, RightClickTrainingDataTemplate
		},
		Predicate_UserHasSelectedTC							-- function that returns true to complete this goal
	)

	local GoalHighlightVillagerIcon = Training_Goal(
		"PBG",											-- target type: "Squad", "Entity", "PBG" (for buttton), "Position"
		{
			ID = "Villagers",					-- unique ID string
			Message = "$11193413", 							-- LOCID of text to display
			DataTemplate="LeftClickTrainingDataTemplate",	-- LeftClickTrainingDataTemplate, GenericTrainingDataTemplate, RightClickTrainingDataTemplate
		},
		Predicate_VillagersBuilt							-- function that returns true to complete this goal
	)

	local GoalSequencehighlightVillagersIcon = Training_GoalSequence(
		goal_sequence_highlightVillagers, 					-- id
		2, 													-- repeatMax
		2, 													-- remindMax
		MissionZero_VillagerLessonTrigger, 			-- trigger
		IgnorePredicate_VillagersBuilt, 												-- ignore
		nil,										 		-- remind
		IgnorePredicate_VillagersBuilt, 				      		-- bypass
		true, 												-- canRegress
		{GoalSelectTCforVillagers, GoalHighlightVillagerIcon}								-- goals
	)
	Training_AddGoalSequence(GoalSequencehighlightVillagersIcon)
	
	Training_EnableGoalSequenceByID(goal_sequence_highlightVillagers, true)
	
end

function MissionZero_VillagerLessonTrigger(goalSequence)
	
	if Timer_GetElapsed(goalSequence.timerID) >= g_training_timers.short then
		goalSequence.goals[1].key = EGroup_GetEntityAt(eg_TC, 1)
		goalSequence.goals[2].key = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", player1) 
		return true
	end	
end


function Predicate_VillagersBuilt(goal)
	
	return Player_IsProducingSquad("scar_villager")
	--return Objective_IsComplete(SOBJ_ProduceVillagers)
	
end

function IgnorePredicate_VillagersBuilt(goalSequence)
	
	if Player_IsProducingSquad("scar_villager") or Objective_IsComplete(SOBJ_ProduceVillagers) then
		Training_EndGoalSequence(goalSequence, true)
		return true
	else
		Player_GetAll(player1)
		if SGroup_Count(sg_allsquads) > 3 then
			Training_EndGoalSequence(goalSequence, true)
			return true
		end
	end
	
	return false
end



-- LESSON: IDLE VILLAGERS

function Tutorials_MissionZero_IdleVillagers()
	
	local goal_sequence_idleVillagers = "MZ_IdleVillagers"
		
	local GoalHighlightIdleButton = Training_Goal(
		"PopulationButton",											-- target type: "Squad", "Entity", "PBG" (for buttton), "Position"
		{
			ID = "HighlightIdle",					-- unique ID string
			Message = "$11199560", 							-- LOCID of text to display
			DataTemplate="LeftClickTrainingDataTemplate",	-- LeftClickTrainingDataTemplate, GenericTrainingDataTemplate, RightClickTrainingDataTemplate
		},
		Predicate_IdleVillagerSelected							-- function that returns true to complete this goal
	)
	
	local GoalAssignIdleToWork = Training_Goal (
		"Cursor",
		{
			ID = "AssignIdle",
			Message = "$11199561",
			DataTemplate= "RightClickTrainingDataTemplate",
		},
		Predicate_SelectedVillagerNotIdle
		)

	
	local GoalSequenceIdleVillagers = Training_GoalSequence(
		goal_sequence_idleVillagers, 					-- id
		2, 													-- repeatMax
		2, 													-- remindMax
		MissionZero_IdleLessonTrigger, 			-- trigger
		nil, 												-- ignore
		nil,										 		-- remind
		nil, 				      		-- bypass
		true, 												-- canRegress
		{GoalHighlightIdleButton, GoalAssignIdleToWork}								-- goals
	)
	Training_AddGoalSequence(GoalSequenceIdleVillagers)
	
	Training_EnableGoalSequenceByID(goal_sequence_idleVillagers, true)
	
end

function MissionZero_IdleLessonTrigger(goalSequence)
		
	if Timer_GetElapsed(goalSequence.timerID) >= g_training_timers.mid then
		
		Player_GetAll(player1)
		SGroup_Filter(sg_allsquads, "scar_villager", FILTER_KEEP)
		
		if SGroup_IsIdle(sg_allsquads, ANY) then		
			goalSequence.goals[1].key = "PopulationButton"
			return true
			
		end
	end
end

function Predicate_IdleVillagerSelected(goal)
	
	-- this first portion short circuits the goal sequence at this stage if all villagers stop being idle without player input
	-- this can occur for villagers building things in a queue as they can briefly go idle between construction targets
	Player_GetAll(player1)
	SGroup_Filter(sg_allsquads, "scar_villager", FILTER_KEEP)
	
	if SGroup_IsIdle(sg_allsquads, ANY) == false then
		--get the right goal sequence
		for i, goalSequence in pairs(_TrainingGoals) do
			if goalSequence.id == "MZ_IdleVillagers" then
				Training_EndGoalSequence(goalSequence, false)
				return
			end
		end
	end
	
	-- if there are still idle villagers in the world, then we continue 
		
	Misc_GetSelectedSquads(sg_temp, false)
	SGroup_Filter(sg_temp, "scar_villager", FILTER_KEEP)
	
	if SGroup_Count(sg_temp) == 0 then
		return false
	elseif SGroup_IsIdle(sg_temp, ANY) then
		return true
	end

end

function Predicate_SelectedVillagerNotIdle(goal)
	Misc_GetSelectedSquads(sg_temp, false)
	SGroup_Filter(sg_temp, "scar_villager", FILTER_KEEP)
	
	if SGroup_IsIdle(sg_temp, ANY) then
		return false
	else
		return true
	end
end

