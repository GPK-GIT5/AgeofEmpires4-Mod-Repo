function MissionZero_AttackLessonTrigger(goalSequence)
	if Timer_GetElapsed(goalSequence.timerID) >= g_training_timers.normal then
		
		Player_GetAll(player1)
		SGroup_Filter(sg_allsquads, "scar_spearman", FILTER_KEEP)
		
		if SGroup_Count(sg_allsquads) == 0 then
			return false
		end
		
		local keySquad = nil
		
		local function _findOnScreen(group, index, squad) 
			if Misc_IsSquadOnScreen(squad, 0.85) and keySquad == nil then
				keySquad = squad
			end
		end
		
		SGroup_ForEach(sg_allsquads, _findOnScreen)
		
		keySquad = keySquad or SGroup_GetSquadAt(sg_allsquads, 1)
		
		goalSequence.goals[1].key = keySquad
		goalSequence.goals[2].key = Util_GetPosition(mkr_closeToGate)
		return true
		
	end
end

function ListenForAttack(context)
	
	if context.command == CMD_Attack or context.command == CMD_AttackForced then
		b_attackOrderIssued = true
		Rule_RemoveMe()
	end
	
end

function Predicate_SpearmanSelected(goal)
	Misc_GetSelectedSquads(sg_currentSelection, false)
	SGroup_Filter(sg_currentSelection, "scar_spearman", FILTER_KEEP)
	return SGroup_CountSpawned (sg_currentSelection) > 0 
	
end

function Predicate_SpearmanAttacking(goal)
	return b_attackOrderIssued	
end


function IgnorePredicate_AttackUsed(goalSequence)
	-- ignore if the attack objective is complete
	if Objective_IsComplete(SOBJ_DestroyThePallisade) then
		return true
		
	-- ignore if the attack objective isn't even running (say because of some skip ahead)
	elseif not Objective_IsStarted(SOBJ_DestroyThePallisade) then
		return true
	
	-- if neither of the above, get all the enemy palisades and return true if one has been damaged or there are none
	else
		Player_GetAll(player2)
		EGroup_Filter(eg_allentities, EBP.FRENCH.BUILDING_DEFENSE_PALISADE_FRE, FILTER_KEEP)
		if EGroup_Count(eg_allentities) == 0 then
			return true
		else
			return EGroup_GetAvgHealth(eg_allentities) < 1
		end
	end
end

-- LESSON: ATTACK-MOVE
----

function Tutorials_MissionZero_AttackMove()
	
	local goal_sequence_AttackMove = "AttackMoveSequence"
	
	--preamble-
	-- this sequence works differently if the player has spearmen in control group 1
	-- so we start by checking that
	
	Misc_GetControlGroupContents(1,sg_control_group, eg_control_group)
	SGroup_Filter(sg_control_group, "scar_spearman", FILTER_KEEP)
	if SGroup_Count(sg_control_group) > 0 then
		control_group_1_has_spearmen = true
	end
	
	local GoalSpearmanSelected = {}
	
	if control_group_1_has_spearmen == true then
		GoalSpearmanSelected = Training_Goal(
			"PBG", 
			{
				ID = "SelectSpearmen",
				Message ="$11201432", -- double click spearmen
				DataTemplate = "LeftClickTrainingDataTemplate",
			}, 
			Predicate_SpearmenSelected
		)
	else
		GoalSpearmanSelected = Training_Goal(
			"Squad", 
			{
				ID = "SelectSpearmen",
				Message ="$11195535", -- double click spearmen
				DataTemplate = "LeftClickTrainingDataTemplate",
			}, 
			Predicate_SpearmenSelected
		)
		
	end
		
	-- step 2 do attack move
	
	local GoalDoAttackMove = Training_Goal(
		"Position", 
		{
			ID = "AttackMove",
			Message= "$11197297", --"Attack Move
			DataTemplate="LeftClickTrainingDataTemplate",
		}, 
		SpearmenAreAttackMoving
	)
	local GoalSequenceSpearmenAttackMove = Training_GoalSequence(
		goal_sequence_AttackMove, 					-- id
		2, 													-- repeatMax
		2, 													-- remindMax
		UserHasSpearmenOnScreen, 			-- trigger
		IgnorePredicate_AttackMoveUsed, 					-- ignore							
		nil,										 		-- remind
		SpearmenAreAttackMoving, 				      		-- bypass
		true, 												-- canRegress
		{GoalSpearmanSelected, GoalDoAttackMove}								-- goals
	)
	Training_AddGoalSequence(GoalSequenceSpearmenAttackMove)
	
	Training_EnableGoalSequenceByID(goal_sequence_AttackMove, true)
	
end

 --Attack Move goal completion criteria
function SpearmenAreAttackMoving(goal)
	Misc_GetSelectedSquads(sg_currentSelection, false)
		
		for i = 1, SGroup_Count(sg_currentSelection) do
			local squad = SGroup_GetSquadAt(sg_currentSelection, i)
			
			if Squad_IsOfType(squad, "scar_spearman") then
			
				if Squad_IsAttackMoving(squad) then 
					
					return true
					
				end
			end
		end
	
	return false
	
end


function UserHasSpearmenOnScreen(goalSequence)
	
	Player_GetAll(player1)
	
	SGroup_Filter(sg_allsquads, "scar_spearman", FILTER_KEEP)
	
	local n_OnScreen = 0
	local targetSquad = nil
	local function _CountOnScreen(group, index, squad)
		if Misc_IsSquadOnScreen(squad, 0.85) then
			n_OnScreen = n_OnScreen + 1
			if targetSquad == nil then
				targetSquad = squad
			end
		end
	end
	
	if SGroup_CountSpawned(sg_allsquads) > 0 then
		SGroup_ForEach(sg_allsquads, _CountOnScreen)
		
		if n_OnScreen > 2 then
			if control_group_1_has_spearmen then
				goalSequence.goals[1].key = "ControlGroupButton1Tag"
			else
				goalSequence.goals[1].key = targetSquad
			end
			goalSequence.goals[2].key = Util_GetPosition(mkr_training_attackMove)
			return true
		end
	end
	
	return false

end

function Predicate_SpearmenSelected(goal)
	-- return true if I have more than 2 spearmen selected
	Misc_GetSelectedSquads(sg_currentSelection, false)
	SGroup_Filter(sg_currentSelection, "scar_spearman", FILTER_KEEP)
	return SGroup_CountSpawned (sg_currentSelection) > 2 

end

function IgnorePredicate_AttackMoveUsed(goalSequence)
	-- remove the hint if the target sentry is fighting (as the hint will be in the way)
	if SGroup_IsUnderAttack(sg_fre_attackMove_scout, ANY, 1) or SGroup_IsDoingAttack(sg_fre_attackMove_scout, ANY, 1) then
		return true
	end
		
	if Objective_IsComplete(SOBJ_AttackMove) then
		Training_EndGoalSequence(goalSequence, true)
		return true
	end
	
	return false
end






