--
-- Rochester 1215 - Capture Village
--

--
-- TO USE THIS TEMPLATE:
-- 1. Decide on a prefix for this objective / section of the mission
-- 2. save this template as a new file in the same directory as your mission script - use "obj_<prefix>.scar" for the name 
-- 3. import this file into your main mission script with import("obj_<prefix>.scar")
-- 4. call the <prefix>_InitObjectives function from inside you main mission script's Mission_SetupVariables function
--

function DestroyRochester_InitObjectives()		-- rename this function to use your prefix for this part of the mission

	OBJ_DestroyRochester = {
	
		Title = "$11175643", --"Destroy Rochester Keep"
		Type = ObjectiveType_Battle,
		PreStart = DestroyRochester_PreStart,
		OnStart = DestroyRochester_OnStart,
		IsComplete = DestroyRochester_IsComplete, --Verify the completion of the objective
		OnComplete = DestroyRochester_OnComplete, --Roll on to next objective
		IsFailed = DestroyRochester_IsFailed,
		OnFail = DestroyRochester_OnFail,
	}
				
	Objective_Register(OBJ_DestroyRochester)

end

--DESTROY ROCHESTER OBJECTIVE--
function DestroyRochester_PreStart()
	Rule_AddEGroupEvent(BesiegeRochester_EntityKilled, eg_rochester_walls_notowers, GE_EntityKilled) --Start watching what gets killed
	Rule_AddEGroupEvent(InnerRochester_EntityKilled, eg_rochester_innerwalls, GE_EntityKilled) 
	Rule_AddEGroupEvent(SiegeCounter_OnDamageReceived, eg_rochester_walls, GE_DamageReceived)
end

function DestroyRochester_OnStart()
	--Mark Rochester Keep & start sending out poke waves	
	Rochester_IconRochester = Objective_AddUIElements(OBJ_DestroyRochester, mkr_keep_orbitcam, true, 11175642, true, 5) --"Rochester Keep"
	--Objective_RemoveUIElements(OBJ_DestroyRochester, Rochester_IconRochester)
	Rule_AddInterval(KeepReveal, 1)
			
	EGroup_SetInvulnerable(eg_thekeep, 0.09)
	
	--Checks if player has spotted attack wave
	Rule_AddInterval(AttackWave_Intel, 1)
	
end

function DestroyRochester_IsComplete()
	
	if EGroup_GetAvgHealth(eg_thekeep) <= 0.15 then
		return true
	else
		return false
	end
end

function DestroyRochester_OnComplete() 	--Play outro event on mission complete
	Music_LockIntensity(MUSIC_TENSE_COMBAT)
	Mission_Complete()
end

function DestroyRochester_IsFailed() 	--See if the player has been wiped out
	Player_GetAll(player1)
	EGroup_Filter(eg_allentities, "town_center", FILTER_KEEP)
	if EGroup_CountSpawned(eg_allentities) <= 0 and Objective_IsComplete(OBJ_CaptureVillage) then
		return true
	else
		return false
	end
end

function DestroyRochester_OnFail()
	Mission_Fail()
end
--End Destroy Rochester Objective--