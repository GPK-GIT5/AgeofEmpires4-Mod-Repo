local goal_heal = "healing"
local goal_holysite = "holysite"
local goal_buildrelic = "buildrelic"
local goal_market = "market"
local goal_buysell = "buysell"
local goal_producetrader = "producetraders"
local goal_assigntrader = "assigntraders"

function Rochester_Tutorials_Init()
	-- if on xbox, a couple training sequences have variant steps
	if UI_IsXboxControllerUI() then
		MissionTutorial_Healing_Xbox()
		MissionTutorial_Market_Xbox()
	else
		MissionTutorial_Healing()
		MissionTutorial_Market()	
	end
	
	MissionTutorial_HolySite()
	MissionTutorial_BuySell()
	MissionTutorial_ProduceTrader()
	MissionTutorial_AssignTrader()
end

function MissionTutorial_Init()	-- called from the mission's Mission_Start() function, so post-intro
	
	-- this enables the tutorial system, regardless of preferences
	
	--Training_Init()
	--Training_ForceGoalsActive()	
	
	--if Rule_Exists(Training_Update) == false then -- if it hasn't already been started up...
		--Rule_AddInterval( Training_Update, 0.5)
	--end
	
end

--------------------------------------------------------------
-- Monks Healing training hints
--------------------------------------------------------------

function MissionTutorial_Healing_Xbox()
	
	-- "Wounded units can be healed when not in combat. Press D-Pad Right to Select a Monk."
	local selectMonk = Training_Goal("Squad", {Message = "$11248621", DataTemplate="GenericTrainingDataTemplate"}, Healing_MonkIsSelected)
	
	--"Move the Monk close to a wounded unit and they will begin healing."
	local targetWounded = Training_Goal("Squad", {Message = "$11248622", DataTemplate="GenericTrainingDataTemplate"}, Healing_TargetWounded)

	healSequence = Training_GoalSequence(goal_heal, 1, 0, Healing_TriggerPredicate_Xbox, CampaignTraining_TimeoutIgnorePredicate, nil, nil, true, {selectMonk, targetWounded})
	
	Training_AddGoalSequence(healSequence)
	Training_EnableGoalSequenceByID(healSequence, true)
end

function MissionTutorial_Healing()
	
	-- "Wounded units can be healed when not in combat. Select a Monk."
	local selectMonk = Training_Goal("Squad", {Message = "$11191769", DataTemplate="LeftClickTrainingDataTemplate"}, Healing_MonkIsSelected)
	
	-- "Use Heal."
	local useHeal = Training_Goal("PBG", {Message = "$11191770", DataTemplate="LeftClickTrainingDataTemplate"}, Healing_UseHeal)
	
	--"Target wounded units."
	local targetWounded = Training_Goal("Squad", {Message = "$11191771", DataTemplate="LeftClickTrainingDataTemplate"}, Healing_TargetWounded)

	healSequence = Training_GoalSequence(goal_heal, 1, 0, Healing_TriggerPredicate, CampaignTraining_TimeoutIgnorePredicate, nil, nil, true, {selectMonk, useHeal, targetWounded})
	
	Training_AddGoalSequence(healSequence)
	Training_EnableGoalSequenceByID(healSequence, true)
end

function Healing_TriggerPredicate_Xbox(goalSequence)
	sg_monks = SGroup_CreateIfNotFound("sg_monks")
	Player_GetAll(player1, sg_monks)
	SGroup_Filter(sg_monks, "scar_monk", FILTER_KEEP)
		
	if SGroup_CountSpawned(sg_monks) > 0 then
		goalSequence.goals[1].key = SGroup_GetSquadAt(sg_monks, 1)
		local woundedBool, woundedTarget = FindWounded()
		if woundedTarget ~= nil and woundedBool == true then
			goalSequence.goals[2].key = woundedTarget
			return true
		end
	end	
	
end

function Healing_TriggerPredicate(goalSequence)
	sg_monks = SGroup_CreateIfNotFound("sg_monks")
	Player_GetAll(player1, sg_monks)
	SGroup_Filter(sg_monks, "scar_monk", FILTER_KEEP)
		
	if SGroup_CountSpawned(sg_monks) > 0 then
		goalSequence.goals[1].key = SGroup_GetSquadAt(sg_monks, 1)
		goalSequence.goals[2].key = BP_GetAbilityBlueprint("monk_heal_target")
		local woundedBool, woundedTarget = FindWounded()
		if woundedTarget ~= nil and woundedBool == true then
			goalSequence.goals[3].key = woundedTarget
			return true
		end
	end	
	
end

function Healing_MonkIsSelected(goal)
	Misc_GetSelectedSquads(sg_currentSelection, true)
	SGroup_Filter(sg_currentSelection, "scar_monk", FILTER_KEEP)
	if SGroup_CountSpawned(sg_currentSelection) > 0 then
		return true
	end
	
	return false
end

function Healing_UseHeal(goal)
	Misc_GetSelectedSquads(sg_currentSelection, true)
	SGroup_Clear(sg_temp)
	SGroup_Filter(sg_currentSelection, "scar_monk", FILTER_KEEP, sg_temp)
	if SGroup_CountSpawned(sg_currentSelection) > 0 and SGroup_CountSpawned(sg_temp) < 1 then
		return training_currentAbilityBlueprint == BP_GetAbilityBlueprint("monk_heal_target")
	else
		return false
	end
end

function Healing_TargetWounded(goal)
	Misc_GetSelectedSquads(sg_currentSelection, true)
	SGroup_Clear(sg_temp)
	SGroup_Filter(sg_currentSelection, "scar_monk", FILTER_KEEP, sg_temp)
	if SGroup_CountSpawned(sg_currentSelection) > 0 and SGroup_CountSpawned(sg_temp) < 1 then
		if goal.key == nil then
			local woundedBool, woundedTarget = FindWounded()
			goal.key = woundedTarget
		end
		return Entity_GetStateModelInt(Squad_GetFirstEntity(SGroup_GetSquadAt(sg_currentSelection, 1)), "healing_count") > 0
		--return Squad_GetHealthPercentage(goal.key, false) >= 1.0
	else
		return false
	end
end

function FindWounded()
	
	local squadID = nil
	
	local _IsCanidate = function(gid, index, sid)
		if Squad_GetHealthPercentage(sid, false) < 1.0 then
			if Squad_IsUnderAttack(sid, 3) == false and Squad_IsAttacking(sid, 3) == false then
				squadID = sid
				return true
			end
		end
	end
	
	Player_GetAll(player1)
	
	--Remove gaia (we don't want to heal sheep)
	SGroup_Filter(sg_allsquads, "gaia", FILTER_REMOVE)
	return SGroup_ForEachAllOrAny(sg_allsquads, ANY, _IsCanidate), squadID
end

--------------------------------------------------------------
-- Relic training hints
--------------------------------------------------------------

function MissionTutorial_HolySite()
	
	-- "Monks can secure holy sites. Select a Monk."
	local selectMonk = Training_Goal("Squad", {Message = "$11191772", DataTemplate="LeftClickTrainingDataTemplate" }, MonkIsSelected)
	
	-- "Secure the holy site by moving your monk to it."
	local secureHolySite = Training_Goal("Entity", {Message = "$11191773", DataTemplate="RightClickTrainingDataTemplate"}, MonkIsAtSite)
	
	holysiteSequence = Training_GoalSequence(goal_holysite, 1, 0, 
		HolySite_TriggerPredicate, 
		CampaignTraining_TimeoutIgnorePredicate, 
		nil, 
		HolySite_BypassPredicate, 
		true, 
		{selectMonk, secureHolySite}
	)
	
	Training_AddGoalSequence(holysiteSequence)
	Training_EnableGoalSequenceByID(holysiteSequence, true)
	
end

function HolySite_TriggerPredicate(goalSequence)
	
	local _HolySiteLocation = function(gid, index, eid)
		if Player_CanSeeEntity(player1, eid) then
			goalSequence.goals[2].key = eid
			return
		end
	end
	EGroup_ForEachAllOrAny(eg_holysites, ANY, _HolySiteLocation)
		
	Player_GetAll(player1)
	SGroup_Filter(sg_allsquads, "scar_monk", FILTER_KEEP)
	
	if scartype(goalSequence.goals[2].key) == ST_ENTITY and SGroup_CountSpawned(sg_allsquads) > 0 then
		goalSequence.goals[1].key = SGroup_GetSquadAt(sg_allsquads, 1)
		return true
	end
	
end

function HolySite_BypassPredicate(goalSequence)
	
	local _HolySiteLocation = function(gid, index, eid)
		if World_OwnsEntity(eid) ~= true then
			if Entity_GetPlayerOwner(eid) == player1 then
				return true
			end
		end
	end
	if EGroup_ForEachAllOrAny(eg_holysites, ANY, _HolySiteLocation) then
		return true
	end
end

function MonkIsSelected(goal)
	Misc_GetSelectedSquads(sg_currentSelection, true)
	SGroup_Filter(sg_currentSelection, "scar_monk", FILTER_KEEP)
	if SGroup_CountSpawned(sg_currentSelection) > 0 then
		return true
	end
	
	return false
end

function MonkIsAtSite(goal)
	local site_pos = Util_GetPosition(goal.key)
	Player_GetAllSquadsNearMarker(player1, sg_temp, site_pos, 12)
	SGroup_Filter(sg_temp, "scar_monk", FILTER_KEEP)
	
	if SGroup_CountSpawned(sg_temp) > 0 then
		return true
	end
end

