

------------------------------------------------------------------------------------------------------------------------------------------
--														Player Reinforcement UI
------------------------------------------------------------------------------------------------------------------------------------------

function UI_ReinforcePanel_UpdateData()
	
	uiData_ReinforcePanel = {
		Visible = true,
		Reserves = {}
	}
	
	for index, reserve in pairs(t_reinforcementData) do

		local uiData = {
			
			Name = Loc_GetString(reserve.displayName),
			
			TradeCountVisible = false,
			BuyButtonVisible = false,
			BuyButtonEnabled = false,
			BuyButtonOpacity = 0.44,
			BuyButtonCommand = UI_CreateCommand("UI_RequestAid_ButtonCallback"),
			BuyButtonParameter = reserve.id,
			AidButtonTitle = Loc_GetString(reserve.buttontext),
			Cost = reserve.cost,
			ResourceWarning = true,
			PopWarning = true,
			CostColour = "#FFBFBFBF",
			ShowMoneyIcon = true,
		}			
		
		uiData.TradeCountVisible = false
		uiData.BuyButtonVisible = true
		
		--if player has gold available
		local player_gold = Player_GetResource(playerHuman, RT_Gold)
			
		if player_gold >= reserve.cost then
			uiData.ResourceWarning = false
			uiData.CostColour = "#FFFFDB88"
		end

		local totalAidAmount = reserve.aidAmount + reserve.aidAmount_2	
		if (Player_GetCurrentPopulation(playerHuman, CT_Personnel) + totalAidAmount) <= Player_GetCurrentPopulationCap(playerHuman, CT_Personnel) then
			uiData.PopWarning = false
		end
		
		if uiData.ResourceWarning == false and uiData.PopWarning == false then
			uiData.BuyButtonEnabled = true 
			uiData.BuyButtonOpacity = 1.0
		end
		
		if (UI_IsXboxUI()) then
			uiData.CostAmount = tostring(uiData.Cost)
		else
			uiData.CostAmount = Loc_GetString(Loc_FormatText(11184216, uiData.Cost))
		end
		
		if reserve.aidAmount_2 > 0 then
			uiData.AidButtonTooltip = Loc_GetString(Loc_FormatText(reserve.tooltip, reserve.aidAmount, reserve.aidAmount_2))
		else
			uiData.AidButtonTooltip = Loc_GetString(Loc_FormatText(reserve.tooltip, reserve.aidAmount))
		end
		
		table.insert(uiData_ReinforcePanel.Reserves, uiData)
		
	end
	
	uiData_ReinforcePanel.Visible = true
	_diplomacy.data_context.buyReserves = uiData_ReinforcePanel
	Diplomacy_UpdateUI()
	
end

function UI_RequestAid_ButtonCallback(parameter)
	
	for index, reserve in pairs(t_reinforcementData) do 
	
		if reserve.id == parameter then
			
			if Player_GetResource(playerHuman, RT_Gold) >= reserve.cost then
				
				player_reinforcement_counter = player_reinforcement_counter + 1
				
				reinforcements_called = true
				Player_AddResource(playerHuman, RT_Gold, -reserve.cost)
				
				local units = reserve.units
				local options = { spawnInFormation = true, destination = mkr_reinforce_main_dest}
				
				_G["sg_"..player_reinforcement_counter] = SGroup_CreateIfNotFound(("sg_reinforcement"..player_reinforcement_counter))
				sg_requestAid = _G["sg_"..player_reinforcement_counter]
				
				UnitEntry_DeploySquads(playerHuman, _G["sg_"..player_reinforcement_counter], units, mkr_reinforce_main, nil, nil, options)
				
				UI_RequestAid_EventCue()
				Sound_PlayWallaCelebrateOnSGroup(_G["sg_"..player_reinforcement_counter])
				
				if b_reinforceCooldown == false then
					Start_IntelCooldown(_G["sg_"..player_reinforcement_counter], reserve)
				end
				
				UI_ReinforcePanel_UpdateData()
				
				--achievement data
				for i, unit_group in pairs(units) do 				
					if unit_group.type == "scar_knight" or unit_group.sbp == BP_GetSquadBlueprint("unit_foot_knight_2_cmp_eng") then 
						knight_reinforcements = knight_reinforcements + unit_group.numSquads	
						
						if knight_reinforcements >= 45 then 							
							Game_SendCustomChallengeEvent(playerHuman, CE_ACHIEVPURCHASEKNIGHTSTINCHEBRAY, 1)	
							
						end		
						
					end
					
				end							
								
			end
		end
	end
end

function UI_RequestAid_EventCue()	
	
	local icon_path = "icons\\event_queue_high_priority_large"
	local sfx_path = "sfx_ui_event_queue_high_priority_play"
	UI_CreateEventCueClickable(-1, 10, 0, 0.0, 42813, Loc_Empty(), "high_priority", icon_path, sfx_path, 255, 255, 255, 255, ECV_Title, UI_RequestAid_MoveCamera)
end

function UI_RequestAid_MoveCamera()	
	if sg_requestAid ~= nil then
		Camera_MoveTo(sg_requestAid)
	end
end

function Start_IntelCooldown(target, reserve)

	b_reinforceCooldown = true
	
	UI_CreateMinimapBlip(target, 10, CTA_CELEBRATE)
	
	if reserve.intel_played == false then
		reserve.intel_played = true
		Util_StartIntel(EVENTS[reserve.intel_event])
	end

	Rule_AddOneShot(ReinforceIntel_Cooldown, 20)
end

function ReinforceIntel_Cooldown()
	b_reinforceCooldown = false
end
