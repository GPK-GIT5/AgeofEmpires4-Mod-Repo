--
-- Tinchebray 1106
--
-- Norman campaign, mission 4
--

import("MissionOMatic/MissionOMatic.scar")		-- this imports the Cardinal scripts as well

import("obj_defeat.scar")
import("obj_reinforce.scar")
import("ang_chp2_tinchebray_data.scar")
import("ang_chp2_tinchebray_training.scar")
import("diplomacy_chp2_tinchebray.scar")

function Mission_SetupPlayers()

	playerHuman = World_GetPlayerAt(1)				-- Henry I
	playerRobert = World_GetPlayerAt(2)				-- Robert Curthose
	playerNeutral = World_GetPlayerAt(3)			-- Neutrals, King Henry I placeholder
	playerRobertPrisoner = World_GetPlayerAt(4)		-- Robert Curthose Prisoner
		
	Setup_SetPlayerName(playerHuman, Loc_GetString("$11180364"))
	Player_SetCurrentAge(playerHuman, AGE_FEUDAL)
	Player_SetMaximumAge(playerHuman, AGE_FEUDAL)
	
	Setup_SetPlayerName(playerRobert, Loc_GetString("$11180363"))
	Player_SetCurrentAge(playerRobert, AGE_FEUDAL)
	Player_SetMaximumAge(playerRobert, AGE_FEUDAL)
	
	Setup_SetPlayerName(playerNeutral, Loc_GetString("$11180365"))
	Player_SetCurrentAge(playerNeutral, AGE_FEUDAL)
	AI_Enable(playerNeutral, false)
	
	Setup_SetPlayerName(playerRobertPrisoner, Loc_GetString("$11180363")) 
	
	Player_RemoveUpgrade(playerHuman, UPG.COMMON.UPGRADE_SIEGE_ENGINEERS)
	
	Player_SetPopCapOverride(playerHuman, 200)
	
	World_EnableSharedLineOfSight(playerHuman, playerNeutral, true)
	
	Player_SetRelationship(playerHuman, playerNeutral, R_ALLY)
	Player_SetRelationship(playerNeutral, playerHuman, R_ALLY)
	
	Player_SetRelationship(playerRobert, playerNeutral, R_NEUTRAL)
	Player_SetRelationship(playerNeutral, playerRobert, R_NEUTRAL)
	
	PlayerColour_Enable()
	
	-- 1 - Blue, 2 - Red, 3 - Yellow
	Game_SetPlayerSlotColour(playerHuman, 1)
	Game_SetPlayerUISlotColour(playerHuman, 1)
	
	Game_SetPlayerSlotColour(playerRobert, 2)
	Game_SetPlayerUISlotColour(playerRobert, 2)
	
	Game_SetPlayerSlotColour(playerNeutral, 1)
	Game_SetPlayerUISlotColour(playerNeutral, 1)

	Game_SetPlayerSlotColour(playerRobertPrisoner, 3)
	Game_SetPlayerUISlotColour(playerRobertPrisoner, 3)
	
end

function Mission_SetupVariables()
	
	Tinchebray_Data_Init()
	
	Tinchebray_InitCastle()
	Tinchebray_InitStartingUnits()

	Tinchebray_InitDebugObjective()
	
	-- achievement variable
	knight_reinforcements = 0
	
end

function Mission_SetRestrictions()
	Tinchebray_SetPopulationCapVisibility(false)
end

function Mission_SetDifficulty()
	
	t_difficulty = {
		upgradeLevel = Util_DifVar({0, 0, 1, 2}),
		enemy_reinforcements_horseman = Util_DifVar({20, 30, 15, 5}),
		enemy_reinforcements_knight = Util_DifVar({0, 0, 15, 25}),
		enemy_reinforcements_infantry = Util_DifVar({12, 15, 20, 25}),
		enemy_mainarmy_maa = Util_DifVar({10, 15, 15, 15}),
		enemy_mainarmy_knight = Util_DifVar({0, 0, 10, 18}),
		enemy_scout_limit = Util_DifVar({3, 4, 5, 6}),
	}
	
 end

function Mission_PreInit()
	Tinchebray_HideTributeMenu()
end

function Mission_Preset()
	
	-- Audio considerations
	Sound_SetMusicRaceCode("french")
		
	Sound_ResetMusicIntensityMapping();
	Sound_AddMusicIntensityMappingPoint(50, 200) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(150, 1250) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(200, 2250) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(300, 3000) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(400, 4000) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(600, 6000) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(750, 9999) -- raw value max to scaled value max 
	
	Defeat_InitObjectives()
	
	Cmd_InstantUpgrade(eg_outpost_stone1, UPG.COMMON.UPGRADE_OUTPOST_STONE)
	Cmd_InstantUpgrade(eg_outpost_stone2, UPG.COMMON.UPGRADE_OUTPOST_STONE)
	Cmd_InstantUpgrade(eg_outpost_stone3, UPG.COMMON.UPGRADE_OUTPOST_STONE)
	Cmd_InstantUpgrade(eg_outpost_stone1, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	Cmd_InstantUpgrade(eg_outpost_stone2, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	Cmd_InstantUpgrade(eg_outpost_stone3, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	
	Cmd_InstantUpgrade(eg_keep, UPG.COMMON.UPGRADE_KEEP_ARROWSLITS)
	
	PlayerUpgrades_Auto(playerHuman, false)
	PlayerUpgrades_Auto(playerRobert, true)
		
	enemy_reinforcements = {
		{type = "scar_horseman", numSquads = t_difficulty.enemy_reinforcements_horseman },
		{type = "scar_knight", numSquads = t_difficulty.enemy_reinforcements_knight },
		{type = "scar_spearman", numSquads = t_difficulty.enemy_reinforcements_infantry },
		{type = "scar_archer", numSquads = t_difficulty.enemy_reinforcements_infantry },
	}
	
	local units_robert = {{sbp = BP_GetSquadBlueprint("unit_robert_curthose_cmp_eng"), numSquads = 1}}
	UnitEntry_DeploySquads(playerRobert, sg_robert, units_robert, mkr_duke_robert)
	Prefab_DoAction(MissionOMatic_FindModule("DukeRobert"), "AddSGroup", sg_robert)
	
	if Music_UnlockIntensity then
	   Sound_SetForceMusic(false)
	else
	   Sound_SetForceMusic(true)
	end
	
end

function Mission_Start()
	
	-- on console don't restore VPS since we have no villagers this mission
	Cardinal_EnablePartialXboxUI(true, {VF_XboxUIVillagerPriorities})

	Rule_AddInterval(Tinchebray_CheckMissionFail, 1)
	
	Objective_Start(OBJ_DefeatArmy, false)
	
	-- Reset resources
	Player_SetResource(playerHuman, RT_Wood, 0)
	Player_SetResource(playerHuman, RT_Gold, 0)
	Player_SetResource(playerHuman, RT_Food, 0)
	
	Rule_AddOneShot(Mission_Start_Delayed, 2)
	
end

function Mission_Start_Delayed()
	
	Objective_Start(OBJ_DestroyVillages)
	World_SetInteractionStage(2)
	Tinchebray_InitVillages()
	
end

function Mission_OnTributeSent(tribute)
	
	for index, tributeData in pairs(tribute) do 
		
		if tributeData.receiver.id == playerDanes and tributeData.gold > 0 then
			
			local objective = OBJ_PayTribute
			
			if Objective_IsCounterSet(objective) then
				Objective_IncreaseCounter(objective, tributeData.gold)
				
				local progress = Obj_GetCounterCount(objective.ID) / Obj_GetCounterMax(objective.ID)
				Obj_SetProgress(objective.ID, progress)
				
				if progress >= 1 then 
					Objective_Complete(objective)
					Rule_RemoveMe()
				end
				
			end
		end
	end
end

function Tinchebray_IntroduceDiplomacyUI()
	
	Tinchebray_ShowTributeMenu()
	Tribute_Intel()
	
	Rule_AddInterval(Tinchebray_CheckDiplomacyReminder, 1)
end

function Tinchebray_CheckDiplomacyReminder()
	
	current_gold_total = Player_GetResource(playerHuman, RT_Gold)
	
	if current_gold_total >= 500 and current_gold_total > prev_gold_total and Diplomacy_IsExpanded() == false and UI_IsXboxUI() == false then
		Diplomacy_ShowDiplomacyUI(true)
	end
	
	prev_gold_total = current_gold_total
end

function Tinchebray_ShowTributeMenu()
	Diplomacy_ShowUI(true)
	
	UI_ReinforcePanel_UpdateData()
	Rule_AddInterval(UI_ReinforcePanel_UpdateData, 1)
	
	Rule_AddOneShot(Tinchebray_AddSendGoldDelayed, 10)
end

function Tinchebray_AddSendGoldDelayed()
	TrainingGoal_AddSendGold()
	Rule_AddOneShot(TrainingGoal_EnableSendGold, 3)
end

function Tinchebray_HideTributeMenu()

	Core_CallDelegateFunctions("DiplomacyEnabled", false)
	Diplomacy_ShowUI(false)
end







function Tinchebray_SetPopulationCapVisibility(visibility)
	
	for index, player in pairs(PLAYERS) do
		if player.isLocal == true then
			player.scarModel.PopulationCapOn  = visibility
			UI_SetPlayerDataContext(playerHuman, player.scarModel)
		end
    end
end

function Tinchebray_InitDebugObjective()
	
	OBJ_DebugComplete = {
        Title = LOC("Debug Complete"),
        Type = OT_Primary,
        showTitle = false,
        Cheat = function()
			Rule_RemoveAll()
			Util_StartIntel(EVENTS.Tinchebray_Outro)
	    end,
	    }

    Objective_Register(OBJ_DebugComplete)
end


--? @shortdesc Checks for mission fail
function Tinchebray_CheckMissionFail()
	
	Player_GetAll(playerHuman)
	SGroup_Filter(sg_allsquads, "scar_villager", FILTER_REMOVE)
	SGroup_Filter(sg_allsquads, "gaia", FILTER_REMOVE)
	
	if SGroup_CountSpawned(sg_allsquads) <= 0 then
		Mission_Fail()
	end
end

function Tinchebray_InitCastle()
	
	Player_GetAll(playerRobert)
	EGroup_Clear(eg_temp)
	EGroup_Filter(eg_allentities, "stone_gate", FILTER_REMOVE, eg_gate)
	EGroup_Filter(eg_allentities, "tower", FILTER_REMOVE, eg_temp)
	
	if EGroup_Count(eg_gate) > 0 then
		Modify_ReceivedDamage(eg_gate, 0.5)
		EGroup_SetInvulnerable(eg_gate, 0.05)
	end
	
	if EGroup_Count(eg_temp) > 0 then
		Cmd_InstantUpgrade(eg_temp, UPG.COMMON.UPGRADE_TOWER_ARROWSLITS)
	end
	
end


function Tinchebray_TestOutro()
	
	Rule_RemoveAll()
	Util_StartIntel(EVENTS.Tinchebray_Outro)
end


