--
-- Lincoln 1217 - Reinforcements
--


function Reinforcements_InitObjectives()
	
	OBJ_Reinforce1 = {
		Title = "$11184769", -- Defend Lincoln Castle until William Marshal arrives
		Type = ObjectiveType_Information,
		--Intel_Complete = nil,
		OnStart = function()
			Objective_StartTimer(OBJ_Reinforce1, COUNT_DOWN, 360, 0) 
			Rule_AddOneShot(Reinforce1_TimerComplete, 360) 
			Rule_AddOneShot(Lincoln2_ActivateFortA, 350)
		end,
		PreComplete = function()
			Music_LockIntensity(MUSIC_TENSE_COMBAT_RARE, 30)
			Lincoln2_SpawnReinforcements1()
		end,
		OnComplete = function()
			Util_AutoSave(true)
		end,
	}
	
	Objective_Register(OBJ_Reinforce1)
	
end

function Reinforce1_TimerComplete()
	Objective_Complete(OBJ_Reinforce1, false) -- the CTA notifies the player Wm Marshal has arrived so the objective banner isn't necessary
end


