--
-- Lincoln 1217 - Defeat Rebels
--


function DefeatRebels_InitObjectives()
	
	OBJ_DefeatRebels = {
		Title = "$11180334", -- Destroy rebel military buildings
		Type = ObjectiveType_Primary,
		Intel_Start = EVENTS.DefeatRebelsStart,
		PreStart = function()
			Objective_SetCounter(OBJ_DefeatRebels, 0, 6)
			Lincoln2_TrackMilitaryBuildings()
		end,
		OnComplete = function()
			
			if not Objective_IsComplete(OBJ_DefeatFrench) then
				Util_StartIntel(EVENTS["RebelsDefeatedFirst"])
				Lincoln2_StartDefeatFrench()
			end
			
			Util_AutoSave()
		end,
	}
	
	Objective_Register(OBJ_DefeatRebels)
	
end



