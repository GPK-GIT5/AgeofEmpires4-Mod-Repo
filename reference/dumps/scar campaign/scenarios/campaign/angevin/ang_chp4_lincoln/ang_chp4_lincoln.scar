function Mission_SetupPlayers()
	
	player1 = World_GetPlayerAt(1)
	player2 = World_GetPlayerAt(2)
	player3 = World_GetPlayerAt(3)
	player4 = World_GetPlayerAt(4)
	player5 = World_GetPlayerAt(5)
	
	playerEnglish = player1
	playerRebels = player2
	playerFrench = player3
	playerStowe = player4
	playerNeutral = player5
	
	AI_Enable(playerStowe, false)
	AI_Enable(playerNeutral, false)
	
	Setup_SetPlayerName(player1, Loc_GetString(11180341)) -- William Marshal
	Player_SetCurrentAge(player1, AGE_CASTLE)
	
	Setup_SetPlayerName(playerRebels, Loc_GetString(11180342)) -- Rebels
	Player_SetCurrentAge(playerRebels, AGE_CASTLE)
	Player_SetMaximumAge(playerRebels, AGE_CASTLE)
	
	Setup_SetPlayerName(playerFrench, Loc_GetString(11180343)) -- French
	Player_SetCurrentAge(playerFrench, AGE_CASTLE)
	Player_SetMaximumAge(playerFrench, AGE_CASTLE)
	
	Setup_SetPlayerName(playerStowe, Loc_GetString(11196316)) -- Stowe
	Player_SetCurrentAge(playerStowe, AGE_CASTLE)
	
	Setup_SetPlayerName(playerNeutral, Loc_GetString(11180344)) -- Neutral
	Player_SetCurrentAge(playerNeutral, AGE_CASTLE)
	
	Player_SetRelationship(playerRebels, playerFrench, R_ALLY)
	Player_SetRelationship(playerFrench, playerRebels, R_ALLY)
	
	Player_SetRelationship(player1, playerStowe, R_NEUTRAL)
	Player_SetRelationship(playerStowe, player1, R_NEUTRAL)
	
	Player_SetRelationship(player1, playerNeutral, R_ALLY)
	Player_SetRelationship(playerNeutral, player1, R_ALLY)
	
	Player_SetRelationship(playerRebels, playerNeutral, R_NEUTRAL)
	Player_SetRelationship(playerNeutral, playerRebels, R_NEUTRAL)
	
	Player_SetRelationship(playerFrench, playerNeutral, R_NEUTRAL)
	Player_SetRelationship(playerNeutral, playerFrench, R_NEUTRAL)
	
	Player_AddResource(player1, RT_Food, 2500)
	Player_AddResource(player1, RT_Wood, 600)
	Player_AddResource(player1, RT_Gold, 800)
	Player_AddResource(player1, RT_Stone, 300)
	
	Modify_PlayerPopCap(playerRebels, 1000, MUT_Addition)
	Modify_PlayerMaxPopCap(playerRebels, 1000, MUT_Addition)
	Modify_PlayerPopCap(playerFrench, 1000, MUT_Addition)
	Modify_PlayerMaxPopCap(playerFrench, 1000, MUT_Addition)
	
	PlayerColour_Enable()
	
	Game_SetPlayerSlotColour(player1, 1)
	Game_SetPlayerUISlotColour(player1, 1)
	
	Game_SetPlayerSlotColour(playerRebels, 2)
	Game_SetPlayerUISlotColour(playerRebels, 2)
	
	Game_SetPlayerSlotColour(playerFrench, 6)
	Game_SetPlayerUISlotColour(playerFrench, 6)
	
	Game_SetPlayerSlotColour(playerStowe, 9)
	Game_SetPlayerUISlotColour(playerStowe, 9)
	
	Game_SetPlayerSlotColour(playerNeutral, 1)
	Game_SetPlayerUISlotColour(playerNeutral, 1)
	
end

function Mission_SetupVariables()
	
	Lincoln2_Data_Init()
	
end

function Mission_SetDifficulty()
	
	t_difficulty = {
		enemyTargetLevel = Util_DifVar({0, 0, 1, 2}),
		enemyUnitBuildTime = Util_DifVar({13, 11, 9, 7}),
		siegeUnitBuildTime = Util_DifVar({35, 30, 25, 20}),
		rebelWaveInterval = Util_DifVar({130, 110, 90, 80}),
		rebelSiegeMax = Util_DifVar({3, 4, 6, 8}),
		frenchWaveInterval = Util_DifVar({600, 400, 340, 280}),
		rebelDefenderCount = Util_DifVar({5, 5, 10, 15}),
		frenchDefenderCount = Util_DifVar({3, 4, 7, 10}),
		enemyInitUnitIndex = Util_DifVar({1, 1, 2, 3}),
		enemyEndUnitIndex = Util_DifVar({3, 4, 6, 8}),
	}
	
 end

function Mission_SetRestrictions()
	
	Player_SetStateModelFloat(player1, "has_capital", 1.0)
	
	entity_keep = EGroup_GetEntityAt(eg_keep, 1)
	Entity_RemoveAbility(entity_keep, BP_GetAbilityBlueprint("core_building_scuttle"))
	
	Cmd_InstantUpgrade(eg_keep, UPG.COMMON.UPGRADE_KEEP_ARROWSLITS)
	Cmd_InstantUpgrade(eg_player_outposts, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	Cmd_InstantUpgrade(eg_player_outposts, UPG.COMMON.UPGRADE_OUTPOST_STONE)
	
	Cmd_InstantUpgrade(eg_camp_outposts, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	Cmd_InstantUpgrade(eg_french_outposts_a, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	Cmd_InstantUpgrade(eg_french_outposts_b, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	
	Cmd_InstantUpgrade(eg_rebel_outposts, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	--Cmd_InstantUpgrade(eg_rebel_outposts, UPG.COMMON.UPGRADE_OUTPOST_STONE)
	
	PlayerUpgrades_Auto(player1, true, { 
			UPG.COMMON.UPGRADE_SIEGE_CHEMISTRY, 
			UPG.COMMON.UPGRADE_SIEGE_CORNED_GUNPOWDER
	})
	PlayerUpgrades_Auto(playerRebels, true)
	PlayerUpgrades_Auto(playerFrench, true)
	
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_SIEGE_CHEMISTRY, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_SIEGE_CORNED_GUNPOWDER, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_OUTPOST_CANNON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_KEEP_CANNON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_TOWER_CANNON, ITEM_REMOVED)
	
	Player_SetSquadProductionAvailability(player1, SBP.ENGLISH.UNIT_CANNON_4_ENG, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.ENGLISH.UNIT_RIBAULDEQUIN_4_ENG, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.ENGLISH.UNIT_BOMBARD_4_ENG, ITEM_REMOVED) 
	Player_SetSquadProductionAvailability(player1, SBP.ENGLISH.UNIT_CULVERIN_4_ENG, ITEM_REMOVED) 
	Player_SetSquadProductionAvailability(player1, SBP.ENGLISH.UNIT_HANDCANNON_4_ENG, ITEM_REMOVED) 
	
	--Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_TOWN_CENTER_CAPITAL_ENG, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_TOWN_CENTER_ENG, ITEM_LOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_ECON_MARKET_CONTROL_ENG, ITEM_LOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_TECH_UNIT_INFANTRY_CONTROL_ENG, ITEM_LOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_TECH_UNIT_RANGED_CONTROL_ENG, ITEM_LOCKED)
	
	Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_UNIT_INFANTRY_CONTROL_ENG, ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_DEFENSE_PALISADE_ENG, ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_DEFENSE_PALISADE_GATE_ENG, ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_DEFENSE_OUTPOST_ENG, ITEM_UNLOCKED)
	
	if t_difficulty.enemyTargetLevel == 0 then
		
		french_targets = french_targets_easy
		
	elseif t_difficulty.enemyTargetLevel == 1 then

		french_targets = french_targets_medium
	else
		french_targets = french_targets_hard
	end
	
end

function Mission_Preset()
	
	Reinforcements_InitObjectives()
	DefendKeep_InitObjectives()
	DefeatRebels_InitObjectives()
	DefeatFrench_InitObjectives()
	
	Lincoln2_InitStartingUnits()
	Lincoln2_SetupFrenchForts()
	Lincoln2_InitCollapsedWalls()
	Lincoln2_SetManualTargeting()
	
	Wave_OverrideUnitBuildTime("scar_spearman", t_difficulty.enemyUnitBuildTime)
	Wave_OverrideUnitBuildTime("scar_manatarms", t_difficulty.enemyUnitBuildTime)
	Wave_OverrideUnitBuildTime("scar_archer", t_difficulty.enemyUnitBuildTime)
	Wave_OverrideUnitBuildTime("scar_crossbowman", t_difficulty.enemyUnitBuildTime)
	Wave_OverrideUnitBuildTime("scar_knight", t_difficulty.enemyUnitBuildTime)
	Wave_OverrideUnitBuildTime("scar_horseman", t_difficulty.enemyUnitBuildTime)
	
	Wave_OverrideUnitBuildTime("scar_springald", t_difficulty.siegeUnitBuildTime)
	Wave_OverrideUnitBuildTime("scar_ram", t_difficulty.siegeUnitBuildTime)
	Wave_OverrideUnitBuildTime("scar_mangonel", t_difficulty.siegeUnitBuildTime)
	
	Lincoln2_InitDebugComplete()
	
	--Rule_AddOneShot(Lincoln2_MoveStartingUnits, 7)
	
	
	--Music Setting
	
	if Music_UnlockIntensity then
		Sound_SetForceMusic(false)
	else
		Sound_SetForceMusic(true)
	end
	
	
	-- Set sound intensity for Lincoln 2
	Sound_ResetMusicIntensityMapping();
	Sound_AddMusicIntensityMappingPoint(50, 200) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(100, 1250) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(150, 2500) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(200, 3000) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(300, 3500) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(500, 6000) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(650, 9999) -- raw value max to scaled value max 
	
	
	-- Start music with tense
	Music_LockIntensity(MUSIC_TENSE, 30)
	
end

function Lincoln2_SetManualTargeting()
	
	Player_GetAll(playerRebels)
	EGroup_Filter(eg_allentities, {"house", "gate", "trade_post"}, FILTER_KEEP)
	EGroup_SetTargetingType(eg_allentities, Targeting_Manual)
	
end

function Lincoln2_InitCollapsedWalls()
	
	Player_GetAll(playerRebels)
	
	EGroup_Filter(eg_allentities, "stone_wall_bastion", FILTER_KEEP)
	
	local _CheckBastion = function(gid, idx, eid)
		
		EGroup_Clear(eg_single)
		EGroup_Add(eg_single, eid)
		
		if Prox_AreEntitiesNearMarker(eg_single, mkr_wall_collapse1, ANY, 10) then
			Entity_Destroy(eid)
		elseif Prox_AreEntitiesNearMarker(eg_single, mkr_wall_collapse2, ANY, 10) then
			Entity_Destroy(eid)
		end
		
	end
	EGroup_ForEach(eg_allentities, _CheckBastion)
	
end

function Mission_Start()
	
	Rule_AddGlobalEvent(Lincoln2_OnEntityKilled, GE_EntityKilled)
	Rule_AddInterval(Lincoln2_CheckMissionFail, 1)
	Rule_AddInterval(Lincoln2_CheckMissionWin, 1)
	
	Rule_AddInterval(Lincoln2_CheckRebelBuildingProx, 1)
	Rule_AddInterval(Lincoln2_CheckKeep, 1)
	
	Rule_AddInterval(Lincoln2_CheckFrenchSightTrigger, 1)
	
	Lincoln2_CheckRebelWave(rebel_wave_1, rebel_wave_data_1)
	Rule_AddInterval(Lincoln2_CheckRebelWaves, t_difficulty.rebelWaveInterval)
	
	Objective_Start(OBJ_Reinforce1)
	
	Sound_SetMinimumMusicCombatIntensity(801, 0)
	
	rebel_wave_data_1.unit_index = t_difficulty.enemyInitUnitIndex
	rebel_wave_data_2.unit_index = t_difficulty.enemyInitUnitIndex
	rebel_wave_data_3.unit_index = t_difficulty.enemyInitUnitIndex
	
	french_wave_data_a.unit_index = t_difficulty.enemyInitUnitIndex
	french_wave_data_b.unit_index = t_difficulty.enemyInitUnitIndex
	
	-- prevent player archers from automatically firing on enemy gates from the wall
	local eg_gates = Player_GetAllEntities(player2)
	EGroup_Filter(eg_gates, "stone_gate", FILTER_KEEP)
	EGroup_SetTargetingType(eg_gates, Targeting_Manual)
	
	Lincoln2_ClearIntroUnits()
	Lincoln2_InitRebels()
	
	--Lincoln2_AddKeepUpgradesGoal()
	Lincoln2_GarrisonOutposts()
	
	-- audio triggers for when the player gets near French forts
	
	AudioTrigger_InitAreaTrigger({
    	marker = mkr_fort_a_audio,
    	audioCue = MUSIC_TENSE_RARE,
    	triggeringPlayer = player1,
    	startAboveUnitCount = 1,
    })
	
	AudioTrigger_InitAreaTrigger({
    	marker = mkr_fort_b_audio,
    	audioCue = MUSIC_TENSE_RARE,
    	triggeringPlayer = player1,
    	startAboveUnitCount = 1,
    })

	
end

function Lincoln2_GarrisonOutposts()

	local _Garrison = function(gid, idx, eid)
		SGroup_Clear(sg_temp)
		EGroup_Clear(eg_temp)
		EGroup_Add(eg_temp, eid)
		UnitEntry_DeploySquads(playerFrench, sg_temp, {{type = "scar_archer", numSquads = 3 }}, Util_GetPosition(eg_temp))
		Cmd_Garrison(sg_temp, eg_temp)
	end
	EGroup_ForEach(eg_camp_outposts, _Garrison)
	EGroup_ForEach(eg_french_outposts_a, _Garrison)
	EGroup_ForEach(eg_french_outposts_b, _Garrison)
	
end

