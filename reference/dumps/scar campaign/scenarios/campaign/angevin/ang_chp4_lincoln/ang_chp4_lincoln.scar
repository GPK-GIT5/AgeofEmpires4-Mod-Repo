--? @shortdesc Checks for mission fail
function Lincoln2_CheckMissionFail()
	
	if EGroup_CountSpawned(eg_keep) <= 0 then
		Objective_Fail(OBJ_DefendKeep)
		Mission_Fail()
		Rule_RemoveMe()
	end
end

--? @shortdesc Checks for mission win
function Lincoln2_CheckMissionWin()
	
	if Objective_IsComplete(OBJ_DefeatRebels) and Objective_IsComplete(OBJ_DefeatFrench) then
		Lincoln2_TriggerOutro()
		Rule_RemoveMe()
		Music_LockIntensity(MUSIC_TENSE_COMBAT_RARE)
	end
end

function Lincoln2_SpawnUnitLine(markerName, endIndex, numPerMarker, unitType, startIndex)
	
	for i = startIndex, endIndex do
		local marker_name = markerName..tostring(i)
		local marker = Marker_FromName(marker_name, "")
		local sgroup = SGroup_CreateUnique("")
		UnitEntry_DeploySquads(player1, sgroup, {{type = unitType, numSquads = numPerMarker }}, marker)
		Cmd_HoldPosition(sgroup)
	end
end

function Lincoln2_CheckFrenchArrival()
	
	if Prox_AreSquadsNearMarker(sg_french_attackers_a, mkr_south_gate, ANY, 40) or 
		Prox_AreSquadsNearMarker(sg_french_attackers_a, mkr_french_assault1, ANY, 30) then
		
		Sound_Play2D(MUS_STINGER_WARNING)
		Sound_PlayWallaEngageOnSGroup(sg_french_attackers_a)
		
		EventCues_CallToAction("$11180362", CTA_ALARM, EVENTS.FirstFrench, nil, sg_french_attackers_a, 20) --The French are attacking!
		Sound_Play2D("sfx_campaign_scripted_medium_group_fear")
		
		Rule_AddInterval(Lincoln2_CheckFrenchFirstAttack, 3)
		
		Rule_RemoveMe()
	end
end

function Lincoln2_StartDefeatFrench()
	
	if not Objective_IsFailed(OBJ_DefendKeep) then
		Objective_Start(OBJ_DefeatFrench)
	end
end

function Lincoln2_CheckFrenchFirstAttack()
	
	if SGroup_CountSpawned(sg_french_attackers_a) == 0 then
		Lincoln2_StartDefeatFrench()
		Rule_RemoveMe()
	end
	
end

function Lincoln2_CheckRebelBuildingProx()
		
	Player_GetAll(player1)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_rebels_attack1, ANY, 25) or
		Prox_AreSquadsNearMarker(sg_allsquads, mkr_rebels_attack2, ANY, 25) or 
		Prox_AreSquadsNearMarker(sg_allsquads, mkr_rebels_attack3, ANY, 25) then
		
		if Objective_IsStarted (OBJ_DefeatRebels) == false then
			defeat_rebels_trigger = "prox"
			Objective_Start(OBJ_DefeatRebels)
		end
		
		Rule_AddInterval(Lincoln2_CheckRebelPrematureAttack, 3)
		
		Rule_RemoveMe()
	end
	
end

function Lincoln2_TrackMilitaryBuildings()
	
	Player_GetAll(playerRebels)
	
	local _CheckBuilding = function(gid, idx, eid)
		
		if Entity_IsOfType(eid, "military_production_building") and not Entity_IsOfType(eid, "monastery") then

			EGroup_Add(eg_military, eid)
			
			local entry = {
				id = Entity_GetID(eid),
				hpid = Objective_AddUIElements(OBJ_DefeatRebels, Util_GetPosition(eid), true, 11180340, false, 9),
				blip  = UI_CreateMinimapBlip(eid, -1, "objective_secondary")
			}
			
			table.insert(buildingHints, entry)
			
		end
	end
	EGroup_ForEach(eg_allentities, _CheckBuilding)
	
end

function Lincoln2_ClearIntroUnits()
	
	SGroup_DestroyAllSquads(sg_intro_enemies1)
	SGroup_DestroyAllSquads(sg_intro_enemies2)
	SGroup_DestroyAllSquads(sg_intro_enemies3)
	SGroup_DestroyAllSquads(sg_intro_enemies4)
end

function Lincoln2_InitRebels()
	
	local module1 = MissionOMatic_FindModule("RebelAttack1")
	local module2 = MissionOMatic_FindModule("RebelAttack2")
	local module3 = MissionOMatic_FindModule("RebelAttack3")
	
	SpawnUnitsToModule(t_init_rebels[1], module1, mkr_rebels_attack1)
	SpawnUnitsToModule(t_init_rebels[2], module1, mkr_rebels_attack2)
	SpawnUnitsToModule(t_init_rebels[3], module1, mkr_rebels_attack3)
	
end

function Lincoln2_InitStartingUnits()
	
	UnitEntry_DeploySquads(player1, sg_castle_villagers1, t_player_villager_units[1], mkr_castle_villagers1)
	UnitEntry_DeploySquads(player1, sg_player_archers1, t_player_archer_units[1], mkr_archers1)
	UnitEntry_DeploySquads(player1, sg_player_maa1, t_player_maa_units[1], mkr_maa1)
	
	UnitEntry_DeploySquads(playerRebels, sg_intro_enemies1, {{type = "scar_archer", numSquads = 3 }}, mkr_rebels_archer1)
	UnitEntry_DeploySquads(playerRebels, sg_intro_enemies2, {{type = "scar_archer", numSquads = 2 }}, mkr_rebels_archer2)
	UnitEntry_DeploySquads(playerRebels, sg_intro_enemies3, {{type = "scar_archer", numSquads = 4 }}, mkr_rebels_archer3)
	UnitEntry_DeploySquads(playerRebels, sg_intro_enemies4, {{type = "scar_archer", numSquads = 3 }}, mkr_rebels_archer4)
	
	UnitEntry_DeploySquads(playerStowe, sg_player_farmers, {{type = "scar_villager", numSquads = 5 }}, mkr_player_farmers)
	UnitEntry_DeploySquads(playerStowe, sg_player_woodcutters, {{type = "scar_villager", numSquads = 4 }}, mkr_player_woodcutters)
	UnitEntry_DeploySquads(playerStowe, sg_player_miners, {{type = "scar_villager", numSquads = 2 }}, mkr_player_miners)
	
	SGroup_AddGroup(sg_player_stowe, sg_player_farmers)
	SGroup_AddGroup(sg_player_stowe, sg_player_woodcutters)
	SGroup_AddGroup(sg_player_stowe, sg_player_miners)
	
	Modify_GoldGatherRate(sg_player_miners, 0.1)
	Modify_WoodGatherRate(sg_player_woodcutters, 0.1)
	
	AssignVillagersToFarms(sg_player_farmers)
	AssignVillagersToWood(sg_player_woodcutters)
	AssignVillagersToGold(sg_player_miners)
	
	Cmd_HoldPosition(sg_castle_villagers1)
	
	Lincoln2_SpawnUnitLine("mkr_archer", 6, 2, "scar_archer", 1)
	
	if Game_GetSPDifficulty() == GD_EASY then
		Lincoln2_SpawnUnitLine("mkr_archer", 12, 2, "scar_archer", 8)
		UnitEntry_DeploySquads(player1, sg_castle_villagers1, {{type = "scar_villager", numSquads = 4 }}, mkr_castle_villagers1)
	end
	
end

function Lincoln2_TriggerOutro()
	
	--Music_UnlockIntensity()
	Music_LockIntensity(MUSIC_TENSE)
	
	-- define markers where we should get rid of any buildings placed there by the player
	mkr_cleanupforoutro_group = {
		mkr_outro_william,
		mkr_outro_army1,
		mkr_outro_army2,
		mkr_outro_army3,
	}
		
	Mission_Complete()
	
end

function Lincoln2_OutroSetup()
	
	
	UnitEntry_DeploySquads(player1, sg_outro_william, {{sbp = BP_GetSquadBlueprint("unit_william_marshal_cmp_eng"), numSquads = 1, facing = Marker_GetPosition(mkr_outro_army1) }}, mkr_outro_william)
	
	Cmd_HoldPosition(sg_outro_william)
	
	local lookAt = Marker_GetPosition(mkr_outro_william)
	local outroUnits = {
		{type = "scar_spearman",  numSquads = 12, facing = lookAt, spawn = mkr_outro_army1},
		{type = "scar_manatarms", numSquads = 12, facing = lookAt, spawn = mkr_outro_army2},
		{type = "scar_archer",    numSquads = 6,  facing = lookAt, spawn = mkr_outro_army3},
		{type = "scar_archer",    numSquads = 2,  facing = lookAt, spawn = mkr_outro_wall1},
		{type = "scar_archer",    numSquads = 2,  facing = lookAt, spawn = mkr_outro_wall2},
		{type = "scar_archer",    numSquads = 2,  facing = lookAt, spawn = mkr_outro_wall3},
		{type = "scar_archer",    numSquads = 2,  facing = lookAt, spawn = mkr_outro_wall4},
		{type = "scar_archer",    numSquads = 2,  facing = lookAt, spawn = mkr_outro_wall5},
		{type = "scar_archer",    numSquads = 2,  facing = lookAt, spawn = mkr_outro_wall6},
		{type = "scar_archer",    numSquads = 2,  facing = lookAt, spawn = mkr_outro_wall7},
		{type = "scar_archer",    numSquads = 2,  facing = lookAt, spawn = mkr_outro_wall8},
		{type = "scar_archer",    numSquads = 2,  facing = lookAt, spawn = mkr_outro_wall9},
	}
	
	UnitEntry_DeploySquads(player1, sg_celebrate, outroUnits, mkr_outro_army3)
end


function Lincoln2_CheckFrenchSightTrigger()
	
	Player_GetAll(playerFrench)
	if Player_CanSeeSGroup(player1, sg_allsquads, ANY) then
		
		Rule_AddInterval(Lincoln2_CheckFortProxA, 1)
		Rule_AddInterval(Lincoln2_CheckFortProxB, 1)
		
		Rule_RemoveMe()
	end
end

function Lincoln2_CheckStoweTrigger()
	
	Player_GetAll(player1)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_hamlet, ANY, 30) then
		
		Music_PlayStinger(MUS_STING_POSITIVE)
		Lincoln2_PlayCelebrateAtPosition(mkr_hamlet, 50)
		
		Player_AddResource(player1, RT_Food, 500)
		Player_AddResource(player1, RT_Wood, 500)
		Player_AddResource(player1, RT_Stone, 200)
		
		Location_SetPlayerOwner(LOCATION("Stowe"), player1)
		Util_SetPlayerOwner(sg_player_stowe, player1)
		
		Modify_GoldGatherRate(sg_player_miners, 10)
		Modify_WoodGatherRate(sg_player_woodcutters, 10)

		Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_TOWN_CENTER_ENG, ITEM_DEFAULT)
		Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_ECON_MARKET_CONTROL_ENG, ITEM_DEFAULT)
		Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_TECH_UNIT_INFANTRY_CONTROL_ENG, ITEM_DEFAULT)
		Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_TECH_UNIT_RANGED_CONTROL_ENG, ITEM_DEFAULT)
		
		-- add a hitpoinbt on Stowe TC
		hpid_stowe = HintPoint_Add(eg_hamlet_tc, true, "$11196316", LOCATION_LABEL_HEIGHT)
		
		Rule_AddInterval(Lincoln2_StoweCTA,0.5) -- rule to trigger the CTA once speech things are done
		
		Rule_RemoveMe()
		
	end
end

function Lincoln2_StoweCTA ()
	-- Trigger a notification about Stowe once other speech/objective suff is done
	if Event_IsAnyRunning() == false then
		EventCues_CallToAction("$11192648", CTA_CELEBRATE, EVENTS.TownToPlayer, nil, mkr_hamlet, 20) --You gain control of Stowe!
		Rule_RemoveMe()
		Sound_Play2D("mus_stinger_campaign_triumph_short")
		Sound_Play2D("sfx_campaign_scripted_medium_group_celebrate")
	end
end

