	UnitEntry_DeploySquads(player1, sg_cavalry2, {{ type = "scar_knight", numSquads = 8 }}, mkr_army2, nil, nil, {})
	UnitEntry_DeploySquads(player1, sg_cavalry3, {{ type = "scar_knight", numSquads = 8 }}, mkr_army3, nil, nil, {})
	
	SpawnUnitsToModule({{ sbp = BP_GetSquadBlueprint("unit_william_marshal_cmp_eng"), numSquads = 1, tag = "General", sgroup = g_leaderWilliamMarshal.sgroup }}, "PlayerStartLeader", mkr_player_william)
	
	Rule_AddOneShot(Lincoln2_WilliamMarshalCTA, 0.5)
	Rule_AddOneShot(Lincoln2_MoveReinforcements1, 4.5)
	
	Rule_AddInterval(Lincoln2_CheckStoweTrigger, 1)
	
end

