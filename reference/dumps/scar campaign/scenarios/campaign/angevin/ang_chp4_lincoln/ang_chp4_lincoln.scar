function Lincoln2_SetupFrenchForts()

	Lincoln2_SpawnUnitCluster(playerFrench, "mkr_fort_a1", 5, "scar_crossbowman", sg_fre_fort_a)
	Lincoln2_SpawnUnitCluster(playerFrench, "mkr_fort_a2", 3, "scar_archer", sg_fre_fort_a)

	Lincoln2_SpawnUnitCluster(playerFrench, "mkr_fort_b1", 5, "scar_crossbowman", sg_fre_fort_b)
	Lincoln2_SpawnUnitCluster(playerFrench, "mkr_fort_b2", 4, "scar_archer", sg_fre_fort_b)
	Lincoln2_SpawnUnitCluster(playerFrench, "mkr_fort_b3", 4, "scar_crossbowman", sg_fre_fort_b)
	
	--Lincoln2_SpawnUnitCluster(playerFrench, "mkr_fort_b4", 1, "scar_springald", sg_fre_fort_b)
	--Lincoln2_SpawnUnitCluster(playerFrench, "mkr_fort_b5", 1, "scar_springald", sg_fre_fort_b)
end


function Lincoln2_InitFrenchAttack()
	
	SGroup_Clear(sg_temp)
	local options = {dynamicSpawnType = DST_FURTHEST_HIDDEN, destination = mkr_south_gate}
	UnitEntry_DeploySquads(playerFrench, sg_temp, t_init_french, mkr_fort_a_attack1, nil, nil, options)
	
	local module = MissionOMatic_FindModule("FrenchAttackA")
	Prefab_DoAction(module, "AddSGroup", sg_temp)
	RovingArmy_SetTarget(module, mkr_south_gate)
	
	Lincoln2_InitFrenchActivity()
end

function Lincoln2_InitFrenchActivity()
	
	if french_active == false then
		french_active = true
		Rule_AddInterval(Lincoln2_CheckFrenchArrival, 1)
	end
end

function Lincoln2_ActivateFortA()
	
	Rule_AddInterval(Lincoln2_CheckFrenchWaveA, t_difficulty.frenchWaveInterval)
	
	Lincoln2_InitFrenchActivity()
	
	if not fort_destroyed_a then
		fort_active_a = true
	end
	
	Rule_AddOneShot(Lincoln2_ActivateFortB, 600)
end

function Lincoln2_ActivateFortB()
	
	Rule_AddInterval(Lincoln2_CheckFrenchWaveB, t_difficulty.frenchWaveInterval + 30)
	
	if not fort_destroyed_b then
		fort_active_b = true
	end
end

function Lincoln2_CheckRebelWaves()
	
	--count number of existing siege weapons
	Player_GetAll(playerRebels)
	SGroup_Filter(sg_allsquads, {"scar_ram", "scar_springald", "scar_mangonel"}, FILTER_KEEP)
	rebel_siege_count = SGroup_CountSpawned(sg_allsquads)
	
	if not strongpoint_cleared1 then
		Lincoln2_CheckRebelWave(rebel_wave_1, rebel_wave_data_1)
	end
	
	if not strongpoint_cleared2 then
		Lincoln2_CheckRebelWave(rebel_wave_2, rebel_wave_data_2)
	end
	
	if not strongpoint_cleared3 then
		Lincoln2_CheckRebelWave(rebel_wave_3, rebel_wave_data_3)
	end
	
end

function Lincoln2_CheckFrenchWaveA()
	
	if fort_active_a then
		local targets = Lincoln2_GetFrenchWaveTargets()
		Lincoln2_CheckFrenchWave(french_wave_a, french_wave_data_a, targets)
	end
end

function Lincoln2_CheckFrenchWaveB()
	
	if fort_active_b then
		Lincoln2_CheckFrenchWave(french_wave_b, french_wave_data_b, nil)
	end
end

function Lincoln2_GetFrenchWaveTargets()
	
	local targetTable = nil
	
	targetTable = french_targets[french_target_index]
	french_target_index = french_target_index + 1
	if french_target_index >= #french_targets then
		french_target_index = 1
	end
	return targetTable
	
end

function Lincoln2_CheckRebelWave(wave, data)
	
	local a = data.unit_index
	local units = Table_Copy(data.unit_tables[a])
	
	--cap rebel siege weapon count
	for i = 1, #units do
		local entry = units[i]
		if entry.type == "scar_springald" or entry.type == "scar_ram" or entry.type == "scar_mangonel" then
			if rebel_siege_count > t_difficulty.rebelSiegeMax then
				entry.numSquads = 0
			else
				rebel_siege_count = rebel_siege_count + entry.numSquads
			end
		end
	end
	
	--make sure there aren't too many existing units
	local strongpoint_unit_cap = Util_DifVar({30, 30, 40, 50})
	Player_GetAllSquadsNearMarker(playerRebels, sg_temp, data.spawn, 30)
	if SGroup_CountSpawned(sg_temp) < strongpoint_unit_cap then
		Wave_SetUnits(wave, units)
		Wave_Prepare(wave)
	end
	
	if data.unit_index < #data.unit_tables and data.unit_index < t_difficulty.enemyEndUnitIndex then
		data.unit_index = data.unit_index + 1
	end
end

function Lincoln2_CheckFrenchWave(wave, data, targets)
	
	local a = data.unit_index
	local units = Table_Copy(data.unit_tables[a])
	
	--make sure there aren't too many existing units
	local french_unit_cap = Util_DifVar({70, 70, 85, 100})
	Player_GetAllSquadsNearMarker(playerFrench, sg_blah, data.spawn, 50)
	if SGroup_CountSpawned(sg_blah) < french_unit_cap then
		Wave_SetUnits(wave, units)
		Wave_Prepare(wave)
	end
	
	if data.unit_index < #data.unit_tables and data.unit_index < t_difficulty.enemyEndUnitIndex then
		data.unit_index = data.unit_index + 1
	end

	if targets ~= nil then
		
		--check for siege towers
		for i = 1, #units do
			local entry = units[i]
			if entry.type == "scar_siege_tower" then
				
				targets = french_targets_st[french_target_st_index]
				
				french_target_st_index = french_target_st_index + 1
				if french_target_st_index > #french_targets_st then
					french_target_st_index = 1
				end
			end
		end
		
		RovingArmy_SetTargets(MissionOMatic_FindModule(data.assault_module), targets)
	end
	
end

function Lincoln2_CheckRebelPrematureAttack()
	
	if strongpoint_cleared1 and strongpoint_cleared2 then
		Rule_RemoveMe()
	end
	
	if not strongpoint_cleared1 then
		if SGroup_CountSpawned(sg_rebels_defend1) > 0 and SGroup_CountSpawned(sg_rebels_attack1) == 0 then
			if Player_CanSeePosition(player1, Util_GetPosition(mkr_rebels_defend1)) then
				if #rebel_wave_1.queued_waves > 0 then
					Wave_Launch(rebel_wave_1)
				end
			end
		end
	end
	
	if not strongpoint_cleared2 then
		if SGroup_CountSpawned(sg_rebels_defend2) > 0 and SGroup_CountSpawned(sg_rebels_attack2) == 0 then
			if Player_CanSeePosition(player1, Util_GetPosition(mkr_rebels_defend2)) then
				if #rebel_wave_2.queued_waves > 0 then
					Wave_Launch(rebel_wave_2)
				end
			end
		end
	end
	
	if not strongpoint_cleared3 then
		if SGroup_CountSpawned(sg_rebels_defend3) > 0 and SGroup_CountSpawned(sg_rebels_attack3) == 0 then
			if Player_CanSeePosition(player1, Util_GetPosition(mkr_rebels_defend3)) then
				if #rebel_wave_3.queued_waves > 0 then
					Wave_Launch(rebel_wave_3)
				end
			end
		end
	end
	
end

function Lincoln2_CheckFortProxA()
	
	Player_GetAll(player1)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_fort_a, ANY, 50) then
		
		Lincoln2_StartDefeatFrench()
		
		if fort_revealed == false then
			fort_revealed = true
			Sound_Play2D(MUS_STINGER_ALERT)
			Util_StartIntel(EVENTS["Discover_FrenchFort"])
		end
		
		FOW_RevealArea(Util_GetPosition(mkr_fort_a), 40, 30)
		Rule_RemoveMe()
	end
end

function Lincoln2_CheckFortProxB()
	
	Player_GetAll(player1)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_fort_b, ANY, 50) then
		
		Lincoln2_StartDefeatFrench()
		
		if fort_revealed == false then
			fort_revealed = true
			Sound_Play2D(MUS_STINGER_ALERT)
			Util_StartIntel(EVENTS["Discover_FrenchFort"])
		end
		
		FOW_RevealArea(Util_GetPosition(mkr_fort_b), 40, 30)
		Rule_RemoveMe()
	end
end

function Lincoln2_SpawnUnitCluster(player, markerName, numPerMarker, unitType, masterSgroup)
	local sgroup = SGroup_CreateUnique("")
	local marker = Marker_FromName(markerName, "")
	UnitEntry_DeploySquads(player, sgroup, {{type = unitType, numSquads = numPerMarker }}, marker)
	SGroup_AddGroup(masterSgroup, sgroup)
end

function Lincoln2_CheckStrongpoints()
	
	Player_GetAll(playerRebels)
	
	local strongpoint_count1 = 0
	local strongpoint_count2 = 0
	local strongpoint_count3 = 0
	
	local _CheckForBuildings = function(gid, idx, eid)
		if Entity_IsAlive(eid) then
			
			if Entity_IsOfType(eid, "military_production_building") and not Entity_IsOfType(eid, "monastery") then
				
				EGroup_Clear(eg_single)
				EGroup_Add(eg_single, eid)
				
				if Prox_AreEntitiesNearMarker(eg_single, mkr_rebels_defend1, ANY, 30) then
					strongpoint_count1 = strongpoint_count1 + 1
				elseif Prox_AreEntitiesNearMarker(eg_single, mkr_rebels_defend2, ANY, 30) then
					strongpoint_count2 = strongpoint_count2 + 1
				elseif Prox_AreEntitiesNearMarker(eg_single, mkr_rebels_defend3, ANY, 30) then
					strongpoint_count3 = strongpoint_count3 + 1
				end
				
			end
		end
	end
	
	EGroup_ForEach(eg_allentities, _CheckForBuildings)
	
	if not strongpoint_cleared1 then
		if strongpoint_count1 == 0 then 
			strongpoint_cleared1 = true
			Prefab_DoAction(MissionOMatic_FindModule("RebelDefenders1"), "Disband")
		end
	end
	
	if not strongpoint_cleared2 then
		if strongpoint_count2 == 0 then 
			strongpoint_cleared2 = true
			Prefab_DoAction(MissionOMatic_FindModule("RebelDefenders2"), "Disband")
		end
	end
	
	if not strongpoint_cleared3 then
		if strongpoint_count3 == 0 then 
			strongpoint_cleared3 = true
			Prefab_DoAction(MissionOMatic_FindModule("RebelDefenders3"), "Disband")
		end
	end
	
end

function Lincoln2_OnEntityKilled(context)

	local victim = context.victim
	local owner = context.victimOwner
	
	if owner == player1 and castle_walls_breached == false then
		
		if Entity_IsOfType(victim, "stone_wall") or Entity_IsOfType(victim, "stone_gate") then
			
			castle_walls_breached = true
			Music_PlayStinger(MUS_STINGER_ALERT) -- play an alert stinger the first time the castle walls fall
			Util_StartIntel(EVENTS["EnemyInCastle"])
		end
	
	elseif owner == playerFrench and not Objective_IsComplete(OBJ_DefeatFrench) then
		
		if not Objective_IsComplete(SOBJ_DestroyFortWest) and Objective_IsStarted(SOBJ_DestroyFortWest) then
			
			local current_count_a = EGroup_CountSpawned(eg_fort_a) + EGroup_CountSpawned(eg_french_outposts_a)
			
			if current_count_a < fort_prev_count_a then
				
				fort_prev_count_a = current_count_a
				fort_destroyed_count_a = fort_init_count_a - current_count_a
				Objective_SetCounter(SOBJ_DestroyFortWest, fort_destroyed_count_a, fort_init_count_a)
				
				if fort_destroyed_count_a >= fort_init_count_a then
					
					if Objective_IsComplete(SOBJ_DestroyFortEast) then
						
						Music_PlayStinger (MUS_STING_TRIUMPHANT)
						Lincoln2_PlayCelebrateAtPosition(mkr_fort_a, 45)
						
						Objective_Complete(SOBJ_DestroyFortWest, false)
						Objective_Complete(OBJ_DefeatFrench)
					else
						
						Music_PlayStinger(MUS_STING_POSITIVE)
						Lincoln2_PlayCelebrateAtPosition(mkr_fort_a, 45)
						
						Util_StartIntel(EVENTS["Destroy_FrenchFort"])
						Objective_Complete(SOBJ_DestroyFortWest)
						
						Util_AutoSave()
					end
					
				else
					Music_PlayStinger("sfx_campaign_scripted_ui_objective_counter_update")
					Lincoln2_PlayCelebrateAtPosition(Util_GetPosition(victim), 15)
				end
			end
		end
		
		
		if not Objective_IsComplete(SOBJ_DestroyFortEast) and Objective_IsStarted(SOBJ_DestroyFortEast) then
			
			local current_count_b = EGroup_CountSpawned(eg_fort_b) + EGroup_CountSpawned(eg_french_outposts_b)
			
			if current_count_b < fort_prev_count_b then
				
				fort_prev_count_b = current_count_b
				fort_destroyed_count_b = fort_init_count_b - current_count_b
				Objective_SetCounter(SOBJ_DestroyFortEast, fort_destroyed_count_b, fort_init_count_b)
				
				if fort_destroyed_count_b >= fort_init_count_b then
					
					if Objective_IsComplete(SOBJ_DestroyFortWest) then
						
						Music_PlayStinger (MUS_STING_TRIUMPHANT)
						Lincoln2_PlayCelebrateAtPosition(mkr_fort_b, 45)
						
						Objective_Complete(SOBJ_DestroyFortEast, false)
						Objective_Complete(OBJ_DefeatFrench)
					else
						
						Music_PlayStinger(MUS_STING_POSITIVE)
						Lincoln2_PlayCelebrateAtPosition(mkr_fort_b, 45)
						
						Util_StartIntel(EVENTS["Destroy_FrenchFort"])
						Objective_Complete(SOBJ_DestroyFortEast)
						
						Util_AutoSave()
					end
					
				else
					Music_PlayStinger("sfx_campaign_scripted_ui_objective_counter_update")
					Lincoln2_PlayCelebrateAtPosition(Util_GetPosition(victim), 15)
				end
			end
		end
		
	elseif owner == playerRebels and not Objective_IsComplete(OBJ_DefeatRebels) then
		
		if Entity_IsOfType(victim, "military_production_building") and not Entity_IsOfType(victim, "monastery") then
			
			Lincoln2_PlayCelebrateAtPosition(Util_GetPosition(victim), 30)
			
			military_destroyed_count = military_destroyed_count + 1
			Objective_SetCounter(OBJ_DefeatRebels, military_destroyed_count, 6)
			
			if military_destroyed_count == 3 then
				Util_StartIntel(EVENTS["Military_Buildings_HalfwayDestroyed"])
				
				--if french objective not started, spawn initial french attack
				if not Objective_IsStarted(OBJ_DefeatFrench) then
					Rule_AddOneShot(Lincoln2_InitFrenchAttack, 10)
				end
				
			elseif military_destroyed_count == 5 then
				Util_StartIntel(EVENTS["Last_MilitaryBuilding_UnderAttack"])
			end
			
			Lincoln2_CheckStrongpoints()
			
			for index, entry in pairs(buildingHints) do 	
				if entry.id == Entity_GetID(victim) then
					
					--HintPoint_Remove(entry.hint)
					Objective_RemoveUIElements(OBJ_DefeatRebels, entry.hpid)
					UI_DeleteMinimapBlip(entry.blip)
				end
			end
			
			if military_destroyed_count == 6 then
				Objective_Complete(OBJ_DefeatRebels)
			else
				Music_PlayStinger("sfx_campaign_scripted_ui_objective_counter_update")
			end
			
		end
		
	end
end

function Lincoln2_CheckKeep()
	
	if keep_damaged == false then
		
		if Entity_GetHealthPercentage(entity_keep) < 1 then
			Sound_Play2D(MUS_STINGER_WARNING)
			keep_damaged = true
			Objective_Start(OBJ_DefendKeep, true)
			--Util_StartIntel(EVENTS["Keep_Warning"])
		end
	elseif keep_at_half == false then
		
		if Entity_GetHealthPercentage(entity_keep) < 0.5 then
			keep_at_half = true
			Util_StartIntel(EVENTS["Keep_Halfway"])
			Rule_RemoveMe()
		end
	end
	
end

function Lincoln2_InitDebugComplete()
	OBJ_DebugComplete = {
        Title = LOC("Debug Complete"),
        Type = OT_Primary,
        showTitle = false,
        Cheat = function()
			Lincoln2_TriggerOutro()
	       end,
	    }

    Objective_Register(OBJ_DebugComplete)	
end


