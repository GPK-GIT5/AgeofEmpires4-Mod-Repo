import("MissionOMatic/MissionOMatic.scar")		
--
-- Mission Title and Date - Objective (i.e. Tribute 1375 - Collect Taxes objective)
--


--
-- TO USE THIS TEMPLATE:
-- 1. Decide on a prefix for this objective / section of the mission
-- 2. save this template as a new file in the same directory as your mission script - use "obj_<prefix>.scar" for the name 
-- 3. import this file into your main mission script with import("obj_<prefix>.scar")
-- 4. call the <prefix>_InitObjectives function from inside you main mission script's Mission_SetupVariables function
--

function Destroy_InitObjectives()		-- rename this function to use your prefix for this part of the mission

	OBJ_Destroy= {
	
		Title = "$11181620", -- Burn Bayeux 
		Type = ObjectiveType_Battle,
		OnStart = Destroy_OnStart,
		IsComplete = Destroy_IsComplete,
		OnComplete = Destroy_OnComplete,
	}
	
	OBJ_Rams = {
		
		Title = "$11181617", -- Build Rams
		Type = ObjectiveType_Build,
		StartAlongsideParent = false,
		showTitle = false,
		OnStart = Rams_OnStart,
		IsComplete = Rams_IsComplete,
		OnComplete = Rams_OnComplete,
	}
	
	SOBJ_Blacksmith = {
		
		Title = "$11193892", -- Build a Blacksmith
		Type = ObjectiveType_Build,
		Parent = OBJ_Rams,
		StartAlongsideParent = false,
		showTitle = true,
		--SetupUI = Pallisade_SetupUI,
		--OnStart = Rams_OnStart,
		IsComplete = Blacksmith_IsComplete,
		--PreComplete = Siege_PreComplete,
		OnComplete = Blacksmith_OnComplete,
	}
	
	SOBJ_SiegeEngineer = {
		
		Title = "$11193893", -- Purchase the Siege Engineer Upgrade
		Type = ObjectiveType_Build,
		Parent = OBJ_Rams,
		StartAlongsideParent = false,
		--SetupUI = Pallisade_SetupUI,
		OnStart = SiegeEngineer_OnStart,
		IsComplete = SiegeEngineer_IsComplete,
		--PreComplete = Siege_PreComplete,
		OnComplete = SiegeEngineer_OnComplete,
	}
	
	SOBJ_BuildSiege = {
		
		Title = "$11193894", -- Use infantry to construct rams
		Type = ObjectiveType_Build,
		Parent = OBJ_Rams,
		StartAlongsideParent = false,
		--SetupUI = Pallisade_SetupUI,
		OnStart = BuildSiege_OnStart,
		IsComplete = BuildSiege_IsComplete,
		--PreComplete = Siege_PreComplete,
		--OnComplete = BuildSiege_OnComplete,
	}
	
	SOBJ_Breach = {
		
		Title = "$11181621", -- Breach the Walls
		Type = ObjectiveType_Battle,
		Intel_Complete = EVENTS.Inside_Bayeux,
		Parent = OBJ_Destroy,
		StartAlongsideParent = false,
		SetupUI = Breach_SetupUI,
		--OnStart = Weakness_OnStart,
		--IsComplete = Siege_IsComplete,
		--PreComplete = Siege_PreComplete,
		OnComplete = Breach_OnComplete,
		Sound_Play2D("sfx_campaign_scripted_large_group_celebrate")
	}
	
	SOBJ_Defenders  = {
		
		Title = "$11181616", -- Defeat the City Defenders
		Type = ObjectiveType_Battle,
		Parent = OBJ_Destroy,
		StartAlongsideParent = false,
		SetupUI = Defenders_SetupUI,
		--OnStart = Siege_OnStart,
		--IsComplete = Siege_IsComplete,
		--PreComplete = Siege_PreComplete,
		--OnComplete = Siege_OnComplete,
	}
	
	SOBJ_BurnBuildings  = {
		
		Title = "$11181618", --Destroy Bayeux buildings
		Type = OT_Secondary,
		Parent = OBJ_Destroy,
		StartAlongsideParent = false,
		--SetupUI = Defenders_SetupUI,
		--OnStart = Siege_OnStart,
		--IsComplete = Siege_IsComplete,
		--PreComplete = Siege_PreComplete,
		--OnComplete = Siege_OnComplete,
	}
	
	OBJ_DebugComplete = {
		Title = LOC("Debug Complete"),
		Type = OT_Primary,
		showTitle = false,
		Cheat = function()
			Mission_Complete()
		end,
	}
	
	OBJ_VideoCapture = {
		Title = LOC("Video Capture"),
		Type = OT_Primary,
		showTitle = false,
		IsSecret = true,
		Cheat = function()
			
			b_debugStart = true
			
			SGroup_DestroyAllSquads(villagerlife_woodtown.sg_villagers)
			SGroup_DestroyAllSquads(sg_defend_wood)
						
			Location_SetCapturable(LOCATION("WoodTown"), true)
			Location_Capture(LOCATION("WoodTown"), player1)
			
			vidcap_ExtraHouses = AllMarkers_FromName("mkr_vidcapture_house", "")
			
			for i, house in pairs(vidcap_ExtraHouses) do
				EGroup_Clear(eg_temp)
				Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_HOUSE_CONTROL_ENG, house, 1)
			end
			
			Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_TECH_UNIT_INFANTRY_CONTROL_ENG, mkr_vidcapture_blacksmith, 1)
			Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_UNIT_INFANTRY_CONTROL_ENG, mkr_vidcapture_barracks, 1)
			Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_UNIT_RANGED_CONTROL_ENG, mkr_vidcapture_archery, 1)
			Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_UNIT_CAVALRY_CONTROL_ENG, mkr_vidcapture_stables, 1)
			
			Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_MELEE_ARMOR_I)
			Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_MELEE_DAMAGE_I)
			Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_SIEGE_ENGINEERS)
			Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_2)
			Player_CompleteUpgrade(player1, UPG.ENGLISH.UPGRADE_UNIT_MANATARMS_2_ENG)
				
			UnitEntry_DeploySquads(player1, {sg_player_scouts, sg_player_army}, {type = "scar_scout", numSquads = 1,}, mkr_vidcapture_debug) 
			UnitEntry_DeploySquads(player1, {sg_player_archers_setup, sg_player_army}, {type = "scar_archer", numSquads = 30,}, mkr_vidcapture_debug)
			UnitEntry_DeploySquads(player1, {g_leaderHenry.sgroup, sg_player_henry, sg_player_army}, {sbp = SBP.ENGLISH.UNIT_KING_HENRY_CMP_ENG, numSquads = 1,}, mkr_vidcapture_debug)
			UnitEntry_DeploySquads(player1, {sg_player_archers_setup, sg_player_army}, {type = "scar_manatarms", numSquads = 16,}, mkr_vidcapture_debug)
			UnitEntry_DeploySquads(player1, {sg_player_archers_setup, sg_player_army}, {type = "scar_spearman", numSquads = 30,}, mkr_vidcapture_debug)
			UnitEntry_DeploySquads(player1, {sg_player_archers_setup, sg_player_army}, {type = "scar_ram", numSquads = 4,}, mkr_vidcapture_debug)
			UnitEntry_DeploySquads(player1, {sg_player_archers_setup, sg_player_army}, {type = "scar_siege_tower", numSquads = 2,}, mkr_vidcapture_debug)
			
			Objective_Start(OBJ_Destroy, false)
			Objective_Start(SOBJ_Breach, false)
					
			Rule_Remove(PlayerDeath_PreTown, 1)	
			Rule_AddInterval(PlayerDeath_PostTown, 1)
			
			Rule_AddEGroupEvent(Advance_OnEntityKilled, eg_bayeux_walls, GE_EntityKilled)
			Rule_AddEGroupEvent(Advance_OnEntityDamage, eg_bayeux_town, GE_DamageReceived)
			Rule_AddInterval(BayeuxBurning, 1)	
			
			Rule_Exists(Advance_OnEntityKilled)
			
			EGroup_Kill(eg_bridge_die)

			Music_StopMedium()
			villager_RespawnLocation = villagerlife_woodtown.mkr_flee
			
			SGroup_Clear(sg_temp)
			UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerlife_woodtown.roaming_count},villager_RespawnLocation)
			Cmd_Move(sg_temp, villagerlife_woodtown.location_mkr)
			SGroup_Clear(sg_temp)
			UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerlife_woodtown.food_count}, villager_RespawnLocation)
			AssignVillagersToFarms(sg_temp)
			SGroup_Clear(sg_temp)
			UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerlife_woodtown.wood_count}, villager_RespawnLocation)
			AssignVillagersToWood(sg_temp)
			SGroup_Clear(sg_temp)
			UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerlife_woodtown.stone_count}, villager_RespawnLocation)
			AssignVillagersToStone(sg_temp)
			SGroup_Clear(sg_temp)
			UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerlife_woodtown.gold_count}, villager_RespawnLocation)
			AssignVillagersToGold(sg_temp)
			
			Player_AddResources(player1, {gold = 500, wood = 1000, food = 500, stone = 0,})
			--RochesterSupply_Init()
			
			UI_SetPlayerDataContext(player1, { PopulationCapOn = true })
			
			Camera_FocusOnPosition(Util_GetPosition(mkr_vidcapture_debug))
			
		end,
	}
			
	Objective_Register(OBJ_Destroy)
	Objective_Register(OBJ_Rams)
	Objective_Register(SOBJ_Blacksmith)
	Objective_Register(SOBJ_SiegeEngineer)
	Objective_Register(SOBJ_BuildSiege)
	Objective_Register(SOBJ_Breach)
	Objective_Register(SOBJ_BurnBuildings)
	Objective_Register(SOBJ_Defenders)	
	
	Objective_Register(OBJ_DebugComplete)
	Objective_Register(OBJ_VideoCapture)
	
	
end

function Destroy_OnStart()
	--local attackWave = Init_Cavalry_Attackwave()
	--hint_wave = HintPoint_Add(attackWave.sgroup, true, 11179202, 5, HPAT_Attack, "icons/threat_group_arrow", nil, true, nil)
	--blip_wave = UI_CreateMinimapBlip(attackWave.sgroup, -1, "threat_group")
	Bayeux_Icon = Objective_AddUIElements(OBJ_Destroy, mkr_bayeux_middle, true, 11181619, true, 5) -- Bayeux
	
	Rule_AddOneShot(MissionTutorial_AttackMove, 15)
	
	
	if b_debugStart == false then
		Reinforce_Archers(mkr_player_reinforce, mkr_player_reinforce_dest, true)
		Rule_AddInterval(Bayeux_Walls_Spotted, 1)
		Rule_AddInterval(Bayeux_Gate_Spotted, 1)
	else
		Reinforce_Archers(mkr_vidcapture_debug, mkr_vidcapture_debug, false)
	end
		
end

function Destroy_IsComplete()
	if Objective_IsComplete(SOBJ_BurnBuildings) and Objective_IsComplete(SOBJ_Defenders) then
		return true
	end
end

function Destroy_OnComplete()
	Mission_Complete()
end

function Defenders_SetupUI()
	if Rule_Exists(Bayeux_Walls_Spotted) then
		Rule_Remove(Bayeux_Walls_Spotted)
	end
	
	if Objective_IsStarted(SOBJ_BuildSiege) and Objective_IsStarted(OBJ_Rams) then
		Objective_Stop(SOBJ_BuildSiege)
		Objective_Stop(OBJ_Rams)
	end
end

function Rams_OnStart()
	Util_StartIntel(EVENTS.BatteringRams_Start_Part2)
end

function Blacksmith_IsComplete()
	Player_GetAll(player1)
	EGroup_Filter(eg_allentities, EBP.ENGLISH.BUILDING_TECH_UNIT_INFANTRY_CONTROL_ENG, FILTER_KEEP)
	EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
	return EGroup_CountSpawned(eg_allentities) > 0	
end

function Blacksmith_OnComplete()
	Util_StartIntel(EVENTS.BlacksmithDone)
	Objective_Start(SOBJ_SiegeEngineer, true)
end

function SiegeEngineer_OnStart()
	if UI_IsXboxControllerUI() then
		MissionTutorial_SiegeEngineer_Xbox()
	else
		MissionTutorial_SiegeEngineer()
	end
end

function SiegeEngineer_IsComplete()
	return Player_HasUpgrade(player1, BP_GetUpgradeBlueprint("upgrade_siege_engineers"))	
end

function SiegeEngineer_OnComplete()
	Util_StartIntel(EVENTS.SiegeyDone)
	Objective_Start(SOBJ_BuildSiege, true)
end

function BuildSiege_OnStart()
	MissionTutorial_Ram()
end

function BuildSiege_IsComplete()
	Player_GetAll(player1)
	SGroup_Filter(sg_allsquads, "scar_ram", FILTER_KEEP)
	local int_ramsBuilt = 0
	int_ramsBuiltLastCount = int_ramsBuiltLastCount or 0
	
	local _IsBuilt = function(gid, index, sid)
		if Entity_GetBuildingProgress(Squad_GetFirstEntity(sid)) >= 1 then
			int_ramsBuilt = int_ramsBuilt+1
		end
	end
	SGroup_ForEach(sg_allsquads, _IsBuilt)
		
	if int_ramsBuiltLastCount ~= int_ramsBuilt then
		int_ramsBuiltLastCount = int_ramsBuilt
		Sound_Play2D("sfx_campaign_scripted_ui_objective_counter_update")
		Modifier_Remove(mod_towerDMG)
		Modifier_Remove(mod_towerARM)
		Modifier_Remove(mod_gateARM)
	end
	
	if int_ramsBuilt >= 3 then
		Bayeux_Icon = Objective_AddUIElements(OBJ_Destroy, mkr_bayeux_middle, true, 11181619, true, 5) -- Bayeux
		return true		
	end
	Objective_SetCounter(SOBJ_BuildSiege, int_ramsBuilt, 3)	
	
end

function Rams_IsComplete()
	if Objective_IsStarted(SOBJ_Blacksmith) and Objective_IsStarted(SOBJ_SiegeEngineer) and Objective_IsStarted(SOBJ_BuildSiege) then
		return Objective_AreSubObjectivesComplete(OBJ_Rams, true)
	end
end

function Rams_OnComplete()
	Util_AutoSave()
	Util_StartIntel(EVENTS.BatteringRams_Complete)
	if Objective_IsStarted(SOBJ_Defenders) ~= true and Objective_IsStarted(SOBJ_BurnBuildings) ~= true then
		Objective_Start(SOBJ_Breach, true)
	end
	Rule_Remove(Bayeux_Gate_Spotted)
end

function Breach_SetupUI()
	wallMarker = Objective_AddUIElements(SOBJ_Breach, mkr_wall_hint_1, true, 11181621, true, 5) -- Burn the Gate
end

function Breach_OnComplete()
	Objective_RemoveUIElements(SOBJ_Breach, wallMarker)
end

function Bayeux_Walls_Spotted()

	if (Player_CanSeeEGroup(player1, eg_bayeux_walls, ANY) and EGroup_IsOnScreen(player1, eg_bayeux_walls, ANY, 0.7)) or 
		Player_AreSquadsNearMarker(player1, mkr_bridge) then
		Rule_RemoveMe()
		b_wallsSpotted = true
		Util_StartIntel(EVENTS.Stone_Wall)
	end
end

function Bayeux_Gate_Spotted()
	
	if Player_CanSeeEGroup(player1, eg_bayeux_gates, ANY) and EGroup_IsOnScreen(player1, eg_bayeux_gates, ANY, 0.7)  then
		Rule_RemoveMe()
		Util_StartIntel(EVENTS.Gate_Visibility)
	end
end

function Defenders_Track()
	--Player_GetAll(player2)
	--SGroup_Filter(sg_allsquads, {"scar_archer", "scar_spearman"}, FILTER_KEEP)
	sg_unitsinbayeux = SGroup_CreateIfNotFound("sg_unitsinbayeux")
	Player_GetAllSquadsNearMarker(player2, sg_unitsinbayeux, mkr_town_bayeux, 140)
	SGroup_Intersection(sg_unitsinbayeux, sg_bayeux_defenders)
	
	local countDefenders = SGroup_CountSpawned(sg_unitsinbayeux)

	count_TotalDefenders = count_TotalDefenders or countDefenders

	--Objective_SetCounter(SOBJ_Defenders, (count_TotalDefenders-countDefenders), count_TotalDefenders)
	Obj_SetProgress(SOBJ_Defenders.ID, 1-(countDefenders/count_TotalDefenders))
	
	if countDefenders <= 0 then
		Rule_RemoveMe()
		Objective_Complete(SOBJ_Defenders)
		Obj_SetProgressVisible(SOBJ_Defenders.ID, false)
		Util_StartIntel(EVENTS.Defeat_Defenders_Complete)
	end
end
