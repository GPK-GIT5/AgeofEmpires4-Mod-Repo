function Reinforce_Archers(markerSpawn, markerDestination, cta_bool)
	SGroup_Duplicate(sg_player_army, sg_temp)
	SGroup_Filter(sg_temp, "scar_archer", FILTER_KEEP)
	local archerCount = 0
	archerCount = SGroup_CountSpawned(sg_temp)
	archerCount = t_difficulty.playerArchers-archerCount
	
	--local options = {destination = sg_player_henry}
	
	local units = {
		{type = "scar_scout", numSquads = 3,},
		{type = "scar_spearman", numSquads = t_difficulty.playerSpearmen,},
	}
	
	if archerCount > 0 then
		table.insert(units, {type = "scar_archer", numSquads = archerCount,})
	end
	
	Util_AutoSave()
	
	UnitEntry_DeploySquads(player1, {sg_player_archers_reup, sg_player_army}, units, markerSpawn)
	if cta_bool == true then
		EventCues_CallToAction(11176787, CTA_CELEBRATE, EVENTS.Cavalry_Down, nil, sg_player_archers_reup, 20) --Reinforcements have arrived!
		Sound_Play2D(MUS_STING_TRIUMPHANT)
		Sound_PlayWallaCelebrateOnSGroup(sg_player_army)
	end
	Cmd_FormationMove(sg_player_archers_reup, markerDestination)
	
	--Initialize some field training after the first combat is complete
	--MissionTutorial_FogOfWar()
	MissionTutorial_HeightAdvantage()
	Rule_AddInterval(PlayerRush, 15)
	
	-- Only show control group tutorial for players on lower difficulty settings and using keyboard input
	if Game_GetSPDifficulty() <= GD_HARD and UI_IsXboxControllerUI() == false then
		ControlGroup_Check()
	end
end

function Cavalry_Cleared()
	Sound_PlayWallaCelebrateOnSGroup(sg_player_army)
	Music_StopMedium()
	Rule_AddOneShot(Music_CombatMusicOnly, 1)
	Objective_Start(OBJ_Destroy)
	Init_Cavalry_Defenders()
	if Game_GetSPDifficulty() > GD_EASY then --disable idle attacks for story mode
		Rule_AddInterval(IdleAttack, 15)
	end
end

function UpdateCavalry()
	if SGroup_CountSpawned(sg_player_army) > 0 then
		RovingArmy_SetTarget(MissionOMatic_FindModule("cavalry_wave"), Util_GetPosition(SGroup_GetSquadAt(sg_player_army, 1)))
	end
end

function Init_Cavalry_Attackwave()
	local moduleData = 
	{
		type = "RovingArmy",
		descriptor = "cavalry_wave",
		player = player2,
		sgroup = sg_cavalry_attack,
		targetingType = ARMY_TARGETING_DISCARD,
		targets = {
			mkr_cavalry_target,
		},			
		spawnLocation = mkr_field_cavalry_spawn,
		withdrawThreshold = 0,
		onCompleteFunction = UpdateCavalry,
		onDeathFunction = Cavalry_Cleared,
		units = 
		{
			{type = "scar_knight", numSquads = 1},
			{type = "scar_horseman", numSquads = 15},
		},
	}
	RovingArmy_Init(moduleData)
	Rule_AddInterval(CavalryAudioTrigger_2, 0.5)
end

function Init_Cavalry_Defenders()
	
	for i, entry in pairs(rovingArmy_DefendPositions) do
		local modName = ("cavalry_defense_"..i)
		local moduleData = 
		{
			type = "RovingArmy",
			descriptor = modName,
			player = player2,
			targetingType = ARMY_TARGETING_REVERSE,
			targets = entry.patrol,		
			spawnLocation = entry.spawn,
			withdrawThreshold = 0.45,
			fallbacks = {
				{marker = mkr_bayeux_cavalry_withdraw},
			},
			idleTime = 4,
			leashRange = 400,
			--onWithdrawFunction = function()
				--DissolveModuleIntoModule(modName, "defend_bayeux_walls")
			--end,
			--onCompleteFunction = UpdateCavalry,
			units = 
			{
				{type = "scar_knight", numSquads = t_difficulty.enemyKnights},
				{type = "scar_horseman", numSquads = t_difficulty.enemyCavalry},
			},
		}
		_G["Bayeux_Cavalry_Defender_"..i] = RovingArmy_Init(moduleData)
		table.insert(t_AllCavalryModules, _G["Bayeux_Cavalry_Defender_"..i])
		--Cmd_FormationMove(_G["Bayeux_Cavalry_Defender_"..i].sgroup, marker)
		--Cmd_HoldPosition(_G["Bayeux_Cavalry_Defender_"..i].sgroup, marker, true)
	end
end

function Init_Archer_Defenders()
	
	for i, marker in pairs(archers_DefendPositions) do
		local modName = ("archers_"..i)
		local moduleData = 
		{
			type = "Defend",
			descriptor = modName,
			player = player2,
			marker = marker,		
			spawnLocation = mkr_bayeux_defender_spawn,
			units = 
			{
				{type = "scar_archer", numSquads = t_difficulty.archerAmounts, sgroup = sg_bayeux_defenders},
			},
		}
		_G["Bayeux_Archers_"..i] = Defend_Init(moduleData)
		table.insert(t_AllArcherDefenders, _G["Bayeux_Archers_"..i])
		--table.insert(t_bayeux_extra_infantry, _G["Bayeux_Archers_"..i])
		Cmd_HoldPosition(_G["Bayeux_Archers_"..i].sgroup, true)
		Cmd_Ability(_G["Bayeux_Archers_"..i].sgroup, BP_GetAbilityBlueprint("core_formation_spread"))
	end
end

function ClearArchers()
	for i = #t_AllArcherDefenders, 1, -1 do
		local module = t_AllArcherDefenders[i]
		if module ~= nil and SGroup_CountSpawned(module.sgroup) > 0 then
			if Player_CanSeeSGroup(player1, module.sgroup, ANY) == false then
				SGroup_DestroyAllSquads(module.sgroup)
				if SGroup_CountSpawned(module.sgroup) <= 0 then
					table.remove(t_AllArcherDefenders, i)
				end
			end
		end
	end
end

function Init_Infantry_Defenders()
	
	for i, marker in pairs(infantry_DefendPositions) do
		local modName = ("infantry_"..i)
		local moduleData = 
		{
				type = "RovingArmy",
				descriptor = modName,
				player = player2,
				targetingType = ARMY_TARGETING_DISCARD,
				targets = {
					marker
				},			
				spawnLocation = mkr_bayeux_defender_spawn,
				units = 
				{
					{type = "scar_spearman", numSquads = t_difficulty.gateDefenders.spearmanCount, sgroup = sg_bayeux_defenders},
					{type = "scar_archer", numSquads = t_difficulty.gateDefenders.archerCount, sgroup = sg_bayeux_defenders},
				},
		}
		_G["Bayeux_infantry_"..i] = RovingArmy_Init(moduleData)
		table.insert(t_bayeux_extra_infantry, _G["Bayeux_infantry_"..i])
	end
end

function Init_Infantry_Extra_Defenders()
	t_extraInfantryLocations = AllMarkers_FromName("mkr_bayeux_extra_infantry", "")
	t_spawnOptions = AllMarkers_FromName("mkr_bayeux_defender_hiddenspawnoption", "")
	
	local function spawnCheck()
		for i = 1, #t_spawnOptions do
			if Player_CanSeePosition(player1, Util_GetPosition(t_spawnOptions[i])) ~= true then
				return t_spawnOptions[i]
			else
				return t_spawnOptions[1]
			end
		end
		
	end
	
	for i, marker in pairs(t_extraInfantryLocations) do
		local modName = ("extra_infantry_"..i)
		local moduleData = 
		{
				type = "RovingArmy",
				descriptor = modName,
				player = player2,
				targetingType = ARMY_TARGETING_DISCARD,
				targets = {
					{ marker = marker, combatRange = tune_CombatRange, leashRange = tune_LeashRange},
				},			
				spawnLocation = spawnCheck(),
				units = 
				{
					{type = "scar_spearman", numSquads = t_difficulty.gateDefenders.spearmanCount/2, sgroup = sg_bayeux_defenders},
					{type = "scar_archer", numSquads = t_difficulty.gateDefenders.archerCount/2, sgroup = sg_bayeux_defenders},
				},
		}
		_G["Bayeux_extra_infantry_"..i] = RovingArmy_Init(moduleData)
		table.insert(t_bayeux_extra_infantry, _G["Bayeux_extra_infantry_"..i])
	end
end

function Clear_ExtraDefenders()
	Player_GetAllSquadsNearMarker(player2, sg_temp, mkr_bayeux_infantry_2)
		if Player_CanSeeSGroup(player1, sg_temp, ANY) == false and SGroup_CountSpawned(sg_temp) then
				SGroup_DestroyAllSquads(sg_temp)
		end
	Player_GetAllSquadsNearMarker(player2, sg_temp, mkr_bayeux_infantry_1)
		if Player_CanSeeSGroup(player1, sg_temp, ANY) == false and SGroup_CountSpawned(sg_temp) then
				SGroup_DestroyAllSquads(sg_temp)
		end
end


