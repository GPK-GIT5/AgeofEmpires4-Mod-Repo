function WallDie()
	Player_GetAllEntitiesNearMarker(player2, eg_killwall, mkr_wall_die)
	EGroup_Filter(eg_killwall, "stone_wall", FILTER_KEEP)
	EGroup_Kill(eg_killwall)
end


function PlayerDeath_PreTown()
	SGroup_Duplicate(sg_player_army, sg_temp)
	SGroup_Filter(sg_temp, SBP.ENGLISH.UNIT_KING_HENRY_CMP_ENG, FILTER_REMOVE)
	local playerCount = SGroup_CountSpawned(sg_temp)
	if playerCount <= 0 then 
		Mission_Fail()
	end
end

function PlayerDeath_PostTown()
	if EGroup_CountSpawned(eg_playerbase) <= 0 then 
		Mission_Fail()
	end
end

--[[
PlayerUpgrades_LockAllUpgrades(player2, 3)
]]

function IdleAttack()
	sg_idletarget = SGroup_CreateIfNotFound("sg_idletarget") 
	sg_idleattackers = SGroup_CreateIfNotFound("sg_idleattackers") 
	Player_GetAll(player1, sg_idletarget)
	SGroup_Filter(sg_idletarget, "scar_villager", FILTER_REMOVE)
		
	if SGroup_CountSpawned(sg_idletarget) > 0 then
		local pokeModule = nil
		if SGroup_IsUnderAttack(sg_idletarget, ANY, t_difficulty.idleattacktimer*60) ~= true then
			if #t_AllCavalryModules > 0 then
				for i = #t_AllCavalryModules, 1, -1 do
					if SGroup_CountSpawned(t_AllCavalryModules[i].sgroup) <= 0 or t_AllCavalryModules[i].isWithdrawn == true then
						table.remove(t_AllCavalryModules,i)
					else
						if pokeModule == nil or 
							Util_GetDistanceSquared(pokeModule.sgroup, sg_idletarget) > Util_GetDistanceSquared(t_AllCavalryModules[i].sgroup, sg_idletarget) then
							pokeModule = t_AllCavalryModules[i]
						end
					end
				end
			elseif SGroup_CountSpawned(sg_idleattackers) <= 0 then
				NewAtackerGroup(sg_idletarget)
			end
			
			if pokeModule ~= nil and SGroup_CountSpawned(pokeModule.sgroup) > 0 and SGroup_CountSpawned(sg_idletarget) > 0 then
				RovingArmy_SetTarget(pokeModule, sg_idletarget)
				pokeModule.targetingType = ARMY_TARGETING_DISCARD
				if b_idleIntelPlayed == false then
					b_idleIntelPlayed = true
					Util_StartIntel(EVENTS.Robert_Attack)
					Rule_AddInterval(IdlePoke_IsDead, 1, {module = pokeModule})
				end
			end
		end
	elseif Objective_IsComplete(OBJ_CaptureVillage) and SGroup_CountSpawned(sg_idleattackers) <= 0 then
		NewAtackerGroup(mkr_location_wood)
	end
end

function NewAtackerGroup(target)
	i_spearPokeWaveNumber = i_spearPokeWaveNumber or 0
	local stringPokeDescription = "PokeWave_"..i_spearPokeWaveNumber
	sg_idleattackers = SGroup_CreateIfNotFound("sg_idleattackers") 
	local moduledata = 
	{
		type = "RovingArmy",
		descriptor = stringPokeDescription,
		player = player2,
		targetingType = ARMY_TARGETING_DISCARD,
		targets = {
			target,	
			mkr_location_wood,
		},	
		units = {
			{type = "scar_spearman", numSquads = 20, sgroup = sg_idleattackers},
		},	
		spawnLocation = mkr_bayeux_archer_spawn,
		attackMove = attackMoveStyle_attackEverything,
		onDeathDissolve = true,
		onCompleteFunction = IdleAttack,

	}	
	local attackwaveModule = RovingArmy_Init(moduledata)
	table.insert(t_AllCavalryModules, attackwaveModule)
	i_spearPokeWaveNumber = i_spearPokeWaveNumber+1
end

function IdlePoke_IsDead(context, data)
	if data.module.sgroup ~= nil then
		if SGroup_CountSpawned(data.module.sgroup) <= 0 then
			Rule_RemoveMe()
			IdleAttack_DeadIntel()
		elseif data.module.isWithdrawn then
			Rule_RemoveMe()
			Rule_AddOneShot(IdleAttack_DeadIntel, 8)
		end
	end
end

function IdleAttack_DeadIntel()
	Util_StartIntel(EVENTS.Robert_Attack_Completed)
end

function PushAttack()
	sg_pushtarget = SGroup_CreateIfNotFound("sg_pushtarget") 
	Player_GetAllSquadsNearMarker(player1, sg_pushtarget, mkr_town_bayeux)
	
	if SGroup_CountSpawned(sg_pushtarget) > 0 then
		local pushModule = nil
		local finali = 0
		if #t_bayeux_extra_infantry > 0 then
			for i = #t_bayeux_extra_infantry, 1, -1 do
				if SGroup_CountSpawned(t_bayeux_extra_infantry[i].sgroup) <= 0 then
					table.remove(t_bayeux_extra_infantry,i)
					if finali >= i then 
						finali = finali-1
					end
				else
					if pushModule == nil or 
						Util_GetDistanceSquared(pushModule.sgroup, sg_pushtarget) > Util_GetDistanceSquared(t_bayeux_extra_infantry[i].sgroup, sg_pushtarget) then
						pushModule = t_bayeux_extra_infantry[i]
						finali = i
					end
				end
			end
		end
		
		if pushModule ~= nil and SGroup_CountSpawned(pushModule.sgroup) > 0 and SGroup_CountSpawned(sg_pushtarget) > 0 then
			RovingArmy_SetTargets(pushModule, {sg_pushtarget, mkr_town_bayeux})
			table.remove(t_bayeux_extra_infantry, finali)
		end
	end
end

function PlayerRush()
	if SGroup_CountSpawned(sg_player_army) < 5 and SGroup_CountSpawned(sg_player_army) > 0 then
		for index, module in pairs(t_allModules) do
			if SGroup_CountSpawned(module.sgroup) > 0 then
				if module.prefabName == "RovingArmy" then
					RovingArmy_SetTarget(module, sg_player_army)
				else
					Prefab_DoAction(module, "Stop")
					Cmd_AttackMove(module.sgroup, sg_player_army)
				end
			end
		end	
	end	
end

function VillagerFlee()
	Player_GetAllEntitiesNearMarker(player2, eg_temp, mkr_town_bayeux)
	EGroup_Filter(eg_temp, "defensive_structure", FILTER_REMOVE)
	if EGroup_CountSpawned(eg_temp) > 5 then 
		SGroup_Clear(sg_temp)
		UnitEntry_DeploySquads(player2, sg_temp, {type = "scar_villager", numSquads = World_GetRand(1, 3)}, Util_GetPosition(EGroup_GetRandomSpawnedEntity(eg_temp)))
		Modify_UnitSpeed(sg_temp, 1.3, -1)
		Cmd_MoveToAndDestroy(sg_temp, Table_GetRandomItem({mkr_villager_flee1, mkr_villager_flee2, mkr_villager_flee3}))
		if World_GetRand(1, 20) > 18 then
			Sound_PlayOnSquad(WALLA_CAMP_FEAR_SMALL, sg_temp)
		end
		Rule_AddOneShot(VillagerFlee, World_GetRand(20, 45))
	end
end

function TowerDeathAudio()
	towerCount = towerCount or 2
	if EGroup_CountSpawned(eg_bridge_towers) <= 0 then
		Rule_RemoveMe()
		--Sound_Play2D(MUS_STING_POSITIVE)
		Sound_PlayWallaCelebrateOnSGroup(sg_player_army)
	elseif EGroup_CountSpawned(eg_bridge_towers) ~= towerCount then
		towerCount = EGroup_CountSpawned(eg_bridge_towers)
		--Sound_Play2D(MUS_STING_POSITIVE)
		Sound_PlayWallaCelebrateOnSGroup(sg_player_army)
	end
end

function AudOnFromPoint(player, pos, audString)
    local size = ""
   
    SGroup_Clear(sg_temp)
   
    Player_GetAllSquadsNearMarker(player, sg_temp, pos, 50)
    SGroup_Filter(sg_temp, SBP.GAIA.GAIA_HERDABLE_SHEEP, FILTER_REMOVE)
   
    unitCount = SGroup_CountSpawned(sg_temp)
   
    if unitCount <= 5 then
        return
    else
        if unitCount > 5 and unitCount <= 10 then
            size = "SMALL"
        elseif unitCount > 10 and unitCount <= 20 then
            size = "MEDIUM"
        else
            size = "LARGE"
        end
        Sound_PlayOnSquad(_G[audString..size], sg_temp)
    end
end

function CleanUp_Cavalry()
	for i = #t_AllCavalryModules, 1, -1 do
		if Player_CanSeeSGroup(player1, t_AllCavalryModules[i].sgroup, ANY) ~= true then
			SGroup_DestroyAllSquads(t_AllCavalryModules[i].sgroup)
		else
			DissolveModuleIntoModule(t_AllCavalryModules[i].descriptor, "defend_bayeux_walls")
			table.remove(t_AllCavalryModules,i)
		end	
	end
end

----DEBUG BAYEUX HEALTH

function ShowBayeuxHealth()
	local currentHealth = EGroup_GetTotalHealth(eg_bayeux_town)
	view(currentHealth.."/"..bayeuxHealthTotal.." - "..((currentHealth/bayeuxHealthTotal)*100))
	Rule_AddOneShot(ShowBayeuxHealth, 1)
end
	