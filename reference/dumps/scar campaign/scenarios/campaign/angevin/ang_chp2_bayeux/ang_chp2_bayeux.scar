function Mission_Preset()	-- any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)
		
	Destroy_InitObjectives()
	CaptureVillage_InitObjectives()
	ControlGroup_InitObjectives()

	-- Audio considerations
	Sound_SetMusicRaceCode("french")
	
	Sound_ResetMusicIntensityMapping();
	Sound_AddMusicIntensityMappingPoint(10, 300) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(350, 4500) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(700, 9999) -- raw value max to scaled value max 
			
	--Player_GetAll(player1)
	--SGroup_Filter(sg_allsquads, SBP.ENGLISH.UNIT_KING_HENRY_CMP_ENG, FILTER_REMOVE, sg_player_henry)
	
	--Outposts get archers
	Player_GetAll(player2)
    EGroup_Filter(eg_allentities, EBP.FRENCH.BUILDING_DEFENSE_OUTPOST_FRE, FILTER_KEEP)
    Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	
	--Towers get Springalds
	Player_GetAll(player2)
    EGroup_Filter(eg_allentities, EBP.FRENCH.BUILDING_DEFENSE_TOWER_FRE, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_TOWER_ARROWSLITS)
	mod_towerDMG = Modify_WeaponDamage(eg_allentities, "hardpoint_01", 1) --Previous value: 2
	mod_towerRNG = Modify_WeaponRange(eg_allentities, "hardpoint_01", 0.6)
	mod_towerARM = Modify_ReceivedDamage(eg_allentities, 1) --Previous value: 0.001
	mod_gateARM = Modify_ReceivedDamage(eg_bayeux_gates, 1) --Previous value: 0.001
	--Modify_EntityMaxHealth(eg_allentities, 100, MUT_Multiplication)
	--Modify_EntityMaxHealth(eg_bayeux_gates, 100, MUT_Multiplication)
	
	Init_Archer_Defenders()
	Init_Infantry_Defenders()
	
	--Player_CompleteUpgrade(player1, UPG.ENGLISH.UPGRADE_LONGBOW_MAKE_CAMP_ENG)
	
	--Kill the rear wall for art
	--WallDie()
	
	--[[Scar_AddInit(missionstart_OnInit)]]
	
	UI_SetPlayerDataContext(player1, { PopulationCapOn = false })
	UI_SetModalConstructionPhaseCallback(TrainingContructionCallback) -- callback used to track construction for training hint purposes

	
end

function Mission_PreStart()
	Player_SetResource(player1, RT_Wood, 0)
	Player_SetResource(player1, RT_Gold, 0)
	Player_SetResource(player1, RT_Food, 0)	
end

function Mission_Start()	-- this is triggered after the intro, just as control is passed to the player
	
	-- on console don't restore econ-related HUD elements at first
	Cardinal_EnablePartialXboxUI(true, {VF_XboxUIResourceCard, VF_XboxUIVillagerPriorities})
	
	--FOW_RevealAll()

	--AssignVillagersToFarms(sg_enemy_farmers)
	--MissionTutorial_Init()
	--Rule_AddEGroupEvent(SiegeCounter_OnDamageReceived, eg_bayeux_walls, GE_DamageReceived)
	Rule_AddEGroupEvent(Advance_OnEntityKilled, eg_bayeux_walls, GE_EntityKilled)
	Rule_AddEGroupEvent(Advance_OnEntityDamage, eg_bayeux_town, GE_DamageReceived)
	Rule_AddInterval(BayeuxBurning, 1)
	--TrainingGoal_AddHeightAdvantage()
	
	MissionTutorial_Palings()
	
	--DEBUG--
	--debugInfo ={Game_GetSPDifficulty()}
	--view(debugInfo)
	
	--Modify_EntityMaxHealth(eg_bayeux_gates, 100, MUT_Multiplication)
	EGroup_Kill(eg_bridge_die)
	SGroup_Kill(sg_robcorpse)	
	
	Rule_AddInterval(PlayerDeath_PreTown, 1)
	Rule_AddInterval(TowerDeathAudio, 1)
	
	SGroup_AddGroup(sg_bayeux_defenders, sg_wall_defenders)
end

function GetRecipe()

	local recipe = {

		audioSettings = { 
			campaignName = "ang",
			missionName = "rts1106bayeux",
		},

		introNIS = EVENTS.Intro,
		outroNIS = EVENTS.Victory,
		
		-- Locations
		locations = {
