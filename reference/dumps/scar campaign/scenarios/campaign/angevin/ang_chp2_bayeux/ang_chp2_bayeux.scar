--
-- Bayeux 1106
--
-- Norman campaign, Mission 3
--

import("MissionOMatic/MissionOMatic.scar")		-- this imports the Cardinal scripts as well
import("obj_destroy.scar")
import("obj_capturewood.scar")
import("obj_controlgroups.scar")

-- Training
import("training_bayeux.scar")

function Mission_SetupPlayers()
	
	player1 = World_GetPlayerAt(1) -- Normans
	player2 = World_GetPlayerAt(2) -- Robert's Forces
	player3 = World_GetPlayerAt(3) -- Downed Leader
	AI_Enable(player3, false)
		
	-- player 1 - Normans
	Setup_SetPlayerName(player1, "$11179198") --Henry's Forces
	Player_SetCurrentAge(player1, AGE_FEUDAL)
	Player_SetMaximumAge(player1, AGE_FEUDAL)

	-- player 2 - Village Rebels	
	Setup_SetPlayerName(player2, "$11179199") --Robert's Forces
	Player_SetCurrentAge(player2, AGE_FEUDAL)
	Player_SetMaximumAge(player2, AGE_FEUDAL)
	
	--Enable Player Colours
	PlayerColour_Enable()
	
	Game_SetPlayerSlotColour(player1, 1)
    Game_SetPlayerUISlotColour(player1, 1)
	Game_SetPlayerSlotColour(player2, 2)
    Game_SetPlayerUISlotColour(player2, 2)
	Game_SetPlayerSlotColour(player3, 1)
    Game_SetPlayerUISlotColour(player3, 1)	
	
	--Perform Upgrades
	PlayerUpgrades_Auto(player1, false)
	PlayerUpgrades_Auto(player2, true)
	PlayerUpgrades_Auto(player3, true)
	
	Player_SetRelationship(player3, player1, R_ALLY)	
	Player_SetRelationship(player3, player2, R_ALLY)
	Player_SetRelationship(player1, player3, R_ALLY)	
	Player_SetRelationship(player2, player3, R_ALLY)
		
end

function Mission_SetupVariables()	-- create any extra sgroups, egroups, and mission variables in here

	
	--Enemy sgroups
	sg_enemy_farmers = SGroup_CreateIfNotFound("sg_enemy_farmers")
	sg_cavalry_spawn = SGroup_CreateIfNotFound("sg_cavalry_spawn")
	sg_cine_cavalry = SGroup_CreateIfNotFound("sg_cine_cavalry")
	sg_cavalry_attack = SGroup_CreateIfNotFound("sg_cavalry_attack")
	sg_cavalry_attack2 = SGroup_CreateIfNotFound("sg_cavalry_attack2")
	sg_inland_cavalry = SGroup_CreateIfNotFound("sg_inland_cavalry")
	sg_bayeux_defenders = SGroup_CreateIfNotFound("sg_bayeux_defenders")
	sg_wall_defenders = SGroup_CreateIfNotFound("sg_wall_defenders")
	sg_defend_wood = SGroup_CreateIfNotFound("sg_defend_wood")
	sg_enemy_troops = SGroup_CreateIfNotFound("sg_enemy_troops")
	
	--Player Sgroups
	sg_player_army = SGroup_CreateIfNotFound("sg_player_army")
	sg_player_scouts = SGroup_CreateIfNotFound("sg_player_scout")
	sg_player_archers = SGroup_CreateIfNotFound("sg_player_archers")
	sg_player_archers_setup = SGroup_CreateIfNotFound("sg_player_archers_setup")
	sg_player_archers_reup = SGroup_CreateIfNotFound("sg_player_archers_reup")
	sg_player_henry = SGroup_CreateIfNotFound("sg_player_henry")
	sg_player_troops = SGroup_CreateIfNotFound("sg_player_troops")

	--Bayeux Town Egroups
	eg_bayeux_town = EGroup_CreateIfNotFound("eg_bayeux_town")
	eg_allbayeux = EGroup_CreateIfNotFound("eg_allbayeux")
	
	eg_killwall = EGroup_CreateIfNotFound("eg_killwall")
	eg_woodtown = EGroup_CreateIfNotFound("eg_woodtown")
	
	g_leaderHenry = Missionomatic_InitializeLeader({
		name = "$11179251", --King Henry
		owner = player1,
		neutralHolder = player3,
	})
	
	eg_bayeux_walls =  EGroup_CreateIfNotFound("eg_bayeux_walls")
	Player_GetAll(player2)
	EGroup_Filter(eg_allentities, {"wall"}, FILTER_REMOVE, eg_bayeux_walls)
	EGroup_Filter(eg_bayeux_walls, "outpost", FILTER_REMOVE)
	EGroup_AddEGroup(eg_allbayeux, eg_bayeux_walls)
	EGroup_AddEGroup(eg_allbayeux, eg_bayeux_town)
	
	eg_bayeux_gates =  EGroup_CreateIfNotFound("eg_bayeux_gates")
	Player_GetAll(player2)
	EGroup_Filter(eg_allentities, "stone_gate", FILTER_REMOVE, eg_bayeux_gates)
		
