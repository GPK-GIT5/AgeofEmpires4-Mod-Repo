function Advance_OnEntityKilled(context)
	Rule_RemoveEGroupEvent(Advance_OnEntityKilled, eg_bayeux_walls)
	Rule_RemoveEGroupEvent(Advance_OnEntityDamage, eg_bayeux_town)
	
	FOW_PlayerRevealArea(player2, Util_GetPosition(mkr_town_bayeux), 120, -1)
	
	if context.victim ~= nil and MissionOMatic_FindModule("defend_bayeux_walls") ~= nil then
		Dissolve_WithdrawnCavalry()
		CleanUp_Cavalry()
		RovingArmy_SetTarget(MissionOMatic_FindModule("defend_bayeux_walls"), Util_GetPosition(context.victim), 50)
	end
	
	if Objective_IsStarted(SOBJ_BurnBuildings) ~= true then
		ClearArchers()
		Init_Infantry_Extra_Defenders()
		
		Rule_AddOneShot(VillagerFlee, 20)
		Rule_AddOneShot(PushWhenNeeded, 30)
		
		Objective_Complete(SOBJ_Breach)
		Objective_Start(SOBJ_BurnBuildings, true)
		Obj_SetProgressVisible(SOBJ_BurnBuildings.ID, true)
		
		Music_LockIntensity(MUSIC_COMBAT_RARE, 30, MUSIC_TENSE_COMBAT, 30)
		Sound_SetMinimumMusicCombatIntensity(801, 0) -- Lock minimum music intensity tense and above tense
	end
		
end

function Advance_OnEntityDamage(context)
	local _IsOnWalls = function(gid, index, sid)
		if Squad_IsOnWalkableWall(sid, ANY) then
			return true
		end
	end
	Player_GetAll(player1)
	SGroup_Filter(sg_allsquads, "infantry", FILTER_KEEP)
	if SGroup_ForEachAllOrAny(sg_allsquads, ANY, _IsOnWalls) then
		Rule_RemoveEGroupEvent(Advance_OnEntityDamage, eg_bayeux_town)
		Rule_RemoveEGroupEvent(Advance_OnEntityKilled, eg_bayeux_walls)

		FOW_PlayerRevealArea(player2, Util_GetPosition(mkr_town_bayeux), 120, -1)
		
		if context.victim ~= nil and MissionOMatic_FindModule("defend_bayeux_walls") ~= nil then
			Dissolve_WithdrawnCavalry()
			CleanUp_Cavalry()
			RovingArmy_SetTarget(MissionOMatic_FindModule("defend_bayeux_walls"), Util_GetPosition(context.victim), 50)
		end
		
		if Objective_IsStarted(SOBJ_BurnBuildings) ~= true then
			ClearArchers()

			Init_Infantry_Extra_Defenders()
			
			Rule_AddOneShot(VillagerFlee, 20)
			Rule_AddOneShot(PushWhenNeeded, 30)
			
			Objective_Complete(SOBJ_Breach)
			Objective_Start(SOBJ_BurnBuildings, true)
			Obj_SetProgressVisible(SOBJ_BurnBuildings.ID, true)
			
			Music_LockIntensity(MUSIC_COMBAT_RARE, 30, MUSIC_TENSE_COMBAT, 30)
			Sound_SetMinimumMusicCombatIntensity(801, 0) -- Lock minimum music intensity tense and above tense
		end
	end
end

function Dissolve_WithdrawnCavalry()
	if #t_AllCavalryModules > 0 then
		for i = #t_AllCavalryModules, 1, -1 do
			if t_AllCavalryModules[i] ~= nil and SGroup_CountSpawned(t_AllCavalryModules[i].sgroup) > 0 then
				if t_AllCavalryModules[i].isWithdrawn then
					DissolveModuleIntoModule(t_AllCavalryModules[i].descriptor, "defend_bayeux_walls")
					table.remove(t_AllCavalryModules,i)
				end
			end
		end
	end
end

function resetDefenders()
	b_bayeuxIsDefending = false
end

function BayeuxBurning()
	local bayeuxHealthCurrent =  EGroup_GetTotalHealth(eg_bayeux_town)
	
	if ((1-(bayeuxHealthCurrent/bayeuxHealthTotal))/0.25) > 0 then
		Obj_SetProgress(SOBJ_BurnBuildings.ID, (1-(bayeuxHealthCurrent/bayeuxHealthTotal))/0.25)
	end
	
	if bayeuxHealthCurrent/bayeuxHealthTotal <= 0.75 then
		Sound_PlayWallaCelebrateOnSGroup(sg_player_army)
		Objective_Complete(SOBJ_BurnBuildings, true)
		Rule_RemoveMe()
	end
end

function PushWhenNeeded()
	local bayeuxHealthPercent =  EGroup_GetTotalHealth(eg_bayeux_town)/bayeuxHealthTotal
	previousPush = previousPush or 1.0
	if Objective_IsComplete(SOBJ_Defenders) ~= true and #t_bayeux_extra_infantry > 0 then
		local unitCount = SGroup_CountSpawned(sg_player_army)
		if unitCount > 0 then 
			Rule_AddOneShot(PushWhenNeeded, 3)
			if (bayeuxHealthPercent <= (previousPush-0.025) or bayeuxHealthPercent < 0.75) then
				DissolveInArchers()
				PushAttack()
				previousPush = bayeuxHealthPercent
			end
		end
	end
end

function DissolveInArchers()
	if #t_AllArcherDefenders > 0 then
		for i = #t_AllArcherDefenders, 1, -1 do
			local module = t_AllArcherDefenders[i]
			if module ~= nil and SGroup_CountSpawned(module.sgroup) > 0 then
				DissolveModuleIntoModule(module, MissionOMatic_FindModule("defend_bayeux_walls"), false)
				sg_pushtarget = SGroup_CreateIfNotFound("sg_pushtarget") 
				Player_GetAll(player1, sg_pushtarget)
				if SGroup_CountSpawned(sg_pushtarget) > 0 then
					RovingArmy_AddTarget(MissionOMatic_FindModule("defend_bayeux_walls"), sg_pushtarget)
				else
					RovingArmy_AddTarget(MissionOMatic_FindModule("defend_bayeux_walls"), mkr_location_wood)
				end
			else
				table.remove(t_AllArcherDefenders, i)
			end
		end
	end
	
end
