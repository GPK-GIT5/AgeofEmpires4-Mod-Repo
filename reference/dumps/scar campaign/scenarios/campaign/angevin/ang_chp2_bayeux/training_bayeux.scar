import("training/campaigntraininggoals.scar")

local palings = "palings"
local fogofwar = "fogofwar"
local attackMove = "attackMove"
local blacksmith = "blacksmith"
local siegeengineer = "siegeengineer"
local rams = "rams"

local goal_sequence_height = "height_enabled"
local goal_sequence_attackmove = "attack_move_enabled"
local goal_sequence_blacksmith = "blacksmith_enabled"
local goal_sequence_rams = "rams_enabled"

sg_currentSelection = SGroup_CreateIfNotFound("sg_currentSelection")
eg_currentSelection = SGroup_CreateIfNotFound("eg_currentSelection")

function MissionTutorial_Init()	-- called from the mission's Mission_Start() function, so post-intro
	
	
end

function Ram_TutorialBranch()
	MissionTutorial_Blacksmith()
	
	if UI_IsXboxControllerUI() then
		MissionTutorial_SiegeEngineer_Xbox()
	else
		MissionTutorial_SiegeEngineer()
	end
	
	MissionTutorial_Ram()
end

------------------------------------------
-- Palings Tutorial--
------------------------------------------

_PalingsDeployed = function(gid, index, sid)
	if Entity_GetStateModelBool(Squad_GetFirstEntity(sid), "archer_palings_deployed") == true then
		return true
	end
end

_PalingsNotDeployed = function(gid, index, sid)
	if Entity_GetStateModelBool(Squad_GetFirstEntity(sid), "archer_palings_deployed") == false then
		return true
	end
end

function MissionTutorial_Palings()
	local selectArcher = Training_Goal("Squad", {Message = UI_PickIDForInputMode(11191533, 1000594), DataTemplate="LeftClickTrainingDataTemplate"}, Palings_ArcherIsSelected) --DOUBLE LEFT CLICK to select all your Archers.
	local usePalings = Training_Goal("PBG", {Message = UI_PickIDForInputMode(11191534, 11256335), DataTemplate="LeftClickTrainingDataTemplate"}, Palings_PalingsUsed) --Use palings to defend against cavalry.
	
	palingsSequence = Training_GoalSequence(palings, 1, 0, Palings_TriggerPredicate, CampaignTraining_TimeoutIgnorePredicate, nil , Palings_BypassPredicate, true, {selectArcher, usePalings})
	
	Training_AddGoalSequence(palingsSequence)
	Training_EnableGoalSequenceByID(palingsSequence, true)
end

function Palings_TriggerPredicate(goalSequence)
	SGroup_Clear(sg_temp)
	Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_player_a1)
	SGroup_RemoveGroup(sg_temp, sg_player_archers_setup)
	
	if SGroup_CountSpawned(sg_temp) > 5 then
		if SGroup_ForEachAllOrAny(sg_player_archers, ANY, _PalingsNotDeployed) then
			goalSequence.goals[1].key = Squad_GetID(SGroup_GetSquadAt(sg_player_archers, 1))
			if UI_IsXboxControllerUI() then
				goalSequence.goals[2].key = Squad_GetID(SGroup_GetSquadAt(sg_player_archers, 1))
			else
				goalSequence.goals[2].key = BP_GetAbilityBlueprint("deploy_palings")
			end
			return true
		end
	end
end

function Palings_BypassPredicate(goalSequence)
	return SGroup_ForEachAllOrAny(sg_player_archers, ANY, _PalingsDeployed)
end

function Palings_ArcherIsSelected(goal)
	Misc_GetSelectedSquads(sg_currentSelection, true)
	SGroup_Filter(sg_currentSelection, "scar_archer", FILTER_KEEP)
	
	if SGroup_CountSpawned(sg_currentSelection) > 0 and SGroup_ForEachAllOrAny(sg_currentSelection, ANY, _PalingsNotDeployed) then
		return true
	end
	
	return false
end

function Palings_PalingsUsed(goal)
	return SGroup_ForEachAllOrAny(sg_player_archers, ANY, _PalingsDeployed)
end

