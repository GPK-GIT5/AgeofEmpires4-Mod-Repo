--
-- Research Fire Arrows  PlayerIsResearchingIncendiary
--
function Wallingford_AddHintIncendiaryArrows()
	local showArsinalGoal = Training_Goal("Entity", 
		{Message=11191028, DataTemplate="LeftClickTrainingDataTemplate"}, --The Arsinal lets you research upgrades for your ranged units.
		UserIsSelectingArsenal)
	
	local researchIncendiaryGoal = Training_Goal("PBG", 
		{Message=11191029, DataTemplate="LeftClickTrainingDataTemplate"}, --Researching Incendiary Arrows allows archers and crossbowmen to shoot siege equipment.
		PlayerIsResearchingIncendiary)
	
	local researchFireArrowsSequence = Training_GoalSequence(
		"researchFireArrows",						-- id 
		1,											-- repeatMax
		0,											-- remindMax
		ResearchFireArrowsTrigger,					-- trigger
		CampaignTraining_TimeoutIgnorePredicate,	-- ignore
		nil, 										-- remind
		ReasearchFireArrowsIgnore,					-- bypass
		true, 										-- canRegress
		{ showArsinalGoal, researchIncendiaryGoal })
	
	Training_AddGoalSequence(researchFireArrowsSequence)
	Training_EnableGoalSequenceByID(researchFireArrowsSequence, true)
end

-- trigger
function ResearchFireArrowsTrigger(goalSequence)
	--print("ResearchFireArrowsTrigger")
	
	if AShortPeriodOfTimeHasPassed(goalSequence) then
		local arsenal = Wallingford_FindEntityOnScreen("bowyer")
		if arsenal ~= nil then
			goalSequence.goals[1].key = arsenal
			goalSequence.goals[2].key = UPG.COMMON.UPGRADE_RANGED_INCENDIARY
			return true
		end
	end
	return false
end

function ReasearchFireArrowsIgnore(goalSequence)
	if Player_HasUpgrade(player1, UPG.COMMON.UPGRADE_RANGED_INCENDIARY) or PlayerResearchingIncendiary() then
		return true
	end
	return false
end

function PlayerResearchingIncendiary()
	Player_GetAll(player1)
	local upgradeFound = false
	local checkArsenal = function(group, item_index, item)
		local queue_size = Entity_GetProductionQueueSize(item)
		for i = 0, queue_size - 1 do
			if Entity_GetProductionQueueItem(item, i) == UPG.COMMON.UPGRADE_RANGED_INCENDIARY then
				upgradeFound = true
				return true
			end
		end
	end
	EGroup_Filter(eg_allentities, "bowyer", FILTER_KEEP)
	EGroup_ForEach(eg_allentities, checkArsenal)
	--if upgradeFound then print("player is researching")
	--else print("player is NOT researching") end
	return upgradeFound
end

-- goal 1      
function UserIsSelectingArsenal(goal)
	return UserIsSelectingBuilding("bowyer")
end

function PlayerIsResearchingIncendiary(goal) -- Goal 2
	Misc_GetSelectedEntities(eg_currentSelection, true)
	EGroup_Filter(eg_currentSelection, "bowyer", FILTER_KEEP)
	if EGroup_CountSpawned(eg_currentSelection) > 0 then
		for i = 1, EGroup_CountSpawned(eg_currentSelection) do
			local entity = EGroup_GetSpawnedEntityAt(eg_currentSelection, i)
			if Entity_HasProductionQueue(entity) then
				local production_queue_size = Entity_GetProductionQueueSize(entity)
				--print("Production queue size: "..production_queue_size)
				for i = 0, production_queue_size - 1 do
					if Entity_GetProductionQueueItem(entity, i) == UPG.COMMON.UPGRADE_RANGED_INCENDIARY then
						return true
					end
				end
			end
		end
		
	end
	return false
end


--
-- Keep Upgrades
--
function Wallingford_AddHintToKeep()
	local showKeepGoal = Training_Goal("castle", 
		{Message=11191030, DataTemplate="GenericTrainingDataTemplate"}, --You can research unique English upgrades at the keep.
		DelayTimeElapsed)
	
	local KeepGoalSequence = Training_GoalSequence(
		"select",									-- id 
		1,											-- repeatMax
		0,											-- remindMax
		KeepTrigger,								-- trigger
		CampaignTraining_TimeoutIgnorePredicate,										-- ignore
		nil, 										-- remind
		nil,										-- bypass
		true, 										-- canRegress
		{ showKeepGoal })
	
	Training_AddGoalSequence(KeepGoalSequence)
	Training_EnableGoalSequenceByID(KeepGoalSequence, true)
end

-- trigger
function KeepTrigger(goalSequence)
	--print("KeepTrigger")
	
	if AShortPeriodOfTimeHasPassed(goalSequence) then
		keep = Wallingford_FindEntityOnScreen("castle")
		if keep ~= nil then
			goalSequence.goals[1].key = keep
			return true
		end
	end
	return false
end

--
-- UTILITY
--

function Wallingford_FindArcher()
	local localPlayer = Game_GetLocalPlayer()
	local archerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_archer", localPlayer)
	local squads = Player_GetSquads(localPlayer)
	
	for i = 1, SGroup_Count(squads) do
		local squad = SGroup_GetSquadAt(squads, i)
		
		if Squad_GetBlueprint(squad) == archerBP and Squad_IsOnWalkableWall(squad, false) == false then
			return Squad_GetID(squad)
		end
	end
	
	return nil
end


function Wallingford_FindEntityOnScreen(scar_type)
	local localPlayer = Game_GetLocalPlayer()
	local walls = Player_GetEntitiesFromType(localPlayer, scar_type)
	if EGroup_CountSpawned(walls) > 0 then
		local camera_pos = Camera_GetTargetPos()
		local closest_wall = World_GetClosest(camera_pos, walls)
		if Misc_IsEntityOnScreen(closest_wall, 100) then
			return closest_wall
		end
	end
	
	return nil
end

function PlayerInCombat()
	Player_GetAll()
	return EGroup_IsUnderAttack(eg_allentities, ANY, 10) or EGroup_IsDoingAttack(eg_allentities, ANY, 10) or SGroup_IsUnderAttack(sg_allsquads, ANY, 10) or SGroup_IsDoingAttack(sg_allsquads, ANY, 10)
end

function DelayTimeElapsed(goal)
	local currentTime = Timer_GetElapsed(goal.timerID)
	
	if currentTime >= __t_trainingShortInterval then
		return true
	end
end

function UserIsSelectingBuilding(building)
	local player_is_selecting_building = false
	local buildingBP = Cardinal_ConvertTypeToEntityBlueprint(building, Game_GetLocalPlayer())
	Misc_GetSelectedEntities(eg_currentSelection, true)
	for i = 1, EGroup_Count(eg_currentSelection) do
		local entity = EGroup_GetEntityAt(eg_currentSelection, i)
		if Entity_GetBlueprint(entity) == buildingBP then
			return true
		end
	end
	
	return false
end