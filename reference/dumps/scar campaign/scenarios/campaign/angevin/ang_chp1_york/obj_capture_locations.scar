--
-- York 1069 - Capture Locations
--

function CaptureLocations_InitMiddlethorpe()
	
	local location = LOCATION("Middlethorpe")
	
	OBJ_CaptureMiddlethorpe = {
		
		Title = "$11172029", -- Capture Middlethorpe
		Type = ObjectiveType_Capture,
		Intel_Start = EVENTS.ShowObjective_Middlethorpe,
		Intel_Complete = EVENTS.CaptureMiddlethorpe,
		OnStart = function()
			Location_SetCapturable(LOCATION("Middlethorpe"), true)
			TrainingGoal_AddStopAttacking()
		end,
		PreComplete = function()
			
			HintPoint_Add(mkr_kp_middlethorpe, true, "$11172031", LOCATION_LABEL_HEIGHT)
			
			if early_raiders_stopped == false and t_difficulty.rebels_earlyRaiderCount > 0 then
				Rule_AddInterval(York_SpawnEarlyRaiders, t_difficulty.rebels_earlyRaidInterval)
			end
			
			DissolveModuleIntoModule("SouthBridgeGuards", "WestBridgeGuards")
			
			York_SetPopulationCapVisibility(true)
			FOW_PlayerUnRevealArea(player1, Util_GetPosition(mkr_kp_middlethorpe))
			-- on console, restore the econ HUD at this point
			if UI_IsXboxUI() then
				Game_SetVisibility (VF_XboxUIResourceCard, true)
				Game_SetVisibility (VF_XboxUIVillagerPriorities, true)
			end				
		end,
		OnComplete = function()
			if not Objective_IsStarted(OBJ_CaptureFulford) then
				Objective_Start(OBJ_DevelopEconomy)
			end
			player_has_captured_tc = true
		end,
	}
	SOBJ_DefeatMiddlethorpeRebels = {
		
		Title = "$11172030", -- Defeat Middlethorpe rebels
		Type = ObjectiveType_Capture,
		Parent = OBJ_CaptureMiddlethorpe,
	}
	SOBJ_LocationMiddlethorpe = {
		Title = "$11172031", -- Middlethorpe
		Type = ObjectiveType_Capture,
		Parent = OBJ_CaptureMiddlethorpe,
	}
	
	Objective_Register(OBJ_CaptureMiddlethorpe)
	Objective_Register(SOBJ_DefeatMiddlethorpeRebels)
	Objective_Register(SOBJ_LocationMiddlethorpe)
	
	location.objectivePrimary = OBJ_CaptureMiddlethorpe
	location.objectiveSecondary = SOBJ_DefeatMiddlethorpeRebels
	location.objectiveCapture = SOBJ_LocationMiddlethorpe
	
end



function CaptureLocations_InitFulford()
	
	local location = LOCATION("Fulford")
	
	OBJ_CaptureFulford = {
		
		Title = "$11172032", -- Capture Fulford
		Type = ObjectiveType_Capture,
		Intel_Start = EVENTS.ShowObjective_CaptureFulford,
		Intel_Complete = EVENTS.CaptureFulford,
		OnStart = function()
			Location_SetCapturable(LOCATION("Fulford"), true)
		end,
		PreComplete = function()
			HintPoint_Add(mkr_kp_fulford, true, "$11172034", LOCATION_LABEL_HEIGHT)
			-- on console, restore the econ HUD at this point
			if UI_IsXboxUI() then
				Game_SetVisibility (VF_XboxUIResourceCard, true)
				Game_SetVisibility (VF_XboxUIVillagerPriorities, true)
			end				
		end,
		OnComplete = function()
			if not Objective_IsComplete(OBJ_DevelopEconomy) then
				Objective_Complete(SOBJ_BuildFarms, false, false)
				Objective_Complete(SOBJ_BuildHouses, false, false)
				Objective_Complete(SOBJ_AssignToWood, false, false)
				Objective_Complete(OBJ_DevelopEconomy, false, false)
			end
			
			Objective_Start(OBJ_BuildSupport)
			
			DissolveModuleIntoModule("WestBridgeGuards", "CityRebelsCenter")
			
			York_FindPalisadeBastion()
			York_StopEarlyRaiders()
			
			EGroup_Filter(eg_fulford, "town_center", FILTER_REMOVE, eg_fulford_tc)
			Rule_AddInterval(York_CheckFulfordTC, 5)
			
			if Objective_IsComplete(OBJ_DestroyCampAlt) then
				Rule_AddOneShot(York_AddPatrolTargets, t_difficulty.rebels_attackStartDelay)
			end
			
			FOW_PlayerUnRevealArea(player1, Util_GetPosition(mkr_kp_fulford))
			player_has_captured_tc = true
		end,
	}
	SOBJ_DefeatFulfordRebels = {
		
		Title = "$11172033", -- Defeat Fulford rebels
		Type = ObjectiveType_Capture,
		Parent = OBJ_CaptureFulford,
	}
	SOBJ_LocationFulford = {
		Title = "$11172034", -- Fulford
		Type = ObjectiveType_Capture,
		Parent = OBJ_CaptureFulford,
	}
	
	Objective_Register(OBJ_CaptureFulford)
	Objective_Register(SOBJ_DefeatFulfordRebels)
	Objective_Register(SOBJ_LocationFulford)
	
	location.objectivePrimary = OBJ_CaptureFulford
	location.objectiveSecondary = SOBJ_DefeatFulfordRebels
	location.objectiveCapture = SOBJ_LocationFulford
	
end


