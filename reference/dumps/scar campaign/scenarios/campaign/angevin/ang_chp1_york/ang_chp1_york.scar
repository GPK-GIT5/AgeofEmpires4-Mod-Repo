function Mission_SetupPlayers()
	
	player1 = World_GetPlayerAt(1) --Normans
	player2 = World_GetPlayerAt(2) --VillageRebels
	player3 = World_GetPlayerAt(3) --CityRebels
	player4 = World_GetPlayerAt(4) --Danes
	player5 = World_GetPlayerAt(5) --Neutral
	
	playerNormans = player1
	playerVillageRebels = player2 
	playerCityRebels = player3
	playerDanes = player4
	playerNeutrals = player5
	
	Setup_SetPlayerName(playerNormans, Loc_GetString(11172017)) -- King William (Normans)
	Setup_SetPlayerName(playerVillageRebels, Loc_GetString(11172018)) -- Rebels
	Setup_SetPlayerName(playerCityRebels, Loc_GetString(11172018)) -- Rebels
	Setup_SetPlayerName(playerDanes, Loc_GetString(11195245)) -- Sweyn II of Denmark (Danes)
	Setup_SetPlayerName(playerNeutrals, Loc_GetString(11172025)) -- Neutral
	AI_Enable(playerNeutrals,false)
	
	Player_SetCurrentAge(player1, AGE_DARK)
	Player_SetMaximumAge(player1, AGE_FEUDAL)
	
	Player_SetConstructionMenuAvailability(player1, "eng_age4", ITEM_REMOVED)
	Player_SetConstructionMenuAvailability(player1, "eng_age3_wonders", ITEM_REMOVED)
	Player_SetConstructionMenuAvailability(player1, "eng_age3", ITEM_REMOVED)
	Player_SetConstructionMenuAvailability(player1, "eng_age2_wonders", ITEM_REMOVED)
	
	
	Player_SetCurrentAge(playerVillageRebels, AGE_DARK)
	Player_SetMaximumAge(playerVillageRebels, AGE_DARK)

	Player_SetCurrentAge(playerCityRebels, AGE_FEUDAL)
	Player_SetMaximumAge(playerCityRebels, AGE_FEUDAL)
	
	Player_SetCurrentAge(playerDanes, AGE_DARK)
	Player_SetMaximumAge(playerDanes, AGE_DARK)
	
	Player_SetCurrentAge(playerNeutrals, AGE_DARK)
	Player_SetMaximumAge(playerNeutrals, AGE_DARK)
	
	World_EnableSharedLineOfSight(player1, playerNeutrals, true)
	
	Player_SetRelationship(player1, playerNeutrals, R_ALLY)
	Player_SetRelationship(playerNeutrals, player1, R_ALLY)
	
	Player_SetRelationship(playerVillageRebels, playerNeutrals, R_NEUTRAL)
	Player_SetRelationship(playerNeutrals, playerVillageRebels, R_NEUTRAL)
	
	Player_SetRelationship(playerCityRebels, playerNeutrals, R_NEUTRAL)
	Player_SetRelationship(playerNeutrals, playerCityRebels, R_NEUTRAL)
	
	Player_SetRelationship(playerDanes, playerNeutrals, R_NEUTRAL)
	Player_SetRelationship(playerNeutrals, playerDanes, R_NEUTRAL)
	
	PlayerColour_Enable()
	
	Game_SetPlayerSlotColour(player1, 1)
	Game_SetPlayerUISlotColour(player1, 1)
	
	Game_SetPlayerSlotColour(playerCityRebels, 2)
	Game_SetPlayerUISlotColour(playerCityRebels, 2)
	
	Game_SetPlayerSlotColour(playerVillageRebels, 2)
	Game_SetPlayerUISlotColour(playerVillageRebels, 2)
	
	Game_SetPlayerSlotColour(playerDanes, 7)
	Game_SetPlayerUISlotColour(playerDanes, 7)
	
	Game_SetPlayerSlotColour(playerNeutrals, 1)
	Game_SetPlayerUISlotColour(playerNeutrals, 1)
	
	Modify_PlayerPopCap(playerDanes, 1000, MUT_Addition)
	Modify_PlayerMaxPopCap(playerDanes, 1000, MUT_Addition)
	Modify_PlayerPopCap(playerCityRebels, 1000, MUT_Addition)
	Modify_PlayerMaxPopCap(playerCityRebels, 1000, MUT_Addition)
	
end

 -- the following needs to be done before OnInit in order for it to be done in time to stop the diplomacy menu removing itself!
function Mission_PreInit()
	
	--York_HideTributeMenu()
end

function Mission_SetupVariables()
	York_HideTributeMenu()
	York_Data_Init()
end

function Mission_SetRestrictions()
	
	Player_SetStateModelFloat(player1, "has_capital", 1.0)
	
	PlayerUpgrades_Auto(player1, false)
	PlayerUpgrades_Auto(playerCityRebels, false)
	PlayerUpgrades_Auto(playerVillageRebels, false)
	PlayerUpgrades_Auto(playerDanes, false)
	
	-- danes should not make rams
	Player_SetResource(playerDanes, RT_Wood, 0)
	
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_SCOUT_FORESTER)
	
	if t_difficulty.upgradeLevel == 0 then
		
		Player_SetUpgradeAvailability(playerCityRebels, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS, ITEM_REMOVED)
		
	elseif t_difficulty.upgradeLevel == 1 then
		
		Cmd_InstantUpgrade(eg_outposts, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
		Cmd_InstantUpgrade(eg_patrol_outposts, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
		Cmd_InstantUpgrade(eg_keep, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
		
	elseif t_difficulty.upgradeLevel == 2 then
		
		Cmd_InstantUpgrade(eg_outposts, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
		Cmd_InstantUpgrade(eg_patrol_outposts, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
		Cmd_InstantUpgrade(eg_daneoutposts, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
		Cmd_InstantUpgrade(eg_keep, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	end
	
	Player_SetEntityProductionAvailability(player1, EBP.CAMPAIGN.BUILDING_DEFENSE_WALL_NRM, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.CAMPAIGN.BUILDING_DEFENSE_WALL_GATE_NRM, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.CAMPAIGN.BUILDING_DEFENSE_TOWER_NRM, ITEM_REMOVED)
	
	Player_SetSquadProductionAvailability(player1, SBP.CAMPAIGN.UNIT_TRADE_CART_NRM, ITEM_REMOVED)
	
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_OUTPOST_CANNON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_OUTPOST_SPRINGALD, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_OUTPOST_STONE, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_TECH_MILITARY_ACADEMY, ITEM_REMOVED)
	
	Player_SetSquadProductionAvailability(playerVillageRebels, SBP.ENGLISH.UNIT_VILLAGER_1_ENG, ITEM_REMOVED)
	
	Player_SetAbilityAvailability(playerVillageRebels, BP_GetAbilityBlueprint("deploy_palings"), ITEM_REMOVED)
	Player_SetAbilityAvailability(playerCityRebels, BP_GetAbilityBlueprint("deploy_palings"), ITEM_REMOVED)
	Player_SetAbilityAvailability(playerDanes, BP_GetAbilityBlueprint("deploy_palings"), ITEM_REMOVED)
	Player_SetAbilityAvailability(playerDanes, BP_GetAbilityBlueprint("tower_outpost_alert_aura_eng"), ITEM_REMOVED)
	
	York_SetPopulationCapVisibility(false)
	
end

function Mission_SetDifficulty()
	
	t_difficulty = {
		danes_goldAmount = Util_DifVar({500, 500, 800, 1200}),
		danes_spawnDelay = Util_DifVar({240, 200, 160, 120}),
		danes_initRaid_Countdown = Util_DifVar({150, 150, 120, 90}),
		danes_raiderCount1 = Util_DifVar({2, 3, 5, 7}), --used for initial raid
		danes_raiderCount2 = Util_DifVar({4, 4, 5, 6}), --used for initial raid
		danes_raiderCountCap = Util_DifVar({16, 20, 30, 40}), --used for repeating raids
		danes_defenderCount = Util_DifVar({8, 10, 15, 20}),
		rebels_earlyRaiderCount = Util_DifVar({0, 1, 2, 3}),
		rebels_earlyRaidInterval = Util_DifVar({200, 200, 160, 120}),
		rebels_defenderCount = Util_DifVar({3, 4, 5, 5}),
		rebels_patrolCount = Util_DifVar({3, 6, 8, 12}),
		rebels_attackStartDelay = Util_DifVar({240, 240, 120, 60}),
		rebels_attackGroupCount = Util_DifVar({0, 1, 2, 3}),
		rebels_initNumSquads = Util_DifVar({3, 4, 5, 6}),
		rebels_reinforceDelay = Util_DifVar({300, 240, 200, 160}),
		rebels_maxModuleSize = Util_DifVar({10, 15, 25, 35}),
		enemy_unitBuildTime = Util_DifVar({30, 25, 20, 12}),
		upgradeLevel = Util_DifVar({0, 0, 1, 2}),
	}
	
 end


function Mission_Preset()
	
	if Game_GetSPDifficulty() == GD_EASY then
		Player_SetResource(player1, RT_Gold, t_difficulty.danes_goldAmount)
	end
	
	York_InitPlayerUnits()
	
	Reclaim_InitObjectives()
	CaptureLocations_InitMiddlethorpe()
	CaptureLocations_InitFulford()
	
	Develop_InitObjectives()
	Strengthen_InitObjectives()
	DefeatDanes_InitObjectives()
	
	Modify_WeaponCooldown(eg_keep, "hardpoint_02", 0.3)
	Modify_WeaponReload(eg_keep, "hardpoint_02", 0.3)
	Modify_WeaponAccuracy(eg_keep, "hardpoint_02", 2)
	
	Entity_SetInvulnerableMinCap(entity_keep, 0.001, 0)	
	
	Wave_OverrideUnitBuildTime("scar_spearman", t_difficulty.enemy_unitBuildTime)
	Wave_OverrideUnitBuildTime("scar_manatarms", t_difficulty.enemy_unitBuildTime)
	Wave_OverrideUnitBuildTime("scar_archer", t_difficulty.enemy_unitBuildTime)
	Wave_OverrideUnitBuildTime("scar_horseman", t_difficulty.enemy_unitBuildTime)
	
	--Allow silence system working in music 
	if Music_UnlockIntensity then
		Sound_SetForceMusic(false)
	else
		Sound_SetForceMusic(true)
	end
	
	-- Set sound intensity for York
	Sound_ResetMusicIntensityMapping();
	Sound_AddMusicIntensityMappingPoint(50, 200) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(100, 1250) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(150, 2500) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(200, 3000) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(300, 3500) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(500, 6000) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(650, 9999) -- raw value max to scaled value max 
	
	Sound_SetMusicIntensityScaling(1.25)
	
	--music triggers
	AudioTrigger_InitAreaTrigger({
		marker = mkr_river_trigger,
		audioCue = MUSIC_TENSE_COMBAT,
		triggeringPlayer = player1,
		startAboveUnitCount = 5,
		duration = 60,
		onExit = {
			--exitAudio = MUSIC_TENSE,
		},
	})
	
	-- Special rules for this scenario
	Rule_AddGlobalEvent(York_OnEntityKilled, GE_EntityKilled)
	Rule_AddGlobalEvent(York_OnConstructionComplete, GE_ConstructionComplete)
	
	York_InitEnemyUnits()
	Rule_AddOneShot(York_MoveStartingUnits, 0.25)
	
end


function Mission_Start()
	-- on console don't restore econ-related HUD elements at first
	Cardinal_EnablePartialXboxUI(true, {VF_XboxUIResourceCard, VF_XboxUIVillagerPriorities})
	
	Objective_Start(OBJ_ReclaimYork, false)
	Objective_Start(OBJ_CaptureMiddlethorpe)
	
	Rule_AddInterval(York_CheckDaneCampReveal, 1)
	Rule_AddInterval(York_CheckDaneCampLooted, 1)
	Rule_AddInterval(York_CheckBridgeTriggers, 1)
	
	Rule_AddInterval(York_CheckMiddlethorpeTrigger, 1)
	Rule_AddInterval(York_CheckFulfordTrigger, 1)
	Rule_AddInterval(York_CheckKeepTrigger, 1)
	
	Rule_AddInterval(York_CheckReactionScout, 1)
	
	Rule_AddInterval(York_CheckMissionFail, 1)
	
	York_SetDaneGoldValue(eg_dane_gold, 300)
	rebel_init_vill_count = York_GetRebelVillagerCount()
	rebel_escalation_counter = t_difficulty.rebels_initNumSquads
	rebel_escalation_max = rebel_escalation_counter * 2
	
	Game_TransitionToState("default", 450)
	Rule_AddOneShot(York_TransitionOutroLight, 450)
	
	TrainingGoal_AddLeaderRecovery()
	
end

function York_TransitionOutroLight()
	
	Game_TransitionToState("outro", 1200)
end

function Mission_OnTributeSent(tribute)
	
	for index, tributeData in pairs(tribute) do 
		
		if tributeData.receiver.id == playerDanes and tributeData.gold > 0 then
			
			local objective = SOBJ_PayTribute
			
			if Objective_IsCounterSet(objective) then
				Objective_IncreaseCounter(objective, tributeData.gold)
				
				local progress = Obj_GetCounterCount(objective.ID) / Obj_GetCounterMax(objective.ID)
				Obj_SetProgress(objective.ID, progress)
				
				if progress >= 1 then 
					Objective_Complete(objective)
					Rule_RemoveMe()
				end
				
			end
		end
	end
end

function York_SetPopulationCapVisibility(visibility)
	
	for index, player in pairs(PLAYERS) do
		if player.isLocal == true then
			player.scarModel.PopulationCapOn  = visibility
			UI_SetPlayerDataContext(player1, player.scarModel)
		end
    end
end

function York_InitPlayerUnits()
	
	SpawnUnitGroups(player1, "sg_player_cav", t_player_cav_units, "mkr_player_cav", false)
	SpawnUnitGroups(player1, "sg_player_scout", t_player_scout_units, "mkr_player_scout", false)
	SpawnUnitGroups(player1, "sg_player_spears", t_player_spear_units, "mkr_player_spears", false)
	SpawnUnitGroups(player1, "sg_player_archers", t_player_archer_units, "mkr_player_archers", false)
end

function York_InitEnemyUnits()
	
	UnitEntry_DeploySquads(playerDanes, sg_dane_line1, units_dane_line1, mkr_dane_line1_1)
	UnitEntry_DeploySquads(playerDanes, sg_dane_line2, units_dane_line2, mkr_dane_line2_1)
	UnitEntry_DeploySquads(playerDanes, sg_dane_line3, units_dane_line3, mkr_dane_line3_1)
	
	local units_dane = {
		{sbp = SBP.ENGLISH.UNIT_RAIDER_DANE, numSquads = t_difficulty.danes_defenderCount},
		{type = "scar_shield_villager", numSquads = t_difficulty.danes_defenderCount}
	}
	
	SpawnUnitsToModule(units_dane, "DaneDefenders", mkr_dane_defend)
	
	UnitEntry_DeploySquads(playerCityRebels, nil, {{type = "scar_archer", numSquads = 3}}, mkr_keep_gate1)
	UnitEntry_DeploySquads(playerCityRebels, nil, {{type = "scar_archer", numSquads = 2}}, mkr_keep_gate2)
	UnitEntry_DeploySquads(playerCityRebels, nil, {{type = "scar_manatarms", numSquads = 3}}, mkr_keep_gate3)
	
	UnitEntry_DeploySquads(playerVillageRebels, sg_middlethorpe_scout, {{type = "scar_scout", numSquads = 1 }}, mkr_middlethorpe_scout)
	
	York_DeployOuterGuard(playerVillageRebels, "scar_archer", 2, mkr_middlethorpe_og1, sg_middlethorpe_og1, sg_middlethorpe_outer_guard)
	York_DeployOuterGuard(playerVillageRebels, "scar_shield_villager", 2, mkr_middlethorpe_og2, sg_middlethorpe_og2, sg_middlethorpe_outer_guard)
	York_DeployOuterGuard(playerVillageRebels, "scar_archer", 1, mkr_middlethorpe_og3, sg_middlethorpe_og3, sg_middlethorpe_outer_guard)
	
	York_DeployOuterGuard(playerVillageRebels, "scar_shield_villager", 1, mkr_fulford_og1, sg_fulford_og1, sg_fulford_outer_guard)
	York_DeployOuterGuard(playerVillageRebels, "scar_shield_villager", 1, mkr_fulford_og2, sg_fulford_og2, sg_fulford_outer_guard)
	York_DeployOuterGuard(playerVillageRebels, "scar_archer", 2, mkr_fulford_og3, sg_fulford_og3, sg_fulford_outer_guard)
	
end

function York_DeployOuterGuard(player, unitType, numSquads, marker, sgroup, sgroupMaster)
	UnitEntry_DeploySquads(player, sgroup, {{type = unitType, numSquads = numSquads}}, marker)
	SGroup_AddGroup(sgroupMaster, sgroup)
end


