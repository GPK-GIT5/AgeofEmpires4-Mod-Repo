	Cmd_FormationMove(sg_player_spears1, mkr_player_spears_dest1)
	Cmd_FormationMove(sg_player_spears2, mkr_player_spears_dest2)
	Cmd_FormationMove(sg_player_spears3, mkr_player_spears_dest3)
	Cmd_FormationMove(sg_player_spears4, mkr_player_spears_dest4)
	Cmd_FormationMove(sg_player_spears5, mkr_player_spears_dest5)
	
	Cmd_FormationMove(sg_player_archers1, mkr_player_archers_dest1)
