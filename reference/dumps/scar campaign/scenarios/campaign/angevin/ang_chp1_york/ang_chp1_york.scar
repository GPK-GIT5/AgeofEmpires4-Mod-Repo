	Cmd_FormationMove(sg_player_archers3, mkr_player_archers_dest3)
	Cmd_FormationMove(sg_player_archers4, mkr_player_archers_dest4)

	Cmd_FormationMove(g_leaderKingWilliam.sgroup, mkr_william_dest)
	
	Cmd_Move(sg_middlethorpe_scout, mkr_middlethorpe_scout_dest)
	
end

--? @shortdesc Checks for mission fail
function York_CheckMissionFail()
	
	Player_GetAll(playerNormans)
	
	if player_has_captured_tc == true then
		
		EGroup_Filter(eg_allentities, "town_center", FILTER_KEEP)
		if EGroup_CountSpawned(eg_allentities) <= 0 then
			Mission_Fail()
			Rule_RemoveMe()
		end
		
	else
		
		SGroup_Filter(sg_allsquads, "scar_villager", FILTER_REMOVE)
		SGroup_Filter(sg_allsquads, "gaia", FILTER_REMOVE)
		if SGroup_CountSpawned(sg_allsquads) <= 0 then
			Mission_Fail()
			Rule_RemoveMe()
		end
		
	end

end

--? @shortdesc Watches for construction
function York_OnConstructionComplete(context)
	
	local buildingOwner = Entity_GetPlayerOwner(context.entity)
	if buildingOwner == player1 then
		
		if not Objective_IsComplete(SOBJ_BuildFarms) and Objective_IsCounterSet(SOBJ_BuildFarms) then
			if Entity_IsOfType(context.entity, "farm") then
				
				Objective_IncreaseCounter(SOBJ_BuildFarms, 1)
				
				if Obj_GetCounterCount(SOBJ_BuildFarms.ID) >= Obj_GetCounterMax(SOBJ_BuildFarms.ID) then
					
					if Objective_IsComplete(SOBJ_BuildHouses) and Objective_IsComplete(SOBJ_AssignToWood) then
						Objective_Complete(SOBJ_BuildFarms, false)
						Objective_Complete(OBJ_DevelopEconomy)
					else
						Objective_Complete(SOBJ_BuildFarms)
					end
					
				else
					Music_PlayStinger("sfx_campaign_scripted_ui_objective_counter_update")
				end
			end
		end
		
		if not Objective_IsComplete(SOBJ_BuildHouses) and Objective_IsCounterSet(SOBJ_BuildHouses) then
			if Entity_IsOfType(context.entity, "house") then
				
				Objective_IncreaseCounter(SOBJ_BuildHouses, 1)
				
				if Obj_GetCounterCount(SOBJ_BuildHouses.ID) >= Obj_GetCounterMax(SOBJ_BuildHouses.ID) then
					
					if Objective_IsComplete(SOBJ_BuildFarms) and Objective_IsComplete(SOBJ_AssignToWood) then
						Objective_Complete(SOBJ_BuildHouses, false)
						Objective_Complete(OBJ_DevelopEconomy)
					else
						Objective_Complete(SOBJ_BuildHouses)
					end
					
				else
					Music_PlayStinger("sfx_campaign_scripted_ui_objective_counter_update")
				end
			end
		end
		
		
		if g_palisadeWallBuilt == false then
			if Entity_IsOfType(context.entity, "palisade_wall_bastion") or Entity_IsOfType(context.entity, "palisade_wall_section") then
				g_palisadeWallBuilt = true
			end
		end
		
		if g_stableBuilt == false then
			if Entity_IsOfType(context.entity, "stable") then
				g_stableBuilt = true
			end
		end
		
		if g_landmarkBuilt == false then
			if Entity_IsOfType(context.entity, "landmark") then
				g_landmarkBuilt = true
			end
		end
		
	end
	
	if Objective_IsComplete(OBJ_DevelopEconomy) and g_palisadeWallBuilt == true and g_stableBuilt == true then
		Rule_RemoveMe()
	end
	
end


function York_FindPalisadeBastion()
	
	Player_GetAll(playerNormans)
	
	local _CheckForBastions = function(gid, idx, eid)
		if Entity_IsAlive(eid) then
			
			if Entity_IsOfType(eid, "palisade_wall_bastion") then
				
				EGroup_Clear(eg_single)
				EGroup_Add(eg_single, eid)
				
				if Prox_AreEntitiesNearMarker(eg_single, mkr_hint_wall, ANY, 20) then
					g_palisadeBastionTarget = eid
				end
				
			end
		end
	end
	
	EGroup_ForEach(eg_allentities, _CheckForBastions)
	
end

function York_AddPatrolTargets()
	
	if not patrol_targets_added then
		
		patrol_targets_added = true
		York_UpdatePatrolTargets()
		
		Rule_AddInterval(York_ReinforceRebels, t_difficulty.rebels_reinforceDelay)
		
	end
end


function York_DefendTheKeep()
	
	RovingArmy_SetTarget(MissionOMatic_FindModule("WestPatrol"), mkr_keep_final1)
	RovingArmy_SetTarget(MissionOMatic_FindModule("CavalryRaiders"), mkr_keep_final2)
	RovingArmy_SetTargets(MissionOMatic_FindModule("BaileyPatrol"), {mkr_keep_forecourt, mkr_keep_entry})
	
	TransferModuleIntoModule("WestRebels", "KeepDefenders")
	TransferModuleIntoModule("CityRebelsCrossroads", "KeepDefenders")
	TransferModuleIntoModule("CityRebelsCenter", "KeepDefenders")
	TransferModuleIntoModule("NorthGateRebels", "KeepDefenders")
end

function York_UpdatePatrolTargets()

	if t_difficulty.rebels_attackGroupCount >= 3 then
		local module_west = MissionOMatic_FindModule("WestPatrol")
		RovingArmy_SetTargets(module_west, west_targets)
	end
	
	if t_difficulty.rebels_attackGroupCount >= 2 then
		local module_bailey = MissionOMatic_FindModule("BaileyPatrol")
		RovingArmy_SetTargets(module_bailey, bailey_targets)
	end
	
	if t_difficulty.rebels_attackGroupCount >= 1 then
		local module_cav = MissionOMatic_FindModule("CavalryRaiders")
		RovingArmy_SetTargets(module_cav, west_targets)
	end
	
end

function York_AddFinalRebelTargets()
	
	if t_difficulty.rebels_attackGroupCount >= 3 then
		local module_west = MissionOMatic_FindModule("WestPatrol")
		RovingArmy_AddTargets(module_west, final_rebel_targets)
	end
	
	if t_difficulty.rebels_attackGroupCount >= 2 then
		local module_bailey = MissionOMatic_FindModule("BaileyPatrol")
		RovingArmy_AddTargets(module_bailey, final_rebel_targets)
		
		for i = 1, #final_rebel_targets do
			table.insert(bailey_targets, final_rebel_targets[i])
		end
	end
	
	if t_difficulty.rebels_attackGroupCount >= 1 then
		local module_cav = MissionOMatic_FindModule("CavalryRaiders")
		RovingArmy_AddTargets(module_cav, final_rebel_targets)
		
		for i = 1, #final_rebel_targets do
			table.insert(west_targets, final_rebel_targets[i])
		end
	end
	
end

function York_OnRiverWithdraw()
	
	York_PlayWallaFear(sg_river_rebels)
	Sound_SetMinimumMusicCombatIntensity(801, -1)
	Objective_Start(OBJ_CaptureFulford)
end

function York_StopEarlyRaiders()
	early_raiders_stopped = true
	SGroup_Clear(sg_temp)
	SGroup_AddGroup(sg_temp, sg_early_raiders)
	RovingArmy_Disband(MissionOMatic_FindModule("EarlyRaiders"))
	Cmd_Move(sg_temp, mkr_bailey1)
	
	Rule_Remove(York_SpawnEarlyRaiders)
end

function York_SpawnEarlyRaiders()
	
	local max_count = t_difficulty.rebels_earlyRaiderCount * 2
	Player_GetAll(playerNormans)
	
	if SGroup_CountSpawned(sg_early_raiders) < max_count and not Prox_AreSquadsNearMarker(sg_allsquads, mkr_early_raiders, ANY, 50) then
		
		if not Objective_IsComplete(OBJ_DevelopEconomy) then
			max_count = t_difficulty.rebels_earlyRaiderCount
		end
			
		local primary_unitCount = (early_raid_count + t_difficulty.rebels_earlyRaiderCount) * 2
		local secondary_unitCount = early_raid_count + t_difficulty.rebels_earlyRaiderCount
		
		if primary_unitCount > max_count then primary_unitCount = max_count end
		if secondary_unitCount > max_count then secondary_unitCount = max_count end
		
		local unit_types = {
			"scar_scout",
			"scar_shield_villager",
			"scar_archer",
			"scar_shield_villager",
			"scar_horseman",
			"scar_shield_villager",
			"scar_manatarms",
			"scar_archer",
			"scar_shield_villager"
		}
		
		local units = {
			{ type = unit_types[early_raid_index], numSquads = primary_unitCount },
			{ type = unit_types[early_raid_index + 1], numSquads = secondary_unitCount }
		}
		early_raid_index = early_raid_index + 1
		if early_raid_index > 7 then early_raid_index = 1 end
		
		SpawnUnitsToModule(units, "EarlyRaiders", mkr_early_raiders)
		
	end
	
	early_raid_count = early_raid_count + 1
	if early_raid_count > 8 then early_raid_count = 4 end
	
end

function York_SpawnDaneGold()
	
	local ebp = BP_GetEntityBlueprint("resource_pickup_gold")
	
	local total_amount = t_difficulty.danes_goldAmount
	local num_pickups = math.ceil(total_amount / 300)
	if num_pickups > 6 then num_pickups = 6 end
	
	for i = 1, num_pickups do
		
		local amount = total_amount
		if amount > 300 then amount = 300 end
		
		local marker = Marker_FromName("mkr_dane_gold"..tostring(i), "")
		
		local eg_gold = EGroup_CreateUnique("gold")
		eg_gold = Util_CreateEntities(nil, eg_gold, ebp, marker, 1)
		York_SetDaneGoldValue(eg_gold, amount)
		
		total_amount = total_amount - amount
	end
	
end

function York_SetDaneGoldValue(egroup, value)
	
	local _SetGold = function(gid, idx, eid)
		Entity_SetStateModelFloat(eid, "resource_pickup_amount_gold", value)
	end
	EGroup_ForEach(egroup, _SetGold)
end

function York_SpawnDaneRaiders()
	
	if Objective_IsComplete(OBJ_StopDaneRaids) then 
		Rule_RemoveMe() 
		return 
	end
	
	if York_RaidersInDaneCamp() == true or SGroup_CountSpawned(sg_dane_attackers) == 0 then
		
		local unit_count_cap = t_difficulty.danes_raiderCountCap
		local unit_count_max = (t_difficulty.danes_raiderCountCap * 0.5) + (dane_raid_count * 5)
		
		if unit_count_max > unit_count_cap then unit_count_max = unit_count_cap end
		local unit_count = unit_count_max - SGroup_CountSpawned(sg_dane_attackers)
		
		if York_PlayerInDaneCamp() == false and unit_count > 0 then
			
			local count = math.ceil(unit_count * 0.33)
			
			SpawnUnitsToModule({{type = "scar_shield_villager", numSquads = count}}, "DaneAttackers1", mkr_dane_attack1)
			SpawnUnitsToModule({{sbp = SBP.ENGLISH.UNIT_RAIDER_DANE, numSquads = count}}, "DaneAttackers2", mkr_dane_attack2)
			SpawnUnitsToModule({{type = "scar_shield_villager", numSquads = count}}, "DaneAttackers3", mkr_dane_attack3)
			
			SGroup_AddGroup(sg_dane_attackers, sg_dane_attackers1)
			SGroup_AddGroup(sg_dane_attackers, sg_dane_attackers2)
			SGroup_AddGroup(sg_dane_attackers, sg_dane_attackers3)
			
			dane_init_count = SGroup_CountSpawned(sg_dane_attackers)
		end
		
		York_TriggerDaneTravel()
		dane_raid_count = dane_raid_count + 1
	end
end

function York_TriggerDaneTravel()
	dane_current_state = "traveling"
	
	local module1 = MissionOMatic_FindModule("DaneAttackers1")
	module1.attackMove = attackMoveStyle_attackEverything
	RovingArmy_SetWithdrawThreshold(module1, 0.2)
	RovingArmy_SetTargets(module1, dane_travel_targets1)
	
	local module2 = MissionOMatic_FindModule("DaneAttackers2")
	module2.attackMove = attackMoveStyle_attackEverything
	RovingArmy_SetWithdrawThreshold(module2, 0.2)
	RovingArmy_SetTargets(module2, dane_travel_targets2)
	
	local module3 = MissionOMatic_FindModule("DaneAttackers3")
	module3.attackMove = attackMoveStyle_attackEverything
	RovingArmy_SetWithdrawThreshold(module3, 0.2)
	RovingArmy_SetTargets(module3, dane_travel_targets3)
end

function York_StartCheckInitDaneRaid()
	if dane_testing == false then
		Rule_AddInterval(York_CheckInitDaneRaid, 5)
	end
end

function York_CheckInitDaneRaid()
	
	if dane_camp_destroyed == true then
		Rule_RemoveMe() 
		return 
	end
	
	if not York_PlayerInDaneCamp() then
		York_StartInitialDaneRaid()
		Rule_RemoveMe() 
	end
end



function York_CheckFulfordTC()
	
	if EGroup_CountSpawned(eg_fulford_tc) <= 0 then
		
		if Objective_IsComplete(OBJ_StopDaneRaids) or Objective_IsComplete(OBJ_DestroyCampAlt) then
			
			York_AddFinalRebelTargets()
			Rule_RemoveMe()
		end
	else
		
		if initial_dane_raid_complete == false then
			
			if EGroup_GetAvgHealth(eg_fulford_tc) <= 0.5 then
				York_TriggerDaneWithdraw()
				Objective_Fail(OBJ_RepelAttack)
			end
		end
	end
end

function York_TestDisableWeaponOnTC()
	
	Player_GetAll(player1)
	EGroup_Filter(eg_allentities, "town_center", FILTER_KEEP)
	
	if EGroup_CountSpawned(eg_allentities) > 0 then
		
		local hardpoint_count = Entity_GetWeaponHardpointCount(EGroup_GetEntityAt(eg_allentities, 1))
		local result = nil
		
		if hardpoint_count > 0 then result = Modify_WeaponEnabled(eg_allentities, "hardpoint_01", false) end
		if hardpoint_count > 1 then Modify_WeaponEnabled(eg_allentities, "hardpoint_02", false) end
		if hardpoint_count > 2 then Modify_WeaponEnabled(eg_allentities, "hardpoint_03", false) end
	end
	
end

function York_TestMiddlethorpe()
	
	UnitEntry_DeploySquads(player1, nil, {type = "scar_manatarms", numSquads = 2}, mkr_villager_spawn_a)
	
	SGroup_DestroyAllSquads(sg_middlethorpe_outer_guard)
	SGroup_DestroyAllSquads(sg_middlethorpe_rebels1)
	SGroup_DestroyAllSquads(sg_middlethorpe_rebels2)
end

function York_TestFulford()
	
	UnitEntry_DeploySquads(player1, nil, {type = "scar_manatarms", numSquads = 2}, mkr_villager_spawn_b)

	SGroup_DestroyAllSquads(sg_fulford_outer_guard)
	SGroup_DestroyAllSquads(sg_fulford_rebels)
end

function York_TestDanes()
	
	dane_testing = true
	York_TestFulford()
	York_StartInitialDaneRaid()
end

function York_StartInitialDaneRaid()
	
	York_SpawnDaneAttackers1()
	York_SpawnDaneAttackers2()
	York_SpawnDaneAttackers3()
	
	dane_init_count = SGroup_CountSpawned(sg_dane_attackers)
	dane_current_state = "traveling"

	Rule_AddInterval(York_CheckDaneArrival, 2)
	Rule_AddInterval(York_SpawnDaneRaiders, t_difficulty.danes_spawnDelay)
	Rule_AddInterval(York_CheckDaneWithdraw, 1)
end

function York_SpawnDaneAttackers1()
	local count = t_difficulty.danes_raiderCount1
	local units = {{ sbp = SBP.ENGLISH.UNIT_RAIDER_DANE, numSquads = count },{ type = "scar_shield_villager", numSquads = count }}
	SpawnUnitsToModule(units, "DaneAttackers1", mkr_dane_attack1)
	SGroup_AddGroup(sg_dane_attackers, sg_dane_attackers1)
	RovingArmy_SetTargets(MissionOMatic_FindModule("DaneAttackers1"), dane_travel_targets1)
end

function York_SpawnDaneAttackers2()
	local count = t_difficulty.danes_raiderCount2
	local units = {{ sbp = SBP.ENGLISH.UNIT_RAIDER_DANE, numSquads = count },{ type = "scar_shield_villager", numSquads = count }}
	SpawnUnitsToModule(units, "DaneAttackers2", mkr_dane_attack2)
	SGroup_AddGroup(sg_dane_attackers, sg_dane_attackers2)
	RovingArmy_SetTargets(MissionOMatic_FindModule("DaneAttackers2"), dane_travel_targets2)
end

function York_SpawnDaneAttackers3()
	local count = t_difficulty.danes_raiderCount1
	local units = {{ sbp = SBP.ENGLISH.UNIT_RAIDER_DANE, numSquads = count },{ type = "scar_shield_villager", numSquads = count }}
	SpawnUnitsToModule(units, "DaneAttackers3", mkr_dane_attack3)
	SGroup_AddGroup(sg_dane_attackers, sg_dane_attackers3)
	RovingArmy_SetTargets(MissionOMatic_FindModule("DaneAttackers3"), dane_travel_targets3)
end

function York_CheckDaneArrival()
	
	if dane_current_state == "traveling" then
		if Prox_AreSquadsNearMarker(sg_dane_attackers, mkr_kp_fulford, ANY, 60) 
			or SGroup_CountSpawned(sg_dane_attackers) < dane_init_count then
			
			if danes_have_raided == false then
				danes_have_raided = true
				Objective_Start(OBJ_RepelAttack)
			end
			
			dane_current_state = "raiding"
			dane_raid_ticker = 0
			
			RovingArmy_SetTargets(MissionOMatic_FindModule("DaneAttackers1"), dane_raid_targets1)
			RovingArmy_SetTargets(MissionOMatic_FindModule("DaneAttackers2"), dane_raid_targets2)
			RovingArmy_SetTargets(MissionOMatic_FindModule("DaneAttackers3"), dane_raid_targets3)
			
		end
	elseif dane_current_state == "raiding" then
		if initial_dane_raid_complete == true then
			dane_raid_ticker = dane_raid_ticker + 1
			
			if dane_raid_ticker >= 60 then
				dane_raid_ticker = 0
				York_TriggerDaneWithdraw()
			end
		end
	end
end

function York_TriggerDaneWithdraw()
	dane_current_state = "retreating"
	
	local module1 = MissionOMatic_FindModule("DaneAttackers1")
	module1.attackMove = attackMoveStyle_ignoreEverything
	RovingArmy_SetWithdrawThreshold(module1, 2)
	
	local module2 = MissionOMatic_FindModule("DaneAttackers2")
	module2.attackMove = attackMoveStyle_ignoreEverything
	RovingArmy_SetWithdrawThreshold(module2, 2)
	
	local module3 = MissionOMatic_FindModule("DaneAttackers3")
	module3.attackMove = attackMoveStyle_ignoreEverything
	RovingArmy_SetWithdrawThreshold(module3, 2)
end

function York_CheckDaneWithdraw()
	
	if dane_current_state == "raiding" or dane_current_state == "traveling" then
		
		if SGroup_CountSpawned(sg_dane_attackers) <= (dane_init_count * 0.5) then
			York_TriggerDaneWithdraw()
			
			if Objective_IsStarted(OBJ_RepelAttack) and initial_dane_raid_complete == false then
				York_PlayWallaFear(sg_dane_attackers)
				initial_dane_raid_complete = true
				Rule_AddOneShot(York_CompleteInitialDaneRaid, 2)
			end
		end
	end
end


function York_SetControlGroup(data, index)
	
	local sg_control = nil
	
	local _AssignToGroup = function(gid, idx, sid)
		Misc_SetSquadControlGroup(sid, index)
	end
	
	if scartype(data) == ST_TABLE then
		for index, sgroup in pairs(data) do
			if scartype(sgroup) == ST_SGROUP then 
				SGroup_AddGroup(sg_control, sgroup)
			end
		end
	elseif scartype(data) == ST_SGROUP then
		sg_control = data
	end
	
	SGroup_ForEach(sg_control, _AssignToGroup)
end

function York_OnEntityKilled(context)

	if scartype(context.victimOwner) ~= ST_NIL then
		
		if context.victimOwner ~= player1 then
		
			if Entity_IsOfType(context.victim, "palisade_gate") then

				Music_PlayStinger(MUS_STING_POSITIVE)
				local pos = Util_GetPosition(context.victim)
				Player_GetAllSquadsNearMarker(player1, sg_temp, pos, 20) 
				York_PlayWallaEngage(sg_temp)
			end
			
		end

	end
end

function York_CompleteInitialDaneRaid()
	
	if SGroup_CountSpawned(sg_dane_attackers) > 0 then
		local pos = SGroup_GetPosition(sg_dane_attackers)
		Player_GetAllSquadsNearMarker(player1, sg_temp, pos, 30) 
		York_PlayWallaCelebrate(sg_temp)
	end
	
	Rule_Remove(DefeatDanes_OnSquadKilled)
	Music_UnlockIntensity()

	TrainingGoal_AddSendGold()
	
	Rule_AddOneShot(York_AddPalisadeTraining, 30)
	
	if not Objective_IsFailed(OBJ_RepelAttack) then
		Objective_Complete(OBJ_RepelAttack)
	end
end

function York_AddPalisadeTraining()
	TrainingGoal_AddBuildPalisade()
end

function York_CheckDaneCampReveal()

	if Player_CanSeeEGroup(playerNormans, eg_danehouses, ANY) or Player_CanSeeEGroup(playerNormans, eg_daneoutposts, ANY) then
		
		danes_discovered = true
		FOW_PlayerRevealArea(player1, Util_GetPosition(mkr_kp_dane_camp), 40, 60)
		
		if danes_have_raided == true then
			Util_StartIntel(EVENTS["DaneCampReveal_RaidComplete"])
		else
			Objective_Start(OBJ_DestroyCampAlt)
		end
		
		Rule_AddOneShot(York_MergeDaneLine1, 5)
		Rule_AddInterval(York_CheckDaneCampEntry, 1)
		Rule_RemoveMe()
	end
end

function York_CheckDaneCampLooted()
	
	if EGroup_Count(eg_dane_gold) == 0 then
		
		-- Unlock Achievement
		Game_SendCustomChallengeEvent(player1, CE_ACHIEVDANECAMPLOOTED, 1)
		
		Rule_RemoveMe()
	end
end

function York_MergeDaneLine1()
	Prefab_DoAction(MissionOMatic_FindModule("DaneDefenders"), "AddSGroup", sg_dane_line1)
end

function York_CheckDaneCampEntry()

	Player_GetAll(playerNormans)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_dane_defend, ANY, 30) then
		
		Prefab_DoAction(MissionOMatic_FindModule("DaneDefenders"), "AddSGroup", sg_dane_line2)
		Rule_RemoveMe()
	end
end

function York_PlayerInDaneCamp()

	Player_GetAll(playerNormans)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_kp_dane_camp, ANY, 55) then
		return true
	end
	return false
end

function York_RaidersInDaneCamp()

	if SGroup_CountSpawned(sg_dane_attackers) > 0 then
		if Prox_AreSquadsNearMarker(sg_dane_attackers, mkr_dane_defend, ANY, 40) then
			return true
		end
	end
	return false
end

function York_CheckBridgeTriggers()
	Player_GetAll(playerNormans)
	
	SGroup_Filter(sg_allsquads, "scar_villager", FILTER_REMOVE)
	SGroup_Filter(sg_allsquads, "gaia", FILTER_REMOVE)
	
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_bridge_trigger1, ANY) or Prox_AreSquadsNearMarker(sg_allsquads, mkr_bridge_trigger2, ANY) then
		
		Sound_SetMinimumMusicCombatIntensity(801, -1)
		Objective_Start(SOBJ_BreachGates)
		Rule_RemoveMe()
	end
end

function York_CheckMiddlethorpeTrigger()
	Player_GetAll(playerNormans)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_kp_middlethorpe, ANY, 55) then
		
		Music_LockIntensity(MUSIC_TENSE_COMBAT)
		
		FOW_PlayerRevealArea(player1, Util_GetPosition(mkr_kp_middlethorpe), 40, -1)
		
		Cmd_Move(sg_middlethorpe_og1, mkr_kp_middlethorpe)
		Cmd_Move(sg_middlethorpe_og2, mkr_kp_middlethorpe)
		Cmd_Move(sg_middlethorpe_og3, mkr_kp_middlethorpe)
		Rule_AddOneShot(York_MergeMiddlethorpeOuterGuard, 6)
		
		Rule_RemoveMe()
	end
end

function York_MergeMiddlethorpeOuterGuard()
	Prefab_DoAction(MissionOMatic_FindModule("MiddlethorpeRebels1"), "AddSGroup", sg_middlethorpe_outer_guard)
end

function York_CheckFulfordTrigger()
	Player_GetAll(playerNormans)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_kp_fulford, ANY, 60) then
		
		Music_LockIntensity(MUSIC_TENSE_COMBAT)

		FOW_PlayerRevealArea(player1, Util_GetPosition(mkr_kp_fulford), 45, -1)
		
		if not Objective_IsStarted(OBJ_CaptureFulford) then
			Objective_Start(OBJ_CaptureFulford)
		end
		
		Cmd_Move(sg_fulford_og1, mkr_kp_fulford)
		Cmd_Move(sg_fulford_og2, mkr_kp_fulford)
		Cmd_Move(sg_fulford_og3, mkr_kp_fulford)
		Rule_AddOneShot(York_MergeFulfordOuterGuard, 5)
		
		Rule_RemoveMe()
	end
end

function York_MergeFulfordOuterGuard()
	Prefab_DoAction(MissionOMatic_FindModule("FulfordRebels"), "AddSGroup", sg_fulford_outer_guard)
end

function York_CheckKeepTrigger()
	
	Player_GetAll(playerNormans)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_kp_keep, ANY, 45) then
		
		keep_revealed = true
		
		FOW_PlayerRevealArea(player1, Util_GetPosition(mkr_kp_keep), 40, -1)
		
		local units_bailey = {{type = "scar_spearman", numSquads = 20 }, {type = "scar_archer", numSquads = 10 }}
		Reinforcement_SetIdealComposition(MissionOMatic_FindModule("BaileyPatrol"), units_bailey)
		
		local units_keep = {{type = "scar_manatarms", numSquads = 20 }, {type = "scar_archer", numSquads = 10 }}
		Reinforcement_SetIdealComposition(MissionOMatic_FindModule("KeepPatrol"), units_keep)
		
		if Game_GetSPDifficulty() >= GD_HARD then
			Rule_AddInterval(York_CheckKeepRepair, 5)
		end
		Rule_AddInterval(York_CheckKeepDefendTrigger, 3)
		
		Objective_Complete(SOBJ_BreachGates, false, false)
		Rule_RemoveMe()
	end
end

function York_CheckKeepDefendTrigger()
	
	if rebels_defending == false then
		
		Player_GetAll(playerNormans)
		if Prox_AreSquadsNearMarker(sg_allsquads, mkr_kp_keep, ANY, 25) then
			rebels_defending = true
			rebels_defend_counter = 0
			Music_LockIntensity(MUSIC_RARE)
			York_DefendTheKeep()
		end
	else
		
		Player_GetAll(playerNormans)
		if not Prox_AreSquadsNearMarker(sg_allsquads, mkr_kp_keep, ANY, 25) then
			
			rebels_defend_counter = rebels_defend_counter + 1
			
			if rebels_defend_counter >= rebels_defend_phase_length then
				
				rebels_defending = false
				York_UpdatePatrolTargets()
				Music_UnlockIntensity()
			end

		end
	end
end

function York_CheckReactionScout()
	if Player_CanSeeSGroup(playerNormans, sg_middlethorpe_scout, ANY) then
		Rule_AddOneShot(York_TriggerReactionScout, 2)
		Rule_RemoveMe()
	end
end

function York_TriggerReactionScout()
	Cmd_Move(sg_middlethorpe_scout, mkr_middlethorpe_scout)
end

function York_ShowTributeMenu()

	-- Configure diplomacy UI to only show the Danes
	Diplomacy_OverrideSettings(true, true, false, false)
	Diplomacy_OverridePlayerSettings(player1, false)
	Diplomacy_OverridePlayerSettings(player2, false)
	Diplomacy_OverridePlayerSettings(player3, false)
	Diplomacy_OverridePlayerSettings(player4, true, true, false, false, true, false)
	Diplomacy_OverridePlayerSettings(playerNeutrals, false)
	Diplomacy_SetTaxRate(Game_GetLocalPlayer(), 0.0)
	Diplomacy_ShowUI(true)
end

function York_HideTributeMenu()

	Core_CallDelegateFunctions("DiplomacyEnabled", false)
	Diplomacy_ShowUI(false)
end

function York_SpawnReinforcements(units, sgroup, spawn, destination, onClickEvent)
	
	--if reinforcements exceep pop cap, show message to explain that pop cap has been hit?
	
	local popSpace = 200 - Player_GetTotalPopulation(player1)
	
	for i = 1, #units do
		local unit = units[i]
		
		if popSpace == 0 then
			unit.numSquads = 0
		elseif unit.numSquads > popSpace then
			local diff = unit.numSquads - popSpace
			unit.numSquads = unit.numSquads - diff
			popSpace = 0
		else
			popSpace = popSpace - unit.numSquads
		end
	end
	
	if Player_GetTotalPopulation(player1) < 200 then
		UnitEntry_DeploySquads(player1, sgroup, units, spawn, nil, nil, {})	
		Rule_AddOneShot(York_MoveReinforcements, 0.5, {sgroup = sgroup, marker = destination, onClick = onClickEvent})
	end
	
	if popSpace == 0 then
		York_DisplayPopcapCue()
	end
end

function York_DisplayPopcapCue()
	local cue = _events.popcap.cue
	UI_CreateEventCueClickable(-1, cue.lifetime, 0, cue.repeatTime, cue.title, cue.desc, cue.template, cue.icon, cue.sfx, cue.color.r, cue.color.g, cue.color.b, cue.color.a, cue.style, __DoNothing)
end

function York_MoveReinforcements(context, data)
	Cmd_FormationMove(data.sgroup, data.marker)
	Sound_Play2D(MUS_STING_TRIUMPHANT)
	EventCues_CallToAction("$11172066", CTA_CELEBRATE, nil, data.onClick, data.sgroup, 20)
	Rule_AddInterval(York_PlayCheerWhenReinforcementsAreSeen, 1, {sgroup = data.sgroup})
end

function York_PlayCheerWhenReinforcementsAreSeen(context, data)
	if Player_CanSeeSGroup(player1, data.sgroup, ANY) then 	
		Sound_PlayOnSquad("sfx_campaign_scripted_medium_group_celebrate", data.sgroup)
		Rule_RemoveMe()
	end
end

function York_PlayWallaCelebrate(sgroup)
	
	local sound_name = nil
	local unit_count = SGroup_CountSpawned(sgroup)
	
	if unit_count <= 10 then
		sound_name = WALLA_CAMP_CELEBRATE_SMALL
	elseif unit_count <= 20 then
		sound_name = WALLA_CAMP_CELEBRATE_MEDIUM
	else
		sound_name = WALLA_CAMP_CELEBRATE_LARGE
	end
	
	Sound_PlayOnSquad(sound_name, sgroup)
end

function York_PlayWallaFear(sgroup)
	
	local sound_name = nil
	local unit_count = SGroup_CountSpawned(sgroup)
	
	if unit_count <= 10 then
		sound_name = WALLA_CAMP_FEAR_SMALL
	elseif unit_count <= 20 then
		sound_name = WALLA_CAMP_FEAR_MEDIUM
	else
		sound_name = WALLA_CAMP_FEAR_LARGE
	end
	
	Sound_PlayOnSquad(sound_name, sgroup)
end

function York_PlayWallaEngage(sgroup)
	
	local sound_name = nil
	local unit_count = SGroup_CountSpawned(sgroup)
	
	if unit_count <= 10 then
		sound_name = WALLA_CAMP_ENGAGE_SMALL
	elseif unit_count <= 20 then
		sound_name = WALLA_CAMP_ENGAGE_MEDIUM
	else
		sound_name = WALLA_CAMP_ENGAGE_LARGE
	end
	
	Sound_PlayOnSquad(sound_name, sgroup)
end

--? @shortdesc pauses music
function York_PauseMusic(delay, restartFunction)
	Music_StopMedium()
	Rule_AddOneShot(restartFunction, delay)
end

--? @shortdesc restarts music
function York_RestartMusic()
	Music_RestartAfterObjective(1)
	--Sound_SetMinimumMusicCombatIntensity(801, -0)
end

--? @shortdesc restarts music with no minimum intensity
function York_RestartMusicNoMin()
	Music_RestartAfterObjective(1)
	Sound_SetMinimumMusicCombatIntensity(0, 0)
end

function York_CheckKeepRepair()
	
	if entity_keep ~= nil then
		
		Player_GetAll(player1)
		if not Prox_AreSquadsNearMarker(sg_allsquads, mkr_kp_keep, ANY, 10) then
		
			if Entity_GetHealthPercentage(entity_keep) < 0.98 then
				
				if SGroup_CountSpawned(sg_keep_villagers) < 1 then
					
					SGroup_Clear(sg_temp)
					local options = {dynamicSpawnType = DST_FURTHEST_HIDDEN, destination = mkr_kp_keep}
					UnitEntry_DeploySquads(playerCityRebels, sg_temp, {{type = "scar_villager", numSquads = 4}}, mkr_city_edgeroad, nil, nil, options)
					SGroup_AddGroup(sg_keep_villagers, sg_temp)
					
				elseif Entity_IsUnderRepair(entity_keep) == false then
					
					Cmd_Ability(sg_keep_villagers, BP_GetAbilityBlueprint("villager_repair"), eg_keep)
				end
				
			end
			
		end
		
	end
end

function York_StopRebels()
	
	Rule_Remove(York_ReinforceRebels)
	Wave_Pause(rebel_wave_1)
	Wave_Pause(rebel_wave_2)
	Wave_Pause(rebel_wave_3)
	
end

function York_ReinforceRebels()
	
	if Player_GetTotalPopulation(playerCityRebels) < rebel_pop_space_max then
		
		if rebel_escalation_counter < rebel_escalation_max then
			rebel_escalation_counter = rebel_escalation_counter + 1
		end
		
		rebel_pop_space = rebel_pop_space_max - Player_GetTotalPopulation(playerCityRebels)
		
		York_CheckWave(rebel_wave_1, rebel_wave_data_1)
		York_CheckWave(rebel_wave_2, rebel_wave_data_2)
		York_CheckWave(rebel_wave_3, rebel_wave_data_3)
		
	end
end

function York_CheckWave(wave, data)
	
	local unit_points = rebel_escalation_counter
	local vill_count = York_GetRebelVillagerCount()
	
	unit_points = unit_points * (vill_count / rebel_init_vill_count)
	unit_points = math.floor(unit_points)
	
	if EGroup_CountSpawned(data.egroup) > 0 and 
	   SGroup_CountSpawned(data.sgroup) < t_difficulty.rebels_maxModuleSize then
		
		for i = 1, #data.unit_table do
			local entry = data.unit_table[i]
			
			if rebel_pop_space < 0 then rebel_pop_space = 0 end
			if unit_points > rebel_pop_space then unit_points = rebel_pop_space end
			rebel_pop_space = rebel_pop_space - unit_points
			
			entry.numSquads = unit_points
		end
		
		Wave_SetUnits(wave, data.unit_table)
		Wave_Prepare(wave)
		
	end
end

function York_GetRebelVillagerCount()
	
	Player_GetAll(playerCityRebels)
	SGroup_Clear(sg_temp)
	SGroup_Filter(sg_allsquads, "scar_villager", FILTER_REMOVE, sg_temp)
	return SGroup_CountSpawned(sg_temp)	
end


function York_SetUpOutro ()
	
	Rule_Remove(York_CheckMissionFail)
	York_StopRebels()
	
	if not keep_revealed then
		Rule_Remove(York_CheckKeepTrigger)
	end
	
	Entity_SetHealth(entity_keep, 0.2)
	Entity_SetInvulnerable(entity_keep, false, 0)
	
	if not Entity_IsBurning(entity_keep) then
		Entity_SetOnFire(entity_keep)
	end
	
	-- to stop outposts and keep shooting
	Player_SetRelationship(playerCityRebels, playerNormans, R_NEUTRAL)
	Player_SetRelationship(playerNormans, playerCityRebels, R_NEUTRAL)
	
	--reset enemy player color to ensure consistency
	Game_SetPlayerSlotColour(playerCityRebels, 2)
	
	local function _Burn (gid, index, iid)
		Entity_SetHealth(iid, 0.2)
		if Entity_IsBurning(iid) ~= true then
			Entity_SetOnFire(iid)
		end	
	end
	
	EGroup_ForEach(eg_outposts, _Burn)
	
	Player_GetAll(playerCityRebels)
	SGroup_DestroyAllSquads(sg_allsquads)
	Player_GetAll(playerVillageRebels)
	SGroup_DestroyAllSquads(sg_allsquads)
	Player_GetAll(playerNormans)
	SGroup_DestroyAllSquads(sg_allsquads)	
	Player_GetAll(playerNeutrals)
	SGroup_DestroyAllSquads(sg_allsquads)
	
	local units = {
		{type = "scar_archer", numSquads = 5, spawn = mkr_outro_1, facing = Marker_GetPosition(mkr_kp_keep)},
		{type = "scar_spearman", numSquads = 5, spawn = mkr_outro_2, facing = Marker_GetPosition(mkr_kp_keep)},
		{type = "scar_manatarms", numSquads = 5, spawn = mkr_outro_3, facing = Marker_GetPosition(mkr_kp_keep)},
		{type = "scar_manatarms", numSquads = 5, spawn = mkr_outro_4, facing = Marker_GetPosition(mkr_kp_keep)},
		{type = "scar_manatarms", numSquads = 5, spawn = mkr_outro_5, facing = Marker_GetPosition(mkr_kp_keep)},
		{type = "scar_spearman", numSquads = 5, spawn = mkr_outro_6, facing = Marker_GetPosition(mkr_kp_keep)},
		{type = "scar_archer", numSquads = 5, spawn = mkr_outro_7, facing = Marker_GetPosition(mkr_kp_keep)},
	}

	UnitEntry_DeploySquads(playerNormans, sg_celebrate, units)
	SGroup_EnableCheering (sg_celebrate, true, -1, WALLA_CAMP_CELEBRATE_LARGE, 4)
	
	local william = {
		{sbp = SBP.CAMPAIGN.UNIT_KING_WILLIAM_CMP_ENG, numSquads = 1, spawn = mkr_outro_ride_1, sgroup = sg_outro_william},
	}
	
	local ride ={
		--mkr_outro_ride_2,
		--mkr_outro_ride_3,
		--mkr_outro_ride_4,
		--mkr_outro_ride_5,
		--mkr_outro_ride_6,
		--mkr_outro_ride_7,
		--mkr_outro_ride_8,
		--mkr_outro_ride_1,
		--mkr_outro_ride_2,
		--mkr_outro_ride_3,
		--mkr_outro_ride_4,
		--mkr_outro_ride_5,
		--mkr_outro_ride_6,
		--mkr_outro_ride_7,
		--mkr_outro_ride_1,
		mkr_outro_ride_2,
		mkr_outro_ride_3,
		mkr_outro_william,
		}
	
	Util_UnitParade(ride, william)
	Modify_UnitSpeed(sg_outro_william, 0.5)
end