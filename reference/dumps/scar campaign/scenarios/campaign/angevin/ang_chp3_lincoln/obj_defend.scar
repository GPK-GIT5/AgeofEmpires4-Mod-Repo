--
-- Lincoln 1141 - Defend
--


function Defend_InitObjectives()
	
	OBJ_DefendKeep = {
		
		Title = "$11180384", -- Lincoln Keep must not fall
		Type = ObjectiveType_Information,
		Icon = "icons/objectives/campaign_objective_info",
		--Intel_Start = EVENTS.KeepFall,
		OnStart = DefendKeep_Start,
		OnFail = DefendKeep_Fail,
	}
	
	Objective_Register(OBJ_DefendKeep)
	
end

function DefendKeep_Start()
	
	HintPoint_Add(mkr_keep_defend,  true, 11180385, 2, HPAT_Attack, "icons/objective_arrow", nil, true, nil)
	--Objective_AddUIElements(OBJ_DefendKeep, mkr_keep_defend, true, 11180385, true) -- Keep
	Rule_AddInterval(DefendKeep_Check, 1)
end

function DefendKeep_Fail()
	Lincoln_Fail()
end


function DefendKeep_Check()
	
	if EGroup_CountSpawned(eg_keep) == 0 then
		
		Objective_Fail(OBJ_DefendKeep)
		Rule_RemoveMe()
	end
end
