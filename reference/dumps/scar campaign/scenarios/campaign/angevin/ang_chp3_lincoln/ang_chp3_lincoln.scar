function Lincoln_StartRendezvous()
	Lincoln_SpawnWelsh()
	Objective_Start(OBJ_Rendezvous)
end

function Lincoln_FinalAttackRetreat()
	
	RovingArmy_SetWithdrawThreshold(MissionOMatic_FindModule("RoyalGuard1"), 2)
	RovingArmy_SetWithdrawThreshold(MissionOMatic_FindModule("RoyalGuard2"), 2)
	RovingArmy_SetWithdrawThreshold(MissionOMatic_FindModule("FinalAttackers1"), 2)
	RovingArmy_SetWithdrawThreshold(MissionOMatic_FindModule("FinalAttackers2"), 2)
	RovingArmy_SetWithdrawThreshold(MissionOMatic_FindModule("FinalAttackers3"), 2)

	Player_GetAll(playerStephen)
	SGroup_FilterSpawned(sg_allsquads, FILTER_KEEP)
	Modify_ReceivedDamage(sg_allsquads, 2)
	
end

function Lincoln_BeginEndStage()
	
	if not endStageHasBegun then
		
		endStageHasBegun = true
		EGroup_SetInvulnerable(eg_keep, true)
		Rule_AddOneShot(Lincoln_Complete, 5)
		
	end
end

function Lincoln_LaunchFinalAttack()
	
	RovingArmy_SetTargets(MissionOMatic_FindModule("FinalAttackers1"), t_final_attack_targets[1])
	RovingArmy_SetTargets(MissionOMatic_FindModule("FinalAttackers2"), t_final_attack_targets[2])
	RovingArmy_SetTargets(MissionOMatic_FindModule("FinalAttackers3"), t_final_attack_targets[3])
	RovingArmy_SetTargets(MissionOMatic_FindModule("RoyalGuard1"), t_final_attack_targets[4])
	RovingArmy_SetTargets(MissionOMatic_FindModule("RoyalGuard2"), t_final_attack_targets[5])
	
	RovingArmy_SetTarget(MissionOMatic_FindModule("GeneralGroup"), mkr_stephen_idle)
	
	SGroup_AddGroup(sg_bodyguard, sg_bodyguard1)
	SGroup_AddGroup(sg_bodyguard, sg_bodyguard2)
	
	bodyguard_init_count = SGroup_CountSpawned(sg_bodyguard)
	
	Modify_ReceivedDamage(sg_stephen, 0.25)
	Rule_AddInterval(Lincoln_CheckRoyalGuard, 2)
	
	Objective_Start(OBJ_DefeatStephen)
end

function Lincoln_CheckRoyalGuard()
	
	if SGroup_CountSpawned(sg_stephen) == 0 then
		Rule_RemoveMe()
	end
	
	local bodyguard_count = SGroup_CountSpawned(sg_bodyguard)
	local bodyguard_strength = bodyguard_count / bodyguard_init_count
	
	if bodyguard_strength <= bodyguard_threshold then
		Modify_ReceivedDamage(sg_stephen, 4)
		Rule_RemoveMe()
	end
	
end



function Lincoln_CheckFinalAttackTrigger()
	
	if Objective_IsStarted(OBJ_DefeatStephen) then
		Rule_RemoveMe()
	end
	
	Player_GetAll(player1)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_fa_trigger, ANY, 60) then
		
		Lincoln_LaunchFinalAttack()
		Rule_RemoveMe()
	end
	
end


function Lincoln_CheckKeep()
	
	if gateBreached == true then
		Rule_RemoveMe()
	end
	
	Player_GetAll(playerStephen)
	
	if Entity_GetHealthPercentage(entity_keep) < 1 then
		
		--Lincoln_TriggerBreachAlert()
		
		Sound_Play2D(MUS_STINGER_WARNING)
		EventCues_CallToAction("$11180391", CTA_ALARM, nil, nil, mkr_keep_defend, 20) -- The keep is under threat!
		Objective_Start(OBJ_DefendKeep)
		
		Rule_RemoveMe()
	end
	
end

function Lincoln_OnEntityKilled(context)
	
	if scartype(context.victim) ~= ST_NIL then
		
		if Entity_IsOfType(context.victim, "stone_gate") or Entity_IsOfType(context.victim, "stone_wall") then
			
			local isValidDeath = false
			
			if scartype(context.killer) == ST_NIL then
				isValidDeath = true
			elseif Util_GetPlayerOwner(context.killer) == playerStephen then
				isValidDeath = true
			end
			
			if isValidDeath == true then
					
				local posVictim = Util_GetPosition(context.victim)
				local posKeep1 = Util_GetPosition(mkr_keep_defend)
				local posKeep2 = Util_GetPosition(mkr_keep_defend_east)
				
				if World_PointPointProx(posKeep1, posVictim, 42) or World_PointPointProx(posKeep2, posVictim, 42) then
					
					Lincoln_TriggerBreachAlert()
					Rule_RemoveMe()
				end
				
			end
			
		end
		
	end
	
end

function Lincoln_TriggerBreachAlert()
	
	if gateBreached == false then
		gateBreached = true
		
		Sound_Play2D(MUS_STINGER_WARNING)
		Util_StartIntel(EVENTS["KeepFall"])
		
		if not Objective_IsStarted(OBJ_DefendKeep) then
			
			EventCues_CallToAction("$11180391", CTA_ALARM, nil, nil, mkr_keep_defend, 20) -- The keep is under threat!
			Rule_AddOneShot(Lincoln_StartDefendKeep, 3)
			
		end
		
	end
end

function Lincoln_StartDefendKeep()
	Objective_Start(OBJ_DefendKeep)
end


function Achievement_OnDamage(context)
	
	-- Achievement check if Castle has been damaged
	defenseKeepDamaged = true
	
	Rule_RemoveMe()
		
end

function Lincoln_SetAdvanceWelshTargets()
	
	local module_a = MissionOMatic_FindModule("WelshArmyA")
	local module_b = MissionOMatic_FindModule("WelshArmyB")
	local module_c = MissionOMatic_FindModule("WelshArmyC")
	
	RovingArmy_AddTargets(module_a, advance_welsh_targets_a)
	RovingArmy_AddTargets(module_b, advance_welsh_targets_b)
	RovingArmy_AddTargets(module_c, advance_welsh_targets_c)
	
	module_a.attackMove = true
	module_b.attackMove = true
	module_c.attackMove = true

end

function Lincoln_SetFinalWelshTargets()
	
	local module_a = MissionOMatic_FindModule("WelshArmyA")
	local module_b = MissionOMatic_FindModule("WelshArmyB")
	local module_c = MissionOMatic_FindModule("WelshArmyC")
	
	RovingArmy_AddTargets(module_a, final_welsh_targets_a)
	RovingArmy_AddTargets(module_b, final_welsh_targets_b)
	RovingArmy_AddTargets(module_c, final_welsh_targets_c)
	
	Rule_AddInterval(Lincoln_CheckWelshCastleTrigger, 2)
end

function Lincoln_CheckWelshCastleTrigger()
	
	Player_GetAll(playerWelsh)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_castle1, ANY, 35) then
		
		Rule_AddOneShot(Lincoln_DisbandWelsh, 25)
		Rule_RemoveMe()
	end
	
end

function Lincoln_DisbandWelsh()
	
	local module_a = MissionOMatic_FindModule("WelshArmyA")
	local module_b = MissionOMatic_FindModule("WelshArmyB")
	local module_c = MissionOMatic_FindModule("WelshArmyC")
	
	--Prefab_DoAction(module_a, "RemoveSGroup", sg_welsh_army_a)
	
	RovingArmy_ClearTargets(module_a)
	RovingArmy_ClearTargets(module_b)
	RovingArmy_ClearTargets(module_c)
	
	RovingArmy_Disband(module_a)
	RovingArmy_Disband(module_b)
	RovingArmy_Disband(module_c)
	
	Rule_AddOneShot(Lincoln_GetWelshArchers, 5)
end

function Lincoln_GetWelshArchers()
	
	Player_GetAll(playerWelsh)
	sg_welsh_archers = SGroup_CreateIfNotFound("sg_welsh_archers")
	sg_welsh_spearmen = SGroup_CreateIfNotFound("sg_welsh_spearmen")
	
	local _GetArcher = function(gid, idx, sid)
		if Squad_IsOfType(sid, "scar_archer") then 
			SGroup_Add(sg_welsh_archers, sid) 
		else
			SGroup_Add(sg_welsh_spearmen, sid) 
		end
	end

	SGroup_ForEach(sg_allsquads, _GetArcher)
	
	Rule_AddOneShot(Lincoln_MoveWelshArchers, 5)
end

function Lincoln_MoveWelshArchers()
	
	local i = 1
	local _MoveArcher = function(gid, idx, sid)
		
		SGroup_Clear(sg_single)
		SGroup_Add(sg_single, sid) 
		
		local marker = Marker_FromName("mkr_wall_archer"..tostring(i), "")
		i = i + 1
		if i > 9 then
			i = 1	
		end
		
		Cmd_Move(sg_single, marker)
	end

	SGroup_ForEach(sg_welsh_archers, _MoveArcher)
	Rule_AddOneShot(Lincoln_ReformWelshSpearmen, 1)
end

function Lincoln_ReformWelshSpearmen()
	
	if SGroup_CountSpawned(sg_welsh_spearmen) > 0 then
		Prefab_DoAction(MissionOMatic_FindModule("WelshDefenders"), "AddSGroup", sg_welsh_spearmen)
	end
end

function Lincoln_ReinforceAssault()
	
	local besiegers = t_besiegers[besiege_index]
	
	if not besiegers.active then
		
		local a = besiege_index
		
		for i = 1, #t_besiegers do
			
			a = a + 1
			if a > #t_besiegers then
				a = 1
			end
			
			besiegers = t_besiegers[a]
			if besiegers.active then
				besiege_index = a
				break
			end
		end
	end
	
	
	local siege_count = 0
	local siege_count_total = 0
	
	local _CountSiege = function(gid, idx, sid)
		if Squad_IsOfType(sid, "scar_mangonel") or Squad_IsOfType(sid, "scar_ram") or Squad_IsOfType(sid, "scar_siege_tower") then
			siege_count = siege_count + 1
			siege_count_total = siege_count_total + 1
		end
	end

	for i = 1, 5 do
		siege_count = 0
		SGroup_ForEach(SGroup_FromName("sg_besiegers"..tostring(i)), _CountSiege)
		t_besiegers[i].siege_count = siege_count
	end
	
	local unit_count = t_difficulty.enemy_besieger_count + siege_wave_count
	local unit_count_max = t_difficulty.enemy_besieger_count * 2
	
	if unit_count > unit_count_max then
		unit_count = unit_count_max
	end
	
	if besiegers.active and not Player_CanSeePosition(player1, Util_GetPosition(besiegers.marker)) then
		
		unit_count = unit_count - SGroup_CountSpawned(besiegers.sgroup)
		
		if unit_count > 0 then
			
			local includes_siegeTower = false
			local type1 = t_besieger_units[besieger_unit_index][1]
			local type2 = t_besieger_units[besieger_unit_index][2]
			
			local units = {
				{ type = type1, numSquads = math.ceil(unit_count * 0.5) },
				{ type = type2, numSquads = math.ceil(unit_count * 0.5) },
			}
			
			besieger_unit_index = besieger_unit_index + 1
			if besieger_unit_index > #t_besieger_units then besieger_unit_index = 1 end
			
			if siege_count_total < t_difficulty.enemy_siege_max and besiegers.siege_count < 2 then
				
				local siege_dist = t_siege_distribution[t_difficulty.enemy_siege_diff]
				local siege_count_new = siege_dist[siege_distribution_index]
				
				siege_distribution_index = siege_distribution_index + 1
				if siege_distribution_index > #siege_dist then siege_distribution_index = 1 end
				
				if siege_count_new > 0 then
					
					for i = 1, siege_count_new do
						Lincoln_AddSiegeWeapon(units)
					end
				end
				
			end
			
			SpawnUnitsToModule(units, besiegers.module, besiegers.marker)
			local module = MissionOMatic_FindModule(besiegers.module)
			
			for i = 1, #units do
				local entry = units[i]
				if entry.type == "scar_siege_tower" then includes_siegeTower = true end
			end
			
			if includes_siegeTower then
				RovingArmy_SetTargets(module, t_besiege_targets[besiege_index])
			else
				RovingArmy_SetTargets(module, {mkr_keep_dest1, mkr_keep_dest2})
			end
		end

	end
	
	siege_wave_count = siege_wave_count + 1
	besiege_index = besiege_index + 1
	if besiege_index > 5 then besiege_index = 1 end

end

function Lincoln_AddSiegeWeapon(units)
	
	local siege_type = t_siege_units[siege_unit_index]
	local siege_units = { type = siege_type, numSquads = 1 }
	
	siege_unit_index = siege_unit_index + 1
	if siege_unit_index > #t_siege_units then siege_unit_index = 1 end
	
	table.insert(units, siege_units)
end


