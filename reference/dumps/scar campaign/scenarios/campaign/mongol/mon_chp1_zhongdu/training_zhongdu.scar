function Predicate_UserHasSelectedGenghis(goal)
	
	Misc_GetSelectedSquads(sg_temp, true)
	return SGroup_CountSpawned(g_leaderGenghisKhan.sgroup) >= 1 and SGroup_ContainsSGroup(sg_temp, g_leaderGenghisKhan.sgroup, ALL)
end

function Predicate_UserHasLookedAtGenghisAbility(goal)
	
	local abilityBP = BP_GetAbilityBlueprint("campaign_mon_chp1_zhongdu_incendiaries")
	return SGroup_CountSpawned(g_leaderGenghisKhan.sgroup) >= 1 and (PredicateHelper_HasUserHoveredOverBP(goal, abilityBP) or training_previousAbilityBlueprint == abilityBP)
end

function Predicate_UserHasNotActivatedGenghisLeaderAbilityRecently(goalSequence)
	
	return Event_IsAnyRunning() == false and SGroup_CountSpawned(g_leaderGenghisKhan.sgroup) >= 1 and Player_OwnsSGroup(player1, g_leaderGenghisKhan.sgroup, ALL)
end


--
-- SIEGE ENGINEERS
--
function Zhongdu_TriggerSiegeEngineersHint_Xbox(goalSequence)
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	if currentTime > __t_trainingHoverInterval then	
		
		Player_GetAll(g_playerMongol)
		local entities = Player_GetEntities(g_playerMongol)
		EGroup_FilterUnderConstruction(entities, FILTER_REMOVE)
	
		goalSequence.goals[1].key = nil
		goalSequence.goals[2].key = nil
		
		for i = 1, EGroup_Count(entities) do
			local entity = EGroup_GetEntityAt(entities, i)
			if entity ~= nil and Entity_GetBlueprint(entity) == EBP.MONGOL.BUILDING_TECH_UNIT_INFANTRY_MON then
				if Misc_IsEntityOnScreen(entity, 100) then 
					goalSequence.goals[1].key = Entity_GetID(entity)
					goalSequence.goals[1].keyIsEntity = true
					goalSequence.goals[2].key = Entity_GetID(entity)
					goalSequence.goals[3].key = BP_GetUpgradeBlueprint("upgrade_siege_engineers")
					break
				end
			end
		end
		
		if goalSequence.goals[1].key ~= nil then
			return true
		end
	end
	return false
end

