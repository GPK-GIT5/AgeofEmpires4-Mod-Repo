end

function Juyong_SendWave(wave)
	Juyong_UpdateMonTC()
	local newWave = Wave_Prepare(wave)
	if newWave ~= nil then
		table.insert(assaultWaveList, newWave.assault_module)
		RovingArmy_AddTarget(newWave.assault_module, mon_tc_position)
	end
end

function Juyong_OnBuildingBurned(context)
	
end

function Juyong_OnEntityDestroyed(context)
	local victim = context.victim
	local owner = context.victimOwner
	
	if owner == g_playerJin then 
		if Entity_IsOfType(victim, "building") then			
			if Objective_IsStarted(SOBJ_YanqingBuildings) and not Objective_IsComplete(SOBJ_YanqingBuildings) then
				local current = SOBJ_YanqingBuildings.counterTarget - EGroup_Count(eg_yanqing)
				Obj_SetProgress(SOBJ_YanqingBuildings.ID, current / SOBJ_YanqingBuildings.counterTarget)
			end
			if Objective_IsStarted(SOBJ_Village_1) and not Objective_IsComplete(SOBJ_Village_1) then
				local current = SOBJ_Village_1.counterTarget - EGroup_Count(SOBJ_Village_1.egroup)
				Objective_SetCounter(SOBJ_Village_1, SOBJ_Village_1.counterTarget - EGroup_Count(SOBJ_Village_1.egroup), SOBJ_Village_1.counterTarget)
			end
			if Objective_IsStarted(SOBJ_Village_2) and not Objective_IsComplete(SOBJ_Village_2) then
				local current = SOBJ_Village_2.counterTarget - EGroup_Count(SOBJ_Village_2.egroup)
				Objective_SetCounter(SOBJ_Village_2, SOBJ_Village_2.counterTarget - EGroup_Count(SOBJ_Village_2.egroup), SOBJ_Village_2.counterTarget)
			end
			if Objective_IsStarted(SOBJ_Village_3) and not Objective_IsComplete(SOBJ_Village_3) then
				local current = SOBJ_Village_3.counterTarget - EGroup_Count(SOBJ_Village_3.egroup)
				Objective_SetCounter(SOBJ_Village_3, current, SOBJ_Village_3.counterTarget)
			end
			if objectiveBuildingCount > (EGroup_Count(SOBJ_Village_1.egroup) + EGroup_Count(SOBJ_Village_2.egroup) + EGroup_Count(SOBJ_Village_3.egroup)) then
				objectiveBuildingCount = (EGroup_Count(SOBJ_Village_1.egroup) + EGroup_Count(SOBJ_Village_2.egroup) + EGroup_Count(SOBJ_Village_3.egroup))
				Sound_Play2D("sfx_campaign_scripted_ui_objective_counter_update")
			end
			if Objective_IsComplete(SOBJ_YanqingBuildings) and Objective_IsComplete(SOBJ_Village_1) and Objective_IsComplete(SOBJ_Village_2) and Objective_IsComplete(SOBJ_Village_3) then
				Rule_RemoveMe()
			end
		end
	end
end

