function Juyong_SupplyCaravanOnClick()
    Sound_PlayOnSquad(WALLA_CAMP_CELEBRATE_SMALL, sg_mon_reinforcements) -- Walla for the reinforcement	
end

function Juyong_MoveBuildingsHint(context, data)
	eg_movingbuildings = EGroup_CreateIfNotFound("eg_movingbuildings")
	EGroup_Clear(eg_movingbuildings)
	Player_GetAll(g_playerMongol)
	EGroup_Filter(eg_allentities, "mobile_building", FILTER_REMOVE, eg_movingbuildings)
	if EGroup_IsEmpty(eg_movingbuildings) then
		MissionTutorial_JuyongMovingBuildings()
		Util_StartIntel(EVENTS.Camp_Move_Hint)
		Rule_RemoveMe()
	end
end

function Juyong_GetBurnableList()
	local _RemoveNonBurnable = function (gid, idx, eid)
		if not Entity_IsBurnable(eid) or Entity_IsBurning(eid) then
			EGroup_Remove(eg_jin_burnables, eid)
		end
	end
			
	eg_jin_burnables = EGroup_CreateIfNotFound("eg_jin_burnables")
	
	Player_GetAll(g_playerJin, sg_allsquads, eg_jin_burnables)
	EGroup_Filter(eg_jin_burnables, "stone_wall", FILTER_REMOVE)
	EGroup_ForEach(eg_jin_burnables, _RemoveNonBurnable)
	
	Rule_AddInterval(Juyong_IsBurnableBurning, 0.125)
end

function Juyong_IsBurnableBurning()
	
	-- Persistently track the number, so we can spot disappearances
	g_trackedBurnables = g_trackedBurnables or EGroup_Count(eg_jin_burnables)
	
	-- How much should burnt buildings, or assumed burnt buildings, yield?
	local burnBountyAmount = (50 * 3)
	if Player_HasUpgrade(g_playerMongol, UPG.MONGOL.UPGRADE_RAID_BOUNTY_IMPROVED_MON) then
		burnBountyAmount = (175 * 3)
	elseif Player_HasUpgrade(g_playerMongol, UPG.MONGOL.UPGRADE_RAID_BOUNTY_MON) then
		burnBountyAmount = (150 * 3)
	end
	
	-- Check for each building to see if it's burning - if it is, respond to the burn state
	local _RemoveBurning = function (gid, idx, eid)
		if Entity_IsBurning(eid) then
			EGroup_Remove(eg_jin_burnables, eid)
			burnResourcesClaimed = burnResourcesClaimed + burnBountyAmount
			if Objective_IsStarted(OBJ_RaidBuildings) and not Objective_IsComplete(OBJ_RaidBuildings) then
				Objective_SetCounter(OBJ_RaidBuildings, burnResourcesClaimed, OBJ_RaidBuildings.counterTarget)
			end
		end
	end
	
	-- Did the EGroup lose any buildings since the last time it was checked?
	-- If so, we have to assume those buildings were destroyed AND burnt in the same interval
	-- We're not getting tech support for a proper callback for when things are set on fire, so this is the best we can do
	local sinceLastCheckDelta = g_trackedBurnables - EGroup_Count(eg_jin_burnables)
	if sinceLastCheckDelta > 1 then
		burnResourcesClaimed = burnResourcesClaimed + (burnBountyAmount * sinceLastCheckDelta)
		if Objective_IsStarted(OBJ_RaidBuildings) and not Objective_IsComplete(OBJ_RaidBuildings) then
			Objective_SetCounter(OBJ_RaidBuildings, burnResourcesClaimed, OBJ_RaidBuildings.counterTarget)
		end
	end
	
	-- Run the check on everyone left and removed anything that burnt
	if EGroup_IsBurning(eg_jin_burnables, ANY) == true then
		if firstBurn then
			Util_StartIntel(EVENTS.DeerStones_GainGold)
			firstBurn = false
		end
		EGroup_ForEach(eg_jin_burnables, _RemoveBurning)
	end
	
	-- Log this number; if anything disappears from it between now and the next call,
	-- it can't have been removed by the removing we just did on account of fire
	g_trackedBurnables = EGroup_Count(eg_jin_burnables)
	
end

--? @shortdesc Recalls all soldiers to Juyong from around the map
function Juyong_RecallAllJinSoldiers(context)
	
	print("Recalling all soldiers to Juyong!")
	
	g_evacuatingArmies = 0
	-- For every single remaining module, we want to send it attack-moving to Juyong
	Juyong_SendToJuyong("YanqingPatrol", "Retreat_Yanqing")
	Juyong_SendToJuyong("SouthPatrol", "Retreat_Patrols")
	Juyong_SendToJuyong("NorthPatrol", "Retreat_North")
	
	Juyong_SendToJuyong("MountainPatrol1", "Retreat_Mountain")
	Juyong_SendToJuyong("MountainPatrol2", "Retreat_Mountain")
	
	Juyong_SendToJuyong("JinForestPost", "Retreat_Mountain")
	Juyong_SendToJuyong("JinPostZhangjiakou1", "Retreat_Zhang")
	Juyong_SendToJuyong("JinZhangjiakou", "Retreat_Zhang")
	Juyong_SendToJuyong("ZhangjiakouDefend", "Retreat_Zhang")
	Juyong_SendToJuyong("ZhangjiakouArchersNorth1", "Retreat_Zhang")
	Juyong_SendToJuyong("ZhangjiakouArchersNorth2", "Retreat_Zhang")
	Juyong_SendToJuyong("ZhangjiakouArchersNorth3", "Retreat_Zhang")
	Juyong_SendToJuyong("ZhangjiakouArchersNorth4", "Retreat_Zhang")
	Juyong_SendToJuyong("ZhangjiakouArchersSouth1", "Retreat_Zhang")
	Juyong_SendToJuyong("ZhangjiakouArchersSouth2", "Retreat_Zhang")
	Juyong_SendToJuyong("ZhangjiakouArchersSouth3", "Retreat_Zhang")
	Juyong_SendToJuyong("ZhangjiakouArchersSouth4", "Retreat_Zhang")
	Juyong_SendToJuyong("NorthDefend", "Retreat_North")
	Juyong_SendToJuyong("MidfieldDefend", "Retreat_Yanqing")
	Juyong_SendToJuyong("JinYanqing", "Retreat_Yanqing")
	
	Juyong_SendToJuyong("JinRoadPost1", "Retreat_Patrols")
	Juyong_SendToJuyong("JinRoadPost2", "Retreat_Patrols")
	
	Rule_AddInterval(Juyong_RetreatOffMap, 10)
	
end

--? @shortdesc Sends a module to Juyong
function Juyong_SendToJuyong(moduleName, newModule)
	
	-- Pick the module to go after
	local module = MissionOMatic_FindModule(moduleName)
	local retreatingModule = nil
	
	if module ~= nil then 
		if MissionOMatic_FindModule(newModule) == nil then
			---- Now create an attack module
			local moduleData = {
				descriptor = newModule,
				type = "RovingArmy",
				target = base_juyong,
				targetingType = ARMY_TARGETING_DISCARD,
				player = g_playerJin,
				attackmove = attackMoveStyle_aggressive,
				onDeathDissolve = true,
				onCompleteModule = "JinJuyong_Retreated",
				
			}
			
			retreatingModule = RovingArmy_Init(moduleData)
		else
			retreatingModule = MissionOMatic_FindModule(newModule)
		end
		
		TransferModuleIntoModule(module, retreatingModule)
		
		-- Increment the ID for the module
		g_evacuatingArmies = g_evacuatingArmies + 1
	end
end
		

function Juyong_PlayVillageWaveVOAndObj()
	if firstVillageAttack then
		Util_StartIntel(EVENTS.Jin_Villages_Attack)
		firstVillageAttack = false
		Objective_Start(OBJ_DestroyVillages)
	end
end

function Juyong_YanqingWave()
	if Objective_IsComplete(OBJ_Yanqing) then
		Rule_RemoveMe()
	else
		Juyong_PlayVillageWaveVOAndObj()
		Juyong_SendWave(wave_yanqing)
		print("Wave: Sending Yanqing")
	end
end

