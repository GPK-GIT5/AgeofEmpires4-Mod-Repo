	end
end

function Juyong_CheckMongolTCDestroyed()
	Juyong_UpdateMonTC()
end

function Juyong_UpdateMonTC()
	
	local function _UpdateAllWaves()
		--Update live RovingArmies and set Dead ones to nil
		for k,v in ipairs(assaultWaveList) do
			if RovingArmy_IsDead(v) then
				assaultWaveList[k] = nil
			else
				local targetList = RovingArmy_GetTargets(v)
				if targetList[#targetList] ~= mon_tc_position then
					RovingArmy_SetTarget(v, mon_tc_position)
				end
			end
		end
		--Clean up nil table entries
		local j=0
		local n = #assaultWaveList
		
		for i=1,n do
	        if assaultWaveList[i]~=nil then
                j=j+1
                assaultWaveList[j]=assaultWaveList[i]
	        end
		end
		
		for i=j+1,n do
      	  assaultWaveList[i]=nil
		end
	end
	
	eg_mon_tc = Player_GetAllEntities(g_playerMongol)
	EGroup_Filter(eg_mon_tc, "town_center", FILTER_KEEP)
	
	if EGroup_IsEmpty(eg_mon_tc) then --verify the TC exists
		Mission_Fail()
	else -- Update TC position
		local new_mon_tc_position = EGroup_GetPosition(eg_mon_tc)

		if mon_tc_position == nil or Util_GetDistance(mon_tc_position, new_mon_tc_position) > 20 then
			mon_tc_position = new_mon_tc_position
			_UpdateAllWaves()
		end
	end
end

function Juyong_RetreatOffMap()
	local module = MissionOMatic_FindModule("JinJuyong_Retreated")
	local sgroup = module.sgroup
	
	if SGroup_Count(sgroup) > 30 then
		local i = 0
		
		local _Retreat = function(gid, idx, sid)
			if i >= 2 then
				i = 0
				SGroup_Single(sg_single, sid)
				Defend_RemoveSGroup(module, sg_single)
				Cmd_MoveToAndDestroy(sg_single, mkr_juyong_outro9)
			else
				i = i + 1
			end
		end
		SGroup_ForEach(sgroup, _Retreat)
	end
end