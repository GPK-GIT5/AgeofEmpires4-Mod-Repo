--
-- Juyong 1213 - Primary Objectives Phase 3
--
--
-- TO USE THIS TEMPLATE:
-- 1. Decide on a prefix for this objective / section of the mission
-- 2. save this template as a new file in the same directory as your mission script - use "obj_<prefix>.scar" for the name 
-- 3. import this file into your main mission script with import("obj_<prefix>.scar")
-- 4. call the <prefix>_InitObjectives function from inside you main mission script's Mission_SetupVariables function
--
import("obj_juyong_phase4.scar")

--? @shortdesc Initializes the main objectives for Juyong
function Juyong_InitObjectives_Phase3()

	OBJ_Yanqing = { Title = "$11180872", -- Raze Yanqing
		Type = ObjectiveType_Battle,
		
		PreStart = function()			
			Util_AutoSave()
		end,
		
		OnStart = function()
			Game_TransitionToState("steppes_midday", 300)
			objectiveBuildingCount = (EGroup_Count(SOBJ_Village_1.egroup) + EGroup_Count(SOBJ_Village_2.egroup) + EGroup_Count(SOBJ_Village_3.egroup))
			Rule_AddGlobalEvent(Juyong_OnEntityDestroyed, GE_EntityKilled)
			
			Player_AddResource(g_playerMongol, RT_Food, 800)
			Player_AddResource(g_playerMongol, RT_Wood, 600)
			Player_AddResource(g_playerMongol, RT_Stone, 0)
			Player_AddResource(g_playerMongol, RT_Gold, 400)
	
			UI_SetPlayerDataContext(g_playerMongol, { PopulationCapOn = true })     

			Rule_AddInterval(Juyong_CheckPlayerApproachYanqing, 5)
			Rule_AddInterval(Juyong_CheckPlayerApproachVillage1, 5)
			Rule_AddInterval(Juyong_CheckPlayerApproachVillage2, 5)
			Rule_AddInterval(Juyong_CheckPlayerApproachVillage3, 5)
			
			MissionTutorial_JuyongGer()
			MissionTutorial_JuyongPasture_Entity()
			MissionTutorial_JuyongPasture_Squad()
			MissionTutorial_JuyongUnpackBuildings()
			MissionTutorial_ImprovedRaiding()
			
			hint_Yanqing = Objective_AddUIElements(OBJ_Yanqing, yanqing_tc, true, 11180873, true, nil ) -- Yanqing
			
			Rule_AddOneShot(Juyong_StartNorthWaves, northWaveStartDelay)
			Rule_AddOneShot(Juyong_StartSouth1Waves, south1WaveStartDelay)
			Rule_AddOneShot(Juyong_StartSouth2Waves, south2WaveStartDelay)
			
			-- Don't do Yanqing waves on Story mode
			if Game_GetSPDifficulty() >= GD_NORMAL then
				Rule_AddOneShot(Juyong_StartYanqingWaves, yanqingWaveStartDelay)
			end
			
			Rule_AddInterval(Juyong_CheckMongolTCDestroyed, 5)
			Init_Waves()
		end,
		
		IsComplete = function()
			return Objective_IsComplete(SOBJ_YanqingBuildings)
		end,
		
		OnComplete = function()
			Player_GetAllSquadsNearMarker(g_playerMongol, sg_mon_army, base_yanqing, 200)
			Sound_PlayWallaCelebrateOnSGroup(sg_mon_army)
			HintPoint_Remove(hint_Yanqing)
			if Game_GetSPDifficulty() >= GD_NORMAL then
				Rule_AddInterval(Juyong_JuyongWave, juyongWavePeriod)
			end
			Util_StartIntel(EVENTS.YanqingComplete)
			Rule_AddInterval(Juyong_MoveBuildingsHint, 45)
			
			Objective_Start(OBJ_Juyong)
			Juyong_RecallAllJinSoldiers()
		end,
		
		IsFailed = Juyong_CheckTotalFailure,
		
		OnFail = function()
			Mission_Fail()
		end,
	}
	
	SOBJ_YanqingBuildings = { Title = "$11191883", -- Destroy buildings
		Type = ObjectiveType_Battle, 
		Parent = OBJ_Yanqing,
		egroup = eg_yanqing,
		counterTarget = 12,
		counterCurrent = 0,

		PreStart = function()
		end,
		
		OnStart = function()
			Obj_SetProgressVisible(SOBJ_YanqingBuildings.ID, true)
			Obj_SetProgress(SOBJ_YanqingBuildings.ID, SOBJ_YanqingBuildings.counterCurrent / SOBJ_YanqingBuildings.counterTarget )
		end,
		
		IsComplete = function()
			return EGroup_Count(SOBJ_YanqingBuildings.egroup) <= 0
		end,
		
		OnComplete = function()
		end,
	}
	OBJ_RaidBuildings = { Title = "$11191861", -- Optional: Collect 2000 resources by burning buildings
		Type = ObjectiveType_Optional,
		
		counterTarget = 2000,
		counterCurrent = 0,
		 
		PreStart = function()
		end,
		
		OnStart = function()
			Juyong_GetBurnableList()
			Objective_SetCounter(OBJ_RaidBuildings, burnResourcesClaimed, 2000)
			
		end,
		
		IsComplete = function()
			return Objective_GetCounter(OBJ_RaidBuildings) >= 2000
		end,
		
		OnComplete = function()
		end,
	}
	OBJ_DestroyVillages = { Title = "$11188383", -- Optional: Destroy outlying Jin villages to cut off reinforcements
		Type = ObjectiveType_Optional,
		 
		PreStart = function()
			if Game_GetSPDifficulty() <= GD_EASY then
				--Obj_SetTitle(OBJ_DestroyVillages.ID, "$11204361")
			end
		end,
		
		OnStart = function()
			Objective_SetCounter(OBJ_DestroyVillages, 0, 3)
			MissionTutorial_JuyongOvoo()
			hint_Village1 = Objective_AddUIElements(OBJ_DestroyVillages, village_1, true, 11191878, true, nil ) -- Jin Village
			hint_Village2 = Objective_AddUIElements(OBJ_DestroyVillages, village_2, true, 11191878, true, nil ) -- Jin Village
			hint_Village3 = Objective_AddUIElements(OBJ_DestroyVillages, village_3, true, 11191878, true, nil ) -- Jin Village
		end,
		
		IsComplete = function()
			return Objective_IsComplete(SOBJ_Village_1) and Objective_IsComplete(SOBJ_Village_2) and Objective_IsComplete(SOBJ_Village_3)
		end,
		
		OnComplete = function()
		end,
	}
	SOBJ_Village_1 = { Title = "$11191882", -- Destroy Western Village
		Type = ObjectiveType_Optional, 
		Parent = OBJ_DestroyVillages,
		egroup = eg_village_1,
		marker = village_1,
		counterTarget = 6,
		counterCurrent = 0,

		PreStart = function()
			
		end,
		
		OnStart = function()
			Objective_SetCounter(SOBJ_Village_1, 0, SOBJ_Village_1.counterTarget)
		end,
		
		IsComplete = function()
			return EGroup_Count(SOBJ_Village_1.egroup) <= 0
		end,
		
		OnComplete = function()
			Juyong_FirstVillageDestroyed()
			Objective_IncreaseCounter(OBJ_DestroyVillages, 1)
			Objective_RemoveUIElements(OBJ_DestroyVillages, hint_Village1)
		end,
	}
	SOBJ_Village_2 = { Title = "$11191881", -- Destroy Southern Village
		Type = ObjectiveType_Optional, 
		Parent = OBJ_DestroyVillages,
		egroup = eg_village_2,
		marker = village_2,
		counterTarget = 8,
		counterCurrent = 0,

		PreStart = function()
			
		end,
		
		OnStart = function()
			Objective_SetCounter(SOBJ_Village_2, 0, SOBJ_Village_2.counterTarget)
		end,
		
		IsComplete = function()
			return EGroup_Count(SOBJ_Village_2.egroup) <= 0
		end,
		
		OnComplete = function()
			Juyong_FirstVillageDestroyed()
			Objective_IncreaseCounter(OBJ_DestroyVillages, 1)
			Objective_RemoveUIElements(OBJ_DestroyVillages, hint_Village2)
		end,
	}
	SOBJ_Village_3 = { Title = "$11191880", -- Destroy Northern Village
		Type = ObjectiveType_Optional, 
		Parent = OBJ_DestroyVillages,
		egroup = eg_village_3,
		marker = village_3,
		counterTarget = 9,
		counterCurrent = 0,

		PreStart = function()
			
		end,
		
		OnStart = function()
			Objective_SetCounter(SOBJ_Village_3, 0, SOBJ_Village_3.counterTarget)
		end,
		
		IsComplete = function()
			return EGroup_Count(SOBJ_Village_3.egroup) <= 0
		end,
		
		OnComplete = function()
			Juyong_FirstVillageDestroyed()
			Objective_IncreaseCounter(OBJ_DestroyVillages, 1)
			Objective_RemoveUIElements(OBJ_DestroyVillages, hint_Village3)
		end,
	}
	
	--
	-- REGISTRATION
	--
	Objective_Register(OBJ_Yanqing)
	Objective_Register(SOBJ_YanqingBuildings)
	Objective_Register(OBJ_RaidBuildings)
	Objective_Register(OBJ_DestroyVillages)
	Objective_Register(SOBJ_Village_1)
	Objective_Register(SOBJ_Village_2)
	Objective_Register(SOBJ_Village_3)
	
	
end

