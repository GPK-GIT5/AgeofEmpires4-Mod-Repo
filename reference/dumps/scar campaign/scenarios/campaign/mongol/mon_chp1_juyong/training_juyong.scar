function _HasPackedAnyBuilding(goalSequence)
	
	Player_GetAll(g_playerMongol)
	EGroup_Filter(eg_allentities, "mobile_building", FILTER_KEEP)
	
	-- Do it this way so it remembers it was already done
	if EGroup_Count(eg_allentities) > 0 then
		g_juyongBuildingsUnpacked = true
	end
	
	return g_juyongBuildingsUnpacked or CampaignTraining_TimeoutIgnorePredicate(goalSequence)
	
end

