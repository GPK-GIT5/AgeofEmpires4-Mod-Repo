----------------------------------
-- Pastures
----------------------------------

function MissionTutorial_JuyongPasture_Entity()
	
	local goal_pasture = "goal_pasture_entity"
		
	local viewEntity = Training_Goal("Entity", 
		{Message="$11187683", DataTemplate="GenericTrainingDataTemplate"},
		_DelayTimeElapsed)
	JuyongPastureEntity_GoalSequence = Training_GoalSequence(goal_pasture, 
		1, 0, --repeat max and remind max
		_HasPastureOnScreen_Entity, --trigger
		CampaignTraining_TimeoutIgnorePredicate, --ignore
		nil, --remind
		_CancelIfSquad, --bypass 
		false, --can regress
		{viewEntity})
	
	Training_AddGoalSequence(JuyongPastureEntity_GoalSequence)
end

function _HasPastureOnScreen_Entity(goalSequence)
		
	if AShortPeriodOfTimeHasPassed(goalSequence) then
		
		local potentialEntity_eid = nil
		local _CheckEntityIsOnScreen = function(gid, idx, eid)
			if Misc_IsEntityOnScreen(eid, 0.8) then
				potentialEntity_eid = eid
				return true
			end
		end
		
		-- Look for entities
		Player_GetAll(g_playerMongol, sg_temp, eg_mon_pastures)
		EGroup_Filter(eg_mon_pastures, EBP.MONGOL.BUILDING_PASTURE_MON, FILTER_KEEP)
		EGroup_ForEach(eg_mon_pastures, _CheckEntityIsOnScreen)
		if potentialEntity_eid ~= nil then
			goalSequence.goals[1].key = Entity_GetID(potentialEntity_eid)
			g_entityPasture = true
			return true
		end
		
	end
end

function _CancelIfEntity()
	return g_entityPasture == true
end

function MissionTutorial_JuyongPasture_Squad()
	
	local goal_pasture = "goal_pasture_squad"
		
	local viewSquad = Training_Goal("Squad", 
		{Message="$11187683", DataTemplate="GenericTrainingDataTemplate"},
		_DelayTimeElapsed)
	JuyongPastureSquad_GoalSequence = Training_GoalSequence(goal_pasture, 
		1, 0, --repeat max and remind max
		_HasPastureOnScreen_Squad, --trigger
		CampaignTraining_TimeoutIgnorePredicate, --ignore
		nil, --remind
		_CancelIfEntity, --bypass 
		false, --can regress
		{viewSquad})
	
	Training_AddGoalSequence(JuyongPastureSquad_GoalSequence)
end

function _HasPastureOnScreen_Squad(goalSequence)
		
	if AShortPeriodOfTimeHasPassed(goalSequence) then
		
		local potentialEntity_eid = nil
		local _CheckEntityIsOnScreen = function(gid, idx, eid)
			if Misc_IsEntityOnScreen(eid, 0.8) then
				potentialEntity_eid = eid
				return true
			end
		end
		
		-- Look for squads
		Player_GetAllEntitiesNearMarker(g_playerMongol, eg_temp, Util_ScarPos(0, 0, 0), 750)
		EGroup_Filter(eg_temp, EBP.MONGOL.BUILDING_PASTURE_MOVING_MON, FILTER_KEEP)
		EGroup_ForEach(eg_temp, _CheckEntityIsOnScreen)
		if potentialEntity_eid ~= nil then
			goalSequence.goals[1].key = Squad_GetID(Entity_GetSquad(potentialEntity_eid))
			g_squadPasture = true
			return true
		end
		
	end
end

function _CancelIfSquad()
	return g_squadPasture == true
end

