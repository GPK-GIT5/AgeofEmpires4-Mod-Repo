function _HasUnpackedBuildingOnScreen(goalSequence)
		
	if AShortPeriodOfTimeHasPassed(goalSequence) then
		
		Player_GetAll(g_playerMongol)
		EGroup_Filter(eg_allentities, "packable_building", FILTER_KEEP)
		EGroup_Filter(eg_allentities, "mobile_building", FILTER_REMOVE)
		
		local potentialBuilding_eid = nil
		
		local _CheckEntityIsOnScreen = function(gid, idx, eid)
			if Misc_IsEntityOnScreen(eid, 0.8) then
				potentialEntity_eid = eid
				return true
			end
		end
		EGroup_ForEach(eg_allentities, _CheckEntityIsOnScreen)
		
		if potentialEntity_eid ~= nil then 
			
			goalSequence.goals[1].key = Entity_GetID(potentialEntity_eid)

