function MissionTutorial_JuyongOvoo()
	
	local goal_ovoo = "goal_ovoo"
		
	local GoalBuildOvoo = Training_Goal("Entity", 
		{Message="$11191885", DataTemplate="GenericTrainingDataTemplate"},
		_DelayTimeElapsed)
	JuyongOvoo_GoalSequence = Training_GoalSequence(goal_ovoo, 
		1, 0, --repeat max and remind max
		Predicate_IsStoneOnscreen, --trigger
		CampaignTraining_TimeoutIgnorePredicate, --ignore
		nil, --remind
		Predicate_UserHasOvoo, --bypass 
		false, --can regress
		{GoalBuildOvoo})
	
	Training_AddGoalSequence(JuyongOvoo_GoalSequence)
end

function Predicate_UserHasOvoo(goal)
	Player_GetAll(g_playerMongol)
	EGroup_Filter(eg_allentities, EBP.MONGOL.BUILDING_STONE_DEPOSIT_OVOO_MON, FILTER_KEEP)
	return EGroup_Count(eg_allentities) > 0
end

function Predicate_IsStoneOnscreen(goalSequence)
	
	eg_stone_onscreen = EGroup_CreateIfNotFound("eg_stone_onscreen")
	EGroup_Clear(eg_stone_onscreen)
	
	local _CheckOnscreen = function(gid, idx, eid)
		if Misc_IsEntityOnScreen(eid, 100) == true then
			EGroup_Add(eg_stone_onscreen, eid)
		end
	end
	EGroup_ForEach(eg_world_stone, _CheckOnscreen)
	
	if ABriefPeriodOfTimeHasPassed(goalSequence) and EGroup_Count(eg_stone_onscreen) > 0 then
		local entity = EGroup_GetEntityAt(eg_stone_onscreen, 1)
		goalSequence.goals[goalSequence.currentGoalIndex].key = entity
		return true
	end
	
	return false
end

------------------------------------------
-- Improved Raiding Tutorial--
------------------------------------------
function MissionTutorial_ImprovedRaiding()
	
	local improvedRaiding = "improvedRaiding"

	local selectOutpost = Training_Goal("Entity", {Message="$11201590", DataTemplate="LeftClickTrainingDataTemplate"}, ImprovedRaiding_OutpostIsSelected)
	local highlightImprovedRaiding = Training_Goal("PBG", {Message="$11201591", DataTemplate="LeftClickTrainingDataTemplate"}, ImprovedRaiding_HasUpgrade)
	
	improvedRaidingSequence = Training_GoalSequence(improvedRaiding, 1, 0, ImprovedRaiding_TriggerPredicate, CampaignTraining_TimeoutIgnorePredicate, nil, ImprovedRaiding_BypassPredicate, true, {selectOutpost, highlightImprovedRaiding})
	
	Training_AddGoalSequence(improvedRaidingSequence)
	Training_EnableGoalSequenceByID(improvedRaidingSequence, true)
	
end

function ImprovedRaiding_TriggerPredicate(goalSequence)
	local improvedRaidingBP = BP_GetUpgradeBlueprint("upgrade_raid_bounty_mon")
	Player_GetAll(g_playerMongol)
	EGroup_Filter(eg_allentities, "outpost", FILTER_KEEP)
	EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)

	if EGroup_CountSpawned(eg_allentities) > 0 
		and	improvedRaidingBP ~= nil then
			local entity = EGroup_GetEntityAt(eg_allentities, 1)
			goalSequence.goals[1].key = Entity_GetID(entity)
			goalSequence.goals[2].key = improvedRaidingBP
			return true
	end
end

function ImprovedRaiding_OutpostIsSelected(goal)
	Misc_GetSelectedEntities(eg_currentSelection, true)
	EGroup_Filter(eg_currentSelection, "outpost", FILTER_KEEP)
	if EGroup_CountSpawned(eg_currentSelection) > 0 then
		return true
	end
	
	return false
end

function ImprovedRaiding_HasUpgrade(goal)
	local improvedRaidingBP = BP_GetUpgradeBlueprint("upgrade_raid_bounty_mon")
	Player_GetAll(g_playerMongol)
	EGroup_Filter(eg_allentities, "outpost", FILTER_KEEP)
	EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
	
	local _IsImprovedRaiding = function(gid, index, eid)
		local queueSize = Entity_GetProductionQueueSize(eid)
		if queueSize > 0 then
			for i = 0, queueSize - 1 do
				if Entity_GetProductionQueueItem(eid, i) == improvedRaidingBP then
					return true
				end
			end
		end
	end
	
	if EGroup_CountSpawned(eg_allentities) > 0 then
		return EGroup_ForEachAllOrAny(eg_allentities, ANY, _IsImprovedRaiding)
	end
end

function ImprovedRaiding_BypassPredicate(goalSequence)
	return Player_HasUpgrade(g_playerMongol, BP_GetUpgradeBlueprint("upgrade_raid_bounty_mon"))
end

------------------------------------------
-- Blacksmith Tutorial--
------------------------------------------
function MissionTutorial_Blacksmith()

	local blacksmith = "buildBlacksmith"
	
	local selectVillager = Training_Goal("Squad", {Message = "$11201972", DataTemplate="LeftClickTrainingDataTemplate"}, Blacksmith_VillagerIsSelected) --"Select a villager to build a Blacksmith."
	local isGoingToBuildBlacksmith = Training_Goal("PBG", {Message = "$11201973", DataTemplate="LeftClickTrainingDataTemplate"}, Blacksmith_PlayerIsGoingToBuild) --"Select the Blacksmith."
	
	--This seems unsupported by UI right now
	--local hasBuiltBlacksmith = Training_Goal("Cursor", {Message = "$11193897", DataTemplate="LeftClickDataTemplate"}, Blacksmith_IsBuilt) --"Place the Blacksmith in an open location"
	
	blacksmithSequence = Training_GoalSequence(blacksmith, 1, 0, Blacksmith_TriggerPredicate, CampaignTraining_TimeoutIgnorePredicate, nil, Blacksmith_BlacksmithExists, true, {selectVillager, isGoingToBuildBlacksmith})
	
	Training_AddGoalSequence(blacksmithSequence)
	Training_EnableGoalSequenceByID(blacksmithSequence, true)
	
end

function Blacksmith_TriggerPredicate(goalSequence)
	local blacksmithBP = Cardinal_ConvertTypeToEntityBlueprint("blacksmith", g_playerMongol)
	Player_GetAll(g_playerMongol)
	SGroup_Filter(sg_allsquads, "scar_villager", FILTER_KEEP)

	if SGroup_CountSpawned(sg_allsquads) > 0 
		and	blacksmithBP ~= nil 
		and Player_CanConstruct(g_playerMongol, blacksmithBP) then
			local squad = SGroup_GetSquadAt(sg_allsquads, 1)
			goalSequence.goals[1].key = Squad_GetID(squad)
			goalSequence.goals[2].key = blacksmithBP
			return true
	end
end

function Blacksmith_VillagerIsSelected(goal)
	Misc_GetSelectedSquads(sg_currentSelection, true)
	SGroup_Filter(sg_currentSelection, "scar_villager", FILTER_KEEP)
	if SGroup_CountSpawned(sg_currentSelection) > 0 then
		return true
	end
	
	return false
end

function Blacksmith_PlayerIsGoingToBuild(goal)
	return UserIsGoingToBuildBuildingType("blacksmith")
end

function Blacksmith_IsBuilt(goal)
	Player_GetAll(g_playerMongol)
	EGroup_Filter(eg_allentities, EBP.MONGOL.BUILDING_TECH_UNIT_INFANTRY_MON, FILTER_KEEP)
	return EGroup_CountSpawned(eg_allentities) > 0	
end

function Blacksmith_BlacksmithExists(goalSequence)
	Player_GetAll(g_playerMongol)
	EGroup_Filter(eg_allentities, EBP.MONGOL.BUILDING_TECH_UNIT_INFANTRY_MON, FILTER_KEEP)
	return EGroup_CountSpawned(eg_allentities) > 0
end

