	local selectBlacksmith = Training_Goal("Entity", {Message = "$11201974", DataTemplate="LeftClickTrainingDataTemplate"}, SiegeEngineer_BlacksmithIsSelected) --Select the Blacksmith to purchase the siege engineer upgrade
	local highlightSiegeEngineer = Training_Goal("PBG", {Message = "$11201975", DataTemplate="LeftClickTrainingDataTemplate"}, SiegeEngineer_HasUpgrade) --"Select Siege Engineer."
	
