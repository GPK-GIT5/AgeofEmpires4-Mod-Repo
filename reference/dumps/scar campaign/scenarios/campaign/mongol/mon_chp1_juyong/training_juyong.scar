		}, 
		SiegeEngineer_BlacksmithIsSelected
	) 
	
	local GoalOnOpenRadial = Training_Goal(
		"Entity",
		{
			ID = "Hold RT to see Blacsmith technologies.",
			Message = "$11248536",
			DataTemplate = "GenericTrainingDataTemplate",
		},
		UserHasOpenedContextualRadial
	)
	
	--"Select Siege Engineering."
