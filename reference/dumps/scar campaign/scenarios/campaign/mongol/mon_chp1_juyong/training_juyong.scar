--
-- The Great Wall - Training Goals
--

import("training/campaigntraininggoals.scar")

----------------------------------
-- Utility Functions
----------------------------------

function _DelayTimeElapsed(goal)
	local currentTime = Timer_GetElapsed(goal.timerID)
	
	if currentTime >= __t_trainingModerateInterval then
		return true
	end
end



----------------------------------
-- View Genghis Khan Leader Aura
----------------------------------

function MissionTutorial_JuyongLeaderAura_Xbox()
	
	local goal_sequence_leaderability = "goal_sequence_leaderability"
	
	if SGroup_CountSpawned(g_leaderGenghisKhan.sgroup) >= 1 and Player_OwnsSGroup(g_playerMongol, g_leaderGenghisKhan.sgroup, ALL) then 
		
		local Goal_SelectGenghis = Training_Goal(
			SGroup_GetSpawnedSquadAt(g_leaderGenghisKhan.sgroup, 1),
			{
				ID = "Leaders have unique abilities they can activate at any time. Press D-Pad Right to Select Genghis Khan.",
				Message = "$11248637",
				DataTemplate = "GenericTrainingDataTemplate",
			},
			Predicate_UserHasSelectedGenghis
		)
		
		local GoalOnOpenRadial = Training_Goal(
			SGroup_GetSpawnedSquadAt(g_leaderGenghisKhan.sgroup, 1),
			{
				ID = "Hold RT to see Genghis Khan's abilities.",
				Message = "$11248638",
				DataTemplate = "GenericTrainingDataTemplate",
			},
			UserHasOpenedContextualRadial
		)
		
		local Goal_HoverOverAbility = Training_Goal(
			BP_GetAbilityBlueprint("leader_improved_armor_maneuver_arrow"),
			{
				ID = "Genghis Khan can activate improved Signal Arrows that improve the units around him.",
				Message = "$11187680",
				DataTemplate = "GenericTrainingDataTemplate",
			},
			Predicate_UserHasLookedAtGenghisAbility
		)
		
		local GoalSequence_LeaderAbility = Training_GoalSequence(
			goal_sequence_leaderability, 										-- id
			1, 																	-- repeatMax
			0, 																	-- remindMax
			Predicate_UserHasNotActivatedGenghisLeaderAbilityRecently, 			-- trigger
			CampaignTraining_TimeoutIgnorePredicate, 							-- ignore
			nil,														 		-- remind
			Predicate_UserHasLookedAtGenghisAbility, 							-- bypass
			true, 																-- canRegress
			{Goal_SelectGenghis, GoalOnOpenRadial, Goal_HoverOverAbility}							-- goals
		)
		Training_AddGoalSequence(GoalSequence_LeaderAbility)
		
		
	end
	
end

function MissionTutorial_JuyongLeaderAura()
	
	local goal_sequence_leaderability = "goal_sequence_leaderability"
	
	if SGroup_CountSpawned(g_leaderGenghisKhan.sgroup) >= 1 and Player_OwnsSGroup(g_playerMongol, g_leaderGenghisKhan.sgroup, ALL) then 
		
		local Goal_SelectGenghis = Training_Goal(
			SGroup_GetSpawnedSquadAt(g_leaderGenghisKhan.sgroup, 1),
			{
				ID = "Leaders have unique abilities they can activate at any time. Select Genghis Khan to see his special ability.",
				Message = "$11201592",
				DataTemplate = "LeftClickTrainingDataTemplate",
			},
			Predicate_UserHasSelectedGenghis
		)
		local Goal_HoverOverAbility = Training_Goal(
			BP_GetAbilityBlueprint("leader_improved_armor_maneuver_arrow"),
			{
				ID = "Genghis Khan can activate improved Signal Arrows that improve the units around him.",
				Message = "$11187680",
				DataTemplate = "GenericTrainingDataTemplate",
			},
			Predicate_UserHasLookedAtGenghisAbility
		)
		
		local GoalSequence_LeaderAbility = Training_GoalSequence(
			goal_sequence_leaderability, 										-- id
			1, 																	-- repeatMax
			0, 																	-- remindMax
			Predicate_UserHasNotActivatedGenghisLeaderAbilityRecently, 			-- trigger
			CampaignTraining_TimeoutIgnorePredicate, 							-- ignore
			nil,														 		-- remind
			Predicate_UserHasLookedAtGenghisAbility, 							-- bypass
			true, 																-- canRegress
			{Goal_SelectGenghis, Goal_HoverOverAbility}							-- goals
		)
		Training_AddGoalSequence(GoalSequence_LeaderAbility)
		
		
	end
	
end

function Predicate_UserHasSelectedGenghis(goal)
	
	Misc_GetSelectedSquads(sg_temp, true)
	return SGroup_CountSpawned(g_leaderGenghisKhan.sgroup) >= 1 and SGroup_ContainsSGroup(sg_temp, g_leaderGenghisKhan.sgroup, ALL)
	
end

function Predicate_UserHasLookedAtGenghisAbility(goal)
	
	local abilityBP = BP_GetAbilityBlueprint("leader_improved_armor_maneuver_arrow")
	return SGroup_CountSpawned(g_leaderGenghisKhan.sgroup) >= 1 and (PredicateHelper_HasUserHoveredOverBP(goal, abilityBP) or training_previousAbilityBlueprint == abilityBP)
	
end

function Predicate_UserHasNotActivatedGenghisLeaderAbilityRecently(goalSequence)
	
	return SGroup_CountSpawned(g_leaderGenghisKhan.sgroup) >= 1 and Player_OwnsSGroup(g_playerMongol, g_leaderGenghisKhan.sgroup, ALL)
	
end


----------------------------------
-- Raiding for Resources
----------------------------------

function MissionTutorial_JuyongRaiding()
	
	local goal_deer_stones_raiding = "deer_stones_raiding"
		
	local attackBuilding = Training_Goal("Entity", 
		{Message="$11187681", DataTemplate="GenericTrainingDataTemplate"},
		_BuildingIsBurning)
	JuyongRaiding_GoalSequence = Training_GoalSequence(goal_deer_stones_raiding, 
		1, 0, --repeat max and remind max
		_HasEnemyBuildingOnScreen, --trigger
		CampaignTraining_TimeoutIgnorePredicate, --ignore
		nil, --remind
		nil, --bypass 
		true, --can regress
		{attackBuilding})
	Training_AddGoalSequence(JuyongRaiding_GoalSequence)
end

function _HasEnemyBuildingOnScreen(goalSequence)
	
	if AShortPeriodOfTimeHasPassed(goalSequence) then
		
		Player_GetAll(g_playerJin)
		
		local potentialBuilding_eid = nil
		
		local _CheckEntityIsOnScreenAndNotOnFire = function(gid, idx, eid)			-- add anything that's on fire
			if not Entity_IsBurning(eid) and Misc_IsEntityOnScreen(eid, 0.8) then
				potentialBuilding_eid = eid
				return true
			end
		end
		EGroup_ForEach(eg_allentities, _CheckEntityIsOnScreenAndNotOnFire)
		
		if potentialBuilding_eid ~= nil then 
			
			goalSequence.goals[1].key = Entity_GetID(potentialBuilding_eid)

			return true
			
		end
		
	end
end

function UserCannotSeeEntityKey(goalSequence)
	if CampaignTraining_TimeoutIgnorePredicate(goalSequence) then
		return true
	else
		local key = goalSequence.goals[goalSequence.currentGoalIndex].key
		
		if scartype(key) == ST_NUMBER then 
			
			if Entity_IsValid(key) == false then
				return true
			elseif Entity_IsAlive(Entity_FromID(key)) == false then
				return true
			elseif Misc_IsEntityOnScreen(Entity_FromID(key), 100) == false then
				return true
			end
		end
		
		return false
	end
end

function _BuildingIsBurning(goal)
	
	return Entity_IsBurning(Entity_FromID(goal.key))
end


