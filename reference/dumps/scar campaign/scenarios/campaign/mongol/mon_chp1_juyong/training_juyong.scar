end

function SiegeEngineer_BlacksmithIsSelected(goal)
	Misc_GetSelectedEntities(eg_currentSelection, true)
	EGroup_Filter(eg_currentSelection, "blacksmith", FILTER_KEEP)
	if EGroup_CountSpawned(eg_currentSelection) > 0 then
		return true
	end
	
	return false
end

function SiegeEngineer_HasUpgrade(goal)
	local siegeengineerBP = BP_GetUpgradeBlueprint("upgrade_siege_engineers")
	Player_GetAll(g_playerMongol)
	EGroup_Filter(eg_allentities, "blacksmith", FILTER_KEEP)
	EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
	
	local _IsSiegeEngineer = function(gid, index, eid)
		local queueSize = Entity_GetProductionQueueSize(eid)
		if queueSize > 0 then
			for i = 0, queueSize - 1 do
				if Entity_GetProductionQueueItem(eid, i) == siegeengineerBP then
					return true
				end
			end
		end
	end
	
	if EGroup_CountSpawned(eg_allentities) > 0 then
		return EGroup_ForEachAllOrAny(eg_allentities, ANY, _IsSiegeEngineer)
	end
	
end

function SiegeEngineer_BypassPredicate(goalSequence)
	return Player_HasUpgrade(g_playerMongol, BP_GetUpgradeBlueprint("upgrade_siege_engineers"))
end

------------------------------------------
-- Ram Tutorial--
------------------------------------------
function MissionTutorial_Ram()

	local rams = "buildRams"
	
	local selectUnits = Training_Goal("Squad", {Message = "$11201976", DataTemplate="LeftClickTrainingDataTemplate"}, Rams_UnitsSelected) --Select infantry to build rams
	local openMilitaryTabGoal = Training_Goal("MilitaryCommandCardTab", {Message = "$1001508", DataTemplate="LeftClickTrainingDataTemplate"}, UserHasMilitaryCommandCardTabOpen) --Open the Military tab
	local ramsBuilt = Training_Goal("PBG", {Message = "$11201977", DataTemplate="LeftClickTrainingDataTemplate"}, Rams_RamsBuilt) --Build the Ram
	
	local goalSequence = {selectUnits, ramsBuilt}
	if(UI_IsXboxKBMUI()) then
		goalSequence = {selectUnits, openMilitaryTabGoal, ramsBuilt}
	end
	
	ramSequence = Training_GoalSequence(rams, 1, 0, Rams_TriggerPredicate, CampaignTraining_TimeoutIgnorePredicate, nil, Rams_RamsBuilt, true, goalSequence)
	
	Training_AddGoalSequence(ramSequence)
	Training_EnableGoalSequenceByID(ramSequence, true)
	
end

function Rams_TriggerPredicate(goalSequence)
	local siegeengineerBP = BP_GetUpgradeBlueprint("upgrade_siege_engineers")
	local ramsBP = EBP.MONGOL.UNIT_RAM_3_MON
	Player_GetAll(g_playerMongol)
	SGroup_Filter(sg_allsquads, "infantry", FILTER_KEEP)
	
	local goalOffset = 0
	if(UI_IsXboxKBMUI()) then
		goalOffset = 1
	end
	
	if SGroup_CountSpawned(sg_allsquads) > 0 
		and	Player_HasUpgrade(g_playerMongol, siegeengineerBP) then
			local squad = SGroup_GetSquadAt(sg_allsquads, 1)
			goalSequence.goals[1].key = squad
			goalSequence.goals[2 + goalOffset].key = ramsBP
			return true
	end
end

function Rams_UnitsSelected(goal)
	Misc_GetSelectedSquads(sg_currentSelection, true)
	SGroup_Filter(sg_currentSelection, "infantry", FILTER_KEEP)
	
	if SGroup_CountSpawned(sg_currentSelection) > 0 then
		return true
	end
	
	return false

end

function Rams_RamsBuilt(goal)
	Player_GetAll(g_playerMongol)
	SGroup_Filter(sg_allsquads, "scar_ram", FILTER_KEEP)
	return SGroup_CountSpawned(sg_allsquads) > 0
end