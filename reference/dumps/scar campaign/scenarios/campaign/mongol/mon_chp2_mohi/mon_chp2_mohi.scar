---------------------------------------------------------------------------------------------------------------------------------------------------------------------
-- 																		MISSION FUNCTIONS
---------------------------------------------------------------------------------------------------------------------------------------------------------------------

function Mohi_AddPlayerResources()
	Player_AddResource(player1, RT_Food, 2000)
	Player_AddResource(player1, RT_Wood, 2000)
	Player_AddResource(player1, RT_Gold, 2000)
	Player_AddResource(player1, RT_Stone, 2000)
end

function Mohi_FordNotify()
	--VO stinger when the player discovers a ford
	Player_GetAllSquadsNearMarker(player1, sg_temp, Marker_GetPosition(mkr_ford), Marker_GetProximityRadiusOrDefault(mkr_ford, 0))
	if SGroup_CountSpawned(sg_temp) > 0 then
		Music_PlayStinger(MUS_STING_POSITIVE)
		Rule_AddOneShot(DelayIntel, 3, {intel = EVENTS.Shallow_Crossing})
		Rule_RemoveMe()
	end
end

function Mohi_BridgeNotify()
	--VO stinger when the player discovers a broken bridge
	if bridge_UI_started == true then
		Player_GetAllSquadsNearMarker(player1, sg_temp, Marker_GetPosition(mkr_destroyed_bridge), Marker_GetProximityRadiusOrDefault(mkr_destroyed_bridge, 0))
		if SGroup_CountSpawned(sg_temp) > 0 then
			Music_PlayStinger(MUS_STING_POSITIVE)
			Rule_AddOneShot(DelayIntel, 3, {intel = EVENTS.Destroyed_Bridge})
			Rule_RemoveMe()
			bridge_is_seen = true
			if hpid_findBridge ~= nil then
				Objective_RemoveUIElements(SOBJ_OptRepairBridge, hpid_findBridge) 
				hpid_findBridge = nil
				hpid_repairBridge = Objective_AddUIElements(SOBJ_OptRepairBridge, mkr_bridge_hint, true, "$11195750")
			end
			
			Rule_AddInterval(Mohi_BridgeRepaired, 1)
		end	
	end
end

function Mohi_BridgeRepaired()
	
	if EGroup_CountSpawned(eg_bridge_destroyed) > 0 and Entity_GetHealthPercentage(EGroup_GetEntityAt(eg_bridge_destroyed, 1)) == 1.0 then
		if hpid_repairBridge ~= nil then
			Objective_RemoveUIElements(SOBJ_OptRepairBridge, hpid_repairBridge) 
			hpid_repairBridge = nil
		end
		bridge_is_repaired = true
		Rule_RemoveMe()
		
		if Objective_IsComplete(SOBJ_SupportBatu) == false then
			hpid_leftflank = Objective_AddUIElements(SOBJ_SupportBatu, mkr_flank_hint_left, true, "$11183412") -- Rally your armies here to prepare for the attack	
		end
	end
end

function DelayIntel(context, data)
	Util_StartIntel(data.intel)
end

function Mohi_ApplyKhanBuffs()
	--Buff Subutai
	Player_GetAll(player1, sg_temp)
	SGroup_Filter(sg_temp, SBP.MONGOL.UNIT_SUBUTAI_3_CMP_MON, FILTER_KEEP)
	Modify_AbilityRechargeTime(SGroup_GetSquadAt(sg_temp, 1), BP_GetAbilityBlueprint("khan_attack_speed_signal_arrow_mon"), 0.4, MUT_Multiplication)
	Modify_AbilityRechargeTime(SGroup_GetSquadAt(sg_temp, 1), BP_GetAbilityBlueprint("khan_defensive_signal_arrow_mon"), 0.4, MUT_Multiplication)
	Modify_AbilityRechargeTime(SGroup_GetSquadAt(sg_temp, 1), BP_GetAbilityBlueprint("khan_maneuver_signal_arrow_mon"), 0.4, MUT_Multiplication)
	subutai_sight_modifier = Modify_SightRadius(sg_temp, 1.7)
end

--? @shortdesc This function determines, at any given point, whether the player should be considered to have failed
function Mohi_IsPlayerEconomyLocked()
	
	Player_GetAll(player1, sg_allsquads, eg_playerBuildings)
	SGroup_Filter(sg_allsquads, "gaia", FILTER_REMOVE)
	-- If the player has any units, don't fail them at all and don't bother tallying the rest
	if SGroup_CountSpawned(sg_allsquads) > 0 or g_playerBuildingsGranted ~= true or Objective_IsStarted(SOBJ_SupportBatu) == false then
		return false
	end
	
	-- Consider the economy locked if the player has no villagers (accounted for above), has no food for villagers, and isn't producing any villagers
	EGroup_Duplicate(eg_playerBuildings, eg_temp)
	EGroup_Filter(eg_temp, "town_center", FILTER_KEEP)
	local economyLocked = Player_GetResource(player1, RT_Food) < 50 and not EGroup_IsProducingSquads(eg_temp, ANY)
	if economyLocked then
		return true
	end
	
	local landmarkIsDisabled = false
	if EGroup_CountSpawned(eg_playerBuildings) == 1 then
		local lastEntity = EGroup_GetEntityAt(eg_playerBuildings, 1)
		landmarkIsDisabled = Entity_IsOfType(lastEntity, "age1_landmark2") and Entity_GetHealthPercentage(lastEntity) <= 0.1
	end
	if landmarkIsDisabled then
		return true
	end

	-- Only count production structures here
	EGroup_Filter(eg_playerBuildings,
		{
			EBP.MONGOL.BUILDING_TOWN_CENTER_MON,
			EBP.MONGOL.BUILDING_TOWN_CENTER_MOVING_MON,
			EBP.MONGOL.BUILDING_TOWN_CENTER_CAPITAL_MON,
			EBP.MONGOL.BUILDING_TOWN_CENTER_CAPITAL_MOVING_MON,
			EBP.MONGOL.BUILDING_UNIT_CAVALRY_MON,
			EBP.MONGOL.BUILDING_UNIT_CAVALRY_MOVING_MON,
			EBP.MONGOL.BUILDING_UNIT_INFANTRY_MON,
			EBP.MONGOL.BUILDING_UNIT_INFANTRY_MOVING_MON,
			EBP.MONGOL.BUILDING_UNIT_RANGED_MON,
			EBP.MONGOL.BUILDING_UNIT_RANGED_MOVING_MON,
			EBP.MONGOL.BUILDING_UNIT_SIEGE_MON,
			EBP.MONGOL.BUILDING_UNIT_SIEGE_MOVING_MON,
		}, FILTER_KEEP)
	local structuresAreDead = EGroup_IsEmpty(eg_playerBuildings)
	if structuresAreDead then
		return true
	end
	
	return false
end

function Mohi_RefreshBatuMods()
	
	-- Do this because on lower difficulties, there are too few enemies to reliably stand up to Batu
	-- We don't want Batu eliminating the ambushers and then standing around doing nothing
	-- And we don't want Batu's forces to look visually smaller, that's less fun and would feel more off
	if Game_GetSPDifficulty() <= GD_NORMAL then
		
		-- Make sure we're getting Batu's units only
		Player_GetAll(player3)
		
		if g_batuDamageMod ~= nil then
			Modifier_Remove(g_batuDamageMod)
		end
		if Objective_IsComplete(SOBJ_AttackBridge) == false then
			Player_GetAll(player3)
			g_batuDamageMod = Modify_ReceivedDamage(sg_allsquads, 2.0, true)
		end
		
	end
end

-- Intermittently healing ambushers helps prevent a situation where Batu, left completely alone, can kill them all off and force them back
function Mohi_HealAmbushers()
	
	-- Find all player-allied units within the area of the ambush tracking, and a bit of buffer
	local buffer = -10
	local markerRange = Marker_GetProximityRadiusOrDefault(mkr_ambush_tracking, 50)
	local countAllied = 0
	SGroup_Clear(sg_temp)
	Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_ambush_tracking, buffer + markerRange)
	countAllied = SGroup_CountSpawned(sg_temp)
	SGroup_Clear(sg_temp)
	Player_GetAllSquadsNearMarker(player3, sg_temp, mkr_ambush_tracking, buffer + markerRange)
	countAllied = countAllied + SGroup_CountSpawned(sg_temp)
	
	-- Don't do anything if the player or ally has units nearby and the human might see
	if countAllied > 0 then
		return
	end
	
	SGroup_Clear(sg_temp)
	Player_GetAllSquadsNearMarker(player2, sg_temp, mkr_ambush_tracking, markerRange)
	SGroup_SetAvgHealth(sg_temp, 1.0)
	
end

