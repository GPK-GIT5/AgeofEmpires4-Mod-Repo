function Mohi_OutroUnitMovement()
	
	local pos = nil
	local dest = nil

	local _adjustSquadHealth = function(gid, idx, eid)
		Squad_SetHealth(eid, 0.1)
	end
	
	local _spawnRandomMovement = function(data)
		for i=1, data.count, 1 do
			pos = Prox_GetRandomPosition(data.spawn, Marker_GetProximityRadiusOrDefault(data.spawn, 0), 5)
			dest = Prox_GetRandomPosition(data.destination, 10, 5)
			
			UnitEntry_DeploySquads(data.player, data.sgroup, {type = data.unitType, numSquads = 1, spawn = pos, destination = dest})
			SGroup_ForEach(data.sgroup, _adjustSquadHealth)
		end
	end
		
	_spawnRandomMovement({player = player2, sgroup = sg_hungarian_rout, unitType = "scar_spearman", count = 5, spawn = mkr_camp_melee_1, destination = mkr_camp_rout})
	_spawnRandomMovement({player = player2, sgroup = sg_hungarian_rout, unitType = "scar_spearman", count = 8, spawn = mkr_rout4, destination = mkr_camp_rout_right})
	_spawnRandomMovement({player = player2, sgroup = sg_hungarian_rout, unitType = "scar_manatarms", count = 4, spawn = mkr_rout1, destination = mkr_camp_rout})
	_spawnRandomMovement({player = player2, sgroup = sg_hungarian_rout, unitType = "scar_knight", count = 2, spawn = mkr_rout1, destination = mkr_camp_rout})
	_spawnRandomMovement({player = player2, sgroup = sg_hungarian_rout, unitType = "scar_spearman", count = 2, spawn = mkr_rout2, destination = mkr_camp_rout})
	_spawnRandomMovement({player = player2, sgroup = sg_hungarian_rout, unitType = "scar_spearman", count = 8, spawn = mkr_rout3, destination = mkr_camp_rout})
	_spawnRandomMovement({player = player1, sgroup = sg_player_outro_units, unitType = "scar_knight", count = 3, spawn = mkr_outro_archers_1, destination = mkr_outro_archers_2})
	_spawnRandomMovement({player = player1, sgroup = sg_player_outro_units, unitType = "scar_knight", count = 3, spawn = mkr_outro_archers_1a, destination = mkr_outro_archers_2})
	_spawnRandomMovement({player = player1, sgroup = sg_player_outro_units, unitType = "scar_knight", count = 3, spawn = mkr_outro_archers_1b, destination = mkr_outro_archers_end_left})
	--_spawnRandomMovement({player = player1, sgroup = sg_player_outro_units, unitType = "scar_horsearcher", count = 2, spawn = mkr_outro_archers_2, destination = mkr_outro_archers_2})
			
	-- Stop outposts firing
	Modify_WeaponEnabled(eg_hungarian_outpost, "hardpoint_01", false)
	
	-- Batu and Subutai's entourage
	sg_outro_knights = SGroup_CreateIfNotFound("sg_outro_knights")
	sg_outro_spearmen_cheer = SGroup_CreateIfNotFound("sg_outro_spearmen_cheer")
	sg_outro_cavalry_patrol = SGroup_CreateIfNotFound("sg_outro_cavalry_patrol")
	
	UnitEntry_DeploySquads(player3, sg_outro_knights, {{type = "scar_knight", numSquads = 8, facing = Marker_GetPosition(mkr_outro_batu_target)}}, mkr_outro_knights)
	UnitEntry_DeploySquads(player1, sg_outro_spearmen_cheer, {type = "scar_spearman", numSquads = 8}, mkr_outro_spearmen_cheer)
	
	Cmd_HoldPosition(sg_outro_spearmen_cheer, mkr_outro_spearmen_cheer)
	--UnitEntry_DeploySquads(player1, sg_outro_cavalry_patrol, {type = "scar_knight", numSquads = 4 }, mkr_outro_cavalry_patrol)
	--UnitEntry_DeploySquads(g_playerMongol, sg_mon_scout,  { type = "scar_scout", numSquads = 1 }, mkr_intro_scout1 )
end

-- If there is a more elegant way to do the following, please make it so:

function Mohi_OutroBurnStart()
	
	-- Stagger the start of each set of tents burning so that the last ones are not destroyed before the camera reaches them
	
	local function _Burn (gid, index, iid)
        if Entity_IsAlive(iid) then
            Entity_SetHealth(iid, (World_GetRand(1,3)/10))
            if Entity_IsBurning(iid) ~= true then
                Entity_SetOnFire(iid)
            end 
        end
    end
    
    EGroup_ForEach(eg_tents_7, _Burn)
	EGroup_ForEach(eg_tents_4, _Burn)
	EGroup_ForEach(eg_hungarian_outpost, _Burn)
	Rule_AddOneShot(Mohi_OutroBurnMiddle, 2)
end

function Mohi_OutroBurnMiddle()
	local function _Burn (gid, index, iid)
        if Entity_IsAlive(iid) then
            Entity_SetHealth(iid, (World_GetRand(1,3)/10))
            if Entity_IsBurning(iid) ~= true then
                Entity_SetOnFire(iid)
            end 
        end
    end
    
	EGroup_ForEach(eg_tents_3, _Burn)
	EGroup_ForEach(eg_tents_5, _Burn)
	Rule_AddOneShot(Mohi_OutroBurnEnd, 4)
end

function Mohi_OutroBurnEnd()
	local function _Burn (gid, index, iid)
        if Entity_IsAlive(iid) then
            Entity_SetHealth(iid, (World_GetRand(1,3)/10))
            if Entity_IsBurning(iid) ~= true then
                Entity_SetOnFire(iid)
            end 
        end
    end
    
	EGroup_ForEach(eg_tents_1, _Burn)
	EGroup_ForEach(eg_tents_2, _Burn)
end

function Mohi_OutroDeadBodies()
	local dead_spear = BP_GetSquadBlueprint("unit_spearman_1_hre_infinite_corpse")
	--local dead_manatarms = BP_GetSquadBlueprint("")
	Util_CorpseField (dead_spear, mkr_outro_dead_01)
	Util_CorpseField (dead_spear, mkr_outro_dead_02)
	Util_CorpseField (dead_spear, mkr_outro_dead_03)
end

---------------------------------------------------------------------------------------------------------------------------------------------------------------------
-- 																		ACHIEVEMENT TRACKING
---------------------------------------------------------------------------------------------------------------------------------------------------------------------

-- Achievement tracking for Achievement #19 - Forgot A Batu - Kill twice as many opponents as Batu's army when assaulting the bridge in the Battle of Mohi
function Achievement_TrackArmyKills(context)
	
	if context.killer then
		
		if Squad_IsValid(Squad_GetID(context.victim)) then
			
			local owner = Squad_GetPlayerOwner(context.victim)
			
			-- Verify that victim is Hungarian Army
			if owner == player2 then
				
				-- If killer is local player
				if not World_OwnsEntity(context.killer) and	Entity_GetPlayerOwner(context.killer) == player1 then
					
					subutaiKills = subutaiKills + 1
					
				-- If killer is Batu Khan
				elseif not World_OwnsEntity(context.killer) and Entity_GetPlayerOwner(context.killer) == player3 then
					
					batuKills = batuKills + 1
					
				end
			end
		end
	end
end