--
-- Battle of Mohi 1241
--
-- The Mongol Horde, Mission 6
--

import("MissionOMatic/MissionOMatic.scar")
import("obj_hungarianarmy.scar")
import("obj_scoutbridge.scar")

function Mission_SetupPlayers()
	
	--
	-- Get player IDs for each player
	--
	
	player1 = World_GetPlayerAt(1) -- Subutai
	player2 = World_GetPlayerAt(2) -- Bela
	player3 = World_GetPlayerAt(3) -- Batu
	player4 = World_GetPlayerAt(4) -- Neutral
	player5 = World_GetPlayerAt(5) -- Mohi
	
	-- player 1 - Subutai
	Setup_SetPlayerName(player1, "$11176391") -- General Subutai
	Player_SetCurrentAge(player1, AGE_CASTLE)
	Player_SetMaximumAge(player1, AGE_CASTLE)
	
	-- player 2 - Bela
	Setup_SetPlayerName(player2, "$11176392") -- Hungarian Army
	Player_SetCurrentAge(player2, AGE_CASTLE)
	Player_SetMaximumAge(player2, AGE_CASTLE)
	
	-- player 3 - Batu
	Setup_SetPlayerName(player3, "$11176393") -- Batu Khan
	Player_SetCurrentAge(player3, AGE_CASTLE)
	Player_SetMaximumAge(player3, AGE_CASTLE)
	
	-- player 4 - Neutral
	Setup_SetPlayerName(player4, "$11176394") -- Neutral
	Player_SetCurrentAge(player4, AGE_CASTLE)
	Player_SetMaximumAge(player4, AGE_CASTLE)
	
	-- player 5 - Mohi
	Setup_SetPlayerName(player5, "$11195752") -- Mohi
	Player_SetCurrentAge(player5, AGE_CASTLE)
	Player_SetMaximumAge(player5, AGE_CASTLE)
	
	--
	-- set player relationships
	--
	
	Player_SetRelationship(player1, player3, R_ALLY)
	Player_SetRelationship(player3, player1, R_ALLY)
	
	--World_EnableSharedLineOfSight(player1, player3, true)
	--World_EnableSharedLineOfSight(player3, player1, true)
	
	Player_SetRelationship(player1, player4, R_ALLY)
	Player_SetRelationship(player2, player4, R_NEUTRAL)
	Player_SetRelationship(player3, player4, R_ALLY)
	
	Player_SetRelationship(player4, player1, R_ALLY)
	Player_SetRelationship(player4, player2, R_NEUTRAL)
	Player_SetRelationship(player4, player3, R_ALLY)
	
	Player_SetRelationship(player1, player5, R_NEUTRAL)
	Player_SetRelationship(player2, player5, R_NEUTRAL)
	Player_SetRelationship(player3, player5, R_NEUTRAL)
	Player_SetRelationship(player4, player5, R_NEUTRAL)
	
	Player_SetRelationship(player5, player1, R_NEUTRAL)
	Player_SetRelationship(player5, player2, R_NEUTRAL)
	Player_SetRelationship(player5, player3, R_NEUTRAL)
	Player_SetRelationship(player5, player4, R_NEUTRAL)
	
	World_EnableSharedLineOfSight(player1, player2, false)
	World_EnableSharedLineOfSight(player1, player4, false)
	
	World_EnableSharedLineOfSight(player2, player1, false)
	World_EnableSharedLineOfSight(player2, player3, false)
	World_EnableSharedLineOfSight(player2, player4, false)
	
	World_EnableSharedLineOfSight(player3, player2, false)
	World_EnableSharedLineOfSight(player3, player4, false)
	
	World_EnableSharedLineOfSight(player4, player1, false)
	World_EnableSharedLineOfSight(player4, player2, false)
	World_EnableSharedLineOfSight(player4, player3, false)
	
	World_EnableSharedLineOfSight(player1, player5, false)
	World_EnableSharedLineOfSight(player2, player5, false)
	World_EnableSharedLineOfSight(player3, player5, false)
	World_EnableSharedLineOfSight(player4, player5, false)
	
	World_EnableSharedLineOfSight(player5, player1, false)
	World_EnableSharedLineOfSight(player5, player2, false)
	World_EnableSharedLineOfSight(player5, player3, false)
	World_EnableSharedLineOfSight(player5, player4, false)
	
	--
	-- Set Player Colours
	--
	
	PlayerColour_Enable()								--Turn on custom colour configuration for this session
	
	Game_SetPlayerSlotColour(player1, 1)			--Paint Scheme
	Game_SetPlayerUISlotColour(player1, 1)		--UI Colour
	
	Game_SetPlayerSlotColour(player2, 2)			--Paint Scheme
	Game_SetPlayerUISlotColour(player2, 2)		--UI Colour
	
	Game_SetPlayerSlotColour(player3, 3)			--Paint Scheme
	Game_SetPlayerUISlotColour(player3, 3)		--UI Colour
	
	Game_SetPlayerSlotColour(player4, 1)	--Paint Scheme
	Game_SetPlayerUISlotColour(player4, 1)--UI Colour
	
	Game_SetPlayerSlotColour(player5, 9)		--Paint Scheme
	Game_SetPlayerUISlotColour(player5, 9)		--UI Colour
	
end --Mission_SetupPlayers()

function Mission_SetupVariables() -- create any extra sgroups, egroups, and mission variables in here
	
	--OBJECTIVES
	HungarianArmy_InitObjectives()
	ScoutBridge_InitObjectives()
	
	-- EGroups
	sg_player_ambush_survivors = SGroup_CreateIfNotFound("sg_player_ambush_survivors")
	eg_playerBuildings = EGroup_CreateIfNotFound("eg_playerBuildings")
	eg_hungarian_outposts = EGroup_CreateIfNotFound("eg_hungarian_outposts")
	
	-- SGroups
	sg_leaderBatu = SGroup_CreateIfNotFound("sg_leaderBatu")
	sg_player_units = SGroup_CreateIfNotFound("sg_player_units")
	sg_player_scout_1 = SGroup_CreateIfNotFound("sg_player_scout_1")
	sg_player_scout_2 = SGroup_CreateIfNotFound("sg_player_scout_2")
	sg_player_outro_units = SGroup_CreateIfNotFound("sg_player_outro_units")
	sg_playerBuildings = SGroup_CreateIfNotFound("sg_playerBuildings")
	sg_player_villagers = SGroup_CreateIfNotFound("sg_player_villagers")
	sg_cavgroup_left = SGroup_CreateIfNotFound("sg_cavgroup_left")
	sg_cavgroup_right = SGroup_CreateIfNotFound("sg_cavgroup_right")
	sg_forward_guard_01 = SGroup_CreateIfNotFound("sg_forward_guard_01")
	sg_forward_guard_02 = SGroup_CreateIfNotFound("sg_forward_guard_02")
	sg_forward_guard_03 = SGroup_CreateIfNotFound("sg_forward_guard_03")
	sg_bela_counter_1 = SGroup_CreateIfNotFound("sg_bela_counter_1")
	sg_bela_counter_2 = SGroup_CreateIfNotFound("sg_bela_counter_2")
	sg_bela_wave_01 = SGroup_CreateIfNotFound("sg_bela_wave_01")
	sg_bela_wave_02 = SGroup_CreateIfNotFound("sg_bela_wave_02")
	sg_ally_units = SGroup_CreateIfNotFound("sg_ally_units")
	sg_hungarian_camp = SGroup_CreateIfNotFound("sg_hungarian_camp")
	sg_hungarian_rout = SGroup_CreateIfNotFound("sg_hungarian_rout")
	sg_dl_1 = SGroup_CreateIfNotFound("sg_dl_1")
	sg_dl_2 = SGroup_CreateIfNotFound("sg_dl_2")
	sg_dr_1 = SGroup_CreateIfNotFound("sg_dr_1")
	sg_dr_2 = SGroup_CreateIfNotFound("sg_dr_2")
	
	--MISSION VARIABLES
	batu_timer = Util_DifVar({900, 840, 780, 720})
	player_army_size = 80
	
	DEFENSE_LINE_LEFT = 1
	DEFENSE_LINE_RIGHT = 2
	
	routThresholds = {}
	routThresholds[DEFENSE_LINE_LEFT] = 10
	routThresholds[DEFENSE_LINE_RIGHT] = 10
	
	LEFT_FRONT = 1
	LEFT_REAR = 2
	RIGHT_FRONT = 3
	RIGHT_REAR = 4
	
	defenseline_stages = {}
	defenseline_stages[LEFT_FRONT] = 1
	defenseline_stages[LEFT_REAR] = 1
	defenseline_stages[RIGHT_FRONT] = 1
	defenseline_stages[RIGHT_REAR] = 1
	
	bridge_is_seen = false
	bridge_is_repaired = false
	bridge_UI_started = false
	
	visibleGroups = {}
	for i = 1, 5, 1 do
		visibleGroups[i] = false
	end
	
	--UNIT GROUP TEMPLATES
	U_AMBUSH_PURSUERS = {
		{ type = "scar_horseman", numSquads = Util_DifVar({6, 6, 6, 4}) },
		{ type = "scar_knight", numSquads = 4, difficulty = GD_EXPERT },
	}
	
	U_DEFENSE_LINE = {
		{type = "scar_spearman", 	numSquads = Util_DifVar({6, 6, 8, 4})},
		{type = "scar_manatarms", 	numSquads = Util_DifVar({0, 0, 2, 6}), difficulty = {GD_HARD, GD_EXPERT}},
		{type = "scar_landsknecht",	numSquads = Util_DifVar({0, 0, 2, 6}), difficulty = {GD_HARD, GD_EXPERT}},
		{type = "scar_archer", 		numSquads = Util_DifVar({6, 6, 2, 4})},
		{type = "scar_crossbowman", numSquads = Util_DifVar({0, 0, 4, 6}), difficulty = {GD_HARD, GD_EXPERT}},
		{type = "scar_springald", 	numSquads = 1, difficulty = GD_EXPERT},
	}
	
	-- HERO VARIABLES
	sg_leaderSubutai = Missionomatic_InitializeLeader({
		name = 11161114, -- General Subutai
		owner = player1,
		neutralHolder = player4,
	})
	
end --Mission_SetupVariables()

function Mission_SetRestrictions() -- set up any restrictions (i.e. locking out units, etc) in here
	
	--PLAYER UPGRADES AND RESEARCH GOES HERE
	PlayerUpgrades_Auto(player1)
	PlayerUpgrades_Auto(player2)
	PlayerUpgrades_Auto(player3)
	PlayerUpgrades_Auto(player4)
	
	PlayerUpgrades_LearnAllUnits(player1, AGE_CASTLE, {}, Player_GetRaceName(player1))
	
end --Mission_SetRestrictions()

function Mission_Preset() -- any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)
	
	PlayerColour_Enable()
	
	Mohi_AddPlayerResources()
	
	--Spawn intro units
	Mohi_SpawnIntroUnits()
	
	--Destroy the western bridge so the player cannot cross it until repaired
	Entity_SetHealth(EGroup_GetEntityAt(eg_bridge_destroyed, 1), 0.0)

	-- Achievement tracking for Achievement #19 - Forgot A Batu - Kill twice as many opponents as Batu's army when assaulting the bridge in the Battle of Mohi
	subutaiKills = 0
	batuKills = 0
	Rule_AddGlobalEvent(Achievement_TrackArmyKills, GE_SquadKilled)
	
end --Mission_Preset()

function Mission_Start() -- this is triggered after the intro, just as control is passed to the player
	
	-- on console don't restore econ HUD at first 
	Cardinal_EnablePartialXboxUI(true, {VF_XboxUIVillagerPriorities, VF_XboxUIResourceCard})
	
	--Setup references to modules created in the recipe
	batu_start = MissionOMatic_FindModule("batu_start")
	batu_attack = MissionOMatic_FindModule("batu_attack")
	batu_mapedge_reinforce = MissionOMatic_FindModule("batu_mapedge_reinforce")
	
	ambush_01 = MissionOMatic_FindModule("ambush_01")
	ambush_02 = MissionOMatic_FindModule("ambush_02")
	ambush_03 = MissionOMatic_FindModule("ambush_03")
	
	bela_cavgroup_right = MissionOMatic_FindModule("bela_cavgroup_right")
	bela_cavgroup_left = MissionOMatic_FindModule("bela_cavgroup_left")
	
	def_L01 = MissionOMatic_FindModule("def_L01")
	def_L02 = MissionOMatic_FindModule("def_L02")
	def_R01 = MissionOMatic_FindModule("def_R01")
	def_R02 = MissionOMatic_FindModule("def_R02")
	
	camp_melee_1 = MissionOMatic_FindModule("camp_melee_1")
	camp_melee_2 = MissionOMatic_FindModule("camp_melee_2")
	camp_melee_3 = MissionOMatic_FindModule("camp_melee_3")
	
	camp_ranged_1 = MissionOMatic_FindModule("camp_ranged_1")
	camp_ranged_2 = MissionOMatic_FindModule("camp_ranged_2")
	camp_ranged_3 = MissionOMatic_FindModule("camp_ranged_3")
	camp_ranged_4 = MissionOMatic_FindModule("camp_ranged_4")
	camp_ranged_5 = MissionOMatic_FindModule("camp_ranged_5")
	camp_ranged_6 = MissionOMatic_FindModule("camp_ranged_6")
	camp_ranged_7 = MissionOMatic_FindModule("camp_ranged_7")
	camp_ranged_8 = MissionOMatic_FindModule("camp_ranged_8")
	camp_ranged_9 = MissionOMatic_FindModule("camp_ranged_9")
	
	camp_cavalry = MissionOMatic_FindModule("camp_cavalry")
	
	-- start the opening objectives (if you're using ObjectiveTable style objectives)
	Objective_Start(OBJ_DestroyArmy)
	
	-- Setting up VO triggers for if the player explores on the flanks
	Rule_AddInterval(Mohi_FordNotify, 1)
	Rule_AddInterval(Mohi_BridgeNotify, 1)
	
	--Adding weapon upgrades to the Hungarian Outposts
	Player_GetAll(player2, eg_hungarian_outposts)
	EGroup_Filter(eg_hungarian_outposts, EBP.HRE.BUILDING_DEFENSE_OUTPOST_HRE, FILTER_KEEP)
	if Game_GetSPDifficulty() == GD_EXPERT then
		Cmd_InstantUpgrade(eg_hungarian_outposts, UPG.COMMON.UPGRADE_OUTPOST_SPRINGALD, 1)
	else
		Cmd_InstantUpgrade(eg_hungarian_outposts, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS, 1)
	end
	
	--Setting Batu to invulnerable when at a certain percentage
	SGroup_SetInvulnerable(sg_leaderBatu, 0.2)
	SGroup_SetTargetingType(sg_leaderBatu, Targeting_None)
	
	HintPoint_Add(mkr_mohi_hintpoint, true, "$11195751", LOCATION_LABEL_HEIGHT)
	
	Mohi_RefreshBatuMods()
	
	print("TRACKING START TIME FOR EVENT CHALLENGE")
	-- Track when player takes control
	mission_start_time = World_GetGameTime()
	
end --Mission_Start()

