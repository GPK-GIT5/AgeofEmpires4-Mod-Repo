function Mission_SetRestrictions()	-- set up any restrictions (i.e. locking out units, etc) in here

	-- Set tech based on difficulty and age
	PlayerUpgrades_Auto(g_playerMongol, false, { UPG.COMMON.UPGRADE_SIEGE_ENGINEERS, UPG.MONGOL.UPGRADE_IMPROVED_SIEGE_ENGINEERS_MON })
	-- Playtesters absolutely LOATHE the Palace Guard AOE attacks. Don't give it to them.
	PlayerUpgrades_Auto(g_playerSong, false, { UPG.CHINESE.UPGRADE_MANATARMS_AOE_CHI})
	PlayerUpgrades_Auto(g_playerCivilians, false)
	PlayerUpgrades_Auto(g_playerAllies, false)
	
	Player_SetSquadProductionAvailability(g_playerMongol, SBP.MONGOL.UNIT_TREBUCHET_4_CW_MON, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(g_playerMongol, SBP.MONGOL.UNIT_TREBUCHET_4_TR_MON, ITEM_REMOVED)
	
	Cmd_InstantUpgrade(eg_post1_outposts, UPG.CHINESE.UPGRADE_OUTPOST_HANDCANNONSLITS_CHI)
	Cmd_InstantUpgrade(eg_post4_outposts, UPG.CHINESE.UPGRADE_OUTPOST_HANDCANNONSLITS_CHI)
	Cmd_InstantUpgrade(eg_post5_outposts, UPG.CHINESE.UPGRADE_OUTPOST_HANDCANNONSLITS_CHI)
	
	Player_CompleteUpgrade(g_playerMongol, UPG.MONGOL.UPGRADE_RAID_BOUNTY_IMPROVED_MON)
	Player_CompleteUpgrade(g_playerMongol, UPG.MONGOL.UPGRADE_RAID_STONE_BOUNTY_IMPROVED_MON)
	Player_CompleteUpgrade(g_playerMongol, UPG.MONGOL.UPGRADE_RANGED_INCENDIARY_MON)
	
	Player_CompleteUpgrade(g_playerSong, UPG.COMMON.UPGRADE_RANGED_INCENDIARY)
	
	-- We may need to disallow siege engineers - mangonels can mess with bridge flow, and we don't want to encourage anyone attacking the walls
	-- Some players, if given the tools, seem determined to throw themselves at the walls even if it's hopeless rather than following the objectives
	Player_SetUpgradeAvailability(g_playerMongol, UPG.COMMON.UPGRADE_SIEGE_ENGINEERS, ITEM_REMOVED)
	Player_SetUpgradeAvailability(g_playerMongol, UPG.MONGOL.UPGRADE_IMPROVED_SIEGE_ENGINEERS_MON, ITEM_REMOVED)
	
	-- Also hide the menus
	Player_SetConstructionMenuAvailability(g_playerMongol, "siege_engineer", ITEM_REMOVED)
	Player_SetConstructionMenuAvailability(g_playerMongol, "siege_engineer_field_construction_mon", ITEM_REMOVED)
	
	--Also upgrade Chinese lumberjackery
	Player_CompleteUpgrade(g_playerCivilians, UPG.COMMON.UPGRADE_ECON_RESOURCE_WOOD_FELL_RATE_1)
	Player_CompleteUpgrade(g_playerCivilians, UPG.COMMON.UPGRADE_ECON_RESOURCE_WOOD_HARVEST_RATE_2)
	Player_CompleteUpgrade(g_playerCivilians, UPG.COMMON.UPGRADE_ECON_RESOURCE_WOOD_HARVEST_RATE_3)
	Player_CompleteUpgrade(g_playerCivilians, UPG.COMMON.UPGRADE_ECON_RESOURCE_WOOD_HARVEST_RATE_4)
	Player_CompleteUpgrade(g_playerCivilians, UPG.COMMON.UPGRADE_UNIT_TOWN_CENTER_WHEELBARROW_1)
	
	UI_SetPlayerDataContext(g_playerMongol, { PopulationCapOn = false })
	
	-- Lock the eastern gates
	eg_songCityGates = EGroup_CreateIfNotFound("eg_songCityGates")
	Player_GetAllEntitiesNearMarker(g_playerSong, eg_temp, mkr_song_gate_east)
	EGroup_AddEGroup(eg_songCityGates, eg_temp)
	Player_GetAllEntitiesNearMarker(g_playerSong, eg_temp, mkr_song_gate_north)
	EGroup_AddEGroup(eg_songCityGates, eg_temp)
	Player_GetAllEntitiesNearMarker(g_playerSong, eg_temp, mkr_song_gate_west)
	EGroup_AddEGroup(eg_songCityGates, eg_temp)
	EGroup_Filter(eg_songCityGates, EBP.CHINESE.BUILDING_DEFENSE_WALL_GATE_CHI, FILTER_KEEP)
	Missionomatic_SetGateLock(eg_songCityGates, true)
	print(string.format("SONG FORTRESS: %s exterior gates found around cities", EGroup_Count(eg_songCityGates)))
	
	-- Inner gates are needed at different times
	eg_songCityGatesInner = EGroup_CreateIfNotFound("eg_songCityGatesInner")
	Player_GetAllEntitiesNearMarker(g_playerSong, eg_songCityGatesInner, mkr_song_gate_central)
	EGroup_Filter(eg_songCityGatesInner, EBP.CHINESE.BUILDING_DEFENSE_WALL_GATE_CHI, FILTER_KEEP)
	Missionomatic_SetGateLock(eg_songCityGatesInner, true)
	
	-- Unlock the post gates so Song units can move through them
	eg_songGatesPost = EGroup_CreateIfNotFound("eg_songGatesPost")
	Player_GetAllEntitiesNearMarker(g_playerSong, eg_songGatesPost, mkr_song_post_1)
	EGroup_Filter(eg_songGatesPost, EBP.CHINESE.BUILDING_DEFENSE_PALISADE_GATE_CHI, FILTER_KEEP)
	Missionomatic_SetGateLock(eg_songGatesPost, false)
	
	-- Apply buffs to the defensive buildings
	Xiangyang_BoostDefences()
	
	-- Players need to stop attacking these. This is the heavy-handed solution.
	Player_GetAll(g_playerSong)
	EGroup_AddEGroup(eg_song_invulnerable_walls, eg_allentities)
	EGroup_Filter(eg_song_invulnerable_walls, {"stone_wall", "stone_gate", "stone_wall_tower", }, FILTER_KEEP)
	--Modify_Armor(eg_song_invulnerable_walls, 500)
	
	-- Make sure the wooden camp lights up in a blaze real fast
	Modify_OnFireDamagePerTick(eg_post4_buildings, MUT_Multiplication, 4.0)
	Modify_ReceivedDamage(eg_post4_buildings, 2.0)
	
	-- Make the settlements invulnerable
	EGroup_SetInvulnerable(eg_settlement_1, true)
	EGroup_SetInvulnerable(eg_settlement_2, true)

end

-- Any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)
function Mission_Preset()
	
	-- Enable player colours
	PlayerColour_Enable()
   
    Game_SetPlayerSlotColour(g_playerMongol, 1)
    Game_SetPlayerUISlotColour(g_playerMongol, 1)
	
    Game_SetPlayerSlotColour(g_playerSong, 2)
    Game_SetPlayerUISlotColour(g_playerSong, 2)
	
    Game_SetPlayerSlotColour(g_playerCivilians, 3)
    Game_SetPlayerUISlotColour(g_playerCivilians, 3)
    Game_SetPlayerSlotColour(g_playerAllies, 3)
    Game_SetPlayerUISlotColour(g_playerAllies, 3)
	
	-- These should be grouped for the purposes of the Fear walla tracker
	g_villagerSgroupTable = {
		sg_village_2_workers,
		sg_village_3_workers,
		sg_village_4_workers,
		sg_village_4_miners,
		sg_village_5_workers,
		sg_village_6_workers,
		sg_song_refugees,
		SGroup_FromName("song_lumber_villagers"),
		SGroup_FromName("song_farms_1_villagers"),
		SGroup_FromName("song_farms_2_villagers"),
		SGroup_FromName("song_farms_3_villagers"),
		SGroup_FromName("song_village_north_villagers"),
		SGroup_FromName("song_village_west_villagers"),
		SGroup_FromName("song_village_south_villagers"),
	}
	
	
	-- Special rules for this scenario
	Rule_AddGlobalEvent(Xiangyang1267_OnSquadKilled, GE_SquadKilled)
	--Rule_AddGlobalEvent(Xiangyang1267_OnDamageReceived, GE_DamageReceived)
	Rule_AddInterval(Xiangyang1267_SpawnRoadPatrol, 90)
	Rule_AddInterval(Xiangyang1267_WatchSallyBridge, 1)
	Rule_AddInterval(Xiangyang1267_WaitForRefugees, 1)
	Rule_AddInterval(Xiangyang1267_WaitForBribe, 1)
	Rule_AddInterval(Xiangyang1267_VillagerFearWallas, 1)
	
	-- Make sure we're watching for that first breach, to play walla
	eg_first_palisades = EGroup_CreateUnique("eg_first_palisades")
	Player_GetAllEntitiesNearMarker(g_playerSong, eg_first_palisades, mkr_song_post_1, 60)
	EGroup_Filter(eg_first_palisades, "wall", FILTER_KEEP)
	Rule_AddEGroupEvent(Xiangyang1267_OnBreachFirst, eg_first_palisades, GE_EntityKilled)
	
	-- Ditto for the wooden camp
	eg_second_palisades = EGroup_CreateUnique("eg_second_palisades")
	Player_GetAllEntitiesNearMarker(g_playerSong, eg_second_palisades, mkr_song_post_4, 60)
	EGroup_Filter(eg_second_palisades, "wall", FILTER_KEEP)
	Rule_AddEGroupEvent(Xiangyang1267_OnBreachSecond, eg_second_palisades, GE_EntityKilled)
	
	-- Make the tents way easier to burn
	Modify_OnFireHealthPercentage(eg_post4_tents, MUT_Addition, 0.55)
	
	-- Setup scout spotting
	table.insert(g_modulesToSpot, MissionOMatic_FindModule("SongPost1"))
	Rule_AddInterval(Xiangyang1267_ScoutSpotting, 1)

	-- Make sure the bridgeblasters don't run around
	Modify_WeaponDamage(sg_bridgeblasters_1, "hardpoint_01", 1.0)
	Modify_WeaponDamage(sg_bridgeblasters_2, "hardpoint_01", 1.0)
	Cmd_HoldPosition(sg_bridgeblasters_1, nil, true)
	Cmd_HoldPosition(sg_bridgeblasters_2, nil, true)
	
	Cmd_HoldPosition(sg_post_6_a, nil, true)
	Cmd_HoldPosition(sg_post_6_c, nil, true)
	Cmd_HoldPosition(sg_post_7_a, nil, true)
	Cmd_HoldPosition(sg_post_7_b, nil, true)
	Cmd_HoldPosition(sg_post_7_c, nil, true)
	
	-- Audio considerations
	if Music_UnlockIntensity then
		Sound_SetForceMusic(false)
	else
		Sound_SetForceMusic(true)
	end
	
    Music_LockIntensity(MUSIC_TENSE_COMBAT)

	-- This bridge shouldn't be destroyed until the outro, so let's make it safe
	g_fanchengBridgeInvulnerability = Modify_ReceivedDamage(eg_bridge_fancheng, 0.0)
	
	Xiangyang1267_SpawnPickups()
	
	-- Inventory the existing city bridges
	g_southernBridgeData = {}
	local _InventoryBridge = function(gid, idx, eid)
		-- Log it
		local newEntry = {
			position = Entity_GetPosition(eid),
			facing = Entity_GetHeading(eid),
		}
		-- Store it
		table.insert(g_southernBridgeData, newEntry)
		-- Blast it
		Entity_SetHealth(eid, 0.0)
	end
	EGroup_ForEach(eg_southern_bridges, _InventoryBridge)
	
	Game_SetPlayerUISlotColour(g_playerAllies, 3)
	
end

-- This is triggered after the intro, just as control is passed to the player
function Mission_Start()
	
	print("Mission Start with difficulty "..Game_GetSPDifficulty())
	
	-- on console we don't need the VPS 
	Cardinal_EnablePartialXboxUI(true, {VF_XboxUIVillagerPriorities})

	-- Sets initial player resources
	Player_SetResource(g_playerMongol, RT_Food, 0)
	Player_SetResource(g_playerMongol, RT_Wood, 0)
	Player_SetResource(g_playerMongol, RT_Stone, 0)
	Player_SetResource(g_playerMongol, RT_Gold, 0)
	
	-- Start any objectives
	Objective_Start(OBJ_Advance, true)
	
	Modifier_Remove(g_introBurnInvulnerability)
	
	-- Get those Nests of Bees facing
	SGroup_Single(sg_temp, SGroup_GetSquadAt(sg_fancheng_mangonels, 1))
	LocalCommand_SquadMovePosFacing(g_playerSong, sg_temp, Marker_GetPosition(mkr_outro_catapult_1), Marker_GetPosition(mkr_outro_target_a), false, false, false, 0.0)
	SGroup_Single(sg_temp, SGroup_GetSquadAt(sg_fancheng_mangonels, 2))
	LocalCommand_SquadMovePosFacing(g_playerSong, sg_temp, Marker_GetPosition(mkr_outro_catapult_2), Marker_GetPosition(mkr_outro_target_a), false, false, false, 0.0)

	-- This is needed because some ScarUtil functions assume "player1" is always the name of the human player, which is problematic
	player1 = g_playerMongol
	
	-- Init the tutorialization? Not sure if this does anything.
	MissionTutorial_Init()
	
	-- Flag the start!
	g_SongFortressStarted = true
	
end

