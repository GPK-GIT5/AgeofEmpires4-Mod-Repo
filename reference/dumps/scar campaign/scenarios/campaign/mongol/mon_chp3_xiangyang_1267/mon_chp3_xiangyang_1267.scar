--? @shortdesc Spawns resource pickups for off-track areas
function Xiangyang1267_SpawnPickups()
	
	local pickupTypes = {
		"wood",
		"gold",
		"food",
		"food",
		"wood",
		"gold",
		"gold",
		"food",
		"wood",
		"gold",
		"wood",
	}
	
	-- Create the pickups
	for i = 1, #pickupTypes do
		local marker = Marker_FromName("mkr_pickup_"..tostring(i), "")
		Missionomatic_SpawnPickup(marker, pickupTypes[i])
	end
	
end

--? @shortdesc Checks for killed squads, which are important for some objectives
function Xiangyang1267_OnSquadKilled(context)
	
	local victim = context.victim
	if World_OwnsSquad(victim) == false and Squad_GetPlayerOwner(victim) == g_playerSong then
		--[[ Track how many recent deaths we've had while defending the trebuchets
		local playerKiller = context.killer ~= nil and World_OwnsEntity(context.killer) == false and Entity_GetPlayerOwner(context.killer) == g_playerMongol
		if playerKiller and Objective_IsStarted(SOBJ_DefendTrebs) == true and Objective_IsComplete(SOBJ_DefendTrebs) == false then
			SOBJ_DefendTrebs.killsCurrent = SOBJ_DefendTrebs.killsCurrent + 1
		end
		]]
		
	end
end

--? @shortdesc Outro functionality
function Xiangyang1267_RunOutro()
	
	-- MONGOLS TO RETREAT
	sg_outro_mongols_1 = SGroup_CreateIfNotFound("sg_outro_mongols_1")
	sg_outro_mongols_2 = SGroup_CreateIfNotFound("sg_outro_mongols_2")
	sg_outro_mongols_3 = SGroup_CreateIfNotFound("sg_outro_mongols_3")
	sg_outro_allied_01 = SGroup_CreateIfNotFound("sg_outro_allied_01")
	sg_outro_allied_02 = SGroup_CreateIfNotFound("sg_outro_allied_02")
	sg_outro_allied_03 = SGroup_CreateIfNotFound("sg_outro_allied_03")
	sg_outro_allied_04 = SGroup_CreateIfNotFound("sg_outro_allied_04")
	sg_outro_mongols_4 = SGroup_CreateIfNotFound("sg_outro_mongols_4")
	
	UnitEntry_DeploySquads (g_playerMongol, nil, {
		{type = "scar_knight", numSquads = 6, spawn = mkr_outro_mongol_1,  sgroup = sg_outro_mongols_1},
		{type = "scar_horsearcher", numSquads = 8, spawn = mkr_outro_mongol_2,  sgroup = sg_outro_mongols_2},			
		{type = "scar_knight", numSquads = 8, spawn = mkr_outro_mongol_3,  sgroup = sg_outro_mongols_3},
		{type = "scar_horsearcher", numSquads = 6, spawn = mkr_outro_mongol_07, sgroup = sg_outro_mongols_4},
	})
	
	UnitEntry_DeploySquads (g_playerAllies, nil, {
		{type = "scar_horseman", numSquads = 8, spawn = mkr_outro_mongol_05, sgroup = sg_outro_allied_01},
		{type = "scar_knight", numSquads = 6, spawn = mkr_outro_mongol_06,  sgroup = sg_outro_allied_02},			
		{type = "scar_horseman", numSquads = 8, spawn = mkr_outro_mongol_04,  sgroup = sg_outro_allied_03},
		{type = "scar_horseman", numSquads = 8, spawn = mkr_outro_mongol_08,  sgroup = sg_outro_allied_04},
	})
	
	-- REMOVE RANGE ON TOWERS FOR OUTRO
	local cutRange = Modifier_Create(MAT_Weapon, WM_RANGE, MUT_Multiplication, false, 0.01, nil)
	local function _CutTowers(gid, idx, eid)
		if Entity_IsValid(Entity_GetID(eid)) then
			Modifier_ApplyToEntity(cutRange, eid, 0)
		end
	end
	
	Player_GetAll(g_playerSong)
	EGroup_Filter(eg_allentities, {
			EBP.CHINESE.BUILDING_DEFENSE_TOWER_CHI,
			EBP.CHINESE.BUILDING_DEFENSE_WALL_CHI,
			EBP.CHINESE.BUILDING_DEFENSE_WALL_GATE_CHI,
			EBP.CHINESE.BUILDING_DEFENSE_WALL_BASTION_CHI,
			EBP.CHINESE.BUILDING_DEFENSE_KEEP_CHI,
		}, FILTER_KEEP)
	EGroup_ForEach(eg_allentities, _CutTowers)
	
	-- WALL INFANTRY
	sg_outro_patrol_1 = SGroup_CreateUnique("sg_outro_patrol_1")
	sg_outro_patrol_2 = SGroup_CreateUnique("sg_outro_patrol_2")
	
	-- Group 1
	Action_SpawnUnits_Do({
		player = g_playerSong,
		spawnLocation = mkr_outro_wallpatrol_1,
		sgroup = sg_outro_patrol_1,
		units = {
			{ type = "scar_spearman", numSquads = 2, },
			{ type = "scar_archer", numSquads = 2, }
		},
	})
	Cmd_FormationMove(sg_outro_patrol_1, mkr_outro_wallpatrol_2, true)
	Cmd_FormationMove(sg_outro_patrol_1, mkr_outro_wallpatrol_1, true)
	Cmd_FormationMove(sg_outro_patrol_1, mkr_outro_wallpatrol_2, true)
	
	-- Group 2
	Action_SpawnUnits_Do({
		player = g_playerSong,
		spawnLocation = mkr_outro_wallpatrol_3,
		sgroup = sg_outro_patrol_2,
		units = {
			{ type = "scar_spearman", numSquads = 2, },
			{ type = "scar_archer", numSquads = 2, }
		},
	})
	Cmd_FormationMove(sg_outro_patrol_2, mkr_outro_wallpatrol_4, true)
	Cmd_FormationMove(sg_outro_patrol_2, mkr_outro_wallpatrol_3, true)
	Cmd_FormationMove(sg_outro_patrol_2, mkr_outro_wallpatrol_4, true)
	
	-- MANGONELS
	local sgroupCatapults1 = SGroup_CreateUnique("sgroupCatapults1")
	UnitEntry_DeploySquads(
		g_playerSong,
		sgroupCatapults1,
		{
			{ sbp = SBP.CHINESE.UNIT_TREBUCHET_4_CW_CHI, numSquads = 1, spawn = mkr_outro_catapult_1, },
			{ sbp = SBP.CHINESE.UNIT_TREBUCHET_4_CW_CHI, numSquads = 1, spawn = mkr_outro_catapult_2, },
		},
		mkr_outro_catapult_1)
	-- Activate FIRE
	--LocalCommand_SquadAbility(g_playerSong, sgroupCatapults1, BP_GetAbilityBlueprint("mangonel_incendiary_weapon"), true, false)
	-- Boost range to shoot the bridges properly
	local modRange = Modifier_Create(MAT_Weapon, WM_RANGE, MUT_Multiplication, false, 3, nil)
	local function _BoostForOutro(gid, idx, sid)
		local entity = Squad_GetFirstEntity(sid)
		Modifier_ApplyToEntity(modRange, entity, 0)
	end
	SGroup_ForEach(sgroupCatapults1, _BoostForOutro)
	Modify_WeaponReload(sgroupCatapults1, "hardpoint_01", 0.1)
	Modify_WeaponReload(sgroupCatapults1, "hardpoint_02", 0.1)
	
	-- Make bridges vulnerable again and weaken them
	Modifier_Remove(g_fanchengBridgeInvulnerability)
	EGroup_SetInvulnerable(eg_city_bridges, false)
	EGroup_SetAvgHealth(eg_city_bridges, 1.0)
	
	-- Attack the bridge!
	Cmd_Attack(sgroupCatapults1, mkr_outro_target_a)
	
end

function Xiangyang_BoostDefences()
	
	-- Artificially boost tower ranges - LOS needed too or it won't work!
	local modHealth = Modifier_Create(MAT_Entity, "health_maximum_modifier", MUT_Multiplication, false, 15, "")
	local modRegen = Modifier_Create(MAT_Entity, "health_regeneration_modifier", MUT_Addition, false, 25, "")
	local modSight = Modifier_Create(MAT_Entity, "sight_radius_modifier", MUT_Multiplication, false, 10, "")
	local modFireThresh = Modifier_Create(MAT_Entity, "on_fire_threshold_modifier", MUT_Multiplication, false, 100, "")
	local modFireArmour = Modifier_Create(MAT_Entity, "on_fire_damage_per_tick_modifier", MUT_Multiplication, false, 0, "")
	local function _BoostDefences(gid, idx, eid)
		if Entity_IsValid(Entity_GetID(eid)) then
			Modifier_ApplyToEntity(modHealth, eid, 0)
			Modifier_ApplyToEntity(modRegen, eid, 0)
			Modifier_ApplyToEntity(modSight, eid, 0)
			Modifier_ApplyToEntity(modFireThresh, eid, 0)
			Modifier_ApplyToEntity(modFireArmour, eid, 0)
		end
	end
	
	Player_GetAll(g_playerSong)
	EGroup_Filter(eg_allentities, {
			EBP.CHINESE.BUILDING_DEFENSE_TOWER_CHI,
			EBP.CHINESE.BUILDING_DEFENSE_WALL_CHI,
			EBP.CHINESE.BUILDING_DEFENSE_WALL_GATE_CHI,
			EBP.CHINESE.BUILDING_DEFENSE_WALL_BASTION_CHI,
			EBP.CHINESE.BUILDING_DEFENSE_KEEP_CHI,
		}, FILTER_KEEP)
	EGroup_ForEach(eg_allentities, _BoostDefences)
	
	-- Also boost tower attack
	local hardpointName = "hardpoint_01"
	local modArmor = Modifier_Create(MAT_Entity, "armor_modifier", MUT_Multiplication, false, 50, "")
	local modDamage = Modifier_Create(MAT_Weapon, WM_DAMAGE, MUT_Multiplication, false, 4, hardpointName)
	local modReload = Modifier_Create(MAT_Weapon, WM_RELOAD, MUT_Multiplication, false, 0.5, hardpointName)
	local modRange = Modifier_Create(MAT_Weapon, WM_RANGE, MUT_Multiplication, false, 1.5, hardpointName)
	local function _BoostTowers(gid, idx, eid)
		if Entity_IsValid(Entity_GetID(eid)) then
			Modifier_ApplyToEntity(modArmor, eid, 0)
			Modifier_ApplyToEntity(modDamage, eid, 0)
			Modifier_ApplyToEntity(modReload, eid, 0)
			Modifier_ApplyToEntity(modRange, eid, 0)
		end
	end
	
	-- Find all the towers
	Player_GetAll(g_playerSong)
	EGroup_Filter(eg_allentities, { EBP.CHINESE.BUILDING_DEFENSE_TOWER_CHI, EBP.CHINESE.BUILDING_DEFENSE_KEEP_CHI, }, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.CHINESE.UPGRADE_TOWER_HANDCANNONSLITS_CHI)
	EGroup_ForEach(eg_allentities, _BoostTowers)
	
end

--? @shortdesc Watches for damage taken by Song defences
function Xiangyang1267_OnDamageReceived(context, data)
	
	local attacker = context.attacker
	local victim = context.victim
	
	g_lastWarning = g_lastWarning or 0
	local currentGameTime = World_GetGameTime()
	-- Only do this every 10 seconds at most
	if (currentGameTime - g_lastWarning) > 20 then
		if attacker ~= nil and Util_GetPlayerOwner(attacker) == g_playerMongol and Util_GetPlayerOwner(victim) == g_playerSong then
			if Entity_HasBlueprint(victim, {"stone_wall", "stone_wall_tower", "stone_gate"}) == true then
				Obj_CreatePopup(OBJ_CampUp.ID, "$11192346", "")
				g_lastWarning = currentGameTime
			end
		end
	end
	
end

--? @shortdesc Spawns a group to patrol the roads beyond Xiangyang
function Xiangyang1267_SpawnRoadPatrol(context, data)
	
	g_patrolCount = g_patrolCount or 0
	if g_patrolCount >= 4 then
		Rule_RemoveMe()
		return
	end
	
	-- Write up a patrol ID
	g_patrolId = g_patrolId or 0
	g_patrolId = g_patrolId + 1
	
	-- UNIT COMPOSITION
	local unitList = {
		{ sbp = BP_GetSquadBlueprint("unit_militia_cmp_chi"), numSquads = 2, },
		{ type = "scar_archer", numSquads = Util_DifVar({2, 4, 5, 6, }), },
	}
	
	local newPatrol = RovingArmy_Init({
		type = "RovingArmy",
		descriptor = "RoadPatrol"..tostring(g_patrolId),
		player = g_playerSong,
		spawnLocation = mkr_song_post_4,
		units = unitList,
		targetingType = ARMY_TARGETING_REVERSE,
		targets = {
			mkr_road_patrol_1,
			mkr_road_patrol_2,
			mkr_road_patrol_3,
			mkr_road_patrol_4,
			mkr_road_patrol_5,
			mkr_road_patrol_6,
		},
		onDeathDissolve = true,
		onDeathFunction = Xiangyang1267_OnPatrolDeath,
		attackMove = attackMoveStyle_attackEverything,
	})
	
	table.insert(g_modulesToSpot, newPatrol)
	table.insert(g_roadPatrols, newPatrol)
	g_patrolCount = g_patrolCount + 1
	
end

--? @shortdesc Moves the refugees away when the player can see them
function Xiangyang1267_WaitForBribe(context, data)

	Player_GetAllSquadsNearMarker(g_playerMongol, sg_temp, mkr_pickup_11, Marker_GetProximityRadiusOrDefault(mkr_pickup_11, 5))
	if SGroup_Count(sg_temp) <= 0 then
		return
	end

	-- WARNING. DO NOT use VillagerLife here, or for anything wood related for that matter.
	-- It scans the whole map for trees. It's super slow and will cause lag.
	-- Grab the briber directly and send them to a close by tree instead.
	EGroup_Clear(eg_temp)
	local player = Util_GetPlayerOwner(sg_lumberyard_briber)
	World_GetEntitiesNearPoint(player, eg_temp, SGroup_GetPosition(sg_lumberyard_briber), 10, OT_Neutral)
	EGroup_Filter(eg_temp, "tree", FILTER_KEEP)

	-- This check is here to cover edge cases. Highly doubt that the distance will change but technically the player
	-- could leave the game running for 1h and the other 6 villagers could have chopped down all the trees in range...
	-- in that case the briber will not go anywhere and just stand there.
	if EGroup_CountSpawned(eg_temp) > 0 then
		 -- just take the first best one. Sim will sort itself out if it's unreachable.
		local treeEntity = EGroup_GetEntityAt(eg_temp, 1)

		local gatherFromTree = function(sgroup, villager_index, villager)
			VillagerGatherFromEntityDeposit(player, villager, treeEntity)
		end

		SGroup_ForEach(sg_lumberyard_briber, gatherFromTree)
	end

	Rule_RemoveMe()
	
end

--? @shortdesc Moves the refugees away when the player can see them
function Xiangyang1267_WaitForRefugees(context, data)

	if Player_CanSeeSGroup(g_playerMongol, sg_song_refugees, ALL) == false then
		return
	end
	
	Player_GetAllSquadsNearMarker(g_playerMongol, sg_temp, mkr_refugee_spawn, Marker_GetProximityRadiusOrDefault(mkr_refugee_spawn, 60))
	SGroup_Filter(sg_temp, "scar_scout", FILTER_REMOVE)
	if SGroup_Count(sg_temp) <= 0 and SGroup_GetAvgHealth(sg_song_refugees) >= 1.0 then
		return
	end
	
	print("Song Fortress: Refugees spawned")
	-- This formation move tries to delete on arrival but it does not work anymore
	-- Looks like the units fail to arrive at their destination due to a gate blocking them so they don't get deleted
	Cmd_FormationMove(sg_song_refugees, mkr_base_fancheng, false, true)
	Sound_PlayWallaFearOnSGroup(sg_song_refugees)
	Rule_RemoveMe()
	
end

--? @shortdesc Xiangyang starts without guards; this spawns them
function Xiangyang1267_SpawnAllies()
	
	-- This check is mostly for safety while cheating
	if g_alliesAlreadySpawned == true then
		return
	end
	-- Make sure this never happens twice
	g_alliesAlreadySpawned = true
	
	-- Spawn whoever the player will get as reinforcements
	-- Make sure it's at least 15 units, so repeat-players don't feel cheated
	local reinforcementCount = 15
	Player_GetAll(g_playerMongol)
	if SGroup_Count(sg_allsquads) < 80 then
		reinforcementCount = reinforcementCount + (80 - SGroup_Count(sg_allsquads))
	end
		
	UnitEntry_DeploySquads(g_playerAllies, sg_allied_reinforcement_group, {
		{ type = "scar_horseman", numSquads = 1 + (reinforcementCount * 0.5), },
		{ type = "scar_knight", numSquads = 1 + (reinforcementCount * 0.3), },
		{ type = "scar_horsearcher", numSquads = 1 + (reinforcementCount * 0.2), },
	}, mkr_mongol_reinforcements)
	
	-- Spawn the main force
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(g_playerAllies, sg_allies, {
			{ type = "scar_horseman", numSquads = 32, },
			{ type = "scar_knight", numSquads = 16, },
			{ type = "scar_trebuchet_traction", spawn = mkr_ally_treb_spawn, sgroup = sg_treb_1, numSquads = 1, },
			{ type = "scar_trebuchet_traction", spawn = mkr_ally_treb_spawn, sgroup = sg_treb_2, numSquads = 1, },
			{ type = "scar_trebuchet_traction", spawn = mkr_ally_treb_spawn, sgroup = sg_treb_3, numSquads = 1, },
			{ type = "scar_trebuchet_traction", spawn = mkr_ally_treb_spawn, sgroup = sg_treb_4, numSquads = 1, },
		}, mkr_mongol_rally_1)
	UnitEntry_DeploySquads(g_playerAllies, sg_allies, {
			{ type = "scar_horseman", numSquads = 32, },
			{ type = "scar_knight", numSquads = 16, },
		}, mkr_mongol_rally_2)
	UnitEntry_DeploySquads(g_playerAllies, sg_allies, {
			{ type = "scar_horseman", numSquads = 32, },
			{ type = "scar_knight", numSquads = 16, },
		}, mkr_mongol_rally_3)
	
	-- Also add the allied trebs to a larger group
	sg_allied_trebuchets = SGroup_CreateIfNotFound("sg_allied_trebuchets")
	SGroup_AddGroups(sg_allied_trebuchets, { sg_treb_1, sg_treb_2, sg_treb_3, sg_treb_4, })
	-- Boost those trebuchets so they survive a while against the cannons
	Modify_ReceivedDamage(sg_allied_trebuchets, 0.2, MUT_Multiplication)
	-- But make sure they die easily to fire from the attackers
	Modify_OnFireThreshold(sg_allied_trebuchets, MUT_Multiplication, 0.25)
	Modify_OnFireDamagePerTick(sg_allied_trebuchets, MUT_Multiplication, 5.0)
	
	-- Get them all to hold position for now
	LocalCommand_SquadExt(g_playerSong, sg_allies, SCMD_HoldPosition, 1, false)
	
end

function Xiangyang1267_ScoutSpotting(context, data)
	
	-- Remove the rule if there's nothing left to spot
	if #g_modulesToSpot <= 0 then
		Rule_RemoveMe()
		return
	end
	
	-- Make sure we have scouts
	Player_GetAll(g_playerMongol, sg_temp)
	SGroup_Filter(sg_temp, "scar_scout", FILTER_KEEP)
	if SGroup_Count(sg_temp) <= 0 then
		return
	end
	
	-- We want to know if a player scout spotted these units or not
	local spotted = false
	local _CheckScoutSpotted = function(gid, idx, sid)
		local num_spawned_squads = SGroup_CountSpawned(sg_temp)
		for idx = 1, num_spawned_squads do
			if Squad_CanSeeSquad(SGroup_GetSpawnedSquadAt(sg_temp, idx), sid) == true then
				spotted = true
				return
			end
		end
	end
	
	-- If so, we do stuff
	for index, module in pairs(g_modulesToSpot) do
		spotted = false
		SGroup_ForEach(module.sgroup, _CheckScoutSpotted)
		if spotted == true then
			ThreatArrow_CreateGroup("enemy squad", module.sgroup)
			table.remove(g_modulesToSpot, index)
			if g_scoutSpottingCueTriggered ~= true then
				-- Does the player have any Scouts selected?
				Misc_GetSelectedSquads(sg_temp, false)
				SGroup_Filter(sg_temp, "scar_scout", FILTER_KEEP)
				-- If we trigger the hint when a scout it already selected, it will auto-resolve silently. That's bad, so let's avoid that
				if SGroup_Count(sg_temp) <= 0 then
					MissionOMatic_HintOnSquadSelect("Carefully guide Scouts through unexplored territory to find Song ambushes and alternate paths",
						"$11195822",
						"mon_chp3_xiangyang_1267_scouting",
						"scar_scout")
					g_scoutSpottingCueTriggered = true
				end
			end
		end
	end
	
end

--? @shortdesc Used to destroy or delete whatever should already have been deleted
function Xiangyang1267_CheatDeleteOutlyingUnits(stage)
	
	stage = stage or 1
	
	-- Delete all units in these modules; the player should have killed these off
	local modulesToNuke = {
		"SongRunners",
		"SongPost1",
	}
	if stage > 1 then
		table.insert(modulesToNuke, "SongPost4North")
		table.insert(modulesToNuke, "SongPost4East")
		table.insert(modulesToNuke, "SongPost4NorthBuff")
		table.insert(modulesToNuke, "SongPost4EastBuff")
		table.insert(modulesToNuke, "SongPost4Southwest")
		table.insert(modulesToNuke, "SongPost6Front")
		table.insert(modulesToNuke, "SongPost6Spears")
		table.insert(modulesToNuke, "SongPost6Back1")
		table.insert(modulesToNuke, "SongPost6Back2")
		table.insert(modulesToNuke, "SongPost6Back3")
		table.insert(modulesToNuke, "SongPost6Back4")
		table.insert(modulesToNuke, "SongPost7A")
		table.insert(modulesToNuke, "SongPost7B")
		table.insert(modulesToNuke, "SongPost7C")
	end
	if stage > 2 then
		table.insert(modulesToNuke, "SongSiegeAttackers")
	end
	
	-- Now kill them all
	for index, moduleName in pairs(modulesToNuke) do
		local module = MissionOMatic_FindModule(moduleName)
		if module ~= nil and module.sgroup ~= nil then
			SGroup_DestroyAllSquads(module.sgroup)
		end
	end
	
	-- Also get rid of blocking entities the player would have destroyed
	local markersToSearch = {
		mkr_song_post_1,
		mkr_song_post_2,
		mkr_song_post_3,
		mkr_post_6_a,
		mkr_post_6_b,
		mkr_post_6_c,
		mkr_post_6_d,
		mkr_post_6_e,
		mkr_post_6_f,
		mkr_post_7_a,
		mkr_post_7_b,
		mkr_post_7_c,
	}
	if stage > 1 then
		table.insert(markersToSearch, mkr_song_post_4)
		table.insert(markersToSearch, mkr_village_4)
	end
	if stage > 2 then
		table.insert(markersToSearch, mkr_song_post_5)
	end
	
	-- Now destroy them all
	for index, marker in pairs(markersToSearch) do
		EGroup_Clear(eg_temp)
		Player_GetAllEntitiesNearMarker(g_playerSong, eg_temp, marker, 60)
		if EGroup_Count(eg_temp) > 0 then
			EGroup_Kill(eg_temp)
		end
	end
end

--? @shortdesc Check to see if the player is sneaking their way over the bridge
function Xiangyang1267_WatchSallyBridge(context, data)
	
	if g_sallyBridgeDestroyed ~= true then
		Player_GetAllSquadsNearMarker(g_playerMongol, sg_temp, mkr_player_no_touchy)
		if SGroup_Count(sg_temp) >= 1 then
			Xiangyang1267_BlastSallyBridge()
			-- Flag as destroyed
			g_sallyBridgeDestroyed = true
			-- Also stop the breadcrumbers, if there are any
			g_breadcrumbersLaunched = 99
			if Rule_Exists(Xiangyang1267_LaunchBreadcrumbers) then
				Rule_Remove(Xiangyang1267_LaunchBreadcrumbers)
			end
		end
		
	elseif Xiangyang1267_IsBridgeDestroyed() == true then
		Cmd_FormationMove(sg_bridgeblasters_1, mkr_song_swarmers_5, false, true)
		Cmd_FormationMove(sg_bridgeblasters_2, mkr_song_swarmers_5, false, true)
		Rule_RemoveMe()
		
	end
end

--? @shortdesc Split out so we can call it through the console
function Xiangyang1267_BlastSallyBridge()
	FOW_RevealMarker(mkr_song_swarmers_1, 10)
	
	Cmd_Attack(sg_bridgeblasters_1, mkr_sally_bridge_target)
	Cmd_Attack(sg_bridgeblasters_2, mkr_sally_bridge_target)
	
	Util_StartIntel(EVENTS.Song_Burn_West_Bridge)
end

--? @shortdesc Check to see if the player is sneaking their way over the bridge
function Xiangyang1267_OnBreachFirst(context, data)
	
	if g_firstBreach ~= true then
		g_firstBreach = true
		-- Make player units near the breach cheer
		local destructionPos = Util_GetPosition(context.victim)
		Player_GetAllSquadsNearMarker(g_playerMongol, sg_temp, destructionPos, 20)
		Sound_PlayWallaChargeOnSGroup(sg_temp)
		-- And a general stinger
		Sound_Play2D(MUS_STING_POSITIVE)
	end
	
	-- This should only play once for this EGroup, so get rid of it
	Rule_RemoveMe()
	
end

