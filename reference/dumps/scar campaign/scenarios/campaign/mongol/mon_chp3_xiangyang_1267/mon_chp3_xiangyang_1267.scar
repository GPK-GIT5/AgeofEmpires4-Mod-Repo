--
-- Xiangyang 1267
--
-- Mongol Chapter 3
--
-- We need to import this for anything to work. We don't need anything else
import("MissionOMatic/MissionOMatic.scar")
-- We need to import custom objective files
import("obj_xiangyang1_phase1.scar")
import("obj_xiangyang1_secondary.scar")
import("training_xiangyang1.scar")
import("gathering_utility.scar")

-- Setup player data
function Mission_SetupPlayers()
	
	-- Get IDs for all players
	g_playerMongol = World_GetPlayerAt(1)
	g_playerSong = World_GetPlayerAt(2)
	g_playerCivilians = World_GetPlayerAt(3)
	g_playerAllies = World_GetPlayerAt(4)
	
	-- The human player
	Setup_SetPlayerName(g_playerMongol, Loc_GetString("$11179203"))
	Player_SetCurrentAge(g_playerMongol, AGE_CASTLE)
	Player_SetMaximumAge(g_playerMongol, AGE_CASTLE)

	-- The main enemy AI player	
	Setup_SetPlayerName(g_playerSong, Loc_GetString("$11179204"))
	Player_SetCurrentAge(g_playerSong, AGE_CASTLE)
	Player_SetMaximumAge(g_playerSong, AGE_CASTLE)
	
	-- A neutral Chinese AI player	
	Setup_SetPlayerName(g_playerCivilians, Loc_GetString("$11179205"))
	Player_SetCurrentAge(g_playerCivilians, AGE_FEUDAL)
	Player_SetMaximumAge(g_playerCivilians, AGE_FEUDAL)
	
	-- The allied Mongol player
	Setup_SetPlayerName(g_playerAllies, Loc_GetString("$11179203"))
	Player_SetCurrentAge(g_playerAllies, AGE_FEUDAL)
	Player_SetMaximumAge(g_playerAllies, AGE_FEUDAL)

	-- Player relationships
	Player_SetRelationship(g_playerMongol, g_playerSong, R_ENEMY)
	Player_SetRelationship(g_playerSong, g_playerMongol, R_ENEMY)
	
	Player_SetRelationship(g_playerMongol, g_playerAllies, R_ALLY)
	Player_SetRelationship(g_playerAllies, g_playerMongol, R_ALLY)
	
	Player_SetRelationship(g_playerSong, g_playerAllies, R_ENEMY)
	Player_SetRelationship(g_playerAllies, g_playerSong, R_ENEMY)
	
	-- Civilians are allied with everyone
	Player_SetRelationship(g_playerMongol, g_playerCivilians, R_ALLY)
	Player_SetRelationship(g_playerCivilians, g_playerMongol, R_ALLY)
	
	Player_SetRelationship(g_playerSong, g_playerCivilians, R_NEUTRAL)
	Player_SetRelationship(g_playerCivilians, g_playerSong, R_NEUTRAL)
	
	World_EnableSharedLineOfSight(g_playerMongol, g_playerSong, false)
	World_EnableSharedLineOfSight(g_playerMongol, g_playerCivilians, false)
	World_EnableSharedLineOfSight(g_playerMongol, g_playerAllies, false)
	
	
end

