		-- Make player units near the breach cheer
		local destructionPos = Util_GetPosition(context.victim)
		Player_GetAllSquadsNearMarker(g_playerMongol, sg_temp, destructionPos, 20)
		Sound_PlayWallaChargeOnSGroup(sg_temp)
		-- And a general stinger
		Sound_Play2D(MUS_STING_POSITIVE)
	end
	
	-- This should only play once for this EGroup, so get rid of it
	Rule_RemoveMe()
	
end

--? @shortdesc Ensures villagers play a Fear walla when attacked
function Xiangyang1267_VillagerFearWallas(context, data)
	
	for index, sgroup in pairs(g_villagerSgroupTable) do
		if scartype(sgroup) ~= ST_SGROUP or SGroup_Count(sgroup) <= 0 then
			table.remove(g_villagerSgroupTable, index)
		elseif SGroup_IsUnderAttack(sgroup, ANY, 2) then
			Sound_PlayWallaFearOnSGroup(sgroup)
			table.remove(g_villagerSgroupTable, index)
		end
	end
	
	if #g_villagerSgroupTable <= 0 then
		Rule_RemoveMe()
	end
	
end