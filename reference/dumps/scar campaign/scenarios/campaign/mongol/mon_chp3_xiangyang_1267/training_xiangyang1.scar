function Predicate_UserHasAnyOutpostSelected(goal)
	Player_GetAll(g_playerMongol)
	EGroup_Filter(eg_allentities, "outpost", FILTER_KEEP)
	EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
	return Misc_IsEGroupSelected(eg_allentities, ANY)
end

function Predicate_UserHasNotSelectedOutpostsRecently(goalSequence)
	
	Player_GetAll(g_playerMongol)
	EGroup_Filter(eg_allentities, "outpost", FILTER_KEEP)
	EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
	if ABriefPeriodOfTimeHasPassed(goalSequence) and EGroup_Count(eg_allentities) > 0 then
		local entity = EGroup_GetSpawnedEntityAt(eg_allentities, 1)
		goalSequence.goals[goalSequence.currentGoalIndex].key = entity
		return true
	end
	return false
end

function MissionTutorial_AddHintToOutposts()

	local GoalUI = {
		ID = "Move cavalry near your Outposts to give them a temporary speed bonus.",
		Message = "$11184824",
		DataTemplate = "GenericTrainingDataTemplate",
	}
	local GoalUseOutposts = Training_Goal(
		nil, 
		GoalUI, 
		Predicate_UserHasAnyOutpostSelected
	)
	local GoalSequenceUseOutposts = Training_GoalSequence(
		goal_sequence_use_outposts, 						-- id
		1, 													-- repeatMax
		0, 													-- remindMax
		Predicate_UserHasNotSelectedOutpostsRecently, 		-- trigger
		CampaignTraining_TimeoutIgnorePredicate, 												-- ignore
		nil,										 		-- remind
		Predicate_UserHasAnyOutpostSelected, 				-- bypass
		false, 												-- canRegress
		{GoalUseOutposts}									-- goals
	)
	Training_AddGoalSequence(GoalSequenceUseOutposts)
		
	Training_EnableGoalSequenceByID(goal_sequence_use_outposts, true)
	
end