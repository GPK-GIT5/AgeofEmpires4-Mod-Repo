-- function starts the Position Squad C monitor
function GetSquadToPositionC_Start()
	
	Rule_Add(GetSquadProgressC_Monitor)
end


function GetSquadProgressC_Monitor()
	local sg_tempC = SGroup_CreateIfNotFound("sg_tempC")
	
	Player_GetAllSquadsNearMarker(player1,sg_tempC,mkr_ambush_position_c, 20)
--	SGroup_Filter(sg_tempC,SBP.MONGOL.UNIT_KNIGHT_2_MON, FILTER_KEEP)
	
	local unitCount = SGroup_CountSpawned(sg_tempC)

	if unitCount < AMOUNT_ALLY_AT_POINTS_Central then 
		Objective_SetProgressBar(SOBJ_GetSquadToPositionC, (unitCount / AMOUNT_ALLY_AT_POINTS_Central))
	else
		Objective_SetProgressBar(SOBJ_GetSquadToPositionC, (unitCount / AMOUNT_ALLY_AT_POINTS_Central))
		Objective_Complete(SOBJ_GetSquadToPositionC)
		Rule_RemoveMe()
	end

	
end

function GetSquadToPositionC_OnComplete()
	
	Objective_RemoveUIElements(SOBJ_GetSquadToPositionC,hpid_AmbushC)

end


-- function called when ambush setup is done
function SetupTheRusAmbush_OnComplete()
	Music_RestartAfterObjective(2.5)
	
	Objective_Start(OBJ_DestroyTheRusUltimate, false, true)
	
end
