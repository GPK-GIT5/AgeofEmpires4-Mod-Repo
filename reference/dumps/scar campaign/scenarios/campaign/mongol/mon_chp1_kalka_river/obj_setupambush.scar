function GetSquadToPositionC_UI()
	
	hpid_AmbushC = Objective_AddUIElements(SOBJ_GetSquadToPositionC, mkr_ambush_position_c, true,"$11172160", true, nil, nil, nil)
	Objective_SetProgressBar(SOBJ_GetSquadToPositionC, 0)
