--
-- Xiangyang 1273 - Tutorial elements
--

import("training.scar")
import("training/campaigntraininggoals.scar")

-- called from the mission's Mission_Start() function, so post-intro
function MissionTutorial_Init()

	UI_SetModalHoverCallback(OnHoverChange)
	
end

function Xiangyang1273_TriggerIsmailHint_Xbox(goalSequence)
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	if currentTime > __t_trainingHoverInterval then	
		
		Player_GetAll(g_playerMongol)
		local squads = Player_GetSquads(g_playerMongol)
	
		goalSequence.goals[1].key = nil
		goalSequence.goals[2].key = nil
		
		for i = 1, SGroup_Count(squads) do
			local squad = SGroup_GetSquadAt(squads, i)
			if squad ~= nil and Squad_GetBlueprint(squad) == SBP.MONGOL.UNIT_ISMAIL_CMP_MON then
				if Misc_IsSquadOnScreen(squad, 100) then 
					goalSequence.goals[1].key = Squad_GetID(squad)
					goalSequence.goals[2].key = Squad_GetID(squad)
					goalSequence.goals[3].key = BP_GetAbilityBlueprint("leader_falcon_sight")
					break
				end
			end
		end
		
		if goalSequence.goals[1].key ~= nil then
			return true
		end
	end
	return false
end

