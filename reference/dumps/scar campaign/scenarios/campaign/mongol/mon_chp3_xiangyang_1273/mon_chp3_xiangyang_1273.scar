--
-- Xiangyang 1273
--
-- Mongol Chapter 3
--

-- We need to import this for anything to work. We don't need anything else
import("MissionOMatic/MissionOMatic.scar")
import("obj_xiangyang2_secondary.scar")
import("obj_xiangyang2_phase1.scar")
-- And this shared base file
--import("cardinal/scenarios/campaign/mongol/mon_base_xiangyang/mon_base_xiangyang.scar")
import("training_xiangyang2.scar")

-- Setup player data
function Mission_SetupPlayers()
	
	-- Get IDs for all players
	g_playerMongol = World_GetPlayerAt(1)
	g_playerSong = World_GetPlayerAt(2)
	g_playerYuan = World_GetPlayerAt(3)
	g_playerNeutral= World_GetPlayerAt(4)
	
	-- The human player
	Setup_SetPlayerName(g_playerMongol, Loc_GetString("$11179233"))
	Player_SetCurrentAge(g_playerMongol, AGE_IMPERIAL)
	Player_SetMaximumAge(g_playerMongol, AGE_IMPERIAL)

	-- The main enemy AI player	
	Setup_SetPlayerName(g_playerSong, Loc_GetString("$11179234"))
	Player_SetCurrentAge(g_playerSong, AGE_IMPERIAL)
	Player_SetMaximumAge(g_playerSong, AGE_IMPERIAL)

	-- Player relationships	
	Player_SetRelationship(g_playerMongol, g_playerSong, R_ENEMY)
	Player_SetRelationship(g_playerSong, g_playerMongol, R_ENEMY)
	
	--
	-- The player's AI ally
	--
	Setup_SetPlayerName(g_playerYuan, Loc_GetString("$11179235"))
	Player_SetCurrentAge(g_playerYuan, AGE_IMPERIAL)
	Player_SetMaximumAge(g_playerYuan, AGE_IMPERIAL)
	-- Relationship to player
	Player_SetRelationship(g_playerMongol, g_playerYuan, R_ALLY)
	Player_SetRelationship(g_playerYuan, g_playerMongol, R_ALLY)
	-- Enemy needs to be able to attack the player's ally
	Player_SetRelationship(g_playerSong, g_playerYuan, R_ENEMY)
	Player_SetRelationship(g_playerYuan, g_playerSong, R_ENEMY)
	-- In this particular case, we also want shared LOS
	World_EnableSharedLineOfSight(g_playerMongol, g_playerYuan, true)
	World_EnableSharedLineOfSight(g_playerYuan, g_playerMongol, true)
	
	--
	-- The AI neutral holder player
	--
	Setup_SetPlayerName(g_playerNeutral, Loc_GetString("$11179233"))
	Player_SetCurrentAge(g_playerNeutral, AGE_IMPERIAL)
	Player_SetMaximumAge(g_playerNeutral, AGE_IMPERIAL)
	-- Relationship to player
	Player_SetRelationship(g_playerMongol, g_playerNeutral, R_ALLY)
	Player_SetRelationship(g_playerNeutral, g_playerMongol, R_ALLY)
	-- Enemy also needs to consider this player an ally, so they don't attack neutral units
	Player_SetRelationship(g_playerSong, g_playerNeutral, R_ALLY)
	-- In this particular case, we also want shared LOS
	World_EnableSharedLineOfSight(g_playerMongol, g_playerNeutral, true)
	World_EnableSharedLineOfSight(g_playerNeutral, g_playerMongol, true)
	
	AI_Enable(g_playerNeutral, false)
	
	-- Ally the allies
	Player_SetRelationship(g_playerNeutral, g_playerYuan, R_ALLY)
	Player_SetRelationship(g_playerYuan, g_playerNeutral, R_ALLY)
	
end

-- Setup other data
function Mission_SetupVariables()
	
	-- SGroups
	sg_player = SGroup_CreateIfNotFound("sg_player")
	sg_enemy = SGroup_CreateIfNotFound("sg_enemy")
	
	sg_intro_horsemen = SGroup_CreateIfNotFound("sg_intro_horsemen")
	sg_intro_troops = SGroup_CreateIfNotFound("sg_intro_troops")
	
	sg_song_superarchers = SGroup_CreateIfNotFound("sg_song_superarchers")
	
	sg_mongol_starting_army_1 = SGroup_CreateIfNotFound("sg_mongol_starting_army_1")
	sg_mongol_starting_army_2 = SGroup_CreateIfNotFound("sg_mongol_starting_army_2")
	
	sg_mongol_traders_south = SGroup_CreateIfNotFound("sg_mongol_traders_south")
	sg_mongol_traders_west = SGroup_CreateIfNotFound("sg_mongol_traders_west")
	sg_villagers_sheep = SGroup_CreateIfNotFound("sg_villagers_sheep")
	sg_villagers_wood = SGroup_CreateIfNotFound("sg_villagers_wood")
	
	eg_player_pastures = EGroup_CreateIfNotFound("eg_player_pastures")
	eg_silk_road_landmark = EGroup_CreateIfNotFound("eg_silk_road_landmark")

	sg_outro_cavalry = SGroup_CreateIfNotFound("sg_outro_cavalry")
	sg_outro_cheer = SGroup_CreateIfNotFound("sg_outro_cheer")
	sg_outro_ismail = SGroup_CreateIfNotFound("sg_outro_ismail")
	sg_outro_liu_zheng = SGroup_CreateIfNotFound("sg_outro_liu_zheng")

	-- List of all the players' Huihui Pao
	sg_huihuipao = SGroup_CreateIfNotFound("sg_huihuipao")
	
	-- EGroups
	eg_fancheng = EGroup_CreateIfNotFound("eg_fancheng")
	eg_fancheng_spiritway = EGroup_CreateIfNotFound("eg_fancheng_spiritway")
	eg_fancheng_barbican = EGroup_CreateIfNotFound("eg_fancheng_barbican")
	eg_fancheng_houses = EGroup_CreateIfNotFound("eg_fancheng_houses")
	eg_fancheng_walls = EGroup_CreateIfNotFound("eg_fancheng_walls")
	eg_xiangyang = EGroup_CreateIfNotFound("eg_xiangyang")
	eg_xiangyang_keep = EGroup_CreateIfNotFound("eg_xiangyang_keep")
	eg_xiangyang_walls = EGroup_CreateIfNotFound("eg_xiangyang_walls")
	eg_yuan_landmarks = EGroup_CreateIfNotFound("eg_yuan_landmarks")
	eg_twin_city_bridge = EGroup_CreateIfNotFound("eg_twin_city_bridge")
	eg_moat_bridges = EGroup_CreateIfNotFound("eg_moat_bridges")
	eg_bridge_1 = EGroup_CreateIfNotFound("eg_bridge_1")
	eg_bridge_2 = EGroup_CreateIfNotFound("eg_bridge_2")
	eg_bridge_3 = EGroup_CreateIfNotFound("eg_bridge_3")
	eg_allies_west = EGroup_CreateIfNotFound("eg_allies_west")
	eg_allies_south = EGroup_CreateIfNotFound("eg_allies_south")
	eg_allied_production_west = EGroup_CreateIfNotFound("eg_allied_production_west")
	eg_allied_production_south = EGroup_CreateIfNotFound("eg_allied_production_south")
	
	eg_player_gers = EGroup_CreateIfNotFound("eg_player_gers")
	
	-- Find all the towers and add them to the defences list
	Player_GetAll(g_playerSong)
	EGroup_Filter(eg_allentities, EBP.CHINESE.BUILDING_DEFENSE_TOWER_CHI, FILTER_KEEP)
	eg_song_defences = EGroup_CreateIfNotFound("eg_song_defences")
	EGroup_AddEGroup(eg_song_defences, eg_allentities)
	
	-- Set up the leaders as global variables
	g_leaderIsmail = Missionomatic_InitializeLeader({
		name = "$11179237",
		owner = g_playerMongol,
		neutralHolder = g_playerNeutral,
	})
	
	g_leaderLiuZheng = Missionomatic_InitializeLeader({
		name = "$11178725",
		owner = g_playerMongol,
		neutralHolder = g_playerNeutral,
	})
	
	-- Still don't want no Khans
	Player_SetStateModelBool(g_playerMongol, "khan_spawning_enabled", false)
	
	-- A list of the blueprints for buildings that will be replaced
	g_buildingReplacements = {}
	g_buildingReplacements["barracks"] = SBP.MONGOL.BUILDING_UNIT_INFANTRY_MOVING_MON
	g_buildingReplacements["archery_range"] = SBP.MONGOL.BUILDING_UNIT_RANGED_MOVING_MON
	g_buildingReplacements["stable"] = SBP.MONGOL.BUILDING_UNIT_CAVALRY_MOVING_MON
	g_buildingReplacements["siege_workshop"] = SBP.MONGOL.BUILDING_UNIT_SIEGE_MOVING_MON
	g_buildingReplacements["monastery"] = SBP.MONGOL.BUILDING_UNIT_RELIGIOUS_MOVING_MON
	g_buildingReplacements["trade_post"] = SBP.MONGOL.BUILDING_ECON_MARKET_MOVING_MON
	
	-- VO for the case where the player breaks the walls without filling in the bridges first
	g_missingBridgeVOPlayed = false
	
	g_countersiegeCount = 6
	g_lastBridgeHealth = { 0.0, 0.0, 0.0, }
	g_lastBridgeAssignment = { true, true, true, }
	g_siegeAttackAggro = {
		lastPos = nil,
		lastChecked = nil,
		timeLeft = 20,
		timeMax = 20,
	}
	g_sizeDefenderChunk = 20
	g_playerKillsByTower = 0
	
	-- Also, find the towers that are just around Fancheng
	eg_fancheng_towers = EGroup_CreateIfNotFound("eg_song_defences")
	for index = 1, g_countersiegeCount, 1 do
		local mrkName = "mkr_city_countersiege_"..tostring(index)
		local marker = Marker_FromName(mrkName, "")
		Player_GetAllEntitiesNearMarker(g_playerSong, eg_temp, marker, Marker_GetProximityRadiusOrDefault(marker, 80))
		EGroup_AddEGroup(eg_song_defences, eg_temp)
	end
	
	-- Markers for the defense of the inner city
	g_innerDefense = {
		mkr_inner_defense_1,
		mkr_inner_defense_2,
		mkr_inner_defense_3,
		mkr_inner_defense_4,
		mkr_inner_defense_5,
		mkr_inner_defense_6,
		mkr_inner_defense_7,
		mkr_inner_defense_8,
		mkr_inner_defense_9,
		mkr_inner_defense_10,
		mkr_inner_defense_11,
		mkr_inner_defense_12,
	}
	
	-- The list of groups of Song units trying to harass the Yuan
	g_songRaiderFrequency = 75
	g_songRaiderTargets = {
		mkr_yuan_camp_1,
		mkr_yuan_camp_3,
	}
	g_lastSpawnedRaidIdx = 0
	g_raidBalancer = 0
	g_allyCounts = Util_DifVar({60, 50, 45, 40})
	g_enemyCountWalls = Util_DifVar({6, 8, 12, 14})
	g_enemyCountGarrison = Util_DifVar({18, 26, 34, 40})
	-- Setup the raiding system
	Raiding_Init({
		player = g_playerSong,
		spawnLocations = {
			mkr_song_harass_1,
			mkr_song_harass_2,
		},
		despawnLocation = mkr_song_retreat,
		scoutTargets = {
			mkr_yuan_camp_1,
			mkr_yuan_camp_2,
			mkr_yuan_camp_3,
		},
		raiderComposition = {
			{ type = "scar_horseman", ratio = Util_DifVar({0.7, 0.7, 0.5, 0.4}), },
			{ type = "scar_knight", ratio = Util_DifVar({0.15, 0.15, 0.25, 0.3}), },
			{ type = "scar_firelancer", ratio = Util_DifVar({0.15, 0.15, 0.25, 0.3}), },
		},
		sendProbes = false,
		activeScouting = false,
		partyLimit = Util_DifVar({2, 2, 3, 4}),
		partySize = Util_DifVar({12, 12, 14, 18}),
		raidSpacing = 30,
		raidTiming = Util_DifVar({45, 45, 42, 40}),
		onIdle = function()
			Xiangyang1273_ManageRaiders(nil, {ignoreExclusions = true})
		end,
	})
	
	-- Objectives
	Xiangyang1273_InitObjectives_Phase1()
	Xiangyang1273_InitObjectives_Phase2()
	Xiangyang1273_InitObjectives_Phase3()
	Xiangyang1273_InitObjectivesSecondary()
	
end

function Mission_SetRestrictions()	-- set up any restrictions (i.e. locking out units, etc) in here

	-- Make sure all fortifications actually shoot, for both players
	-- Player
	Player_GetAll(g_playerMongol)
	EGroup_Filter(eg_allentities, EBP.MONGOL.BUILDING_DEFENSE_OUTPOST_MON, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.MONGOL.UPGRADE_OUTPOST_CANNON_MON)
	-- Enemy
	Player_GetAll(g_playerSong)
	EGroup_Filter(eg_allentities, EBP.CHINESE.BUILDING_DEFENSE_OUTPOST_CHI, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.CHINESE.UPGRADE_OUTPOST_HANDCANNONSLITS_CHI)
	
	-- Upgrade all relevant units
	PlayerUpgrades_Auto(g_playerMongol, false)
	PlayerUpgrades_Auto(g_playerSong, true)
	PlayerUpgrades_Auto(g_playerYuan, true)
	
	Player_CompleteUpgrade(g_playerMongol, UPG.MONGOL.UPGRADE_ORTOO_ALL_UNITS_MON)
	Player_CompleteUpgrade(g_playerMongol, UPG.MONGOL.UPGRADE_RAID_BOUNTY_IMPROVED_MON)
	Player_CompleteUpgrade(g_playerMongol, UPG.MONGOL.UPGRADE_RAID_STONE_BOUNTY_IMPROVED_MON)
	Player_CompleteUpgrade(g_playerMongol, UPG.MONGOL.UPGRADE_TRADER_SILKROAD_STONE_IMPROVED_MON)
	Player_CompleteUpgrade(g_playerMongol, UPG.MONGOL.UPGRADE_SCOUT_KHAN_VISION_IMPROVED_MON)
	--[[
	local gruntWorkBP = BP_GetUpgradeBlueprint("upgrade_grunt_work")
	if (Player_HasUpgrade(g_playerMongol, gruntWorkBP) == false) then
		Player_CompleteUpgrade(g_playerMongol, gruntWorkBP)
	end
	]]
	-- The player should have plenty of resources at their disposal
	Player_SetResource(g_playerMongol, RT_Food, 2000)
	Player_SetResource(g_playerMongol, RT_Wood, 1000)
	Player_SetResource(g_playerMongol, RT_Gold, 1200)
	Player_SetResource(g_playerMongol, RT_Stone, 0)
	
	-- Lock all the gates
	eg_songGates = EGroup_CreateIfNotFound("eg_songGates")
	Player_GetAllEntitiesNearMarker(g_playerSong, eg_songGates, mkr_gates)
	EGroup_Filter(eg_songGates, EBP.CHINESE.BUILDING_DEFENSE_WALL_GATE_CHI, FILTER_KEEP)
	print("Count gates (LOCK): "..tostring(EGroup_Count(eg_songGates)))
	Missionomatic_SetGateLock(eg_songGates, true)
	
	-- Lock the one allied gate to block traders
	eg_trader_gate = EGroup_CreateIfNotFound("eg_trader_gate")
	Player_GetAllEntitiesNearMarker(g_playerYuan, eg_trader_gate, mkr_yuan_camp_2)
	EGroup_Filter(eg_trader_gate, EBP.CHINESE.BUILDING_DEFENSE_PALISADE_GATE_CHI, FILTER_KEEP)
	print("Count ALLY gates (LOCK): "..tostring(EGroup_Count(eg_trader_gate)))
	Missionomatic_SetGateLock(eg_trader_gate, true)
	
	Xiangyang_BoostDefences()

	--CMP TRADERS: Spawn the landmark here so that it's available when the traders spawn and need a home market
	Util_CreateEntities(g_playerMongol, eg_silk_road_landmark, EBP.MONGOL.BUILDING_WONDER_AGE2_KARAKORUM_MON, mkr_base_karakorum, 1)
end

function Mission_Preset()	-- any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)
	
	-- Enable player colours
	PlayerColour_Enable()
	
	Game_SetPlayerSlotColour(g_playerMongol, 1)
    Game_SetPlayerUISlotColour(g_playerMongol, 1)
	
    Game_SetPlayerSlotColour(g_playerSong, 2)
    Game_SetPlayerUISlotColour(g_playerSong, 2)
	
    Game_SetPlayerSlotColour(g_playerYuan, 3)
    Game_SetPlayerUISlotColour(g_playerYuan, 3)
	
    Game_SetPlayerSlotColour(g_playerNeutral, 1)
    Game_SetPlayerUISlotColour(g_playerNeutral, 1)
	
	-- Make sure the Mongol player can use their scout falcon
	Player_SetStateModelBool(g_playerMongol, "district_spec_scout_falcon_ability_mon", true)

	-- The player has explored everything because they've been here for years
	FOW_PlayerExploreAll(g_playerMongol)
	FOW_RevealAll()
	Rule_AddOneShot(Xiangyang1273_Unreveal, 0.125)
	
	-- The enemy sees everything, because they're cornered and we don't want to think about their FOW
	FOW_PlayerRevealAll(g_playerSong)
	
	-- Also boost the speed and construction rate of the otherwise annoyingly slow Traders
	-- They're important for the objectives, but it shouldn't feel like a grind
	local traderSpeedBoost = Modifier_Create(MAT_EntityType, "speed_maximum_modifier", MUT_Multiplication, false, 2, EBP.MONGOL.UNIT_TRADE_CART_MON)
	Modifier_ApplyToPlayer(traderSpeedBoost, g_playerMongol, 0)
	Modify_EntityBuildTime(g_playerMongol, EBP.MONGOL.UNIT_TRADE_CART_MON, 0.5)
	
	-- Add whatever rules
	Rule_AddInterval(Xiangyang1273_UpgradeBridges, 1)
	Rule_AddInterval(Xiangyang1273_WatchForMissingStone, 1)
	Rule_AddGlobalEvent(Xiangyang1273_WatchFalcons, GE_AbilityExecuted)
	Rule_AddGlobalEvent(Xiangyang1273_OnConstructionComplete, GE_ConstructionComplete)
	Rule_AddGlobalEvent(Xiangyang1273_OnSquadBuilt, GE_BuildItemComplete)
	Rule_AddGlobalEvent(Xiangyang1273_OnEntityKilled, GE_EntityKilled)
	Rule_AddGlobalEvent(Xiangyang1273_OnSquadKilled, GE_SquadKilled)

	Rule_AddGlobalEvent(Xiangyang1273_OnDamageReceived, GE_DamageReceived)	
	Rule_AddEventFilter_EntityPlayerOwner(Xiangyang1273_OnDamageReceived, FC_Attacker, FO_AND, { g_playerMongol }, { })
	Rule_AddEventFilter_EntityPlayerOwner(Xiangyang1273_OnDamageReceived, FC_Victim, FO_AND, { g_playerSong }, { })
	Rule_AddEventFilter_EntityBlueprint(Xiangyang1273_OnDamageReceived, FC_Victim, FO_AND, { "stone_wall", "stole_wall_tower", "stone_gate" }, { })
	
	-- Audio considerations
	Music_LockIntensity(MUSIC_TENSE_COMBAT, 20, MUSIC_TENSE, 5)
	
	-- Deconstruct the buildings that need deconstructing
	EGroup_SetTargetingType(eg_moat_bridges, Targeting_Manual)
	g_highestMoatHealth = 0.1
	EGroup_SetAvgHealth(eg_moat_bridges, g_highestMoatHealth)
	
	-- The bridge needs to be invulnerable, because it keeps getting hit by cannons due to hitbox issues
	Modify_ReceivedDamage(eg_twin_city_bridge, 0.0)
	
	-- Spawn player buildings -- this is because placing them through editor does not allow them to move!

	--Util_CreateEntities(g_playerMongol, eg_temp, EBP.MONGOL.BUILDING_TOWN_CENTER_CAPITAL_MON, mkr_base_tc, 1)
	Util_CreateEntities(g_playerMongol, eg_temp, EBP.MONGOL.BUILDING_UNIT_INFANTRY_MON, mkr_base_barracks, 1)
	Util_CreateEntities(g_playerMongol, eg_temp, EBP.MONGOL.BUILDING_UNIT_RANGED_MON, mkr_base_archery, 1)
	Util_CreateEntities(g_playerMongol, eg_temp, EBP.MONGOL.BUILDING_UNIT_CAVALRY_MON, mkr_base_stable_1, 1)
	Util_CreateEntities(g_playerMongol, eg_temp, EBP.MONGOL.BUILDING_UNIT_CAVALRY_MON, mkr_base_stable_2, 1)
	Util_CreateEntities(g_playerMongol, eg_temp, EBP.MONGOL.BUILDING_WONDER_AGE1_KURULTAI_MON, mkr_base_kurultai, 1)
	Util_CreateEntities(g_playerMongol, eg_temp, EBP.MONGOL.BUILDING_WONDER_AGE3_STUPA_MON, mkr_base_stupa, 1)
	--Util_CreateEntities(g_playerMongol, eg_temp, EBP.MONGOL.BUILDING_HOUSE_MON, mkr_base_house_1, 1)
	--Util_CreateEntities(g_playerMongol, eg_temp, EBP.MONGOL.BUILDING_HOUSE_MON, mkr_base_house_2, 1)
	Util_CreateEntities(g_playerMongol, eg_player_pastures, EBP.MONGOL.BUILDING_PASTURE_MON, mkr_base_pasture_1, 1)
	Util_CreateEntities(g_playerMongol, eg_player_pastures, EBP.MONGOL.BUILDING_PASTURE_MON, mkr_base_pasture_2, 1)
	Util_CreateEntities(g_playerMongol, eg_temp, EBP.MONGOL.BUILDING_TECH_UNIT_RANGED_MON, mkr_base_arsenal, 1)
	Util_CreateEntities(g_playerMongol, eg_temp, EBP.MONGOL.BUILDING_TECH_UNIT_INFANTRY_MON, mkr_base_smithy, 1)
	
	-- For buildings that don't settle nicely into place, do this
	local buildingsToSpawn = {
		{ bp = SBP.MONGOL.BUILDING_TOWN_CENTER_CAPITAL_MOVING_MON, mkr = mkr_base_tc, },
		--{ bp = SBP.MONGOL.BUILDING_UNIT_INFANTRY_MOVING_MON, mkr = mkr_base_barracks, },
		--{ bp = SBP.MONGOL.BUILDING_UNIT_RANGED_MOVING_MON, mkr = mkr_base_archery, },
		--{ bp = SBP.MONGOL.BUILDING_UNIT_CAVALRY_MOVING_MON, mkr = mkr_base_stable_1, },
		--{ bp = SBP.MONGOL.BUILDING_UNIT_CAVALRY_MOVING_MON, mkr = mkr_base_stable_2, },
		--{ bp = SBP.MONGOL.BUILDING_WONDER_AGE1_KURULTAI_MOVING_MON, mkr = mkr_base_kurultai, },
		--{ bp = SBP.MONGOL.BUILDING_WONDER_AGE2_KARAKORUM_MOVING_MON, mkr = mkr_base_karakorum, },
		--{ bp = SBP.MONGOL.BUILDING_WONDER_AGE3_STUPA_MOVING_MON, mkr = mkr_base_stupa, },
		{ bp = SBP.MONGOL.BUILDING_HOUSE_MOVING_MON, mkr = mkr_base_house_1, },
		{ bp = SBP.MONGOL.BUILDING_HOUSE_MOVING_MON, mkr = mkr_base_house_2, },
		--{ bp = SBP.MONGOL.BUILDING_PASTURE_MOVING_MON, mkr = mkr_base_pasture_1, },
		--{ bp = SBP.MONGOL.BUILDING_PASTURE_MOVING_MON, mkr = mkr_base_pasture_2, },
		--{ bp = SBP.MONGOL.BUILDING_TECH_UNIT_RANGED_MOVING_MON, mkr = mkr_base_arsenal, },
		--{ bp = SBP.MONGOL.BUILDING_TECH_UNIT_INFANTRY_MOVING_MON, mkr = mkr_base_smithy, },
	}
	
	for index, building in pairs(buildingsToSpawn) do
		SGroup_Clear(sg_temp)
		UnitEntry_DeploySquads(g_playerMongol, sg_temp, { sbp = building.bp, numSquads = 1}, building.mkr)
		local abilityName = string.gsub(BP_GetName(building.bp), "moving_", "")
		Cmd_Ability(sg_temp, BP_GetAbilityBlueprint("unpack_"..abilityName), Marker_GetPosition(building.mkr))
	end
	
	-- Spawn garrisons
	SpawnGarrisonsIntoEGroup(eg_xiangyang_keep, g_playerSong, "scar_archer", 15)
	
	-- Make sure Mongol infantry can repair the bridges to full health
	Player_GetAll(g_playerMongol)
	SGroup_Filter(sg_allsquads, "infantry", FILTER_KEEP)
	SGroup_AddAbility(sg_allsquads, BP_GetAbilityBlueprint("infantry_repair"))
	SGroup_AddAbility(g_leaderIsmail.sgroup, BP_GetAbilityBlueprint("infantry_repair"))
	
	-- Make the sheep rally to the villagers
	EGroup_SetRallyPoint(eg_player_pastures, mkr_yuan_camp_2_villagers_a)
	
	AssignVillagersToWood(sg_villagers_wood)
	
	-- Move the units
	SGroup_SetAvgHealth(sg_intro_horsemen, 0.25)
	Cmd_FormationMove(sg_intro_horsemen, mkr_intro_dest, false)
	
	Player_GetAllEntitiesNearMarker(g_playerSong, eg_fancheng_walls, mkr_city_inclusion_1_walls)
	EGroup_Filter(eg_fancheng_walls, {
			EBP.CHINESE.BUILDING_DEFENSE_WALL_CHI,
			EBP.CHINESE.BUILDING_DEFENSE_WALL_GATE_CHI,
			EBP.CHINESE.BUILDING_DEFENSE_WALL_BASTION_CHI,
		}, FILTER_KEEP)
	Rule_AddEGroupEvent(Xiangyang1273_ListenForWallDestruction, eg_fancheng_walls, GE_EntityKilled)
	
	Player_GetAllEntitiesNearMarker(g_playerSong, eg_xiangyang_walls, mkr_city_inclusion_2_walls)
	EGroup_Filter(eg_xiangyang_walls, {
			EBP.CHINESE.BUILDING_DEFENSE_WALL_CHI,
			EBP.CHINESE.BUILDING_DEFENSE_WALL_GATE_CHI,
			EBP.CHINESE.BUILDING_DEFENSE_WALL_BASTION_CHI,
		}, FILTER_KEEP)
	Rule_AddEGroupEvent(Xiangyang1273_ListenForWallDestruction, eg_xiangyang_walls, GE_EntityKilled)
	
	-- Compile the list of superarchers
	for index = 1, 9, 1 do
		local moduleName = "SongSiegeDefence"..tostring(index)
		local module = MissionOMatic_FindModule(moduleName)
		if module ~= nil then
			SGroup_AddGroup(sg_song_superarchers, module.sgroup)
		end
	end
	
	--CMP TRADERS: Order the traders to trade; they have already been spawned
	-- Their home market defaults to the Silk Road landmark, which begins as a packed Mongol structure
	-- The landmark is referenced using this EGroup: eg_silk_road_landmark
	LocalCommand_SquadEntity(g_playerMongol, sg_mongol_traders_west, SCMD_Trade, eg_market_1, false)
	LocalCommand_SquadEntity(g_playerMongol, sg_mongol_traders_south, SCMD_Trade, eg_market_2, false)
	
	-- Achievement tracking for Achievement #20 - Boom Boom Pao - Don't lose any HuiHui Pao
	huihuiPaoDestroyed = false
	Rule_AddGlobalEvent(Achievement_CheckHuiHuiPaoDestroyed, GE_SquadKilled)
	
end

-- This is triggered after the intro, just as control is passed to the player
function Mission_Start()	
	
	print("Mission Start with difficulty "..Game_GetSPDifficulty())
	
	-- Update with the real, non-cinematic modifiers
	if scartype(g_excessRangeModifiers) == ST_TABLE then
		for index, modifier in pairs(g_excessRangeModifiers) do
			Modifier_Remove(modifier)
		end
	end
	
	local modRange = Modifier_Create(MAT_Weapon, WM_RANGE, MUT_Multiplication, false, 1.7, hardpointCannon)
	local function _ApplyFinalTowerRange(gid, idx, eid)
		if Entity_IsValid(Entity_GetID(eid)) then
			Modifier_ApplyToEntity(modRange, eid, 0)
		end
	end
	
	-- Find all the towers
	Player_GetAll(g_playerSong)
	EGroup_Filter(eg_allentities, EBP.CHINESE.BUILDING_DEFENSE_TOWER_CHI, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_TOWER_CANNON)
	EGroup_ForEach(eg_allentities, _ApplyFinalTowerRange)
	
	AssignVillagersToSheep(sg_villagers_sheep)
	
	MissionTutorial_Init()
	
	-- start the opening objectives (if you're using ObjectiveTable style objectives)
	Objective_Start(OBJ_Prepare)
	
	-- Delay this by a minute, to prevent sensory overload
	if UI_IsXboxControllerUI() then
		Rule_AddOneShot(Xiangyang1273_DelayedHint_Xbox, 60)
	else
		Rule_AddOneShot(Xiangyang1273_DelayedHint, 60)
	end
	
end

