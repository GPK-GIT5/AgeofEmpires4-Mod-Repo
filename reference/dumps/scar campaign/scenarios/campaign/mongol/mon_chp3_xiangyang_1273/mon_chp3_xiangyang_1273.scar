--? Achievement tracking for Achievement #20 - Boom Boom Pao - Don't lose any HuiHui Pao
function Achievement_CheckHuiHuiPaoDestroyed(context)
	
	-- Check if squad is valid
	if Squad_IsValid(Squad_GetID(context.victim)) then
		
		-- Check if destroyed HuiHuiPao belongs to local player
		if World_OwnsSquad(context.victim) == false then
			local owner = Squad_GetPlayerOwner(context.victim)
			if owner == g_playerMongol and Squad_GetBlueprint(context.victim) == BP_GetSquadBlueprint("unit_great_trebuchet_cmp_mon") then
				huihuiPaoDestroyed = true
				Rule_RemoveMe()
			end
		end
	end
end
