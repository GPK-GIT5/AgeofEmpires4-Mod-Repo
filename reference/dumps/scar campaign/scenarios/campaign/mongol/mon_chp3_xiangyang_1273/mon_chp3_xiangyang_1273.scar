--? @shortdesc Watches for the construction of HuihuiPao
function Xiangyang1273_OnConstructionComplete(context)
	
	local owner = Entity_GetPlayerOwner(context.entity)
	if owner == g_playerMongol and Entity_GetBlueprint(context.entity) == BP_GetEntityBlueprint("unit_great_trebuchet_cmp_mon") then
		-- Increment the objective if necessary
		if Objective_IsComplete(SOBJ_BuildTrebuchet) == false then
			Objective_Complete(SOBJ_BuildTrebuchet)
		end
		-- Add the Huihuipao to the list - we want to track them all to make sure the enemy responds to them appropriately
		SGroup_Add(sg_huihuipao, Entity_GetSquad(context.entity))
	end
	
end

--? @shortdesc Gives the Gruntwork ability to new infantry squads
function Xiangyang1273_OnSquadBuilt(context)
	
	local itemOwner = Squad_GetPlayerOwner(context.spawnedSquad)
	if itemOwner == g_playerMongol and Squad_IsOfType(context.spawnedSquad, "infantry") == true then
		Squad_AddAbility(context.spawnedSquad, BP_GetAbilityBlueprint("infantry_repair"))
	end
	
end

--? @shortdesc Watches for the spawning of a Falcon
function Xiangyang1273_WatchFalcons(context, data)

	if context.ability == BP_GetAbilityBlueprint("leader_falcon_sight") then
		-- Complete the objective, if it's in the right spot
		local distFromTrigger1 = Util_GetDistance(mkr_trigger_falcon_1, context.executer)
		local distFromTrigger2 = Util_GetDistance(mkr_trigger_falcon_2, context.executer)
		local closestDistance = math.min(distFromTrigger1, distFromTrigger2)
		-- This doesn't quite line up with AE data but better reflects how it looks in-game? Hm
		local falconSightRadius = 150
		if Objective_IsComplete(SOBJ_OptUseFalcon) == false and closestDistance <= falconSightRadius then
			Objective_Complete(SOBJ_OptUseFalcon)
		end
		
	end
	
end

--? @shortdesc Ensures bridges become walkable when fixed
function Xiangyang1273_UpgradeBridges(context)
	
	local _UpgradeFinishedBridge = function(gid, idx, eid)
		if Entity_IsValid(Entity_GetID(eid)) and Entity_HasBlueprint(eid, BP_GetEntityBlueprint("bridge_dirt_long_unfinished")) then
			if Entity_GetHealthPercentage(eid) >= 1.0 then
				Entity_ConvertBlueprint(eid, BP_GetEntityBlueprint("bridge_dirt_long"))
				-- These bridges should not be selectable once completed - otherwise they eat various commands
				EGroup_Single(eg_temp, eid)
				EGroup_SetSelectable(eg_temp, false)
				-- Set them invulnerable because their destruction isn't handled
				Entity_SetInvulnerable(eid, true, -1)
			end
		end
	end
	EGroup_ForEach(eg_moat_bridges, _UpgradeFinishedBridge)
	
end

--? @shortdesc Creates a Mongol parade for the outro cinematic; cleans up for the Outro
function Xiangyang1273_OutroParade()
	
	-- destroy some off camera buildings that can cause problems if still around (outposts, etc.)
	if EGroup_Count(eg_outro_destroy) > 0 then
		EGroup_DestroyAllEntities(eg_outro_destroy)
	end	

	-- switch ownership on the palisade (so outro units can go through the gates) 
	if EGroup_Count(eg_xiangyang_palisade) > 0 then
		EGroup_SetPlayerOwner(eg_xiangyang_palisade, g_playerMongol)
	end	
	
	-- swtich ownership on most of the buildings in the inner area (if still there) so as not to draw fire from outro troops
	if EGroup_Count(eg_outro_switch) > 0 then
		EGroup_SetPlayerOwner(eg_outro_switch, g_playerMongol)
	end	
	
	local cheering = {
		{sbp = SBP.MONGOL.UNIT_ISMAIL_CMP_MON, spawn = mkr_outro_cheer_ismail, sgroup = sg_outro_ismail},
		--{type = "scar_spearman", numSquads = 4, spawn = mkr_outro_cheer_1},
		{type = "scar_manatarms", numSquads = 4, spawn = mkr_outro_cheer_2},
		{type = "scar_spearman", numSquads = 4, spawn = mkr_outro_cheer_3},
		{type = "scar_manatarms", numSquads = 4, spawn = mkr_outro_cheer_4},
		{type = "scar_spearman", numSquads = 4, spawn = mkr_outro_cheer_5},
		{type = "scar_manatarms", numSquads = 4, spawn = mkr_outro_cheer_6},
		{type = "scar_spearman", numSquads = 4, spawn = mkr_outro_cheer_7},
		--{type = "scar_manatarms", numSquads = 4, spawn = mkr_outro_cheer_8},
	}
	
	
	UnitEntry_DeploySquads(g_playerMongol, sg_outro_cheer, cheering)
	
	local cavalry = {
		{sbp = SBP.MONGOL.UNIT_LIU_ZHENG_CMP_MON, spawn = mkr_outro_cav_1, destination = mkr_outro_rte_final, sgroup = sg_outro_liu_zheng},
		{type = "scar_knight", numSquads = 2, spawn = mkr_outro_cav_2, destination = mkr_outro_rte_final},
		{type = "scar_knight", numSquads = 2, spawn = mkr_outro_cav_3, destination = mkr_outro_rte_final},
		{type = "scar_knight", numSquads = 2, spawn = mkr_outro_cav_4, destination = mkr_outro_rte_final},
		{type = "scar_horseman", numSquads = 2, spawn = mkr_outro_cav_5, destination = mkr_outro_rte_final},
		{type = "scar_horseman", numSquads = 2, spawn = mkr_outro_cav_6, destination = mkr_outro_rte_final},
		{type = "scar_horseman", numSquads = 2, spawn = mkr_outro_cav_7, destination = mkr_outro_rte_final},
	}
	
	local parade = {
		mkr_outro_rte_1,
		mkr_outro_rte_2,
		mkr_outro_rte_3,
	}
	
	Util_UnitParade(parade, cavalry, sg_outro_cavalry , nil, g_playerMongol)
	
	SGroup_EnableCheering(sg_outro_cheer, true)	
	
	SGroup_EnableLeaderCrown(sg_outro_ismail, false)
	SGroup_EnableLeaderCrown(sg_outro_liu_zheng, false)	
end

function Xiangyang_BoostDefences()
	
	print("MODIFIERS - Start Game")
	-- Clear those intro modifiers
	if scartype(g_allIntroModifiers) == ST_TABLE then
		for index, modifier in pairs(g_allIntroModifiers) do
			Modifier_Remove(modifier)
		end
	end
	
	g_receivedDamageMods = {}
	
	-- Artificially boost tower ranges - LOS needed too or it won't work!
	--local modHealth = Modifier_Create(MAT_Entity, "health_maximum_modifier", MUT_Multiplication, false, 15, "")
	local modHealth = Modifier_Create(MAT_Entity, "received_damage_modifier", MUT_Multiplication, false, 0.06, "")
	local modSight = Modifier_Create(MAT_Entity, "sight_radius_modifier", MUT_Multiplication, false, 10, "")
	local modFireThresh = Modifier_Create(MAT_Entity, "on_fire_threshold_modifier", MUT_Multiplication, false, 15, "")
	local modFireArmour = Modifier_Create(MAT_Entity, "on_fire_damage_per_tick_modifier", MUT_Multiplication, false, 0, "")
	local function _BoostDefences(gid, idx, eid)
		if Entity_IsValid(Entity_GetID(eid)) then
			table.insert(g_receivedDamageMods, Modifier_ApplyToEntity(modHealth, eid, 0))
			Modifier_ApplyToEntity(modSight, eid, 0)
			Modifier_ApplyToEntity(modFireThresh, eid, 0)
			Modifier_ApplyToEntity(modFireArmour, eid, 0)
		end
	end
	
	Player_GetAll(g_playerSong)
	EGroup_Filter(eg_allentities, {
			EBP.CHINESE.BUILDING_DEFENSE_TOWER_CHI,
			EBP.CHINESE.BUILDING_DEFENSE_WALL_CHI,
			EBP.CHINESE.BUILDING_DEFENSE_WALL_GATE_CHI,
			EBP.CHINESE.BUILDING_DEFENSE_WALL_BASTION_CHI,
			EBP.CHINESE.BUILDING_DEFENSE_KEEP_CHI,
		}, FILTER_KEEP)
	EGroup_ForEach(eg_allentities, _BoostDefences)
	
	-- Towers get a different health boost, or an armour boost instead of a health boost
	local modHealthTowers = Modifier_Create(MAT_Entity, "received_damage_modifier", MUT_Multiplication, false, 0.5, "")
	local modArmor = Modifier_Create(MAT_Entity, "armor_modifier", MUT_Multiplication, false, 50, "")
	local modSight = Modifier_Create(MAT_Entity, "sight_radius_modifier", MUT_Multiplication, false, 2.5, "")
	-- Also boost tower attack
	local hardpointCannon = "hardpoint_03"
	local modDamage = Modifier_Create(MAT_Weapon, WM_DAMAGE, MUT_Multiplication, false, 5, hardpointCannon)
	local modReload = Modifier_Create(MAT_Weapon, WM_RELOAD, MUT_Multiplication, false, 0.1, hardpointCannon)
	
	g_excessRangeModifiers = {}
	local modRange = Modifier_Create(MAT_Weapon, WM_RANGE, MUT_Multiplication, false, 2.0, hardpointCannon)
	
	local function _BoostTowers(gid, idx, eid)
		if Entity_IsValid(Entity_GetID(eid)) then
			table.insert(g_receivedDamageMods, Modifier_ApplyToEntity(modHealthTowers, eid, 0))
			Modifier_ApplyToEntity(modArmor, eid, 0)
			Modifier_ApplyToEntity(modSight, eid, 0)
			Modifier_ApplyToEntity(modDamage, eid, 0)
			Modifier_ApplyToEntity(modReload, eid, 0)
			table.insert(g_excessRangeModifiers, Modifier_ApplyToEntity(modRange, eid, 0))
		end
	end
	
	-- Find all the towers
	Player_GetAll(g_playerSong)
	EGroup_Filter(eg_allentities, EBP.CHINESE.BUILDING_DEFENSE_TOWER_CHI, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_TOWER_CANNON)
	EGroup_ForEach(eg_allentities, _BoostTowers)
	
	-- Keeps are special - they have a ton of hardpoints and different upgrades
	Player_GetAll(g_playerSong)
	EGroup_Filter(eg_allentities, EBP.CHINESE.BUILDING_DEFENSE_KEEP_CHI, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_KEEP_ARROWSLITS)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_KEEP_CANNON)
	local xiangyangKeep = EGroup_GetEntityAt(eg_allentities, 1)
	-- Apply the same health and armor mods
	Modifier_ApplyToEntity(modHealthTowers, xiangyangKeep, 0)
	Modifier_ApplyToEntity(modArmor, xiangyangKeep, 0)
	-- But hardpoints... yeah. This modifies all Handcannon and Garrison Arrow Slit hardpoints, but doesn't touch the other ones, like boiling oil
	local relevantHardpoints = {
		"hardpoint_01",
		"hardpoint_02",
		"hardpoint_03",
		"hardpoint_05",
		"hardpoint_06",
		"hardpoint_07",
		"hardpoint_08",
		"hardpoint_09",
		"hardpoint_10",
		"hardpoint_11",
		"hardpoint_12",
		"hardpoint_13",
		"hardpoint_14",
		"hardpoint_15",
		"hardpoint_16",
		"hardpoint_17",
		"hardpoint_18",
		"hardpoint_19",
		"hardpoint_20",
		"hardpoint_21",
		"hardpoint_22",
	}
	-- Formatting is weird, so just use the list
	for index, hardpoint in pairs(relevantHardpoints) do
		local keepDamage = Modifier_Create(MAT_Weapon, WM_DAMAGE, MUT_Multiplication, false, 8, hardpoint)
		Modifier_ApplyToEntity(keepDamage, xiangyangKeep, 0)
		
		local keepCooldown = Modifier_Create(MAT_Weapon, WM_COOLDOWN, MUT_Multiplication, false, 0.1, hardpoint)
		Modifier_ApplyToEntity(keepCooldown, xiangyangKeep, 0)
		
		local keepReload = Modifier_Create(MAT_Weapon, WM_RELOAD, MUT_Multiplication, false, 0.1, hardpoint)
		Modifier_ApplyToEntity(keepReload, xiangyangKeep, 0)
		
		local keepRange = Modifier_Create(MAT_Weapon, WM_RANGE, MUT_Multiplication, false, 2.4, hardpoint)
		Modifier_ApplyToEntity(keepRange, xiangyangKeep, 0)
		
	end
	
end

--? @shortdesc Removes the received damage mods from towers and walls
function Xiangyang1273_RemoveHealthMods()
	
	if scartype(g_receivedDamageMods) == ST_TABLE then
		for index, modifier in pairs(g_receivedDamageMods) do
			Modifier_Remove(modifier)
		end
		g_receivedDamageMods = {}
	end
	
end

--? @shortdesc Manages raiders during the mission, checking phase to determing how they'll move
function Xiangyang1273_ManageRaiders(context, data)

	if scartype(data) ~= ST_TABLE then
		data = { ignoreExclusions = false }
	end
	
	if Game_GetSPDifficulty() < GD_NORMAL then
		print("Managing raiders on STORY")
	end
	
	--
	-- RAIDING PHASE
	--
	if Objective_IsComplete(SOBJ_EnterCity) == false and (Game_GetSPDifficulty() >= GD_NORMAL or Objective_IsFailed(OBJ_AlliedTradePartners) == false) then
		
		local nextRaidTarget = nil
			
		-- Do we need a new party? If so, send it first to one of the base positions, to try to ensure even spawning
		-- Otherwise too many of them spawn on the left side of the map
		if Raiding_CountParties() < g_raidSystem.partyLimit then
			
			-- Choose a geographic target, but make sure we don't repeat more than twice in a row
			local thisRaidIdx = g_lastSpawnedRaidIdx or World_GetRand(1, 2)
			if thisRaidIdx == 1 then
				thisRaidIdx = 2
			else
				thisRaidIdx = 1
			end
			-- Take that target and make a raid
			nextRaidTarget = g_songRaiderTargets[thisRaidIdx]
			
			print(string.format("XIANGYANG: Requesting raid on %s (%s, %s, %s)", nextRaidTarget, thisRaidIdx, g_lastSpawnedRaidIdx, g_raidBalancer))
			
			-- We want to know if we've added a new raid party; we should prune the existing ones to be sure the only ones left are valid
			Raiding_PruneParties()
			-- Then count the valid ones
			local raidersBefore = Raiding_CountParties()
			-- Log the actual raid target
			Raiding_TriggerRaid(nextRaidTarget, data.ignoreExclusions, nil, true)
			-- Now see if there's a new valid raid party - if so, we spawned something. Log the index!
			if raidersBefore < Raiding_CountParties() then
				g_lastSpawnedRaidIdx = thisRaidIdx
				print(string.format("XIANGYANG: New raiders detected, they spawned from targeting %s, index switched to %s", nextRaidTarget, g_lastSpawnedRaidIdx))
			end
			
			-- And increase the raid size for next time
			if g_raidSystem.partySize < Util_DifVar({20, 20, 24, 28}) then
				g_raidSystem.partySize = g_raidSystem.partySize + 1
			end
			
		-- Otherwise, if we're NOT on story mode, designate a unit target
		elseif Game_GetSPDifficulty() >= GD_NORMAL then
			
			Player_GetAll(g_playerMongol)
			local randomTargets = SGroup_CreateUnique("")
			-- Pick out economic and siege targets
			SGroup_Filter(sg_allsquads, "scar_trade_cart", FILTER_REMOVE, randomTargets)
			SGroup_Filter(sg_allsquads, "scar_villager", FILTER_REMOVE, randomTargets)
			SGroup_Filter(sg_allsquads, SBP.MONGOL.UNIT_ISMAIL_CMP_MON, FILTER_REMOVE, randomTargets)
			SGroup_Filter(sg_allsquads, SBP.MONGOL.UNIT_GREAT_TREBUCHET_CMP_MON, FILTER_REMOVE, randomTargets)
			-- If any of these are valid, pick one
			if SGroup_Count(randomTargets) > 0 then
				nextRaidTarget = SGroup_CreateUnique("sg_ph1_raid_target")
				local targetSquad = SGroup_GetRandomSpawnedSquad(randomTargets)
				SGroup_Add(nextRaidTarget, targetSquad)
				print(string.format("XIANGYANG: Unit raid on SQUAD %s, count %s", targetSquad, SGroup_Count(nextRaidTarget)))
			-- Otherwise, pick the player's default camp location
			else
				nextRaidTarget = mkr_yuan_camp_2
				print(string.format("XIANGYANG: Defaulting to raid on mkr_yuan_camp_2, printed: %s", nextRaidTarget))
			end
			
			-- If there's anything in there, raid it!
			if nextRaidTarget ~= nil and g_stopSpawingRaiders ~= true then
				Raiding_TriggerRaid(nextRaidTarget, data.ignoreExclusions)
				-- And increase the raid size for next time
				if g_raidSystem.partySize < Util_DifVar({20, 20, 24, 28}) then
					g_raidSystem.partySize = g_raidSystem.partySize + 1
				end
			end
			
		end
			
	--
	-- END OF RAIDING
	--
	elseif Raiding_CountParties() <= 0 then
		
		print("XIANGYANG: Phase 3, stopping raids")
		-- If we've gotten here, then we're out of raiders and the player has finished the raiding part of the mission
		-- Get rid of the rule
		Rule_RemoveMe()
		
		--
		-- END OF NEW PARTIES
		-- This occurs if the player has finised the fist part of the mission but there are still raiders running around
		--
	elseif Game_GetSPDifficulty() >= GD_NORMAL then
		-- Send any remaining raiders on a foolish raid to attack the player
		if Raiding_CountIdleRaiders() > 0 then
			Raiding_TriggerRaid(mkr_yuan_camp_2, data.ignoreExclusions)
		end
		-- And ensure no more raiders are spawned!
		Raiding_SetPartyLimit(0)
	
	else
		-- If we're on Story Mode, tell everybody to retreat
		for index, army in pairs(g_raidSystem.raidParties) do
			if SGroup_CountSpawned(army.sgroup) > 0 then
				local closestExit = Util_GetClosestMarker(army.sgroup, { mkr_song_harass_1, mkr_song_harass_2, })
				RovingArmy_SetTarget(army, closestExit)
				Raiding_RemoveParty(army)
				army.onCompleteFunction = Xiangyang1273_VanishRaiders
			end
		end
		-- And ensure no more raiders are spawned!
		Raiding_SetPartyLimit(0)
	end
	
end

--? @shortdesc A function invoked when raiders become blocked
function Xiangyang1273_VanishRaiders(module)
	
	if module == nil or module.sgroup == nil then
		print(string.format("WARNING (Lumen): blocked raider module %s doesn't have an sgroup?", module))
		return	
	end
	
	print("LUMEN: Raiders blocked, arrived at exit, despawning")
	SGroup_DestroyAllSquads(module.sgroup)
	
end

--? @shortdesc Replaces Mongol buildings that are destroyed
function Xiangyang1273_OnEntityKilled(context)

	local killer = context.killer
	local victim = context.victim
	local victimOwner = context.victimOwner
	local victimBP = Entity_GetBlueprint(victim)
	
	if context.victimOwner == g_playerSong then
		
		if scartype(killer) == ST_ENTITY and Entity_IsOfType(killer, "tower") then
			g_playerKillsByTower = g_playerKillsByTower + 1
			
			if g_playerKillsByTower == 8 then
				Raiding_UpdateComposition({
						{ type = "scar_horseman", ratio = Util_DifVar({0.7, 0.7, 0.5, 0.4}), },
						{ type = "scar_knight", ratio = Util_DifVar({0.15, 0.15, 0.25, 0.3}), },
						{ type = "scar_firelancer", ratio = Util_DifVar({0.15, 0.15, 0.25, 0.3}), },
						{ type = "scar_mangonel", ratio = 0.05, },
					})
			elseif g_playerKillsByTower == 16 then
				Raiding_UpdateComposition({
						{ type = "scar_horseman", ratio = Util_DifVar({0.7, 0.7, 0.5, 0.4}), },
						{ type = "scar_knight", ratio = Util_DifVar({0.15, 0.15, 0.25, 0.3}), },
						{ type = "scar_firelancer", ratio = Util_DifVar({0.15, 0.15, 0.25, 0.3}), },
						{ type = "scar_mangonel", ratio = 0.1, },
					})
			end
			
		end
		
		if g_missingBridgeVOPlayed == false then
			local songWallKilled = Entity_IsOfType(victim, "wall")
			if songWallKilled == false then
				return
			end
			
			local moatNotFilled = Objective_IsComplete(SOBJ_MoatHintpoints) == false
			if moatNotFilled == false then
				return
			end
			
			Util_StartIntel(EVENTS.MissingBridge)
			g_missingBridgeVOPlayed = true
		end 
	end
end

--? @shortdesc Watches for damage taken by Song defences
function Xiangyang1273_OnDamageReceived(context, data)
	
	local attacker = context.attacker
	local victim = context.victim
	
	if attacker ~= nil and Util_GetPlayerOwner(attacker) == g_playerMongol and Util_GetPlayerOwner(victim) == g_playerSong then
		if Entity_HasBlueprint(victim, {"stone_wall", "stone_wall_tower", "stone_gate"}) == true then
			if g_siegeAttackAggro.timeLeft <= (g_siegeAttackAggro.timeMax / 2) then
				g_siegeAttackAggro.lastPos = Util_GetPosition(victim)
				g_siegeAttackAggro.timeLeft = g_siegeAttackAggro.timeMax
			end
		end
	end
	
end

--? @shortdesc Global fail condition
function Xiangyang1273_IsFailed()
	
	Player_GetAll(g_playerMongol)
	
	SGroup_Filter(sg_allsquads, "gaia", FILTER_REMOVE)
	if SGroup_Count(sg_allsquads) <= 1 then
		return true
	end
	 
	SGroup_Filter(sg_allsquads, "scar_villager", FILTER_KEEP)
	EGroup_Filter(eg_allentities, "town_center", FILTER_KEEP)
	return (SGroup_Count(sg_allsquads) + EGroup_Count(eg_allentities)) <= 0
	
end

--? @shortdesc Plays a positive stinger when a section of wall from an EGroup is destroyed
function Xiangyang1273_ListenForWallDestruction(context, data)
	
	if g_wallDestructionStung ~= true then
		g_wallDestructionStung = true
		Music_PlayStinger(MUS_STING_POSITIVE)
	end
	Rule_RemoveMe()
	
end

--? @shortdesc Watch for aging up to notify player of fancy new stuff
function Xiangyang1273_WatchForMissingStone(context, data)
	
	local playerStone = Player_GetResource(g_playerMongol, RT_Stone)
	g_stonePeak = g_stonePeak or playerStone
	if playerStone > g_stonePeak then
		g_stonePeak = playerStone
	end
	
	-- If they're 3 minutes into the game and still haven't peaked at 1000 stone or more, give them a hint
	if World_GetGameTime() > 180 then
		Rule_RemoveMe()
		
		-- Count traders
		Player_GetAll(g_playerMongol)
		SGroup_Filter(sg_allsquads, {SBP.MONGOL.UNIT_TRADE_CART_MON, SBP.MONGOL.UNIT_TRADE_CART_DOUBLE_MON}, FILTER_KEEP)
		local traderCount = SGroup_Count(sg_allsquads)
		
		if g_stonePeak < 1000 or traderCount < 14 then
			print(string.format("XIANGYANG: Not enough stone (%s) or traders (%s); offering hint!", g_stonePeak, traderCount))
			
			if UI_IsXboxControllerUI() then
				Xiangyang1273_SetupSilkRoadHint_Xbox()
			else
				Xiangyang1273_SetupSilkRoadHint()
			end
		else
			print("XIANGYANG: Enough stone; no hint needed!")
		end
	end
end

function Xiangyang1273_SetupSilkRoadHint_Xbox()
	
	MissionOMatic_HintOnHover_Xbox(
		Xiangyang1273_TriggerSilkRoadHint_Xbox,
		"Once the Silk Road bonus is maxed out, building more Traders will increase your stone income",
		"$11200377",
		"campaign_mon_chp3_xiangyang_silkroad")
end

function Xiangyang1273_SetupSilkRoadHint()
	
	MissionOMatic_HintOnHover(
		Xiangyang1273_TriggerSilkRoadHint,
		"Once the Silk Road bonus is maxed out, building more Traders will increase your stone income",
		"$11200377",
		"campaign_mon_chp3_xiangyang_silkroad")
end

--? @shortdesc Takes care of things when the twin city bridge is constructed, regardless of whether the objectives are ready for it
function Xiangyang1273_HandlePrematureBridgeConstruction(context, data)
	
	-- Bridge immunity can be activated if the bridge is totally destroyed OR if 15 seconds have elapsed since it was burnt
	if g_bridgeImmunityOn ~= true and (EGroup_GetAvgHealth(eg_twin_city_bridge) <= 0.01 or (World_GetGameTime() - g_bridgeBurnTime) > 15) then
		print("FALL OF XIANGYANG: Applying Twin City Fire Immunity")
		
		-- Make sure that bridge doesn't catch fire
		Entity_StopFire(EGroup_GetSpawnedEntityAt(eg_twin_city_bridge, 1))
		Modify_OnFireDamagePerTick(eg_twin_city_bridge, MUT_Multiplication, 0.0)
		
		-- Also unlock the bridge gates so that when it's rebuilt, units can come through
		eg_songGates = EGroup_CreateIfNotFound("eg_songGates")
		Player_GetAllEntitiesNearMarker(g_playerSong, eg_songGates, mkr_twin_city_gates)
		EGroup_Filter(eg_songGates, EBP.CHINESE.BUILDING_DEFENSE_WALL_GATE_CHI, FILTER_KEEP)
		print("Count gates (UNLOCK): "..tostring(EGroup_Count(eg_songGates)))
		Missionomatic_SetGateLock(eg_songGates, false)
		
		g_bridgeImmunityOn = true
		
	end
	
	-- Did bridge construction START early? This should happen no matter what
	if EGroup_GetAvgHealth(eg_twin_city_bridge) > 0.01 and g_bridgeImmunityOn == true then
		
		-- Remove this rule - at this point it's no longer needed
		if Rule_Exists(Xiangyang1273_MonitorInnerDefense) then
			Rule_Remove(Xiangyang1273_MonitorInnerDefense)
			print("FALL OF XIANGYANG: Removed inner defense monitoring")
		end
		
		-- If the player hasn't killed off the defenders of Fancheng that rule was managing, they should attack the bridge area
		if scartype(sg_fancheng_last_stand) == ST_SGROUP and SGroup_Count(sg_fancheng_last_stand) > 0 then
			Cmd_FormationAttackMove(sg_fancheng_last_stand, mkr_last_stand_bridge)
		end
	end
	
	-- Is bridge construction FINISHED early?
	if EGroup_GetAvgHealth(eg_twin_city_bridge) >= 1.0 then
		
		-- Make the bridge invulnerable - it's annoying for it to keep getting destroyed
		EGroup_SetAvgHealth(eg_twin_city_bridge, 1.0)
		
		print("FALL OF XIANGYANG: Fixed twin city bridge health")
		
		Rule_RemoveMe()
	end
	
end

--? @shortdesc Warns the player if they're getting shot at from the towers after sending their units on the shortest route to the allies
function Xiangyang1273_OnSquadKilled(context, data)
	
	local victim = context.victim
	if World_OwnsSquad(victim) == false and Squad_GetPlayerOwner(victim) == g_playerMongol then
		
		local gameTime = World_GetGameTime()
		g_lastKilledSquad = g_lastKilledSquad or gameTime
		if gameTime - g_lastKilledSquad < 20 then
			return
		end
		g_lastKilledSquad = gameTime
		
		if Util_GetDistance(victim, mkr_waypoint_warning_east) < Marker_GetProximityRadiusOrDefault(mkr_waypoint_warning_east, 45) then
			print(string.format("Player %s killed in EAST warning zone!", victim))
			--UI_CreateEventCue("$11201472", Loc_Empty(), "high_priority_negative", "", "sfx_ui_event_queue_campaign_high_priority_negative_play", ECV_Title)
			
		elseif Util_GetDistance(victim, mkr_waypoint_warning_west) < Marker_GetProximityRadiusOrDefault(mkr_waypoint_warning_west, 45) then
			print(string.format("Player %s killed in WEST warning zone!", victim))
			--UI_CreateEventCue("$11201472", Loc_Empty(), "high_priority_negative", "", "sfx_ui_event_queue_campaign_high_priority_negative_play", ECV_Title)
			
		end
		
	end
end

