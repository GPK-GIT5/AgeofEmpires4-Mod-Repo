--? @shortdesc Watches for construction of walls
function Lumen_OnConstructionStart(context)
	
	local buildingOwner = Entity_GetPlayerOwner(context.entity)
	if buildingOwner == g_playerMongol and Entity_IsOfType(context.entity, "wall") then
		-- Update the wall position, so the AI can hunt it
		g_lastWallPos = Util_GetPosition(context.entity)
		
		if Objective_IsComplete(SOBJ_Walls) == true then
			Rule_RemoveGlobalEvent(Lumen_OnConstructionStart)
		end
		
	end
	
end

--? @shortdesc Launches a single sally from the north of the map that will attempt to make their way south and must be stopped
--? @args NIL
--? @result VOID
function Lumen_LaunchSongSally()

	-- Create a new army
	g_moduleReturnSally = RovingArmy_Init({		
		descriptor = "SongReturnSally",
		type = "RovingArmy",
		player = g_playerSong,
		spawnLocation = mkr_song_north_1,
			
		units = {
			{ type = "scar_manatarms", numSquads = Util_DifVar({15, 15, 20, 25}), },
			{ type = "scar_spearman", numSquads = Util_DifVar({12, 12, 16, 20}), },
			{ type = "scar_archer", numSquads = Util_DifVar({10, 10, 12, 14}), },
			{ type = "scar_crossbowman", numSquads = Util_DifVar({8, 8, 10, 12}), },
			{ type = "scar_repeater_crossbow", numSquads = Util_DifVar({6, 6, 9, 12}), },
			{ type = "scar_grenadier", numSquads = Util_DifVar({2, 2, 6, 10}), },
		},
		
		idleTimeOverride = 0,
		targetingType = ARMY_TARGETING_DISCARD,
		targets = {
			mkr_neutral_lumen,
			mkr_neutral_bohekou,
			mkr_song_south_2,
		},
	})
	
	-- This global variable says we're now allowed to check conditions on the sally
	g_songReliefActive = false
	g_songSallyActive = true
	
	-- We also want to track what units are already near the southern marker
	-- If there are any, we should ignore them for the first minute or so of the objective
	g_songSallyTime = World_GetGameTime()
	sg_songSallyExemption = SGroup_CreateIfNotFound("sg_songSallyExemption")
	Player_GetAllSquadsNearMarker(g_playerMongol, sg_songSallyExemption, mkr_song_south_2, 45)
	
end

--? @shortdesc Checks for Song units near the exit point and deletes them, incrementing the relevant counters
--? @args NIL
--? @result VOID
function Lumen_CheckForExit()
	
	if g_songReliefActive == true or g_songSallyActive == true then
		
		local testRange = 10
		local exitSGroup = SGroup_CreateUnique("exiting")
		
		if g_songReliefActive == true then
			
			-- EXIT 1
			local exitMarker1 = mkr_song_north_2
			local markerGroup1 = SGroup_CreateUnique()
			Player_GetAllSquadsNearMarker(g_playerSong, markerGroup1, exitMarker1, Marker_GetProximityRadiusOrDefault(exitMarker1, 0) + testRange)
			
			-- EXIT 2
			local exitMarker2 = mkr_song_north_1
			local markerGroup2 = SGroup_CreateUnique()
			Player_GetAllSquadsNearMarker(g_playerSong, markerGroup2, exitMarker2, Marker_GetProximityRadiusOrDefault(exitMarker2, 0) + testRange)
			
			-- Combine them all
			SGroup_AddGroup(exitSGroup, markerGroup1)
			SGroup_AddGroup(exitSGroup, markerGroup2)
			
			-- Now see if there's anything to remove
			local numSquads = SGroup_Count(exitSGroup)
			if numSquads > 0 then
				
				SGroup_DestroyAllSquads(exitSGroup)
				
				-- Also increase the doomsday progress bar by however many just escaped
				if Objective_IsStarted(SOBJ_BlockadeFailure) then
					SOBJ_BlockadeFailure.counterCurrent = SOBJ_BlockadeFailure.counterCurrent + numSquads
					
					-- Account for the case where this actually might also end the mission
					if SOBJ_BlockadeFailure.counterCurrent >= SOBJ_BlockadeFailure.counterMax then
						g_failureThresholdCrossed = true
					end
				end
				
			end
		end
		
		if g_songSallyActive == true then
			
			-- EXIT
			local exitSGroup = SGroup_CreateUnique()
			Player_GetAllSquadsNearMarker(g_playerSong, exitSGroup, mkr_song_south_2, Marker_GetProximityRadiusOrDefault(mkr_song_south_2, 0) + testRange)
	
			-- If the objective just started, we want to ignore any units who were near the exit when it started
			if (World_GetGameTime() - g_songSallyTime) < 60 then
				SGroup_RemoveGroup(exitSGroup, sg_songSallyExemption)
			end
			
			-- Now see if there's anything to remove
			local numSquads = SGroup_Count(exitSGroup)
			if numSquads > 0 then
			
				SGroup_DestroyAllSquads(exitSGroup)
				
				-- Also increase the doomsday progress bar by however many just escaped
				if Objective_IsStarted(SOBJ_FinalChance) then
					SOBJ_FinalChance.counterCurrent = SOBJ_FinalChance.counterCurrent + numSquads-- Account for the case where this actually might also end the mission
					if SOBJ_FinalChance.counterCurrent >= SOBJ_FinalChance.counterMax then
						g_finaleThresholdCrossed = true
					end
				end
				
			end
			
		end
		
		SGroup_Destroy(exitSGroup)
	end
	
end

--? @shortdesc Starts the intro camera behaviour for the player units
--? @args NIL
--? @result VOID
function Lumen_StartIntro()
	
	Cmd_FormationMove(g_leaderLiuZheng.sgroup, mkr_mongol_dest_1, false)
	Cmd_FormationMove(sg_intro_mongols_2, mkr_mongol_dest_2, false)
	Cmd_FormationMove(sg_intro_mongols_3, mkr_mongol_dest_3, false)
	Cmd_FormationMove(sg_intro_mongols_4, mkr_mongol_dest_4, false)
	Cmd_FormationMove(sg_intro_mongols_5, mkr_mongol_dest_5, false)
	
end

--? @shortdesc Starts the outro
--? @args NIL
--? @result VOID
function Lumen_StartOutro()
	
	-- Delete any leftover units
	Player_GetAll(g_playerMongol)
	SGroup_DestroyAllSquads(sg_allsquads)

	-- Also many any enemy buildings player-owned
	Player_GetAll(g_playerSong)
	SGroup_DestroyAllSquads(sg_allsquads)
	EGroup_SetPlayerOwner(eg_allentities, g_playerMongol)
	
	-- Where will the units run?
	local retreatRoute = {
		mkr_outro_song_retreat_0,
		mkr_outro_song_retreat_1,
		mkr_outro_song_retreat_2,
		mkr_outro_song_retreat_3,
		mkr_outro_song_retreat_4,
	}
	
	-- Deploy the Song retreat
	UnitEntry_DeploySquads(g_playerSong,
	sg_outro_song,
	{
		{ sbp = BP_GetSquadBlueprint("unit_spearman_4_chi"), numSquads = 30, spawn = mkr_outro_song_runners_infantry, },
		--{ sbp = BP_GetSquadBlueprint("unit_horseman_4_chi"), numSquads = 12, spawn = mkr_outro_song_runners_cavalry, },
	},
	mkr_outro_song_runners_infantry)
	MissionOMatic_SGroupCommandDelayed(sg_outro_song, retreatRoute, false, 0.25)
	SGroup_SetAvgHealth(sg_outro_song, 0.15)

	
	-- Deploy the outro units
	UnitEntry_DeploySquads(g_playerMongol,
	sg_outro_troops,
	{
		{ sbp = BP_GetSquadBlueprint("unit_liu_zheng_cmp_mon"), numSquads = 1, sgroup = sg_outro_liu_zheng, spawn = mkr_outro_liuzheng, },
		{ sbp = BP_GetSquadBlueprint("unit_spearman_4_chi"), numSquads = 30, sgroup = sg_outro_yuan_infantry, spawn = mkr_outro_spearmen, },
		{ sbp = BP_GetSquadBlueprint("unit_archer_4_chi"), numSquads = 16, sgroup = sg_outro_yuan_archers, spawn = mkr_outro_archers, },
		--{ sbp = BP_GetSquadBlueprint("unit_knight_4_mon"), numSquads = 8, sgroup = sg_outro_yuan_cavalry, spawn = mkr_outro_cavalry, },
		{ sbp = BP_GetSquadBlueprint("unit_horsearcher_4_mon"), numSquads = 12, sgroup = sg_outro_yuan_cavalry, spawn = mkr_outro_cavalry, },
	},
	mkr_outro_spearmen)
	Cmd_HoldPosition(sg_outro_liu_zheng)
	Cmd_HoldPosition(sg_outro_yuan_infantry)
	Cmd_HoldPosition(sg_outro_yuan_archers)
	
	-- to avoid the Mangudai doubling back we only give them a couple points along the route
	Cmd_FormationAttackMove(sg_outro_yuan_cavalry, mkr_outro_song_retreat_2, false, false)
	Cmd_FormationAttackMove(sg_outro_yuan_cavalry, mkr_outro_song_retreat_4, true, true)
	
	-- Buff them up so they can shoot
	local hardpointName = "hardpoint_01"
	local modRange = Modifier_Create(MAT_Weapon, WM_RANGE, MUT_Multiplication, false, 2, hardpointName)
	local function _BoostArchers(gid, idx, sid)
		local entity = Squad_GetFirstEntity(sid)
		Modifier_ApplyToEntity(modRange, entity, 0)
	end
	SGroup_ForEach(sg_outro_yuan_archers, _BoostArchers)
	
end

--? @shortdesc Compiles a valid path along Lumen Shan's various channels
function Lumen_GetValidPath()
	
	-- What's the full potential list?
	local spawnListTotal = {
		mkr_song_south_1,
		mkr_song_south_2,
		mkr_song_south_3,
	}
	local thisNode = spawnListTotal[World_GetRand(1, #spawnListTotal)]
	local finalPath = { thisNode, }
	
	-- Figure out where to go
	while thisNode ~= nil do
		
		-- What are the possible next nodes?
		local nextNodes = g_validPathStructures[Marker_GetName(thisNode)]
		local validatedNodes = {}
		
		-- Make sure we don't take something already in the path
		for idx = 1, #nextNodes, 1 do
			if Table_Contains(finalPath, nextNodes[idx]) == false then
				table.insert(validatedNodes, nextNodes[idx])
			end
		end
		
		-- DEBUG USAGE
		if #validatedNodes <= 0 then
			local debugLine = ""
			for index, marker in pairs(finalPath) do
				debugLine = debugLine..Marker_GetName(marker).." > "
			end
		end
		
		-- Pick a validated node
		local nextNode = validatedNodes[World_GetRand(1, #validatedNodes)]
		table.insert(finalPath, nextNode)
		
		-- Set things up for next time
		if nextNode ~= mkr_song_north_1 and nextNode ~= mkr_song_north_2 then
			thisNode = nextNode
		else
			thisNode = nil
		end
	end
	
	return finalPath
	
end

--? @shortdesc Spawns resource pickups for off-track areas
function Lumen_SpawnPickups()

	local pickupTypes = {
		"gold",
		"food",
		"wood",
		"food",
		"gold",
		"gold",
		"wood",
		"gold",
		"food",
		"gold",
		"gold",
	}
	
	-- Create the pickups
	for i = 1, #pickupTypes do
		local marker = Marker_FromName("mkr_pickup_"..tostring(i), "")
		Missionomatic_SpawnPickup(marker, pickupTypes[i])
	end
	
end

--? @shortdesc Replenishes the key Mongol structures the player might need, if they're missing
function Lumen_ResendMongolBuildings(context, data)
	
	eg_tech_infantry = EGroup_CreateIfNotFound("eg_tech_infantry")
	eg_tech_ranged = EGroup_CreateIfNotFound("eg_tech_ranged")
	eg_tech_stables = EGroup_CreateIfNotFound("eg_tech_stables")
	
	EGroup_Clear(eg_tech_infantry)
	EGroup_Clear(eg_tech_ranged)
	EGroup_Clear(eg_tech_stables)
	
	eg_temp = Player_GetAllEntities(g_playerMongol)
	
	EGroup_Filter(eg_temp, {EBP.MONGOL.BUILDING_UNIT_INFANTRY_MON, EBP.MONGOL.BUILDING_UNIT_INFANTRY_MOVING_MON}, FILTER_REMOVE, eg_tech_infantry)
	EGroup_Filter(eg_temp, {EBP.MONGOL.BUILDING_UNIT_RANGED_MON, EBP.MONGOL.BUILDING_UNIT_RANGED_MOVING_MON}, FILTER_REMOVE, eg_tech_ranged)
	EGroup_Filter(eg_temp, {EBP.MONGOL.BUILDING_UNIT_CAVALRY_MON, EBP.MONGOL.BUILDING_UNIT_CAVALRY_MOVING_MON}, FILTER_REMOVE, eg_tech_stables)
	
	local unitList = {}
	
	if EGroup_Count(eg_tech_infantry) <= 0 then
		table.insert(unitList, { sbp = SBP.MONGOL.BUILDING_UNIT_INFANTRY_MOVING_MON, numSquads = 1, spawn = mkr_mongol_reinforce_7, })
	end
	if EGroup_Count(eg_tech_ranged) <= 0 then
		table.insert(unitList, { sbp = SBP.MONGOL.BUILDING_UNIT_RANGED_MOVING_MON, numSquads = 1, spawn = mkr_mongol_reinforce_8, })
	end
	if EGroup_Count(eg_tech_stables) <= 0 then
		table.insert(unitList, { sbp = SBP.MONGOL.BUILDING_UNIT_CAVALRY_MOVING_MON, numSquads = 2, spawn = mkr_mongol_reinforce_4, })
	end
	
	-- If we're missing any of these, spawn!
	if #unitList > 0 then
		local reinforcementSGroup = SGroup_CreateUnique("reinforcements")
		UnitEntry_DeploySquads(g_playerMongol,
			reinforcementSGroup,
			unitList,
			mkr_mongol_start_1)
		EventCues_CallToAction("$11178742", CTA_CELEBRATE, nil, nil, reinforcementSGroup)
	end
	
end

--? @shortdesc Checks for entity destruction
function Lumen_OnEntityKilled(context, data)

	local killer = context.killer
	local victim = context.victim
	local victimOwner = context.victimOwner
	
	if scartype(victimOwner) == ST_PLAYER and victimOwner == g_playerMongol and Entity_HasBlueprint(victim, "wall") then

		-- Only do this every 20 seconds at most
		g_lastWarning = g_lastWarning or 0
		local currentGameTime = World_GetGameTime()
		if (currentGameTime - g_lastWarning) > 20 then
			--Sound_Play2D(MUS_STING_NEGATIVE)
			g_lastWarning = currentGameTime
		end
		
		if (currentGameTime - g_lastWarning) > 6 then
			-- Where was the entity killed?
			local deathPos = Util_GetPosition(victim)
			-- Issue a raid against anything near the point of death
			Player_GetAllSquadsNearMarker(g_playerSong, sg_temp, deathPos, 30)
			if SGroup_Count(sg_temp) > 0 then
				Sound_PlayWallaEngageOnSGroup(sg_temp)
				g_lastWarning = currentGameTime
			end
		end
		
	end
	
end

--? @shortdesc Watches for a bridge encounter and then launches a hint
function Lumen_WatchForBridges(context, data)
	
	if Misc_IsEGroupOnScreen(eg_bridges_wood, 100, ANY) == true then
		
		eg_bridges_onscreen = EGroup_CreateIfNotFound("eg_bridges_onscreen")
		EGroup_Clear(eg_bridges_onscreen)
		local _CheckOnscreen = function(gid, idx, eid)
			if Misc_IsEntityOnScreen(eid, 100) == true then
				EGroup_Add(eg_bridges_onscreen, eid)
			end
		end
		EGroup_ForEach(eg_bridges_wood, _CheckOnscreen)
		
		OBJ_HintBridge.targetBridge = EGroup_GetEntityAt(eg_bridges_onscreen, 1)
		Objective_Start(OBJ_HintBridge)
		
		MissionTutorial_AddHintToBrokenBridge()
		
		Rule_RemoveMe()
	end
	
end

--? @shortdesc Watches for idle enemy scouts and redirects them
function Lumen_WatchIdleScouts(context, data)
	
	Player_GetAll(g_playerSong)
	SGroup_Filter(sg_allsquads, "scar_scout", FILTER_KEEP)
	if SGroup_Count(sg_allsquads) <= 0 then
		return
	end
	
	-- Only bother if there are idle scouts
	if SGroup_IsIdle(sg_allsquads, ANY) == false then
		return
	end
	
	-- Make sure this exists
	if scartype(g_idleScoutAttempts) ~= ST_TABLE then
		g_idleScoutAttempts = {
			{sgroup = SGroup_CreateUnique("exit_north_1"), marker = mkr_song_north_1, },
			{sgroup = SGroup_CreateUnique("exit_north_2"), marker = mkr_song_north_2, },
			{sgroup = SGroup_CreateUnique("exit_south_1"), marker = mkr_song_south_1, },
			{sgroup = SGroup_CreateUnique("exit_south_2"), marker = mkr_song_south_2, },
			{sgroup = SGroup_CreateUnique("exit_south_3"), marker = mkr_song_south_3, },
		}
	end
	
	-- Find every idle scout and try to get them to despawn at an exit
	local _PuntIdleScout = function(gid, idx, sid)
		if Squad_IsIdle(sid) == false then
			return
		end
		
		local asigned = false
		for index, attempt in pairs(g_idleScoutAttempts) do
			if asigned == false and SGroup_ContainsSquad(attempt.sgroup, sid.SquadID, false) == false then
				SGroup_Single(sg_temp, sid)
				Cmd_MoveToAndDestroy(sg_temp, attempt.marker, false)
				SGroup_Add(attempt.sgroup, sid)
				asigned = true
			end
		end
		-- If it hasn't been assigned at all, that's because it is in every group
		-- Remove and try again next time
		if asigned == false then
			for index, attempt in pairs(g_idleScoutAttempts) do
				SGroup_Remove(attempt.sgroup, sid)
			end
		end
	end
	SGroup_ForEach(sg_allsquads, _PuntIdleScout)
	
end

--? @shortdesc Used to destroy or delete whatever should already have been deleted
function Lumen_CheatDeleteEnemies()
	
	-- Delete all units in these modules; the player should have killed these off
	local modulesToNuke = {
		"SongFortGarrison",
		"SongResist2",
		"SongResist3",
		"SongResist4",
		"SongResist5",
	}
	
	-- Now kill them all
	for index, moduleName in pairs(modulesToNuke) do
		local module = MissionOMatic_FindModule(moduleName)
		if module ~= nil and module.sgroup ~= nil then
			SGroup_DestroyAllSquads(module.sgroup)
		end
	end
	
	-- Also get rid of blocking entities the player would have destroyed
	local markersToSearch = {
		mkr_song_fort,
	}
	
	-- Now destroy them all
	for index, marker in pairs(markersToSearch) do
		EGroup_Clear(eg_temp)
		Player_GetAllEntitiesNearMarker(g_playerSong, eg_temp, marker, 60)
		if EGroup_Count(eg_temp) > 0 then
			EGroup_Kill(eg_temp)
		end
	end
end