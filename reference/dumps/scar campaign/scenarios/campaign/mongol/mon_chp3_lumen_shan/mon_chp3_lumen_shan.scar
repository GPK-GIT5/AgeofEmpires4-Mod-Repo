--
-- Lumen Shan 1260s
--
-- Mongol Chapter 3
--

-- We need to import this for anything to work. We don't need anything else
import("MissionOMatic/MissionOMatic.scar")
-- We need to import custom objective files
import("obj_lumen_phase1.scar")
import("obj_lumen_secondary.scar")
import("training_lumen.scar")

import("mon_chp3_lumen_shan_automated.scar")

-- Setup player data
function Mission_SetupPlayers()
	
	-- Get IDs for all players
	g_playerMongol = World_GetPlayerAt(1)
	g_playerSong = World_GetPlayerAt(2)
	g_playerChina = World_GetPlayerAt(3)
	g_playerNeutral = World_GetPlayerAt(4)

	-- The human player
	Setup_SetPlayerName(g_playerMongol, Loc_GetString("$11178722"))
	Player_SetCurrentAge(g_playerMongol, AGE_IMPERIAL)
	Player_SetMaximumAge(g_playerMongol, AGE_IMPERIAL)

	-- The main enemy AI player	
	Setup_SetPlayerName(g_playerSong, Loc_GetString("$11178723"))
	Player_SetCurrentAge(g_playerSong, AGE_IMPERIAL)
	Player_SetMaximumAge(g_playerSong, AGE_IMPERIAL)
	
	-- The main neutral AI player	
	Setup_SetPlayerName(g_playerChina, Loc_GetString("$11178724"))
	Player_SetCurrentAge(g_playerChina, AGE_CASTLE)
	Player_SetMaximumAge(g_playerChina, AGE_CASTLE)
	
	AI_Enable(g_playerNeutral, false)
	
	-- Player relationships
	Player_SetRelationship(g_playerMongol, g_playerSong, R_ENEMY)
	Player_SetRelationship(g_playerSong, g_playerMongol, R_ENEMY)
	
	-- The allied player
	Player_SetRelationship(g_playerMongol, g_playerChina, R_ALLY)
	Player_SetRelationship(g_playerChina, g_playerMongol, R_ALLY)
	World_EnableSharedLineOfSight(g_playerMongol, g_playerChina, false)
	
	Player_SetRelationship(g_playerChina, g_playerNeutral, R_ALLY)
	Player_SetRelationship(g_playerNeutral, g_playerChina, R_ALLY)
	
	Player_SetRelationship(g_playerChina, g_playerSong, R_NEUTRAL)
	Player_SetRelationship(g_playerSong, g_playerChina, R_NEUTRAL)

	-- The neutral leader-holder player
	Setup_SetPlayerName(g_playerNeutral, Loc_GetString("$11178722"))
	Player_SetCurrentAge(g_playerNeutral, AGE_CASTLE)
	Player_SetMaximumAge(g_playerNeutral, AGE_CASTLE)
	
	Player_SetRelationship(g_playerMongol, g_playerNeutral, R_ALLY)
	Player_SetRelationship(g_playerNeutral, g_playerMongol, R_ALLY)
	
	Player_SetRelationship(g_playerSong, g_playerNeutral, R_NEUTRAL)
	Player_SetRelationship(g_playerNeutral, g_playerSong, R_NEUTRAL)
	
	
end

-- Setup other data
function Mission_SetupVariables()
	
	Player_SetStateModelBool(g_playerMongol, "allow_mongol_stone_market", true)
	Player_GetStateModelBool(g_playerMongol, "allow_mongol_stone_market")
	
	-- SGroups
	sg_player = SGroup_CreateIfNotFound("sg_player")
	sg_enemy = SGroup_CreateIfNotFound("sg_enemy")
	
	sg_intro_mongols_1 = SGroup_CreateIfNotFound("sg_intro_mongols_1")
	sg_intro_mongols_2 = SGroup_CreateIfNotFound("sg_intro_mongols_2")
	sg_intro_mongols_3 = SGroup_CreateIfNotFound("sg_intro_mongols_3")
	sg_intro_mongols_4 = SGroup_CreateIfNotFound("sg_intro_mongols_4")
	sg_intro_mongols_5 = SGroup_CreateIfNotFound("sg_intro_mongols_5")
	
	sg_all_intro_mongols = SGroup_CreateIfNotFound("sg_all_intro_mongols")
	
	sg_mongols_with_camp = SGroup_CreateIfNotFound("sg_mongols_with_camp")
	sg_lumen_villagers_1 = SGroup_CreateIfNotFound("sg_lumen_villagers_1")
	sg_lumen_villagers_2 = SGroup_CreateIfNotFound("sg_lumen_villagers_2")
	
	sg_bohekou_villagers_1 = SGroup_CreateIfNotFound("sg_bohekou_villagers_1")
	sg_bohekou_villagers_2 = SGroup_CreateIfNotFound("sg_bohekou_villagers_2")
	sg_bohekou_troops = SGroup_CreateIfNotFound("sg_bohekou_troops")
	
	sg_outro_troops = SGroup_CreateIfNotFound("sg_outro_troops")
	sg_outro_song = SGroup_CreateIfNotFound("sg_outro_song")
	
	sg_outro_liu_zheng = SGroup_CreateIfNotFound("sg_outro_liu_zheng")
	sg_outro_yuan_archers = SGroup_CreateIfNotFound("sg_outro_yuan_archers")
	sg_outro_yuan_infantry = SGroup_CreateIfNotFound("sg_outro_yuan_infantry")
	sg_outro_yuan_cavalry = SGroup_CreateIfNotFound("sg_outro_yuan_cavalry")
	
	-- EGroup
	eg_song_fort_keep = EGroup_CreateIfNotFound("eg_song_fort_keep")
	eg_village_lumen = EGroup_CreateIfNotFound("eg_village_lumen")
	eg_village_bohekou = EGroup_CreateIfNotFound("eg_village_bohekou")
	eg_bridges_wood = EGroup_CreateIfNotFound("eg_bridges_wood")
	
	eg_settlement_1 = EGroup_CreateIfNotFound("eg_settlement_1")
	eg_settlement_2 = EGroup_CreateIfNotFound("eg_settlement_2")
	
	eg_player_walls = EGroup_CreateIfNotFound("eg_player_walls")
	
	-- Add some hintpoints to help orientation
	HintPoint_Add(eg_settlement_1, true, "$11178726", LOCATION_LABEL_HEIGHT)
	HintPoint_Add(eg_settlement_2, true, "$11178727", LOCATION_LABEL_HEIGHT)
	HintPoint_Add(mkr_neutral_lumen, true, "$11200085", LOCATION_LABEL_HEIGHT)
	HintPoint_Add(mkr_neutral_bohekou, true, "$11200086", LOCATION_LABEL_HEIGHT)
	
	-- Leader
	g_leaderLiuZheng = Missionomatic_InitializeLeader({
		name = "$11178725",
		owner = g_playerMongol,
		neutralHolder = g_playerNeutral,
		respawns = { mkr_leader_respawn_1 },
	})
	
	-- Setup the path verification system
	g_pathChecks = {
		west = {
			ID = 0,
			origin = Util_GetPosition(mkr_song_south_1),
			target = Util_GetPosition(mkr_song_north_1),
			blockDist = 9999999,
			length = nil,
			originalLength = nil,
			pathName = "lumen_west",
			fullyBlocked = false,
		},
		westAlt = {
			ID = 1,
			origin = Util_GetPosition(mkr_song_south_2),
			target = Util_GetPosition(mkr_song_north_1),
			blockDist = 9999999,
			length = nil,
			originalLength = nil,
			pathName = "lumen_westalt",
			fullyBlocked = false,
		},
		east = {
			ID = 2,
			origin = Util_GetPosition(mkr_song_south_3),
			target = Util_GetPosition(mkr_song_north_2),
			blockDist = 9999999,
			length = nil,
			originalLength = nil,
			pathName = "lumen_east",
			fullyBlocked = false,
		},
		eastAlt = {
			ID = 3,
			origin = Util_GetPosition(mkr_song_south_3),
			target = Util_GetPosition(mkr_song_north_1),
			blockDist = 9999999,
			length = nil,
			originalLength = nil,
			pathName = "lumen_eastalt",
			fullyBlocked = false,
		}
	}
	
	-- Setup the raiding system
	Raiding_Init({
		player = g_playerSong,
		spawnLocations = {
			mkr_song_south_2,
			mkr_song_south_3,
		},
		despawnLocation = mkr_song_south_2_despawn,
		scoutTargets = {
			mkr_song_north_1,
			mkr_song_north_2,
		},
		raiderComposition = {
			{ type = "scar_horseman", ratio = Util_DifVar({0.8, 0.8, 0.6, 0.4}), },
			{ type = "scar_knight", ratio = Util_DifVar({0.0, 0.0, 0.2, 0.3}), },
			{ type = "scar_firelancer", ratio = Util_DifVar({0.2, 0.2, 0.2, 0.3}), },
		},
		sendProbes = false,
		activeScouting = false,
		partyLimit = Util_DifVar({1, 1, 2, 3}),
		partySize = Util_DifVar({12, 12, 18, 24}),
		raidSpacing = 50,
		raidTiming = Util_DifVar({30, 30, 25, 20}),
		canBuildRams = false,
	})
	
	-- Variables
	g_lastWallPos = nil
	g_songHarassment = 0
	g_pathLengthWest = nil
	g_pathLengthEast = nil
	g_wallStingerCooldown = { current = 0, max = 30 }
	g_northernMarkers = {
		mkr_song_north_1,
		mkr_song_north_2,
	}
	g_southernMarkers = {
		{ marker = mkr_song_south_1, markerAlt = mkr_song_south_2, uses = 0 },
		{ marker = mkr_song_south_3, uses = 0 },
	}
	g_songAllExitMarkers = {
		mkr_song_north_1,
		mkr_song_north_2,
		mkr_song_south_1,
		mkr_song_south_2,
		mkr_song_south_3,
	}
	g_songPushComplete = false
	g_wallbreakerWaveCount = 8
	g_songAttackersPhase3 = {}
	g_wallbreakerNextIdx = World_GetRand(1, 2)
	g_westSideModulo = World_GetRand(0, 1)
	
	-- Start with a small timer to account for scouts that may be reaching the exit just as the player walls off
	g_escapeWarningTimer = 45
	g_escapeWarningCount = 0
	
	-- Objectives
	LumenShan_InitObjectives_Phase1()
	LumenShan_InitObjectives_Phase2()
	LumenShan_InitObjectives_Phase3()
	LumenShan_InitObjectives_Phase4()
	LumenShan_InitObjectivesSecondary()
end

function Mission_SetRestrictions()	-- set up any restrictions (i.e. locking out units, etc) in here

	-- The player shouldn't get any stone to start with
	Player_SetResource(g_playerMongol, RT_Food, 1000)
	Player_SetResource(g_playerMongol, RT_Wood, 800)
	Player_SetResource(g_playerMongol, RT_Gold, 800)
	Player_SetResource(g_playerMongol, RT_Stone, 0)
	
	-- We're setting neutral player resources to zero so they don't build units
	Player_SetResource(g_playerChina, RT_Food, 0)
	Player_SetResource(g_playerChina, RT_Wood, 0)
	Player_SetResource(g_playerChina, RT_Gold, 0)
	Player_SetResource(g_playerChina, RT_Stone, 0)
	
	-- The AI needs resources and popcap to build rams
	Player_SetResource(g_playerSong, RT_Wood, 50000)
	Player_SetResource(g_playerSong, RT_Gold, 50000)
	Player_SetPopCapOverride(g_playerSong, 1000)
	
	UI_SetPlayerDataContext(g_playerMongol, { PopulationCapOn = false })
	
	-- HIDE UNAVAILABLE ITEMS
	-- Non-Defensive Chinese Buildings
	Player_SetEntityProductionAvailability(g_playerMongol, EBP.CHINESE.BUILDING_LANDMARK_AGE1_GATEHOUSE_CONTROL_CHI, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(g_playerMongol, EBP.CHINESE.BUILDING_LANDMARK_AGE1_ACADEMY_CONTROL_CHI, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(g_playerMongol, EBP.CHINESE.BUILDING_LANDMARK_AGE2_CLOCKTOWER_CONTROL_CHI, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(g_playerMongol, EBP.CHINESE.BUILDING_LANDMARK_AGE2_PALACE_CONTROL_CHI, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(g_playerMongol, EBP.CHINESE.BUILDING_LANDMARK_AGE3_GREAT_WALL_CONTROL_CHI, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(g_playerMongol, EBP.CHINESE.BUILDING_LANDMARK_AGE3_SPIRIT_WAY_CONTROL_CHI, ITEM_REMOVED)
	
	-- Officials won't work, so we'll remove them
	Player_SetSquadProductionAvailability(g_playerMongol, SBP.CHINESE.UNIT_OFFICIAL_1_CHI, ITEM_REMOVED)
	Player_SetUpgradeAvailability(g_playerMongol, UPG.CHINESE.UPGRADE_IMPERIAL_EXAMINATIONS_CHI, ITEM_REMOVED)
	
	--No relics, remove tithe barn & pagoda
	Player_SetEntityProductionAvailability(g_playerMongol, EBP.CHINESE.BUILDING_DYNASTY_PAGODA_CONTROL_CHI, ITEM_REMOVED)
	Player_SetUpgradeAvailability(g_playerMongol, UPG.COMMON.UPGRADE_UNIT_RELIGIOUS_TITHE_BARN_4, ITEM_REMOVED)
	
	--No population limit, remove houses and villages
	Player_SetEntityProductionAvailability(g_playerMongol, EBP.CHINESE.BUILDING_HOUSE_CONTROL_CHI, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(g_playerMongol, EBP.CHINESE.BUILDING_DYNASTY_VILLAGE_CONTROL_CHI, ITEM_REMOVED)
	
	--No Dynasty Remove realted upgrades
	Player_SetUpgradeAvailability(g_playerMongol, UPG.CHINESE.UPGRADE_DYNASTY_ECON_BONUS_CHI, ITEM_REMOVED)
	
	-- Set tech based on difficulty and age
	PlayerUpgrades_Auto(g_playerMongol, false)
	PlayerUpgrades_Auto(g_playerMongol, false, {}, "chinese")
	PlayerUpgrades_Auto(g_playerSong, true)
	PlayerUpgrades_Auto(g_playerChina, false)
	PlayerUpgrades_Auto(g_playerNeutral, true)
	
	-- Complete these upgrades to make sure players can use these units
	Player_CompleteUpgrade(g_playerMongol, UPG.COMMON.UPGRADE_SIEGE_CHEMISTRY)
	Player_CompleteUpgrade(g_playerMongol, UPG.MONGOL.UPGRADE_SIEGE_CHEMISTRY_MON)
	
	Player_SetPopCapOverride(g_playerMongol, 160)
	
	-- Give the Song border towers stone
	EGroup_CompleteUpgrade(eg_songterritory, UPG.COMMON.UPGRADE_OUTPOST_STONE)
	EGroup_CompleteUpgrade(eg_songterritory, UPG.COMMON.UPGRADE_OUTPOST_CANNON)
	EGroup_SetInvulnerable(eg_songterritory, true)
	EGroup_SetTargetingType(eg_songterritory, Targeting_None)
	-- And the walls
	EGroup_SetInvulnerable(eg_song_walls, true)
	EGroup_SetTargetingType(eg_song_walls, Targeting_None)

end

function Mission_Preset()	-- any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)
	
	-- Enable player colours
	PlayerColour_Enable()
	
	Game_SetPlayerSlotColour(g_playerMongol, 1)
    Game_SetPlayerUISlotColour(g_playerMongol, 1)
	
    Game_SetPlayerSlotColour(g_playerSong, 2)
    Game_SetPlayerUISlotColour(g_playerSong, 2)
	
    Game_SetPlayerSlotColour(g_playerChina, 3)
    Game_SetPlayerUISlotColour(g_playerChina, 3)
	
    Game_SetPlayerSlotColour(g_playerNeutral, 1)
    Game_SetPlayerUISlotColour(g_playerNeutral, 1)
	
	-- Special rules for this scenario
	Rule_AddInterval(Lumen_CheckForExit, 1)
	Rule_AddGlobalEvent(Lumen_OnConstructionStart, GE_ConstructionStart)
	Rule_AddGlobalEvent(Lumen_OnEntityKilled, GE_EntityKilled)
	Rule_AddInterval(Lumen_WatchForBridges, 1)
	Rule_AddInterval(Lumen_WatchIdleScouts, 3)
	
	-- Audio considerations
	if Music_UnlockIntensity then
		Sound_SetForceMusic(false)
	else
		Sound_SetForceMusic(true)
	end
	
	Music_LockIntensity(MUSIC_RARE)
	
	-- Assign villagers to look alive
	AssignVillagersToFarms(sg_lumen_villagers_1)
	AssignVillagersToWood(sg_lumen_villagers_2)
	AssignVillagersToFarms(sg_bohekou_villagers_1)
	AssignVillagersToStone(sg_bohekou_villagers_2)
	
	-- Valid path structures
	g_validPathStructures = {
		mkr_song_south_1 = { mkr_song_path_a },
		mkr_song_south_2 = { mkr_song_path_a },
		mkr_song_south_3 = { mkr_song_path_b },
		mkr_song_path_a = { mkr_song_path_d },
		mkr_song_path_b = { mkr_song_path_c, mkr_song_path_e },
		mkr_song_path_c = { mkr_song_path_d, mkr_song_path_e },
		mkr_song_path_d = { mkr_song_path_c, mkr_song_path_f },
		mkr_song_path_e = { mkr_song_path_f, mkr_song_north_2 },
		mkr_song_path_f = { mkr_song_path_e, mkr_song_north_1 },
	}
	
	-- Set up AI cached paths between specific markers to aid AI pathfinding to
	-- detect and break through blocking walls.
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(g_playerSong, mkr_song_north_1, Util_GetPosition(mkr_song_south_2), 5.0)
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(g_playerSong, mkr_song_north_2, Util_GetPosition(mkr_song_south_2), 5.0)
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(g_playerSong, mkr_song_north_1_dupe1, Util_GetPosition(mkr_song_south_3), 5.0)
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(g_playerSong, mkr_song_north_2_dupe1, Util_GetPosition(mkr_song_south_3), 5.0)
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(g_playerSong, mkr_song_north_1_dupe2, Util_GetPosition(mkr_song_south_1), 5.0)
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(g_playerSong, mkr_song_north_2_dupe2, Util_GetPosition(mkr_song_south_1), 5.0)
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(g_playerSong, mkr_neutral_lumen, Util_GetPosition(mkr_song_south_1), 5.0)
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(g_playerSong, mkr_neutral_lumen_dupe_2, Util_GetPosition(mkr_song_south_2), 5.0)
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(g_playerSong, mkr_neutral_lumen_dupe_3, Util_GetPosition(mkr_song_south_3), 5.0)
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(g_playerSong, mkr_neutral_bohekou, Util_GetPosition(mkr_song_south_1), 5.0)
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(g_playerSong, mkr_neutral_bohekou_dupe_2, Util_GetPosition(mkr_song_south_2), 5.0)
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(g_playerSong, mkr_neutral_bohekou_dupe_3, Util_GetPosition(mkr_song_south_3), 5.0)
	
	-- Also the southward path after that
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(g_playerSong, mkr_song_north_1_dupe3, Util_GetPosition(mkr_neutral_lumen), 5.0)
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(g_playerSong, mkr_neutral_lumen_dupe_4, Util_GetPosition(mkr_neutral_bohekou), 5.0)
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(g_playerSong, mkr_neutral_bohekou_dupe_4, Util_GetPosition(mkr_song_south_2), 5.0)
	
	-- Spawn pickups
	Lumen_SpawnPickups()
	
	--DEBUG: Auto Test--
	AutoTest_OnInit()
	
end

-- This is triggered after the intro, just as control is passed to the player
function Mission_Start()	
	
	print("Mission Start with difficulty "..Game_GetSPDifficulty())
	
	-- on console don't restore VPS at first 
	Cardinal_EnablePartialXboxUI(true, {VF_XboxUIVillagerPriorities})

	-- start the opening objectives (if you're using ObjectiveTable style objectives)
	Objective_Start(OBJ_ClaimArea, false)
	
	Music_LockIntensity(MUSIC_TENSE, 8)
	
	-- Init the tutorialization? Not sure if this does anything.
	MissionTutorial_Init()
	
end

