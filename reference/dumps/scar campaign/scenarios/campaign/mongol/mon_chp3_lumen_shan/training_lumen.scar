import("training/campaigntraininggoals.scar")


local goal_sequence_use_liu_zheng = "campaign_mon_chp3_lumen_shan_liu_zheng"
local goal_sequence_repair_bridge = "campaign_mon_chp3_lumen_shan_repair_bridge"

