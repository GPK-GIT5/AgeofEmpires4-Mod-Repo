--
-- Battle of Liegnitz 1241
--
-- The Mongol Horde, Mission 5
--

import("MissionOMatic/MissionOMatic.scar")
import("obj_destroypoles.scar")

--Training
import("training_liegnitz.scar")

function Mission_SetupPlayers()
	
	player1 = World_GetPlayerAt(1) -- Mongols
    player2 = World_GetPlayerAt(2) -- Polish
	player3 = World_GetPlayerAt(3) -- Bohemians
	player4 = World_GetPlayerAt(4) -- Neutral
	
	-- player 1 - Mongol Army
	Setup_SetPlayerName(player1, "$11176009") 		-- 'Baidar'
	Player_SetCurrentAge(player1, AGE_CASTLE)
	Player_SetMaximumAge(player1, AGE_CASTLE)

	-- player 2 - Polish Army	
	Setup_SetPlayerName(player2, "$11176010")		-- 'Polish Army'
	Player_SetCurrentAge(player2, AGE_CASTLE)
	Player_SetMaximumAge(player2, AGE_CASTLE)
	
	-- player 3 - Bohemian Army	
	Setup_SetPlayerName(player3, "$11176011")		-- 'Bohemian Army'
	Player_SetCurrentAge(player3, AGE_CASTLE)
	Player_SetMaximumAge(player3, AGE_CASTLE)
	
	-- player 4 - Environment
	Setup_SetPlayerName(player4, "$11176009")		-- 'Baidar'
	Player_SetCurrentAge(player4, AGE_DARK)
	Player_SetMaximumAge(player4, AGE_IMPERIAL)
	
	-- NEUTRAL GROUPING
	Player_SetRelationship(player1, player4, R_ALLY)
	Player_SetRelationship(player2, player4, R_ALLY)
	Player_SetRelationship(player3, player4, R_ALLY)
	Player_SetRelationship(player4, player1, R_ALLY)
	Player_SetRelationship(player4, player2, R_ALLY)
	Player_SetRelationship(player4, player3, R_ALLY)
	
	-- POLISH / BOHEMIAN COALITION
	Player_SetRelationship(player2, player3, R_ALLY)
	Player_SetRelationship(player3, player2, R_ALLY)
	
	World_EnableSharedLineOfSight(player1, player2, false)
	World_EnableSharedLineOfSight(player1, player3, false)
	World_EnableSharedLineOfSight(player1, player4, true)
	
	World_EnableSharedLineOfSight(player2, player1, false)
	World_EnableSharedLineOfSight(player2, player3, true)
	World_EnableSharedLineOfSight(player2, player1, false)
	
	World_EnableSharedLineOfSight(player3, player1, false)
	World_EnableSharedLineOfSight(player3, player2, true)
	World_EnableSharedLineOfSight(player3, player4, false)
	
	World_EnableSharedLineOfSight(player4, player1, true)
	World_EnableSharedLineOfSight(player4, player2, false)
	World_EnableSharedLineOfSight(player4, player3, false)
	
	--
	-- Set Player Colours
	--
	
	PlayerColour_Enable()								--Turn on custom colour configuration for this session
	
	Game_SetPlayerSlotColour(player1, 1)			--Paint Scheme
	Game_SetPlayerUISlotColour(player1, 1)		--UI Colour
	
	Game_SetPlayerSlotColour(player2, 2)			--Paint Scheme
	Game_SetPlayerUISlotColour(player2, 2)		--UI Colour
	
	Game_SetPlayerSlotColour(player3, 7)				--Paint Scheme
	Game_SetPlayerUISlotColour(player3, 7)				--UI Colour
	
	Game_SetPlayerSlotColour(player4, 1)	--Paint Scheme
	Game_SetPlayerUISlotColour(player4, 1)--UI Colour
	
end

function Mission_SetupVariables()
	
	--OBJECTIVES
	DestroyPoles_InitObjectives()
	
	--SGROUPS
	--PLAYER UNITS
	sg_player_units = SGroup_CreateIfNotFound("sg_player_units")
	sg_scout_01 = SGroup_CreateIfNotFound("sg_scout_01")
	sg_scout_02 = SGroup_CreateIfNotFound("sg_scout_02")
	sg_group_01 = SGroup_CreateIfNotFound("sg_group_01")
	sg_rocketsiege = SGroup_CreateIfNotFound("sg_rocketsiege")
	
	--ENEMY UNITS
	sg_field_left 	 = SGroup_CreateIfNotFound("sg_field_left")
	sg_field_center  = SGroup_CreateIfNotFound("sg_field_center")
	sg_field_right 	 = SGroup_CreateIfNotFound("sg_field_right")
	sg_field_patrol  = SGroup_CreateIfNotFound("sg_field_patrol")
	sg_ridge_center	 = SGroup_CreateIfNotFound("sg_ridge_center")
	sg_ridge_left 	 = SGroup_CreateIfNotFound("sg_ridge_left")
	sg_ridge_right 	 = SGroup_CreateIfNotFound("sg_ridge_right")
	sg_ridge_patrol  = SGroup_CreateIfNotFound("sg_ridge_patrol")
	sg_valley_front  = SGroup_CreateIfNotFound("sg_valley_front")
	sg_valley_center = SGroup_CreateIfNotFound("sg_valley_center")
	sg_valley_back 	 = SGroup_CreateIfNotFound("sg_valley_back")
	sg_valley_left 	 = SGroup_CreateIfNotFound("sg_valley_left")
	sg_valley_right  = SGroup_CreateIfNotFound("sg_valley_right")
	sg_valley_patrol = SGroup_CreateIfNotFound("sg_valley_patrol")
	sg_roving_templars = SGroup_CreateIfNotFound("sg_roving_templars")
	
	sg_bohemians_left = SGroup_CreateIfNotFound("sg_bohemians_left")
	sg_bohemians_center = SGroup_CreateIfNotFound("sg_bohemians_center")
	sg_bohemians_right = SGroup_CreateIfNotFound("sg_bohemians_right")
	
	sg_polish_units = SGroup_CreateIfNotFound("sg_polish_units")
	sg_bohemian_units = SGroup_CreateIfNotFound("sg_bohemian_units")
	
	eg_player_production_structures = EGroup_CreateIfNotFound("eg_player_production_structures")
	eg_player_buildings = EGroup_CreateIfNotFound("eg_player_buildings")
	
	Liegnitz_AssignWallsToEGroups()
	
	--MISSION VARIABLES
	field_vo_hint = false
	last_killed_position = nil
	
	--LEADERS
	sg_leaderKhan = Missionomatic_InitializeLeader({
		name = "$11176009", -- Baidar
		owner = player1,
		neutralHolder = player4,
	})
	
	--UNIT GROUPS
	field_cavalry = {
		{ sbp = SBP.HRE.UNIT_HORSEMAN_3_HRE, numSquads = Util_DifVar({7, 8, 10, 12}) },
		{ sbp = SBP.HRE.UNIT_KNIGHT_3_HRE, numSquads = Util_DifVar({1, 2, 3, 4}) },
	}
	
end

function Mission_SetRestrictions()
	
	--Auto player upgrades
	PlayerUpgrades_Auto(player1, false)
	PlayerUpgrades_Auto(player2)
	PlayerUpgrades_Auto(player3)
	PlayerUpgrades_Auto(player4)
	
	--Units
	PlayerUpgrades_LearnAllUnits(player1, AGE_CASTLE, nil, Player_GetRaceName(player1))
	Player_SetSquadProductionAvailability(player1, SBP.MONGOL.UNIT_TRADE_CART_MON, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.MONGOL.UNIT_TRADE_CART_DOUBLE_MON, ITEM_REMOVED)
	
	Player_CompleteUpgrade(player1, UPG.MONGOL.UPGRADE_SCOUT_KHAN_VISION_IMPROVED_MON)
	
	Player_SetUpgradeAvailability(player1, UPG.MONGOL.UPGRADE_ORTOO_ALL_UNITS_MON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_ECON_RESOURCE_FOOD_HARVEST_RATE_3, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.MONGOL.UPGRADE_ECON_RESOURCE_FOOD_HARVEST_RATE_2_IMPROVED_MON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_ECON_RESOURCE_GOLD_HARVEST_RATE_3, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.MONGOL.UPGRADE_ECON_RESOURCE_GOLD_HARVEST_RATE_2_IMPROVED_MON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_ECON_RESOURCE_WOOD_HARVEST_RATE_3, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.MONGOL.UPGRADE_ECON_RESOURCE_WOOD_HARVEST_RATE_2_IMPROVED_MON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.MONGOL.UPGRADE_ECON_RESOURCE_PASTURE_SPAWN_RATE_MON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.MONGOL.UPGRADE_ECON_RESOURCE_PASTURE_SPAWN_RATE_IMPROVED_MON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.MONGOL.UPGRADE_ECON_VILLAGER_HUNTING_GEAR_1_MON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.MONGOL.UPGRADE_ECON_VILLAGER_HUNTING_GEAR_1_IMPROVED_MON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.MONGOL.UPGRADE_SCOUT_FORESTER_IMPROVED_MON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.MONGOL.UPGRADE_UNIT_TOWN_CENTER_WHEELBARROW_1_MON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.MONGOL.UPGRADE_UNIT_WHEELBARROW_1_IMPROVED_MON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.MONGOL.UPGRADE_SIEGE_WEAPON_SPEED_MON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.MONGOL.UPGRADE_SIEGE_WEAPON_SPEED_IMPROVED_MON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.MONGOL.UPGRADE_ECON_RESOURCE_WOOD_FELL_RATE_1_IMPROVED_MON, ITEM_REMOVED)
	
end

function Mission_SetDifficulty()
	t_difficulty = {
		bohemian_timer = Util_DifVar({1440, 1320, 1200, 1140}),
	}
end

function Mission_Preset()
	
	--Start the music with tense intensity
	Sound_SetMusicIntensityScaling(1.35)
	
	AudioTrigger_InitAreaTrigger({
		marker = mkr_village_tl_1,
		audioCue = MUSIC_TENSE_COMBAT,
		triggeringPlayer = player1,
		startAboveUnitCount = 5,
		duration = 10,
	})
	
	-- Spawn in player buildings -- this is because placing them through editor does not allow them to move!
	Util_CreateEntities(player1, eg_player_buildings, EBP.MONGOL.BUILDING_STONE_DEPOSIT_OVOO_MON, mkr_player_ovoo, 1)
	Util_CreateEntities(player1, eg_player_buildings, EBP.MONGOL.BUILDING_TECH_UNIT_RANGED_MON, mkr_arsenal_spawn, 1)
	Util_CreateEntities(player1, eg_player_buildings, EBP.MONGOL.BUILDING_TECH_UNIT_INFANTRY_MON, mkr_blacksmith_spawn, 1)
	Util_CreateEntities(player1, eg_player_buildings, EBP.MONGOL.BUILDING_ECON_MARKET_MON, mkr_market_spawn, 1)
	Util_CreateEntities(player1, eg_player_production_structures, EBP.MONGOL.BUILDING_UNIT_CAVALRY_MON, mkr_stable_spawn_1, 1)
	Util_CreateEntities(player1, eg_player_production_structures, EBP.MONGOL.BUILDING_UNIT_CAVALRY_MON, mkr_stable_spawn_2, 1)
	Util_CreateEntities(player1, eg_player_production_structures, EBP.MONGOL.BUILDING_UNIT_CAVALRY_MON, mkr_stable_spawn_3, 1)
	--Util_CreateEntities(player1, eg_player_buildings, EBP.MONGOL.BUILDING_HOUSE_MON, mkr_ger_1, 1)
	Util_CreateEntities(player1, eg_player_buildings, EBP.MONGOL.BUILDING_HOUSE_MON, mkr_ger_2, 1)
	Util_CreateEntities(player1, eg_player_buildings, EBP.MONGOL.BUILDING_HOUSE_MON, mkr_ger_3, 1)
	Util_CreateEntities(player1, eg_player_buildings, EBP.MONGOL.BUILDING_HOUSE_MON, mkr_ger_4, 1)
	Util_CreateEntities(player1, eg_player_buildings, EBP.MONGOL.BUILDING_HOUSE_MON, mkr_ger_5, 1)
	--Util_CreateEntities(player1, eg_player_buildings, EBP.MONGOL.BUILDING_HOUSE_MON, mkr_ger_6, 1)
	Util_CreateEntities(player1, eg_player_buildings, EBP.MONGOL.BUILDING_WONDER_AGE1_KURULTAI_MON, mkr_kurultai, 1)
	
	local player_resources = Util_DifVar({
		{ gold = 1000, wood = 1000, food = 1000, stone = 500 },
		{ gold = 800, wood = 800, food = 800, stone = 400 },
		{ gold = 600, wood = 600, food = 600, stone = 300 },
		{ gold = 400, wood = 400, food = 400, stone = 200 },
	})
	
	Player_SetResource(player1, RT_Food, player_resources.food)
	Player_SetResource(player1, RT_Wood, player_resources.wood)
	Player_SetResource(player1, RT_Gold, player_resources.gold)
	Player_SetResource(player1, RT_Stone, player_resources.stone)
	
	local nest_of_bees_speed_buff = Modifier_Create(MAT_EntityType, "speed_maximum_modifier", MUT_Multiplication, false, 1.4, EBP.CHINESE.UNIT_NEST_OF_BEES_4_CHI)
	Modifier_ApplyToPlayer(nest_of_bees_speed_buff, player1, 0)
	
	--TEMPORARY DEBUG "CHEATS"
	--if debug then Liegnitz_AssignSquadsToControlGroups() end
	
end

function Mission_Start()
	
	-- on console we don't need the VPS for this mission (no villagers) 
	Cardinal_EnablePartialXboxUI(true, {VF_XboxUIVillagerPriorities})
	
	field_defend_left = MissionOMatic_FindModule("field_defend_left")
	field_defend_center = MissionOMatic_FindModule("field_defend_center")
	field_defend_right = MissionOMatic_FindModule("field_defend_right")
	field_patrol = MissionOMatic_FindModule("field_patrol")
	
	ridge_defend_left = MissionOMatic_FindModule("ridge_defend_left")
	ridge_defend_center = MissionOMatic_FindModule("ridge_defend_center")
	ridge_defend_right = MissionOMatic_FindModule("ridge_defend_right")
	ridge_patrol = MissionOMatic_FindModule("ridge_patrol")
	
	valley_defend_front = MissionOMatic_FindModule("valley_defend_front")
	valley_defend_center = MissionOMatic_FindModule("valley_defend_center")
	valley_defend_back = MissionOMatic_FindModule("valley_defend_back")
	valley_defend_left = MissionOMatic_FindModule("valley_defend_left")
	valley_defend_right = MissionOMatic_FindModule("valley_defend_right")
	valley_patrol = MissionOMatic_FindModule("valley_patrol")
	
	roving_templars = MissionOMatic_FindModule("roving_templars")
	roving_bohemians = MissionOMatic_FindModule("roving_bohemians")
	
	polish_modules = {
		field_defend_left,
		field_defend_center,
		field_defend_right,
		field_patrol,
		ridge_defend_left,
		ridge_defend_center,
		ridge_defend_right,
		ridge_patrol,
		valley_defend_front,
		valley_defend_center,
		valley_defend_back,
		valley_defend_left,
		valley_defend_right,
		valley_patrol,
		roving_templars
	}
	
	bohemian_modules = {
		roving_bohemians,
	}
	
	Rule_AddInterval(Liegnitz_FirstGroupIsEngaged, 1)
	Rule_AddInterval(Liegnitz_ValleyGroupAggro, 1)
	Rule_AddGlobalEvent(Liegnitz_BreachWallCharge, GE_EntityKilled)
	
	-- Upgrade Liegnitz towers to have springalds
	Player_GetAll(player2)
	EGroup_Filter(eg_allentities, EBP.HRE.BUILDING_DEFENSE_TOWER_HRE, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_TOWER_SPRINGALD)
	
	stable_position = Entity_GetPosition(EGroup_GetEntityAt(eg_player_production_structures, 1))
	
	Objective_Start(OBJ_DestroyPolishArmy)
	
end


