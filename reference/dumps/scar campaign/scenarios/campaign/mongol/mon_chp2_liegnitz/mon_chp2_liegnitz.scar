		{	sbp = SBP.MONGOL.UNIT_HORSEARCHER_3_MON, 	numSquads = 3, spawn = mkr_outro_parade_04_far,	sgroup = sg_outro_parade_far_horsearcher },
		{	sbp = SBP.MONGOL.UNIT_HORSEMAN_3_MON, 		numSquads = 3, spawn = mkr_outro_parade_05_far,	sgroup = sg_outro_parade_far },
		{	sbp = SBP.MONGOL.UNIT_HORSEMAN_3_MON, 		numSquads = 3, spawn = mkr_outro_parade_06_far,	sgroup = sg_outro_parade_far },
	}
	
	local parade_markers_far = {
		mkr_outro_parade_far01_target,
		mkr_outro_parade_far02_target,
		mkr_outro_parade_far_target,
	}
	
	Util_UnitParade(parade_markers_far, units_parade_far)
	Modify_UnitSpeed(sg_outro_parade_far, 0.3)
	Modify_UnitSpeed(sg_outro_parade_far_horsearcher, 0.37)
	
    local function _Burn (gid, index, iid)
        if Entity_IsAlive(iid) then
            Entity_SetHealth(iid, (World_GetRand(1,3)/10))
            if Entity_IsBurning(iid) ~= true then
                Entity_SetOnFire(iid)
            end 
        end
    end
    
    EGroup_ForEach(eg_outro_burn, _Burn)	
	
	Rule_AddOneShot(Outro_ScoutMove, 20)
	
end

function Outro_ScoutMove()
	
	Cmd_FormationMove(sg_outro_scout_01, mkr_outro_scout_01_target)
	
end