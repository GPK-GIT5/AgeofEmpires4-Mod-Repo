------------------------------------------------------------------------------------------------------------------------------------------
--															COMBAT
------------------------------------------------------------------------------------------------------------------------------------------

function Liegnitz_FirstGroupIsEngaged() --Triggers rest of polish army to advance once first cav group is engaged.

	if Player_CanSeeSGroup(player1, sg_field_left, ANY) or Player_CanSeeSGroup(player1, sg_field_center, ANY) or Player_CanSeeSGroup(player1, sg_field_right, ANY) then	
		
		local groups = {
			{sgroup = sg_field_left, module = field_defend_left, marker = mkr_field_left},
			{sgroup = sg_field_center, module = field_defend_center, marker = mkr_field_center},
			{sgroup = sg_field_right, module = field_defend_right, marker = mkr_field_right},
		}
		
		Liegnitz_StaggerAttackerEngagement(groups)
		
		Rule_RemoveMe()
		
	end
end

function Liegnitz_StaggerAttackerEngagement(groups)
	
	Player_GetAll(player1)
	
	if SGroup_CountSpawned(sg_allsquads) > 0 then
		
		for index = #groups, 1, -1 do 
			
			local entry = groups[index]
			
			if SGroup_CountSpawned(entry.sgroup) == 0 then 
				table.remove(groups, index)
			else
				local pos = Util_GetPosition(entry.sgroup)
				local closest = SGroup_GetClosestSquad(sg_allsquads, pos)
				entry.distance = Util_GetDistance(closest, pos)
			end
		end

		table.sort(groups, function(a, b) return a.distance < b.distance end)
		
		local delay = 0
		local timeStamp = World_GetGameTime()
		
		for index, entry in ipairs(groups) do 
			entry.timeOut = timeStamp + delay 
			Rule_AddInterval(Liegnitz_StaggerAttackerEngagement_Delayed, 1, entry)
			delay = delay + 5
		end
		
	end
			
end

function Liegnitz_StaggerAttackerEngagement_Delayed(context, data)

	if SGroup_CountSpawned(data.sgroup) == 0 then 
		Rule_RemoveMe()
		return 
	end
	
	if SGroup_IsUnderAttackByPlayer(data.sgroup, player1, 5) or World_GetGameTime() >= data.timeOut then 
		
		if not Objective_IsFailed(OBJ_BohemianTimer) then
			RovingArmy_SetTarget(data.module, data.marker, 120, 150)		
		end
		
		Rule_RemoveMe()
		
	end

end


function Liegnitz_ValleyGroupAggro()
	if Player_CanSeeSGroup(player1, sg_valley_front, ANY) or
		Player_CanSeeSGroup(player1, sg_valley_center, ANY) or
		Player_CanSeeSGroup(player1, sg_valley_back, ANY) or
		Player_CanSeeSGroup(player1, sg_valley_left, ANY) or
		Player_CanSeeSGroup(player1, sg_valley_right, ANY) then
		
		local groups = {
			{sgroup = sg_valley_front, module = valley_defend_front, marker = mkr_valley_front},
			{sgroup = sg_valley_center, module = valley_defend_center, marker = mkr_valley_center},
			{sgroup = sg_valley_back, module = valley_defend_back, marker = mkr_valley_back},
			{sgroup = sg_valley_left, module = valley_defend_left, marker = mkr_valley_left},
			{sgroup = sg_valley_right, module = valley_defend_right, marker = mkr_valley_right},
		}
		
		Liegnitz_StaggerAttackerEngagement(groups)
		
		Rule_RemoveMe()
	end
end

