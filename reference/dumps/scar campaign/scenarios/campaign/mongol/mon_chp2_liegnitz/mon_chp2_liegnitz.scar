function Liegnitz_AssignWallsToEGroups()
	eg_west_village_walls = EGroup_CreateIfNotFound("eg_west_village_walls")
	eg_east_village_walls = EGroup_CreateIfNotFound("eg_east_village_walls")
	
	Player_GetAllEntitiesNearMarker(player2, eg_west_village_walls, mkr_village_tl_6, 35)
	EGroup_Filter(eg_west_village_walls, "wall", FILTER_KEEP)
	
	Player_GetAllEntitiesNearMarker(player2, eg_east_village_walls, mkr_village_tl_7, 35)
	EGroup_Filter(eg_east_village_walls, "wall", FILTER_KEEP)
end

function Liegnitz_BreachWallCharge(context, data)
	if context.victim ~= nil and Entity_IsOfType(context.victim, "wall") then

		if Util_GetDistance(mkr_village_tl_6, context.victim) <= 35 and not b_westVillageBreach then
			b_westVillageBreach = true
			Player_GetAllSquadsNearMarker(player1, sg_temp, Entity_GetPosition(context.victim), 25)
			Sound_PlayWallaChargeOnSGroup(sg_temp)
		elseif Util_GetDistance(mkr_village_tl_7, context.victim) <= 35 and not b_eastVillageBreach then
			b_eastVillageBreach = true
			Player_GetAllSquadsNearMarker(player1, sg_temp, Entity_GetPosition(context.victim), 25)
			Sound_PlayWallaChargeOnSGroup(sg_temp)
		end
		
		if b_westVillageBreach and b_eastVillageBreach then
			print("All viable walls breached. Closing off this event.")
			Rule_RemoveMe()
		end

	end
end

--Withdraw celebration, VO callouts and UI cleanup when a group is defeated
function Liegnitz_FieldWithdrawCelebrate()
	
	local groups = {
		field_defend_left,
		field_defend_center,
		field_defend_right,
		field_patrol,
	}
	
	Liegnitz_WithdrawCleanup(groups, OBJ_DestroyPolishArmy, true)
	
end

function Liegnitz_RidgeWithdrawCelebrate()
	
	local groups = {
		ridge_defend_left,
		ridge_defend_center,
		ridge_defend_right,
		ridge_patrol,
	}
	
	Liegnitz_WithdrawCleanup(groups, OBJ_DestroyPolishArmy, true)
	
end

function Liegnitz_ValleyWithdrawCelebrate()
	
	local groups = {
		valley_defend_front,
		valley_defend_center,
		valley_defend_back,
		valley_defend_left,
		valley_defend_right,
		valley_patrol,
	}
	
	Liegnitz_WithdrawCleanup(groups, OBJ_DestroyPolishArmy, true)
	
end

function Liegnitz_RovingWithdrawCelebrate()
	
	Liegnitz_WithdrawCleanup({roving_templars}, OBJ_DestroyPolishArmy, nil, EVENTS.Polish_Cavalry_Defeated)
	
end

function Liegnitz_BohemianWithdrawCelebrate()
	
	Liegnitz_WithdrawCleanup({roving_bohemians}, OBJ_DestroyBohemianArmy)
	
end

function Liegnitz_WithdrawCleanup(module_list, objective, b_playGroupDefeatedVO, playIntelEvent)
	
	local b_groupIsStillActive = false
	
	--Remove any UI elements for any withdrawn modules in the list.
	for i in pairs(module_list) do
		if module_list[i].isWithdrawn then
			if module_list[i].uiElement ~= nil then
				Objective_RemoveUIElements(objective, module_list[i].uiElement)
			end
		else
			b_groupIsStillActive = true
		end
	end
	
	if not b_groupIsStillActive then
		
		--Have the player's units celebrate if they are near the group as they rout
		for i in pairs(module_list) do
			if SGroup_CountSpawned(module_list[i].sgroup) > 0 then
				Player_GetAllSquadsNearMarker(player1, sg_temp, SGroup_GetPosition(module_list[i].sgroup), 80)
				Sound_PlayWallaCelebrateOnSGroup(sg_temp)
				break
			end
		end
		
		--Play defeated group VO if the module group has been defeated for the first or second time
		if b_playGroupDefeatedVO == true then
			defeated_groups = defeated_groups or 1
	
			if defeated_groups == 1 then
				Util_StartIntel(EVENTS.Polish_Group01_Defeated)
			elseif defeated_groups == 2 then
				Util_StartIntel(EVENTS.Polish_Group02_Defeated)
			end
			
			defeated_groups = defeated_groups + 1
		end
		
		--Play 
		if playIntelEvent ~= nil then
			Util_StartIntel(playIntelEvent)
		end
	end
	
end

