		siegeTowerPassengerCount = assault_siege_tower_passenger_count,
	}
	
	assault_data_1 = {
		type  = "RovingArmy",
		descriptor = "assault_1",
		player = player2,
		spawnLocation = mkr_siege_launch_1,
		targets = { mkr_siege_target_1_a, mkr_siege_target_1_b, mkr_siege_target_1_c, mkr_siege_target_1_d, mkr_siege_target_1_e },
		ramPassengerCount = assault_ram_passenger_count,
		siegeTowerPassengerCount = assault_siege_tower_passenger_count,
	}
	assault_data_2 = {
		type  = "RovingArmy",
		descriptor = "assault_2",
		player = player2,
		spawnLocation = mkr_siege_launch_2,
		targets = { mkr_siege_target_2_a, mkr_siege_target_2_b, mkr_siege_target_2_c, mkr_siege_target_2_d, mkr_siege_target_2_e },
		ramPassengerCount = assault_ram_passenger_count,
		siegeTowerPassengerCount = assault_siege_tower_passenger_count,
	}
	assault_data_3 = {
		type  = "RovingArmy",
		descriptor = "assault_3",
		player = player2,
		spawnLocation = mkr_siege_launch_3,
		targets = { mkr_siege_target_3_a, mkr_siege_target_3_b, mkr_siege_target_3_c, mkr_siege_target_3_d, mkr_siege_target_3_e },
		ramPassengerCount = assault_ram_passenger_count,
		siegeTowerPassengerCount = assault_siege_tower_passenger_count,
	}
	
	wave_data_1 = {
		descriptor = "wave_1",
		player = player2,
		use_separate_spawns = false,
		spawn = mkr_enemy_spawn_1,
		units = {},
		staging_module_data = staging_data_1,
		assault_module_data = assault_data_1,
		ignore_build_times = true,
	}
	
	wave_data_2 = {
		descriptor = "wave_2",
		player = player2,
		use_separate_spawns = false,
		spawn = mkr_enemy_spawn_2,
		units = {},
