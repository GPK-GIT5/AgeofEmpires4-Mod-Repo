		assault_module_data = assault_data_2,
		ignore_build_times = true,
	}
	
	wave_data_3 = {
		descriptor = "wave_3",
		player = player2,
		use_separate_spawns = false,
		spawn = mkr_enemy_spawn_3,
		units = {},
		staging_module_data = staging_data_3,
		assault_module_data = assault_data_3,
		ignore_build_times = true,
	}
	
    wave_1 = Wave_New(wave_data_1)
	wave_1.lane = 1
	wave_2 = Wave_New(wave_data_2)
	wave_2.lane = 2
    wave_3 = Wave_New(wave_data_3)
	wave_3.lane = 3
	
	paris_waves = { wave_1, wave_2, wave_3 }
end

