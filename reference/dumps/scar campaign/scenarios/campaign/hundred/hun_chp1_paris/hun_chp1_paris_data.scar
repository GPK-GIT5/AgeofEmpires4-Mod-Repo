	wave_units_total = wave_units_total + UnitTable_CountUnits(wave_units_bonus[4][1])
	wave_units_total = wave_units_total + UnitTable_CountUnits(wave_units_bonus[6][1])
	wave_units_total = wave_units_total + UnitTable_CountUnits(wave_units_bonus[6][2])
	wave_units_total = wave_units_total + UnitTable_CountUnits(wave_units_bonus[8][1])
	wave_units_total = wave_units_total + UnitTable_CountUnits(wave_units_bonus[8][2])
	wave_units_total = wave_units_total - UnitTable_CountUnitsOfType(wave_units_bonus[4][1], "scar_siege_tower")
	wave_units_total = wave_units_total - UnitTable_CountUnitsOfType(wave_units_bonus[6][1], "scar_siege_tower")
	wave_units_total = wave_units_total - UnitTable_CountUnitsOfType(wave_units_bonus[6][2], "scar_siege_tower")
	wave_units_total = wave_units_total - UnitTable_CountUnitsOfType(wave_units_bonus[8][1], "scar_siege_tower")
	wave_units_total = wave_units_total - UnitTable_CountUnitsOfType(wave_units_bonus[8][2], "scar_siege_tower")
	print("wave_units_total = "..wave_units_total)
end

