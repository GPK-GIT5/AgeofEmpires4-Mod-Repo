	staging_data_1 = {
		type = "RovingArmy",
		descriptor = "staging_1",
		player = player2,
		spawnLocation = mkr_enemy_spawn_1, 
		targets = Table_Copy(road_targets[1]),
		onComplete = Paris_OnCompleteStaging,
		lane = 1,
		ramPassengerCount = assault_ram_passenger_count,
		siegeTowerPassengerCount = assault_siege_tower_passenger_count,
	}
	staging_data_2 = {
