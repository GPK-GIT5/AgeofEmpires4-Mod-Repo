function Paris_InitData1()
	debug_reinforcements = false
	debug_invasion = false
	paris_seconds = { 0 }
	--invasion
	INVASION_DELAY_1 = 20
	INVASION_DELAY_2 = 0
	INVASION_DELAY_3 = 10
	invasion_started = false
	invasion_half_complete = false
	invasion_complete = false
	invader_has_withdrawn = false
	invasions_started = 0
	lanes_half = 0
	lanes_complete = 0
	lane_victories = { 0, 0, 0 }
	lane_victories_total = 0
	lane_is_started = { false, false, false }
	lane_is_half = { false, false, false }
	lane_has_standby = { false, false, false }
	lane_is_complete = { false, false, false }
	--siege
	INVASION_UNTIL_OBJECTIVE_DELAY = 25
	INVASION_UNTIL_SIEGE_DELAY = 50
	PREPARE_TIME = 180
	WAVE_INTERVALS = { 0, 105, 105, 135, 105, 105, 135, 105 }
	local total_time = 0
	for i = 1, 8 do
		total_time = total_time + WAVE_INTERVALS[i]
		WAVE_INTERVALS[i] = total_time
	end
	siege_started = false
	waves_prepared = 0
	waves_launched = 0
	waves_killed = 0
	assault_lane_order = Table_Shuffle({ 1, 2, 3})
	wave_info = {}
	for i = 1, 8, 1 do
		wave_info[i] = {}
		wave_info[i].sgroup = SGroup_Create("sg_wave_"..i)
		wave_info[i].is_spawned = false
		wave_info[i].is_launched = false
		wave_info[i].is_dead = false
		wave_info[i].main_lane = nil
		wave_info[i].bonus_lane_1 = nil
		wave_info[i].bonus_lane_2 = nil
		wave_info[i].units_spawned = nil
		wave_info[i].units_killed = nil
	end
	
	assault_ram_passenger_count = Util_DifVar({ 10, 10, 10, 10 })
	assault_siege_tower_passenger_count = Util_DifVar({ 3, 4, 6, 8 })
	
	--markers
	enemy_spawns = { mkr_enemy_spawn_1, mkr_enemy_spawn_2, mkr_enemy_spawn_3 }
	standby_reinforcement_targets = {
		{ mkr_invasion_target_1_a, mkr_invasion_target_1_b, mkr_invasion_target_1_c },
		{ mkr_invasion_target_2_a, mkr_invasion_target_2_b },
		{ mkr_invasion_target_3_a, mkr_invasion_target_3_b },
	}
	invader_targets = {
		{ mkr_invasion_target_1_a, mkr_invasion_target_1_b, mkr_invasion_target_1_c, mkr_invasion_target_1_d, mkr_invasion_target_1_e, mkr_invasion_target_1_f },
		{ mkr_invasion_target_2_a, mkr_invasion_target_2_b, mkr_invasion_target_2_c, mkr_invasion_target_2_d, mkr_invasion_target_2_e },
		{ mkr_invasion_target_3_a, mkr_invasion_target_3_b, mkr_invasion_target_3_c, mkr_invasion_target_3_d, mkr_invasion_target_3_e },
	}
	road_targets = {
		{ mkr_road_1_a, mkr_road_1_b, mkr_road_1_c, mkr_road_1_d, mkr_road_1_e, mkr_road_1_f },
		{ mkr_road_2_a, mkr_road_2_b, mkr_road_2_c, mkr_road_2_d, mkr_road_2_e },
		{ mkr_road_3_a, mkr_road_3_b, mkr_road_3_c, mkr_road_3_d, mkr_road_3_e, mkr_road_3_f, mkr_road_3_g },
	}
	staging_targets_final = {
		{ mkr_staging_1_a, { marker = mkr_staging_1_b, useCustomDirection = true } },
		{ mkr_staging_2_a, { marker = mkr_staging_2_b, useCustomDirection = true } },
		{ { marker = mkr_staging_3_a, useCustomDirection = true } },
	}
	patrol_targets = {
		{ mkr_lp_1_a, mkr_lp_1_b, mkr_lp_1_c, mkr_lp_1_d },
		{ mkr_lp_2_a, mkr_lp_2_b, mkr_lp_2_c, mkr_lp_2_d },
		{ mkr_lp_3_a, mkr_lp_3_b, mkr_lp_3_c, mkr_lp_3_d },
	}
	LANE_VICTORIES_REQUIRED_HALF = { 2, 2, 2 }
	LANE_VICTORIES_REQUIRED_STANDBY = { 3, 2, 2 }
	LANE_VICTORIES_REQUIRED_COMPLETE = { #invader_targets[1], #invader_targets[2], #invader_targets[3] }
	LANE_VICTORIES_REQUIRED_TOTAL = #invader_targets[1] + #invader_targets[2] + #invader_targets[3]
	--sgroups	
	sg_intro_troops = SGroup_CreateIfNotFound("sg_intro_troops")
	sg_intro_archer_1 = SGroup_Create("sg_intro_archer_1")
	sg_intro_archer_2 = SGroup_Create("sg_intro_archer_2")
	sg_intro_archer_3 = SGroup_Create("sg_intro_archer_3")
	sg_intro_archer_4 = SGroup_Create("sg_intro_archer_4")
	sg_intro_archer_5 = SGroup_Create("sg_intro_archer_5")
	sg_intro_archer_6 = SGroup_Create("sg_intro_archer_6")
	sg_intro_archer_7 = SGroup_Create("sg_intro_archer_7")
	sg_intro_archer_8 = SGroup_Create("sg_intro_archer_8")
	sg_intro_archer_9 = SGroup_Create("sg_intro_archer_9")
	sg_intro_crossbow_1 = SGroup_Create("sg_intro_crossbow_1")
	sg_intro_infantry_1 = SGroup_Create("sg_intro_infantry_1")
	sg_intro_knight_1 = SGroup_Create("sg_intro_knight_1")
	sg_intro_horsemen = SGroup_Create("sg_intro_horsemen")
	sg_intro_army_1 = SGroup_Create("sg_intro_army_1")
	sg_idle_villagers = SGroup_Create("sg_idle_villagers")
	sg_intro_fake_villager_1 = SGroup_Create("sg_intro_fake_villager_1")
	sg_intro_fake_villager_2 = SGroup_Create("sg_intro_fake_villager_2")
	
	sg_paris_farm_1 = SGroup_Create("sg_paris_farmers_1")
	sg_paris_farm_2 = SGroup_Create("sg_paris_farmers_2")
	sg_paris_farm_3 = SGroup_Create("sg_paris_farmers_3")
	sg_paris_farm_4 = SGroup_Create("sg_paris_farmers_4")
	sg_paris_farm_5 = SGroup_Create("sg_paris_farmers_5")
	sg_paris_farm_6 = SGroup_Create("sg_paris_farmers_6")
	sg_paris_farm_7 = SGroup_Create("sg_paris_farmers_7")
	sg_paris_gold_1 = SGroup_Create("sg_paris_gold_1")
	sg_paris_gold_2 = SGroup_Create("sg_paris_gold_2")
	sg_paris_stone_1 = SGroup_Create("sg_paris_stone_1")
	sg_paris_stone_2 = SGroup_Create("sg_paris_stone_2")
	sg_paris_wood_1 = SGroup_Create("sg_paris_wood_1")
	sg_paris_wood_2 = SGroup_Create("sg_paris_wood_2")
	sg_paris_wood_3 = SGroup_Create("sg_paris_wood_3")
	sg_paris_wood_4 = SGroup_Create("sg_paris_wood_4")
	sg_paris_wood_5 = SGroup_Create("sg_paris_wood_5")
	
	sg_retreat = SGroup_Create("sg_retreat")
	sg_retreat_original = SGroup_Create("sg_retreat_original")
	
	eg_paris_walls = Player_GetEntitiesFromType(player1, "wall")
	EGroup_Filter(eg_paris_walls, "stone_wall_tower", FILTER_REMOVE)
	LoadUnitTables()
end

function Paris_InitData2()
	invader_1 = MissionOMatic_FindModule("invader_1")
	invader_2 = MissionOMatic_FindModule("invader_2")
	invader_3 = MissionOMatic_FindModule("invader_3")
	invader_modules = { invader_1, invader_2, invader_3 }
	
	standby_1 = MissionOMatic_FindModule("standby_1")
	standby_2 = MissionOMatic_FindModule("standby_2")
	standby_3 = MissionOMatic_FindModule("standby_3")
	standby_modules = { standby_1, standby_2, standby_3 }
	
	for i = 1, 3, 1 do
		invader_modules[i].standby_module = standby_modules[i]
	end
	
	invader_stone = MissionOMatic_FindModule("invader_stone")
	invader_gold = MissionOMatic_FindModule("invader_gold")
	
	invader_stone.standby_module = standby_1
	invader_gold.standby_module = standby_3
	
	reinforced_modules = { invader_1, invader_stone, invader_2, invader_3, invader_gold, standby_1, standby_2, standby_3 }
	reinforced_modules_index = 0

	siege_defend_1 = MissionOMatic_FindModule("siege_defend_1")
	siege_defend_2 = MissionOMatic_FindModule("siege_defend_2")
	siege_defend_3 = MissionOMatic_FindModule("siege_defend_3")
	siege_defend_4 = MissionOMatic_FindModule("siege_defend_4")
	siege_defend_5 = MissionOMatic_FindModule("siege_defend_5")
	siege_defend_6 = MissionOMatic_FindModule("siege_defend_6")
	siege_defend_7 = MissionOMatic_FindModule("siege_defend_7")
	siege_defend_8 = MissionOMatic_FindModule("siege_defend_8")
	siege_defend_9 = MissionOMatic_FindModule("siege_defend_9")
	siege_defend_10 = MissionOMatic_FindModule("siege_defend_10")
	siege_defend_11 = MissionOMatic_FindModule("siege_defend_11")
	siege_defend_12 = MissionOMatic_FindModule("siege_defend_12")
	siege_defend_13 = MissionOMatic_FindModule("siege_defend_13")
	siege_defend_14 = MissionOMatic_FindModule("siege_defend_14")
	siege_defend_15 = MissionOMatic_FindModule("siege_defend_15")
end

