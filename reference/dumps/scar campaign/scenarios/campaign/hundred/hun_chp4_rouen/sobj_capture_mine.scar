--
-- Rouen - Capture Locations
--

function CaptureLocations_InitRouenMine_Optional()
	
	local location = LOCATION("RouenMine")
	
	SOBJ_CaptureRouenMine_Optional = {
		
		Title = 11196669, -- Capture the Mine
		Type = ObjectiveType_Capture,
		Parent = OBJ_AssistTheBrothers,
		StartAlongsideParent = false, 
		--Intel_Start = EVENTS.ShowObjective_RouenMine,
		--Intel_Complete = EVENTS.CaptureRouenMine,
		OnStart = function()
			Location_SetCapturable(LOCATION("RouenMine"), true)
			--TrainingGoal_AddStopAttacking()
		end,
		PreComplete = function()
			CelebrateOnPosition(mkr_mine, 90)
			Util_AutoSave(true, true)
			--Music_StopMedium()
			--Music_UnlockIntensity()
		end,
		OnComplete = function()		
			OptionalObjective_Data.minecapture.isCompleted = true			
			Player_CompleteUpgrade(player1, BP_GetUpgradeBlueprint("upgrade_surplus_iron_fre"))
			
			t_reinforcementData[3].activated = true
			Objective_Stop(SOBJ_DefeatRouenMineRebels_Optional)
			Util_StartIntel(EVENTS.ResearchObj_Mine)
		end,
	}
	SOBJ_DefeatRouenMineRebels_Optional = {
		
		Title = 11196670, -- Defeat Mine Defenders
		Type = ObjectiveType_Capture,
		Parent = SOBJ_CaptureRouenMine_Optional,
	}
	SOBJ_LocationRouenMine_Optional = {
		Title = 11196671, -- Rouen Mine
		Type = ObjectiveType_Capture,
		Parent = SOBJ_CaptureRouenMine_Optional,
	}
	
	Objective_Register(SOBJ_CaptureRouenMine_Optional)
	Objective_Register(SOBJ_DefeatRouenMineRebels_Optional)
	Objective_Register(SOBJ_LocationRouenMine_Optional)
	
	location.objectivePrimary = SOBJ_CaptureRouenMine_Optional
	location.objectiveSecondary = SOBJ_DefeatRouenMineRebels_Optional
	location.objectiveCapture = SOBJ_LocationRouenMine_Optional
	
end