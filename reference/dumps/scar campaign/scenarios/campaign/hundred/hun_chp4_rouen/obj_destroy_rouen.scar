--
-- Mission Retake Normandy and 1448 - Objective Destroy Rouen
--

function RetakeNormandy_InitObjectives()		-- rename this function to use your prefix for this part of the mission

	OBJ_RetakeNormandy = {
	
		Title = 11172307, --("Retake Normandy"),
		Type = ObjectiveType_Battle,
		
		--Intel_Complete = ,
		
		OnComplete = RetakeNormandy_OnComplete,
		
		SetupUI = DestroyWalls_UI,
		
		OnStart = DestroyWalls_Start,
		
	}
	
	SOBJ_GetCannons = {
	
		Title = 11172308, --("Build Cannons"),
		Type = ObjectiveType_Build,
		Parent = OBJ_RetakeNormandy,
		StartAlongsideParent = false, 
		
		Intel_Start = EVENTS.NewObj_BuildCannons,
		Intel_Complete = EVENTS.GetCannonsCompleted,
		
		SetupUI = GetCannons_SetUI,
		
		OnStart = GetCannons_Start,
		OnComplete = GetCannons_Complete,
	}
	
	SOBJ_DestroyRouenWalls = {
	
		Title = "$11172347", --Breach Rouen's Walls --11172309, --("Destroy Rouen"),
		Type = ObjectiveType_Battle,
		Parent = OBJ_RetakeNormandy,
		StartAlongsideParent = false, 
		
		Intel_Start = EVENTS.NewObj_BreachRouen,
		
		--SetupUI = DestroyWalls_UI,
		
		--OnStart = DestroyWalls_Start,
		
		OnComplete = DestroyWalls_OnComplete,
	}
	
	SOBJ_DestroyLandmarks= {
	
		Title = 11172310, --("Destroy Rouen's landmarks"),
		Type = ObjectiveType_Battle,
		Parent = OBJ_RetakeNormandy,
		StartAlongsideParent = false, 
		
		Intel_Start = EVENTS.DestroyLandmarks,
		
		SetupUI = DestroyLandmarks_UI,
				
		OnComplete = DestroyLandmarks_OnComplete,
	}
		
	
	Objective_Register(OBJ_RetakeNormandy)
	Objective_Register(SOBJ_GetCannons)
	Objective_Register(SOBJ_DestroyRouenWalls)
	Objective_Register(SOBJ_DestroyLandmarks)
		
	--
	-- any other variable initialization can go in here
	--
	
	OBJ_DebugComplete = {
        Title = LOC("Debug Complete"),
        Type = OT_Primary,
        showTitle = false,
        Cheat = function()
			Rule_RemoveAll()
			Player_GetAll(player2)
			SGroup_DestroyAllSquads(sg_allsquads)
			EGroup_SetPlayerOwner(eg_allentities, player1)
			RetakeNormandy_OnComplete()
			end,
	    }

    Objective_Register(OBJ_DebugComplete)	
	
end


function GetCannons_SetUI()
	
	Objective_SetCounter(SOBJ_GetCannons, 0, numberOfCannonsObj)
	
end

function GetCannons_Start()
	
	Rule_AddInterval(GetCannons_Monitor,1)	
	
end

function GetCannons_Complete()
	Objective_Start(SOBJ_DestroyRouenWalls, true)
	Game_TransitionToState("sunset", 600)
end

function GetCannons_Monitor()
	
	--{SBP.FRENCH.UNIT_CANNON_4_FRE, SBP.FRENCH.UNIT_CANNON_4_BUILDABLE_FRE}
	Player_GetAll(player1,sg_allsquads)
	SGroup_Filter(sg_allsquads, {"scar_culverin", "scar_ribauldequin", "scar_cannon"}, FILTER_KEEP)
	local numberCannons = SGroup_CountSpawned(sg_allsquads)
	cannonLastCount = cannonLastCount or 0
   
	if numberCannons > cannonLastCount then
		cannonLastCount = numberCannons
		Sound_Play2D("sfx_campaign_scripted_ui_objective_counter_update")
		
	end
	
	if numberCannons >= numberOfCannonsObj then
		Objective_Complete(SOBJ_GetCannons,true,true)
		Rule_RemoveMe()
	else
		if Objective_IsCounterSet(SOBJ_GetCannons) then 
			
			if numberCannons >= 1 then
				Intel_CannonUpgrade()
				--if b_IntelStartOnFirstCannon == false then
					--b_IntelStartOnFirstCannon = true
					--Util_StartIntel(EVENTS.FirstCannon)
				--end
			end
			Objective_SetCounter(SOBJ_GetCannons, numberCannons, numberOfCannonsObj)
			
			
		end
	end
	
end

function Intel_CannonUpgrade()
	if b_cannonUpgradeIntelPlayed == false then
		if Player_HasUpgrade(player1, UPG.COMMON.UPGRADE_SIEGE_CORNED_GUNPOWDER) == false and Player_HasUpgrade(player1, UPG.COMMON.UPGRADE_SIEGE_STEEL_BORE) == false then
			b_cannonUpgradeIntelPlayed = true	
			--Util_StartIntel(EVENTS.FirstCannon)
		end
	end
end

function DestroyWalls_UI()
		
	hpid_Rouen = Objective_AddUIElements(OBJ_RetakeNormandy, mkr_enemy_base, true,11172311, true) --"Rouen"
	
end

function DestroyWalls_Start()
	Rule_Add(GetNearRouen_Monitor)	
end	

--ask to get more units to defend Rouen (timer of 360 seconds) will need to request units in v3
function AddUnitsToDefendRouen()
	
	if Objective_IsComplete(SOBJ_DestroyRouenWalls) == false then
		if Prox_ArePlayersNearMarker(player1, mkr_enemy_base_approach, ANY, nil, "gaia", FILTER_REMOVE ) == false then
			
			local choice = World_GetRand(1,3)
			
			if choice == 1 then
				units = {
					{type = "scar_manatarms", numSquads = Util_DifVar({1,1,3,5}), difficulty = {GD_HARD, GD_EXPERT}},
					{type = "scar_spearman", numSquads = Util_DifVar({4,4,3,5}) }, --was 3
				}
				
				
			elseif choice == 2 then
				units = {
					{type = "scar_knight", numSquads = Util_DifVar({2,2,2,5}) }, --was 2
					{type = "scar_horseman", numSquads = Util_DifVar({3,3,3,5}) }, --was 3
				}
				
			else
				units = {
					{type = "scar_archer", numSquads = Util_DifVar({2,2,3,4}) }, --was 2
					{type = "scar_crossbowman", numSquads = Util_DifVar({2,2,3,4}) }, --was 2
				}
			end
			
			SpawnUnitsToModule(units, "enemy_base",mkr_enemy_base_garrison)

		end
	else
		Rule_RemoveMe()
	end
end


