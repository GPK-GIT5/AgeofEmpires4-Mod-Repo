	Cmd_FormationMove(sg_outro_parade02, mkr_outro_parade_04_target)
	Cmd_FormationMove(sg_outro_parade03, mkr_outro_parade_05_target)
	Cmd_FormationMove(sg_outro_parade04, mkr_outro_parade_05_target)
	Cmd_FormationMove(sg_outro_infantry03, mkr_outro_parade_06_target)
	Cmd_FormationMove(sg_outro_infantry04, mkr_outro_parade_06_target)
	Cmd_FormationMove(sg_outro_infantry05, mkr_outro_parade_07_target)
	Cmd_FormationMove(sg_outro_infantry06, mkr_outro_parade_07_target)
	Cmd_FormationMove(sg_outro_infantry07, mkr_outro_parade_08_target)
	Cmd_FormationMove(sg_outro_infantry08, mkr_outro_parade_08_target)
	Modify_UnitSpeed(sg_outro_parade02, outro_horse_speed)
	Modify_UnitSpeed(sg_outro_parade03, outro_horse_speed)
	Modify_UnitSpeed(sg_outro_parade04, outro_horse_speed)
	Modify_UnitSpeed(sg_outro_infantry03, outro_man_speed_slow)
	Modify_UnitSpeed(sg_outro_infantry04, outro_man_speed_slow)	
	Modify_UnitSpeed(sg_outro_infantry05, outro_man_speed_slow)
	Modify_UnitSpeed(sg_outro_infantry06, outro_man_speed_slow)
	Modify_UnitSpeed(sg_outro_infantry07, outro_man_speed)
	Modify_UnitSpeed(sg_outro_infantry08, outro_man_speed)
	
	-- Cheering people
	
	UnitEntry_DeploySquads(player1, sg_outro_cheer_left, {type = "scar_villager", numSquads = 2}, mkr_outro_cheer_01)
	UnitEntry_DeploySquads(player1, sg_outro_cheer_left, {type = "scar_villager", numSquads = 2}, mkr_outro_cheer_02)
	UnitEntry_DeploySquads(player1, sg_outro_cheer_left, {type = "scar_villager", numSquads = 2}, mkr_outro_cheer_03)
	
	UnitEntry_DeploySquads(player1, sg_outro_cheer_right, {type = "scar_villager", numSquads = 2}, mkr_outro_cheer_04)
