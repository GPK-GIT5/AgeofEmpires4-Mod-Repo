function GetNearRouen_Monitor()
	
	if Prox_ArePlayersNearMarker(player1, mkr_enemy_base_approach, ANY, nil, "gaia", FILTER_REMOVE ) == true then
		--Objective_UpdateText(SOBJ_DestroyRouenWalls, 11172347,11172348, true,true) -- "Breach Rouen's walls" , "Use cannons to breach Rouen's walls"
		Rule_RemoveMe()
		Util_AutoSave(true, true, 30)
		checkWallsID = Rule_AddEGroupEvent(DestroyWallRouen_EntityKill, eg_rouenwalls ,GE_EntityKilled)
		--Rule_Add(PlayerGetsInsideRouenNoDestruction)
		Util_StartIntel(EVENTS.DestroyWalls_IntelStart)
	end
end



function PlayerGetsInsideRouenNoDestruction()
	
	if Prox_ArePlayersNearMarker(player1, mkr_enemy_base_inside_01, ANY ) == true or Prox_ArePlayersNearMarker(player1, mkr_enemy_base_inside_02, ANY ) == true then
		if Objective_IsComplete(SOBJ_DestroyRouenWalls) == false then
			Objective_Fail(SOBJ_DestroyRouenWalls,false,false)
		end
		
		if Objective_IsComplete(SOBJ_GetCannons) == false then
			Objective_Fail(SOBJ_GetCannons,false,false)
		end
		
		DestroyWalls_OnComplete()
		Rule_RemoveEGroupEvent(DestroyWallRouen_EntityKill)
		Rule_RemoveMe()
	end
end


function DestroyWallRouen_EntityKill(context) --Checks to see if the entity killed was the gate and completes the objective
	
	if context.victim ~= nil then
		local victimBP = Entity_GetBlueprint(context.victim)
		if context.killer == nil then
			SGroup_Clear(sg_temp)
			Entity_GetLastAttackers(context.victim,sg_temp,4)
			if SGroup_CountSpawned(sg_temp) >= 1 then
				if SGroup_ContainsBlueprints(sg_temp, SBP.FRENCH.UNIT_CANNON_4_FRE, ANY) == true then
					SGroup_Filter(sg_temp,SBP.FRENCH.UNIT_CANNON_4_FRE, FILTER_KEEP)
					context.killer = SGroup_GetSpawnedSquadAt(sg_temp, 1)
				end
			end
		end
		
		if victimBP == EBP.ENGLISH.BUILDING_DEFENSE_WALL_ENG or victimBP == EBP.ENGLISH.BUILDING_DEFENSE_WALL_GATE_ENG then
		
			if context.killer ~= nil then
				
				if Squad_GetBlueprint(Entity_GetSquad(context.killer)) == SBP.FRENCH.UNIT_CANNON_4_FRE then 
					b_CannonDestroyedWall = true
				end
			end
			
			i_numberWallPieces = i_numberWallPieces + 1
			
			if i_numberWallPieces >= i_numberWallPiecesToDestroy then
				
				CelebrateOnPosition(context.victim, 60)
				Objective_Complete(SOBJ_DestroyRouenWalls)
				Rule_Remove(PlayerGetsInsideRouenNoDestruction)
				Rule_RemoveMe()
				
			end
		end
	end
end -- 

function DestroyWalls_OnComplete()
	
	--[[ only use generic 'breachWall' line.
	
	if b_CannonDestroyedWall == true then
		Util_StartIntel(EVENTS.BreachWall_Cannon)
	else
		Util_StartIntel(EVENTS.BreachWall)
	end
	]]--
	
	Util_StartIntel(EVENTS.BreachWall)
	
	Rule_AddOneShot(StartDestroyLandmarkObj,3)
	Objective_RemoveUIElements(OBJ_RetakeNormandy,hpid_Rouen)
	
	--send reinforcements for city
	if SGroup_CountSpawned(sg_defend_town5) > 0 then
		DissolveModuleIntoModule("enemy_defend_5","enemy_base")
	end
	--send reinforcements for city
	if SGroup_CountSpawned(sg_defend_town4) > 0 then
		DissolveModuleIntoModule("enemy_defend_4","enemy_base")
	end
	
end

function StartDestroyLandmarkObj()
	Objective_Start(SOBJ_DestroyLandmarks)
end


function DestroyLandmarks_UI()
	Player_GetAll(player2, sg_allsquads, eg_enemy_landmarks)
	EGroup_Filter(eg_enemy_landmarks, "landmark", FILTER_KEEP)
	local numberLandmarksDestroyed = i_maxNumberLandmarks - EGroup_CountSpawned(eg_enemy_landmarks)
	
	Objective_SetCounter(SOBJ_DestroyLandmarks, numberLandmarksDestroyed, i_maxNumberLandmarks)
	
	if EGroup_CountSpawned(eg_enemy_landmarks) > 0 then
		
		landmarkUI = Objective_AddUIElements(SOBJ_DestroyLandmarks, eg_enemy_landmarks, true, "$11197408", true, 5)
		Rule_AddEGroupEvent(DestroyRouenLandmark_EntityKill, eg_enemy_landmarks, GE_EntityKilled)
	else
		Objective_Complete(SOBJ_DestroyLandmarks, false)
	end
end


function DestroyRouenLandmark_EntityKill(context) --Checks to see if the entity killed was the gate and completes the objective
	if context.victim ~= nil then
		local victimBP = Entity_GetBlueprint(context.victim)
		
		--if victimBP == EBP.ENGLISH.BUILDING_LANDMARK_AGE1_WESTMINSTER_HALL_ENG or victimBP == EBP.ENGLISH.BUILDING_LANDMARK_AGE2_WHITE_TOWER_ENG or victimBP == EBP.ENGLISH.BUILDING_TOWN_CENTER_CAPITAL_ENG then
			
			if Objective_IsCounterSet(SOBJ_DestroyLandmarks) == true then
				
				Objective_IncreaseCounter(SOBJ_DestroyLandmarks, 1 )
				local numberLandmarksDestroyed = Objective_GetCounter(SOBJ_DestroyLandmarks)
				
				Objective_RemoveUIElements(SOBJ_DestroyLandmarks, landmarkUI)
				landmarkUI = Objective_AddUIElements(SOBJ_DestroyLandmarks, eg_enemy_landmarks, true, "$11197408", true, 5)
				Sound_Play2D("sfx_campaign_scripted_ui_objective_counter_update")
				Sound_Play2D("sfx_campaign_scripted_small_group_celebrate")
				
				if numberLandmarksDestroyed == i_maxNumberLandmarks then
					Objective_Complete(SOBJ_DestroyLandmarks, false)
					Rule_RemoveMe()
				end
				
			end
		
		--end
	end
end

function DestroyLandmarks_OnComplete()
	Objective_Complete(OBJ_RetakeNormandy)
	Sound_Play2D("sfx_campaign_scripted_medium_group_celebrate")
	
end


function RetakeNormandy_OnComplete()
	Sound_Play2D("sfx_campaign_scripted_large_group_celebrate")
	--Music_StopMedium()
	Util_StartIntel(EVENTS.Victory)
end

