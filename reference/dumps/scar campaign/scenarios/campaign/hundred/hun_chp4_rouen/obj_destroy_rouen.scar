function MonitorTown05()
	if EGroup_CountSpawned(eg_defendCity_5) == 0 then
		Rule_RemoveMe()
		defend5VillageDestroyed = true 
		--Util_StartIntel(EVENTS.Village5_Destroyed)
		
		Rule_AddOneShot(SendTown05UnitsOff,10)
	else
		if EGroup_CountSpawned(eg_defendCity_5) == 1 and EGroup_CountSpawned(eg_defendCity_5_TC) > 0 then
			if Villagers05BuildingNow == false then 
				Villagers05BuildingNow = true
				
				if SGroup_CountSpawned(sg_defend5_villager_prodbuilding) < 1 then
					UnitEntry_DeploySquads(player2, sg_defend5_villager_prodbuilding, {{type = "scar_villager", numSquads = 2 }}, mkr_enemy_defend_5_villagers)
				end
				
				Rule_AddOneShot(SendVillagersDefend05_ToBuildProdBuild,15)
				
			end
		end
		
	end
end

function SendVillagersDefend05_ToBuildProdBuild()

	if defend5VillageDestroyed == false then 
		if SGroup_CountSpawned(sg_defend5_villager_prodbuilding) > 0 then
			Cmd_Construct(sg_defend5_villager_prodbuilding, EBP.ENGLISH.BUILDING_UNIT_INFANTRY_CONTROL_ENG, mkr_enemy_defend_5_infantrybuildings, nil, false)
			Cmd_Construct(sg_defend5_villager_prodbuilding, EBP.ENGLISH.BUILDING_UNIT_CAVALRY_CONTROL_ENG, mkr_enemy_defend_5_cavalrybuildings, nil, true)
			
			Rule_AddInterval(MonitorConstructionDefend5, 10)
		else
			Villagers05BuildingNow = false
		end
	end
end

function MonitorConstructionDefend5()

	local eg_player_structures = EGroup_CreateUnique("eg_player_structures")
	
	--EGroup_FilterUnderConstruction
	--Player_HasBuildingUnderConstruction
		
	Player_GetAll(player2, sg_allsquads, eg_player_structures)
	
	--Filter out any non-unit producing structures that aren't fully constructed
	EGroup_Filter(eg_player_structures, "production_building", FILTER_KEEP)
	
	EGroup_FilterUnderConstruction(eg_player_structures, FILTER_KEEP )
	
	
	if EGroup_IsEmpty(eg_player_structures) == true then
		
		Player_GetAllEntitiesNearMarker(player2,eg_temp, mkr_enemy_defend_5)
		EGroup_Filter(eg_temp,EBP.ENGLISH.BUILDING_UNIT_INFANTRY_CONTROL_ENG, FILTER_KEEP)
		
		if EGroup_CountSpawned(eg_temp) > 0 then
			EGroup_Add( eg_defendCity_5, EGroup_GetSpawnedEntityAt(eg_temp,1) )
		end
		
		EGroup_Clear(eg_temp)
		Player_GetAllEntitiesNearMarker(player2,eg_temp, mkr_enemy_defend_5)
		EGroup_Filter(eg_temp,EBP.ENGLISH.BUILDING_UNIT_CAVALRY_CONTROL_ENG, FILTER_KEEP)
		
		if EGroup_CountSpawned(eg_temp) > 0 then
			EGroup_Add( eg_defendCity_5, EGroup_GetSpawnedEntityAt(eg_temp,1) )
		end

		Villagers05BuildingNow = false
		
		Rule_RemoveMe()
	end
		
end



