	--Rule_AddOneShot(ChooseWhereToSendUnitsToPlayer,5)
	
end

function MonitorFirstAttackers()
	
	Player_GetAllSquadsNearMarker(player2, sg_temp, mkr_player_base, 100)
	SGroup_Filter(sg_temp, "scar_villager", FILTER_REMOVE)
	
	if SGroup_CountSpawned(sg_temp) > 0 then
		Rule_RemoveMe()
		Util_StartIntel(EVENTS.FirstWave)
	end
end

function ChooseWhereToSendUnitsToPlayer()
	
	choiceAttack = World_GetRand(1,15)
	
--	choiceAttack = 14 ---- COMMMMMMENT!!!
	
	--PrepareWaves()
	
	if firstAttackDone == false then 
		firstAttackDone = true
		Rule_AddOneShot(StartNextWave,20)

	else
		if choiceAttack <= 5 then --was 5
			Rule_AddOneShot(StartNextWave,LaneTimerTop)
		else 
			if choiceAttack <= 10 then
				Rule_AddOneShot(StartNextWave,LaneTimerMiddle)
			else
				Rule_AddOneShot(StartNextWave, LaneTimerBelow)
			end
		end
	end
end

function PrepareWaves()

	----waves setup from Rouen
	local units01 = {
		{type = "scar_horseman", numSquads = Util_DifVar({5,5,6,10})} -- was 6
	}
			
	local units02 = { 
		{type = "scar_knight", numSquads = Util_DifVar({2,2,3,6})}, -- was 2
		{type = "scar_horseman", numSquads = Util_DifVar({3,3,4,6})}, --was 3
		{type = "scar_manatarms", numSquads = Util_DifVar({2,2,6,6}) }, ---was 3
		{type = "scar_spearman", numSquads = Util_DifVar({4,4,1,1}), difficulty = {GD_EASY, GD_NORMAL} }, --was 3

	}

	local units03 = { 
		{type = "scar_knight", numSquads = Util_DifVar({2,2,2,4})}, --was 2
		{type = "scar_horseman", numSquads = Util_DifVar({1,1,3,6}), difficulty = {GD_HARD, GD_EXPERT} },  --was 3
		{type = "scar_manatarms", numSquads = Util_DifVar({1,1,4,6}), difficulty = {GD_HARD, GD_EXPERT} }, --was 4
		{type = "scar_spearman", numSquads = Util_DifVar({4,4,1,1}), difficulty = {GD_EASY, GD_NORMAL} }, --was 4
		{type = "scar_archer", numSquads = Util_DifVar({4,4,4,6}) }, --was 4

	}
	
	local units04 = { 
		{type = "scar_knight", numSquads = Util_DifVar({3,3,3,5}) }, --was 3 
		{type = "scar_manatarms", numSquads = Util_DifVar({2,2,4,5}) }, --was 4
		{type = "scar_horseman", numSquads = Util_DifVar({3,3,3,5}) }, --was 3
		{type = "scar_crossbowman", numSquads = Util_DifVar({3,3,3,5}) }, --was 3
		{type = "scar_spearman", numSquads = Util_DifVar({3,3,4,5}) }, --was 4

	}
	
	local lane = 1
	moduleUsed = wave_rouen_middle_base
	

	if Objective_IsComplete(SOBJ_DestroyRouenWalls) == false then 
		
		
		if choiceAttack <= 5 then --was 5
			lane = 1
						
			if defend3VillageDestroyed == false then
				
				moduleUsed = wave_defend3_base
				
				units01 = {
					{type = "scar_horseman", numSquads = Util_DifVar({4,4,5,8}) }, --was 5
				}
				
				units02 = { 
					{type = "scar_knight", numSquads = Util_DifVar({2,2,3,4}) }, --was 3
					{type = "scar_horseman", numSquads = Util_DifVar({4,4,5,6}) }, --was 5
				}
				
				units03 = { 
					{type = "scar_knight", numSquads = Util_DifVar({4,4,5,5})}, --was 5
					{type = "scar_horseman", numSquads = Util_DifVar({4,4,5,8}) }, --was 5
				}
				
				units04 = { 
					{type = "scar_knight", numSquads = Util_DifVar({6,6,6,12}) }, --was 10
				}
				
			else
				moduleUsed = wave_rouen_defend3_base
				
			end
		else 
			if choiceAttack <= 10  then
				lane = 2
				
				if defend2VillageDestroyed == false then

					moduleUsed = wave_defend2_base
				
					units01 = {
						{type = "scar_manatarms", numSquads = Util_DifVar({1,1,3,4}), difficulty = {GD_HARD, GD_EXPERT} }, --was 7
						{type = "scar_spearman", numSquads = Util_DifVar({5,5,5,6}) }, --was 7
					}
							
					units02 = { 
						{type = "scar_spearman", numSquads = Util_DifVar({8,8,5,8}) }, --was 5
						{type = "scar_manatarms", numSquads = Util_DifVar({1,1,5,4}), difficulty = {GD_HARD, GD_EXPERT}}, --was 5

					}
				
					units03 = { 
						{type = "scar_manatarms", numSquads = Util_DifVar({2,2,5,6})}, --was 6
						{type = "scar_spearman", numSquads = Util_DifVar({8,8,7,10}) }, --was 6

					}
					
					units04 = { 
						{type = "scar_manatarms", numSquads = Util_DifVar({1,1,6,8}), difficulty = {GD_HARD, GD_EXPERT} }, --was 8
						{type = "scar_spearman", numSquads = Util_DifVar({12,12,8,12}) }, --was 8

					}
					
				elseif defend4VillageDestroyed == false then
					
					moduleUsed = wave_defend4_base

					units01 = {
						{type = "scar_manatarms", numSquads = Util_DifVar({1,1,5,6}), difficulty = {GD_HARD, GD_EXPERT} }, --was 4
						{type = "scar_spearman", numSquads = Util_DifVar({8,8,4,8}) }, --was 4
					}
							
					units02 = { 
						{type = "scar_spearman", numSquads = Util_DifVar({6,6,6,8})}, --was 6
						{type = "scar_archer", numSquads = Util_DifVar({4,4,6,8}) }, --was 6

					}
				
					units03 = { 
						{type = "scar_crossbowman", numSquads = Util_DifVar({5,5,5,10}) }, --was 5
						{type = "scar_spearman", numSquads = Util_DifVar({5,5,7,10}) }, --was 6

					}
					
					units04 = { 
						{type = "scar_manatarms", numSquads = Util_DifVar({2,2,6,8}) }, --was 6
						{type = "scar_spearman", numSquads = Util_DifVar({6,6,5,8}) }, --was 5
						{type = "scar_crossbowman", numSquads = Util_DifVar({4,4,5,8}) }, --was 5
					}
					
				else
					moduleUsed = wave_rouen_middle_base
				end
		
			else
				lane = 3
			
				if defend6VillageDestroyed == false then

					moduleUsed = wave_defend6_base
				
					units01 = {
						{type = "scar_spearman", numSquads = Util_DifVar({6,6,8,8}) }, --was 8
					}
							
					units02 = { 
						{type = "scar_spearman", numSquads = Util_DifVar({8,8,8,8}) }, --was 5
						{type = "scar_manatarms", numSquads = Util_DifVar({1,1,2,4}), difficulty = {GD_HARD, GD_EXPERT} }, --was 5

					}
				
					units03 = { 
						{type = "scar_manatarms", numSquads = Util_DifVar({2,2,4,8}) }, --was 9
						{type = "scar_spearman", numSquads = Util_DifVar({6,6,8,8}) }, --was 6

					}
					
					units04 = { 
						{type = "scar_manatarms", numSquads = Util_DifVar({4,4,6,8}) }, --was 9
						{type = "scar_spearman", numSquads = Util_DifVar({6,6,8,10}) }, --was 9

					}
					
				elseif defend5VillageDestroyed == false then
					
					moduleUsed = wave_defend5_base

					units01 = {
						{type = "scar_horseman", numSquads = Util_DifVar({6,6,8,10}) }, --was 7
					}
					
					units02 = { 
						{type = "scar_spearman", numSquads = Util_DifVar({4,4,6,8}) }, --was 5
						{type = "scar_horseman", numSquads = Util_DifVar({4,4,4,6}) }, --was 6

					}
					
					units03 = { 
						{type = "scar_horseman", numSquads = Util_DifVar({4,4,6,8}) }, --was 6
						{type = "scar_spearman", numSquads = Util_DifVar({6,6,6,8}) }, --was 6
						{type = "scar_manatarms", numSquads = Util_DifVar({2,2,3,4}) }, --was 5

					}
					
					units04 = { 
						{type = "scar_manatarms", numSquads = Util_DifVar({2,2,4,6}) }, --was 6
						{type = "scar_spearman", numSquads = Util_DifVar({6,6,6,8}) }, --was 6
						{type = "scar_knight", numSquads = Util_DifVar({1,1,4,4}) }, --was 5
						{type = "scar_horseman", numSquads = Util_DifVar({3,3,4,6}) }, --was 5
					}
					
				else
					
					moduleUsed = wave_rouen_lower_base
				end
			end
		end	
		
	end
	
	if i_rouen_phase[lane] <= 2 then
		if scartype(moduleUsed) == ST_STRING then
			print(moduleUsed)
		end
		Wave_SetUnits(moduleUsed, units01)
		Wave_Prepare(moduleUsed)
	else
		if i_rouen_phase[lane] <= 6 then 
			Wave_SetUnits(moduleUsed, units02)
			Wave_Prepare(moduleUsed)
				
		else
			if i_rouen_phase[lane] <= 9 then 
								
				Wave_SetUnits(moduleUsed, units03)
				Wave_Prepare(moduleUsed)
			else
				Wave_SetUnits(moduleUsed, units04)
				Wave_Prepare(moduleUsed)
			end
		end
	end
	
	i_rouen_phase[lane] = i_rouen_phase[lane] + 1
	
end

function StartNextWave()
	
	if Objective_IsComplete(SOBJ_DestroyRouenWalls) == true then 
		Rule_RemoveMe()
		print("rouen wall destroyed so stop waves")
	else
		
		if #moduleUsed.queued_waves > 0 then
			if #moduleUsed.queued_waves[1].units == 0 then

				Wave_Launch(moduleUsed)
				Rule_AddOneShot(ChooseWhereToSendUnitsToPlayer,5)
				
			else
				Rule_AddOneShot(retrySendingUnitsWaves,15)
			end
		--else
			--Rule_AddOneShot(ChooseWhereToSendUnitsToPlayer,5)
		end
		
	end
	
end

function retrySendingUnitsWaves()
	Wave_Launch(moduleUsed)
	Rule_AddOneShot(ChooseWhereToSendUnitsToPlayer,5)
end


function FrenchMovesOnTown()

	
	--Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_enemy_base_approach, 160)
	--SGroup_DestroyAllSquads(sg_temp)
	
	Player_GetAll(player2)
	SGroup_DestroyAllSquads(sg_allsquads)
	EGroup_Filter(eg_allentities, BP_GetEntityBlueprint("holy_site"), FILTER_REMOVE)
	EGroup_SetPlayerOwner(eg_allentities, player1)

	sg_outro_parade01 = SGroup_CreateIfNotFound("sg_outro_parade01")
	sg_outro_parade02 = SGroup_CreateIfNotFound("sg_outro_parade02")
	sg_outro_parade03 = SGroup_CreateIfNotFound("sg_outro_parade03")
	sg_outro_parade04 = SGroup_CreateIfNotFound("sg_outro_parade04")
	sg_outro_cheer_right = SGroup_CreateIfNotFound("sg_outro_cheer_right")
	sg_outro_cheer_left = SGroup_CreateIfNotFound("sg_outro_cheer_left")
	sg_outro_cheer_wall = SGroup_CreateIfNotFound("sg_outro_cheer_wall")
	sg_outro_cheer_central = SGroup_CreateIfNotFound("sg_outro_cheer_central")
	sg_outro_eng_flee01 = SGroup_CreateIfNotFound("sg_outro_eng_flee01")
	sg_outro_eng_flee02 = SGroup_CreateIfNotFound("sg_outro_eng_flee02")
	sg_outro_infantry = SGroup_CreateIfNotFound("sg_outro_infantry")
	sg_outro_infantry02 = SGroup_CreateIfNotFound("sg_outro_infantry02")
	sg_outro_infantry03 = SGroup_CreateIfNotFound("sg_outro_infantry03")
	sg_outro_infantry04 = SGroup_CreateIfNotFound("sg_outro_infantry04")
	sg_outro_infantry05 = SGroup_CreateIfNotFound("sg_outro_infantry05")
	sg_outro_infantry06 = SGroup_CreateIfNotFound("sg_outro_infantry06")
	sg_outro_infantry07 = SGroup_CreateIfNotFound("sg_outro_infantry07")
	sg_outro_infantry08 = SGroup_CreateIfNotFound("sg_outro_infantry08")
	
	-- Set fleeing English soldiers to be Neutral so that villagers leave them alone
	Player_SetRelationship(player1, player2, R_NEUTRAL)
	Player_SetRelationship(player2, player1, R_NEUTRAL)
	
	-- ... but that makes them white, so...
	-- Change colour of English raiders to enemy colour
	Game_SetPlayerSlotColour(player2, 2)              -- England
    Game_SetPlayerUISlotColour(player2, 2)
	
	
	-- OLD Parade from top-left of shot to TC
	--[[
	local units_parade01 = {
		{type = "scar_knight", numSquads = 2, spawn = mkr_outro_parade_01, sgroup = sg_outro_parade01},
		{type = "scar_spearman", numSquads = 3, spawn = mkr_outro_parade_02, sgroup = sg_outro_infantry},
		{type = "scar_manatarms", numSquads = 3, spawn = mkr_outro_parade_03, sgroup = sg_outro_infantry},
		{type = "scar_scout", numSquads = 2, spawn = mkr_outro_parade_03a, sgroup = sg_outro_parade01},
	}
	
	local parade01_markers = {
	mkr_outro_parade_03_target,
	}
		
	Util_UnitParade(parade01_markers, units_parade01)
	Modify_UnitSpeed(sg_outro_parade01, 0.2)
	Modify_UnitSpeed(sg_outro_infantry, 0.4)
	--]]
	
	
	-- NEW Parade from top-left of shot to TC
	
	local outro_horse_speed = 0.21
	local outro_man_speed = 0.32
	local outro_man_speed_slow = 0.3
	
	UnitEntry_DeploySquads(player1, sg_outro_parade01, {type = "scar_knight", numSquads = 2}, mkr_outro_parade_03)
	UnitEntry_DeploySquads(player1, sg_outro_infantry, {type = "scar_spearman", numSquads = 4}, mkr_outro_parade_01)
	UnitEntry_DeploySquads(player1, sg_outro_infantry02, {type = "scar_manatarms", numSquads = 2}, mkr_outro_parade_02)
	Cmd_FormationMove(sg_outro_parade01, mkr_outro_parade_03_target)
	Cmd_FormationMove(sg_outro_infantry, mkr_outro_parade_01_target)
	Cmd_FormationMove(sg_outro_infantry02, mkr_outro_parade_02_target)
	Modify_UnitSpeed(sg_outro_parade01, outro_horse_speed)
	Modify_UnitSpeed(sg_outro_infantry, outro_man_speed)
	Modify_UnitSpeed(sg_outro_infantry02, outro_man_speed)
	
	
	-- OLD Parade from right of shot to TC
	--[[
	local units_parade02 = {
		{type = "scar_knight", numSquads = 1, spawn = mkr_outro_parade_04, sgroup = sg_outro_parade02},
		{type = "scar_knight", numSquads = 2, spawn = mkr_outro_parade_05, sgroup = sg_outro_parade02},
		{type = "scar_knight", numSquads = 2, spawn = mkr_outro_parade_06, sgroup = sg_outro_parade02},
		{type = "scar_manatarms", numSquads = 2, spawn = mkr_outro_parade_07, sgroup = sg_outro_infantry02},
		{type = "scar_manatarms", numSquads = 2, spawn = mkr_outro_parade_08, sgroup = sg_outro_infantry02},
		{type = "scar_spearman", numSquads = 3, spawn = mkr_outro_parade_09, sgroup = sg_outro_infantry02},
		{type = "scar_spearman", numSquads = 3, spawn = mkr_outro_parade_10, sgroup = sg_outro_infantry02},
		{type = "scar_archer", numSquads = 2, spawn = mkr_outro_parade_11, sgroup = sg_outro_infantry02},
		{type = "scar_archer", numSquads = 2, spawn = mkr_outro_parade_12, sgroup = sg_outro_infantry02},
	}
	
	local parade02_markers = {
