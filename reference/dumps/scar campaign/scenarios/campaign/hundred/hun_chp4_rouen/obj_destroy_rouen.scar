	Util_UnitParade(parade02_markers, units_parade02)
	Modify_UnitSpeed(sg_outro_parade02, 0.2)
	Modify_UnitSpeed(sg_outro_infantry02, 0.3)
	--]]
	
	-- NEW Parade from right of shot to TC
	
	UnitEntry_DeploySquads(player1, sg_outro_parade02, {type = "scar_knight", numSquads = 1}, mkr_outro_parade_04)
	UnitEntry_DeploySquads(player1, sg_outro_parade03, {type = "scar_knight", numSquads = 1}, mkr_outro_parade_05)
	UnitEntry_DeploySquads(player1, sg_outro_parade04, {type = "scar_knight", numSquads = 1}, mkr_outro_parade_06)
