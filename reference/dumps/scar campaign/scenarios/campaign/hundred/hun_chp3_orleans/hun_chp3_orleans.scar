end

--------------------------------------------------------------------------------------
-------------------------------- WAVE COMPOSITION ------------------------------------
--------------------------------------------------------------------------------------
function Orleans_GetPower(seconds)
	local minutes = seconds/60
	local minutes_capped = math.min(minutes, 71)
	local power = 1500 + (15 * minutes_capped) + ((1/15000) * minutes_capped^4)
	power = power * Util_DifVar({0.8, 1, 1.4, 2})
	return power
end 

--waves have 2 buckets for unit types. regular-units includes all non-siege units, as well as those siege units who are 
--not good vs walls (mangonels, springalds). anti-wall-units includes those siege units who are good vs walls
--(rams, siege-towers, trebuchets)
function Orleans_GetWaveUnits(categories, power_max, lane)
	waves_prepared = waves_prepared + 1
	local power_regular_max = power_max
	local power_anti_wall_max = 0
	local power_regular = 0
	local power_anti_wall = 0
	local unit_type_candidates = {  }
	local chosen_unit_types = {  }
	local units = {}
	local lane_has_siege = false
	
	--determine siege requirements
	if Table_Contains(categories, "siege") then
		Table_RemoveFirstItem(categories, "siege")
		lane_has_siege = true
		power_anti_wall_max = power_max * (1/5)
		power_regular_max = power_max * (4/5)
	end	
	
	if #categories > 0 then
		--get unit_type_candidates, not including siege
		for i, category in ipairs(categories) do
			for i, unit_type in ipairs(category_unit_types[category]) do
				table.insert(unit_type_candidates, unit_type)
			end
		end
		
		--pick 1 unit_type randomly
		local chosen_unit_type = Table_GetRandomItem(unit_type_candidates)
		table.insert(chosen_unit_types, chosen_unit_type)
		--prevent that category from being chosen again, unless there is only 1
		if #categories > 1 then
			for i = #unit_type_candidates, 1, -1 do
				local unit_type = unit_type_candidates[i]
				if unit_type_categories[unit_type] == unit_type_categories[chosen_unit_type] then
					table.remove(unit_type_candidates, i)
				end
			end
		end
		
		--add siege as a valid category if available
		if lane_has_siege then
			table.insert(categories, "siege")
			for i, unit_type in ipairs(category_unit_types["siege"]) do
				table.insert(unit_type_candidates, unit_type)
			end
		end
		
		--pick a 2nd unit_type randomly
		chosen_unit_type = Table_GetRandomItem(unit_type_candidates)
		table.insert(chosen_unit_types, chosen_unit_type)
		Table_RemoveFirstItem(unit_type_candidates, chosen_unit_type)
		
		--add regular units, and keep track of how many siege towers might be useful
		local siege_tower_units = 0
		while power_regular < power_regular_max do
			local max_unit_type_power = power_regular_max - power_regular 
			chosen_unit_type = Orleans_PickUnitType(chosen_unit_types, unit_type_weights_regular, max_unit_type_power)
			if chosen_unit_type == nil then
				break
			end
			power_regular = power_regular + unit_type_power[chosen_unit_type]
			UnitTable_AddUnitsByType(units, chosen_unit_type)
			if unit_type_categories[chosen_unit_type] == "infantry" or unit_type_categories[chosen_unit_type] == "ranged" then
				siege_tower_units = siege_tower_units + 1
			end
		end
		local siege_towers_needed = 0
		if siege_tower_units > 0 then
			siege_towers_needed = 1
		end
		
		--add anti-wall units
		anti_wall_unit_types = { "scar_ram", "scar_siege_tower", "scar_trebuchet_cw" }
		local forced_pick = true --for guaranteeing that atleast 1 anti-wall unit is chosen
		while power_anti_wall < power_anti_wall_max do
			local max_unit_type_power = power_anti_wall_max - power_anti_wall 
			if Table_Contains(anti_wall_unit_types, "scar_siege_tower") and siege_towers_needed == 0 then
				Table_RemoveFirstItem(anti_wall_unit_types, "scar_siege_tower")
			end
			chosen_unit_type = Orleans_PickUnitType(anti_wall_unit_types, unit_type_weights_anti_wall, max_unit_type_power, forced_pick)
			forced_pick = false
			if chosen_unit_type == nil then
				break
			end
			if chosen_unit_type == "scar_siege_tower" then
				siege_towers_needed = siege_towers_needed - 1
			end
			power_anti_wall = power_anti_wall + unit_type_power[chosen_unit_type]
			UnitTable_AddUnitsByType(units, chosen_unit_type)
		end
		
		--top off units with more regular units
		local power_total = power_anti_wall + power_regular
		while power_total < power_max do
			local max_unit_type_power = power_max - power_total
			chosen_unit_type = Orleans_PickUnitType(chosen_unit_types, unit_type_weights_regular, max_unit_type_power)
			if chosen_unit_type == nil then
				break
			end
			power_regular = power_regular + unit_type_power[chosen_unit_type]
			power_total = power_anti_wall + power_regular
			UnitTable_AddUnitsByType(units, chosen_unit_type)
		end
		
		print("wave "..waves_prepared.." prepared at "..orleans_seconds[1].." - lane "..lane.." - power ".. power_total.."/"..power_max)
		--Util_PrintUnitTable(units, 1)
		return units
	else
		return nil
	end
	
end

function Orleans_PickUnitType(unit_types, weight_table, max_power, forced_pick)
	local valid_unit_types_with_weight = {}
	local valid_unit_types = 0
	if forced_pick == true and max_power < unit_type_power["scar_ram"] then
		max_power = unit_type_power["scar_ram"]
	end
	for i, unit_type in ipairs(unit_types) do
		if unit_type_power[unit_type] <= max_power then
			valid_unit_types_with_weight[unit_type] = weight_table[unit_type]
			valid_unit_types = valid_unit_types + 1	
		end
	end
	if valid_unit_types > 0 then
		return Table_GetRandomItemWeighted(valid_unit_types_with_weight)
	else
		return nil
	end
end


--------------------------------------------------------------------------------------
-------------------------------------- UTILITY ---------------------------------------
--------------------------------------------------------------------------------------

function Orleans_OnLaunch(queue_wave, wave)
	waves_launched = waves_launched + 1
	print("wave "..waves_launched.." launched at "..orleans_seconds[1].." - lane "..wave.lane)
end

function Orleans_OnLaunchAmbush(queue_wave, wave)
	print("ambush launched from "..wave.from)
end

function RemoveTownCenterFromCategories(categories)
	for i = #categories, 1, -1 do
		if categories[i] == "town_center" then
			table.remove(categories, i)
		end
	end
end

function Orleans_Autosave(context, data)
	Util_AutoSave(true)
end

function Orleans_GetWaveInterval()
	wave_interval_index = wave_interval_index + 1
	if wave_interval_index > #WAVE_INTERVAL_VARIATION then
		wave_interval_index = 1
	end
	return WAVE_INTERVAL + WAVE_INTERVAL_VARIATION[wave_interval_index]
end
