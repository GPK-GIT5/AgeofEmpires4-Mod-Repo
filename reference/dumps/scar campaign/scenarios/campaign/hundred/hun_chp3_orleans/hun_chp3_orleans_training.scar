
import("training.scar")
import("training/campaigntraininggoals.scar")

function Orleans_AddJoanAbilityHint_Xbox()
	
	local Goal_SelectJoan = Training_Goal(SGroup_GetSpawnedSquadAt(leaderJoan.sgroup, 1),
		{ Message = "$11248635", DataTemplate = "GenericTrainingDataTemplate" }, --Leaders have unique abilities they can activate at any time. Select Jeanne d'Arc to see her special ability.
		UserHasSelectedJoan)
	
	local GoalOnOpenRadial = Training_Goal(
		SGroup_GetSpawnedSquadAt(leaderJoan.sgroup, 1),
		{
			ID = "Hold RT to see Jeanne d'Arc's abilities.",
			Message = "$11248636",
			DataTemplate = "GenericTrainingDataTemplate",
		},
		UserHasOpenedContextualRadial
	)
	
	local Goal_HoverOverAbility = Training_Goal(BP_GetAbilityBlueprint("leader_healing_activated"),
		{ Message = "$11203561", DataTemplate = "RadialTrainingDataTemplate" }, -- Jeanne d'Arc can heal nearby allies.
		Predicate_UserHasLookedAtJoansAbility)
	
	local GoalSequence_LeaderAbility = Training_GoalSequence(
		"joanAbilityGoalSequence", 										-- id
		1, 																	-- repeatMax
		0, 																	-- remindMax
		Predicate_JoanIsAlive, 												-- trigger
		CampaignTraining_TimeoutIgnorePredicate, 							-- ignore
		nil,														 		-- remind
		Predicate_UserHasLookedAtJoansAbility, 								-- bypass
		true, 																-- canRegress
		{Goal_SelectJoan, GoalOnOpenRadial, Goal_HoverOverAbility}							-- goals
	)
	Training_AddGoalSequence(GoalSequence_LeaderAbility)
	
end

function Orleans_AddJoanAbilityHint()
	
	local Goal_SelectJoan = Training_Goal(SGroup_GetSpawnedSquadAt(leaderJoan.sgroup, 1),
		{ Message = "$11203562", DataTemplate = "LeftClickTrainingDataTemplate" }, --Leaders have unique abilities they can activate at any time. Select Jeanne d'Arc to see her special ability.
		UserHasSelectedJoan)
	
	local Goal_HoverOverAbility = Training_Goal(BP_GetAbilityBlueprint("leader_healing_activated"),
		{ Message = "$11203561", DataTemplate = "GenericTrainingDataTemplate" }, -- Jeanne d'Arc can heal nearby allies.
		Predicate_UserHasLookedAtJoansAbility)
	
	local GoalSequence_LeaderAbility = Training_GoalSequence(
		"joanAbilityGoalSequence", 										-- id
		1, 																	-- repeatMax
		0, 																	-- remindMax
		Predicate_JoanIsAlive, 												-- trigger
		CampaignTraining_TimeoutIgnorePredicate, 							-- ignore
		nil,														 		-- remind
		Predicate_UserHasLookedAtJoansAbility, 								-- bypass
		true, 																-- canRegress
		{Goal_SelectJoan, Goal_HoverOverAbility}							-- goals
	)
	Training_AddGoalSequence(GoalSequence_LeaderAbility)
	
end

function UserHasSelectedJoan(goal)
	Misc_GetSelectedSquads(sg_temp, true)
	return SGroup_CountSpawned(leaderJoan.sgroup) >= 1 and SGroup_ContainsSGroup(sg_temp, leaderJoan.sgroup, ALL)
end

function Predicate_UserHasLookedAtJoansAbility(goal)
	local abilityBP = BP_GetAbilityBlueprint("leader_healing_activated")
	return SGroup_CountSpawned(leaderJoan.sgroup) >= 1 and (PredicateHelper_HasUserHoveredOverBP(goal, abilityBP) or training_previousAbilityBlueprint == abilityBP)
	
end

function Predicate_JoanIsAlive(goalSequence)
	return SGroup_CountSpawned(leaderJoan.sgroup) > 0 and SGroup_IsOnScreen(player1, leaderJoan.sgroup, ALL)
end

