	SGroup_DestroyAllSquads(sg_allsquads)
	EGroup_SetPlayerOwner( eg_allentities, player1)
	-- Destroy gate
	eg_formigny_gate = EGroup_CreateIfNotFound("eg_formigny_gate")
	Player_GetAllEntitiesNearMarker(player1, eg_formigny_gate, mkr_outrocam_gate, 5)
	EGroup_DestroyAllEntities(eg_formigny_gate)
	local crowd = {
		{type = "scar_villager", numSquads = 1, spawn = mkr_outrocam_villagers01},
		{type = "scar_villager", numSquads = 3, spawn = mkr_outrocam_villagers02},
