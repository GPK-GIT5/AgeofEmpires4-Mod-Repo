function SpawnPlayerArmy()
	print("SpawnPlayerArmy")
	UnitEntry_DeploySquads(player1, sg_clermont_army, player_units_clermont, mkr_player_sp_pursuit_01_dest)
end

function Transition()
	print("Transition")
	HintPoint_Remove(village_carentan)
	Player_SetPopCapOverride(player1, 200)
	SGroup_DestroyAllSquads(sg_enemy_intro)
	print("transition 1")
	SpawnEnemyArmy()
	print("transition 2")
	SpawnValognesUnits()
	print("transition 3")
	GiveEnemyAmbushVision()
	print("transition 4")
end

function SpawnEnemyArmy() 
	local remaining_archers_halved = math.floor(archer_count_final / 2)
	SpawnRemainingUnits(archers_front, remaining_archers_halved, "scar_archer", sg_first_line)
	
	if archer_count_final % 2 == 1 then
		remaining_archers_halved = remaining_archers_halved + 1
	end
	SpawnRemainingUnits(archers_back, remaining_archers_halved, "scar_archer", sg_second_line)
	SpawnRemainingUnits(spearman_all, spearman_count_final, "scar_spearman", sg_first_line)
	SpawnRemainingUnits(manatarms_all, manatarms_count_final, "scar_manatarms", sg_second_line)
	if Game_GetSPDifficulty() >= GD_HARD then
		Rule_AddOneShot(SetPailingsArchers, 10)
	end
	--print("army_count_final="..army_count_final.."  sg_main_army count="..SGroup_CountSpawned(sg_main_army))
	army_count_final = SGroup_CountSpawned(sg_main_army)
	
	--army_killed_threshold_cannons = math.floor(army_count_final * ARMY_KILLED_RATIO_CANNONS)
	army_killed_threshold_frenzy_start = math.floor(army_count_final * ARMY_KILLED_RATIO_FRENZY_START)
	army_killed_threshold_frenzy_end = math.floor(army_count_final * ARMY_KILLED_RATIO_FRENZY_END)
	army_killed_threshold_retreat = math.floor(army_count_final * ARMY_KILLED_RATIO_RETREAT)
end

function SpawnValognesUnits()
	--enemy
	SpawnUnitsToModule(valogne_units_enemy_cavalry, valogne_enemy_horseman)
	SpawnUnitsToModule(valogne_units_enemy_archers, valogne_enemy_archer)
	SGroup_AddGroups(sg_valogne_enemy, { sg_valogne_enemy_horseman, sg_valogne_enemy_archers })
	valogne_attacker_count_init = SGroup_CountSpawned(sg_valogne_enemy)
	--ally
	SpawnUnitsToModule(valogne_units_horseman, valogne_horseman)
	--SpawnUnitsToModule(valogne_units_archer_1, valogne_archer_1)
	--SpawnUnitsToModule(valogne_units_archer_2, valogne_archer_2)
	--SGroup_AddGroups(sg_valogne, { sg_valogne_horseman, sg_valogne_archer_1, sg_valogne_archer_2 })
	SGroup_AddGroups(sg_valogne, { sg_valogne_horseman })
end

function GiveEnemyAmbushVision()
	FOW_PlayerRevealArea(player2,Marker_GetPosition(mkr_pretown_1_defend_2), Marker_GetProximityRadiusOrDefault(mkr_pretown_1_defend_2, 1),-1)
	FOW_PlayerRevealArea(player2,Marker_GetPosition(mkr_pretown_2_defend_2), Marker_GetProximityRadiusOrDefault(mkr_pretown_2_defend_2, 1),-1)
	FOW_PlayerRevealArea(player2,Marker_GetPosition(mkr_pretown_2_defend_3), Marker_GetProximityRadiusOrDefault(mkr_pretown_2_defend_3, 1),-1)
	FOW_PlayerRevealArea(player2,Marker_GetPosition(mkr_pretown_2_defend_4), Marker_GetProximityRadiusOrDefault(mkr_pretown_2_defend_4, 1),-1)
	FOW_PlayerRevealArea(player2,Marker_GetPosition(mkr_ambush_reveal_1), Marker_GetProximityRadiusOrDefault(mkr_ambush_reveal_1, 1),-1)
	
	FOW_PlayerRevealArea(player3,Marker_GetPosition(mkr_valogne_horseman), Marker_GetProximityRadiusOrDefault(mkr_valogne_horseman, 1),-1)
end

function SpawnRemainingUnits(modules, units_remaining, unit_type, add_to_group)
	local module_count = #modules
	local unit_table_array = {}
	local units_added = 0
	for i = 1, module_count, 1 do
		table.insert(unit_table_array, {})
	end
	while units_added < units_remaining do
		for i = 1, module_count, 1 do
			UnitTable_AddUnitsByType(unit_table_array[i], unit_type)
			units_added = units_added + 1
			if units_added == units_remaining then
				break
			end
		end	
	end
	for i, module in ipairs(modules) do
		local units = unit_table_array[i]
		if #units >= 1 then
			SpawnUnitsToModule(units, module)
			SGroup_AddGroup(add_to_group, module.sgroup)
			SGroup_AddGroup(sg_main_army, module.sgroup)
		end
	end
end

function SetPailingsArchers()
	for i, module in ipairs(archers_all) do
		Cmd_Ability(module.sgroup, BP_GetAbilityBlueprint("deploy_palings"))
	end
end

