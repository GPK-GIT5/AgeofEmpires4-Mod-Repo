function Mission_SetupPlayers()
	player1 = World_GetPlayerAt(1) 
	player2 = World_GetPlayerAt(2)
	player3 = World_GetPlayerAt(3) 
	player4 = World_GetPlayerAt(4)

	Setup_SetPlayerName(player1, Loc_GetString("$11172280")) -- France
	Player_SetCurrentAge(player1, AGE_IMPERIAL)
	Player_SetMaximumAge(player1, AGE_IMPERIAL)

	Setup_SetPlayerName(player2, Loc_GetString("$11172281")) -- England
	Player_SetCurrentAge(player2, AGE_IMPERIAL)
	Player_SetMaximumAge(player2, AGE_IMPERIAL)
	
	Setup_SetPlayerName(player3, Loc_GetString("$11172280")) -- France
	Player_SetCurrentAge(player3, AGE_IMPERIAL)
	Player_SetMaximumAge(player3, AGE_IMPERIAL)
	
	Setup_SetPlayerName(player4, Loc_GetString("$11190004")) -- Breton
	Player_SetCurrentAge(player4, AGE_IMPERIAL)
	Player_SetMaximumAge(player4, AGE_IMPERIAL)
	
	Player_SetRelationship(player3, player1, R_ALLY)
	Player_SetRelationship(player1, player3, R_ALLY)
	Player_SetRelationship(player3, player2, R_ENEMY)
	Player_SetRelationship(player2, player3, R_ENEMY)
	Player_SetRelationship(player4, player1, R_ALLY)
	Player_SetRelationship(player1, player4, R_ALLY)
	Player_SetRelationship(player4, player2, R_ENEMY)
	Player_SetRelationship(player2, player4, R_ENEMY)
	Player_SetRelationship(player3, player4, R_ALLY)
	Player_SetRelationship(player4, player3, R_ALLY)
	
	PlayerColour_Enable()		
	Game_SetPlayerSlotColour(player1, 1) --player
	Game_SetPlayerUISlotColour(player1, 1) 
	Game_SetPlayerSlotColour(player2, 2) --enemy french villagers    
	Game_SetPlayerUISlotColour(player2, 2) 
	Game_SetPlayerSlotColour(player3, 3) --allies 
	Game_SetPlayerUISlotColour(player3, 3) 
	Game_SetPlayerSlotColour(player4, 3 ) -- player ally  
	Game_SetPlayerUISlotColour(player4, 3 ) 
end

function Mission_SetupVariables()
	Formigny_InitData1()
end

function Mission_SetRestrictions()
	--Player_SetPopCapOverride(player1, 180)
end

function Mission_Preset()
	Formigny_InitData2()
	
	UI_SetPlayerDataContext(player1, { PopulationCapOn = false })
	
	local cannon_range_buff = Modifier_Create(MAT_WeaponType, "range_weapon_modifier", MUT_Multiplication, false, 1.1, BP_GetWeaponBlueprint("weapon_cannon_4_form_fre"))
	Modifier_ApplyToPlayer(cannon_range_buff, player1, 0)
	local ribauldequin_range_buff = Modifier_Create(MAT_WeaponType, "range_weapon_modifier", MUT_Multiplication, false, 1.5, BP_GetWeaponBlueprint("weapon_ribauldequin_4_form_fre"))
	Modifier_ApplyToPlayer(ribauldequin_range_buff, player1, 0)
	local monk_speed_buff = Modifier_Create(MAT_EntityType, "speed_maximum_modifier", MUT_Multiplication, false, 1.285, EBP.FRENCH.UNIT_MONK_3_FRE)
	Modifier_ApplyToPlayer(monk_speed_buff , player1, 0)
	local manatarms_speed_nerf= Modifier_Create(MAT_EntityType, "speed_maximum_modifier", MUT_Multiplication, false, 0.885, EBP.ENGLISH.UNIT_MANATARMS_4_ENG)
	Modifier_ApplyToPlayer(manatarms_speed_nerf , player2, 0)
	local spearman_speed_nerf = Modifier_Create(MAT_EntityType, "speed_maximum_modifier", MUT_Multiplication, false, 0.8, EBP.ENGLISH.UNIT_SPEARMAN_4_ENG)
	Modifier_ApplyToPlayer(spearman_speed_nerf , player2, 0)
	
	Player_GetAll(player2)
    EGroup_Filter(eg_allentities, EBP.ENGLISH.BUILDING_DEFENSE_OUTPOST_ENG, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	
	Player_GetAll(player3)
    EGroup_Filter(eg_allentities, EBP.FRENCH.BUILDING_DEFENSE_OUTPOST_FRE, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	
	PlayerUpgrades_Auto(player1, false, { UPG.FRENCH.UPGRADE_RANGED_INCENDIARY_FRE })
	PlayerUpgrades_LearnAllUnits(player1, 4, {}, Player_GetRaceName(player1))
	PlayerUpgrades_Auto(player2, false, { UPG.COMMON.UPGRADE_RANGED_DAMAGE_II, UPG.COMMON.UPGRADE_MELEE_DAMAGE_II, UPG.COMMON.UPGRADE_MELEE_ARMOR_III, UPG.COMMON.UPGRADE_MELEE_DAMAGE_III, UPG.COMMON.UPGRADE_RANGED_ARMOR_III, UPG.COMMON.UPGRADE_RANGED_DAMAGE_III, UPG.COMMON.UPGRADE_TECH_UNIVERSITY_MURDER_HOLES_4, UPG.COMMON.UPGRADE_MANATARMS_ELITE_ARMY_TACTICS})
	PlayerUpgrades_Auto(player3, false, { UPG.COMMON.UPGRADE_MELEE_ARMOR_III, UPG.COMMON.UPGRADE_MELEE_DAMAGE_III, UPG.COMMON.UPGRADE_RANGED_ARMOR_III, UPG.COMMON.UPGRADE_RANGED_DAMAGE_III })
	PlayerUpgrades_Auto(player4, false, { UPG.COMMON.UPGRADE_MELEE_ARMOR_III, UPG.COMMON.UPGRADE_MELEE_DAMAGE_III, UPG.COMMON.UPGRADE_RANGED_ARMOR_III, UPG.COMMON.UPGRADE_RANGED_DAMAGE_III })
	
	Player_SetAbilityAvailability(player1, BP_GetAbilityBlueprint("monastery_create_relic"), ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_UNIT_RELIGIOUS_TITHE_BARN_4, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_SIEGE_CHEMISTRY, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_SIEGE_ADJUSTABLE_CROSSBAR, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_TECH_UNIVERSITY_ARCHITECTURE_4, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_SIEGE_WORKS, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_UNIT_RELIGIOUS_PIETY_4, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_MANATARMS_ELITE_ARMY_TACTICS, ITEM_REMOVED)

	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_SIEGE_ROLLER_TRIGGER, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.FRENCH.UNIT_TRADE_CART_FRE, ITEM_REMOVED)
	
	InitObjectives_IntroObjectives()
	InitObjectives_ClearNormandy()
	InitObjectives_SaveValognes()
	InitObjectives_CaptureFormigny()
	
	SetupIntroUnitsEnemy()
	Rule_AddOneShot(IntroMovePlayerUnits, 16)
	
	Player_SetResource( player1, RT_Gold, 0)
	Player_SetResource( player1, RT_Wood, 0)
	Player_SetResource( player1, RT_Food, 0)
	
	local gold_chest_markers = AllMarkers_FromName("mkr_gold_chest", "")
	for i, marker in ipairs(gold_chest_markers) do
		Missionomatic_SpawnPickup(marker, "gold", 200)
	end
end

function Mission_SetDifficulty()
end

function Mission_Start()	-- this is triggered after the intro, just as control is passed to the player
	-- on console don't restore VPS as we have no villagers
	Cardinal_EnablePartialXboxUI(true, {VF_XboxUIVillagerPriorities})

	village_carentan = HintPoint_Add(mkr_carentan, true, "$11172345", LOCATION_LABEL_HEIGHT) --"Carentan"
	village_bricquebec = HintPoint_Add(mkr_town_1_hintpoint, true, "$11172292", LOCATION_LABEL_HEIGHT) --BricQuebec
	village_stsauveur = HintPoint_Add(mkr_town_2_hintpoint, true, "$11172294", LOCATION_LABEL_HEIGHT) --"Saint-Sauveur de Vicomte"
	village_formigny = HintPoint_Add(mkr_formigny_hintpoint, true, "$11172298", LOCATION_LABEL_HEIGHT) --Formigny

	Objective_Start(OBJ_DefendCarentan)
	
	Player_SetPopCapOverride(player2, 1000)
	Sound_SetMinimumMusicCombatIntensity(801, 0)
	
	Rule_AddGlobalEvent(Achievement_OnCannonDeath, GE_SquadKilled)
	Player_SetResource( player1, RT_Gold, 0)
	Player_SetResource( player1, RT_Wood, 0)
	Player_SetResource( player1, RT_Food, 0)
	Rule_AddOneShot(PutEnemiesIntoModules, 0.1)
	
	Rule_AddInterval(CheckForFinalFight, 1)
	
	
end

