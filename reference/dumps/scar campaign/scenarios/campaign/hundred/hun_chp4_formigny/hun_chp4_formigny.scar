		{type = "scar_villager", numSquads = 2, spawn = mkr_outrocam_villagers04},
		{type = "scar_villager", numSquads = 5, spawn = mkr_outrocam_villagers05},
		{type = "scar_villager", numSquads = 3, spawn = mkr_outrocam_villagers06},
		{type = "scar_villager", numSquads = 2, spawn = mkr_outrocam_villagers07},
		{type = "scar_villager", numSquads = 3, spawn = mkr_outrocam_villagers08},
		{type = "scar_villager", numSquads = 4, spawn = mkr_outrocam_villagers09},
		{type = "scar_monk", numSquads = 1, spawn = mkr_outrocam_villagers10},
		{type = "scar_villager", numSquads = 1, spawn = mkr_outrocam_villagers11},
	}
		
	UnitEntry_DeploySquads(player1, sg_outro_cheer, crowd)
	SGroup_EnableCheering(sg_outro_cheer, true, -1, WALLA_CAMP_CELEBRATE_LARGE)
	
	local parade_markers = {
		mkr_outrocam_Formigny_dest01,
		mkr_outrocam_Formigny_dest02,
		--mkr_outrocam_Formigny_dest03,
		mkr_outrocam_Formigny_dest04,
		mkr_outrocam_Formigny_dest05,
		mkr_outrocam_Formigny_dest06,
		mkr_outrocam_Formigny_dest07,
	}
	local units = {
		{sbp = SBP.FRENCH.UNIT_KNIGHT_4_FRE, numSquads = 2, spawn = mkr_outrocam_Formigny_unitsenter02},
		{sbp = SBP.FRENCH.UNIT_KNIGHT_4_FRE, numSquads = 2, spawn = mkr_outrocam_Formigny_unitsenter03},
		{sbp = SBP.FRENCH.UNIT_KNIGHT_4_FRE, numSquads = 2, spawn = mkr_outrocam_Formigny_unitsenter04},
		{sbp = SBP.FRENCH.UNIT_KNIGHT_3_FRE, numSquads = 2, spawn = mkr_outrocam_Formigny_unitsenter05},
		{sbp = SBP.FRENCH.UNIT_KNIGHT_3_FRE, numSquads = 2, spawn = mkr_outrocam_Formigny_unitsenter06},
		{sbp = SBP.FRENCH.UNIT_KNIGHT_3_FRE, numSquads = 2, spawn = mkr_outrocam_Formigny_unitsenter07},
		{sbp = SBP.FRENCH.UNIT_KNIGHT_2_FRE, numSquads = 2, spawn = mkr_outrocam_Formigny_unitsenter08},
		{sbp = SBP.FRENCH.UNIT_KNIGHT_2_FRE, numSquads = 2, spawn = mkr_outrocam_Formigny_unitsenter09},
	}
	Util_UnitParade (parade_markers, units, sg_parade_outro)
	Modify_UnitSpeed(sg_parade_outro, 0.5)

end

-- Achievement tracking for Achievement #16 - Careful Cannons - Win Formigny without losing any cannons
function Achievement_OnCannonDeath(context)
	if Squad_IsValid(Squad_GetID(context.victim)) then
		if not World_OwnsSquad(context.victim) then
			local owner = Squad_GetPlayerOwner(context.victim)
			if owner == player1 and Squad_IsOfType(context.victim, "cannon") then
				cannon_has_been_lost = true
				Rule_RemoveMe()	
			end
		end
	end
end

function CheckAchievementCompletion()
	if cannon_has_been_lost == false then
		Game_SendCustomChallengeEvent(player1, CE_ACHIEVALLCANNONSSURVIVEFORMIGNY, 1)
	end	
	
	if Game_GetSPDifficulty() >= GD_HARD then
		Game_SendCustomChallengeEvent(player1,CE_FORMIGNYVICTORYHARD, 1)
	end
	
end
