function SpawnUnitsAndMoveAlongPath(player, units, sgroup, path_marker_name, path_start_index, path_index_end)
	local markers = AllMarkers_FromName(path_marker_name, "")
	local sgroup = sgroup
	if sgroup == nil then
		SGroup_Clear(sg_temp)
		sgroup = sg_temp
	end
	UnitEntry_DeploySquads(player, sgroup, units, markers[path_start_index])  	
	MarkerPaths_MoveSGroupAlongPath(sgroup, path_marker_name, "", path_start_index + 1, path_index_end)
end

function StartIntroSkipped()
	intro_was_skipped = true
	--enemy
	WarpSgroupToPathMarker(sg_enemy_intro_1, "mkr_intro_path_1", 0)
	WarpSgroupToPathMarker(sg_enemy_intro_2, "mkr_intro_path_1", 2)
	WarpSgroupToPathMarker(sg_enemy_intro_3, "mkr_intro_path_1", 4)
	WarpSgroupToPathMarker(sg_enemy_intro_4, "mkr_intro_path_1", 6)
	WarpSgroupToPathMarker(sg_enemy_intro_5, "mkr_intro_path_1", 8)
	WarpSgroupToPathMarker(sg_enemy_intro_6, "mkr_intro_path_2", 0)
	WarpSgroupToPathMarker(sg_enemy_intro_7, "mkr_intro_path_2", 2)
	WarpSgroupToPathMarker(sg_enemy_intro_8, "mkr_intro_path_2", 4)
	WarpSgroupToPathMarker(sg_enemy_intro_9, "mkr_intro_path_2", 6)
	WarpSgroupToPathMarker(sg_enemy_intro_10, "mkr_intro_path_2",8)
	for i, sgroup in ipairs(intro_sgroups) do
		Cmd_Stop(sgroup)
	end
	--player
	SGroup_FormationWarpToMarker(sg_intro_player_units_01, mkr_player_intro_unit_01_dest)
	SGroup_FormationWarpToMarker(sg_intro_player_units_02, mkr_player_intro_unit_02_dest)
	SGroup_FormationWarpToMarker(sg_intro_player_units_03, mkr_player_intro_unit_03_dest)
end

function WarpSgroupToPathMarker(sgroup, path_marker_name, negative_index)
	local markers = AllMarkers_FromName(path_marker_name, "")
	local marker_count = #markers
	SGroup_FormationWarpToMarker(sgroup, markers[marker_count - negative_index])
end

function IntroMovePlayerUnits()
	if intro_was_skipped == false then		
		Cmd_FormationMove(sg_intro_player_units_01, mkr_player_intro_unit_01_dest, false, false, Util_GetFacingFromDirection(Marker_GetPosition(mkr_player_intro_unit_01_dest), Marker_GetDirection(mkr_player_intro_unit_01_dest)))
		Cmd_FormationMove(sg_intro_player_units_02, mkr_player_intro_unit_02_dest, false, false, Util_GetFacingFromDirection(Marker_GetPosition(mkr_player_intro_unit_02_dest), Marker_GetDirection(mkr_player_intro_unit_02_dest)))
		Cmd_FormationMove(sg_intro_player_units_03, mkr_player_intro_unit_03_dest, false, false, Util_GetFacingFromDirection(Marker_GetPosition(mkr_player_intro_unit_03_dest), Marker_GetDirection(mkr_player_intro_unit_03_dest)))
	end
end

function PutEnemiesIntoModules()
	for i, sgroup in ipairs(intro_sgroups) do
		local module = intro_armies[i]
		RovingArmy_AddSGroup(module, sgroup)
	end
end

function FindNewTargetForModule(module)
	if SGroup_CountSpawned(sg_intro_player_units) > 0 then
		local closest_squad = SGroup_GetClosestSquad(sg_intro_player_units, SGroup_GetPosition(module.sgroup))
		RovingArmy_SetTarget(module, Squad_GetPosition(closest_squad))
	end
end

