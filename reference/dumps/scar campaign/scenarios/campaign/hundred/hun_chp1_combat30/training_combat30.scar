--
-- Combat of the Thirty - Training Goals
--

import("training/campaigntraininggoals.scar")

----------------------------------
-- Utility Functions
----------------------------------

function _DelayTimeElapsed(goal)
	local currentTime = Timer_GetElapsed(goal.timerID)
	
	if currentTime >= __t_trainingModerateInterval then
		return true
	end
end


----------------------------------
-- View Beaumanoir Leader Aura
----------------------------------

function MissionTutorial_BeaumanoirAura_Xbox()
	
	local general_aura_attack = "general_aura_attack"
	
	if SGroup_CountSpawned(g_leaderBeaumanoir.sgroup) >= 1 and Player_OwnsSGroup(player1, g_leaderBeaumanoir.sgroup, ALL) then 
		
		local Goal_SelectJean = Training_Goal(
			SGroup_GetSpawnedSquadAt(g_leaderBeaumanoir.sgroup, 1),
			{
				ID = "Leaders have unique abilities they can activate at any time. Use D-Pad Right to Select Jean de Beaumanoir.",
				Message = "$11248623",
				DataTemplate = "GenericTrainingDataTemplate",
			},
			Predicate_UserHasSelectedJean
		)
		
		local GoalOnOpenRadial = Training_Goal(
			SGroup_GetSpawnedSquadAt(g_leaderBeaumanoir.sgroup, 1),
			{
				ID = "Hold RT to see Jean de Beaumanoir's abilities.",
				Message = "$11248624",
				DataTemplate = "GenericTrainingDataTemplate",
			},
			UserHasOpenedContextualRadial
		)
		
		local Goal_HoverOverAbility = Training_Goal(
			BP_GetAbilityBlueprint("leader_attack_speed_activated_lowcd"),
			{
				ID = "Jean de Beaumanoir can improve the attack speed of nearby allies",
				Message = "$11199258",
				DataTemplate = "RadialTrainingDataTemplate",
			},
			Predicate_UserHasLookedAtJeanAbility
		)
		
		local GoalSequence_LeaderAbility = Training_GoalSequence(
			general_aura_attack, 												-- id
			1, 																	-- repeatMax
			0, 																	-- remindMax
			Predicate_UserHasNotActivatedJeanLeaderAbilityRecently, 			-- trigger
			CampaignTraining_TimeoutIgnorePredicate, 							-- ignore
			nil,														 		-- remind
			Predicate_UserHasLookedAtJeanAbility, 		 						-- bypass
			true, 																-- canRegress
			{Goal_SelectJean, GoalOnOpenRadial, Goal_HoverOverAbility}							-- goals
		)
		Training_AddGoalSequence(GoalSequence_LeaderAbility)
		
		
	end
	
end

function MissionTutorial_BeaumanoirAura()
	
	local general_aura_attack = "general_aura_attack"
	
	if SGroup_CountSpawned(g_leaderBeaumanoir.sgroup) >= 1 and Player_OwnsSGroup(player1, g_leaderBeaumanoir.sgroup, ALL) then 
		
		local Goal_SelectJean = Training_Goal(
			SGroup_GetSpawnedSquadAt(g_leaderBeaumanoir.sgroup, 1),
			{
				ID = "Leaders have unique abilities they can activate at any time. Select Jean de Beaumanoir to see his special ability.",
				Message = "$11202647",
				DataTemplate = "LeftClickTrainingDataTemplate",
			},
			Predicate_UserHasSelectedJean
		)
		local Goal_HoverOverAbility = Training_Goal(
			BP_GetAbilityBlueprint("leader_attack_speed_activated_lowcd"),
			{
				ID = "Jean de Beaumanoir can improve the attack speed of nearby allies",
				Message = "$11199258",
				DataTemplate = "GenericTrainingDataTemplate",
			},
			Predicate_UserHasLookedAtJeanAbility
		)
		
		local GoalSequence_LeaderAbility = Training_GoalSequence(
			general_aura_attack, 												-- id
			1, 																	-- repeatMax
			0, 																	-- remindMax
			Predicate_UserHasNotActivatedJeanLeaderAbilityRecently, 			-- trigger
			CampaignTraining_TimeoutIgnorePredicate, 							-- ignore
			nil,														 		-- remind
			Predicate_UserHasLookedAtJeanAbility, 		 						-- bypass
			true, 																-- canRegress
			{Goal_SelectJean, Goal_HoverOverAbility}							-- goals
		)
		Training_AddGoalSequence(GoalSequence_LeaderAbility)
		
		
	end
	
end

function Predicate_UserHasSelectedJean(goal)
	
	Misc_GetSelectedSquads(sg_temp, true)
	return SGroup_CountSpawned(g_leaderBeaumanoir.sgroup) >= 1 and SGroup_ContainsSGroup(sg_temp, g_leaderBeaumanoir.sgroup, ALL)
	
end

function Predicate_UserHasLookedAtJeanAbility(goal)
	
	local abilityBP = BP_GetAbilityBlueprint("leader_attack_speed_activated_lowcd")
	return SGroup_CountSpawned(g_leaderBeaumanoir.sgroup) >= 1 and (PredicateHelper_HasUserHoveredOverBP(goal, abilityBP) or training_previousAbilityBlueprint == abilityBP)
	
end

function Predicate_UserHasNotActivatedJeanLeaderAbilityRecently(goalSequence)
	
	return SGroup_CountSpawned(g_leaderBeaumanoir.sgroup) >= 1 and Player_OwnsSGroup(player1, g_leaderBeaumanoir.sgroup, ALL)
	
end

