----------------------------------
-- Blacksmith
----------------------------------


function MissionTutorial_Combat30Blacksmith()
	
	local goal_blacksmith = "goal_blacksmith"
		
	local viewSquad = Training_Goal("Entity", 
		{Message="$11199263", DataTemplate="GenericTrainingDataTemplate"},
		_DelayTimeElapsed)
	Combat30Blacksmith_GoalSequence = Training_GoalSequence(goal_blacksmith, 
		1, 1, --repeat max and remind max
		_HasBlacksmithOnScreen, --trigger
		UserCannotSeeEntityKey, --ignore
		nil, --remind
		nil, --bypass 
		false, --can regress
		{viewSquad, viewSquad2})
	
	Training_AddGoalSequence(Combat30Blacksmith_GoalSequence)
end

function _HasBlacksmithOnScreen (goalSequence)
		
	if AShortPeriodOfTimeHasPassed(goalSequence) then
		
		
		local potentialEntity_eid = nil
		
		local _CheckEntityIsOnScreen = function(gid, idx, eid)
			if Misc_IsEntityOnScreen(eid, 0.8) then
				potentialEntity_eid = eid
				return true
			end
		end
		EGroup_ForEach(eg_fre_production, _CheckEntityIsOnScreen)
		
		if potentialEntity_eid ~= nil then 
			
			goalSequence.goals[1].key = Entity_GetID(potentialEntity_eid)

			return true
			
		end
		
	end
end