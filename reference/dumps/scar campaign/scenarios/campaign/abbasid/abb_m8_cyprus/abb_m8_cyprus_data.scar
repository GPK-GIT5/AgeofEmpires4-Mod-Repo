				{type = "scar_ribauldequin", numSquads = t_difficulty.nicosia_army_ribauldequinAmount},
				{type = "scar_trebuchet", numSquads =  t_difficulty.nicosia_army_mangosAmount},
			},
			{ -- boss wave
				{type = "scar_knight", numSquads = t_difficulty.num_12_to_20},
				{type = "scar_manatarms", numSquads = t_difficulty.num_12_to_20},
				{type = "scar_handcannon", numSquads = t_difficulty.num_12_to_20},
				{type = "scar_springald", numSquads =  t_difficulty.nicosia_army_springsAmount},
				{type = "scar_cannon", numSquads = t_difficulty.nicosia_army_cannonsAmount},
			},
		},
		-------------
		--DEFENDERS--
		-------------
		NICOSIA_DEFENDERS = {
			WALL_LINE = {
				{type = "scar_archer", numSquads = t_difficulty.nicosia_wall_archerAmount},
				{type = "scar_handcannon", numSquads = t_difficulty.nicosia_wall_handcannonAmount},
			},
		},
		
		FAMAGUSTA_DEFENDERS = {
			WALL_LINE = {
				{sbp = SBP.CRUSADER_CMP.UNIT_GENOESE_CROSSBOWMAN_CRU, numSquads = t_difficulty.famagusta_wall_xbowAmount},
			},
			PATROL = {
				{type = "scar_horseman", numSquads = t_difficulty.famagusta_horsie_patrol_amount},
				{type = "scar_knight", numSquads = t_difficulty.famagusta_knight_patrol_amount},
			},
		},
		LIMASSOL_DEFENDERS = {
			CAPTURE = {
				{type = "scar_crossbowman", numSquads = t_difficulty.limassol_defenders_xbowsAmount},
			},					
			HORSIES = {
				{type = "scar_horseman", numSquads = t_difficulty.limassol_defenders_horsiesAmount}, 
			},					
			ANTISHIP = {
				{type = "scar_spearman", numSquads = t_difficulty.limassol_defenders_spearsAmount},
				{type = "scar_springald", numSquads = t_difficulty.limassol_defenders_springsAmount},
			},			
			ANTIINFANTRY = {
				{type = "scar_archer", numSquads = t_difficulty.limassol_defenders_archersAmount},
				{type = "scar_spearman", numSquads = t_difficulty.limassol_defenders_spearsAmount},
			},
		},
		
		---------------
		--NAVAL UNITS--
		---------------		
		FAMAGUSTA_NAVY = {
			--------------------------
			--STATICALLY PLACED NAVY--
			--------------------------
			DEFENCE = {
