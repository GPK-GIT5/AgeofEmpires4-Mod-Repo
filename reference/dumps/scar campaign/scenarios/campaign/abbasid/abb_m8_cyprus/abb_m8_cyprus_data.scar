function Cyprus_EnemyMarkerData()
	
	intro_transport_markers = AllMarkers_FromName("mkr_allied_troop_transport_spawn","")
	
	limassol_defence_melee_markers = AllMarkers_FromName("mkr_limassol_defence_melee", "")
	limassol_defence_horsie_markers = AllMarkers_FromName("mkr_limassol_defence_horsies", "")
	limassol_defence_antiinfantry_markers = AllMarkers_FromName("mkr_limassol_defence_antiinfantry", "")
	
	famagusta_navy_defence_markers = AllMarkers_FromName ("mkr_famagusta_navy_defence", "")
	famagusta_navy_patrol_markers = AllMarkers_FromName("mkr_famagusta_navy_patrol", "")
	
	enemy_prison_guards_markers = AllMarkers_FromName("mkr_prison_guards", "")
	
end


