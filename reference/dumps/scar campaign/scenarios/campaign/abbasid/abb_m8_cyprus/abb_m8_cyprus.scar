function Init_Famagusta_Patrols()
	local famagustaPatrolsParams = {
		player = player5,
		name = "famagusta_patrol",
		targetOrder = TARGET_ORDER_RANDOM,
		combatRangeEnRoute = 50,
		spawn = mkr_famagusta_patrol_spawn,
		marker = mkr_famagusta_patrol_spawn,
		--sgroup = data.sgroup,
		units = CYPRUS_UNITS.FAMAGUSTA_DEFENDERS.PATROL,
		targets = CYPRUS_MARKER_LOCATIONS.FAMAGUSTA_PATROLS
	}
	Army_Init(famagustaPatrolsParams)
end
------------------
--FAMAGUSTA NAVY--
------------------
function Spawn_Navy_Raids() -- FAMAGUSTA NAVY SPAWNS TO RAID THE PLAYER HERE.

	local raid_table = Table_GetRandomItem(CYPRUS_UNITS.FAMAGUSTA_NAVY_RAIDERS)
	BuildingTrainer_TrainUnits(Unit_Trainer_Famagusta_Navy, raid_table, 0, Famagusta_Navy_Raids_OnSpawn, Famagusta_Navy_Raids_OnComplete, nil)
end
		
function Famagusta_Navy_Raids_OnSpawn(context, data)
	SGroup_Single(sg_single, context.unit)
	SGroup_AttackMove(sg_single, mkr_famagusta_navy_raid_muster)
end
		
function Famagusta_Navy_Raids_OnComplete(context, data)
	local sgroup = SGroup_CreateUniqueWithPrefix("sg_famagusta_navy_on_complete")
	SGroup_AddGroup(sgroup, context.sgroup)
	Rule_AddOneShot(Famagusta_Navy_Raids_Launch_Attack, 30, {sgroup = sgroup})
end

function Famagusta_Navy_Raids_Launch_Attack(context, data)
			
	navalRaidInterval = navalRaidInterval or 0
	navalRaidInterval = navalRaidInterval + 1
	
	local famagustaNavyAttackWaveParams = {
		player = player5,
		name = "naval_raid_wave_"..navalRaidInterval,
		targetOrder = TARGET_ORDER_PATROL,
		holdPositionWhileWaiting = false,
		sgroup = data.sgroup,
		targets = {mkr_naval_raid_dest1, mkr_naval_raid_dest2, mkr_naval_raid_dest3, mkr_naval_raid_dest4, mkr_naval_raid_dest5, mkr_naval_raid_dest6},
	}
	table.insert(naval_armies, NavalArmy_Init(famagustaNavyAttackWaveParams))
end


--? @shortdesc Handles events associated with any squad deaths
function Cyprus_CheckSquadDeath(context)
	
	local victim = context.victim
	
	if Squad_IsOfType(victim, "naval_unit") then
		
		if Squad_GetPlayerOwner(victim) == player5 then
			
			if World_GetRand(1,100) < t_difficulty.navalLootChance then
				
				local position = Squad_GetPosition(victim)
				local pickup = BP_GetEntityBlueprint(CYPRUS_NAVAL_LOOT_TABLE[naval_loot_index])
				Util_CreateEntities(nil, nil, pickup, position, 1, nil, true)
				
				naval_loot_index = naval_loot_index + 1
				if naval_loot_index > #CYPRUS_NAVAL_LOOT_TABLE then
					naval_loot_index = 1
				end
				
				naval_loot_count = naval_loot_count + 1
				if naval_loot_count >= naval_loot_cap then
					Rule_RemoveMe()
				end
			end
		end
	end
end


