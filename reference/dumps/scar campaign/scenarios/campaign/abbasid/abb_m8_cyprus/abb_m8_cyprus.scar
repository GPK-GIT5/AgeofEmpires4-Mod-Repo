	Player_SetRelationship(player6, player8, R_ALLY)
	
	Player_SetRelationship(player7, player1, R_ENEMY)
	Player_SetRelationship(player7, player2, R_ALLY)
	Player_SetRelationship(player7, player3, R_ALLY)
	Player_SetRelationship(player7, player4, R_ENEMY)
	Player_SetRelationship(player7, player5, R_ALLY)
