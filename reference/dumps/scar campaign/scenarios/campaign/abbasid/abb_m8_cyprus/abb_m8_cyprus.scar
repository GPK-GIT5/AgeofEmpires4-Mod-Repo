	Player_SetRelationship(player5, player1, R_ENEMY)
	Player_SetRelationship(player5, player2, R_ALLY)
	Player_SetRelationship(player5, player3, R_ALLY)
	Player_SetRelationship(player5, player4, R_ENEMY)
	Player_SetRelationship(player5, player6, R_ALLY)
