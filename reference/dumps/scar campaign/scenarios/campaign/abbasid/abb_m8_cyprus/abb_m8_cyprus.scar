function Mission_SetupPlayers()
	content_pack = CONTENT_PACK_ABBASID_CAMPAIGN
	
	player1 = Missionomatic_InitPlayer(1, { name = "$11253752", currentAge = AGE_IMPERIAL}) --Mamluk Sultanate
	player2 = Missionomatic_InitPlayer(2, { name = "$11250539", currentAge = AGE_IMPERIAL}) --Franks (Nicosia)
	player3 = Missionomatic_InitPlayer(3, { name = "$11254228", currentAge = AGE_IMPERIAL}) --Prisoners
	player4 = Missionomatic_InitPlayer(4, { name = "$11253752", currentAge = AGE_IMPERIAL}) --Mamluk Sultanate (Intro ships)
	player5 = Missionomatic_InitPlayer(5, { name = "$11254230", currentAge = AGE_IMPERIAL}) --Genoese / Famagusta
	player6 = Missionomatic_InitPlayer(6, { name = "$11254269", currentAge = AGE_IMPERIAL}) --Kyrenia
	player7 = Missionomatic_InitPlayer(7, { name = "$11250539", currentAge = AGE_IMPERIAL}) --Franks (Nicosia + Limassol)
	player8 = Missionomatic_InitPlayer(8, { name = "$11250539", currentAge = AGE_IMPERIAL}) --Franks (Nicosia + Limassol)
	
	--RELATIONSHIP STUFF : IDK IF THIS IS ALL NEEDED BUT DO NOT UPSET THE DEEP ONES BY REMOVING IT --
	
	Player_SetRelationship(player1, player2, R_ENEMY)
	Player_SetRelationship(player1, player3, R_ALLY)
	Player_SetRelationship(player1, player4, R_NEUTRAL)
	Player_SetRelationship(player1, player5, R_ENEMY)
	Player_SetRelationship(player1, player6, R_ENEMY)
	Player_SetRelationship(player1, player7, R_ENEMY)
	Player_SetRelationship(player1, player8, R_ENEMY)
	
	Player_SetRelationship(player2, player1, R_ENEMY)
	Player_SetRelationship(player2, player3, R_ALLY)
	Player_SetRelationship(player2, player4, R_ENEMY)
	Player_SetRelationship(player2, player5, R_ALLY)
	Player_SetRelationship(player2, player6, R_ALLY)
