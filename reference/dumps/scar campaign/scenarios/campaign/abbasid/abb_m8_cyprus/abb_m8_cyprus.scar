function Mission_SetupVariables()	-- create any extra sgroups, egroups, and mission variables in here
	
	i_prisonsFreed = 0
	i_prisonsFreedCounterMax = 3
	hpid_prisons = {}
	
	eg_p1_how = EGroup_Create("eg_p1_how")
	
	sg_nicosia_sa_siege = SGroup_CreateIfNotFound("sg_nicosia_sa_siege")
	sg_nicosia_wall_defenders = SGroup_CreateIfNotFound("sg_nicosia_wall_defenders")
	sg_nicosia_scattered = SGroup_CreateIfNotFound("sg_nicosia_scattered")
	sg_nicosia_keep_garrison1 = SGroup_CreateIfNotFound("sg_nicosia_keep_garrison1")
	sg_nicosia_keep_garrison2 = SGroup_CreateIfNotFound("sg_nicosia_keep_garrison2")
	sg_nicosia_retreat = SGroup_CreateIfNotFound("sg_nicosia_retreat")
	
	sg_famagusta_sa_siege = SGroup_CreateIfNotFound("sg_famagusta_sa_siege")
	sg_famagusta_wall_defenders = SGroup_CreateIfNotFound("sg_famagusta_wall_defenders")
	sg_famagusta_scattered = SGroup_CreateIfNotFound("sg_famagusta_scattered")
	
	sg_famagusta_navy_attackers = SGroup_CreateIfNotFound("sg_famagusta_navy_attackers")
	sg_famagusta_navy = SGroup_CreateIfNotFound("sg_famagusta_navy")
	
	sg_init_kyrenia_raid = SGroup_CreateIfNotFound("sg_init_kyrenia_raid")
	sg_kyrenia_retreat = SGroup_CreateIfNotFound("sg_kyrenia_retreat")
	
	sg_limassol_defenders = SGroup_CreateIfNotFound("sg_limassol_defenders")
	
	sg_trade_ships = SGroup_CreateIfNotFound("sg_trade_ships")
	sg_player_ships = SGroup_CreateIfNotFound("sg_player_ships")
	
	house_of_wisdom_started = false
	house_of_wisdom_complete = false
	
	b_isLowGold = false  -- BOOLEANS USED WITH PRISONER LOGIC FOR DETERMINING UNIT TABLE RATIOS AND WHICH TABLE TO USE BELOW
	b_isLowWood = false
	
	b_limassolCaptureStarted = false 
	
	b_kyreniaDestroyed = false 
	
	b_famagustaRaidsTriggered = false
	b_famagustaFinaleTriggered = false
	
	b_nicosiaTCDestroyed = false
	b_nicosiaKeepsDestroyed = false
	b_nicosiaFinaleTriggered = false
end

function Mission_SetDifficulty()  -- DIFFICULTY VARIABLES, FOUND IN .DATA
	Init_Cyprus_Difficulty()
 end

function Mission_SetRestrictions()	-- set up any restrictions (i.e. locking out units, etc) in here
	Player_SetEntityProductionAvailability(player1, EBP.AYYUBID_CMP.BUILDING_ECON_MARKET_AYY, ITEM_REMOVED) 	-- NO TRADE
	Player_SetEntityProductionAvailability(player1, EBP.AYYUBID_CMP.BUILDING_RESOURCE_FARM_AYY, ITEM_REMOVED)	-- NO FARMS 
	Player_SetUpgradeAvailability(player1, UPG.ABBASID.UPGRADE_UNIT_RELIGIOUS_TITHE_BARN_4_ABB, ITEM_REMOVED)	-- NO TITHE BARNS
	Player_SetUpgradeAvailability(player1, UPG.AYYUBID_CMP.UPGRADE_NAVAL_ALLIED_DOCK_HEAL_AYY, ITEM_REMOVED)	-- REMOVING MISSION-SPECIFIC UPGRADE
end

function Mission_Preset()	-- any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)	
	Cyprus_SetupData()   --SETS UP UNIT AND LOCATION TABLES AND FILTERED UNIT DATA, FOUND IN .DATA FILE
	
	Cyprus_EnemyMarkerData() -- SETS UP MARKER DATA FOR THE MAJORITY OF DEFENSIVE UNITS, FOUND IN .DATA FILE. THESE ARE MOSTLY USED WITH MASS SPAWNING/INTRO STUFFS
	
	Cyprus_Init_Objectives() -- INITALISES OBJECTIVES DATA
	
	Init_Limassol() -- INITIALISES LIMASSOL DEFENSIVE TROOPS. CAPTURE DATA IS FOUND IN .OBJECTIVES FILE
	
	Init_Famagusta() -- INITIALISES FAMAGUSTA DEFENSIVE LAND TROOPS AND PATROLS
	
	Init_Nicosia() -- INTIALISES NICOSIA DEFENSIVE TROOPS AND PATROLS
	
	Init_Famagusta_Navy() -- INITIALISES FAMAGUSTA NAVY DEFENCES AND PATROLS
	
	Init_Prisons() -- INITIALISES THE PRISON CAMPS CAPTURE LOGIC AND UNITS

	FoodReserves_Init()
	
	Unit_Trainer_Famagusta = BuildingTrainer_Init(eg_famagusta_production) -- UNIT TRAINERS
	Unit_Trainer_Famagusta_Navy = BuildingTrainer_Init(eg_famagusta_dock)
	Unit_Trainer_Nicosia = BuildingTrainer_Init(eg_nicosia_production)
	
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Famagusta, "scar_knight", 10)   	-- MODIFIES UNIT TRAINING TIMES. COINCIDES WITH THE TIMERS IN DIFFICULTY 
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Famagusta, "scar_horseman", 10) 	-- TO GIVE THE ACTUAL TIMES BETWEEN ATTACKS. FEEL FREE TO CHANGE WITH BALANCE BUT
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Famagusta, "scar_spearman", 10) 	-- THIS KEEPS EVERYTHING UNIFORM, EASY TO CALCULATE AND MOST IMPORTANTLY, LOOKS
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Famagusta, "scar_manatarms", 10)	-- COOL.
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Famagusta, "scar_archer", 10)
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Famagusta, "scar_crossbowman", 10)
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Famagusta, "scar_trebuchet", 10)
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Famagusta, "scar_mangonel", 10)
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Famagusta, "scar_springald", 10)
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Famagusta, "scar_ram", 10)
	
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Famagusta_Navy, "scar_warship", 10)
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Famagusta_Navy, "scar_combat_ship", 10)
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Famagusta_Navy, "scar_war_galley", 10)
	
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Nicosia, "scar_knight", 10) 
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Nicosia, "scar_horseman", 10) 
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Nicosia, "scar_spearman", 10)
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Nicosia, "scar_manatarms", 10)
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Nicosia, "scar_archer", 10)
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Nicosia, "scar_crossbowman", 10)
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Nicosia, "scar_trebuchet", 10)
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Nicosia, "scar_mangonel", 10)
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Nicosia, "scar_springald", 10)
	UnitTrainer_OverrideBuildTime(Unit_Trainer_Nicosia, "scar_ram", 10)
	
	Player_SetResource(player1, RT_Food, 0)    -- SET RESOURCES TO 0 UNTIL LIMASSOL IS TAKEN
	Player_SetResource(player1, RT_Wood, 0)
	Player_SetResource(player1, RT_Stone, 0)
	Player_SetResource(player1, RT_Gold, 0)
	
	--We're not using the old upgrade wrapper, but still need to apply special health bonuses
	PlayerUpgrades_ApplyHealthBonuses(player1)
	Player_ModifyAyyubidMilitaryBuildTimes(player1, Util_DifVar({ 0.5, 0.75, 1, 1 }))
	
	-- Audio
	Sound_ResetMusicIntensityMapping();
	Sound_AddMusicIntensityMappingPoint(50, 200) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(100, 1250) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(150, 2500) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(200, 3000) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(300, 3500) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(500, 6000) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(650, 9999) -- raw value max to scaled value max 
	
	----------------------------
	--INITIALISE PLAYER TROOPS--
	----------------------------
	
	sg_p1_land_units = SGroup_Create("sg_p1_land_units")
	sg_p1_villagers = SGroup_Create("sg_p1_villagers")
	
	CreateUnits(player1, P1_UNITS.INFANTRY, mkr_p1_infantry, sg_p1_land_units)
	CreateUnits(player1, P1_UNITS.CAVALRY, mkr_p1_cavalry, sg_p1_land_units)
	
	sg_p1_warships = CreateUnits(player1, P1_UNITS.WARSHIPS, mkr_p1_warships, "sg_p1_warships")
	SGroup_AddGroup(sg_player_ships, sg_p1_warships)
	
	--DEBUG: Auto Test--
	AutoTest_OnInit()
	
end

function Mission_PreStart()
	
	-- To make finding enemies easier, increase ship line of sight for player
	local sight_multiplier = 2.5
	
	Modify_EntityTypeSightRadius(player1, EBP.AYYUBID_CMP.UNIT_NAVAL_FISHING_BOAT_AYY, sight_multiplier)
	Modify_EntityTypeSightRadius(player1, EBP.AYYUBID_CMP.UNIT_NAVAL_TRADE_SHIP_AYY, sight_multiplier)
	Modify_EntityTypeSightRadius(player1, EBP.AYYUBID_CMP.UNIT_NAVAL_DHOW_AYY, sight_multiplier)
	Modify_EntityTypeSightRadius(player1, EBP.AYYUBID_CMP.UNIT_NAVAL_EXPLOSIVE_DHOW_AYY, sight_multiplier)
	Modify_EntityTypeSightRadius(player1, EBP.AYYUBID_CMP.UNIT_NAVAL_BAGHLAH_AYY, sight_multiplier)
	Modify_EntityTypeSightRadius(player1, EBP.AYYUBID_CMP.UNIT_NAVAL_TRANSPORT_AYY, sight_multiplier)
	Modify_EntityTypeSightRadius(player1, EBP.AYYUBID_CMP.UNIT_NAVAL_XEBEC_AYY, sight_multiplier)
	Modify_EntityTypeSightRadius(player1, EBP.AYYUBID_CMP.BUILDING_UNIT_NAVAL_AYY, sight_multiplier)
	
	-- Also boost the speed of player warships specifically
	local speedMod_dhow = Modifier_Create(MAT_EntityType, "speed_maximum_modifier", MUT_Multiplication, false, 1.2, EBP.AYYUBID_CMP.UNIT_NAVAL_DHOW_AYY)
	Modifier_ApplyToPlayer(speedMod_dhow, player1, 0)
	local speedMod_dhow_explosive = Modifier_Create(MAT_EntityType, "speed_maximum_modifier", MUT_Multiplication, false, 1.2, EBP.AYYUBID_CMP.UNIT_NAVAL_EXPLOSIVE_DHOW_AYY)
	Modifier_ApplyToPlayer(speedMod_dhow_explosive, player1, 0)
	local speedMod_baghlah = Modifier_Create(MAT_EntityType, "speed_maximum_modifier", MUT_Multiplication, false, 1.2, EBP.AYYUBID_CMP.UNIT_NAVAL_BAGHLAH_AYY)
	Modifier_ApplyToPlayer(speedMod_baghlah, player1, 0)
	local speedMod_xebec = Modifier_Create(MAT_EntityType, "speed_maximum_modifier", MUT_Multiplication, false, 1.2, EBP.AYYUBID_CMP.UNIT_NAVAL_XEBEC_AYY)
	Modifier_ApplyToPlayer(speedMod_xebec, player1, 0)
end

function Mission_Start()	-- this is triggered after the intro, just as control is passed to the player
								 
	Init_LimassolCapture() -- INITIALISES LIMASSOL CAPTURE DATA, FOUND IN .OBJECTIVES FILE
	
	Objective_Start(OBJ_CaptureLimassol)
	
	Rule_AddInterval(Monitor_Player_Nicosia_Prox, 2)
	
	Rule_AddInterval(Monitor_Player_Famagusta_Prox, 2)
	Rule_AddInterval(Monitor_Player_Kyrenia_Prox, 2)
	Rule_AddInterval(Monitor_Player_Prisons_Prox, 2)
	
	-- Narrative
	SGroup_MoveToAndDestroy(sg_allied_troop_transport_intro, mkr_allied_vil_transport_spawn) -- MAKE THE TRANSPORTS ON THE SHORE LEAVE AFTER CINEMATIC INTRO
	
	Rule_AddEGroupEvent(Cyprus_ObjectiveTargetKilled, eg_objective_targets, GE_EntityKilled)
	Rule_AddGlobalEvent(Cyprus_CheckSquadDeath, GE_SquadKilled)
	
	--enhance limassol berries
	EGroup_SetRemainingResourceDepositAmount(eg_limassol_berries, 350)
	
	Cyprus_InitNavalRaid()
end

function Cyprus_InitNavalRaid()
	
	local raid_units = {
		{type = "scar_war_galley", numSquads = t_difficulty.famagusta_naval_raid_war_galley_amount},
		{type = "scar_combat_ship", numSquads = t_difficulty.famagusta_naval_raid_combat_ships_amount}
	}
	
	sg_init_naval_raid = SGroup_CreateIfNotFound("sg_init_naval_raid")
	CreateUnits(player5, raid_units, mkr_famagusta_init_raid_spawn, sg_init_naval_raid)
	Rule_AddOneShot(Cyprus_MoveInitNavalRaid, 1)
end

function Cyprus_MoveInitNavalRaid()
	Cmd_AttackMove(sg_init_naval_raid, mkr_famagusta_init_raid)
end

function Cyprus_LaunchInitNavalRaid()
	Cmd_AttackMove(sg_init_naval_raid, mkr_famagusta_init_raid_dest)
end

function Cyprus_LaunchInitKyreniaRaid()
	
	--send out init raiders
	kyrenia_raiders = Army_FindFromName("army_kyrenia_init_raiders")
	SGroup_AddGroup(sg_init_kyrenia_raid, Army_GetSGroup(kyrenia_raiders))
	
	Army_AddTargets(kyrenia_raiders, {mkr_kyrenia_raid_dest1, mkr_kyrenia_raid_dest2, mkr_kyrenia_raid_dest3, mkr_player_base})
	Rule_AddInterval(Cyprus_CheckKyreniaRaidProx, 2)
end

function Cyprus_CheckKyreniaRaidProx()
	
	if Player_CanSeeSGroup(player1, sg_init_kyrenia_raid, ANY) then
		
		Rule_RemoveMe()
		Rule_AddOneShot(Cyprus_StartKyreniaDelayed, 5)
		Rule_AddOneShot(Cyprus_DissolveKyreniaRaid, 12)
	end
end

function Cyprus_DissolveKyreniaRaid()
	
	Army_Dissolve(kyrenia_raiders, sg_kyrenia_retreat)
	Rule_AddOneShot(Kyrenia_RetreatAttackers, 2)
end

function Kyrenia_RetreatAttackers()
	if SGroup_CountSpawned(sg_kyrenia_retreat) > 0 then
		Cmd_Move(sg_kyrenia_retreat, mkr_kyrenia_raid_spawn)
	end
end

function Cyprus_StartShipAttackCheck()
	Rule_AddInterval(Cyprus_CheckPlayerShipAttacked, 2)
end

function Cyprus_CheckPlayerShipAttacked()
	
	-- First ship attacked
	if VOPlayed_FranksAttackShips_CTA == false then
		
		local _CheckShip = function(gid, idx, sid)
			SGroup_Clear(sg_temp)
			SGroup_Add(sg_temp, sid)
			if SGroup_IsUnderAttack(sg_temp, ANY, 1) and VOPlayed_FranksAttackShips_CTA == false then
				
				VOPlayed_FranksAttackShips_CTA = true
				Sound_Play2D("mus_stinger_campaign_warning")
				EventCues_CallToAction("$11254246", CTA_ALARM, EVENTS.ShipUnderAttack, nil, Util_GetPosition(sid), 30, "icons/cta/illustrations/announce_incoming_attack_naval")
				
				Rule_AddOneShot(Cyprus_StartFamagustaRaids, 30)
				
				return
			end
		end
		
		SGroup_ForEach(sg_player_ships, _CheckShip)
	else
		Rule_RemoveMe()
	end
	
end

-----------------------------------
--AFTER "LIMASSOL IS TAKEN" LOGIC--
-----------------------------------

function Cyprus_Ship_Built(context)
	
	if Squad_IsOfType(context.spawnedSquad, "naval_unit") == true then
		
		SGroup_Add(sg_player_ships, context.spawnedSquad)
		
		if Squad_IsOfType(context.spawnedSquad, "scar_trade_ship") == true then
			SGroup_Add(sg_trade_ships, context.spawnedSquad)
		end	
	end
end

---------------------------------------
--HOUSE OF WISDOM UPGRADES WORKAROUND--
--------------------------------------- 
function Cyprus_HoW_Started(context)
	
	if Entity_GetBlueprint(context.entity) == EBP.AYYUBID_CMP.BUILDING_HOUSE_OF_WISDOM_AYY then
		house_of_wisdom_started = true
	end
end
function Cyprus_HoW_Constructed(context)
	
	if Entity_GetBlueprint(context.entity) == EBP.AYYUBID_CMP.BUILDING_HOUSE_OF_WISDOM_AYY then
		house_of_wisdom_complete = true
		EGroup_Add(eg_p1_how, context.entity)
		Rule_AddOneShot(Cyprus_BuildWings, 0.5)
	end
end

function Cyprus_BuildWings()
	if EGroup_CountSpawned(eg_p1_how) > 0 then
		Cmd_Upgrade(eg_p1_how, UPG.ABBASID.UPGRADE_ADD_CULTURE_WING, 1, true)
		Cmd_Upgrade(eg_p1_how, UPG.ABBASID.UPGRADE_ADD_ECONOMY_WING_FEUDAL, 1, true)
		Cmd_Upgrade(eg_p1_how, UPG.ABBASID.UPGRADE_ADD_MILITARY_WING_CASTLE, 1, true)
		Cmd_Upgrade(eg_p1_how, UPG.AYYUBID_CMP.UPGRADE_ADD_TRADE_WING_IMPERIAL_AYY, 1, true)
	end
end

function Cyprus_AutoSaveInterval()
	Util_AutoSave(true, true, 30)
end


------------------------
--TRADE SHIP CTA TIMER-- -- SETS OFF A TIMER THAT EVENTUALLY REVEALS THE TRADE SHIP POST AND PINGS A CTA
------------------------
function Tradeship_Timer()
	EventCues_CallToAction("$11254247", CTA_UNIQUE_CHANGE, EVENTS.TradeOutpostAvailable, nil, mkr_trade_hint, 15, "icons/cta/illustrations/abbasid_celebration")
	Sound_Play2D("mus_stinger_campaign_triumph_short")
	build_navy_hint_ping = UI_CreateMinimapBlip(mkr_build_navy_hint, 5, "general")
	FOW_RevealArea(Util_GetPosition(mkr_trade_hint), 80, -1)
	
	hpid_trade_post = HintPoint_Add(mkr_trade_hint, true, "$11257490", 10)
	
	Rule_AddInterval(VOCue_TradeRouteComplete, 2)
end

-----------------------------
--ARMY ATTACK WAVE MONITORS--
-----------------------------
function Monitor_Nicosia_Attacks_Start(context, data) -- MONITORS IF THE GRACE PERIOD IS OVER. TRIGGERS WAVES OF ARMIES FROM NICOSIA
	if Nicosia_Attacks_Have_Started ~= true then
		Nicosia_Attacks_Have_Started = true
	end
	EventCues_CallToAction("$11254248", CTA_ALARM, EVENTS.NicosiaAttackBegins_CTA, EVENTS.NicosiaAttackBegins_CTA_OnClick, mkr_nicosia_reveal, 15, "icons/cta/illustrations/enemy_army_has_entered_off_map")
	Sound_Play2D("mus_stinger_campaign_warning")
	FOW_RevealArea(Util_GetPosition(mkr_nicosia_reveal), 65, 30)
	
	Rule_AddInterval(Nicosia_Attacks, t_difficulty.nicosia_attacks_timer)
	
	--send out init raiders
	local raiders = Army_FindFromName("army_nicosia_init_raiders")
	Army_AddTargets(raiders, {mkr_nicosia_gates, mkr_mountain_northern_pass, mkr_mountain_crossroads, mkr_player_base})
	Rule_AddInterval(Nicosia_Monitor_InitRaid, 2, { army = raiders })
end

function Nicosia_Monitor_InitRaid(context, data)
	local army = data.army
	if SGroup_CountSpawned(army.sgroup) <= t_difficulty.nicosia_retreat_threshold then
		Army_Dissolve(army, sg_nicosia_retreat)
		Rule_AddOneShot(Nicosia_RetreatAttackers, 2)
		Rule_RemoveMe()
	end
end

function Cyprus_StartFamagustaRaids() 
	
	if b_famagustaRaidsTriggered == false then
		
		b_famagustaRaidsTriggered = true
		Sound_Play2D("mus_stinger_campaign_warning")
		EventCues_CallToAction("$11254251", CTA_ALARM, EVENTS.ApproachedFamagusta, nil, mkr_famagusta_reveal, 25, "icons/cta/illustrations/announce_incoming_attack_naval")
		Rule_AddInterval(Spawn_Navy_Raids, t_difficulty.navy_raid_timer)
		FOW_RevealArea(Util_GetPosition(mkr_famagusta_reveal), 53, 30)
		
		Cyprus_StartFamagustaObjective()
		
	end
end

-- KYRENIA SENDS REINFORCEMENTS HERE
function Monitor_Kyrenia_Reinforcements() 
	
	if b_kyreniaDestroyed == false and Player_AreSquadsNearMarker(player1, mkr_nicosia_defense_final) then
		Rule_RemoveMe()	
		EventCues_CallToAction("$11254250", CTA_ALARM, nil, nil, mkr_kyrenia_cap, 10, "icons/cta/illustrations/announce_incoming_attack_land")
		Sound_Play2D("mus_stinger_campaign_warning")
		FOW_RevealArea(Util_GetPosition(mkr_ui_kyrenia), 45, 30)
		
		--add targets
		local cav1 = Army_FindFromName("army_kyrenia_cav1")
		local cav2 = Army_FindFromName("army_kyrenia_cav2")
		local cav3 = Army_FindFromName("army_kyrenia_cav3")
		
		Army_AddTargets(cav1, Cyprus_GetSequentialMarkers("mkr_kyrenia_dest1_", 6))
		Army_AddTargets(cav2, Cyprus_GetSequentialMarkers("mkr_kyrenia_dest2_", 5))
		Army_AddTargets(cav3, Cyprus_GetSequentialMarkers("mkr_kyrenia_dest3_", 4))
	end 
	
	if b_kyreniaDestroyed then
		Rule_RemoveMe()	
	end
end		

function Cyprus_GetSequentialMarkers(marker_stem, num)
	
	local markers = {}
	
	for i = 1, num do
		local marker = Marker_FromName(marker_stem..tostring(i), "")
		table.insert(markers, marker)
	end
	return markers
end

----------------------
--ATTACK WAVES LOGIC--
----------------------
-----------
--NICOSIA--
-----------
function Nicosia_Attacks()  -- NICOSIA REPEATEDLY ATTACKS THE PLAYER HERE
	
	if Player_GetTotalPopulation(player2) < CYPRUS_UNIT_CAP then
		
		local raid_table = CYPRUS_UNITS.NICOSIA_ATTACKERS[nicosia_raid_index]
		
		--reduce enemy numbers if the player has captured their gold mine
		if b_isLowGold then
			for i, unitrow in ipairs(raid_table) do
				if unitrow.numSquads > 5 then
					unitrow.numSquads = math.ceil(unitrow.numSquads * 0.85)
				end
			end
		end
		
		BuildingTrainer_TrainUnits(Unit_Trainer_Nicosia, raid_table, 0, Nicosia_OnSpawn, Nicosia_OnComplete, nil) 
		
		nicosia_raid_index = nicosia_raid_index + 1
		if nicosia_raid_index > #CYPRUS_UNITS.NICOSIA_ATTACKERS then
			nicosia_raid_index = NICOSIA_RAID_CYCLE_INDEX --cycle back to earlier index in the table
		end
	end
end																															

function Nicosia_OnSpawn(context, data) 	-- WHAT HAPPENS WHEN THE UNITS SPAWN FROM BUILDINGS; PUT THEM IN AN SGROUP TO MOVE THEM TO THE 
	SGroup_Single(sg_single, context.unit)  -- MUSTER MARKER AND CLEAR THE SGROUP READY FOR THE NEXT UNITS
	
	if Squad_IsOfType(context.unit, "cavalry") then
		SGroup_AttackMove(sg_single, Util_GetRandomPosition(mkr_nicosia_muster_cav))
	elseif Squad_IsOfType(context.unit, "siege") then
		SGroup_AttackMove(sg_single, Util_GetRandomPosition(mkr_nicosia_muster_siege))
	else
		SGroup_AttackMove(sg_single, Util_GetRandomPosition(mkr_nicosia_muster_misc))
	end
end

function Nicosia_OnComplete(context, data) 									-- WHAT HAPPENS WHEN ALL UNITS ARE COMPLETE; STICK THEM IN ANOTHER SGROUP
	local sgroup = SGroup_CreateUniqueWithPrefix("sg_nicosia_on_complete")  -- AND GET THAT SGROUP READY TO ACTUALLY LAUNCH AN ATTACK AND BECOME AN ARMY.
	SGroup_AddGroup(sgroup, context.sgroup)									-- GIVE THEM 30 SECONDS FOR THE LAST UNITS OUT OF THE BUILDINGS TO MAKE IT TO THE
	Rule_AddOneShot(Nicosia_Launch_Attack, 30, {sgroup = sgroup})			-- MARKER SO EVERYTHING IS IN THE SAME PLACE AND NO MAN/HORSIE/SIEGE IS LEFT BEHIND
end

function Nicosia_Launch_Attack(context, data)
	
	nicosiaAttackInterval = nicosiaAttackInterval or 0
	nicosiaAttackInterval = nicosiaAttackInterval + 1
	
	local nicosiaAttackWaveParams = {
		player = player2,
		name = "nicosia_attack_"..nicosiaAttackInterval,
		targetOrder = TARGET_ORDER_LINEAR,
		attackBuildingsEnRoute = BUILDINGS_IMPORTANT,
		combatRangeEnRoute = 60,
		onBlockedFunction = Nicosia_Attack_Blocked,
		ramsBuiltWhenBlocked = 1,
		brokenWallThreshold = 40,
		sgroup = data.sgroup,
		targets = Table_GetRandomItem(CYPRUS_ATTACK_ROUTES),
	}							 
	
	local attack_army = Army_Init(nicosiaAttackWaveParams)
	
	if SGroup_CountSpawned(sg_nicosia_retreat) > 0 then
		
		if Prox_AreSquadsNearMarker(sg_nicosia_retreat, mkr_nicosia_retreat_dest, ALL, 30) then
			Army_AddSGroup(attack_army, sg_nicosia_retreat)
			SGroup_Clear(sg_nicosia_retreat)
		end
	end
	
	Rule_AddInterval(Nicosia_Monitor_Attack, 2, { army = attack_army })
end

function Nicosia_Attack_Blocked(army)
	
	Army_Dissolve(army, sg_nicosia_retreat)
		
	--The retreating units abandon their siege weapons
	SGroup_Filter(sg_nicosia_retreat, "siege", FILTER_REMOVE)
	Rule_AddOneShot(Nicosia_RetreatAttackers, 2)
		
	Rule_RemoveMe()
end

function Nicosia_Monitor_Attack(context, data)
	local army = data.army
	
	if SGroup_CountSpawned(army.sgroup) <= t_difficulty.nicosia_retreat_threshold then
		
		Army_Dissolve(army, sg_nicosia_retreat)
		
		--The panicked retreating units abandon their siege weapons
		SGroup_Filter(sg_nicosia_retreat, "siege", FILTER_REMOVE)
		Rule_AddOneShot(Nicosia_RetreatAttackers, 2)
		
		Rule_RemoveMe()
	end
end

function Nicosia_RetreatAttackers()
	if SGroup_CountSpawned(sg_nicosia_retreat) > 0 then
		Cmd_Move(sg_nicosia_retreat, mkr_nicosia_retreat_dest)
	end
end

