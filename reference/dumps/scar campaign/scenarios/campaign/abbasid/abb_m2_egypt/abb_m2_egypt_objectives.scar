			local descriptionString = Loc_FormatText("$11255474", Egypt_GetHeldPoints(player2)) -- Crusader: %1COUNT%+
			Objective_UpdateText(OBJ_Control, titleString, descriptionString, false, true)
			UI_SetPlayerDataContext(player1, { tug_of_war_velocity = trend })
			Obj_SetProgress(OBJ_Control.ID, control_balance)
			if control_balance >= 1 then
				return true
			end
		end,
		IsFailed = function()
		end,
		OnComplete = function()
		end,
		OnFail = function()
		end,
	}
	
	OBJ_Reinforcements = {
		Title = "$11253769", --Next Reinforcement Wave in
		Type = ObjectiveType_Primary,
		--Parent = OBJ_Unrest,
		--StartAlongsideParent = true,
		
		PreStart = function()
		end,
		OnStart = function()
			Objective_StartTimer(OBJ_Reinforcements, COUNT_DOWN, 90)
			Rule_AddInterval(_Egypt_ReinforcementWaves, 0.5)
		end,
		IsComplete = function()
		end,
		IsFailed = function()
		end,
		OnComplete = function()
		end,
		OnFail = function()
		end,
	}
	TOBJ_ControlPointTip = {
		Title = "$11253770", --Control increases for whomever holds the most control points.
		Type = ObjectiveType_Tip,
		Parent = OBJ_Control,
		StartAlongsideParent = true,
		
		PreStart = function()
		end,
		OnStart = function()
		end,
		IsComplete = function()
		end,
		IsFailed = function()
		end,
		OnComplete = function()
		end,
		OnFail = function()
		end,
	}

	Objective_Register(OBJ_ControlPrimary)
	Objective_Register(OBJ_Control)
	Objective_Register(OBJ_Alexandria)
	Objective_Register(OBJ_Reinforcements)
	Objective_Register(TOBJ_ControlPointTip)
	--Objective_Register(SOBJ_PlayerWave)
	--Objective_Register(SOBJ_EnemyWave)
	

end

function Egypt_GetControlBalance()
	
	control_balance = control_balance or 0.3
	control_acceleration = control_acceleration or 1
	
	local trend = Egypt_GetControlTrend()
	
	trend = trend/3
	local ramp_value = math.floor(World_GetGameTime()/300)
	ramp_value = ramp_value
	local ramping_change = 1+ramp_value
	trend = trend*ramping_change*control_acceleration
	
	local current_control = control_balance*4000
	local current_control = current_control+trend
	
	control_balance = current_control/4000
	
end

function Egypt_GetControlTrend()
	local player_heldPoints = Egypt_GetHeldPoints(player1)
	local enemy_heldPoints = Egypt_GetHeldPoints(player2)
	
	local trend = player_heldPoints-enemy_heldPoints
	
	if player_heldPoints >= 9 then
		Game_SendCustomChallengeEvent(player1, CE_ACHIEVALLCONTROLPOINTSINTOEGYPT, 1)
	end
	
	return trend
end

function Egypt_RaiseStakesSlow()
	VOCue_StakesRaise_OneShot()
	control_acceleration = control_acceleration+0.5
	reinforcements_acceleration = reinforcements_acceleration+12
end

function Egypt_RaiseStakesFast()
	local New_Attack_Interval = New_Attack_Interval or t_difficulty.enemyMods.ATTACK_INTERVAL
	if New_Attack_Interval-t_difficulty.enemyMods.ATTACK_ACCELERATION < t_difficulty.enemyMods.ATTACK_INTERVAL_FLOOR then
		New_Attack_Interval = t_difficulty.enemyMods.ATTACK_INTERVAL_FLOOR
	else
		New_Attack_Interval = New_Attack_Interval-t_difficulty.enemyMods.ATTACK_ACCELERATION
	end
	
	local New_Attack_Size = New_Attack_Size or t_difficulty.enemyMods.attack_group_size
	if New_Attack_Size+t_difficulty.enemyMods.ATTACK_GROUP_SIZE_ACCELERATION > t_difficulty.enemyMods.ATTACK_GROUP_SIZE_CEILING then
		New_Attack_Size = t_difficulty.enemyMods.ATTACK_GROUP_SIZE_CEILING
	else
		New_Attack_Size = New_Attack_Size+t_difficulty.enemyMods.ATTACK_GROUP_SIZE_ACCELERATION
	end
	
	Rule_ChangeInterval(SpawnTypedEnemySquads, New_Attack_Interval)
	t_difficulty.enemyMods.attack_group_size = New_Attack_Size
end

function Egypt_AddTemplars()
	ENEMY_SQUAD_TYPES.typeList = {"scar_archer", "scar_spearman", "scar_horseman", "templars", "scar_militia"}

	local units = {
			{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEMPLAR_CRU, numSquads = 4},
			{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEMPLAR_MASTER_CRU, numSquads = 1},
	}
		
	local thisSgroup = CreateUnits(player2, units, mkr_enemy_unit_spawn, "Frankish_Army_")
	ApplyCaptureModifier(thisSgroup)
	Distribute_Enemy_Army(thisSgroup)		
	
	Rule_AddOneShot(AssignOldestWaitingArmyToBestTarget, 1)
end

function _Egypt_ReinforcementWaves()
	if Objective_GetTimerSeconds(OBJ_Reinforcements) <= 0 then
		Objective_StartTimer(OBJ_Reinforcements, COUNT_DOWN, 90)
		Egypt_ReinforcementWave(player1)
		Egypt_ReinforcementWave(player2)
		
		-- CTAs: Reinforcements 
		Sound_Play2D("sfx_horn_reinforcements_arrive_egypt")
		if reinforcement_wave_count == 0 then
			VOCue_FirstReinforcements()
		elseif reinforcement_wave_count == 1 then
			VOCue_SecondReinforcements()
		end
		
		if reinforcement_wave_count > 0 then
			UI_CreateEventCue("$11253757", Loc_Empty(), "high_priority", "", "sfx_ui_event_queue_campaign_high_priority_positive_play", ECV_Title|ECV_Queue)
			UI_CreateMinimapBlip(mkr_player_unit_spawn, 6, "general")
		end
		
		reinforcement_wave_count = reinforcement_wave_count+1
		
		if SGroup_CountSpawned(sg_reinforcement_transports) > 0 then
			Cmd_FormationMove(sg_reinforcement_transports, mkr_player_boat_spawn, false, true)
		end
		
	elseif Objective_GetTimerSeconds(OBJ_Reinforcements) <= 10 then
		if SGroup_CountSpawned(sg_reinforcement_transports) <= 0 then
			CreateUnits(player7, {type = "scar_transport_ship", numSquads = 2}, mkr_player_boat_spawn, sg_reinforcement_transports)
			Cmd_FormationMove(sg_reinforcement_transports, mkr_player_boat_landing)
		end
	end
end
