	OBJ_ControlPrimary = {
		Title = "$11253760", -- Hold the area to gain control over time
		--Description = "$11253761", --Capture Control Points to increase control of the area.
		Type = ObjectiveType_Primary,
		
		PreStart = function()
		end,
		OnStart = function()	
			Util_StartIntel(EVENTS.MissionStart)
			Objective_Start(OBJ_Alexandria, false)
		end,
		IsComplete = function()
			--local controlString = Loc_FormatText("$11253763", Egypt_GetHeldPoints(player1), Egypt_GetHeldPoints(player2)) --"Gain Control - Sultan: %1%%+ vs Frankish: %2%%+"
			--Objective_UpdateText(OBJ_ControlPrimary, controlString, nil, false, true)
			--Objective_SetCounter(OBJ_ControlPrimary, Egypt_GetControlTrend())
			return Objective_AreSubObjectivesComplete(OBJ_ControlPrimary, true)
		end,
		IsFailed = function()
			--return Objective_AreSubObjectivesFailed(OBJ_ControlPrimary, true)
		end,
		OnComplete = function()
			Mission_Complete()
		end,
		OnFail = function()
			--Mission_Fail()
		end,
	}
	
	OBJ_Control = {
		Title = Loc_FormatText("$11255473", 2), -- Sultan: %1COUNT%+
		Description = Loc_FormatText("$11255474", 2), -- Crusader: %1COUNT%+
		Type = ObjectiveType_TugOfWar_WithVelocity,
		Parent = OBJ_ControlPrimary,
		StartAlongsideParent = true,
		
		PreStart = function()
			Obj_SetProgressVisible(OBJ_Control.ID, true)
