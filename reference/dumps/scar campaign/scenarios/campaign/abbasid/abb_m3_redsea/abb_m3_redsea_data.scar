--
-- HELPER FUNCTIONS
--
function GetBundle(id)
	local eligible_target_bundles = Clone(RAIDER_TARGET_BUNDLES)
	for i, bundle in ipairs(eligible_target_bundles) do
		if bundle.id == id then
			print("bundle "..bundle.id)
			return bundle
		end
	end
	fatal("bundle not found")
end

function GetLandingPartyIndex()
	landing_party_index = landing_party_index or 0
	landing_party_index = landing_party_index + 1
	return landing_party_index
end

function GetRaiderIndex()
	raider_index = raider_index or 0
	raider_index = raider_index + 1
	return raider_index
end

function GetRaiderUnits()
	raider_units_index = raider_units_index or 0
	raider_units_index = raider_units_index + 1
	if raider_units_index > #raider_unit_groups then
		raider_units_index = 1
	end
	return raider_unit_groups[raider_units_index]
end

function GetRaiderTargets()
	raider_target_index = raider_target_index or 0
	raider_target_index = raider_target_index + 1
	if raider_target_index > #RAIDER_TARGETS then
		raider_target_index = 1
	end
	return Clone(RAIDER_TARGETS[raider_target_index])
end

function GetRecipe()
	local recipe = {		
		introNIS = EVENTS.Intro,
		outroNIS = EVENTS.Victory,
		-- Presentation things for the start or end of a mission
		onStart = {
			titleCard = {
				icon = "icons/campaign/campaign_saladin",
				title = "$11234485", -- Red Sea
				date = "$11252168", -- 1183
			},
		},
		modules = {
			{
				type = "Army",
				name = "pirate_army_1",
				targets = { mkr_pirate_army_1_1 },
				targetOrder = TARGET_ORDER_LINEAR,
