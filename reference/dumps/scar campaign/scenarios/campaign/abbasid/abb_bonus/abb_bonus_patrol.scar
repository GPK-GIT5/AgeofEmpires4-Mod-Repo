import("cardinal.scar")
import("MissionOMatic/MissionOMatic.scar")


function AbbBonus_CreatePatrol(player, unitTable, sgroupName, markerStem, numMarkers)
	
	--set data
	local patrol = {
		unitTable = unitTable,
		sgroup = SGroup_CreateIfNotFound(sgroupName),
		markers = AbbBonus_GetMarkers(markerStem, numMarkers),
	}
	table.insert(patrols_data, patrol)
	
	--spawn
	CreateUnits(player, patrol.unitTable, patrol.markers[1], patrol.sgroup)
	
	--launch
	for i, marker in ipairs(patrol.markers) do
		SGroup_AttackMove(patrol.sgroup, marker, true)
	end
	
	--monitor
	Rule_AddInterval(AbbBonus_MonitorPatrol, 2, { patrol = patrol })
end

function AbbBonus_MonitorPatrol(context, data)
	local patrol = data.patrol
	
	if SGroup_CountSpawned(patrol.sgroup) > 0 then
		if SGroup_IsIdle(patrol.sgroup, true) then
			--the patrol has reached the end of its route
			for i, marker in ipairs(patrol.markers) do
				SGroup_AttackMove(patrol.sgroup, marker, true)
			end
		end
	else
		--the patrol is dead, reform with new units
	end
end




