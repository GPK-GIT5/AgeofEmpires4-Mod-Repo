---------------------------------------------------------------------------------
---------------------------------- Appoint Spy ----------------------------------
---------------------------------------------------------------------------------

function AppointSpyTutorial_Init()	
	local select_shajar_goal = Training_Goal(
		SGroup_GetSquadAt(sg_shajar, 1),
		{ ID = "select_shajar_goal", Message = "$11257153", DataTemplate = "LeftClickTrainingDataTemplate" }, --Spies enter Stealth automatically. They are revealed after attacking the enemy.
		AppointSpyTutorial_ShajarIsSelected
	)
	-- Controller only hint for opening the radial
	local open_shajar_radial = Training_Goal(
		"LooseReticle",
		{ ID = "open_shajar_radial", Message = "$1000968", DataTemplate = "GenericTrainingDataTemplate" }, -- Press RT to open the radial menu
		OpenShajarRadialMenu
	)
	local appoint_spy_goal = Training_Goal(
		BP_GetAbilityBlueprint("shajar_convert_to_spy_ayy"),
		{ ID = "appoint_spy_goal", Message = "$11257213", DataTemplate = "LeftClickTrainingDataTemplate" }, --Spies enter Stealth automatically. They are revealed after attacking the enemy.
		UsedAppointSpy
	)
	-- Extra controller hint for when the player begins issuing the command and the radial closes
	local appoint_spy_goal_reticle = Training_Goal(
		"LooseReticle",
		{ ID = "appoint_spy_goal_reticle", Message = "$11257213", DataTemplate = "GenericTrainingDataTemplate" }, --Spies enter Stealth automatically. They are revealed after attacking the enemy.
		ReturnFalse
	)
	
	local goals = { select_shajar_goal, appoint_spy_goal }
	
	if UI_IsXboxControllerUI() == true then
		goals = { select_shajar_goal, open_shajar_radial, appoint_spy_goal, appoint_spy_goal_reticle}
	end

	appoint_spy_sequence = Training_GoalSequence(
		"appoint_spy_sequence", 
		1, 
		0, 
		AppointSpyTutorial_Trigger, 
		AppointSpyTutorial_Ignore, 
		nil, 
		nil, 
		true, 
		goals
	)
end

function AppointSpyTutorial_Enable()
	if UI_IsXboxControllerUI() == true then
		UI_SetModalAbilityPhaseCallback(PlacingSpyMonitor)
	end
	Training_AddGoalSequence(appoint_spy_sequence)
	Training_EnableGoalSequenceByID(appoint_spy_sequence, true)
end

function AppointSpyTutorial_Trigger(goalSequence)
	if SGroup_CountSpawned(sg_shajar) > 0 then
		local shajar = SGroup_GetSquadAt(sg_shajar, 1)
		if Misc_IsSquadOnScreen(shajar, 0.9) then
			goalSequence.goals[1].triggered_at = goalSequence.goals[1].triggered_at or World_GetGameTime()
			return true
		end
	end
	return false
end

function AppointSpyTutorial_Ignore(goalSequence)
	
	-- first exit condition: player has used the ability to spawn a spy
	Player_GetAll(player1)
	SGroup_Filter(sg_allsquads, SBP.AYYUBID_CMP.UNIT_SPY_AYY, FILTER_KEEP)
	local spyCount = SGroup_CountSpawned(sg_allsquads)
	if spyCount > 1 then
		Training_RemoveGoalSequence(goalSequence)
		return true
	end
	
	-- get the current goal
	local goal = goalSequence.goals[goalSequence.currentGoalIndex]
	
	-- second exit condition: the current goal is ignored for 60 seconds
	if goalSequence.isActive then
		if goal.timerID ~= nil and Timer_Exists(goal.timerID) then
			if Timer_GetElapsed(goal.timerID) >= 60 then
				Training_RemoveGoalSequence(goalSequence)
				return true
			end
		end
	end
	
	-- third exit condition: the player hovers over Shajar's ability for a standard time
	if PlayerIsSelectingShajar() then
		-- On controller: Only allow cancelling if the player is in the radial for standard time
		if UI_IsXboxControllerUI() and goalSequence.currentGoalIndex ~= 3 then
			return false
		end
			
		if PredicateHelper_HasUserHoveredOverBP(goal, BP_GetAbilityBlueprint("shajar_convert_to_spy_ayy")) then
			Training_RemoveGoalSequence(goalSequence)
			return true
		end
	end
	
	return false
end

function AppointSpyTutorial_ShajarIsSelected(goal)
	return PlayerIsSelectingShajar()
end

function OpenShajarRadialMenu(goal)

	-- If the menu is closed but the player is currently appointing then we go to the next hint
	return UI_GetActiveRadialMenuType() == RMT_ContextualRadialMenu or training_appointing == true
end

function UsedAppointSpy(goal)

	-- On KBM we leave the hint until we hit the ignore predicate
	if UI_IsXboxControllerUI() == false then
		return false
	end
	
	-- Player has used the ability on the radial so now we show the next stage of the hint sequence on the reticle
	return training_appointing
	
end

function PlacingSpyMonitor(blueprint, phase)
	if blueprint == BP_GetAbilityBlueprint("shajar_convert_to_spy_ayy") then
		if phase == TP_Cancelled then
			training_appointing = false
		elseif phase == TP_Issued then
			training_appointing = true
			Rule_RemoveMe()
		else
			training_appointing = true
		end
	end
end

---------------------------------------------------------------------------------
------------------------------------ UTIL ---------------------------------------
---------------------------------------------------------------------------------

function ReturnFalse()
	return false	
end

function PlayerIsSelectingShajar()
	Misc_GetSelectedSquads(sg_temp, true)
	if SGroup_CountSpawned(sg_shajar) > 0 and Misc_IsSGroupSelected(sg_shajar, ANY) then -- is sg_shajar valid after respawn?
		return true
	end
	return false
end