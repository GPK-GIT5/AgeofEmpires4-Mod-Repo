import("training.scar")
import("training/campaigntraininggoals.scar")
import("cardinal.scar")
import("missionomatic/missionomatic.scar")

function Tutorials_Init()
	SpyTutorial_Init()
	StealthStrikeTutorial_Init()
	PickupTutorial_Init()
	FarmhouseTutorial_Init()
	AppointSpyTutorial_Init()
end

---------------------------------------------------------------------------------
-------------------------------------- Spy --------------------------------------
---------------------------------------------------------------------------------

function SpyTutorial_Init()
	local spy_goal = Training_Goal(
		SGroup_GetSquadAt(sg_spies, 1),
		{ ID = "spy_goal", Message = "$11257212", DataTemplate = "GenericTrainingDataTemplate" }, --Spies enter Stealth automatically. They are revealed after attacking the enemy.
		ReturnFalse
	)

	spy_sequence = Training_GoalSequence(
		"spy_sequence", 
		1, 
		0, 
		SpyTutorial_Trigger, 
		SpyTutorial_Ignore, 
		nil, 
		nil, 
		false, 
		{spy_goal}
	)
end

function SpyTutorial_Enable()
	Training_AddGoalSequence(spy_sequence)
	Training_EnableGoalSequenceByID(spy_sequence, true)
end

function SpyTutorial_Trigger(goalSequence)
	if SGroup_CountSpawned(sg_spies) > 0 then
		local spy = SGroup_GetSquadAt(sg_spies, 1)
		if Misc_IsSquadOnScreen(spy, 0.9) then
			goalSequence.goals[1].triggered_at = goalSequence.goals[1].triggered_at or World_GetGameTime()
			return true
		end
	end
	return false
end

function SpyTutorial_Ignore(goalSequence)
	local triggered_at = goalSequence.goals[1].triggered_at
	if triggered_at ~= nil then
		if World_GetGameTime() - triggered_at >= 15 or SGroup_CountSpawned(sg_spies) == 0 then 
			return true
		end
	end
	return false
end

