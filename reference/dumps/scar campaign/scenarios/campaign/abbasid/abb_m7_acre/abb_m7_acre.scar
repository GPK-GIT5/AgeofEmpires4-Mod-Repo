MissionOMatic_UpdateHolyOrderFlags()

function Mission_SetupPlayers()
	content_pack = CONTENT_PACK_ABBASID_CAMPAIGN
		
	player1 = World_GetPlayerAt(1)
	Setup_SetPlayerName(player1, "$11253752") --Mamluk Sultanate
	--Player_SetCurrentAge(player1, AGE_FEUDAL)
	
	player2 = World_GetPlayerAt(2)
	Setup_SetPlayerName(player2, "$11250539") --Franks
	--Player_SetCurrentAge(player2, AGE_IMPERIAL)
	
	player3 = World_GetPlayerAt(3)
	Setup_SetPlayerName(player3, "$11253753") --Mamluk Allies
	--Player_SetCurrentAge(player3, AGE_CASTLE)

	Player_SetRelationship(player1, player2, R_ENEMY)
	Player_SetRelationship(player1, player3, R_ALLY)
	
	Player_SetRelationship(player2, player1, R_ENEMY)
	Player_SetRelationship(player2, player3, R_ENEMY)
	
	Player_SetRelationship(player3, player1, R_ALLY)
	Player_SetRelationship(player3, player2, R_ENEMY)
	
	PlayerColour_Enable()
	Game_SetPlayerSlotColour(player1, COLOR_BLUE)
    Game_SetPlayerSlotColour(player2, COLOR_RED)
	Game_SetPlayerSlotColour(player3, COLOR_GREEN)
	Game_SetPlayerUISlotColour(player1, COLOR_BLUE)
    Game_SetPlayerUISlotColour(player2, COLOR_RED)
	Game_SetPlayerUISlotColour(player3, COLOR_GREEN)
	
	World_EnableSharedLineOfSight(player1, player3, true)
    World_EnableSharedLineOfSight(player3, player1, true)
	
	Player_SetStateModelBool(player2, "disable_landmark_rebuild", true)
end

function Mission_SetupVariables()	-- create any extra sgroups, egroups, and mission variables in here
	TechTree_GiveEconUpgrades(player1, 3, TT_INCLUDE_TIERED)
	TechTree_GiveEconUpgrades(player1, 2, TT_INCLUDE_NONTIERED)
	TechTree_GiveMilitaryUpgrades(player1, 3, TT_INCLUDE_TIERED)
	TechTree_GiveMilitaryUpgrades(player1, 2, TT_INCLUDE_NONTIERED)
	TechTree_GiveUnitUpgrades(player1, 3, TT_INCLUDE_BOTH)
	Player_CompleteUpgrade(player1, UPG.AYYUBID_CMP.UPGRADE_MIL_PARTHIAN_TACTICS_AYY)
	
	--Enemy Exclusions--
	local enemyExcludedUpgrades = {UPG.COMMON.UPGRADE_NAVAL_MOUNTED_GUNS, UPG.COMMON.UPGRADE_NAVAL_SWIVEL_CANNON, UPG.ENGLISH.UPGRADE_NETWORK_OF_CITADELS_ENG, UPG.COMMON.UPGRADE_NAVAL_FORECASTLE}
	
				
	if Game_GetSPDifficulty() == GD_EXPERT then
		TechTree_GiveEconUpgrades(player2, 4, TT_INCLUDE_BOTH)
		TechTree_GiveMilitaryUpgrades(player2, 4, TT_INCLUDE_BOTH, enemyExcludedUpgrades)
		TechTree_GiveUnitUpgrades(player2, 4, TT_INCLUDE_BOTH)
		
		TechTree_GiveAllUpgrades_ByAge(player3, 3,TT_INCLUDE_BOTH)
	elseif Game_GetSPDifficulty() == GD_HARD then
		TechTree_GiveEconUpgrades(player2, 2, TT_INCLUDE_BOTH)
		TechTree_GiveMilitaryUpgrades(player2, 2, TT_INCLUDE_BOTH, enemyExcludedUpgrades)
		TechTree_GiveUnitUpgrades(player2, 4, TT_INCLUDE_BOTH)
		
		TechTree_GiveAllUpgrades_ByAge(player3, 3,TT_INCLUDE_BOTH)
	elseif Game_GetSPDifficulty() == GD_NORMAL then
		TechTree_GiveEconUpgrades(player2, 2, TT_INCLUDE_BOTH)
		TechTree_GiveMilitaryUpgrades(player2, 2, TT_INCLUDE_BOTH, enemyExcludedUpgrades)
		TechTree_GiveUnitUpgrades(player2, 3, TT_INCLUDE_BOTH)
		
		TechTree_GiveAllUpgrades_ByAge(player3, 4,TT_INCLUDE_BOTH)
	elseif Game_GetSPDifficulty() == GD_EASY then
		TechTree_GiveEconUpgrades(player2, 1, TT_INCLUDE_BOTH)
		TechTree_GiveMilitaryUpgrades(player2, 1, TT_INCLUDE_BOTH, enemyExcludedUpgrades)
		TechTree_GiveUnitUpgrades(player2, 3, TT_INCLUDE_BOTH)
		
		TechTree_GiveAllUpgrades_ByAge(player3, 4,TT_INCLUDE_BOTH)
	end
	
	ABILITY_BARRAGE = BP_GetAbilityBlueprint("acre_barrage_ayy")
	ABILITY_SMALL_BARRAGE = BP_GetAbilityBlueprint("acre_barrage_small_ayy")
	
	Modify_SightRadius(eg_lighthouse_01, 2.5)
	Modify_SightRadius(eg_lighthouse_02, 1.85)
	EGroup_SetInvulnerable(eg_lighthouses, true, -1)
	EGroup_SetTargetingType(eg_lighthouses, Targeting_None)
	local _RemoveScuttle = function(gid, index, eid)
		Entity_RemoveAbility(eid, BP_GetAbilityBlueprint("core_building_scuttle"))
	end
	EGroup_ForEach(eg_lighthouses, _RemoveScuttle)
	EGroup_CompleteUpgrade(eg_lighthouses, UPG.COMMON.UPGRADE_OUTPOST_SPRINGALD)
	EGroup_CompleteUpgrade(eg_lighthouses, UPG.COMMON.UPGRADE_OUTPOST_STONE)
	
	
	sg_all_enemy_ships = SGroup_CreateIfNotFound("sg_all_enemy_ships")
	
	bFirstFlank = true
	bBarrageUsed = false
	
	--DEBUG--
	debug_bGenoeseSkip = false
end

function Mission_SetDifficulty()
	Init_Acre_Difficulty()
end

