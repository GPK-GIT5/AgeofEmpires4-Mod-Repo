function Mission_Preset()	-- any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)	
	Acre_InitMarkerArmies()
	Acre_InitObjectives()
	Acre_InitAlliedUnits()
	
	EGroup_SetAnimatorState(eg_siegecamp, "deploy_splat", "on")
	EGroup_SetAnimatorState(eg_siegecamp, "projectile_vis_state", "on")
	
	Game_TransitionToState("dawn", 0)
	
	--DEBUG: Auto Test--
	AutoTest_OnInit()
	
	FoodReserves_Init()
	
	Player_ModifyAyyubidMilitaryBuildTimes(player1, Util_DifVar({ 0.5, 0.75, 1, 1 }))
	PlayerUpgrades_ApplyHealthBonuses(player1)
	
	--Give the monastery some relics
	local player_mosque = EGroup_GetSpawnedEntityAt(eg_player_mosque, 1)
	Entity_SetStateModelFloat(player_mosque, "relic_count", 1)
		
end

function Mission_Start()	-- this is triggered after the intro, just as control is passed to the player
	Objective_Start(OBJ_DefendSiegeCamp, false)
	
	Objective_Start(OBJ_Genoese, false)
	
	Objective_Start(OBJ_DestroyCrusaders, true)	
	
	--Init Autosave Points
	Rule_AddInterval(Acre_AutoSaveInterval, 600)
	
	Rule_AddInterval(Acre_LaunchAttack, t_difficulty.enemyMods.ACRE_ATTACK_WAVE_TIMER )
	Rule_AddInterval(_Monitor_Enemy_Replacements, t_difficulty.enemyMods.ACRE_ENEMY_REINFORCEMENT_TIMER)
	
	Misc_SetEntityControlGroup(EGroup_GetEntityAt(eg_siegecamp, 1), 0)
	--Misc_SetEntityControlGroup(EGroup_GetEntityAt(eg_alliedbanner, 1), 9)
	
	Player_SetResource(player1, RT_Food, 5000)
	Player_SetResource(player1, RT_Wood, 5000)
	Player_SetResource(player1, RT_Gold, 5000)
	Player_SetResource(player1, RT_Stone, 1000)
	
	--Init Ship Spawned Resource Drops on Death
	Rule_AddSGroupEvent(_Monitor_Ship_Resource_Drops, sg_all_enemy_ships, GE_SquadKilled)
	
	--Init Building Spawned Resource Drops on Death
	Rule_AddEGroupEvent(_Monitor_Land_Resource_Drops, eg_stone_buildings, GE_EntityKilled)	
	
	--Rule_AddInterval(Mission_TrickleResources, 1)
	
	-- Delay VO a bit to give some space after camera
	Rule_AddOneShot(VOCue_MissionStart_Acre, 15)
		
	Acre_LaunchAttack()
	
	if Game_GetSPDifficulty() >= GD_HARD then
		_Monitor_WaterRuins()
		Rule_AddInterval(_Monitor_WaterRuins, t_difficulty.enemyMods.NAVAL_TRANSPORT_REBUILD)
		Rule_AddInterval(SpawnEnemy_FrankishMarines, t_difficulty.enemyMods.NAVAL_ATTACK_TIMER)
		Rule_AddInterval(Flank_Warning, 1)
		
		Rule_AddInterval(_Monitor_Enemy_Naval_Replacements, t_difficulty.enemyMods.ACRE_ENEMY_NAVAL_REINFORCEMENT_TIMER)
		
		Monitor_KeepVisbility()
	end
	
	if Game_GetSPDifficulty() == GD_EASY then
		Init_StoryModeItems()
	end
			
	-- Turn crowns on that were off for the intro cam
	Player_GetAll(player2)
	SGroup_EnableLeaderCrown(sg_allsquads, true)
end

function _Control_AlliedArmy(context, data)
	local thisArmy = data.thisArmy
	local bannerEntity = data.bannerEntity
	
	if SGroup_CountSpawned(thisArmy.sgroup) > 0 then
		if Util_GetDistanceSquared(thisArmy.targets[1].position, Entity_GetPosition(bannerEntity)) > 8 then
			Army_SetTarget(thisArmy, Entity_GetPosition(bannerEntity))
		end
	end
end

function _MonitorAllyArmy(context, data)
	local thisArmy = data.thisArmy
	if SGroup_CountSpawned(thisArmy.sgroup) < 70 then
		SGroup_Clear(sg_temp)
		UnitEntry_DeploySquads(player3, sg_temp, {{type="scar_spearman", numSquads=3},{type="scar_manatarms", numSquads=2},{type="scar_archer", numSquads=2},}, mkr_ally_spawn)
		Army_AddSGroup(thisArmy, sg_temp)
	end
end

function _Monitor_Enemy_Replacements()
	--if World_GetGameTime() - lastCounterAttackTime >= t_difficulty.enemyMods.ACRE_ENEMY_REINFORCEMENT_DELAY then
		if All_Army_Distance_Sorted ~= nil and #All_Army_Distance_Sorted > 0 then
			local thisArmy = nil
			for i = #All_Army_Distance_Sorted, 1, -1 do
				if SGroup_IsEmpty(All_Army_Distance_Sorted[i].sgroup) then
					thisArmy = All_Army_Distance_Sorted[i]
					break
				end
			end
			if thisArmy ~= nil and EGroup_IsEmpty(eg_crusaderkeeps) ~= true then
				if thisArmy.spawn == nil then
					local a=2
				end
				local nearestKeep = EGroup_GetClosestEntity(eg_crusaderkeeps, thisArmy.spawn.position)
				if nearestKeep ~= nil then
					SGroup_Clear(sg_temp)
					CreateUnits(player2, thisArmy.ORIGINAL_UNITS, Util_GetPosition(nearestKeep), sg_temp)
					Army_AddSGroup(thisArmy, sg_temp)
					Army_SetTarget(thisArmy, thisArmy.spawn.position)
				end
			end
		end
	--end
end

function _Monitor_Enemy_Naval_Replacements()
	--if World_GetGameTime() - lastCounterAttackTime >= t_difficulty.enemyMods.ACRE_ENEMY_REINFORCEMENT_DELAY then
		if All_Navy_Distance_Sorted ~= nil and #All_Navy_Distance_Sorted > 0 then
			local thisNavy = nil
			for i = #All_Navy_Distance_Sorted, 1, -1 do
				if SGroup_IsEmpty(All_Navy_Distance_Sorted[i].sgroup) then
					thisNavy = All_Army_Distance_Sorted[i]
					break
				end
			end
			if thisNavy ~= nil and EGroup_IsEmpty(eg_enemy_docks) ~= true then
				if thisNavy.spawn == nil then
					local a=2
				end
				local nearestDock = EGroup_GetClosestEntity(eg_enemy_docks, thisNavy.spawn.position)
				if nearestDock ~= nil then
					SGroup_Clear(sg_temp)
					CreateUnits(player2, thisNavy.ORIGINAL_UNITS, Util_GetPosition(nearestDock), sg_temp)
					Army_AddSGroup(thisNavy, sg_temp)
					Army_SetTarget(thisNavy, thisNavy.spawn.position)
				end
			end
		end
	--end
end

function Mission_TrickleResources()
		
	if t_difficulty.playerMods.RES_TRICKLE_AMOUNT > 0 then
		local resPerSecond = t_difficulty.playerMods.RES_TRICKLE_AMOUNT/60
		Player_AddResource(player1, RT_Gold, resPerSecond, RES_Resourcing)
		Player_AddResource(player1, RT_Food, resPerSecond, RES_Resourcing)
		Player_AddResource(player1, RT_Wood, resPerSecond, RES_Resourcing)
	end
end

function _Monitor_Ship_Resource_Drops(context, data)
	shipsDestroyed = shipsDestroyed or 0
	shipsDestroyed = shipsDestroyed + 1
	local woodPickup = BP_GetEntityBlueprint("resource_pickup_naval_wood_xp3")
	local spawnChance = t_difficulty.playerMods.RES_PICKUP_SPAWN_CHANCE_NAVAL
	local spawnPos = Util_GetPosition(context.victim)
	if shipsDestroyed < 2 then
		CreateEntity(player2, woodPickup, spawnPos)
	elseif shipsDestroyed % spawnChance == 0 then
		CreateEntity(player2, woodPickup, spawnPos)
	end
end

function _Monitor_Land_Resource_Drops(context, data)
	local stonePickup = BP_GetEntityBlueprint("resource_pickup_stone_xp3")
	local spawnAmount = t_difficulty.playerMods.RES_PICKUP_SPAWN_AMOUNT_LAND
	local spawnPos = Util_GetPosition(context.victim)
	local offSets = {OFFSET_FRONT, OFFSET_BACK, OFFSET_LEFT, OFFSET_RIGHT}
	if spawnAmount > 1 then
		for i = 1, spawnAmount do
			local spawnOffset = Util_GetOffsetPosition(spawnPos, offSets[i], 3)
			CreateEntity(player2, stonePickup, spawnOffset)
		end
	else
		CreateEntity(player2, stonePickup, spawnPos)
	end
end

function Get_ValidEnemySpawn()
	local spawn = mkr_crusader_spawning
	if EGroup_IsEmpty(eg_crusaderkeeps) == false then
		spawn = EGroup_GetClosestEntity(eg_crusaderkeeps, mkr_crusader_spawning)
	end
	return spawn
end

function Get_ValidEnemySpawn_Naval()
	local spawn = mkr_naval_spawn
	if EGroup_IsEmpty(eg_enemy_docks) == false then
		spawn = EGroup_GetClosestEntity(eg_enemy_docks, mkr_naval_spawn)
	end
	return spawn
end

function Acre_AutoSaveInterval()
	Util_AutoSave(true, true, 30)
end

function GetRecipe()
	local recipe = {		
		--victory_message = "$39257",
		introNIS = EVENTS.Intro,
		outroNIS = EVENTS.Victory,
		
		onStart = {
			titleCard = {
				icon = "icons/campaign/campaign_slaves_to_sultans",
				title = "$11234497", -- Acre
				date = "$11252172", --1291
			},
		},
		
		locations = {},  
		modules = {},
		onWin = {},
		onLose = {},
	}
	return recipe
end

