--
-- Hattin 1187 - Crusaders objective
--
import("abb_m4_hattin.scar")
import("abb_m4_hattin_data.scar")

function Crusaders_InitObjectives()

	OBJ_Crusaders = {
		Title = "$11253253", 
		Type = ObjectiveType_Primary,
		SetupUI = function()
			Objective_AddUIElements(OBJ_Crusaders, mkr_ui_tiberias, true, "$11253269", false)
		end,
		OnStart = function()
			-- Give the player resources
			Player_SetResource(player1, RT_Food, t_difficulty.playerStartFood)
			Player_SetResource(player1, RT_Wood, t_difficulty.playerStartWood)
			Player_SetResource(player1, RT_Gold, t_difficulty.playerStartGold)
			Player_SetResource(player1, RT_Stone, t_difficulty.playerStartStone)
			-- Re-enable control
			SGroup_SetPlayerOwner(sg_playerUnitsDisabled, player1)
			EGroup_SetPlayerOwner(eg_playerBuildingsDisabled, player1)
			VOCue_SaladinAvailable()
			Rule_AddInterval(VOCue_EnemiesAtTheHorns, 3)
			-- Set rally points for player production buildings
			EGroup_SetRallyPoint(eg_production_infantry, mkr_playerRally_infantry)
			EGroup_SetRallyPoint(eg_production_ranged, mkr_playerRally_ranged)
			EGroup_SetRallyPoint(eg_production_cavalry, mkr_playerRally_cavalry)
			
			SGroup_AddAbility(sg_scuttle_removed, BP_GetAbilityBlueprint("core_unit_death"))
		end,
		IsFailed = function()
			Player_GetAllSquadsNearMarker(player2, sg_temp, mkr_tiberias_control, Marker_GetProximityRadius(mkr_tiberias_control))
			return SGroup_CountSpawned(sg_temp) > 0
		end,
		OnComplete = function()
			Mission_Complete()
		end,
		OnFail = function()
			Mission_Fail()
		end,
		-- This is Objective: 8
		Cheat = function()
			print("CHEAT: Cheating past tutorial")
			-- Unlock the rest of the map
			World_SetInteractionStage(1)
			-- Spawn the allies now that interactivity is enabled
			Hattin_SpawnBarricadeAllies()
			
			-- Simulate perfect tutorial play
			CreateUnits(player1, {type = "scar_spearman", numSquads = 4}, mkr_tutorial_player_spawn_1, sg_tutorial_infantry)
			CreateUnits(player1, {type = "scar_crossbowman", numSquads = 16}, mkr_tutorial_player_spawn_1, sg_tutorial_infantry)
			SGroup_FormationWarpToMarker(sg_tutorial_infantry, mkr_tutorial_skip)
			
			-- Make sure control groups are accessible
			SGroup_SetPlayerOwner(sg_saladin_forces, player1)
			local _AssignToGroup1 = function(gid, idx, sid)
				Misc_SetSquadControlGroup(sid, 1)
			end
			SGroup_ForEach(sg_saladin_forces, _AssignToGroup1)
			
			local _AssignToGroup2 = function(gid, idx, sid)
				Misc_SetSquadControlGroup(sid, 2)
			end
			SGroup_ForEach(sg_tutorial_infantry, _AssignToGroup2)
			
			-- Speed this up
			t_difficulty.crusadePrepTime = 60
		end,
	}
	TOBJ_BurnableFields = {
		Title = "$11253252", 
		Type = ObjectiveType_Tip,
		showTitle = false,
		Parent = OBJ_Crusaders,
	}
	SOBJ_WaveCounter = {
		Title = "$11257167",
		Type = ObjectiveType_Primary,
		Parent = OBJ_Crusaders,
		StartAlongsideParent = true,
		showTitle = false,
		IsComplete = function()
			-- Count the waves killed
			for ii = 1, g_crusaderWaveTotal do
				if scartype(t_waveSGroups[ii]) == ST_SGROUP and SGroup_CountSpawned(t_waveSGroups[ii]) == 0 then
					t_waveSGroups[ii] = nil
					g_crusaderWavesKilled = g_crusaderWavesKilled + 1
				end
			end
			-- Update the counter
			if g_crusaderWaveTotal ~= nil and g_crusaderWaveTotal > 0 then
				Objective_SetCounter(SOBJ_WaveCounter, g_crusaderWavesKilled, g_crusaderWaveTotal)
			end
			
			-- We can't win if we haven't defeated Reynal
			if Objective_IsComplete(SOBJ_DefeatReynald) == false then
				return false	
			end
			
			-- The overall objective is complete not only if Reynald is defeated, but also if all enemies are defeated
			-- This accounts for stragglers from other waves for any reason
			-- (penultimate wave units getting slowed by fires and falling behind final wave units, for example)
			Player_GetAll(player2)
			return SGroup_CountSpawned(sg_allsquads) == 0
		end,
		OnComplete = function()
			Objective_Complete(OBJ_Crusaders)
		end,
	}
	SOBJ_DefeatReynald = {
		Title = "$11253259",		
		Type = ObjectiveType_Primary,
		Parent = OBJ_Crusaders,
		StartAlongsideParent = false,
		SetupUI = function()
			
		end,
		OnStart = function()
			SOBJ_DefeatReynald.showTitle = false
		end,
		IsComplete = function()
			-- True if Reynald has been neutralized
			return SGroup_CountSpawned(sg_crusaders_reynald) == 0
		end,
	}
	TOBJ_PrepareForCrusaders = {
		Title = "$11253255", 
		Type = ObjectiveType_Tip,
		Parent = OBJ_Crusaders,
		StartAlongsideParent = true,
		SetupUI = function()
			Objective_StartTimer(TOBJ_PrepareForCrusaders, COUNT_DOWN, t_difficulty.crusadePrepTime)
			-- Also queue up the warning UI
			local firstCrusaderEntry = t_crusaderData[3]
			if scartype(firstCrusaderEntry) == ST_TABLE then
				firstCrusaderEntry.callbacks.onQueued()
				local preSpawntime = t_difficulty.crusadePrepTime - CRUSADER_INCOMING_ANIMATION_TIME
				Rule_AddOneShot(_Crusaters_PreSpawn, preSpawntime, {entry = firstCrusaderEntry})
			end
		end,
		IsComplete = function()
			if Objective_GetTimerSeconds(TOBJ_PrepareForCrusaders) <= 0 then
				Crusaders_Start()
			end
			return false
		end,
		OnComplete = function()
			-- Remove the objective telling players to look at the fields
			if Objective_IsComplete(OBJ_FieldScoutingGuidance) == false then
				Objective_Complete(OBJ_FieldScoutingGuidance, false, false)
			end
			-- Start the objective-tip telling players to burn the fields
			if Objective_IsStarted(TOBJ_BurnableFields) == false then
				Objective_Start(TOBJ_BurnableFields)
			end
			Objective_Start(OBJ_NextWaveTimer, false, false)
			Objective_Show(TOBJ_PrepareForCrusaders, false, false)
			Objective_Show(OBJ_NextWaveTimer, true, true)
			
			-- Also begin the assistive systems for lower difficulty levels
			if t_difficulty.extraGuidance == true then
				-- Activate the objective that nudges the player to build more units if they've not been building
				-- The reinforcements are also controlled through that
				Rule_AddInterval(Tutorial_CheckForQueueGuidanceStart, {delay = 30, interval = 5})
			end
			
			if t_difficulty.emergencyReinforcements == true then
				Rule_AddInterval(Hattin_ReinforceAsNeeded, 1)
			end
		end,
	}
	SOBJ_PlacementGuidance = {
		Title = "$11256520", 
		Type = ObjectiveType_Bonus,
		showTitle = false,
		Parent = OBJ_Crusaders,
		StartAlongsideParent = t_difficulty.extraGuidance,
		SetupUI = function()
			Objective_SetCounter(SOBJ_PlacementGuidance, 0, PREP_UNIT_COUNT)
			Objective_AddUIElements(SOBJ_PlacementGuidance, mkr_player_preparation, true, "$11256520", true)
			Objective_AddGroundReticule(SOBJ_PlacementGuidance, Marker_GetPosition(mkr_player_preparation), Marker_GetProximityRadius(mkr_player_preparation), BP_GetReticuleBlueprint("aura_ring"))
		end,
		IsComplete = function()
			Player_GetAllSquadsNearMarker(player1, sg_temp, Marker_GetPosition(mkr_player_preparation), Marker_GetProximityRadius(mkr_player_preparation))
			SGroup_Filter(sg_temp, "military", FILTER_KEEP)
			local unitsPresent = SGroup_CountSpawned(sg_temp)
			Objective_SetCounter(SOBJ_PlacementGuidance, unitsPresent, PREP_UNIT_COUNT)
			return unitsPresent >= 15
		end,
		OnComplete = function()
			Objective_Show(SOBJ_PlacementGuidance, false, false)
		end,
		IsFailed = function()
			return Objective_IsComplete(TOBJ_PrepareForCrusaders) == true and Objective_IsComplete(SOBJ_PlacementGuidance) == false
		end,
		OnFail = function()
			Objective_Show(SOBJ_PlacementGuidance, false, false)
		end,
	}
	OBJ_NextWaveTimer = {
		Title = "$11253256", 
		Type = ObjectiveType_Information,
	}
	SOBJ_BuildTroops = {
		Title = "$11253258",		
		Type = ObjectiveType_Primary,
		Parent = OBJ_Crusaders,
		StartAlongsideParent = false,
		SetupUI = function()
			Player_GetAll(player1)
			SGroup_Filter(sg_allsquads, "military", FILTER_KEEP)
			local troopStart = SGroup_CountSpawned(sg_allsquads)
			g_obj_troopGoal = troopStart + TROOP_TRAINING_TARGET
			Objective_SetCounter(SOBJ_BuildTroops, 0, TROOP_TRAINING_TARGET)
			--print(string.format("HATTIN - Training obj counter %s of %s", 0, TROOP_TRAINING_TARGET))
		end,
		OnStart = function()
			
		end,
		IsComplete = function()
			Player_GetAll(player1)
			SGroup_Filter(sg_allsquads, "military", FILTER_KEEP)
			local troopTotal = SGroup_CountSpawned(sg_allsquads)
			-- If we're aiming for 90 and we've got 85, that means we have (20-5)=15 trained so far
			local trainedSoFar = TROOP_TRAINING_TARGET - (g_obj_troopGoal - troopTotal)
			Objective_SetCounter(SOBJ_BuildTroops, trainedSoFar, TROOP_TRAINING_TARGET)
			--print(string.format("HATTIN - Training obj counter %s of %s", trainedSoFar, TROOP_TRAINING_TARGET))
			return troopTotal >= g_obj_troopGoal
		end,
		OnComplete = function()
			Objective_Show(SOBJ_BuildTroops, false, false)
		end,
	}
	OBJ_ProductionQueueGuidance = {
		Title = "$11253276", 
		Type = ObjectiveType_Information,
		PreStart = function()
			g_lastGoodProductionTime = World_GetGameTime()
		end,
		IsComplete = function()
			-- We want to see how many units they're producing
			local totalProductionQueueSize = Player_GetProductionQueueSize(player1)
			-- Warn the player if they're not producing enough!
			
			if totalProductionQueueSize < PRODUCTION_QUEUE_TARGET and Player_GetCurrentPopulation(player1, CT_Personnel) < 200 then
				local elapsedWithoutProduction = World_GetGameTime() - g_lastGoodProductionTime
				if elapsedWithoutProduction >= PRODUCTION_QUEUE_WARNING_TIME and Objective_IsVisible(OBJ_ProductionQueueGuidance) == false then
					Objective_Show(OBJ_ProductionQueueGuidance, true, true)
				end
			elseif totalProductionQueueSize >= PRODUCTION_QUEUE_TARGET then
				g_lastGoodProductionTime = World_GetGameTime()
				if Objective_IsVisible(OBJ_ProductionQueueGuidance) == true then
					Objective_Show(OBJ_ProductionQueueGuidance, false, false)
				end
			end
		end,
	}
	
	-- Registered in order of their desired appearance in the on-screen list
	Objective_Register(OBJ_NextWaveTimer)
	Objective_Register(OBJ_ProductionQueueGuidance)
	Objective_Register(OBJ_Crusaders)
	Objective_Register(TOBJ_BurnableFields)
	Objective_Register(TOBJ_PrepareForCrusaders)
	Objective_Register(SOBJ_WaveCounter)
	Objective_Register(SOBJ_DefeatReynald)
	Objective_Register(SOBJ_BuildTroops)
	Objective_Register(SOBJ_PlacementGuidance)
	Objective_Register(OBJ_FieldScoutingGuidance)
	
	--[[
		The following callbacks are available by including any of the following table entries: (callback recieves the crusader group entry as a parameter)
		callbacks = {
			onSpawned = MyFunc,
			onSpotted = MyFunc,
			onApproached = MyFunc,
			onEngaged = MyFunc,
			onKilled = MyFunc,
		},
	--]]
	
	-- These represent the individual groups that make up the crusaders
	-- They are spawned in this order
	t_crusaderData = {				
		{
			id = "scouts1", spawn = "tut1", rank = 1, tutorial = true,
			army = {
				name = "army_scouts1",
				units = {
					{type = "scar_horseman", numSquads = 8},									
				},
			},
			callbacks = {
				onKilled = Scouts1_Killed,
				preSpawn = function()
				end,
				onSpawned = function()
					UI_CreateMinimapBlip(mkr_tutorial_crusader_spawn, 8, "threat_group")
					MarkerPaths_RepeatAnimateArrowPath(AllMarkers_FromName("mkr_crusaderpath_ui_tutorial", ""), 5, 1)
				end,
			},
		},
		{
			id = "scouts2", spawn = "tut2", rank = 1, tutorial = true,
			army = {
				name = "army_scouts2",
				units = {
					{type = "scar_horseman", numSquads = 18},
					{type = "scar_knight", numSquads = 12},									
				},
				-- This is technically only required for the one part at mkr_crusaderpath_tutorial_3 where
				-- the army needs to funnel through the narrow passage while the crossbowmen are shooting them
				-- from the top. The AI needs to extra leash range to be able to determine a valid path up the hill
				-- that doesn't leave its combat area.
				-- Increasing the leash range to 100 makes sure that they can path towards the ramp on the south.
				-- Without this the AI can get stuck stutter stepping because it keeps getting attacked but can't
				-- figure out how to get to their opponent.
				leashRange = 100,
			},
			callbacks = {
				onKilled = Scouts2_Killed,
				preSpawn = function()
				end,
				onSpawned = function()
					UI_CreateMinimapBlip(mkr_tutorial_crusader_spawn, 8, "threat_group")
					MarkerPaths_RepeatAnimateArrowPath(AllMarkers_FromName("mkr_crusaderpath_ui_tutorial", ""), 5, 1)
				end,
			},
		},
		-- WAVE 1
		{
			id = "crusaders1a", spawn = "north", rank = 1,
			army = {
				units = {
					{type = "scar_archer", numSquads = 6 + t_difficulty.crusaderDifficultyTopUp},
					{type = "scar_militia", numSquads = 4 + t_difficulty.crusaderDifficultyTopUp},
					{type = "scar_spearman", numSquads = 2 + t_difficulty.crusaderDifficultyTopUp},			
				},
			},
			callbacks = {
				onQueued = function()
					g_nextWaveBlips.north = UI_CreateMinimapBlip(mkr_crusader_spawn_north, -1, "threat_group")
				end,
				preSpawn = function()
					UI_DeleteMinimapBlip(g_nextWaveBlips.north)
					MarkerPaths_RepeatAnimateArrowPath(AllMarkers_FromName("mkr_crusaderpath_ui_north", ""), CRUSADER_INCOMING_ANIMATION_TIME, 1)
				end,
				onSpawned = function()
					Util_StartIntel(EVENTS.CrusadersFirstArriveOnMap)
					Sound_Play2D("sfx_campaign_scripted_attack_horn_under_attack_hattin")
				end,
			},
		},
		{
			id = "crusaders1b", spawn = "north", rank = 2,
			army = {
				units = {
					{type = "scar_archer", numSquads = 6 + t_difficulty.crusaderDifficultyTopUp},
					{type = "scar_militia", numSquads = 4 + t_difficulty.crusaderDifficultyTopUp},
					{type = "scar_spearman", numSquads = 2 + t_difficulty.crusaderDifficultyTopUp},				
				},
			},
		},
		{
			id = "crusaders1c", spawn = "north", rank = 3, minDifficulty = GD_NORMAL,
			army = {
				units = {
					{type = "scar_archer", numSquads = 6 + t_difficulty.crusaderDifficultyTopUp},
					{type = "scar_militia", numSquads = 4 + t_difficulty.crusaderDifficultyTopUp},
					{type = "scar_spearman", numSquads = 2 + t_difficulty.crusaderDifficultyTopUp},			
				},
			},
		},
		-- WAVE 2 - TEMPLARS
		{
			id = "templarA", spawn = "south", rank = 1,
			army = {
				units = {
					{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEMPLAR_CRU, numSquads = 6, sgroup = sg_crusaders_firsttemplars},
					{type = "scar_horseman", numSquads = 8 + t_difficulty.crusaderDifficultyTopUp},
				},
			},
			callbacks = {
				onQueued = function()
					g_nextWaveBlips.south = UI_CreateMinimapBlip(mkr_crusader_spawn_south, -1, "threat_group")
				end,
				preSpawn = function()
					UI_DeleteMinimapBlip(g_nextWaveBlips.south)
					MarkerPaths_RepeatAnimateArrowPath(AllMarkers_FromName("mkr_crusaderpath_ui_south", ""), CRUSADER_INCOMING_ANIMATION_TIME, 1)
				end,
				onSpawned = function()
					Util_StartIntel(EVENTS.TemplarsArrive)
					Sound_Play2D("sfx_campaign_scripted_attack_horn_under_attack_hattin")
				end,
			},
		},
		{
			id = "templarB", spawn = "south", rank = 2,
			army = {
				units = {
					{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEMPLAR_CRU, numSquads = 6},
					{type = "scar_horseman", numSquads = 8 + t_difficulty.crusaderDifficultyTopUp},		
				},
			},
		},
		{
			id = "templarC", spawn = "south", rank = 3, minDifficulty = GD_NORMAL,
			army = {
				units = {
					{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEMPLAR_CRU, numSquads = 6},
					{type = "scar_horseman", numSquads = 8 + t_difficulty.crusaderDifficultyTopUp},					
				},
			},
		},
		-- WAVE 3
		{
			id = "crusaders3a", spawn = "mid", rank = 1,
			army = {
				units = {
					{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEMPLAR_MASTER_CRU, sgroup = {sg_crusaders_templarGrandMaster}},
					{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEMPLAR_CRU, numSquads =  8 + t_difficulty.crusaderDifficultyTopUp},
					{type = "scar_horseman", numSquads = 6 + t_difficulty.crusaderDifficultyTopUp},
					{sbp = SBP.CRUSADER_CMP.UNIT_MANGONEL_CRU, numSquads = (1 * t_difficulty.crusaderHasSiege)},
				},
			},
			callbacks = {
				onQueued = function()
					g_nextWaveBlips.mid = UI_CreateMinimapBlip(mkr_crusader_spawn_mid, -1, "threat_group")
				end,
				preSpawn = function()
					UI_DeleteMinimapBlip(g_nextWaveBlips.mid)
					MarkerPaths_RepeatAnimateArrowPath(AllMarkers_FromName("mkr_crusaderpath_ui_mid", ""), CRUSADER_INCOMING_ANIMATION_TIME, 1)
				end,
				onSpawned = function()
					Sound_Play2D("sfx_campaign_scripted_attack_horn_under_attack_hattin")
					Rule_AddInterval(VOCue_TemplarGrandMaster, 1)
				end,
			},
		},
		{
			id = "crusaders3b", spawn = "mid", rank = 2,
			army = {
				units = {
					{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEMPLAR_CRU, numSquads = 6},
					{type = "scar_spearman", numSquads = 8 + t_difficulty.crusaderDifficultyTopUp},
					{type = "scar_archer", numSquads = 8 + t_difficulty.crusaderDifficultyTopUp},
					{sbp = SBP.CRUSADER_CMP.UNIT_MANGONEL_CRU, numSquads = (1 * t_difficulty.crusaderHasSiege)},	
				},
			},
		},
		{
			id = "crusaders3c", spawn = "mid", rank = 3, minDifficulty = GD_NORMAL,
			army = {
