					{type = "scar_manatarms", numSquads = 8 + t_difficulty.crusaderDifficultyTopUp},	
					{sbp = SBP.CRUSADER_CMP.UNIT_TREBUCHET_CRU, numSquads = 2},
				},
			},
		},
		-- WAVE 4
		{
			id = "crusaders4a", spawn = "north", rank = 1,
			army = {
				units = {
					{type = "scar_archer", numSquads = 8 + t_difficulty.crusaderDifficultyTopUp},
					{type = "scar_militia", numSquads = 10 + t_difficulty.crusaderDifficultyTopUp},
					{sbp = SBP.CRUSADER_CMP.UNIT_SPRINGALD_CRU, numSquads = (1 * t_difficulty.crusaderHasSiege)},	
				},
			},
			callbacks = {
				onQueued = function()
					g_nextWaveBlips.north = UI_CreateMinimapBlip(mkr_crusader_spawn_north, -1, "threat_group")
				end,
				preSpawn = function()
					UI_DeleteMinimapBlip(g_nextWaveBlips.north)
					MarkerPaths_RepeatAnimateArrowPath(AllMarkers_FromName("mkr_crusaderpath_ui_north", ""), CRUSADER_INCOMING_ANIMATION_TIME, 1)
				end,
				onSpawned = function()
					Sound_Play2D("sfx_campaign_scripted_attack_horn_under_attack_hattin")
				end,
			},
		},
		{
			id = "crusaders4b", spawn = "north", rank = 2,
			army = {
				units = {
					{type = "scar_archer", numSquads = 8 + t_difficulty.crusaderDifficultyTopUp},
					{type = "scar_militia", numSquads = 10 + t_difficulty.crusaderDifficultyTopUp},
					{sbp = SBP.CRUSADER_CMP.UNIT_SPRINGALD_CRU, numSquads = (1 * t_difficulty.crusaderHasSiege)},
				},
			},
		},
		{
			id = "crusaders4c", spawn = "north", rank = 3, minDifficulty = GD_NORMAL,
			army = {
				units = {
					{type = "scar_archer", numSquads = 8 + t_difficulty.crusaderDifficultyTopUp},
					{type = "scar_militia", numSquads = 10 + t_difficulty.crusaderDifficultyTopUp},
					{sbp = SBP.CRUSADER_CMP.UNIT_SPRINGALD_CRU, numSquads = (1 * t_difficulty.crusaderHasSiege)},			
				},
			},
		},
		-- WAVE 5 - HOSPITALLERS
		{
			id = "hospitallerA", spawn = "south", rank = 1,
			army = {
				units = {
					{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_HOSPITALLER_CRU, numSquads = 6, sgroup = sg_crusaders_firsthospitallers},
					{type = "scar_horseman", numSquads = 6 + t_difficulty.crusaderDifficultyTopUp},									
				},
			},
			callbacks = {
				onQueued = function()
					g_nextWaveBlips.south = UI_CreateMinimapBlip(mkr_crusader_spawn_south, -1, "threat_group")
				end,
				preSpawn = function()
					UI_DeleteMinimapBlip(g_nextWaveBlips.south)
					MarkerPaths_RepeatAnimateArrowPath(AllMarkers_FromName("mkr_crusaderpath_ui_south", ""), CRUSADER_INCOMING_ANIMATION_TIME, 1)
				end,
				onSpawned = function()
					Sound_Play2D("sfx_campaign_scripted_attack_horn_under_attack_hattin")
					Util_StartIntel(EVENTS.HospitallersArrive)
