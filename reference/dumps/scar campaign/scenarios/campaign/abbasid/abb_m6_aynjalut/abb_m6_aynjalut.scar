function MakeEGroupAttackable(context, data)
	if data.is_attackable then
		EGroup_SetInvulnerable(data.egroup, false)
		EGroup_SetTargetingType(data.egroup, Targeting_Automatic)		
	else
		EGroup_SetInvulnerable(data.egroup, true)
		EGroup_SetTargetingType(data.egroup, Targeting_None)	
	end
end

------------------------------------------------------------------------
-------------------------- MinimapPaths --------------------------------
------------------------------------------------------------------------

function ShowMinimapPath()
	local minimap_markers = AllMarkers_FromName("mkr_minimap_arrows", "")
	local pathInterval = 1
	local offset = pathInterval - 0.125
	for i = 1, 8 do
		Rule_AddOneShot(Minimap_AnimateArrowPath, pathInterval * i - offset, { path = minimap_markers })
	end
end


function Minimap_AnimateArrowPath(context, data)
	local path = data.path
	local iconSpacing = 50
	local iconSize = 0.25
	local iconName = "icons\\minimap\\military_route_enemy"
	local iconDuration = 0.75
	local iconInterval = 0.125

	local data = {
		path = path,
		iconSpacing = iconSpacing,
		iconSize = iconSize,
		iconName = iconName,
		progress = {
			distanceSoFar = 0,
			pointIndex = 1,
			distanceBetweenPoints = Util_GetDistance(path[1], path[2]),
		},
		blipIDs = {},
	}
	Rule_AddInterval(Minimap_AnimateArrowPath_AddBlip, {interval = iconInterval}, data)
	Rule_AddInterval(Minimap_AnimateArrowPath_RemoveBlip, {delay = iconDuration, interval = iconInterval}, data)
end

function Minimap_AnimateArrowPath_AddBlip(context, data)
	-- get the position between the current point and the next point
	local pointA = Util_GetPosition(data.path[data.progress.pointIndex])
	local pointB = Util_GetPosition(data.path[data.progress.pointIndex + 1])
	local position = Util_GetPositionFromAtoB(pointA, pointB, math.max(data.progress.distanceSoFar, 1))		-- distances less than 1 are taken as percentages, so round up if we're under that threshold
	
	-- create the arrow at that position
	local blipID = MapIcon_CreatePosition(position, data.iconName, data.iconSize, 255, 255, 255, 255)
	MapIcon_SetFacingPosition(blipID, pointB)
	table.insert(data.blipIDs, blipID)
	
	-- step forward the iconSpacing amount
	data.progress.distanceSoFar = data.progress.distanceSoFar + data.iconSpacing
	while data.progress.distanceSoFar > data.progress.distanceBetweenPoints do 	
		data.progress.pointIndex = data.progress.pointIndex + 1
		local newIndex = data.progress.pointIndex
		if newIndex >= #data.path then 
			Rule_RemoveMe()		-- we've reached the end of the path, so remove the rule and stop the while loop
			break
		else
			data.progress.distanceSoFar = data.progress.distanceSoFar - data.progress.distanceBetweenPoints
			data.progress.distanceBetweenPoints = Util_GetDistance(data.path[newIndex], data.path[newIndex + 1])
		end
	end	
end

function Minimap_AnimateArrowPath_RemoveBlip(context, data)
	local blipID = data.blipIDs[1]
	table.remove(data.blipIDs, 1)
	MapIcon_Destroy(blipID)
	if #data.blipIDs == 0 then 
		Rule_RemoveMe()
	end
end

function Healers_Init()
	healers = {}
	for _, marker in ipairs(AllMarkers_FromName("mkr_healer", "")) do
		local healer = { marker = marker, sgroup = SGroup_CreateUniqueWithPrefix("sg_healer") }
		CreateUnits(player5, {{ type = "scar_monk" }}, marker, healer.sgroup)
		SGroup_AddGroup(sg_afula_villagers, healer.sgroup)
		table.insert(healers, healer)
	end
	Rule_Add(Healers_Monitor)
end

function Healers_Monitor(context, data)
	for _, healer in ipairs(healers) do
		if SGroup_CountSpawned(healer.sgroup) > 0 then
			local healer_heading = Squad_GetHeading(SGroup_GetSquadAt(healer.sgroup, 1))
			local marker_direction = Marker_GetDirection(healer.marker)
			if healer_heading ~= marker_direction then
				if SGroup_IsIdle(healer.sgroup, ANY) then
					SGroup_MoveAndFace(healer.sgroup, healer.marker)	
				end
			end
		end
	end
end

function PrintReport(prefix)
	Player_GetAll(player1, sg_allsquads)
	local militaryCost = SGroup_GetResourceCost(sg_allsquads)
	print(prefix.."  PlayerMilitaryCost: "..militaryCost.."  PlayerMilitaryCount:"..SGroup_CountSpawned(sg_allsquads))
end

function GetReinforcementRatio()
	Player_GetAll(player1, sg_allsquads)
	SGroup_Filter(sg_allsquads, "scar_leader", FILTER_REMOVE)
	local militaryCost = SGroup_GetResourceCost(sg_allsquads)
	militaryCost = math.max(militaryCost, PLAYER_MILITARY_COST_FLOOR)
	militaryCost = math.min(militaryCost, PLAYER_MILITARY_COST_CEIL)
	local ratio = militaryCost - PLAYER_MILITARY_COST_FLOOR
	ratio = ratio / (PLAYER_MILITARY_COST_CEIL - PLAYER_MILITARY_COST_FLOOR)
	ratio = REINFORCEMENT_RATIO_MAX + ratio * (REINFORCEMENT_RATIO_MIN - REINFORCEMENT_RATIO_MAX)
	return ratio
end

function Math_Round(float)
	return math.floor(float + 0.5)
end
