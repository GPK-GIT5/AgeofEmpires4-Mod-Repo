function Malian_PreIntro_Shot04_Units()
	
	sg_preintro4_player_javelin_01 = SGroup_CreateIfNotFound("sg_preintro4_player_javelin_01")
	sg_preintro4_player_archer_01 = SGroup_CreateIfNotFound("sg_preintro4_player_archer_01")
	
	sg_preintro4_enemy_archer_01 = SGroup_CreateIfNotFound("sg_preintro4_enemy_archer_01")
	sg_preintro4_enemy_manatarms_01 = SGroup_CreateIfNotFound("sg_preintro4_enemy_manatarms_01")
	sg_preintro4_enemy_towerElephant_01 = SGroup_CreateIfNotFound("sg_preintro4_enemy_towerElephant_01")
	
	UnitEntry_DeploySquads(localPlayer, sg_preintro4_player_javelin_01, {{sbp = BP_GetSquadBlueprint("unit_javelin_4_mal"), numSquads = 12 }}, mkr_preintro4_javelin_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_preintro4_player_archer_01, {{sbp = BP_GetSquadBlueprint("unit_archer_4_mal"), numSquads = 8 }}, mkr_preintro4_archer_spawn)
	
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro4_enemy_archer_01, {{sbp = BP_GetSquadBlueprint("unit_archer_4_sul"), numSquads = 10 }}, mkr_preintro4_enemy_archer_spawn01)
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro4_enemy_towerElephant_01, {{sbp = BP_GetSquadBlueprint("unit_war_elephant_tower_4_sul"), numSquads = 1 }}, mkr_preintro4_enemy_elephant_spawn01)
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro4_enemy_manatarms_01, {{sbp = BP_GetSquadBlueprint("unit_manatarms_4_sul"), numSquads = 4 }}, mkr_preintro4_enemy_menatarms_spawn01)
	
	SGroup_SetAvgHealth(sg_preintro4_enemy_archer_01, 0.3)
	
	Cmd_FormationAttackMove(sg_preintro4_enemy_archer_01, mkr_preintro4_enemy_archer_rally01, false)
	Cmd_FormationAttackMove(sg_preintro4_enemy_towerElephant_01, mkr_preintro4_enemy_archer_rally01, false)
	
	local leftArcPos = Util_GetPosition(mkr_preintro4_javelin_rally_left)
	local rightArcPos = Util_GetPosition(mkr_preintro4_javelin_rally_right)
	ArcFormation(leftArcPos, rightArcPos, sg_preintro4_player_javelin_01, 0, false, 0)
	
	
	Cmd_Attack(sg_preintro4_player_javelin_01, sg_preintro4_enemy_towerElephant_01, true)
	Cmd_AttackMove(sg_preintro4_player_archer_01, mkr_preintro4_enemy_menatarms_spawn01, false)
	
	Rule_AddOneShot(Malian_PreIntro_Shot04_ManAtArms_Attack, 10)
	Rule_AddOneShot(Malian_PreIntro_Shot04_Archer_Attack, 10)
	Rule_AddOneShot(Malian_PreIntro_Shot04_Archer_Retreat, 14)
	Rule_AddOneShot(Malian_PreIntro_Shot04_Enemy_Archer_Chase, 15)
end

function Malian_PreIntro_Shot04_ManAtArms_Attack()
	
	Cmd_Attack(sg_preintro4_enemy_manatarms_01, sg_preintro4_player_archer_01, false)
end

function Malian_PreIntro_Shot04_Archer_Attack()
	--tell Malian archers to each attack one of the enemy archers, applying poison to all of them
	
	sg_singleE = SGroup_CreateIfNotFound("sg_singleE")
	
	
	for i = 1, SGroup_Count(sg_preintro4_player_archer_01) do
		local squad = SGroup_GetSquadAt(sg_preintro4_player_archer_01, i)
		if(squad ~= nil) then
			SGroup_Single(sg_single, squad)
			
			if(i < SGroup_Count(sg_preintro4_enemy_archer_01)) then
				
				local squad2 = SGroup_GetSquadAt(sg_preintro4_enemy_archer_01, i)
				if(squad2 ~= nil) then
					SGroup_Single(sg_singleE, squad2)
					
					Cmd_Attack(sg_single, sg_singleE, false)
					
				end
			end
			
		end
	end
	
	
	
end

function Malian_PreIntro_Shot04_Archer_Retreat()
	
	if(SGroup_Exists("sg_preintro4_player_archer_01") == true) then
		Cmd_Move(sg_preintro4_player_archer_01, mkr_preintro4_archer_spawn, false)
	end
	
end

function Malian_PreIntro_Shot04_Enemy_Archer_Chase()
	
	if(SGroup_Exists("sg_preintro4_player_archer_01") == true) then
		if(SGroup_Exists("sg_preintro4_enemy_archer_01") == true) then
			
			sg_singleP = SGroup_CreateIfNotFound("sg_singleP")
	
	
			for i = 1, SGroup_Count(sg_preintro4_enemy_archer_01) do
				local squad = SGroup_GetSquadAt(sg_preintro4_enemy_archer_01, i)
				if(squad ~= nil) then
					SGroup_Single(sg_single, squad)
					
					local targetIndex = i
					if(targetIndex < SGroup_Count(sg_preintro4_player_archer_01)) then
						local squad2 = SGroup_GetSquadAt(sg_preintro4_player_archer_01, targetIndex)
						if(squad2 ~= nil) then
							SGroup_Single(sg_singleP, squad2)
							
							Cmd_Attack(sg_single, sg_singleP, false)
							Cmd_Move(sg_single, mkr_preintro4_archer_spawn, true)
							
						end
					else
						--Cmd_AttackMove(sg_single, mkr_preintro4_archer_spawn, false)
						Cmd_Move(sg_single, mkr_preintro4_archer_spawn, false)
					end
					
					
				end
			end
			
			
			
		end
	end
end

function Malian_Intro_Shot_Units()
	
	
	
end


