		SGroup_DestroyAllSquads(sg_preintro4_enemy_archer_01)
	end
	if(SGroup_Exists("sg_preintro4_enemy_towerElephant_01") == true) then
		SGroup_DestroyAllSquads(sg_preintro4_enemy_towerElephant_01)
	end
	if(SGroup_Exists("sg_preintro4_enemy_manatarms_01") == true) then
		SGroup_DestroyAllSquads(sg_preintro4_enemy_manatarms_01)
	end
	
end

function Malian_PreIntro_Shot05_Clean_Up()
	
	
end

-----------------------------------------------------------------------
-- Additional Functions
-----------------------------------------------------------------------

-- Destroys a squad
function Destroy(gid, idx, eid)
	Squad_Destroy(eid)
end

-- Destroy an entity
function DestroyEntity(gid, idx, eid)
	Entity_Destroy(eid)	
end
	
function DespawnCarcasses()
		
	local _DespawnCarcass = function(gid, idx, eid)
		-- Checks if the entity is a carcass and destroys it
		if Entity_IsOfType(eid, "carriable") then	
			Entity_Destroy(eid)
		end
	end
	
	World_GetAllNeutralEntities(eg_all_neutral)
	EGroup_ForEach(eg_all_neutral, _DespawnCarcass)
end



