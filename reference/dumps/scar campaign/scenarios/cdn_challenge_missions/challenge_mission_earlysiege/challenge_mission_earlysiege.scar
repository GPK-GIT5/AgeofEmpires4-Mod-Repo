	Cmd_FormationMove(sg_enemy_spearmen, mkr_enemy_spearmen_rally, false, false, mkr_enemy_spearmen_facing)
	Cmd_FormationMove(sg_enemy_menatarms, mkr_enemy_menatarms_rally, false, false,  mkr_enemy_menatarms_facing)
	Cmd_FormationMove(sg_enemy_archers, mkr_enemy_archers_rally, false, false,  mkr_enemy_archers_facing)
	Cmd_FormationMove(sg_enemy_mangonels, mkr_enemy_mangonel_rally, false, false,  mkr_enemy_mangonel_facing)
	Cmd_FormationMove(sg_enemy_springalds, mkr_inner_springald_rally, false, false,  mkr_spearmen_defend_inner)
	
end

-- Add new objectives
function ChallengeMission_InitializeObjectives()
	
	EarlySiegeTrainingGoals_OnInit()
	TrainingGoal_EnableEarlySiegeGoals()
	
	-- For every player
	for i, player in pairs(PLAYERS) do
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			
			-----------------------------------------------------------------------
			-- Victory Objective
			
			-- Register Primary objective
			Objective_Register(_challenge.victory.objectiveVictory, player.id)
			-- Start objective
			Objective_Start(_challenge.victory.objectiveVictory, true, false)
			-- Player has victory objective
			player._challenge.hasObjectiveVictory = true;
			
			-----------------------------------------------------------------------
			-- Secondary Objective(s)
			
			-- Assign Victory Objective as Parent
			_challenge.victory.objectiveSub1.Parent = _challenge.victory.objectiveVictory
			-- Register Construct objective
			Objective_Register(_challenge.victory.objectiveSub1, player.id)
			-- Start objective
			Objective_Start(_challenge.victory.objectiveSub1, false, false)
			-- Add UI Elements to Outpost
			Objective_AddUIElements(_challenge.victory.objectiveSub1, enemy_capital, false, "$11202434", true, 10)
			-- Player has objective
			player._challenge.hasObjectiveSub1 = true;

			-- Assign Victory Objective as Parent
			_challenge.victory.objectiveSub2.Parent = _challenge.victory.objectiveVictory
			-- Register Capital objective
			Objective_Register(_challenge.victory.objectiveSub2, player.id)
			-- Start objective
			Objective_Start(_challenge.victory.objectiveSub2, false, false)
			-- Add UI Elements to Outpost
			Objective_AddUIElements(_challenge.victory.objectiveSub2, enemy_landmark, false, "$11202435", true, 10)
			-- Player has objective
			player._challenge.hasObjectiveSub2 = true;
			
			-----------------------------------------------------------------------
			-- Medal Objective
			
			-- Get time elapsed since start time (end of cinematic)
			local timeElapsed = World_GetGameTime() - player._challenge.startTime
			
			-- Register Medal objective
			Objective_Register(_challenge.benchmarks.gold.objective, player.id)
			-- Start objective
			Objective_Start(_challenge.benchmarks.gold.objective, false, false)
			-- Player has kpi objective
			player._challenge.hasKpiObjective = true;
			
			-- If timer does not already exist
			if not Timer_Exists(player._challenge.timer) then 
				-- Start timer
				Timer_Start(player._challenge.timer, _challenge.benchmarks.gold.time)
			end
			
			-- Update timer display (incrementing)
			Objective_StartTimer(_challenge.benchmarks.gold.objective, COUNT_UP, timeElapsed, 10)
			
			-- Set player's current benchmark as Gold
			player.currentBenchmark = _challenge.benchmarks.gold
			
		end
	end
end


-- Update Objectives - Called by a rule every simtic
function ChallengeMission_Update()
	
	-- For every player
	for i, player in pairs(PLAYERS) do
		
		-- If player is local (not one of the AI players)
		if player.isLocal then
			
			-----------------------------------------------------------------------
			-- Objective Logic
			
			-- If player has the Victory Objective
			if (player._challenge.hasObjectiveVictory and not Objective_IsComplete(_challenge.victory.objectiveVictory)) then
				-- Check for Victory
				ChallengeMission_CheckVictory()
			end
			
			--return if player has the victory objective to prevent medal changes during outro narration
			if (Objective_IsComplete(_challenge.victory.objectiveVictory)) then
				return
			end
			
			-----------------------------------------------------------------------
			-- Medal Logic
			
			-- Get time elapsed since start time (end of cinematic)
			--local timeElapsed = Timer_GetElapsed(player._challenge.timer)
			local timeElapsed = World_GetGameTime() - player._challenge.startTime
			
			--if the player has lost all of their units and got replacements, disable medals
			if(playerGotReinforcements == true) then
				--fail the current objective
				if(player.currentBenchmark == _challenge.benchmarks.gold) then
					Objective_Fail(_challenge.benchmarks.gold.objective)
					
					-- Register Failed Medal objective
					Objective_Register(_challenge.victory.failedMedals, player.id)
					-- Start objective
					Objective_Start(_challenge.victory.failedMedals, false, false)
					
				elseif(player.currentBenchmark == _challenge.benchmarks.silver) then
					Objective_Fail(_challenge.benchmarks.silver.objective)
					
					-- Register Failed Medal objective
					Objective_Register(_challenge.victory.failedMedals, player.id)
					-- Start objective
					Objective_Start(_challenge.victory.failedMedals, false, false)
					
				elseif(player.currentBenchmark == _challenge.benchmarks.bronze) then
					Objective_Fail(_challenge.benchmarks.bronze.objective)
					
					-- Register Failed Medal objective
					Objective_Register(_challenge.victory.failedMedals, player.id)
					-- Start objective
					Objective_Start(_challenge.victory.failedMedals, false, false)
					
				end
				
				--set benchmark to unplaced
				player.currentBenchmark = _challenge.benchmarks.unplaced
				
				-- If objective timer already exists
				if Timer_Exists(player._challenge.timer) then
					-- End objective timer
					Timer_End(player._challenge.timer)
				end
			else
				
				--print(timeElapsed)
				
				-- If time elapsed meets the time requirement for Gold
				if timeElapsed < _challenge.benchmarks.gold.time then
					
					-- If player's current Benchmark is not set to Gold
					if player.currentBenchmark ~= _challenge.benchmarks.gold then
						
						-- Register objective
						Objective_Register(_challenge.benchmarks.gold.objective, player.id)
						-- Start objective
						Objective_Start(_challenge.benchmarks.gold.objective, false, false)
						
						-- If objective timer already exists
						if Timer_Exists(player._challenge.timer) then
							-- End objective timer
							Timer_End(player._challenge.timer)
						end	
						
						-- Start timer
						Timer_Start(player._challenge.timer, _challenge.benchmarks.gold.time)
						
						-- Update timer display (incrementing)
						Objective_StartTimer(_challenge.benchmarks.gold.objective, COUNT_UP, timeElapsed, 10)
						
						-- Set player's current benchmark as Gold
						player.currentBenchmark = _challenge.benchmarks.gold
						
					end
					
					-- If time elapsed meets the time requirement for Silver
				elseif timeElapsed < _challenge.benchmarks.silver.time then
					
					-- If player's current Benchmark is not set to Silver
					if player.currentBenchmark ~= _challenge.benchmarks.silver then
						
						-- Remove kpi objective
						Objective_Fail(_challenge.benchmarks.gold.objective, false, false)
						
						-- Register objective
						Objective_Register(_challenge.benchmarks.silver.objective, player.id)
						-- Start objective
						Objective_Start(_challenge.benchmarks.silver.objective, false, false)
						
						-- If objective timer already exists
						if Timer_Exists(player._challenge.timer) then
							-- End objective timer
							Timer_End(player._challenge.timer)
						end
						
						-- Start timer
						Timer_Start(player._challenge.timer, _challenge.benchmarks.silver.time)
						
						-- Update timer display (incrementing)
						Objective_StartTimer(_challenge.benchmarks.silver.objective, COUNT_UP, timeElapsed, 10)
						
						--play failed gold dialogue
						Rule_AddOneShot(ChallengeMission_MissedGold, 1.2)
						
						-- Set player's current benchmark as Silver
						player.currentBenchmark = _challenge.benchmarks.silver
						
					end
					
					-- If time elapsed meets the time requirement for Bronze
				elseif timeElapsed < _challenge.benchmarks.bronze.time then		
					
					-- If player's current Benchmark is not set to Bronze
					if player.currentBenchmark ~= _challenge.benchmarks.bronze then
						
						-- Remove kpi objective
						Objective_Fail(_challenge.benchmarks.silver.objective, false, false)
						
						-- Register objective
						Objective_Register(_challenge.benchmarks.bronze.objective, player.id)
						-- Start objective
						Objective_Start(_challenge.benchmarks.bronze.objective, false, false)
						
						-- If objective timer already exists
						if Timer_Exists(player._challenge.timer) then
							-- End objective timer
							Timer_End(player._challenge.timer)
						end
						
						-- Start timer
						Timer_Start(player._challenge.timer, _challenge.benchmarks.bronze.time)
						
						-- Update timer display (incrementing)
						Objective_StartTimer(_challenge.benchmarks.bronze.objective, COUNT_UP, timeElapsed, 10)
						
						--play failed silver dialogue
						Rule_AddOneShot(ChallengeMission_MissedSilver, 1.2)
						
						-- Set player's current benchmark as Bronze
						player.currentBenchmark = _challenge.benchmarks.bronze
						
					end
					
					-- If time elapsed exceeds the time requirement for Bronze
				else
					
					-- If player's current Benchmark is not set to Unplaced
					if player.currentBenchmark ~= _challenge.benchmarks.unplaced then
						
						-- Remove kpi objective
						Objective_Fail(_challenge.benchmarks.bronze.objective, false, false)
						
						-- Register objective
						Objective_Register(_challenge.benchmarks.unplaced.objective, player.id)
						-- Start objective
						Objective_Start(_challenge.benchmarks.unplaced.objective, false, false)
						
						-- If objective timer already exists
						if Timer_Exists(player._challenge.timer) then
							-- End objective timer
							Timer_End(player._challenge.timer)
						end	
						
						-- Start timer
						Timer_Start(player._challenge.timer, timeElapsed)
						
						-- Update timer display (incrementing)
						Objective_StartTimer(_challenge.benchmarks.unplaced.objective, COUNT_UP, timeElapsed)
						
						--play failed bronze dialogue
						Rule_AddOneShot(ChallengeMission_MissedBronze, 1.2)
						
						-- Set player's current benchmark as Unplaced
						player.currentBenchmark = _challenge.benchmarks.unplaced
						
					end
				end
			end
		end
	end
end

function ChallengeMission_MissedGold()
	if(not Objective_IsComplete(_challenge.victory.objectiveVictory)) then
		Util_StartIntel(EVENTS.NarrGoldFailed)
	end
end

function ChallengeMission_MissedSilver()
	if(not Objective_IsComplete(_challenge.victory.objectiveVictory)) then
		Util_StartIntel(EVENTS.NarrSilverFailed)
	end
end

function ChallengeMission_MissedBronze()
	if(not Objective_IsComplete(_challenge.victory.objectiveVictory)) then
		Util_StartIntel(EVENTS.NarrBronzeFailed)
	end
end

-- Check where player units are to update music
function ChallengeMission_MusicCheck()
	
	if Player_AreSquadsNearMarker(localPlayer, audio_area_trigger_upper) then
		-- Lock Music Intensity
		Music_LockIntensity(MUSIC_RARE)
		print("Trigger MUSIC_RARE")
	elseif Player_AreSquadsNearMarker(localPlayer, audio_area_trigger_lower) then
		-- Lock Music Intensity
		Music_LockIntensity(MUSIC_TENSE_COMBAT_RARE)
		print("Trigger MUSIC_TENSE_COMBAT_RARE")
	end
end

-- Global event callback for destruction
function ChallengeMission_OnDestruction(context)
	
	-- Check if player has destroyed a Conquest building
	if Entity_IsOfType(context.victim, _challenge.victory.destroyRequirement) then
		
		-- For every player
		for i, player in pairs(PLAYERS) do	
			
			-- If the player is local (not one of the AI players)
			if player.isLocal then
				
				-- If player has not completed Capital Town Center subobjective
				if (player._challenge.hasObjectiveSub1 and not Objective_IsComplete(_challenge.victory.objectiveSub1)) then
					
					-- If the destroyed building was the East
					if (context.victim == player._challenge.enemyCapital) then
						
						-- Track as last destroyed entity marker
						_challenge.victory.lastConquestLocation = Entity_GetPosition(player._challenge.enemyCapital)
						
						-- Mark Objective as Complete
						Objective_Complete(_challenge.victory.objectiveSub1, true, false)
						-- Increment Victory counter
						player._challenge.conquestProgress = player._challenge.conquestProgress + 1
						
						-- Play Victory Stinger
						Music_PlayStinger("mus_stinger_campaign_positive")
						
						-- Play dialogue
       					Util_StartIntel(EVENTS.NarrDestroyTC)
			
						-- Create SGroups
						local sg_attackers = SGroup_CreateIfNotFound("sg_attackers")
						Player_GetAllSquadsNearMarker(localPlayer, sg_attackers, Entity_GetPosition(context.victim), 10)
						SGroup_Filter(sg_attackers, "infantry", FILTER_KEEP)
						
						-- If there was more than one infantry attacker
						if (SGroup_Count(sg_attackers) > 0) then
							-- Trigger Walla
							Sound_PlayWallaCelebrateOnSGroup(sg_attackers)
						end
	
					end
					
					--remove minimap blip
					for index, entry in pairs(minimapBlips) do 	
						if entry.id == Entity_GetID(context.victim) then
							UI_DeleteMinimapBlip(entry.blip)
						end
					end
					
				end
				
				-- If player has not completed Landmark subobjective
				if (player._challenge.hasObjectiveSub2 and not Objective_IsComplete(_challenge.victory.objectiveSub2)) then
					
					-- If the destroyed building was the West
					if (context.victim == player._challenge.enemyLandmark) then
						
						-- Track as last destroyed entity
						_challenge.victory.lastConquestLocation = Entity_GetPosition(player._challenge.enemyLandmark)
						
						-- Mark Objective as Complete
						Objective_Complete(_challenge.victory.objectiveSub2, true, false)
						-- Increment Victory counter
						player._challenge.conquestProgress = player._challenge.conquestProgress + 1
						
						-- Play Victory Stinger
						Music_PlayStinger("mus_stinger_campaign_positive")
						
						-- Play dialogue
						Util_StartIntel(EVENTS.NarrDestroyKremlin)
						
						-- Create SGroups
						local sg_attackers = SGroup_CreateIfNotFound("sg_attackers")
						Player_GetAllSquadsNearMarker(localPlayer, sg_attackers, Entity_GetPosition(context.victim), 10)
						SGroup_Filter(sg_attackers, "infantry", FILTER_KEEP)
						
						-- If there was more than one infantry attacker
						if (SGroup_Count(sg_attackers) > 0) then
							-- Trigger Walla
							Sound_PlayWallaCelebrateOnSGroup(sg_attackers)
						end
					end
					
					--remove minimap blip
					for index, entry in pairs(minimapBlips) do 	
						if entry.id == Entity_GetID(context.victim) then
							UI_DeleteMinimapBlip(entry.blip)
						end
					end
					
				end
			end
		end
	end
	
	-- If player has not breached the enemy walls
	if (_challenge.victory.hasBreachedWall == false) then
		
		-- Check if destroyed entity was a wall
		if Entity_IsOfType(context.victim, "wall") then
			
			-- Play Victory Stinger
			Music_PlayStinger("mus_stinger_campaign_positive")

			-- Play dialogue
       		--Util_StartIntel(EVENTS.NarrEnteredWalls)
			
			-- Create SGroups
			local sg_attackers = SGroup_CreateIfNotFound("sg_attackers")
			Player_GetAllSquadsNearMarker(localPlayer, sg_attackers, Entity_GetPosition(context.victim), 10)
			SGroup_Filter(sg_attackers, "infantry", FILTER_KEEP)
			
			-- If there was more than one infantry attacker
			if (SGroup_Count(sg_attackers) > 0) then
				-- Trigger Walla
				Sound_PlayWallaCelebrateOnSGroup(sg_attackers)
			end
			
			-- Play dialogue
       		Util_StartIntel(EVENTS.NarrEnteredWalls)
			
			--retreat archers defending front gate
			Rule_Remove(WallArchersReset)
			Rule_AddOneShot(WallArchersRetreat, 0)
			
			--activate defend triggers
			Rule_AddInterval(DefendWithArchers, 3.5)
			Rule_AddInterval(DefendWithMenAtArms, 3.5)
			Rule_AddInterval(DefendWithSpearmen, 3.5)
			Rule_AddInterval(DefendWithSpringalds, 5)
			
			--remove outside gate trigger (this won't be hit if the player attacks from the north)
			Rule_Remove(EnemyPatrolDetectedPlayer)
			
			-- Track that wall was breached
			_challenge.victory.hasBreachedWall = true
			
		end
	end
	
	-- If player has not destroyed a non-critical building
	if (hasDestroyedBuilding == false) then
		
		-- Check if destroyed entity was a building that is not a defensive structure or the 2 objectives
		if (Entity_IsOfType(context.victim, "building") and Entity_IsOfType(context.victim, "defensive_structure") == false and context.victim ~= enemyCapital and context.victim ~= enemyLandmark)then
			
			-- Play dialogue
       		Util_StartIntel(EVENTS.NarrTargetPriority)
			
			-- Track that building was destroyed
			hasDestroyedBuilding = true
			
		end
	end
	
	-- For every player
	for i, player in pairs(PLAYERS) do	
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			-- If player has the Victory Objective and it hasn't been completed
			if (player._challenge.hasObjectiveVictory and not Objective_IsComplete(_challenge.victory.objectiveVictory)) then
				
				-- Check if local player is annihilated
				ChallengeMission_CheckAnnihilation(context)
				
			end
		end
	end
end

hasStartedReinforcementTimer = false
reinforcementTime = 0
-- Evaluates whether the player whose unit/building was killed is eliminated.
function ChallengeMission_CheckAnnihilation(context)		
	
	-- For every player
	for i, player in pairs(PLAYERS) do	
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			
			-- If the victim is the local player
			if context.victimOwner == player.id then
				
				-- If player has not been eliminated
				if not player.isEliminated then	
					
					-- Get player squads
					local squads = Player_GetSquads(player.id)
					-- Filter out sheep
					SGroup_Filter(squads, "gaia", FILTER_REMOVE)
					-- Filter out scouts
					SGroup_Filter(squads, "scout", FILTER_REMOVE)
					-- Get number of squads
					local num_squads = SGroup_CountSpawned(squads)
					-- Remove sgroup that was just created
					SGroup_Destroy(squads)
					
					-- Check for annihiliation when player has no squads left
					if num_squads == 0 then
						
						isCheckingAnnihiliation = true
						
					end			
				end
			end
		end
	end
end


isCheckingAnnihiliation = false

function CheckEarlySiegeAnnihiliation()
	
	if(isCheckingAnnihiliation == false) then
		hasStartedReinforcementTimer = false
		return
	end
	
	-- For every player
	for i, player in pairs(PLAYERS) do	
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			
			-- Get player squads
			local squads = Player_GetSquads(player.id)
			-- Filter out sheep
			SGroup_Filter(squads, "gaia", FILTER_REMOVE)
			-- Filter out scouts
			SGroup_Filter(squads, "scout", FILTER_REMOVE)
			-- Get number of squads
			local num_squads = SGroup_CountSpawned(squads)
			-- Remove sgroup that was just created
			SGroup_Destroy(squads)
			
			-- Check for annihiliation when player has no squads left
			if num_squads == 0 then
				
				-- Get player resources
				local food = Player_GetResource(player.id, RT_Food)
				local wood = Player_GetResource(player.id, RT_Wood)
				local gold = Player_GetResource(player.id, RT_Gold)
				
				
				local has_entity_with_queue = false
				local has_squads_in_queue = false
				local has_resources_remaining = false
				local entities = Player_GetEntities(player.id)
				
				-- Check if player has a unit in production or sufficient resources to produce something. 
				for i = 1, EGroup_CountSpawned(entities) do
					local entity = EGroup_GetEntityAt(entities, i)					
					if not Entity_IsBuilding(entity) or Entity_GetBuildingProgress(entity) >= 1.0 then		-- Accounts for both packed Mongol buildings and finished buildings of other civs 
						if Entity_HasProductionQueue(entity) then
							local num_items_in_queue = Entity_GetProductionQueueSize(entity)
							for j = 0, (num_items_in_queue - 1) do
								if Entity_GetProductionQueueItemType(entity, j) == PITEM_Spawn then
									has_entity_with_queue = true
									has_squads_in_queue = true
									break
								end
							end
							if has_squads_in_queue then
								break
							end
						end
						for entity_type, cost in pairs(player._annihilation.cheapest_squad_cost) do 
							if Entity_IsOfType(entity, entity_type) then 									
								has_entity_with_queue = true
								if food >= cost.food and wood >= cost.wood and gold >= cost.gold then
									has_resources_remaining = true
									break
								end
							end
						end
						if has_entity_with_queue and has_resources_remaining then
							break
						end
					end
				end
				EGroup_Destroy(entities)
				
				
				if(has_squads_in_queue == true) then
					hasStartedReinforcementTimer = false
				else
					if(hasStartedReinforcementTimer == false) then
						reinforcementTime = World_GetGameTime()
						hasStartedReinforcementTimer = true
					end
					
				end
				
				--after enough time has passed, ignore remaining resources
				local currentGameTime = World_GetGameTime()
				if(hasStartedReinforcementTimer == true and currentGameTime > reinforcementTime + 10) then
					has_resources_remaining = false
				end
				
				
				
				-- Player is annihilated if they have no units alive and either: no buildings that can produce something or no units in production (and no resources to produce anything).
				if not has_entity_with_queue or (not has_squads_in_queue and not has_resources_remaining) then
					
					if(not Objective_IsComplete(_challenge.victory.objectiveVictory)) then
						--instead of losing the mission, the player will now get additional units
						EarlySiegeReinforcements()
					end
				end
			end	
		end
	end
end


function EarlySiegeReinforcements()
	
	playerGotReinforcements = true
	hasStartedReinforcementTimer = false
	
	-- Set starting resources
	Player_SetResource(localPlayer, RT_Food, _challenge.startingResources.food)
	Player_SetResource(localPlayer, RT_Wood, _challenge.startingResources.wood)
	Player_SetResource(localPlayer, RT_Gold, _challenge.startingResources.gold)
	Player_SetResource(localPlayer, RT_Stone, _challenge.startingResources.stone)
	
	
	-- Get unit blueprints
	local sbp_spearman_mon = BP_GetSquadBlueprint("unit_spearman_3_mon")
	local sbp_scout_mon = BP_GetSquadBlueprint("unit_scout_1_mon")
	local sbp_archer_mon = BP_GetSquadBlueprint("unit_archer_3_mon")
	
	--[[ PLAYER UNITS ]]--
	
	-- Create SGroups
	sg_player_spearmen1 = SGroup_CreateIfNotFound("sg_player_spearmen1")
	sg_player_spearmen2 = SGroup_CreateIfNotFound("sg_player_spearmen2")
	sg_player_scout = SGroup_CreateIfNotFound("sg_player_scout")
	
	-- Spawn units
	UnitEntry_DeploySquads(localPlayer, sg_player_spearmen1, {{sbp = sbp_archer_mon, numSquads = 16 }}, mkr_player_spearmen1_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_player_spearmen2, {{sbp = sbp_spearman_mon, numSquads = 16 }}, mkr_player_spearmen2_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_player_scout, {{sbp = sbp_scout_mon, numSquads = 3 }}, mkr_player_scout_spawn)
	
	-- Face units
	Cmd_FormationMove(sg_player_spearmen1, mkr_player_spearmen1_spawn, false, false, mkr_player_spearmen1_facing)
	Cmd_FormationMove(sg_player_spearmen2, mkr_player_spearmen2_spawn, false, false, mkr_player_spearmen2_facing)
	Cmd_FormationMove(sg_player_scout, mkr_player_scout_spawn, false, false, mkr_player_scout_facing)
	
	
	--add call to action
	EventCues_CallToAction("$11202439", CTA_CELEBRATE, nil, nil, Marker_GetPosition(mkr_intro_endpoint), 30, "icons/cta/illustrations/02_celebration", "mus_stinger_campaign_triumph_short")
	
end

-- Gets number of entries in given Table
function GetTableLength(T)
	
	-- Store count
	local count = 0
	
	-- For every entry in Table
	for _ in pairs(T) do
			
		-- Increment count
		count = count + 1 
			
	end
	
	-- Return count
	return count
		
end

-- Check if player has completed the Challenge Mission
function ChallengeMission_CheckVictory()
	
	-- For every player
	for i, player in pairs(PLAYERS) do	

		-- If the player is local (not one of the AI players)
		if player.isLocal then
			
			-- Check if key buildings have been destroyed
			if (player._challenge.conquestProgress >= _challenge.victory.completionRequirement) then
				
				--special case: fail objective if the player needed reinforcements
				if(playerGotReinforcements) then
					
					Objective_Fail(_challenge.victory.objectiveVictory, false, true)
					Mission_Complete()
					
				else
					-- Store completion time
					local completionSeconds = World_GetGameTime() - player._challenge.startTime
					player._challenge.completionTime = completionSeconds / 60
					
					-- Package completion time for Data Store
					local trialInformation = {kpi = completionSeconds}
					
					-- Provide completion time to Stats system via Data Store
					Game_StoreTableData("trial", trialInformation)
					
					print(string.format("CHALLENGE COMPLETED IN %f MINUTES", player._challenge.completionTime))
					
					-- Set victory objective to complete
					Objective_Complete(_challenge.victory.objectiveVictory, false, true)
					
					-- Pause objective timer
					Objective_PauseTimer(player.currentBenchmark.objective)
				end
			end
		end
	end
end

-- Trigger unit walla and building fires
function ChallengeMission_InitializeOutro()
	
	-- For every player
	for i, player in pairs(PLAYERS) do	

		-- If the player is local (not one of the AI players)
		if player.isLocal then
			
			-- Get player's surviving units
			local sg_playerUnits = Player_GetSquads(player.id)
			
			-- Set player's units to invulnerable
			SGroup_SetInvulnerable(sg_playerUnits, true, 0)
		end
	end
	
	-- Check for last units standing
	Rule_AddInterval(ChallengeMission_CheckCheer, 1)
	-- Set enemy buildings on fire
	ChallengeMission_SetBuildingsOnFire()
	
end

-- Check for last team standing and initialize cheering
function ChallengeMission_CheckCheer()
	
	-- Create SGroups
	local sg_playerSurvivors = SGroup_CreateIfNotFound("sg_playerSurvivors")
	local sg_enemySurvivors = SGroup_CreateIfNotFound("sg_enemySurvivors")
	
	-- Get player squads near 
	Player_GetAllSquadsNearMarker(localPlayer, sg_playerSurvivors, _challenge.victory.lastConquestLocation, 40)
	local playerUnitCount = SGroup_Count(sg_playerSurvivors)

	-- Get player squads near 
	Player_GetAllSquadsNearMarker(enemyPlayer, sg_enemySurvivors, _challenge.victory.lastConquestLocation, 40)
	local enemyUnitCount = SGroup_Count(sg_enemySurvivors)

	-- If the enemy does not have any units near the end position
	if enemyUnitCount == 0 then
		
		-- Make units cheer
		SGroup_EnableCheering(sg_playerSurvivors, true, -1, WALLA_CAMP_CELEBRATE_LARGE)
		
		-- End this rule
		Rule_RemoveMe()
		
	end
end

-- Randomly sets enemy buildings on fire
function ChallengeMission_SetBuildingsOnFire()
	
	-- Get units
	local sg_enemy_units = Player_GetSquads(enemyPlayer)
	-- Remove units
	SGroup_DestroyAllSquads(sg_enemy_units)
	
	-- Create Egroup
	local eg_enemy_buildings = EGroup_CreateIfNotFound("eg_enemy_buildings")
	-- Get all enemy buildings
	eg_enemy_buildings = Player_GetAllEntities(enemyPlayer)
	
	-- Set building on fire
	local function _SetFire(gid, idx, eid)
		
		-- Gets random number for fire threshold
		local randFire = World_GetRand(1, 100)
		-- Gets random number for damage
		local randDamage = World_GetRand(20, 80)/100
		
		-- If entity is a wall
		if Entity_IsOfType(eid, "wall") then
			
			-- If number is greater than wall threshold
			if (randFire > 80) then
				
				-- Damage
				Entity_SetHealth(eid, randDamage)
				-- Set on Fire
				Entity_SetOnFire(eid)
				
			end
		
		-- If not a wall, it's a building
		else
			-- If number is greater than building threshold
			if (randFire > 0) then
				
				-- Damage
				Entity_SetHealth(eid, randDamage)
				-- Set on Fire
				Entity_SetOnFire(eid)
				
			end
		end
	end
	
	-- For every building
	EGroup_ForEach(eg_enemy_buildings, _SetFire)
	
end

-- End Challenge
function ChallengeMission_EndChallenge()

	-- Set player as victorious
	Core_SetPlayerVictorious(localPlayer, nil, WR_OBJECTIVECOMPLETE)
	-- Slowdown sim rate for post-match screen
	Game_SetSimRate(0.5)
	
end

-- Defeat Presentation Functions
function ChallengeMission_DefeatPresentation(playerID)
		
	-- For every player
	for i, player in pairs(PLAYERS) do	
		
		-- If player is local (not AI)
		if player.isLocal then 
			
			-- Clear player selection
			Misc_ClearSelection()
			-- Set taskbar to invisible
			Taskbar_SetVisibility(false)
			
			-- Set primary end message
			local endMessage = "$11179828" -- "Challenge Failed"
			-- Stores a victory message (default = nothing)
			local defeatMessage = "$11166951"
			
			-- Add Victory presentation
			Rule_AddOneShot(_gameOver_message, GAMEOVER_OBJECTIVE_TIME, {_playerID = playerID, _icon = _challenge.icons.victoryObjective, _endType = endMessage, _message = defeatMessage, _sound = "ConquestDefeatEvent", _videoURI = "stinger_defeat"})
			
		end
	end
end


function SetVillagersToHunt()

	
	local function _AssignHunter(gid, idx, sid)
		
		-- There are no more than 2 deer (alive) within 15 Meters of the drop off
		local eg_close_food_deposits = Misc_FindDepositsOfTypeCloseToPosition(RT_Food,
			Cardinal_ConvertTypeToEntityBlueprint("villager", localPlayer), 
			Squad_GetPosition(sid),
			120)
		
		local genericDeerBp = BP_GetSquadBlueprint("gaia_huntable_deer")
		local sg_deer = SGroup_CreateUnique("")
		
		
		if EGroup_Count(eg_close_food_deposits) ~= 0 then
			for i = 1, EGroup_Count(eg_close_food_deposits), 1 do
				local deposit = EGroup_GetEntityAt(eg_close_food_deposits, i) 
				local deposit_squad = Entity_GetSquad(deposit)
				if deposit_squad ~= nil then
					local squadBP = Squad_GetBlueprint(deposit_squad)
					if squadBP == genericDeerBp then
						SGroup_Add(sg_deer, deposit_squad)
					end
				end
			end
			EGroup_Clear(eg_close_food_deposits)
		end
		
		-- Assign!
		if SGroup_Count(sg_deer) > 0 then
			local sg_targetDeer = SGroup_CreateUnique("")

			SGroup_Single(sg_single, sid)
			local sacrificialDeer = SGroup_GetClosestSquad(sg_deer, Util_GetPosition(sid))
			if sacrificialDeer ~= nil then
				SGroup_Single(sg_targetDeer, sacrificialDeer)
				LocalCommand_SquadSquad(localPlayer, sg_single, SCMD_Gather, sg_targetDeer, false)
			end
		end
		
	end
	
	
	
	SGroup_ForEach(sg_enemy_hunter, _AssignHunter)
	
	
	
end

