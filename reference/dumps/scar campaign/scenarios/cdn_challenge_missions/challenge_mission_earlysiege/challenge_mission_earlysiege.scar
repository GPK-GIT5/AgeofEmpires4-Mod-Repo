-- Called when Mission loads
function Mission_OnInit()
	
	if UI_IsXboxUI() then
		_challenge.benchmarks.bronze = {
			goal = 20, -- 20 minutes
			time = 20*60, -- 20 minutes
			objective = {},
		}
		_challenge.benchmarks.silver = {
			goal = 12, -- 12 minutes
			time = 12*60, -- 12 minutes
			objective = {},
		}
		_challenge.benchmarks.gold = {
			goal = 7, -- 7 minutes
			time = 7*60, -- 7 minutes
			objective = {},
		}
	end
	
	-- Setup Victory Objectives
	_challenge.victory.objectiveVictory = {
		-- Set Objective Title
		Title = "$11202404", -- "Defeat the Rus"
		-- Set Objective Type
		Type = OT_Primary,
		OnComplete = function()
			Mission_Complete()
		end,
	}
	_challenge.victory.objectiveSub1 = {
		-- Set Objective Title
		Title = "$11202405", -- "Destroy the Rus Town Center"
		-- Set Objective Type
		Type = OT_Secondary,
	}
	_challenge.victory.objectiveSub2 = {
		-- Set Objective Title
		Title = "$11202406", -- "Destroy the Kremlin Landmark"
		-- Set Objective Type
		Type = OT_Secondary,
	}
	--set up minimap blips
	-- Get Capital Town Center
	enemyCapital = EGroup_GetEntityAt(enemy_capital, 1)
	-- Get Landmark
	enemyLandmark = EGroup_GetEntityAt(enemy_landmark, 1)
	local entry = {
		id = Entity_GetID(enemyCapital),
		blip  = UI_CreateMinimapBlip(enemyCapital, -1, "objective_secondary")
	}
	table.insert(minimapBlips, entry)
	entry = {
		id = Entity_GetID(enemyLandmark),
		blip  = UI_CreateMinimapBlip(enemyLandmark, -1, "objective_secondary")
	}
	table.insert(minimapBlips, entry)
	
	_challenge.victory.destroyRequirement = "landmark"
	_challenge.victory.completionRequirement = 2
	_challenge.victory.lastConquestLocation = nil
	_challenge.victory.hasBreachedWall = false
	
	-- Setup Benchmark Objectives
	_challenge.benchmarks.unplaced.objective = {
		-- Set Objective Title
		Title = "$11166938", -- "Time Elapsed"
		-- Set Objective Type
		Type = OT_Bonus,
		-- Set Objective Icon
		Icon = _challenge.icons.noMedalObjective,
	}
	_challenge.benchmarks.bronze.objective = {
		-- Set Objective Title
		Title = Loc_FormatText("$11202175", _challenge.benchmarks.bronze.goal, 0), -- "Bronze Medal (Goal %1TIME_REQUIREMENT%m) - "
		TelemetryTitle = "TimeRequired_BronzeMedal",
		-- Set Objective Type
		Type = OT_Bonus,
		-- Set Objective Icon
		Icon = _challenge.icons.bronzeMedalObjective,
	}
	_challenge.benchmarks.silver.objective = {
		-- Set Objective Title
		Title = Loc_FormatText("$11202176", _challenge.benchmarks.silver.goal, 0), -- "Silver Medal (Goal %1TIME_REQUIREMENT%m) - "
		TelemetryTitle = "TimeRequired_SilverMedal",
		-- Set Objective Type
		Type = OT_Bonus,
		-- Set Objective Icon
		Icon = _challenge.icons.silverMedalObjective,
	}
	_challenge.benchmarks.gold.objective = {
		-- Set Objective Title
		Title = Loc_FormatText("$11202177", _challenge.benchmarks.gold.goal, 0), -- "Gold Medal (Goal %1TIME_REQUIREMENT%m) - "
		TelemetryTitle = "TimeRequired_GoldMedal",
		-- Set Objective Type
		Type = OT_Bonus,
		-- Set Objective Icon
		Icon = _challenge.icons.goldMedalObjective,
	}
	
	_challenge.victory.failedMedals =
	{
		Title = "$11215025",
		Type = ObjectiveType_Information,
	}
	
	--Cache the cost of the cheapest unit that can be made from each type of building.
	for i, player in pairs(PLAYERS) do
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			
			-- Setup table to store cheapest squad
			player._annihilation = {cheapest_squad_cost = {}}
			
			
			for entity_type, squad_type in pairs(_challenge.annihilation.type_map) do 
				
				local sbp = Cardinal_ConvertTypeToSquadBlueprint(squad_type, player.id)
				
				if sbp == nil then
					
					print(string.format("Annihilation_OnInit() - No squad blueprint found for %s %s", player.raceName, squad_type))
					
				else
					
					player._annihilation.cheapest_squad_cost[entity_type] = Player_GetSquadBPCost(player.id, sbp)
					
				end
			end
		end
	end
	
end

-- Setup functionality for mission
function Mission_OnGameSetup()
	
	localPlayer = World_GetPlayerAt(1) --Player
	enemyPlayer = World_GetPlayerAt(2) --Enemy
	Player_SetStateModelBool(enemyPlayer, "disable_landmark_rebuild", true)
	Player_SetStateModelBool(localPlayer, "disable_landmark_rebuild", true)
	
end

-- Mission Preset
function Mission_Preset()
	
	-- Setup Game and Players
	ChallengeMission_SetupChallengePlayers()
	-- Add unit and upgrade restrictions
	ChallengeMission_SetRestrictions()
	
end

-- Called before Mission Start
function Mission_PreStart()
	
	-- Get map resources
	ChallengeMission_FindAllResources()
	-- Spawn Starting Units
	ChallengeMission_InitStartingUnits()
	-- Add Starting Upgrades
	ChallengeMission_InitStartingUpgrades()
	
	Rule_AddInterval(MenAtArmsPatrolLeft, 1)
	Rule_AddInterval(MenAtArmsPatrolCenter, 1)
	Rule_AddInterval(MenAtArmsPatrolRight, 1)
	
	-- Check for end of Event
	Rule_AddInterval(Mission_PreStart_IntroNISFinished, 0.125)
	-- Hold off on starting the mission until cinematic finishes
	StartMission_Hold()
end

-- Called at Mission Start
function Mission_Start()

	-- Setup Challenge Mission
	ChallengeMission_SetupChallenge()
	
	-- Initialize Objectives
	ChallengeMission_InitializeObjectives()
	
	-- Register callbacks for global events
	Rule_AddGlobalEvent(ChallengeMission_OnDestruction, GE_EntityKilled)
	
	Rule_AddInterval(CheckEarlySiegeAnnihiliation, .5)
	
	Rule_AddInterval(EnemyPatrolDetectedPlayer, .5)
	Rule_AddInterval(EnemyPatrolAttackPlayer, .5)
	menAtArmsPatrolDirection = 1
	
	Rule_AddInterval(PositionEnemySpearmen, 1)
	
	SetVillagersToHunt()
	
	--reduce ram build time
	local sbp_ram_mon = BP_GetSquadBlueprint("unit_ram_3_mon")
	Modify_EntityBuildTime(localPlayer, sbp_ram_mon, .1)
	
	-- Update Objectives and check for Victory
	Rule_AddInterval(ChallengeMission_Update, 0.125)
	Rule_AddInterval(ChallengeMission_MusicCheck, 1)
	
	Rule_AddInterval(EarlySiegeTrainingHelper, .125)
	
	--play start dialogue
    Util_StartIntel(EVENTS.NarrationAtStart)
	
    Util_StartIntel(EVENTS.NarrRamIntro)
end
cinematicFinished = false
-- Checks if intro Event is running
function Mission_PreStart_IntroNISFinished()
	    if Event_IsAnyRunning() == false then
		EarlySiege_PreIntro_CleanUpAll()
        Rule_RemoveMe()
        StartMission_ReleaseHold()
    end
end
-----------------------------------------------------------------------
-- Functions
-----------------------------------------------------------------------

function EarlySiegeTrainingHelper()
	if(selectSiegeEngineersCount <= selectSiegeEngineersMax and placingRamPhaseActive == false) then
		--if no infantry are selected, reset construction
		local sg_currentSelection = SGroup_CreateIfNotFound("sg_currentSelection")
		if(SGroup_Count(sg_currentSelection) > 0) then
			SGroup_Filter(sg_currentSelection, "infantry", FILTER_KEEP)
			if(SGroup_Count(sg_currentSelection) == 0) then
				OnConstructionPhaseChange(nil, TP_Issued, 0)
			end
		end
	end
end
-- Configure Players
function ChallengeMission_SetupChallengePlayers()
	
	Setup_SetPlayerName(localPlayer, "$11202432") -- Mongols
	Player_SetCurrentAge(localPlayer, AGE_CASTLE)
	Player_SetMaximumAge(localPlayer, AGE_CASTLE)
	
	Setup_SetPlayerName(enemyPlayer, "$11202433") -- Rus Fortress
	Player_SetCurrentAge(enemyPlayer, AGE_CASTLE)
	Player_SetMaximumAge(enemyPlayer, AGE_CASTLE)

end

