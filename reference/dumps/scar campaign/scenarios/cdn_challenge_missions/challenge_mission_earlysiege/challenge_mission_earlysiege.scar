-- Get all resources on map
function ChallengeMission_FindAllResources()
	
	-- Create egroups
	eg_allNeutral = EGroup_CreateIfNotFound("eg_allNeutral")
	eg_allWoodResources = EGroup_CreateIfNotFound("eg_allWoodResources")
	eg_allStoneResources = EGroup_CreateIfNotFound("eg_allStoneResources")
	eg_allGoldResources = EGroup_CreateIfNotFound("eg_allGoldResources")
	
	-- Get all neutral entities
	World_GetAllNeutralEntities(eg_allNeutral)
	
	-- Filter out resources
	EGroup_Filter(eg_allNeutral, "tree", FILTER_REMOVE, eg_allWoodResources)
	EGroup_Filter(eg_allNeutral, "stone", FILTER_REMOVE, eg_allStoneResources)
	EGroup_Filter(eg_allNeutral, "gold", FILTER_REMOVE, eg_allGoldResources)
	
end

-- Initialize Town Life
function ChallengeMission_InitTownLifeModules()
	
	-- Assign enemy Villagers to TownLife Modules
	Prefab_DoAction(MissionOMatic_FindModule("RusHuntingEcon"), "AddSGroup", sg_enemy_hunter)
	
	-- workaround for fisherman not working
	Rule_AddOneShot(ChallengeMission_InitFisherman, 2)
	
end

-- workaround for fisherman not working
function ChallengeMission_InitFisherman()
	
	local function _AssignFisherman(gid, idx, sid)
		SGroup_Single(sg_single, sid)
		local e_closest_fish = EGroup_GetClosestEntity(eg_shore_fish, Util_GetPosition(sid))
		if e_closest_fish ~= nil then
			EGroup_Single(eg_single, e_closest_fish)
			LocalCommand_SquadEntity(localPlayer, sg_single, SCMD_Gather, eg_single, false)
			EGroup_Remove(eg_shore_fish, e_closest_fish)
		else
			print("Could not find fish to assign villager to")
		end
		
	end
	
	SGroup_ForEach(sg_enemy_fisherman0, _AssignFisherman)
	SGroup_ForEach(sg_enemy_fisherman1, _AssignFisherman)
	
end

-- Initialize Combat Mission-o-Matic Modules
function ChallengeMission_InitCombatModules()
	
	-- Assign enemy units to Defend Modules
	Prefab_DoAction(MissionOMatic_FindModule("DefendFord"), "AddSGroup", sg_enemy_mangonels)
	Prefab_DoAction(MissionOMatic_FindModule("DefendInner"), "AddSGroup", sg_enemy_spearmen)
	Prefab_DoAction(MissionOMatic_FindModule("DefendInner"), "AddSGroup", sg_enemy_springalds)
	Prefab_DoAction(MissionOMatic_FindModule("DefendOuter"), "AddSGroup", sg_enemy_menatarms)
	Prefab_DoAction(MissionOMatic_FindModule("DefendGate"), "AddSGroup", sg_enemy_archers)
	
	-- Ensure military units move to their starting location
	Rule_AddOneShot(ChallengeMission_RallyMilitary, 10)
	
end

