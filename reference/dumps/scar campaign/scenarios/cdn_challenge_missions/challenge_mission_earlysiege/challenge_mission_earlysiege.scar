function MenAtArmsPatrolLeft()
	
	if Prox_AreSquadsNearMarker(sg_enemy_menatarms2, mkr_menatarms_patrol_right, ANY, 5) then
		
		menAtArmsPatrolDirection = -1
		--move enemy men at arms to trigger location
		Cmd_Move(sg_enemy_menatarms2, mkr_menatarms_patrol_center, false)
		
	end
end

function MenAtArmsPatrolCenter()
	
	if Prox_AreSquadsNearMarker(sg_enemy_menatarms2, mkr_menatarms_patrol_center, ANY, 5) then
		
		--move enemy men at arms to trigger location
		if(menAtArmsPatrolDirection == 1) then 
			Cmd_Move(sg_enemy_menatarms2, mkr_menatarms_patrol_right, false)
		else
			Cmd_Move(sg_enemy_menatarms2, mkr_menatarms_patrol_left, false)
		end
		
	end
end

function MenAtArmsPatrolRight()
	
	if Prox_AreSquadsNearMarker(sg_enemy_menatarms2, mkr_menatarms_patrol_left, ANY, 5) then
		
		menAtArmsPatrolDirection = 1
		--move enemy men at arms to trigger location
		Cmd_Move(sg_enemy_menatarms2, mkr_menatarms_patrol_center, false)
		
	end
end

--play dialogue and reveal map when the player gets within a certain distance
function EnemyPatrolDetectedPlayer()
	
	local sg_player_units = Player_GetSquads(localPlayer)
		
	local s_closest_attacker = SGroup_GetClosestSquad(sg_player_units, Util_GetPosition(sg_enemy_menatarms2))
	if s_closest_attacker ~= nil then	
		--only attack if the unit is close enough (prevents attacking across the map)
		if(Util_GetDistance(s_closest_attacker, sg_enemy_menatarms2) < 70) then
			
			--reveal map at gate
			FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_ford_zone), 20, -1)
			
			-- Play dialogue
       		Util_StartIntel(EVENTS.NarrEnemyPatrols)
			Rule_RemoveMe()
		end
	end
	
end

--end the patrols and attack when the player gets close
function EnemyPatrolAttackPlayer()
	
	local sg_count = SGroup_Count(sg_enemy_menatarms2)
	
	-- If menatarms have been defeated
	if SGroup_Count(sg_enemy_menatarms2) == 0 then
		--remove rules
		Rule_Remove(MenAtArmsPatrolLeft)
		Rule_Remove(MenAtArmsPatrolCenter)
		Rule_Remove(MenAtArmsPatrolRight)
		Rule_RemoveMe()
		return
	end
		
	local sg_player_units = Player_GetSquads(localPlayer)
	
	local s_closest_attacker = SGroup_GetClosestSquad(sg_player_units, Util_GetPosition(sg_enemy_menatarms2))
	if s_closest_attacker ~= nil then	
		if(Util_GetDistance(s_closest_attacker, sg_enemy_menatarms2) < 40) then
			Cmd_AttackMove(sg_enemy_menatarms2, Util_GetPosition(s_closest_attacker), false)
			
			EnemyGarrisonWoodFort()
			
			--remove rules
			Rule_Remove(MenAtArmsPatrolLeft)
			Rule_Remove(MenAtArmsPatrolCenter)
			Rule_Remove(MenAtArmsPatrolRight)
			Rule_RemoveMe()
			
		end
	end
end

--garrison the wooden fort with nearby villagers
function EnemyGarrisonWoodFort()
	
	-- Create SGroup
	local sg_garrison_workers = SGroup_CreateIfNotFound("sg_garrison_workers")
	Player_GetAllSquadsNearMarker(enemyPlayer, sg_garrison_workers, Util_GetPosition(mkr_enemy_fisherman0_spawn), 30)
	SGroup_Filter(sg_garrison_workers, "villager", FILTER_KEEP)
	
	-- Create EGroup
	local eg_garrison_fort = EGroup_CreateIfNotFound("eg_garrison_fort")
	Player_GetAllEntitiesNearMarker(enemyPlayer, eg_garrison_fort, Util_GetPosition(mkr_enemy_fisherman0_spawn), 30)
	EGroup_Filter(eg_garrison_fort, "wooden_fortress", FILTER_KEEP)
	
	if(SGroup_CountSpawned(sg_garrison_workers) > 0 and EGroup_CountSpawned(eg_garrison_fort) > 0) then
		Cmd_Garrison(sg_garrison_workers, eg_garrison_fort, false, false, false)
	end
	
end

function Mission_SetupCheatMenu()

	CheatMenu_RegisterCheatFunction(Mission_Cheat_ViewRecipe, "View Recipe", false)
	CheatMenu_RegisterCheatFunction(Mission_Cheat_Win, "Mission-o-Matic Win", false)
	CheatMenu_RegisterCheatFunction(Mission_Cheat_Lose, "Mission-o-Matic Lose", false)
	CheatMenu_RegisterCheatFunction(Mission_Cheat_Complete_Obj, "Complete Active Objectives", false)
	CheatMenu_RegisterCheatFunction(Mission_Cheat_Fail_Obj, "Fail Active Objectives", false)
	
	if scartype(EVENTS) == ST_TABLE then 
		for index, event in pairs(EVENTS) do
			if string.find(index, "ECAM") ~= nil then
				CheatMenu_AddMenuItem_Event("Play E-Cam "..index, false, "playECAM", index)
			else
				CheatMenu_AddMenuItem_Event("Play Speech "..index, false, "playSpeechEvent", index)
			end
		end
	end
	
end

function Mission_ActivateMenuItem(mode, value)

	if mode == "playECAM" and scartype(value) == ST_STRING then
		PlayECAM(value)
	elseif mode == "playSpeechEvent" and scartype(value) == ST_STRING then
		PlaySpeech(value)
	end	
	
end

--? @shortdesc Used to view the mission recipe that this mission was generated from
function Mission_Cheat_ViewRecipe()

	view(MissionRecipe)
	
end

--? @shortdesc Used to WIN the entire mission
function Mission_Cheat_Win()
	
	-- kill everything that isn't the player's
	for index, player in pairs(PLAYERS) do 
		if player.index ~= 1 then
			Player_GetAll(player.id)
			SGroup_Kill(sg_allsquads)
		end
	end
	
	-- complete all objectives
	for index, objective in pairs(g_missionObjectives) do 
		Obj_SetState(objective.ID, OS_Complete)
	end
	
	World_NotifyDebugEndSP(true)

	CardinalMissionData = {
		report = {
			win = true,
			gameLength = World_GetGameTime(),
		},
	}
	
	Game_RetrieveTableData("CardinalMissionData", true) -- clear out the old store
	Game_StoreTableData("CardinalMissionData", CardinalMissionData)
	
	Game_EndSP(true, WR_OBJECTIVECOMPLETE)
	
end

--? @shortdesc Used to FAIL the entire mission
function Mission_Cheat_Lose()
	
	-- kill everything player-owned
	local player = World_GetPlayerAt(1)
	Player_GetAll(player)
	SGroup_Kill(sg_allsquads)
	
	-- fail all objectives
	for index, objective in pairs(g_missionObjectives) do 
		Obj_SetState(objective.ID, OS_Failed)
	end
	
	World_NotifyDebugEndSP(false)
	
	CardinalMissionData = {
		report = {
			win = false,
			gameLength = World_GetGameTime(),
		},
	}
	
	Game_RetrieveTableData("CardinalMissionData", true) -- clear out the old store
	Game_StoreTableData("CardinalMissionData", CardinalMissionData)
	
	Game_EndSP(false, WR_OBJECTIVEFAILED)

end

--? @shortdesc Used to successfully COMPLETE all currently-active objectives
function Mission_Cheat_Complete_Obj()

	-- Complete all objectives that have STARTED
	for index, objective in pairs(__t_Objectives) do
		if objective.Type ~= OT_Secondary and Objective_IsStarted(objective) == true and Objective_IsComplete(objective) == false and Objective_IsFailed(objective) == false then
			
			-- First, figure out subobjectives, if there are any
			local subObjectives = Objective_GetSubObjectives(objective)
			local countPendingSubobjectives = 0
			
			-- First we want to extract started subobjectives
			local subobjsToComplete = {}
			-- We have to complete them separately or one subobjective might start another on completion,
			-- which could lead to that knock-on subobjective also getting completed before it becomes active
			for index, subObjective in pairs(subObjectives) do
				-- If an objective has any subobjectives that aren't yet resolved, we don't want to complete the objective itself yet
				if Objective_IsComplete(subObjective) == false and Objective_IsFailed(subObjective) == false then
					countPendingSubobjectives = countPendingSubobjectives + 1
					-- If we have a pending objective that is started, we need to complete it
					if Objective_IsStarted(subObjective) == true then
						table.insert(subobjsToComplete, subObjective)
					end
				end
			end
			
			-- Complete only the ones that were already started here
			for index, subObjective in pairs(subobjsToComplete) do
				print("CHEAT - Completing Sub: "..Loc_ToAnsi(subObjective.Title))
				Objective_Complete(subObjective)
			end
			
			-- If there weren't any subobjectives to resolve, we may have to resolve this directly
			if countPendingSubobjectives <= 0 then
				Objective_Complete(objective)
				print("CHEAT - Completing Obj: "..Loc_ToAnsi(objective.Title))
			end
		end
	end

end

--? @shortdesc Used to FAIL all currently-active objectives
function Mission_Cheat_Fail_Obj()

	-- Fail all objectives that have STARTED
	for index, objective in pairs(__t_Objectives) do
		if objective.Type ~= OT_Secondary and Objective_IsStarted(objective) == true and Objective_IsComplete(objective) == false and Objective_IsFailed(objective) == false then
			
			-- First, figure out subobjectives, if there are any
			local subObjectives = Objective_GetSubObjectives(objective)
			local countPendingSubobjectives = 0
			
			-- First we want to extract started subobjectives
			local subobjsToFail = {}
			-- We have to fail them separately or one subobjective might start another on failure,
			-- which could lead to that knock-on subobjective also getting failed before it becomes active
			for index, subObjective in pairs(subObjectives) do
				-- If an objective has any subobjectives that aren't yet resolved, we don't want to fail the objective itself yet
				if Objective_IsComplete(subObjective) == false and Objective_IsFailed(subObjective) == false then
					countPendingSubobjectives = countPendingSubobjectives + 1
					-- If we have a pending objective that is started, we need to fail it
					if Objective_IsStarted(subObjective) == true then
						table.insert(subobjsToFail, subObjective)
					end
				end
			end
			
			-- Fail only the ones that were already started here
			for index, subObjective in pairs(subobjsToFail) do
				print("CHEAT - Failing Sub: "..Loc_ToAnsi(subObjective.Title))
				Objective_Fail(subObjective)
			end
			
			-- If there weren't any subobjectives to resolve, we may have to resolve this directly
			if countPendingSubobjectives <= 0 then
				Objective_Fail(objective)
				print("CHEAT - Failing Obj: "..Loc_ToAnsi(objective.Title))
			end
		end
	end
end

function Mission_SetupCheatForOutroCamera()
	
	OBJ_DebugComplete = {
        Title = LOC("Debug Complete"),
        Type = OT_Primary,
        showTitle = false,
        Cheat = function()
			Rule_RemoveAll()
			Util_StartIntel(EVENTS.EarlySiege_Outro)
			Mission_Complete()
		end,
	}

    Objective_Register(OBJ_DebugComplete)
	
end
function DefendWithArchers()
	
	if(sg_enemy_archers ~= nil and SGroup_Count(sg_enemy_archers) > 0) then
		
		--prefer to target ranged siege
		-- Create SGroups
		local sg_attackers = SGroup_CreateIfNotFound("sg_attackers")
		Player_GetAllSquadsNearMarker(localPlayer, sg_attackers, Util_GetPosition(mkr_gate_zone), 65)
		SGroup_Filter(sg_attackers, "siege_range", FILTER_KEEP)
		
		if (SGroup_Count(sg_attackers) > 0 and SGroup_Count(sg_enemy_archers) > 0) then
			local s_closest_attacker = SGroup_GetClosestSquad(sg_attackers, Util_GetPosition(mkr_gate_zone))
			if s_closest_attacker ~= nil then	
				--only attack if the unit is close enough (prevents attacking across the map)
				if(Util_GetDistance(s_closest_attacker, mkr_gate_zone) < 100) then
					Cmd_AttackMove(sg_enemy_archers, sg_attackers, false)
					return
				end
			end
		end
		
		----
		--attack anything if no ranged siege is in range
		Player_GetAllSquadsNearMarker(localPlayer, sg_attackers, Util_GetPosition(mkr_gate_zone), 65)
		
		if (SGroup_Count(sg_attackers) > 0 and SGroup_Count(sg_enemy_archers) > 0) then
			local s_closest_attacker = SGroup_GetClosestSquad(sg_attackers, Util_GetPosition(mkr_gate_zone))
			if s_closest_attacker ~= nil then	
				--only attack if the unit is close enough (prevents attacking across the map)
				if(Util_GetDistance(s_closest_attacker, mkr_gate_zone) < 100) then
					Cmd_AttackMove(sg_enemy_archers, Util_GetPosition(s_closest_attacker), false)
				end
			end
		end
	else
		Rule_RemoveMe()
		return
	end
end

