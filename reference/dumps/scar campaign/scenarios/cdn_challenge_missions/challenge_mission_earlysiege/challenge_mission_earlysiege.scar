	Cmd_FormationMove(sg_enemy_menatarms, mkr_enemy_menatarms_rally, true, false,  mkr_enemy_menatarms_facing)

end

-- Move Units to their Rally Points
function ChallengeMission_RallyWallArchers()
	
	Cmd_Move(sg_enemy_wall_archers1, mkr_enemy_farmer2_waypoint01, false)
	Cmd_Move(sg_enemy_wall_archers2, mkr_enemy_farmer2_waypoint01, false)
	
	--order wall archers to defend the walls
	local leftArcPos = Util_GetPosition(mkr_wall_archers2)
	local rightArcPos = Util_GetPosition(mkr_wall_archers1)
	ArcFormation(leftArcPos, rightArcPos, sg_enemy_wall_archers1, 0, true, 0)
	local leftArcPos = Util_GetPosition(mkr_wall_archers3)
	local rightArcPos = Util_GetPosition(mkr_wall_archers2)
	ArcFormation(leftArcPos, rightArcPos, sg_enemy_wall_archers2, 0, true, 0)
	
	Rule_AddInterval(WallArchersReset, .5)
end

