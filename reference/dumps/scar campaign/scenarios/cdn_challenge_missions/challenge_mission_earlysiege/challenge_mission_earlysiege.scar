--this function orders units to form a line form startPos to endPos with the curvature curveStrength
function ArcFormation(startPos, endPos, inGroup, curveStrength, inQueued, inOffset)
	if(SGroup_CountSpawned(inGroup) == 0) then
		return
	end
	
	local fLine = Util_GetPosition(startPos)
	fLine["x"] = endPos["x"] - startPos["x"]
	fLine["z"] = endPos["z"] - startPos["z"]
	
	local tLine = Util_GetPosition(startPos)
	tLine["x"] = fLine["z"]
	tLine["z"] = -fLine["x"]
	
	
	for i = 1, SGroup_Count(inGroup) do
		--offset should be from 0 to 1
		local pointD = (i - inOffset) / SGroup_Count(inGroup)
		
		local unitDest = Util_GetPosition(startPos)
		--calculate the destination for each unit
		unitDest["x"] = startPos["x"] + (pointD * fLine["x"])
		unitDest["z"] = startPos["z"] + (pointD * fLine["z"])
		
		local curveMultiplier = pointD - .5
		
		curveMultiplier = curveMultiplier * curveMultiplier
		curveMultiplier = .25 - curveMultiplier
		
		unitDest["x"] = unitDest["x"] + (tLine["x"] * curveMultiplier * curveStrength)
		unitDest["z"] = unitDest["z"] + (tLine["z"] * curveMultiplier * curveStrength)
		
		--isolate each unit and give it a move order
		local squad = SGroup_GetSquadAt(inGroup, i)
		SGroup_Single(sg_single, squad)
		Cmd_Move(sg_single, unitDest, inQueued)
	end
	
end

--this function orders an SGroup to scatter inDistToMove away from its center
function ScriptScatterUnits(inGroup, inDistToMove, inUseGroupCenter, inCenter, inFaceUnits, inFacingMarker, inQueued)
	
	if(inGroup == nil) then
		return
	end
	
	if(SGroup_Count(inGroup) == 0) then
		return
	end
	
	--find center point or use parameter
	local centerPoint = Util_GetPosition(inGroup)
	if(inUseGroupCenter == true) then
		centerPoint["x"] = 0
		centerPoint["z"] = 0
		for i = 1, SGroup_Count(inGroup) do
			
			local squad = SGroup_GetSquadAt(inGroup, i)
			local squadPos = Util_GetPosition(squad)
			
			centerPoint["x"] = centerPoint["x"] + squadPos["x"]
			centerPoint["z"] = centerPoint["z"] + squadPos["z"]
			
		end
		
		if(SGroup_Count(inGroup) > 0) then
			
			centerPoint["x"] = centerPoint["x"] / SGroup_Count(inGroup)
			centerPoint["z"] = centerPoint["z"] / SGroup_Count(inGroup)
		end
	else
		centerPoint = Util_GetPosition(inCenter)
	end
	
	
	
	for i = 1, SGroup_Count(inGroup) do
		
		local squad = SGroup_GetSquadAt(inGroup, i)
		local unitPos = Util_GetPosition(squad)
		local centerDir = Util_GetPosition(squad)
		
		--find vector from individual unit to center
		centerDir["x"] = (unitPos["x"] - centerPoint["x"])
		centerDir["z"] = (unitPos["z"] - centerPoint["z"])
		
		--normalize vector
		local distToCenter = math.sqrt((centerDir["x"] * centerDir["x"]) + (centerDir["z"] * centerDir["z"]))
		if(distToCenter > 0) then
			centerDir["x"] = centerDir["x"] / distToCenter
			centerDir["z"] = centerDir["z"] / distToCenter
		end
		
		--calculate destination
		local unitDest = Util_GetPosition(squad)
		unitDest["x"] = unitPos["x"] + (centerDir["x"] * inDistToMove)
		unitDest["z"] = unitPos["z"] + (centerDir["z"] * inDistToMove)
		
		SGroup_Single(sg_single, squad)
		Cmd_Move(sg_single, unitDest, inQueued)
		
		--give extra facing order if applicable
		if(inFaceUnits == true) then
			if(inFacingMarker ~= nil) then
				-- Face menatarms
				Cmd_FormationMove(sg_single, unitDest, true, false, inFacingMarker)
			else
				--face center
				Cmd_FormationMove(sg_single, unitDest, true, false, centerPoint)
			end
		end
		
	end
	
end