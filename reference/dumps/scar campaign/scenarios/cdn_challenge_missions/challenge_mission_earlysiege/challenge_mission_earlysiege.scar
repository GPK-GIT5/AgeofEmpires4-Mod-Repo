-- Setup Challenge Mission
function ChallengeMission_SetupChallenge()
	
	-- For every player
	for i, player in pairs(PLAYERS) do
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			
			-- Add a challenge table to player table
			player._challenge = {
				-- Add victory objective variable
				hasObjectiveVictory = false,

				-- Add sub objective variable
				hasObjectiveSub1 = false,
				-- Add sub objective variable
				hasObjectiveSub2 = false,
				
				-- Add KPI objective variable
				hasKpiObjective = false,
				-- Add current benchmark
				currentBenchmark = nil,
				-- Add timer variable
				timer = string.format("challengeTimer_%d", player.index),
				-- Store timer start time (relative to World_GetGameTime)
				startTime = World_GetGameTime(),
				-- Store completion time
				completionTime = nil,
				-- Stores number of key buildings destroyed
				conquestProgress = 0,
				-- Get Capital Town Center
				enemyCapital = EGroup_GetEntityAt(enemy_capital, 1),
				-- Get Landmark
				enemyLandmark = EGroup_GetEntityAt(enemy_landmark, 1)
			}
			
			-- Hide Building Scuttle
			Player_SetAbilityAvailability(player.id, BP_GetAbilityBlueprint("core_building_scuttle"), ITEM_REMOVED)
			
			-- Grab player's Entities
			local playerEntities = Player_GetEntities(player.id)
			-- Filter 
			EGroup_Filter(playerEntities, BP_GetEntityBlueprint("starting_position_no_town_center"), FILTER_REMOVE)
			--filter out projectile_torch entities to prevent a crash
			EGroup_Filter(playerEntities, BP_GetEntityBlueprint("projectile_torch"), FILTER_REMOVE)
			-- Set Player Production Speed Modifier (2 = 2x as fast)
			local productionSpeedFactor = 10
			
			-- Function that switches the owner an Entity given the parameters provided by EGroup_ForEach
			local _SetProductionSpeed = function(gid, idx, eid)
				
				-- Modify Production/Research Speed
				Modifier_ApplyToEntity(Modifier_Create(MAT_Entity, "production_speed_modifier", MUT_Multiplication, false, productionSpeedFactor, nil), eid, 0.0)
			end
				
			-- For every Entity
			EGroup_ForEach(playerEntities, _SetProductionSpeed) 
			
			-- Reveal Conquest buildings
			FOW_PlayerRevealArea(player.id, Entity_GetPosition(player._challenge.enemyCapital), 30, -1)
			FOW_PlayerRevealArea(player.id, Entity_GetPosition(player._challenge.enemyLandmark), 30, -1)
			
		end
	end
end

-- Initialize Additional Starting Units
function ChallengeMission_InitStartingUnits()
	
	-- Get unit blueprints
	local sbp_spearman_mon = BP_GetSquadBlueprint("unit_spearman_3_mon")
	local sbp_scout_mon = BP_GetSquadBlueprint("unit_scout_1_mon")
	local sbp_archer_mon = BP_GetSquadBlueprint("unit_archer_3_mon")
	
	--[[ PLAYER UNITS ]]--
	
	-- Create SGroups
	sg_player_spearmen1 = SGroup_CreateIfNotFound("sg_player_spearmen1")
	sg_player_spearmen2 = SGroup_CreateIfNotFound("sg_player_spearmen2")
	sg_player_scout = SGroup_CreateIfNotFound("sg_player_scout")
	
	-- Spawn units
	UnitEntry_DeploySquads(localPlayer, sg_player_spearmen1, {{sbp = sbp_archer_mon, numSquads = 16 }}, mkr_player_spearmen1_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_player_spearmen2, {{sbp = sbp_spearman_mon, numSquads = 16 }}, mkr_player_spearmen2_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_player_scout, {{sbp = sbp_scout_mon, numSquads = 3 }}, mkr_player_scout_spawn)
	
	-- Face units
	Cmd_FormationMove(sg_player_spearmen1, mkr_player_spearmen1_spawn, false, false, mkr_player_spearmen1_facing)
	Cmd_FormationMove(sg_player_spearmen2, mkr_player_spearmen2_spawn, false, false, mkr_player_spearmen2_facing)
	Cmd_FormationMove(sg_player_scout, mkr_player_scout_spawn, false, false, mkr_player_scout_facing)
	
	--[[ ENEMY UNITS ]]--

	-- Get unit blueprints
	local sbp_springald_rus = BP_GetSquadBlueprint("unit_springald_3_rus")
	local sbp_mangonel_rus = BP_GetSquadBlueprint("unit_mangonel_3_rus")
	local sbp_manatarms_rus = BP_GetSquadBlueprint("unit_manatarms_3_rus")
	local sbp_archer_rus = BP_GetSquadBlueprint("unit_archer_3_rus")
	local sbp_spearman_rus = BP_GetSquadBlueprint("unit_spearman_3_rus")
	local sbp_villager_rus = BP_GetSquadBlueprint("unit_villager_1_rus")
	
	-- Create SGroups
	sg_enemy_springalds = SGroup_CreateIfNotFound("sg_enemy_springalds")
	sg_enemy_mangonels = SGroup_CreateIfNotFound("sg_enemy_mangonels")
	sg_enemy_menatarms = SGroup_CreateIfNotFound("sg_enemy_menatarms")
	sg_enemy_menatarms2 = SGroup_CreateIfNotFound("sg_enemy_menatarms2")
	sg_enemy_archers = SGroup_CreateIfNotFound("sg_enemy_archers")
	sg_enemy_spearmen = SGroup_CreateIfNotFound("sg_enemy_spearmen")
	sg_enemy_fisherman0 = SGroup_CreateIfNotFound("sg_enemy_fisherman0")
	sg_enemy_fisherman1 = SGroup_CreateIfNotFound("sg_enemy_fisherman1")
	sg_enemy_hunter = SGroup_CreateIfNotFound("sg_enemy_hunter")
	sg_enemy_wall_archers1 = SGroup_CreateIfNotFound("sg_enemy_wall_archers1")
	sg_enemy_wall_archers2 = SGroup_CreateIfNotFound("sg_enemy_wall_archers2")
	
	--deploy squads
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_springalds, {{sbp = sbp_springald_rus, numSquads = 2}}, mkr_inner_springald_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_mangonels, {{sbp = sbp_mangonel_rus, numSquads = 1}}, mkr_enemy_mangonel_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_menatarms, {{sbp = sbp_manatarms_rus, numSquads = 6 }}, mkr_enemy_menatarms_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_menatarms2, {{sbp = sbp_manatarms_rus, numSquads = 5 }}, mkr_menatarms_patrol_right)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers, {{sbp = sbp_archer_rus, numSquads = 10 }}, mkr_enemy_archers_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_spearmen, {{sbp = sbp_spearman_rus, numSquads = 10 }}, mkr_enemy_spearmen_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_fisherman0, {{sbp = sbp_villager_rus, numSquads = 2 }}, mkr_enemy_fisherman0_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_fisherman1, {{sbp = sbp_villager_rus, numSquads = 1 }}, mkr_enemy_fisherman1_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_hunter, {{sbp = sbp_villager_rus, numSquads = 2 }}, mkr_enemy_hunter_spawn)
	
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_wall_archers1, {{sbp = sbp_archer_rus, numSquads = 8 }}, mkr_enemy_wall_archers_spawn01)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_wall_archers2, {{sbp = sbp_archer_rus, numSquads = 7 }}, mkr_enemy_wall_archers_spawn01)
	
	wallArchers1Count = SGroup_Count(sg_enemy_wall_archers1)
	wallArchers2Count = SGroup_Count(sg_enemy_wall_archers2)
	
	
end

wallArchers1Count = 0
wallArchers2Count = 0

--reset archers in their lines behind the walls after every 2 archers lost
function WallArchersReset()
	if(sg_enemy_wall_archers1 ~= nil) then
		if (SGroup_Count(sg_enemy_wall_archers1) > 0 and SGroup_Count(sg_enemy_wall_archers1) <= wallArchers1Count - 2) then
			wallArchers1Count = SGroup_Count(sg_enemy_wall_archers1)
			--order wall archers to defend the walls
			local leftArcPos = Util_GetPosition(mkr_wall_archers2)
			local rightArcPos = Util_GetPosition(mkr_wall_archers1)
			ArcFormation(leftArcPos, rightArcPos, sg_enemy_wall_archers1, 0, false, 0)
		end
	end
	if(sg_enemy_wall_archers2 ~= nil) then
		if (SGroup_Count(sg_enemy_wall_archers2) > 0 and SGroup_Count(sg_enemy_wall_archers2) <= wallArchers2Count - 2) then
			wallArchers2Count = SGroup_Count(sg_enemy_wall_archers2)
			--order wall archers to defend the walls
			local leftArcPos = Util_GetPosition(mkr_wall_archers3)
			local rightArcPos = Util_GetPosition(mkr_wall_archers2)
			ArcFormation(leftArcPos, rightArcPos, sg_enemy_wall_archers2, 0, false, 0)
		end
	end
end

function WallArchersRetreat()
	
	if(enemy_capital ~= nil) then
		local retreatPosition = Util_GetPosition(enemy_capital)
		
		if(sg_enemy_wall_archers1 ~= nil) then
			if (SGroup_Count(sg_enemy_wall_archers1) > 0) then
				--order wall archers to defend the walls
				local leftArcPos = Util_GetPosition(mkr_wall_archers2)
				leftArcPos["x"] = retreatPosition["x"] - 10
				leftArcPos["z"] = retreatPosition["z"] + 10
				local rightArcPos = Util_GetPosition(mkr_wall_archers1)
				rightArcPos["x"] = retreatPosition["x"] + 10
				rightArcPos["z"] = retreatPosition["z"] - 10
				ArcFormation(leftArcPos, rightArcPos, sg_enemy_wall_archers1, 1.5, false, 0)
			end
		end
		if(sg_enemy_wall_archers2 ~= nil) then
			if (SGroup_Count(sg_enemy_wall_archers2) > 0) then
				--order wall archers to defend the walls
				local leftArcPos = Util_GetPosition(mkr_wall_archers2)
				leftArcPos["x"] = retreatPosition["x"] - 11
				leftArcPos["z"] = retreatPosition["z"] + 9
				local rightArcPos = Util_GetPosition(mkr_wall_archers1)
				rightArcPos["x"] = retreatPosition["x"] + 9
				rightArcPos["z"] = retreatPosition["z"] - 11
				ArcFormation(leftArcPos, rightArcPos, sg_enemy_wall_archers2, 1.5, false, 0)
			end
		end
	end
end

-- Initialize starting upgrades
function ChallengeMission_InitStartingUpgrades()
	
	-- Get upgrade blueprints
	local upg_arrowSlits = UPG.RUS.UPGRADE_WOODEN_CASTLE_ARROWSLITS_RUS
	
	-- Adds Arrow Slits to Outposts
	local function _AddArrowSlits(gid, idx, eid)
		-- Add upgrades to enemy outposts
		Entity_CompleteUpgrade(eid, upg_arrowSlits)
	end
	
	
	-- For every enemy Outpost
	EGroup_ForEach(eg_enemy_outposts, _AddArrowSlits)
	
	-- Get Player Upgrades
	local bp_siege_engineers = BP_GetUpgradeBlueprint("upgrade_siege_engineers")
	local bp_boiling_oil = BP_GetUpgradeBlueprint("upgrade_tech_university_murder_holes_4")
	local bp_spearman_2 = BP_GetUpgradeBlueprint("upgrade_unit_spearman_2")
	local bp_spearman_3 = BP_GetUpgradeBlueprint("upgrade_unit_spearman_3")
	local bp_archer_3 = BP_GetUpgradeBlueprint("upgrade_unit_archer_3")
	
	-- Add Local Player Upgrades
	Player_CompleteUpgrade(localPlayer, bp_siege_engineers)
	-- Add Enemy Player Upgrades
	Player_CompleteUpgrade(enemyPlayer, bp_boiling_oil)
	Player_CompleteUpgrade(enemyPlayer, bp_spearman_2)
	Player_CompleteUpgrade(enemyPlayer, bp_spearman_3)
	Player_CompleteUpgrade(enemyPlayer, bp_archer_3)
	
	
end

