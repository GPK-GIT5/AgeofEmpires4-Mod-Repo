import("training/coretrainingconditions.scar")
import("training/coretraininggoals.scar")

Core_RegisterModule("EarlySiegeTrainingGoals")


local goal_sequence_siege_engineers = "build_siege_engineers"
local goal_sequence_battering_ram = "build_battering_ram_early"
local goal_sequence_siege_tower = "build_siege_tower_early"
local goal_sequence_springald = "build_springald_early"
local goal_sequence_mangonel = "build_mangonel_early"

local trainedSiegeTower = false
local trainedRam = false
local trainedSpringald = false
local trainedMangonel = false

local selectedSiegeWorkshop = false
local selectedSpearman = false

local siegeTowerButtonClicked = false

local training_goals_early_siege =
{
	goal_sequence_siege_engineers,
	goal_sequence_battering_ram,
	goal_sequence_siege_tower,
	goal_sequence_springald,
	goal_sequence_mangonel
}

function TrainingGoal_EnableEarlySiegeGoals()
	for i, goalSequenceID in ipairs(training_goals_early_siege) do
		Training_EnableGoalSequenceByID(goalSequenceID, true)
	end
end

function TrainingGoal_DisableEarlySiegeGoals()
	for i, goalSequenceID in ipairs(training_goals_early_siege) do
		Training_EnableGoalSequenceByID(goalSequenceID, false)
	end
end

function EarlySiegeTrainingGoals_InitRamHint_Xbox()
	
	local selectSiegeEngineerGoal = Training_Goal("Squad",
		{ID= "Select a military unit to build a Battering Ram.", Message= "$11202436", DataTemplate="GenericTrainingDataTemplate"},
		UserHasSelectedSiegeEngineer)
	
	local openRadialGoal = Training_Goal("Squad",
		{ID= "Press RT to open the radial menu.", Message= "$1000968", DataTemplate="GenericTrainingDataTemplate"}, 
		UserHasOpenedContextualRadial)
	
	local selectBatteringRamGoal = Training_Goal("PBG",
		{ID= "Select this option to build a Battering Ram.", Message= "$11249143", DataTemplate="GenericTrainingDataTemplate"},
		UserIsBuildingBatteringRam)
	
	local buildBatteringRamGoal = Training_Goal("LooseReticle",
		{ID= "Press A in a valid location to start construction.", Message= "$1001021", DataTemplate="GenericTrainingDataTemplate"},
		UserHasBuiltBatteringRam)
	
	local selectSiegeEngineerSequence = Training_GoalSequence(goal_sequence_siege_engineers,
		-1, 0,
		UserHasIdleSiegeEngineers_Xbox, 
		RamStartedIgnorePredicate, 
		nil,
		nil,
		true,
		{selectSiegeEngineerGoal, openRadialGoal, selectBatteringRamGoal, buildBatteringRamGoal})
	Training_AddGoalSequence(selectSiegeEngineerSequence)
end

function EarlySiegeTrainingGoals_InitRamHint()
	
	local selectSiegeEngineerGoal = Training_Goal("Squad",
		{ID= "Select a military unit to build a Battering Ram.", Message= "$11202436", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedSiegeEngineer)
	local selectBatteringRamGoal = Training_Goal("PBG",
		{ID= "Click here to build a Battering Ram.", Message= "$11202437", DataTemplate="LeftClickTrainingDataTemplate"},
		UserIsBuildingBatteringRam)
	local buildBatteringRamGoal = Training_Goal("Cursor",
		{ID= "Click a valid location to start construction.", Message= "$11202438", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasBuiltBatteringRam)
	local selectSiegeEngineerSequence = Training_GoalSequence(goal_sequence_siege_engineers,
		-1, 0,
		UserHasIdleSiegeEngineers, 
		RamStartedIgnorePredicate, 
		nil,
		nil,
		true,
		{selectSiegeEngineerGoal, selectBatteringRamGoal, buildBatteringRamGoal})
	Training_AddGoalSequence(selectSiegeEngineerSequence)
end

function EarlySiegeTrainingGoals_OnInit()
	
	-- Disable core training goals for testing purposes
	--TrainingGoal_DisableCoreControlGoals()
	--TrainingGoal_DisableCoreEconGoals()
	
	
	-------------------------------------------------------------------------
	---- Goal Sequences
	-------------------------------------------------------------------------
	
	
	-- Build a ram
	if UI_IsXboxControllerUI() then
		EarlySiegeTrainingGoals_InitRamHint_Xbox()
	else
		EarlySiegeTrainingGoals_InitRamHint()
	end
	
	
	----
	-- Player built a battering ram "Garrison infantry inside this ram to protect them from arrow fire."
	local builtBatteringRamGoal = Training_Goal("Squad",
		{ID= "Garrison infantry", Message= "$11202430", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedBatteringRam)
	local builtBatteringRamSequence = Training_GoalSequence(goal_sequence_battering_ram,
		-1, 0, 
		RamBuiltPredicate, 
		nil, 
		nil,
		UserHasSelectedBatteringRam,
		false, 
		{builtBatteringRamGoal})
	Training_AddGoalSequence(builtBatteringRamSequence)
	
	----
	
	-- Player built a siege tower "Siege Towers are only effective again Stone Walls, not palisades."
	local builtSiegeTowerGoal = Training_Goal("PBG",
		{ID= "Siege Towers are only effective again Stone Walls, not palisades.", Message= "$11202431", DataTemplate="RightClickTrainingDataTemplate"},
		UserHasSelectedSiegeTower)
	local builtSiegeTowerSequence = Training_GoalSequence(goal_sequence_siege_tower,
		-1, 0, 
		SiegeTowerBuiltPredicate, 
		UserHasSelectedSiegeTower,
		nil, 
		nil,
		true, 
		{builtSiegeTowerGoal})
	Training_AddGoalSequence(builtSiegeTowerSequence)
	--]]
	----
	
	
	-- Player built a springald "Springalds are specialized at taking out enemy soldiers but are weak against walls and buildings."
	local builtSpringaldGoal = Training_Goal("Entity",
		{ID= "Springalds are specialized at taking out enemy soldiers but are weak against walls and buildings.", Message= "$11202428", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedSpringald)
	local builtSpringaldSequence = Training_GoalSequence(goal_sequence_springald,
		-1, 0, 
		SpringaldBuiltPredicate, 
		UserHasSelectedSpringald,
		nil, 
		nil,
		true, 
		{builtSpringaldGoal})
	Training_AddGoalSequence(builtSpringaldSequence)
	
	----
	
	
	-- Player built a mangonel "Mangonels are good against groups of slow-moving soldiers."
	local builtMangonelGoal = Training_Goal("Entity",
		{ID= "Mangonels are good against groups of slow-moving soldiers.", Message= "$11202429", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedMangonelIntro)
	local builtMangonelSequence = Training_GoalSequence(goal_sequence_mangonel,
		-1, 0, 
		MangonelBuiltPredicate, 
		UserHasSelectedMangonelIntro,
		nil, 
		nil,
		true, 
		{builtMangonelGoal})
	Training_AddGoalSequence(builtMangonelSequence)
	----
	
end

selectSiegeEngineersActive = false
selectSiegeEngineersCount = 0
selectSiegeEngineersMax = 2

garrisonRamActive = false
garrisonRamCount = 0
garrisonRamMax = 1
garrisonRamCreated = false

selectSpringaldActive = false
selectSpringaldCount = 0
selectSpringaldMax = 1

selectMangonelActive = false
selectMangonelCount = 0
selectMangonelMax = 1

