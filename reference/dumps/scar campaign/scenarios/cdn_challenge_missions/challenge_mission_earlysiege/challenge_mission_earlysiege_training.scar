--Player has clicked Siege Tower icon in command card
function SiegeTowerBuiltPredicate(goalSequence)
	--first check if any valid units are selected
	local hasInfantrySelected = false
	
	--remove warning if no infantry are selected
	local localPlayer = Game_GetLocalPlayer()
	local sg_currentSelection = SGroup_CreateIfNotFound("sg_currentSelection")
	Misc_GetSelectedSquads(sg_currentSelection, false)
	
	-- Check for selected infantry
	for i = 1, SGroup_Count(sg_currentSelection) do
		local squad = SGroup_GetSquadAt(sg_currentSelection, i)
		if(squad ~= nil) then
			-- Check if unit is infantry
			if Squad_IsOfType(squad, "infantry") then 
				hasInfantrySelected = true
			end
		end
	end
	
	if(hasInfantrySelected == true) then
		
		if(UserIsGoingToBuildBuildingType("siege_tower")) then
			
			-- Check if siege tower can be constructed
			local siegeTowerBP = Cardinal_ConvertTypeToEntityBlueprint("siege_tower", localPlayer)
			
			if siegeTowerBP ~= nil then
				-- Assign key to Battering Ram icon
				goalSequence.goals[1].key = siegeTowerBP
				siegeTowerButtonClicked = true
				return true
			end
			
		end
	end
	return false
end

-- remove warning when player is no longer about to build a siege tower
function UserHasSelectedSiegeTower(goal)
	
	--first check if any valid units are selected
	local hasInfantrySelected = false
	
	--remove warning if no infantry are selected
	local localPlayer = Game_GetLocalPlayer()
	local sg_currentSelection = SGroup_CreateIfNotFound("sg_currentSelection")
	Misc_GetSelectedSquads(sg_currentSelection, false)
	
	-- Check for selected infantry
	for i = 1, SGroup_Count(sg_currentSelection) do
		local squad = SGroup_GetSquadAt(sg_currentSelection, i)
		if(squad ~= nil) then
			-- Check if unit is infantry
			if Squad_IsOfType(squad, "infantry") then 
				hasInfantrySelected = true
			end
		end
	end
	
	if(hasInfantrySelected == false) then
			return true
	end
	
	if(siegeTowerButtonClicked == true) then
		if(UserIsGoingToBuildBuildingType("siege_tower") == false) then
			return true
		end
	end
	
	return false
end

