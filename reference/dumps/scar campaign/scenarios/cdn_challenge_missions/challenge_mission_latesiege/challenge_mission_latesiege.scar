				location = "FarmingZone",
				player = enemyPlayer,
				canBuild = false,
				maxVillagers = 0,
				gatheringPreference = {
			        food = 12,
			        wood = 0,
			        stone = 0,
			        gold = 0,
			    },
				allowGatheringOutsideLeash = false,
			},
			{
				descriptor = "HRETownLife",
				type = "TownLife",
				location = "TownLifeZone",
				player = enemyPlayer,
				canBuild = false,
				maxVillagers = 0,
				gatheringPreference = {
			        food = 12,
