function ChallengeMission_PatrolEnemyKnights()
	
	
	Rule_AddInterval(ChallengeMission_PatrolEnemyKnights1, 1)
	Rule_AddInterval(ChallengeMission_PatrolEnemyKnights2, 1)
	Rule_AddInterval(ChallengeMission_PatrolEnemyKnights3, 1)
	
end


knightsPatrolDirection = 1
knightsPatrolWaiting = false
knightsPatrolPauseTimer = 0

function ChallengeMission_PatrolEnemyKnights1()
	
	if(sg_enemy_knights ~= nil) then
		if Prox_AreSquadsNearMarker(sg_enemy_knights, mkr_enemy_knights_patrol1, ANY, 5) then
			--start waiting at the patrol point
			if(knightsPatrolWaiting == false) then
				knightsPatrolPauseTimer = World_GetGameTime()
				knightsPatrolWaiting = true
				
				--check for nearby player units
				local sg_player_units = Player_GetSquads(localPlayer)
				local s_closest_attacker = SGroup_GetClosestSquad(sg_player_units, mkr_enemy_knights_patrol1)
				if s_closest_attacker ~= nil then
					--attack player units that get too close
					if(Util_GetDistance(s_closest_attacker, mkr_enemy_knights_patrol1) < 18) then
						Cmd_AttackMove(sg_enemy_knights, Util_GetPosition(s_closest_attacker), false)
						Rule_Remove(ChallengeMission_PatrolEnemyKnights1)
						Rule_Remove(ChallengeMission_PatrolEnemyKnights2)
						Rule_Remove(ChallengeMission_PatrolEnemyKnights3)
					end
				end
			end
			
			local timeElapsed = World_GetGameTime() - knightsPatrolPauseTimer
			if(timeElapsed > 5) then
				knightsPatrolDirection = 1
				--move enemy knights to trigger location
				Cmd_Move(sg_enemy_knights, mkr_enemy_knights_patrol2, false)
				knightsPatrolPauseTimer = World_GetGameTime()
				knightsPatrolWaiting = false
			end
		end
	end
end

function ChallengeMission_PatrolEnemyKnights2()
	
	if(sg_enemy_knights ~= nil) then
		if(knightsPatrolDirection == 1) then
			if Prox_AreSquadsNearMarker(sg_enemy_knights, mkr_enemy_knights_patrol2, ANY, 5) then
				knightsPatrolWaiting = false
				
				
				--move enemy knights to trigger location
				Cmd_Move(sg_enemy_knights, mkr_enemy_knights_patrol3, false)
				
				--check for nearby player units
				local sg_player_units = Player_GetSquads(localPlayer)
				local s_closest_attacker = SGroup_GetClosestSquad(sg_player_units, mkr_enemy_knights_patrol2)
				if s_closest_attacker ~= nil then
					--attack player units that get too close
					if(Util_GetDistance(s_closest_attacker, mkr_enemy_knights_patrol2) < 18) then
						Cmd_AttackMove(sg_enemy_knights, Util_GetPosition(s_closest_attacker), false)
						Rule_Remove(ChallengeMission_PatrolEnemyKnights1)
						Rule_Remove(ChallengeMission_PatrolEnemyKnights2)
						Rule_Remove(ChallengeMission_PatrolEnemyKnights3)
					end
				end
			end
		else
			if Prox_AreSquadsNearMarker(sg_enemy_knights, mkr_enemy_knights_patrol2, ANY, 5) then
				knightsPatrolWaiting = false
				
				--move enemy knights to trigger location
				Cmd_Move(sg_enemy_knights, mkr_enemy_knights_patrol1, false)
				
				--check for nearby player units
				local sg_player_units = Player_GetSquads(localPlayer)
				local s_closest_attacker = SGroup_GetClosestSquad(sg_player_units, mkr_enemy_knights_patrol2)
				if s_closest_attacker ~= nil then
					--attack player units that get too close
					if(Util_GetDistance(s_closest_attacker, mkr_enemy_knights_patrol2) < 18) then
						Cmd_AttackMove(sg_enemy_knights, Util_GetPosition(s_closest_attacker), false)
						Rule_Remove(ChallengeMission_PatrolEnemyKnights1)
						Rule_Remove(ChallengeMission_PatrolEnemyKnights2)
						Rule_Remove(ChallengeMission_PatrolEnemyKnights3)
					end
				end
			end
		end
	end
	
end

function ChallengeMission_PatrolEnemyKnights3()
	
	if(sg_enemy_knights ~= nil) then
		if Prox_AreSquadsNearMarker(sg_enemy_knights, mkr_enemy_knights_patrol3, ANY, 5) then
			--start waiting at the patrol point
			if(knightsPatrolWaiting == false) then
				knightsPatrolPauseTimer = World_GetGameTime()
				knightsPatrolWaiting = true
				
				--check for nearby player units
				local sg_player_units = Player_GetSquads(localPlayer)
				local s_closest_attacker = SGroup_GetClosestSquad(sg_player_units, mkr_enemy_knights_patrol3)
				if s_closest_attacker ~= nil then
					--only attack if the unit is close enough (prevents attacking across the map)
					if(Util_GetDistance(s_closest_attacker, mkr_enemy_knights_patrol3) < 18) then
						Cmd_AttackMove(sg_enemy_knights, Util_GetPosition(s_closest_attacker), false)
						Rule_Remove(ChallengeMission_PatrolEnemyKnights1)
						Rule_Remove(ChallengeMission_PatrolEnemyKnights2)
						Rule_Remove(ChallengeMission_PatrolEnemyKnights3)
					end
				end
			end
			
			local timeElapsed = World_GetGameTime() - knightsPatrolPauseTimer
			if(timeElapsed > 5) then
				knightsPatrolDirection = -1
				--move enemy knights to trigger location
				Cmd_Move(sg_enemy_knights, mkr_enemy_knights_patrol2, false)
				knightsPatrolPauseTimer = World_GetGameTime()
				knightsPatrolWaiting = false
			end
			
		end
	end
	
end

-- Add new objectives
function ChallengeMission_InitializeObjectives()
	
	
	LateSiegeTrainingGoals_OnInit()
	TrainingGoal_EnableLateSiegeGoals()
	
	-- For every player
	for i, player in pairs(PLAYERS) do
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			
			-----------------------------------------------------------------------
			-- Victory Objective
			
			-- Register Primary objective
			Objective_Register(_challenge.victory.objectiveVictory, player.id)
			-- Start objective
			Objective_Start(_challenge.victory.objectiveVictory, true, false)
			-- Player has victory objective
			player._challenge.hasObjectiveVictory = true;
			
			-----------------------------------------------------------------------
			-- Secondary Objective(s)
			
			-- Assign Victory Objective as Parent
			_challenge.victory.objectiveSub1.Parent = _challenge.victory.objectiveVictory
			-- Register Construct objective
			Objective_Register(_challenge.victory.objectiveSub1, player.id)
			-- Start objective
			Objective_Start(_challenge.victory.objectiveSub1, false, false)
			-- Add UI Elements to Outpost "HRE Town Center"
			Objective_AddUIElements(_challenge.victory.objectiveSub1, enemy_capital, false, "$11202495", true, 8)
			-- Player has objective
			player._challenge.hasObjectiveSub1 = true;
			--add minimap blip
			enemyCapital = EGroup_GetEntityAt(enemy_capital, 1)
			local entry = {
				id = Entity_GetID(enemyCapital),
				blip  = UI_CreateMinimapBlip(enemy_capital, -1, "objective_secondary")
			}
			table.insert(minimapBlips, entry)
			
			-- Assign Victory Objective as Parent
			_challenge.victory.objectiveSub2.Parent = _challenge.victory.objectiveVictory
			-- Register Capital objective
			Objective_Register(_challenge.victory.objectiveSub2, player.id)
			-- Start objective
			Objective_Start(_challenge.victory.objectiveSub2, false, false)
			-- Add UI Elements to Outpost "Aachen Chapel Landmark"
			Objective_AddUIElements(_challenge.victory.objectiveSub2, enemy_landmark1, false, "$11202712", true, 8)
			-- Player has objective
			player._challenge.hasObjectiveSub2 = true;
			--add minimap blip
			enemyLandmark1 = EGroup_GetEntityAt(enemy_landmark1, 1)
			local entry = {
				id = Entity_GetID(enemyLandmark1),
				blip  = UI_CreateMinimapBlip(enemyLandmark1, -1, "objective_secondary")
			}
			table.insert(minimapBlips, entry)
			
			-- Assign Victory Objective as Parent
			_challenge.victory.objectiveSub3.Parent = _challenge.victory.objectiveVictory
			-- Register Capital objective
			Objective_Register(_challenge.victory.objectiveSub3, player.id)
			-- Start objective
			Objective_Start(_challenge.victory.objectiveSub3, false, false)
			-- Add UI Elements to Outpost "Regnitz Cathedral Landmark"
			Objective_AddUIElements(_challenge.victory.objectiveSub3, enemy_landmark2, false, "$11202713", true, 12)
			-- Player has objective
			player._challenge.hasObjectiveSub3 = true;
			--add minimap blip
			enemyLandmark2 = EGroup_GetEntityAt(enemy_landmark2, 1)
			local entry = {
				id = Entity_GetID(enemyLandmark2),
				blip  = UI_CreateMinimapBlip(enemyLandmark2, -1, "objective_secondary")
			}
			table.insert(minimapBlips, entry)
			-----------------------------------------------------------------------
			local localPlayer = Game_GetLocalPlayer()
			local eg_player_units = Player_GetEntities(localPlayer)
			
			local foundFirstSiegeWorkshop = false
			-- Check player units
			for i = 1, EGroup_Count(eg_player_units) do
				
				local entity = EGroup_GetEntityAt(eg_player_units, i)
				-- Check for unit on screen
				if (Entity_IsOfType(entity, "scar_siegeworkshop")) then
					if(foundFirstSiegeWorkshop == true) then
						
						hintPoint_siegeWorkshop = Objective_AddUIElements(_challenge.victory.objectiveVictory, entity, false, "$11202492", true, 5, nil, nil, "icons/objectives/objectives_optional")
						
						--add minimap blip
						local entry = {
							id = Entity_GetID(entity),
							blip  = UI_CreateMinimapBlip(entity, -1, "objective_bonus")
						}
						table.insert(minimapBlips, entry)
					end
					foundFirstSiegeWorkshop = true
				end
			end
			
			-----------------------------------------------------------------------
			
			-- Check player units
			for i = 1, EGroup_Count(eg_player_units) do
				
				local entity = EGroup_GetEntityAt(eg_player_units, i)
				-- Check for unit on screen
				if (Entity_IsOfType(entity, "scar_university")) then
					
					hintPoint_madrasa = Objective_AddUIElements(_challenge.victory.objectiveVictory, entity, false, "$11202494", true, 7, nil, nil, "icons/objectives/objectives_optional")
	
					--add minimap blip
					local entry = {
						id = Entity_GetID(entity),
						blip  = UI_CreateMinimapBlip(entity, -1, "objective_bonus")
					}
					table.insert(minimapBlips, entry)
					
				end
			end
			-----------------------------------------------------------------------
			-- Medal Objective
			
			-- Get time elapsed since start time (end of cinematic)
			local timeElapsed = World_GetGameTime() - player._challenge.startTime
			
			-- Register Medal objective
			Objective_Register(_challenge.benchmarks.gold.objective, player.id)
			-- Start objective
			Objective_Start(_challenge.benchmarks.gold.objective, false, false)
			-- Player has kpi objective
			player._challenge.hasKpiObjective = true;
			
			-- If timer does not already exist
			if not Timer_Exists(player._challenge.timer) then 
				
				-- Start timer
				Timer_Start(player._challenge.timer, _challenge.benchmarks.gold.time)
				
			end
			
			-- Update timer display (incrementing)
			Objective_StartTimer(_challenge.benchmarks.gold.objective, COUNT_UP, timeElapsed, 10)
			
			-- Set player's current benchmark as Gold
			player.currentBenchmark = _challenge.benchmarks.gold
			
		end
	end
end

-- Update Objectives - Called by a rule every simtic
function ChallengeMission_Update()

	-- For every player
	for i, player in pairs(PLAYERS) do
		
		-- If player is local (not one of the AI players)
		if player.isLocal then
			
			
			-----------------------------------------------------------------------
			-- Objective Logic
			
			-- If player has the Victory Objective
			if (player._challenge.hasObjectiveVictory and not Objective_IsComplete(_challenge.victory.objectiveVictory)) then
				-- Check for Victory
				ChallengeMission_CheckVictory()
			end
			
			--return if player has the victory objective to prevent medal changes during outro narration
			if (Objective_IsComplete(_challenge.victory.objectiveVictory)) then
				return
			end
			if(Objective_IsFailed(_challenge.victory.objectiveVictory)) then
				return
			end
			
			-----------------------------------------------------------------------
			-- Medal Logic
			
			-- Get time elapsed since start time (end of cinematic)
			local timeElapsed = World_GetGameTime() - player._challenge.startTime
			
			--if the player has lost all of their units and got replacements, disable medals
			if(playerGotReinforcements == true) then
				--fail the current objective
				if(player.currentBenchmark == _challenge.benchmarks.gold) then
					Objective_Fail(_challenge.benchmarks.gold.objective)
					
					-- Register Failed Medal objective
					Objective_Register(_challenge.victory.failedMedals, player.id)
					-- Start objective
					Objective_Start(_challenge.victory.failedMedals, false, false)
					
				elseif(player.currentBenchmark == _challenge.benchmarks.silver) then
					Objective_Fail(_challenge.benchmarks.silver.objective)
					
					-- Register Failed Medal objective
					Objective_Register(_challenge.victory.failedMedals, player.id)
					-- Start objective
					Objective_Start(_challenge.victory.failedMedals, false, false)
					
				elseif(player.currentBenchmark == _challenge.benchmarks.bronze) then	
					Objective_Fail(_challenge.benchmarks.bronze.objective)
					
					-- Register Failed Medal objective
					Objective_Register(_challenge.victory.failedMedals, player.id)
					-- Start objective
					Objective_Start(_challenge.victory.failedMedals, false, false)
					
				end
				
				--set benchmark to unplaced
				player.currentBenchmark = _challenge.benchmarks.unplaced
				
				-- If objective timer already exists
				if Timer_Exists(player._challenge.timer) then
					-- End objective timer
					Timer_End(player._challenge.timer)
				end
			else
				
				--print(timeElapsed)
				
				-- If time elapsed meets the time requirement for Gold
				if timeElapsed < _challenge.benchmarks.gold.time then
					
					-- If player's current Benchmark is not set to Gold
					if player.currentBenchmark ~= _challenge.benchmarks.gold then
						
						-- Register objective
						Objective_Register(_challenge.benchmarks.gold.objective, player.id)
						-- Start objective
						Objective_Start(_challenge.benchmarks.gold.objective, false, false)
						
						-- If objective timer already exists
						if Timer_Exists(player._challenge.timer) then
							
							-- End objective timer
							Timer_End(player._challenge.timer)
							
						end	
						
						-- Start timer
						Timer_Start(player._challenge.timer, _challenge.benchmarks.gold.time)
						
						-- Update timer display (incrementing)
						Objective_StartTimer(_challenge.benchmarks.gold.objective, COUNT_UP, timeElapsed, 10)
						
						-- Set player's current benchmark as Gold
						player.currentBenchmark = _challenge.benchmarks.gold
						
					end
					
					-- If time elapsed meets the time requirement for Silver
				elseif timeElapsed < _challenge.benchmarks.silver.time then
					
					-- If player's current Benchmark is not set to Silver
					if player.currentBenchmark ~= _challenge.benchmarks.silver then
						
						-- Remove kpi objective
						Objective_Fail(_challenge.benchmarks.gold.objective, false, false)
						
						-- Register objective
						Objective_Register(_challenge.benchmarks.silver.objective, player.id)
						-- Start objective
						Objective_Start(_challenge.benchmarks.silver.objective, false, false)
						
						-- If objective timer already exists
						if Timer_Exists(player._challenge.timer) then
							
							-- End objective timer
							Timer_End(player._challenge.timer)
							
						end
						
						-- Start timer
						Timer_Start(player._challenge.timer, _challenge.benchmarks.silver.time)
						
						-- Update timer display (incrementing)
						Objective_StartTimer(_challenge.benchmarks.silver.objective, COUNT_UP, timeElapsed, 10)
						
						--play failed gold dialogue
						Rule_AddOneShot(ChallengeMission_MissedGold, 1.2)
						
						-- Set player's current benchmark as Silver
						player.currentBenchmark = _challenge.benchmarks.silver
						
					end
					
					-- If time elapsed meets the time requirement for Bronze
				elseif timeElapsed < _challenge.benchmarks.bronze.time then		
					
					-- If player's current Benchmark is not set to Bronze
					if player.currentBenchmark ~= _challenge.benchmarks.bronze then
						
						-- Remove kpi objective
						Objective_Fail(_challenge.benchmarks.silver.objective, false, false)
						
						-- Register objective
						Objective_Register(_challenge.benchmarks.bronze.objective, player.id)
						-- Start objective
						Objective_Start(_challenge.benchmarks.bronze.objective, false, false)
						
						-- If objective timer already exists
						if Timer_Exists(player._challenge.timer) then
							
							-- End objective timer
							Timer_End(player._challenge.timer)
							
						end
						
						-- Start timer
						Timer_Start(player._challenge.timer, _challenge.benchmarks.bronze.time)
						
						-- Update timer display (incrementing)
						Objective_StartTimer(_challenge.benchmarks.bronze.objective, COUNT_UP, timeElapsed, 10)
						
						--play failed silver dialogue
						Rule_AddOneShot(ChallengeMission_MissedSilver, 1.2)
						
						-- Set player's current benchmark as Bronze
						player.currentBenchmark = _challenge.benchmarks.bronze
						
					end
					
					-- If time elapsed exceeds the time requirement for Bronze
				else
					
					-- If player's current Benchmark is not set to Unplaced
					if player.currentBenchmark ~= _challenge.benchmarks.unplaced then
						
						-- Remove kpi objective
						Objective_Fail(_challenge.benchmarks.bronze.objective, false, false)
						
						-- Register objective
						Objective_Register(_challenge.benchmarks.unplaced.objective, player.id)
						-- Start objective
						Objective_Start(_challenge.benchmarks.unplaced.objective, false, false)
						
						-- If objective timer already exists
						if Timer_Exists(player._challenge.timer) then
							
							-- End objective timer
							Timer_End(player._challenge.timer)
							
						end	
						
						-- Start timer
						Timer_Start(player._challenge.timer, timeElapsed)
						
						-- Update timer display (incrementing)
						Objective_StartTimer(_challenge.benchmarks.unplaced.objective, COUNT_UP, timeElapsed)
						
						--play failed bronze dialogue
						Rule_AddOneShot(ChallengeMission_MissedBronze, 1.2)
						
						-- Set player's current benchmark as Unplaced
						player.currentBenchmark = _challenge.benchmarks.unplaced
						
					end
				end
			end
		end
	end
end

function ChallengeMission_MissedGold()
	if(not Objective_IsComplete(_challenge.victory.objectiveVictory)) then
		Util_StartIntel(EVENTS.NarrGoldFailed)
	end
end

function ChallengeMission_MissedSilver()
	if(not Objective_IsComplete(_challenge.victory.objectiveVictory)) then
		Util_StartIntel(EVENTS.NarrSilverFailed)
	end
end

function ChallengeMission_MissedBronze()
	if(not Objective_IsComplete(_challenge.victory.objectiveVictory)) then
		Util_StartIntel(EVENTS.NarrBronzeFailed)
	end
end

-- Checks if front gate has been attacked
function ChallengeMission_GateUnderAttack()
	
	
	-- Get units
	local eg_gate = Player_GetEntities(enemyPlayer)
	EGroup_Filter(eg_gate, "stone_gate", FILTER_KEEP)
	
	--if the gate has been attacked in the last 5 seconds, send spearmen to defend
	if(EGroup_IsUnderAttack(eg_gate, ANY, 5) == true) then
		
		
		if(sg_enemy_spearmen1 ~= nil and SGroup_Count(sg_enemy_spearmen1) > 0) then
			
			-- Attack move enemy spearmen to trigger location
			Cmd_AttackMove(sg_enemy_spearmen1, mkr_gate_trigger, false)
			
			--prefer to target long range siege
			-- Create SGroups
			local sg_attackers = SGroup_CreateIfNotFound("sg_attackers")
			Player_GetAllSquadsNearMarker(localPlayer, sg_attackers, Util_GetPosition(mkr_gate_trigger), 75)
			SGroup_Filter(sg_attackers, "siege_range", FILTER_KEEP)
			
			if (SGroup_Count(sg_attackers) > 0 and SGroup_Count(sg_enemy_spearmen1) > 0) then
				local s_closest_attacker = SGroup_GetClosestSquad(sg_attackers, Util_GetPosition(mkr_gate_trigger))
				if s_closest_attacker ~= nil then	
					--only attack if the unit is close enough (prevents attacking across the map)
					if(Util_GetDistance(s_closest_attacker, mkr_gate_trigger) < 100) then
						Cmd_Attack(sg_enemy_spearmen1, sg_attackers, false)
						
						-- Play dialogue
						Util_StartIntel(EVENTS.NarrEnemySally)
						
						--add rule to continue defending the area
						Rule_AddInterval(ChallengeMission_DefendAfterSallyForth, 5)
	
						-- Remove rules
						Rule_Remove(ChallengeMission_ProximityGate)
						Rule_RemoveMe()
						return
					end
				end
			end
		end
		
		-- Play dialogue
       	Util_StartIntel(EVENTS.NarrEnemySally)
		
		-- Remove rules
		Rule_Remove(ChallengeMission_ProximityGate)
		Rule_RemoveMe()
		
	end
	
end

playerHadSiegeUnitAtGate = false
--after their current siege target is destroyed, the spearmen will retreat if there are no more siege units
function ChallengeMission_DefendAfterSallyForth()
	
	if(sg_enemy_spearmen1 ~= nil and SGroup_Count(sg_enemy_spearmen1) > 0) then
		
		--prefer to target any siege except siege towers
		-- Create SGroups
		local sg_attackers = SGroup_CreateIfNotFound("sg_attackers")
		Player_GetAllSquadsNearMarker(localPlayer, sg_attackers, Util_GetPosition(mkr_gate_trigger), 75)
		SGroup_Filter(sg_attackers, "siege", FILTER_KEEP)
		SGroup_Filter(sg_attackers, "siege_tower", FILTER_REMOVE)
		
		if (SGroup_Count(sg_attackers) > 0) then
			local s_closest_attacker = SGroup_GetClosestSquad(sg_attackers, Util_GetPosition(mkr_gate_trigger))
			if s_closest_attacker ~= nil then	
				--only attack if the unit is close enough (prevents attacking across the map)
				if(Util_GetDistance(s_closest_attacker, mkr_gate_trigger) < 100) then
					playerHadSiegeUnitAtGate = true
					Cmd_Attack(sg_enemy_spearmen1, sg_attackers, false)
					return
				end
			end
		end
		
		
		if (_challenge.victory.hasBreachedWall == false) then
			--if there are no more siege weapons, retreat behind the walls
			if(playerHadSiegeUnitAtGate == true) then
				Cmd_Move(sg_enemy_spearmen1, mkr_enemy_spearmen1_spawn, false)
			end
		end
		
	else
		-- Remove rules
		Rule_RemoveMe()
	end
end

-- Checks player's proximity to inner zone
function ChallengeMission_ProximityInner()

	-- If player enters proximity of inner trigger
	if Prox_ArePlayersNearMarker(localPlayer, mkr_inner_trigger, ANY, 20) then
		
		-- Attack move enemy spearmen to trigger location
		Cmd_AttackMove(sg_enemy_spearmen1, mkr_inner_trigger, false)
		-- Activate defend module
		Prefab_DoAction(MissionOMatic_FindModule("DefendGate"), "AddSGroup", sg_enemy_spearmen1)
		
		-- Remove rules that would change unit behaviour
		Rule_Remove(ChallengeMission_ProximityGate)
		Rule_Remove(ChallengeMission_GateUnderAttack)
		Rule_RemoveMe()
	end
end

-- Checks player's proximity to gate
function ChallengeMission_ProximityGate()
	
	-- If player enters proximity of gate zone
	if Prox_ArePlayersNearMarker(localPlayer, mkr_gate_trigger, ANY, 35) then

		if(sg_enemy_spearmen1 ~= nil and SGroup_Count(sg_enemy_spearmen1) > 0) then
			
			-- Attack move enemy spearmen to trigger location
			Cmd_AttackMove(sg_enemy_spearmen1, mkr_gate_trigger, false)
			
			--prefer to target battering rams
			-- Create SGroups
			local sg_attackers = SGroup_CreateIfNotFound("sg_attackers")
			Player_GetAllSquadsNearMarker(localPlayer, sg_attackers, Util_GetPosition(mkr_gate_trigger), 75)
			SGroup_Filter(sg_attackers, "ram", FILTER_KEEP)
			
			
			--add rule to continue defending the area
			Rule_AddInterval(ChallengeMission_DefendAfterSallyForth, 5)
			
			
			if (SGroup_Count(sg_attackers) > 0 and SGroup_Count(sg_enemy_spearmen1) > 0) then
				local s_closest_attacker = SGroup_GetClosestSquad(sg_attackers, Util_GetPosition(mkr_gate_trigger))
				if s_closest_attacker ~= nil then	
					--only attack if the unit is close enough (prevents attacking across the map)
					if(Util_GetDistance(s_closest_attacker, mkr_gate_trigger) < 35) then
						Cmd_Attack(sg_enemy_spearmen1, sg_attackers, false)
						
						-- Play dialogue
						Util_StartIntel(EVENTS.NarrEnemySally)
						
						-- Remove this rule
						Rule_Remove(ChallengeMission_GateUnderAttack)
						Rule_RemoveMe()
						return
					end
				end
			end
		end
		
		
		-- Play dialogue
       	Util_StartIntel(EVENTS.NarrEnemySally)
		
		-- Remove this rule
		Rule_Remove(ChallengeMission_GateUnderAttack)
		Rule_RemoveMe()
	end
end

-- Checks player's proximity to west zone
function ChallengeMission_ProximityWest()
	
	-- If player enters proximity of west zone
	if Prox_ArePlayersNearMarker(localPlayer, mkr_west_trigger, ANY, 20) then
		
		-- Attack move enemy knights to trigger location
		Cmd_AttackMove(sg_enemy_knights, mkr_west_trigger, false)
		-- Activate defend module
		Prefab_DoAction(MissionOMatic_FindModule("DefendWest"), "AddSGroup", sg_enemy_knights)
		
		-- Remove rules that would change unit behaviour
		Rule_Remove(ChallengeMission_PatrolEnemyKnights1)
		Rule_Remove(ChallengeMission_PatrolEnemyKnights2)
		Rule_Remove(ChallengeMission_PatrolEnemyKnights3)
		Rule_Remove(ChallengeMission_ProximityFlank)
		Rule_RemoveMe()
	end
end

-- Checks player's proximity to flank
function ChallengeMission_ProximityFlank()

	-- If player enters proximity of gate zone
	if Prox_ArePlayersNearMarker(localPlayer, mkr_flank_trigger, ANY, 20) then
		
		-- Attack move enemy knights to trigger location
		Cmd_AttackMove(sg_enemy_knights, mkr_flank_trigger, false)
		
		Rule_AddInterval(ChallengeMission_DefendFlank, 2.5)
		
		-- Play dialogue
		Util_StartIntel(EVENTS.NarrEnemySally)
		
		Rule_Remove(ChallengeMission_PatrolEnemyKnights1)
		Rule_Remove(ChallengeMission_PatrolEnemyKnights2)
		Rule_Remove(ChallengeMission_PatrolEnemyKnights3)
		-- Remove this rule
		Rule_RemoveMe()
	end
end

--after knights sally forth, they will defend until there are no nearby units
function ChallengeMission_DefendFlank()
	
	if(sg_enemy_knights ~= nil and SGroup_Count(sg_enemy_knights) > 0) then
		
		-- Create SGroups
		local sg_attackers = SGroup_CreateIfNotFound("sg_attackers")
		Player_GetAllSquadsNearMarker(localPlayer, sg_attackers, Util_GetPosition(mkr_flank_trigger), 50)
		
		if (SGroup_Count(sg_attackers) > 0 and SGroup_Count(sg_enemy_knights) > 0) then
			local s_closest_attacker = SGroup_GetClosestSquad(sg_attackers, Util_GetPosition(mkr_flank_trigger))
			if s_closest_attacker ~= nil then	
				--only attack if the unit is close enough (prevents attacking across the map)
				if(Util_GetDistance(s_closest_attacker, mkr_flank_trigger) < 50) then
					Cmd_AttackMove(sg_enemy_knights, Util_GetPosition(s_closest_attacker), false)
					return
				end
			end
		end
	end
	
	--if no more player units are nearby, retreat back behind the walls
	Cmd_Move(sg_enemy_knights, mkr_enemy_knights1_rally, false)
	Rule_RemoveMe()
end

function ChallengeMission_AttackRams()
	if(sg_enemy_menatarms ~= nil and SGroup_Count(sg_enemy_menatarms) > 0) then
		
		--prefer to target battering rams
		-- Create SGroups
		local sg_attackers = SGroup_CreateIfNotFound("sg_attackers")
		Player_GetAllSquadsNearMarker(localPlayer, sg_attackers, Util_GetPosition(mkr_inner_trigger), 35)
		SGroup_Filter(sg_attackers, "ram", FILTER_KEEP)
		
		if (SGroup_Count(sg_attackers) > 0 and SGroup_Count(sg_enemy_menatarms) > 0) then
			local s_closest_attacker = SGroup_GetClosestSquad(sg_attackers, Util_GetPosition(mkr_inner_trigger))
			if s_closest_attacker ~= nil then	
				--only attack if the unit is close enough (prevents attacking across the map)
				if(Util_GetDistance(s_closest_attacker, mkr_inner_trigger) < 35) then
					Cmd_Attack(sg_enemy_menatarms, sg_attackers, false)
					return
				end
			end
		end
	end
end

-- Global event callback for destruction
function ChallengeMission_OnDestruction(context)
	
	-- Check if player has destroyed a Conquest building
	if Entity_IsOfType(context.victim, _challenge.victory.destroyRequirement) then
		
		-- For every player
		for i, player in pairs(PLAYERS) do	
			
			-- If the player is local (not one of the AI players)
			if player.isLocal then
				
				-- If player has not completed Capital Town Center subobjective
				if (player._challenge.hasObjectiveSub1 and not Objective_IsComplete(_challenge.victory.objectiveSub1)) then
					
					-- If the destroyed building was the East
					if (context.victim == player._challenge.enemyCapital) then
						
						-- Track as last destroyed entity marker
						--_challenge.victory.lastConquestLocation = Marker_FromName("mkr_outpost_east", "")
						_challenge.victory.lastConquestLocation = Entity_GetPosition(player._challenge.enemyCapital)
						
						-- Mark Objective as Complete
						Objective_Complete(_challenge.victory.objectiveSub1, true, false)
						-- Increment Victory counter
						player._challenge.conquestProgress = player._challenge.conquestProgress + 1
						
						-- Play Victory Stinger
						Music_PlayStinger("mus_stinger_campaign_positive")
						
						-- Play dialogue
						Util_StartIntel(EVENTS.NarrDestroyTC)
						
						-- Create SGroups
						local sg_attackers = SGroup_CreateIfNotFound("sg_attackers")
						Player_GetAllSquadsNearMarker(localPlayer, sg_attackers, Entity_GetPosition(context.victim), 20)
						SGroup_Filter(sg_attackers, "infantry", FILTER_KEEP)
						
						-- If there was more than one infantry attacker
						if (SGroup_Count(sg_attackers) > 0) then
							-- Trigger Walla
							Sound_PlayWallaCelebrateOnSGroup(sg_attackers)
						end
						--remove minimap blip
						for index, entry in pairs(minimapBlips) do 	
							if entry.id == Entity_GetID(context.victim) then
								UI_DeleteMinimapBlip(entry.blip)
							end
						end
					end
					
				end
				
				-- If player has not completed Landmark subobjective
				if (player._challenge.hasObjectiveSub2 and not Objective_IsComplete(_challenge.victory.objectiveSub2)) then
					
					-- If the destroyed building was the West
					if (context.victim == player._challenge.enemyLandmark1) then
						
						-- Track as last destroyed entity
						--_challenge.victory.lastConquestLocation = Marker_FromName("mkr_outpost_west", "")
						_challenge.victory.lastConquestLocation = Entity_GetPosition(player._challenge.enemyLandmark1)
						
						-- Mark Objective as Complete
						Objective_Complete(_challenge.victory.objectiveSub2, true, false)
						-- Increment Victory counter
						player._challenge.conquestProgress = player._challenge.conquestProgress + 1
						
						-- Play Victory Stinger
						Music_PlayStinger("mus_stinger_campaign_positive")
						
						-- Play dialogue
						if(not Objective_IsComplete(_challenge.victory.objectiveSub3)) then
							Util_StartIntel(EVENTS.NarrDestroyFirst)
						else
							Util_StartIntel(EVENTS.NarrDestroySecond)
						end
						
						-- Create SGroups
						local sg_attackers = SGroup_CreateIfNotFound("sg_attackers")
						Player_GetAllSquadsNearMarker(localPlayer, sg_attackers, Entity_GetPosition(context.victim), 20)
						SGroup_Filter(sg_attackers, "infantry", FILTER_KEEP)
						
						-- If there was more than one infantry attacker
						if (SGroup_Count(sg_attackers) > 0) then
							-- Trigger Walla
							Sound_PlayWallaCelebrateOnSGroup(sg_attackers)
						end
						--remove minimap blip
						for index, entry in pairs(minimapBlips) do 	
							if entry.id == Entity_GetID(context.victim) then
								UI_DeleteMinimapBlip(entry.blip)
							end
						end
					end
					
				end
				
				-- If player has not completed Landmark subobjective
				if (player._challenge.hasObjectiveSub3 and not Objective_IsComplete(_challenge.victory.objectiveSub3)) then
					
					-- If the destroyed building was the West
					if (context.victim == player._challenge.enemyLandmark2) then
						
						-- Track as last destroyed entity
						--_challenge.victory.lastConquestLocation = Marker_FromName("mkr_outpost_west", "")
						_challenge.victory.lastConquestLocation = Entity_GetPosition(player._challenge.enemyLandmark2)
						
						-- Mark Objective as Complete
						Objective_Complete(_challenge.victory.objectiveSub3, true, false)
						-- Increment Victory counter
						player._challenge.conquestProgress = player._challenge.conquestProgress + 1
						
						-- Play Victory Stinger
						Music_PlayStinger("mus_stinger_campaign_positive")
						
						-- Play dialogue
						if(not Objective_IsComplete(_challenge.victory.objectiveSub2)) then
							Util_StartIntel(EVENTS.NarrDestroyFirst)
						else
							Util_StartIntel(EVENTS.NarrDestroySecond)
						end
						
						-- Create SGroups
						local sg_attackers = SGroup_CreateIfNotFound("sg_attackers")
						Player_GetAllSquadsNearMarker(localPlayer, sg_attackers, Entity_GetPosition(context.victim), 20)
						SGroup_Filter(sg_attackers, "infantry", FILTER_KEEP)
						
						-- If there was more than one infantry attacker
						if (SGroup_Count(sg_attackers) > 0) then
							-- Trigger Walla
							Sound_PlayWallaCelebrateOnSGroup(sg_attackers)
						end
						--remove minimap blip
						for index, entry in pairs(minimapBlips) do 	
							if entry.id == Entity_GetID(context.victim) then
								UI_DeleteMinimapBlip(entry.blip)
							end
						end
					end
				end
			end
		end
	end
	
	-- If player has not breached the enemy walls
	if (_challenge.victory.hasBreachedWall == false) then
		
		-- Check if destroyed entity was a wall
		if Entity_IsOfType(context.victim, "wall") then
			
			-- Play Victory Stinger
			Music_PlayStinger("mus_stinger_campaign_positive")

			-- Create SGroups
			local sg_attackers = SGroup_CreateIfNotFound("sg_attackers")
			Player_GetAllSquadsNearMarker(localPlayer, sg_attackers, Entity_GetPosition(context.victim), 10)
			SGroup_Filter(sg_attackers, "infantry", FILTER_KEEP)
			
			-- If there was more than one infantry attacker
			if (SGroup_Count(sg_attackers) > 0) then
				-- Trigger Walla
				Sound_PlayWallaCelebrateOnSGroup(sg_attackers)
			end
			
			-- Lock Music Intensity
			Music_LockIntensity(MUSIC_TENSE_COMBAT_RARE)
			
			-- Track that wall was breached
			_challenge.victory.hasBreachedWall = true
			
			--garrison town center
			EnemyGarrisonTownCenter()
		
			-- Play dialogue
       		Util_StartIntel(EVENTS.NarrWallDestroyed)
			
		end
	end
	
	
	-- Check if destroyed entity was the gate and retreat archers so the don't get stuck in rubble
	if Entity_IsOfType(context.victim, "stone_gate") then
		RetreatArchers()
		Rule_AddInterval(ChallengeMission_AttackRams, 1)
	end
	
	-- For every player
	for i, player in pairs(PLAYERS) do	
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			-- If player has the Victory Objective and it hasn't been completed
			if (player._challenge.hasObjectiveVictory and not Objective_IsComplete(_challenge.victory.objectiveVictory)) then
				
				-- Check if local player is annihilated
				ChallengeMission_CheckAnnihilation(context)
				
			end
		end
	end
end

hasStartedReinforcementTimer = false
reinforcementTime = 0
-- Evaluates whether the player whose unit/building was killed is eliminated.
function ChallengeMission_CheckAnnihilation(context)		
	
	-- For every player
	for i, player in pairs(PLAYERS) do	
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			
			-- If the victim is the local player
			if context.victimOwner == player.id then
				
				-- If player has not been eliminated
				if not player.isEliminated then	
					
					-- Get player squads
					local squads = Player_GetSquads(player.id)
					-- Filter out sheep
					SGroup_Filter(squads, "gaia", FILTER_REMOVE)
					-- Filter out monks
					SGroup_Filter(squads, "monk", FILTER_REMOVE)
					-- Get number of squads
					local num_squads = SGroup_CountSpawned(squads)
					-- Remove sgroup that was just created
					SGroup_Destroy(squads)
					
					-- Check for annihiliation when player has no squads left
					if num_squads == 0 then
						
						isCheckingAnnihiliation = true
					end			
				end
			end
		end
	end
end

isCheckingAnnihiliation = false

function CheckLateSiegeAnnihiliation()
	
	if(isCheckingAnnihiliation == false) then
		hasStartedReinforcementTimer = false
		return
	end
	
	-- For every player
	for i, player in pairs(PLAYERS) do	
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			
			-- Get player squads
			local squads = Player_GetSquads(player.id)
			-- Filter out sheep
			SGroup_Filter(squads, "gaia", FILTER_REMOVE)
			-- Filter out monks
			SGroup_Filter(squads, "monk", FILTER_REMOVE)
			-- Get number of squads
			local num_squads = SGroup_CountSpawned(squads)
			-- Remove sgroup that was just created
			SGroup_Destroy(squads)
			
			if(num_squads > 0) then
				isCheckingAnnihiliation = false
				return
			end
			
			-- Get player resources
			local food = Player_GetResource(player.id, RT_Food)
			local wood = Player_GetResource(player.id, RT_Wood)
			local gold = Player_GetResource(player.id, RT_Gold)
			
			
			local has_entity_with_queue = false
			local has_squads_in_queue = false
			local has_resources_remaining = false
			local entities = Player_GetEntities(player.id)
			
			-- Check if player has a unit in production or sufficient resources to produce something. 
			for i = 1, EGroup_CountSpawned(entities) do
				local entity = EGroup_GetEntityAt(entities, i)					
				if not Entity_IsBuilding(entity) or Entity_GetBuildingProgress(entity) >= 1.0 then		-- Accounts for both packed Mongol buildings and finished buildings of other civs 
					if Entity_HasProductionQueue(entity) then
						local num_items_in_queue = Entity_GetProductionQueueSize(entity)
						for j = 0, (num_items_in_queue - 1) do
							if Entity_GetProductionQueueItemType(entity, j) == PITEM_Spawn then
								has_entity_with_queue = true
								has_squads_in_queue = true
								break
							end
						end
						if has_squads_in_queue then
							break
						end
					end
					for entity_type, cost in pairs(player._annihilation.cheapest_squad_cost) do 
						if Entity_IsOfType(entity, entity_type) then 									
							has_entity_with_queue = true
							if food >= cost.food and wood >= cost.wood and gold >= cost.gold then
								has_resources_remaining = true
								break
							end
						end
					end
					if has_entity_with_queue and has_resources_remaining then
						break
					end
				end
			end
			EGroup_Destroy(entities)
			
			if(has_squads_in_queue == true) then
				hasStartedReinforcementTimer = false
			else
				if(hasStartedReinforcementTimer == false) then
					reinforcementTime = World_GetGameTime()
					hasStartedReinforcementTimer = true
				end
				
			end
			
			--after enough time has passed, ignore remaining resources
			local currentGameTime = World_GetGameTime()
			if(hasStartedReinforcementTimer == true and currentGameTime > reinforcementTime + 10) then
				has_resources_remaining = false
			end
			
			-- Player is annihilated if they have no units alive and either: no buildings that can produce something or no units in production (and no resources to produce anything).
			if not has_entity_with_queue or (not has_squads_in_queue and not has_resources_remaining) then
				
				if(not Objective_IsComplete(_challenge.victory.objectiveVictory)) then
					--instead of losing the mission, the player will now get additional units
					LateSiegeReinforcements()
					isCheckingAnnihiliation = false
				end
				
				--[[
				-- Player is now eliminated
				player.isEliminated = true
				
				-- Store completion time
				--local completionSeconds = World_GetGameTime()
				--player._challenge.completionTime = completionSeconds / 60
				
				-- Silently Fail objectives
				Objective_Fail(_challenge.victory.objectiveVictory, true, false)
				
				-- Set player as victorious
				Core_SetPlayerDefeated(player.id, ChallengeMission_DefeatPresentation, WR_OBJECTIVEFAILED)
				--]]
			end
		end
	end
end

--ensure that the player has resources for 2 trebuchets, 1 bombard, 1 ram, 1 siege tower
function CalculateLateSiegeStartingResources()
	
	local sbp_trebuchet_sul = BP_GetSquadBlueprint("unit_trebuchet_4_cw_sul")
	local sbp_bombard_sul = BP_GetSquadBlueprint("unit_bombard_4_sul")
	local sbp_siege_tower_sul = BP_GetSquadBlueprint("unit_siege_tower_3_sul")
	local sbp_ram_sul = BP_GetSquadBlueprint("unit_ram_3_sul")
	
	local highestGoldCost = 0
	local highestWoodCost = 0
	
	local trebuchetCost = Player_GetSquadBPCost(localPlayer, sbp_trebuchet_sul)
	local bombardCost = Player_GetSquadBPCost(localPlayer, sbp_bombard_sul)
	
	highestGoldCost = trebuchetCost.gold * 2
	highestGoldCost = highestGoldCost + bombardCost.gold
	
	highestWoodCost = trebuchetCost.wood * 2
	highestWoodCost = highestWoodCost + bombardCost.wood
	
	_challenge.startingResources.gold = highestGoldCost
	_challenge.startingResources.wood = highestWoodCost
	
	--now check ram and siege tower
	local ramCost = Player_GetSquadBPCost(localPlayer, sbp_ram_sul)
	local siegeTowerCost = Player_GetSquadBPCost(localPlayer, sbp_siege_tower_sul)
	
	_challenge.startingResources.wood = _challenge.startingResources.wood + (ramCost.wood + siegeTowerCost.wood)
end

function LateSiegeReinforcements()
	
	playerGotReinforcements = true
	hasStartedReinforcementTimer = false
	
	CalculateLateSiegeStartingResources()
	-- Set starting resources
	Player_SetResource(localPlayer, RT_Food, _challenge.startingResources.food)
	Player_SetResource(localPlayer, RT_Wood, _challenge.startingResources.wood)
	Player_SetResource(localPlayer, RT_Gold, _challenge.startingResources.gold)
	Player_SetResource(localPlayer, RT_Stone, _challenge.startingResources.stone)
	
	
	-- Get unit blueprints
	local sbp_manatarms_sul = BP_GetSquadBlueprint("unit_manatarms_3_sul")
	local sbp_archer_sul = BP_GetSquadBlueprint("unit_archer_3_sul")
	local sbp_scout_sul = BP_GetSquadBlueprint("unit_scout_1_sul")
	local sbp_warelephant_sul = BP_GetSquadBlueprint("unit_war_elephant_3_sul")
	local sbp_spearman_sul = BP_GetSquadBlueprint("unit_spearman_3_sul")
	
	--[[ PLAYER UNITS ]]--
	
	-- Create SGroups
	sg_player_menatarms1 = SGroup_CreateIfNotFound("sg_player_menatarms1")
	sg_player_spearmen1 = SGroup_CreateIfNotFound("sg_player_spearmen1")
	sg_player_archers1 = SGroup_CreateIfNotFound("sg_player_archers1")
	sg_player_scouts1 = SGroup_CreateIfNotFound("sg_player_scouts1")
	sg_player_warelephants1 = SGroup_CreateIfNotFound("sg_player_warelephants1")
	
	-- Spawn units
	UnitEntry_DeploySquads(localPlayer, sg_player_menatarms1, {{sbp = sbp_manatarms_sul, numSquads = 20 }}, mkr_player_menatarms1_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_player_spearmen1, {{sbp = sbp_spearman_sul, numSquads = 10 }}, mkr_player_menatarms2_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_player_archers1, {{sbp = sbp_archer_sul, numSquads = 10 }}, mkr_player_menatarms2_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_player_scouts1, {{sbp = sbp_scout_sul, numSquads = 3 }}, mkr_player_scouts1_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_player_warelephants1, {{sbp = sbp_warelephant_sul, numSquads = 2 }}, mkr_player_warelephants1_spawn)
	
	
	-- Face units
	Cmd_FormationMove(sg_player_menatarms1, mkr_player_menatarms1_spawn, false, false, mkr_player_menatarms1_facing)
	Cmd_FormationMove(sg_player_spearmen1, mkr_player_menatarms2_spawn, false, false, mkr_player_menatarms2_facing)
	Cmd_FormationMove(sg_player_archers1, mkr_player_menatarms2_spawn, false, false, mkr_player_menatarms2_facing)
	Cmd_FormationMove(sg_player_warelephants1, mkr_player_warelephants1_spawn, false, false, mkr_player_warelephants1_facing)
	Cmd_FormationMove(sg_player_scouts1, mkr_player_scouts1_spawn, true, false,  mkr_player_menatarms2_facing)

	-- Position player units
	Cmd_FormationMove(sg_player_warelephants1, mkr_player_warelephants1_rally, true, false, mkr_player_warelephants1_facing)
	Cmd_FormationMove(sg_player_menatarms1, mkr_player_menatarms1_rally, true, false, mkr_player_menatarms1_facing)
	Cmd_FormationMove(sg_player_spearmen1, mkr_player_menatarms2_rally, true, false,  mkr_player_menatarms2_facing)
	Cmd_FormationMove(sg_player_scouts1, mkr_player_menatarms1_spawn, true, false,  mkr_player_menatarms2_facing)

	
	--add call to action
	EventCues_CallToAction("$11202439", CTA_CELEBRATE, nil, nil, Marker_GetPosition(mkr_player_warelephants1_spawn), 30, "icons/cta/illustrations/02_celebration", "mus_stinger_campaign_triumph_short")
	
end

-- Check if player has completed the Challenge Mission
function ChallengeMission_CheckVictory()
	
	-- For every player
	for i, player in pairs(PLAYERS) do	

		-- If the player is local (not one of the AI players)
		if player.isLocal then
			
			-- Check if key buildings have been destroyed
			if (player._challenge.conquestProgress >= _challenge.victory.completionRequirement) then
				
				--special case: fail objective if the player needed reinforcements
				if(playerGotReinforcements) then
					
					Objective_Fail(_challenge.victory.objectiveVictory, false, true)
					Mission_Complete()
					
				else
					-- Store completion time
					local completionSeconds = World_GetGameTime() - player._challenge.startTime
					player._challenge.completionTime = completionSeconds / 60
					
					-- Package completion time for Data Store
					local trialInformation = {kpi = completionSeconds}
					
					-- Provide completion time to Stats system via Data Store
					Game_StoreTableData("trial", trialInformation)
					
					print(string.format("CHALLENGE COMPLETED IN %f MINUTES", player._challenge.completionTime))
					
					-- Set victory objective to complete
					Objective_Complete(_challenge.victory.objectiveVictory, false, true)
					
					-- Pause objective timer
					Objective_PauseTimer(player.currentBenchmark.objective)
				end
			end
		end
	end
end

-- Trigger unit walla and building fires
function ChallengeMission_InitializeOutro()
	
	-- For every player
	for i, player in pairs(PLAYERS) do	

		-- If the player is local (not one of the AI players)
		if player.isLocal then
			
			-- Get player's surviving units
			local sg_playerUnits = Player_GetSquads(player.id)
			
			-- Set player's units to invulnerable
			SGroup_SetInvulnerable(sg_playerUnits, true, 0)
		end
	end
	
	-- Check for last units standing
	Rule_AddInterval(ChallengeMission_CheckCheer, 1)
	-- Set enemy buildings on fire
	ChallengeMission_SetBuildingsOnFire()
	
end

-- Check for last team standing and initialize cheering
function ChallengeMission_CheckCheer()
	
	-- Create SGroups
	local sg_playerSurvivors = SGroup_CreateIfNotFound("sg_playerSurvivors")
	local sg_enemySurvivors = SGroup_CreateIfNotFound("sg_enemySurvivors")
	
	-- Get player squads near 
	Player_GetAllSquadsNearMarker(localPlayer, sg_playerSurvivors, _challenge.victory.lastConquestLocation, 40)
	local playerUnitCount = SGroup_Count(sg_playerSurvivors)

	-- Get player squads near 
	Player_GetAllSquadsNearMarker(enemyPlayer, sg_enemySurvivors, _challenge.victory.lastConquestLocation, 40)
	local enemyUnitCount = SGroup_Count(sg_enemySurvivors)

	-- If the enemy does not have any units near the end position
	if enemyUnitCount == 0 then
		
		-- Make units cheer
		SGroup_EnableCheering(sg_playerSurvivors, true, -1, WALLA_CAMP_CELEBRATE_LARGE)
		
		-- End this rule
		Rule_RemoveMe()
		
	end
end

-- Randomly sets enemy buildings on fire
function ChallengeMission_SetBuildingsOnFire()
	
	-- Get units
	local sg_enemy_units = Player_GetSquads(enemyPlayer)
	-- Remove units
	SGroup_DestroyAllSquads(sg_enemy_units)
	
	-- Create Egroup
	local eg_enemy_buildings = EGroup_CreateIfNotFound("eg_enemy_buildings")
	-- Get all enemy buildings
	eg_enemy_buildings = Player_GetAllEntities(enemyPlayer)
	
	-- Set building on fire
	local function _SetFire(gid, idx, eid)
		
		-- Gets random number for fire threshold
		local randFire = World_GetRand(1, 100)
		-- Gets random number for damage
		local randDamage = World_GetRand(20, 80)/100
		
		-- If entity is a wall
		if Entity_IsOfType(eid, "wall") then
			
			-- If number is greater than wall threshold
			if (randFire > 80) then
				
				-- Damage
				Entity_SetHealth(eid, randDamage)
				-- Set on Fire
				Entity_SetOnFire(eid)
				
			end
		
		-- If not a wall, it's a building
		else
			-- If number is greater than building threshold
			if (randFire > 0) then
				
				-- Damage
				Entity_SetHealth(eid, randDamage)
				-- Set on Fire
				Entity_SetOnFire(eid)
				
			end
		end
	end
	
	-- For every building
	EGroup_ForEach(eg_enemy_buildings, _SetFire)
	
end

-- End Challenge
function ChallengeMission_EndChallenge()

	-- Set player as victorious
	Core_SetPlayerVictorious(localPlayer, nil, WR_OBJECTIVECOMPLETE)
	-- Slowdown sim rate for post-match screen
	Game_SetSimRate(0.5)
	
end
-- Defeat Presentation Functions
function ChallengeMission_DefeatPresentation(playerID)
		
	-- For every player
	for i, player in pairs(PLAYERS) do	
		
		-- If player is local (not AI)
		if player.isLocal then 
			
			-- Clear player selection
			Misc_ClearSelection()
			-- Set taskbar to invisible
			Taskbar_SetVisibility(false)
			
			-- Set primary end message
			local endMessage = "$11179828" -- "Challenge Failed"
			-- Stores a victory message (default = nothing)
			local defeatMessage = "$11166951"
			
			-- Add Victory presentation
			Rule_AddOneShot(_gameOver_message, GAMEOVER_OBJECTIVE_TIME, {_playerID = playerID, _icon = _challenge.icons.victoryObjective, _endType = endMessage, _message = defeatMessage, _sound = "ConquestDefeatEvent", _videoURI = "stinger_defeat"})
			
		end
	end
end





-- User has ungarrisoned a Siege Tower on top of a wall
function UserHasUnloadedSiegeTowerNarration()
	if(hasUnloadedSiegeTower == false) then
		
		local localPlayer = Game_GetLocalPlayer()
		local sg_player_units = Player_GetSquads(localPlayer)
		
		-- Only look at infantry that can garrison
		SGroup_Filter(sg_player_units, "infantry", FILTER_KEEP)
		
		-- Check if any units are garrisoned
		if SGroup_IsInHoldSquad(sg_player_units, ANY) then
			
			for i = 1, SGroup_Count(sg_player_units) do
				
				local squad = SGroup_GetSquadAt(sg_player_units, i)
				
				-- Check if each unit is garrisoned
				if Squad_IsInHoldSquad(squad) then
					
					-- For garrisoned unit, get garrisoned vehicle
					local garrisonedVehicle = Squad_GetHoldSquad(squad)
					
					-- Check if garrisoned vehicle is a Siege Tower
					if Squad_IsOfType(garrisonedVehicle, "siege_tower") then
						
						local abilBP = BP_GetAbilityBlueprint("siege_tower_unload_on_wall")
						
						-- If player has seen Siege Tower unloading on wall
						if Squad_IsDoingAbility(garrisonedVehicle, abilBP) and Misc_IsSquadOnScreen(garrisonedVehicle, 100) then
							Util_StartIntel(EVENTS.NarrWallsClimbed)
							hasUnloadedSiegeTower = true
							return true
							
						end
					end	
				end
			end
		end
	end
	return false
end




--if the objectives are under attack, defend them with the nearmy units
function DefendAgainstSiege()
	
	if(enemyLandmark1 == nil) then
		enemyLandmark1 = EGroup_GetEntityAt(enemy_landmark1, 1)
	end
	
	--if Palantine Chapel has been attacked in the last 5 seconds, send men at arms to defend
	if(Entity_IsUnderAttack(enemyLandmark1, 5) == true) then
		local sg_player_units = Player_GetSquads(localPlayer)
		
		local s_closest_attacker = SGroup_GetClosestSquad(sg_player_units, Util_GetPosition(enemyLandmark1))
		if s_closest_attacker ~= nil then
			--only attack if the unit is close enough (prevents attacking across the map)
			if(Util_GetDistance(s_closest_attacker, enemyLandmark1) < 100) then
				Cmd_AttackMove(sg_enemy_menatarms, Util_GetPosition(s_closest_attacker), false)
			end
		end
	end
	
	----------
	
	if(enemyLandmark2 == nil) then
		enemyLandmark2 = EGroup_GetEntityAt(enemy_landmark2, 1)
	end
	
	--if Regnitz Cathedral has been attacked in the last 5 seconds, send knights to defend
	if(Entity_IsUnderAttack(enemyLandmark2, 5) == true) then
		local sg_player_units = Player_GetSquads(localPlayer)
		
		local s_closest_attacker = SGroup_GetClosestSquad(sg_player_units, Util_GetPosition(enemyLandmark2))
		if s_closest_attacker ~= nil then
			--only attack if the unit is close enough (prevents attacking across the map)
			if(Util_GetDistance(s_closest_attacker, enemyLandmark2) < 100) then
				Cmd_AttackMove(sg_enemy_knights, Util_GetPosition(s_closest_attacker), false)
				Rule_Remove(ChallengeMission_PatrolEnemyKnights1)
				Rule_Remove(ChallengeMission_PatrolEnemyKnights2)
				Rule_Remove(ChallengeMission_PatrolEnemyKnights3)
			end
		end
	end
	
	----------
	
	if(enemyCapital == nil) then
		enemyCapital = EGroup_GetEntityAt(enemy_capital, 1)
	end
	
	--if the Town Center or the defending spearmen group has been attacked in the last 5 seconds, send spearmen to defend
	if(Entity_IsUnderAttack(enemyCapital, 5) == true or SGroup_IsUnderAttack(sg_enemy_spearmen2, ANY, 5)) then
		local sg_player_units = Player_GetSquads(localPlayer)
		
		local s_closest_attacker = SGroup_GetClosestSquad(sg_player_units, Util_GetPosition(enemyCapital))
		if s_closest_attacker ~= nil then	
			--only attack if the unit is close enough (prevents attacking across the map)
			if(Util_GetDistance(s_closest_attacker, enemyCapital) < 100) then
				Cmd_AttackMove(sg_enemy_spearmen2, Util_GetPosition(s_closest_attacker), false)
			end
		end
	end
	
	
	
end

function CheckIfSiegeBuildingsSelected()
	
	local eg_currentSelection = EGroup_CreateIfNotFound("eg_currentSelection")
	Misc_GetSelectedEntities(eg_currentSelection, false)
	
	-- Check player units
	for i = 1, EGroup_Count(eg_currentSelection) do
		
		local entity = EGroup_GetEntityAt(eg_currentSelection, i)
		-- Check for unit on screen
		if (Entity_IsOfType(entity, "scar_siegeworkshop")) then
			
			Objective_RemoveUIElements(_challenge.victory.objectiveVictory, hintPoint_siegeWorkshop)
			
			--remove minimap blip
			for index, entry in pairs(minimapBlips) do 	
				if entry.id == Entity_GetID(entity) then
					UI_DeleteMinimapBlip(entry.blip)
				end
			end
		end
	end
	
	-----------------------------------------------------------------------
	
	-- Check player units
	for i = 1, EGroup_Count(eg_currentSelection) do
		
		local entity = EGroup_GetEntityAt(eg_currentSelection, i)
		-- Check for unit on screen
		if (Entity_IsOfType(entity, "scar_university")) then
			
			Objective_RemoveUIElements(_challenge.victory.objectiveVictory, hintPoint_madrasa)
			
			--remove minimap blip
			for index, entry in pairs(minimapBlips) do 	
				if entry.id == Entity_GetID(entity) then
					UI_DeleteMinimapBlip(entry.blip)
				end
			end
		end
	end
	
end

--move archers over gate back when the gate is destroyed
function RetreatArchers()
	
	local leftArcPos = Util_GetPosition(mkr_inner_trigger)
	leftArcPos["x"] = leftArcPos["x"] - 10
	leftArcPos["z"] = leftArcPos["z"] + 12
	local rightArcPos = Util_GetPosition(mkr_inner_trigger)
	rightArcPos["x"] = rightArcPos["x"] + 10
	rightArcPos["z"] = rightArcPos["z"] + 12
	
	ArcFormation(leftArcPos, rightArcPos, sg_enemy_archers05, .7, false, 0)
	
	leftArcPos["z"] = leftArcPos["z"] + 2
	rightArcPos["z"] = rightArcPos["z"] + 2
	ArcFormation(leftArcPos, rightArcPos, sg_enemy_archers06, .7, false, .5)
	
end

--garrison the town center with nearby villagers
function EnemyGarrisonTownCenter()
	
	-- Create SGroup
	local sg_garrison_workers = SGroup_CreateIfNotFound("sg_garrison_workers")
	Player_GetAllSquadsNearMarker(enemyPlayer, sg_garrison_workers, Util_GetPosition(mkr_farming_zone), 40)
	SGroup_Filter(sg_garrison_workers, "villager", FILTER_KEEP)
	
	-- Create EGroup
	local eg_garrison_TC = EGroup_CreateIfNotFound("eg_garrison_TC")
	Player_GetAllEntitiesNearMarker(enemyPlayer, eg_garrison_TC, Util_GetPosition(mkr_enemy_spearmen2_rally), 50)
	EGroup_Filter(eg_garrison_TC, "town_center", FILTER_KEEP)
	
	if(SGroup_CountSpawned(sg_garrison_workers) > 0 and EGroup_CountSpawned(eg_garrison_TC) > 0) then
		Cmd_Garrison(sg_garrison_workers, eg_garrison_TC, false, false, false)
	end
	
end

--this function orders units to form a line form startPos to endPos with the curvature curveStrength
function ArcFormation(startPos, endPos, inGroup, curveStrength, inQueued, inOffset)
	if(SGroup_CountSpawned(inGroup) == 0) then
		return
	end
	
	local fLine = Util_GetPosition(startPos)
	fLine["x"] = endPos["x"] - startPos["x"]
	fLine["z"] = endPos["z"] - startPos["z"]
	
	local tLine = Util_GetPosition(startPos)
	tLine["x"] = fLine["z"]
	tLine["z"] = -fLine["x"]
	
	
	for i = 1, SGroup_Count(inGroup) do
		--offset should be from 0 to 1
		local pointD = (i - inOffset) / SGroup_Count(inGroup)
		
		local unitDest = Util_GetPosition(startPos)
		--calculate the destination for each unit
		unitDest["x"] = startPos["x"] + (pointD * fLine["x"])
		unitDest["z"] = startPos["z"] + (pointD * fLine["z"])
		
		local curveMultiplier = pointD - .5
		
		curveMultiplier = curveMultiplier * curveMultiplier
		curveMultiplier = .25 - curveMultiplier
		
		unitDest["x"] = unitDest["x"] + (tLine["x"] * curveMultiplier * curveStrength)
		unitDest["z"] = unitDest["z"] + (tLine["z"] * curveMultiplier * curveStrength)
		
		--isolate each unit and give it a move order
		local squad = SGroup_GetSquadAt(inGroup, i)
		SGroup_Single(sg_single, squad)
		Cmd_Move(sg_single, unitDest, inQueued)
	end
	
end

--this function orders an SGroup to scatter inDistToMove away from its center
function ScriptScatterUnits(inGroup, inDistToMove, inUseGroupCenter, inCenter, inFaceUnits, inFacingMarker, inQueued)
	
	if(inGroup == nil) then
		return
	end
	
	if(SGroup_Count(inGroup) == 0) then
		return
	end
	
	--find center point or use parameter
	local centerPoint = Util_GetPosition(inGroup)
	if(inUseGroupCenter == true) then
		centerPoint["x"] = 0
		centerPoint["z"] = 0
		for i = 1, SGroup_Count(inGroup) do
			
			local squad = SGroup_GetSquadAt(inGroup, i)
			local squadPos = Util_GetPosition(squad)
			
			centerPoint["x"] = centerPoint["x"] + squadPos["x"]
			centerPoint["z"] = centerPoint["z"] + squadPos["z"]
			
		end
		
		if(SGroup_Count(inGroup) > 0) then
			
			centerPoint["x"] = centerPoint["x"] / SGroup_Count(inGroup)
			centerPoint["z"] = centerPoint["z"] / SGroup_Count(inGroup)
		end
	else
		centerPoint = Util_GetPosition(inCenter)
	end
	
	
	
	for i = 1, SGroup_Count(inGroup) do
		
		local squad = SGroup_GetSquadAt(inGroup, i)
		local unitPos = Util_GetPosition(squad)
		local centerDir = Util_GetPosition(squad)
		
		--find vector from individual unit to center
		centerDir["x"] = (unitPos["x"] - centerPoint["x"])
		centerDir["z"] = (unitPos["z"] - centerPoint["z"])
		
		--normalize vector
		local distToCenter = math.sqrt((centerDir["x"] * centerDir["x"]) + (centerDir["z"] * centerDir["z"]))
		if(distToCenter > 0) then
			centerDir["x"] = centerDir["x"] / distToCenter
			centerDir["z"] = centerDir["z"] / distToCenter
		end
		
		--calculate destination
		local unitDest = Util_GetPosition(squad)
		unitDest["x"] = unitPos["x"] + (centerDir["x"] * inDistToMove)
		unitDest["z"] = unitPos["z"] + (centerDir["z"] * inDistToMove)
		
		SGroup_Single(sg_single, squad)
		Cmd_Move(sg_single, unitDest, inQueued)
		
		--give extra facing order if applicable
		if(inFaceUnits == true) then
			if(inFacingMarker ~= nil) then
				-- Face menatarms
				Cmd_FormationMove(sg_single, unitDest, true, false, inFacingMarker)
			else
				--face center
				Cmd_FormationMove(sg_single, unitDest, true, false, centerPoint)
			end
		end
		
	end
	
end

