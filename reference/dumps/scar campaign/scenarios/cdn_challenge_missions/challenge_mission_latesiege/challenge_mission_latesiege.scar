	-- Assign enemy units to Defend Modules (knights and gate spearmen assigned when player navigates within proximity
	Prefab_DoAction(MissionOMatic_FindModule("DefendInner"), "AddSGroup", sg_enemy_menatarms)
	Prefab_DoAction(MissionOMatic_FindModule("DefendEast"), "AddSGroup", sg_enemy_spearmen2)
	
