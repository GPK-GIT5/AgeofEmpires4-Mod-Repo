	return recipe
end

-- Setup Challenge Mission
function ChallengeMission_SetupChallenge()
	
	-- For every player
	for i, player in pairs(PLAYERS) do
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			
			-- Add a challenge table to player table
			player._challenge = {
				-- Add victory objective variable
				hasObjectiveVictory = false,

				-- Add sub objective variable
				hasObjectiveSub1 = false,
				-- Add sub objective variable
				hasObjectiveSub2 = false,
				-- Add sub objective variable
				hasObjectiveSub3 = false,
				
				-- Add KPI objective variable
				hasKpiObjective = false,
				-- Add current benchmark
				currentBenchmark = nil,
				-- Add timer variable
				timer = string.format("challengeTimer_%d", player.index),
				-- Store timer start time (relative to World_GetGameTime)
				startTime = World_GetGameTime(),
				-- Store completion time
				completionTime = nil,
				-- Stores number of key buildings destroyed
				conquestProgress = 0,
				-- Get Capital Town Center
				enemyCapital = EGroup_GetEntityAt(enemy_capital, 1),
				-- Get Landmarks
				enemyLandmark1 = EGroup_GetEntityAt(enemy_landmark1, 1),
				enemyLandmark2 = EGroup_GetEntityAt(enemy_landmark2, 1)
			}

			-- Set artificial pop cap
			Player_SetMaxPopulation(player.id, CT_Personnel, 100)
			
			-- Hide Building Scuttle
			Player_SetAbilityAvailability(player.id, BP_GetAbilityBlueprint("core_building_scuttle"), ITEM_REMOVED)
			-- Hide Toggle Scholar in Madrasa
			Player_SetAbilityAvailability(player.id, BP_GetAbilityBlueprint("toggle_spawn_hold_sul"), ITEM_REMOVED)
			
			-- Hide infantry wall construction
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_defense_palisade_sul"), ITEM_REMOVED)
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_defense_palisade_gate_sul"), ITEM_REMOVED)
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_defense_wall_sul"), ITEM_REMOVED)
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_defense_tower_sul"), ITEM_REMOVED)
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_defense_wall_gate_sul"), ITEM_REMOVED)
			
			-- Grab player's Entities
			local playerEntities = Player_GetEntities(player.id)
			-- Filter 
			EGroup_Filter(playerEntities, BP_GetEntityBlueprint("starting_position_no_town_center"), FILTER_REMOVE)
			-- Set Player Production Speed Modifier (2 = 2x as fast)
			local productionSpeedFactor = 10
			
			-- Function that switches the owner an Entity given the parameters provided by EGroup_ForEach
			local _SetProductionSpeed = function(gid, idx, eid)
				
				-- Modify Production/Research Speed
				Modifier_ApplyToEntity(Modifier_Create(MAT_Entity, "production_speed_modifier", MUT_Multiplication, false, productionSpeedFactor, nil), eid, 0.0)
				
			end
			
			-- For every Entity
			EGroup_ForEach(playerEntities, _SetProductionSpeed) 
			
			-- Reveal Conquest buildings
			FOW_PlayerRevealArea(player.id, Entity_GetPosition(player._challenge.enemyCapital), 20, -1)
			FOW_PlayerRevealArea(player.id, Entity_GetPosition(player._challenge.enemyLandmark1), 20, -1)
			FOW_PlayerRevealArea(player.id, Entity_GetPosition(player._challenge.enemyLandmark2), 20, -1)
			
		end
	end
end

-- Initialize Additional Starting Units
function ChallengeMission_InitStartingUnits()

	-- Get unit blueprints
	local sbp_manatarms_sul = BP_GetSquadBlueprint("unit_manatarms_3_sul")
	local sbp_archer_sul = BP_GetSquadBlueprint("unit_archer_3_sul")
	local sbp_scout_sul = BP_GetSquadBlueprint("unit_scout_1_sul")
	local sbp_warelephant_sul = BP_GetSquadBlueprint("unit_war_elephant_3_sul")
	local sbp_monk_sul = BP_GetSquadBlueprint("unit_monk_2_sul")
	local sbp_spearman_sul = BP_GetSquadBlueprint("unit_spearman_3_sul")
	--[[ PLAYER UNITS ]]--
	
	-- Create SGroups
	sg_player_menatarms1 = SGroup_CreateIfNotFound("sg_player_menatarms1")
	sg_player_spearmen1 = SGroup_CreateIfNotFound("sg_player_spearmen1")
	sg_player_archers1 = SGroup_CreateIfNotFound("sg_player_archers1")
	sg_player_scouts1 = SGroup_CreateIfNotFound("sg_player_scouts1")
	sg_player_warelephants1 = SGroup_CreateIfNotFound("sg_player_warelephants1")
	sg_player_monks1 = SGroup_CreateIfNotFound("sg_player_monks1")
	
	-- Spawn units
	UnitEntry_DeploySquads(localPlayer, sg_player_menatarms1, {{sbp = sbp_manatarms_sul, numSquads = 20 }}, mkr_player_menatarms1_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_player_spearmen1, {{sbp = sbp_spearman_sul, numSquads = 10 }}, mkr_player_menatarms2_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_player_archers1, {{sbp = sbp_archer_sul, numSquads = 10 }}, mkr_player_menatarms2_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_player_scouts1, {{sbp = sbp_scout_sul, numSquads = 3 }}, mkr_player_scouts1_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_player_warelephants1, {{sbp = sbp_warelephant_sul, numSquads = 2 }}, mkr_player_warelephants1_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_player_monks1, {{sbp = sbp_monk_sul, numSquads = 2 }}, mkr_player_scholars1_spawn)
	
	-- Assign monks to Madrasa
	LocalCommand_SquadEntityLoad(localPlayer, sg_player_monks1, SCMD_Load, eg_player_madrasa, false, false)
	
	-- Set rally points for player production buildings
	EGroup_SetRallyPoint(eg_player_siegeworkshop1, mkr_player_siege1_rally)
	EGroup_SetRallyPoint(eg_player_siegeworkshop2, mkr_player_siege2_rally)
	
	--[[ ENEMY UNITS ]]--

	-- Get unit blueprints
	local sbp_villager_hre = BP_GetSquadBlueprint("unit_villager_1_hre")
	local sbp_manatarms_hre = BP_GetSquadBlueprint("unit_manatarms_3_hre")
	local sbp_spearman_hre = BP_GetSquadBlueprint("unit_spearman_3_hre")
	local sbp_knight_hre = BP_GetSquadBlueprint("unit_knight_3_hre")
	local sbp_archer_hre = BP_GetSquadBlueprint("unit_archer_3_hre")
	
	-- Create SGroups
	sg_enemy_menatarms = SGroup_CreateIfNotFound("sg_enemy_menatarms")
	sg_enemy_spearmen1 = SGroup_CreateIfNotFound("sg_enemy_spearmen1")
	sg_enemy_spearmen2 = SGroup_CreateIfNotFound("sg_enemy_spearmen2")
	sg_enemy_knights = SGroup_CreateIfNotFound("sg_enemy_knights")
	sg_enemy_archers01 = SGroup_CreateIfNotFound("sg_enemy_archers01")
	sg_enemy_archers02 = SGroup_CreateIfNotFound("sg_enemy_archers02")
	sg_enemy_archers03 = SGroup_CreateIfNotFound("sg_enemy_archers03")
	sg_enemy_archers04 = SGroup_CreateIfNotFound("sg_enemy_archers04")
	sg_enemy_archers05 = SGroup_CreateIfNotFound("sg_enemy_archers05")
	sg_enemy_archers06 = SGroup_CreateIfNotFound("sg_enemy_archers06")
	sg_enemy_archers07 = SGroup_CreateIfNotFound("sg_enemy_archers07")
	sg_enemy_archers08 = SGroup_CreateIfNotFound("sg_enemy_archers08")
	sg_enemy_archers09 = SGroup_CreateIfNotFound("sg_enemy_archers09")
	sg_enemy_archers10 = SGroup_CreateIfNotFound("sg_enemy_archers10")
	sg_enemy_archers11 = SGroup_CreateIfNotFound("sg_enemy_archers11")
	sg_enemy_archers12 = SGroup_CreateIfNotFound("sg_enemy_archers12")
	sg_enemy_archers13 = SGroup_CreateIfNotFound("sg_enemy_archers13")
	sg_enemy_archers14 = SGroup_CreateIfNotFound("sg_enemy_archers14")
	sg_enemy_archers15 = SGroup_CreateIfNotFound("sg_enemy_archers15")
	sg_enemy_archers16 = SGroup_CreateIfNotFound("sg_enemy_archers16")
	sg_enemy_archers17 = SGroup_CreateIfNotFound("sg_enemy_archers17")
	sg_enemy_archers18 = SGroup_CreateIfNotFound("sg_enemy_archers18")
	
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_menatarms, {{sbp = sbp_manatarms_hre, numSquads = 8 }}, mkr_enemy_menatarms1_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_spearmen1, {{sbp = sbp_spearman_hre, numSquads = 14 }}, mkr_enemy_spearmen1_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_spearmen2, {{sbp = sbp_spearman_hre, numSquads = 18 }}, mkr_enemy_spearmen2_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_knights, {{sbp = sbp_knight_hre, numSquads = 8 }}, mkr_enemy_knights1_spawn)
	
	--sg_enemy_archers01 on left corner of base
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers01, {{sbp = sbp_archer_hre, numSquads = 6 }}, mkr_enemy_archers01_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers02, {{sbp = sbp_archer_hre, numSquads = 2 }}, mkr_enemy_archers02_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers03, {{sbp = sbp_archer_hre, numSquads = 2 }}, mkr_enemy_archers03_spawn)
	--sg_enemy_archers04 on left flank near gate
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers04, {{sbp = sbp_archer_hre, numSquads = 6 }}, mkr_enemy_archers04_spawn)
	--sg_enemy_archers05 on left side of gate
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers05, {{sbp = sbp_archer_hre, numSquads = 7 }}, mkr_enemy_archers05_spawn)
	--sg_enemy_archers06 on right side of gate
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers06, {{sbp = sbp_archer_hre, numSquads = 7 }}, mkr_enemy_archers06_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers07, {{sbp = sbp_archer_hre, numSquads = 1 }}, mkr_enemy_archers07_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers08, {{sbp = sbp_archer_hre, numSquads = 1 }}, mkr_enemy_archers08_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers09, {{sbp = sbp_archer_hre, numSquads = 2 }}, mkr_enemy_archers09_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers10, {{sbp = sbp_archer_hre, numSquads = 2 }}, mkr_enemy_archers10_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers11, {{sbp = sbp_archer_hre, numSquads = 2 }}, mkr_enemy_archers11_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers12, {{sbp = sbp_archer_hre, numSquads = 2 }}, mkr_enemy_archers12_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers13, {{sbp = sbp_archer_hre, numSquads = 2 }}, mkr_enemy_archers13_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers14, {{sbp = sbp_archer_hre, numSquads = 2 }}, mkr_enemy_archers14_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers15, {{sbp = sbp_archer_hre, numSquads = 2 }}, mkr_enemy_archers15_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers16, {{sbp = sbp_archer_hre, numSquads = 2 }}, mkr_enemy_archers16_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers17, {{sbp = sbp_archer_hre, numSquads = 2 }}, mkr_enemy_archers17_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemy_archers18, {{sbp = sbp_archer_hre, numSquads = 2 }}, mkr_enemy_archers18_spawn)
	
end

-- Initialize starting upgrades
function ChallengeMission_InitStartingUpgrades()
	
	-- Get Upgrades
	local bp_siege_engineers = BP_GetUpgradeBlueprint("upgrade_siege_engineers_sul")
	local bp_boiling_oil = BP_GetUpgradeBlueprint("upgrade_tech_university_murder_holes_4")
	local bp_archer_3 = BP_GetUpgradeBlueprint("upgrade_unit_archer_3")
	local bp_superior_transport_construction = BP_GetUpgradeBlueprint("upgrade_transport_construction_speed_sul")
	
	-- Add Local Player Upgrades
	Player_CompleteUpgrade(localPlayer, bp_siege_engineers)
	Player_CompleteUpgrade(localPlayer, bp_archer_3)
	Player_CompleteUpgrade(localPlayer, bp_superior_transport_construction)
	-- Add Enemy Player Upgrades
	Player_CompleteUpgrade(enemyPlayer, bp_boiling_oil)
	Player_CompleteUpgrade(enemyPlayer, bp_archer_3)
	
	-- Upgrade enemy towers
	local eg_towers = Player_GetEntities(enemyPlayer)
	EGroup_Filter(eg_towers, "tower", FILTER_KEEP)
	Cmd_InstantUpgrade(eg_towers, UPG.COMMON.UPGRADE_TOWER_SPRINGALD)
	
end

