-- Prepares the intro shots.
function BasicCombat_PreIntro_Setup_Scenes()
	
	sg_preintro_ally_first_spearmen = SGroup_CreateIfNotFound("sg_preintro_ally_first_spearmen")
	sg_preintro_ally_second_spearmen = SGroup_CreateIfNotFound("sg_preintro_ally_second_spearmen")
	sg_preintro_ally_second_horsemen = SGroup_CreateIfNotFound("sg_preintro_ally_second_horsemen")
	sg_preintro_player_first_archers = SGroup_CreateIfNotFound("sg_preintro_player_first_archers")
	sg_preintro_ally_villagers = SGroup_CreateIfNotFound("sg_preintro_ally_villagers")
	sg_preintro_player_first_spearmen = SGroup_CreateIfNotFound("sg_preintro_player_first_spearmen")
	sg_preintro_enemy_first_horsemen = SGroup_CreateIfNotFound("sg_preintro_enemy_first_horsemen")
	sg_preintro_player_second_spearmen = SGroup_CreateIfNotFound("sg_preintro_player_second_spearmen")
	sg_preintro_enemy_first_archers = SGroup_CreateIfNotFound("sg_preintro_enemy_first_archers")
	sg_preintro_player_third_spearmen = SGroup_CreateIfNotFound("sg_preintro_player_third_spearmen")
	sg_preintro_enemy_first_spearmen = SGroup_CreateIfNotFound("sg_preintro_enemy_first_spearmen")
	sg_preintro_player_second_archers = SGroup_CreateIfNotFound("sg_preintro_player_second_archers")
	sg_preintro_enemy_second_horsemen = SGroup_CreateIfNotFound("sg_preintro_enemy_second_horsemen")
				
end

-- Sets up the first shot of the intro. Shows village life.
function BasicCombat_PreIntro_Shot01_Units()
	
	-- Deploy units
	local units = {
		{type = "scar_villager", numSquads = 4, spawn = mkr_preintro_01_villager_spawn_1, destination = mkr_preintro_01_villager_direction_1},
		{type = "scar_villager", numSquads = 2, spawn = mkr_preintro_01_villager_spawn_2, destination = mkr_preintro_01_villager_direction_2},
		{type = "scar_villager", numSquads = 1, spawn = mkr_preintro_01_villager_spawn_3, destination = mkr_preintro_01_villager_direction_3},
		{type = "scar_villager", numSquads = 2, spawn = mkr_preintro_01_villager_spawn_4, destination = mkr_preintro_01_villager_direction_4},
	}
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_ally_villagers, units)
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_ally_first_spearmen, {type = "scar_spearman", numSquads = 5 }, mkr_preintro_01_player_spearmen_spawn_1)	
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_ally_second_spearmen, {type = "scar_archer", numSquads = 3 }, mkr_preintro_01_player_spearmen_spawn_2)
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_ally_second_horsemen, {type = "scar_horseman", numSquads = 3 }, mkr_preintro_01_player_horsemen_rally_4)	

	SGroup_EnableCheering(sg_preintro_ally_villagers, true, 20)
		
	Cmd_FormationMove(sg_preintro_ally_first_spearmen, mkr_preintro_01_player_spearmen_rally_1, true, false)
	Cmd_FormationMove(sg_preintro_ally_first_spearmen, mkr_preintro_01_player_spearmen_rally_2, true, false)
	Cmd_FormationMove(sg_preintro_ally_first_spearmen, mkr_preintro_01_player_spearmen_rally_3, true, false)
	Cmd_FormationMove(sg_preintro_ally_second_spearmen, mkr_preintro_01_player_spearmen_rally_4, true, false)
	
	Rule_AddOneShot(BasicCombat_PreIntro_Shot01_Train_Archer, 3)
	
end

function BasicCombat_PreIntro_Shot01_Train_Archer()
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_player_first_archers, {type = "scar_archer", numSquads = 1 }, mkr_preintro_01_archers_spawn)
	Cmd_Move(sg_preintro_player_first_archers, mkr_preintro_01_archers_direction, false)
end

-- Sets up the second shot of the intro. Shows spearmen fighting horsemen.
function BasicCombat_PreIntro_Shot02_Units()
	
	-- Deploy units
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_first_spearmen, {type = "scar_spearman", numSquads = 20 }, mkr_preintro_02_player_spearmen_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_enemy_first_horsemen, {type = "scar_horseman", numSquads = 15 }, mkr_preintro_02_enemy_horsemen_spawn)
	
	Cmd_Ability(sg_preintro_player_first_spearmen, BP_GetAbilityBlueprint("core_formation_line"))
	
	Cmd_FormationMove(sg_preintro_player_first_spearmen, mkr_preintro_02_player_spearmen_direction, true, false)
	--Cmd_HoldPosition(sg_preintro_player_first_spearmen,mkr_preintro_02_player_spearmen_direction,false)
	--Cmd_Ability(sg_preintro_player_first_spearmen, BP_GetAbilityBlueprint("core_formation_spread"))
	
	Rule_AddOneShot(BasicCombat_PreIntro_Shot02_Cavalry_Charge, 0.5)	
	
end

function BasicCombat_PreIntro_Shot02_Cavalry_Charge()
	
	Cmd_Ability(sg_preintro_enemy_first_horsemen, BP_GetAbilityBlueprint("core_formation_wedge"))
	
	Cmd_FormationMove(sg_preintro_enemy_first_horsemen, mkr_preintro_02_enemy_horsemen_rally, true, false)
	
	Cmd_FormationAttackMove(sg_preintro_enemy_first_horsemen, mkr_preintro_02_enemy_horsemen_attack, true, false)
end

-- Sets up the third shot of the intro. Shows archers ambushing spearmen.
function BasicCombat_PreIntro_Shot03_Units()
	
	-- Deploy units
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_player_second_spearmen, {type = "scar_spearman", numSquads = 10 }, mkr_preintro_03_enemy_spearmen_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_preintro_enemy_first_archers, {type = "scar_archer", numSquads = 20 }, mkr_preintro_03_player_archers_spawn)	
	
	Cmd_Ability(sg_preintro_enemy_first_archers, BP_GetAbilityBlueprint("core_formation_line"))
	
	Cmd_FormationAttackMove(sg_preintro_player_second_spearmen, mkr_preintro_03_enemy_spearmen_rally, true, false)	
	
	Rule_AddOneShot(BasicCombat_PreIntro_Shot03_Archer_Ambush, 2.5)
			
end

function BasicCombat_PreIntro_Shot03_Archer_Ambush()
	Cmd_FormationAttackMove(sg_preintro_enemy_first_archers, mkr_preintro_03_player_archers_direction, true, false)

	Rule_AddInterval(BasicCombat_PreIntro_Shot03_Archer_Retreat, .5)
end

--retreat half of the archers, demonstrating micro potential
function BasicCombat_PreIntro_Shot03_Archer_Retreat()
	
	if(sg_preintro_enemy_first_archers ~= nil) then
		if(SGroup_CountSpawned(sg_preintro_enemy_first_archers) > 0) then
			
			if(SGroup_IsUnderAttack(sg_preintro_enemy_first_archers, ANY, 3)) then
				
				--split group in half
				sg_preintro_retreating_archers = SGroup_CreateIfNotFound("sg_preintro_retreating_archers")
				
				local archersCount = SGroup_CountSpawned(sg_preintro_enemy_first_archers) / 2
				
				while(archersCount > 1) do
					--find squad closest to the enemy
					local closestSquadIndex = 1
					local closestDist = -1
					for i = 1, SGroup_Count(sg_preintro_enemy_first_archers) do
						
						local squad = SGroup_GetSquadAt(sg_preintro_enemy_first_archers, i)
						local squadDist = Util_GetDistance(squad, mkr_preintro_03_enemy_spearmen_spawn)
						if(squadDist < closestDist or closestDist == -1) then
							closestDist = squadDist
							closestSquadIndex = i
						end
					end
					if(closestDist > -1) then
						local squad = SGroup_GetSquadAt(sg_preintro_enemy_first_archers, closestSquadIndex)
						SGroup_Add(sg_preintro_retreating_archers, squad)
						SGroup_Remove(sg_preintro_enemy_first_archers, squad)
						archersCount = archersCount - 1
					else
						archersCount = 0
					end
				end
				
				--retreat the archers
				if(SGroup_CountSpawned(sg_preintro_retreating_archers) > 0) then
					
					Cmd_FormationMove(sg_preintro_retreating_archers, mkr_preintro_03_player_archers_retreat, false)
				end
				Rule_RemoveMe()
			end
		end
	end
end

-- Sets up the fourth shot of the intro. Shows spearmen fighting spearmen, with archers joining the fight and then a horseman charge from a previous hidden location.
function BasicCombat_PreIntro_Shot04_Units()
	
	-- Deploy units
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_enemy_first_spearmen, {type = "scar_spearman", numSquads = 25 }, mkr_preintro_04_enemy_spearmen_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_third_spearmen, {type = "scar_spearman", numSquads = 30 }, mkr_preintro_04_player_spearmen_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_player_second_archers, {type = "scar_archer", numSquads = 15 }, mkr_preintro_04_enemy_archers_spawn)	
	UnitEntry_DeploySquads(localPlayer, sg_preintro_enemy_second_horsemen, {type = "scar_horseman", numSquads = 20 }, mkr_preintro_04_player_horsemen_spawn)	
	
	
	Cmd_Ability(sg_preintro_player_third_spearmen, BP_GetAbilityBlueprint("core_formation_line"))
	Cmd_Ability(sg_preintro_enemy_first_spearmen, BP_GetAbilityBlueprint("core_formation_line"))
	
	Cmd_FormationMove(sg_preintro_enemy_first_spearmen, mkr_preintro_04_enemy_spearmen_rally, false)
	Cmd_FormationMove(sg_preintro_player_third_spearmen, mkr_preintro_04_player_spearmen_rally, false)
	
	Cmd_FormationAttackMove(sg_preintro_player_third_spearmen, mkr_preintro_04_enemy_spearmen_spawn, true)
	Cmd_FormationAttackMove(sg_preintro_enemy_first_spearmen, mkr_preintro_04_player_spearmen_spawn, true)
	
	--Cmd_HoldPosition()
	Cmd_Ability(sg_preintro_player_second_archers, 	BP_GetAbilityBlueprint("core_formation_spread"))
	Cmd_FormationMove(sg_preintro_player_second_archers, mkr_preintro_04_enemy_archers_spawn, false)
	
	Rule_AddOneShot(BasicCombat_PreIntro_Shot04_Archer_Attack, 1)
	Rule_AddOneShot(BasicCombat_PreIntro_Shot04_Cavalry_Charge, 0)

end

function BasicCombat_PreIntro_Shot04_Archer_Attack()
	Cmd_FormationAttackMove(sg_preintro_player_second_archers, mkr_preintro_04_enemy_archers_attack)
end

function BasicCombat_PreIntro_Shot04_Cavalry_Charge()
	Cmd_FormationAttackMove(sg_preintro_enemy_second_horsemen, mkr_preintro_04_player_horsemen_attack)
end


-- Sets up the fifth shot of the intro. No actions?
function BasicCombat_PreIntro_Shot05_Units()
		
	
end

-----------------------------------------------------------------------
-- Clean Up
-----------------------------------------------------------------------

-- Cleans up all units and buildings from the pre-intro
function BasicCombat_PreIntro_Clean_Scenes()
	
	Rule_Remove(BasicCombat_PreIntro_Shot01_Train_Archer)
	Rule_Remove(BasicCombat_PreIntro_Shot02_Cavalry_Charge)
	Rule_Remove(BasicCombat_PreIntro_Shot03_Archer_Ambush)
	Rule_Remove(BasicCombat_PreIntro_Shot04_Archer_Attack)
	Rule_Remove(BasicCombat_PreIntro_Shot04_Cavalry_Charge)
			
	-- Delete all village and enemy squads
	Player_GetAll(enemyPlayer)
	SGroup_DestroyAllSquads(sg_allsquads)
	Player_GetAll(villagePlayer)
	SGroup_DestroyAllSquads(sg_allsquads)
	Player_GetAll(localPlayer)
	SGroup_DestroyAllSquads(sg_allsquads)
	
end

