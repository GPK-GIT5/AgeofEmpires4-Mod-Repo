-- Prepares the intro shots.
function AdvancedCombat_PreIntro_Setup_Scenes()
	
	sg_preintro_01_crossbowmen1 = SGroup_CreateIfNotFound("sg_preintro_01_crossbowmen1")
	sg_preintro_01_crossbowmen2 = SGroup_CreateIfNotFound("sg_preintro_01_crossbowmen2")
	sg_preintro_01_crossbowmen3 = SGroup_CreateIfNotFound("sg_preintro_01_crossbowmen3")
	sg_preintro_01_crossbowmen_target1 = SGroup_CreateIfNotFound("sg_preintro_01_crossbowmen_target1")
	sg_preintro_01_crossbowmen_target2 = SGroup_CreateIfNotFound("sg_preintro_01_crossbowmen_target2")
	sg_preintro_01_crossbowmen_target3 = SGroup_CreateIfNotFound("sg_preintro_01_crossbowmen_target3")
	sg_preintro_01_knights = SGroup_CreateIfNotFound("sg_preintro_01_knights")
	sg_preintro_01_knights2 = SGroup_CreateIfNotFound("sg_preintro_01_knights2")
	sg_preintro_01_menatarms1 = SGroup_CreateIfNotFound("sg_preintro_01_menatarms1")
	
	sg_preintro_02_menatarms1 = SGroup_CreateIfNotFound("sg_preintro_02_menatarms1")
	sg_preintro_02_menatarms2 = SGroup_CreateIfNotFound("sg_preintro_02_menatarms2")
	sg_preintro_02_spearmen1 = SGroup_CreateIfNotFound("sg_preintro_02_spearmen1")
	sg_preintro_02_archers1 = SGroup_CreateIfNotFound("sg_preintro_02_archers1")
	sg_preintro_02_horsemen1 = SGroup_CreateIfNotFound("sg_preintro_02_horsemen1")
	
	sg_preintro_03_crossbowmen_Upper = SGroup_CreateIfNotFound("sg_preintro_03_crossbowmen_Upper")
	sg_preintro_03_crossbowmen_Lower = SGroup_CreateIfNotFound("sg_preintro_03_crossbowmen_Lower")
	sg_preintro_03_menatarms1 = SGroup_CreateIfNotFound("sg_preintro_03_menatarms1")
	
	sg_preintro_04_knights = SGroup_CreateIfNotFound("sg_preintro_04_knights")
	sg_preintro_04_crossbowmen = SGroup_CreateIfNotFound("sg_preintro_04_crossbowmen")
	sg_preintro_04_spearmen = SGroup_CreateIfNotFound("sg_preintro_04_spearmen")
	
	sg_preintro_05_knights = SGroup_CreateIfNotFound("sg_preintro_05_knights")
	sg_preintro_05_knights1 = SGroup_CreateIfNotFound("sg_preintro_05_knights1")
	sg_preintro_05_knights2 = SGroup_CreateIfNotFound("sg_preintro_05_knights2")
	sg_preintro_05_menatarms = SGroup_CreateIfNotFound("sg_preintro_05_menatarms")
	sg_preintro_05_menatarms2 = SGroup_CreateIfNotFound("sg_preintro_05_menatarms2")
	
	sg_preintro_06_enemy_knights = SGroup_CreateIfNotFound("sg_preintro_06_enemy_knights")
	sg_preintro_06_enemy_menatarms = SGroup_CreateIfNotFound("sg_preintro_06_enemy_menatarms")
	sg_preintro_06_enemy_menatarms2 = SGroup_CreateIfNotFound("sg_preintro_06_enemy_menatarms2")
	
	sg_preintro_06_knights = SGroup_CreateIfNotFound("sg_preintro_06_knights")
	sg_preintro_06_knights2 = SGroup_CreateIfNotFound("sg_preintro_06_knights2")
	sg_preintro_06_crossbowmen = SGroup_CreateIfNotFound("sg_preintro_06_crossbowmen")
	sg_preintro_06_spearmen1 = SGroup_CreateIfNotFound("sg_preintro_06_spearmen1")
	sg_preintro_06_spearmen2 = SGroup_CreateIfNotFound("sg_preintro_06_spearmen2")
	sg_preintro_06_spearmen_combined = SGroup_CreateIfNotFound("sg_preintro_06_spearmen_combined")
	
end

-- Sets up the first shot of the intro. Shows village life.
function AdvancedCombat_PreIntro_Shot01_Units()
	
	local sbp_crossbowman_hre = BP_GetSquadBlueprint("unit_crossbowman_3_hre")
	local sbp_spearman_hre = BP_GetSquadBlueprint("unit_spearman_3_hre")
	
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_01_crossbowmen1, {sbp = sbp_crossbowman_hre, numSquads = 3 }, mkr_preintro_01_player_heavy_ranged_spawn_01)
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_01_crossbowmen2, {sbp = sbp_crossbowman_hre, numSquads = 3 }, mkr_preintro_01_player_heavy_ranged_spawn_02)
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_01_crossbowmen3, {sbp = sbp_crossbowman_hre, numSquads = 3 }, mkr_preintro_01_player_heavy_ranged_spawn_03)
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_01_crossbowmen_target1, {sbp = sbp_spearman_hre, numSquads = 1 }, mkr_crossbowman_range)
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_01_crossbowmen_target2, {sbp = sbp_spearman_hre, numSquads = 1 }, mkr_preintro_01_archery_target_corner)
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_01_crossbowmen_target3, {sbp = sbp_spearman_hre, numSquads = 1 }, mkr_archer_range)
	
	SGroup_SetInvulnerable(sg_preintro_01_crossbowmen_target1, true, -1)
	SGroup_SetInvulnerable(sg_preintro_01_crossbowmen_target2, true, -1)
	SGroup_SetInvulnerable(sg_preintro_01_crossbowmen_target3, true, -1)
	--hide this unit from view
	SGroup_Hide(sg_preintro_01_crossbowmen_target1, true)
	SGroup_Hide(sg_preintro_01_crossbowmen_target2, true)
	SGroup_Hide(sg_preintro_01_crossbowmen_target3, true)
	--make sure it doesn't move
	Modify_UnitSpeed(sg_preintro_01_crossbowmen_target1, 0)
	Modify_UnitSpeed(sg_preintro_01_crossbowmen_target2, 0)
	Modify_UnitSpeed(sg_preintro_01_crossbowmen_target3, 0)
	
	local leftArcPos = Util_GetPosition(mkr_preintro_01_player_heavy_ranged_rally_01)
	local rightArcPos = Util_GetPosition(mkr_preintro_01_player_heavy_ranged_rally_02)
	ArcFormation(leftArcPos, rightArcPos, sg_preintro_01_crossbowmen1, 0, false, 0)
	
	leftArcPos = Util_GetPosition(mkr_preintro_01_player_heavy_ranged_rally_03)
	rightArcPos = Util_GetPosition(mkr_preintro_01_player_heavy_ranged_rally_04)
	ArcFormation(leftArcPos, rightArcPos, sg_preintro_01_crossbowmen2, 0, false, 0)
	
	leftArcPos = Util_GetPosition(mkr_preintro_01_player_heavy_ranged_rally_05)
	rightArcPos = Util_GetPosition(mkr_preintro_01_player_heavy_ranged_rally_06)
	ArcFormation(leftArcPos, rightArcPos, sg_preintro_01_crossbowmen3, 0, false, 0)
	
	Cmd_Attack(sg_preintro_01_crossbowmen1, sg_preintro_01_crossbowmen_target1, true)
	Cmd_Attack(sg_preintro_01_crossbowmen2, sg_preintro_01_crossbowmen_target2, true)
	Cmd_Attack(sg_preintro_01_crossbowmen3, sg_preintro_01_crossbowmen_target3, true)
	
	Rule_AddOneShot(EarlySiege_PreIntro_Shot01_Build_MenAtArms, 0)
	Rule_AddOneShot(EarlySiege_PreIntro_Shot01_Build_Knights, 5)
	Rule_AddOneShot(EarlySiege_PreIntro_Shot01_Move_Crossbowmen, 10)
end

function EarlySiege_PreIntro_Shot01_Move_Crossbowmen()
	
	Cmd_Move(sg_preintro_01_crossbowmen2, mkr_preintro_01_player_heavy_ranged_rally_08, false)
	
	local leftArcPos = Util_GetPosition(mkr_preintro_01_player_heavy_ranged_rally_09)
	local rightArcPos = Util_GetPosition(mkr_preintro_01_player_heavy_ranged_rally_07)
	ArcFormation(leftArcPos, rightArcPos, sg_preintro_01_crossbowmen1, 0, false, 0)
	
	Cmd_Move(sg_preintro_01_crossbowmen3, mkr_preintro_01_player_heavy_ranged_rally_07, false)
	
	Rule_AddOneShot(EarlySiege_PreIntro_Shot01_Move_Crossbowmen2, 1.5)
end

function EarlySiege_PreIntro_Shot01_Move_Crossbowmen2()
	
	SGroup_AddGroup(sg_preintro_01_crossbowmen1, sg_preintro_01_crossbowmen2)
	SGroup_AddGroup(sg_preintro_01_crossbowmen1, sg_preintro_01_crossbowmen3)
	
	Cmd_Ability(sg_preintro_01_crossbowmen1, BP_GetAbilityBlueprint("core_formation_spread"))
	Cmd_FormationMove(sg_preintro_01_crossbowmen1, mkr_preintro_01_player_heavy_ranged_rally_07, false, false, mkr_preintro_01_player_heavy_ranged_facing_07)
	
end

function EarlySiege_PreIntro_Shot01_Build_MenAtArms()
	
	local sbp_manatarms_hre = BP_GetSquadBlueprint("unit_manatarms_3_hre")
	
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_01_menatarms1, {sbp = sbp_manatarms_hre, numSquads = 10 }, mkr_preintro_01_player_heavy_infantry_spawn_01)
	
	Cmd_FormationMove(sg_preintro_01_menatarms1, mkr_preintro_01_player_heavy_infantry_rally_01, false)
	Cmd_FormationMove(sg_preintro_01_menatarms1, mkr_preintro_01_player_heavy_infantry_rally_02, true)
	Cmd_FormationMove(sg_preintro_01_menatarms1, mkr_preintro_01_player_heavy_cavalry_rally_02, true)
	
	Rule_AddInterval(EarlySiege_PreIntro_Shot01_Move_MenAtArms, .25)
end

function EarlySiege_PreIntro_Shot01_Build_Knights()
	
	local sbp_knight_hre = BP_GetSquadBlueprint("unit_knight_3_hre")
	
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_01_knights, {sbp = sbp_knight_hre, numSquads = 3 }, mkr_preintro_01_player_heavy_cavalry_spawn)
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_01_knights2, {sbp = sbp_knight_hre, numSquads = 3 }, mkr_preintro_01_player_heavy_cavalry_spawn_02)
	
	knightSpeedModifier = Modify_UnitSpeed(sg_preintro_01_knights, .7)
	knightSpeedModifier2 = Modify_UnitSpeed(sg_preintro_01_knights2, .7)
	
	Cmd_FormationMove(sg_preintro_01_knights, mkr_preintro_01_player_heavy_cavalry_rally_01, false)
	Cmd_FormationMove(sg_preintro_01_knights2, mkr_preintro_01_player_heavy_cavalry_rally_01, false)
	Rule_AddInterval(EarlySiege_PreIntro_Shot01_Turn_Knights, .25)
	Rule_AddInterval(EarlySiege_PreIntro_Shot01_SpeedUp_Knights, .25)
	Rule_AddInterval(EarlySiege_PreIntro_Shot01_Turn_Knights2, .25)
	Rule_AddInterval(EarlySiege_PreIntro_Shot01_SpeedUp_Knights2, .25)
	
end

function EarlySiege_PreIntro_Shot01_Turn_Knights()
	
	if(sg_preintro_01_knights ~= nil) then
		if(SGroup_Count(sg_preintro_01_knights) > 0) then
			if(Util_GetDistance(sg_preintro_01_knights, mkr_preintro_01_player_heavy_cavalry_rally_01) < 9) then
				Cmd_Move(sg_preintro_01_knights, mkr_preintro_01_player_heavy_cavalry_turn, false)
				Rule_AddOneShot(EarlySiege_PreIntro_Shot01_Turn_Knights_2, .2)
				Rule_RemoveMe()
			end
		end
	end
end

function EarlySiege_PreIntro_Shot01_Turn_Knights_2()
	
	if(sg_preintro_01_knights ~= nil) then
		if(SGroup_Count(sg_preintro_01_knights) > 0) then
			Cmd_Move(sg_preintro_01_knights, mkr_preintro_01_player_heavy_cavalry_turn_02, false)
			Rule_AddOneShot(EarlySiege_PreIntro_Shot01_Move_Knights, .25)
			Rule_RemoveMe()
		end
	end
end

function EarlySiege_PreIntro_Shot01_Move_Knights()
	
	if(sg_preintro_01_knights ~= nil) then
		if(SGroup_Count(sg_preintro_01_knights) > 0) then
			Cmd_Move(sg_preintro_01_knights, mkr_preintro_01_player_heavy_cavalry_rally_02, false)
			Cmd_Move(sg_preintro_01_knights, mkr_preintro_01_player_heavy_cavalry_rally_03, true)
				
		end
	end
end

function EarlySiege_PreIntro_Shot01_SpeedUp_Knights()
	
	if(sg_preintro_01_knights ~= nil) then
		if(SGroup_Count(sg_preintro_01_knights) > 0) then
			if(Util_GetDistance(sg_preintro_01_knights, mkr_preintro_01_player_heavy_cavalry_rally_01) < 12) then
				if(knightSpeedModifier ~= nil) then
					Modifier_Remove(knightSpeedModifier)
				end
				Rule_RemoveMe()
			end
		end
	end
end

function EarlySiege_PreIntro_Shot01_Turn_Knights2()
	
	if(sg_preintro_01_knights2 ~= nil) then
		if(SGroup_Count(sg_preintro_01_knights2) > 0) then
			if(Util_GetDistance(sg_preintro_01_knights2, mkr_preintro_01_player_heavy_cavalry_rally_01) < 9) then
				Cmd_Move(sg_preintro_01_knights2, mkr_preintro_01_player_heavy_cavalry_turn, false)
				Rule_AddOneShot(EarlySiege_PreIntro_Shot01_Turn_Knights2_2, .2)
				Rule_RemoveMe()
			end
		end
	end
end

function EarlySiege_PreIntro_Shot01_Turn_Knights2_2()
	
	if(sg_preintro_01_knights2 ~= nil) then
		if(SGroup_Count(sg_preintro_01_knights2) > 0) then
			Cmd_Move(sg_preintro_01_knights2, mkr_preintro_01_player_heavy_cavalry_turn_02, false)
			Rule_AddOneShot(EarlySiege_PreIntro_Shot01_Move_Knights2, .25)
			Rule_RemoveMe()
		end
	end
end

function EarlySiege_PreIntro_Shot01_Move_Knights2()
	
	if(sg_preintro_01_knights2 ~= nil) then
		if(SGroup_Count(sg_preintro_01_knights2) > 0) then
			Cmd_Move(sg_preintro_01_knights2, mkr_preintro_01_player_heavy_cavalry_rally_02, false)
			Cmd_Move(sg_preintro_01_knights2, mkr_preintro_01_player_heavy_cavalry_rally_03, true)
			
		end
	end
end

function EarlySiege_PreIntro_Shot01_SpeedUp_Knights2()
	
	if(sg_preintro_01_knights2 ~= nil) then
		if(SGroup_Count(sg_preintro_01_knights2) > 0) then
			if(Util_GetDistance(sg_preintro_01_knights2, mkr_preintro_01_player_heavy_cavalry_rally_01) < 12) then
				if(knightSpeedModifier2 ~= nil) then
					Modifier_Remove(knightSpeedModifier2)
				end
				Rule_RemoveMe()
			end
		end
	end
end

function EarlySiege_PreIntro_Shot01_Move_MenAtArms()
	
	if(sg_preintro_01_menatarms1 ~= nil) then
		if(SGroup_Count(sg_preintro_01_menatarms1) > 0) then
			if(Util_GetDistance(sg_preintro_01_menatarms1, mkr_preintro_01_player_heavy_infantry_rally_02) < 5) then
				
				Cmd_Move(sg_preintro_01_menatarms1, mkr_preintro_01_player_heavy_cavalry_rally_02, false)
				Rule_AddInterval(EarlySiege_PreIntro_Shot01_Move_MenAtArms2, .25)
				Rule_RemoveMe()
			end
		end
	end
end

function EarlySiege_PreIntro_Shot01_Move_MenAtArms2()
	
	if(sg_preintro_01_menatarms1 ~= nil) then
		if(SGroup_Count(sg_preintro_01_menatarms1) > 0) then
			if(Util_GetDistance(sg_preintro_01_menatarms1, mkr_preintro_01_player_heavy_cavalry_rally_02) < 7) then
				Cmd_FormationMove(sg_preintro_01_menatarms1, mkr_preintro_01_player_heavy_infantry_rally_03, false)
				Cmd_FormationMove(sg_preintro_01_menatarms1, mkr_preintro_01_player_heavy_infantry_rally_04, true)
				Rule_RemoveMe()
			end
		end
	end
end

function AdvancedCombat_PreIntro_Shot01_Cleanup()
	
	Rule_Remove(EarlySiege_PreIntro_Shot01_Build_MenAtArms)
	Rule_Remove(EarlySiege_PreIntro_Shot01_Build_Knights)
	Rule_Remove(EarlySiege_PreIntro_Shot01_Move_Knights)
	Rule_Remove(EarlySiege_PreIntro_Shot01_Move_Knights2)
	Rule_Remove(EarlySiege_PreIntro_Shot01_Move_MenAtArms)
	Rule_Remove(EarlySiege_PreIntro_Shot01_Move_MenAtArms2)
	Rule_Remove(EarlySiege_PreIntro_Shot01_Move_Crossbowmen)
	Rule_Remove(EarlySiege_PreIntro_Shot01_Move_Crossbowmen2)
	Rule_Remove(EarlySiege_PreIntro_Shot01_SpeedUp_Knights)
	Rule_Remove(EarlySiege_PreIntro_Shot01_SpeedUp_Knights2)
	Rule_Remove(EarlySiege_PreIntro_Shot01_Turn_Knights)
	Rule_Remove(EarlySiege_PreIntro_Shot01_Turn_Knights2)
	Rule_Remove(EarlySiege_PreIntro_Shot01_Turn_Knights_2)
	Rule_Remove(EarlySiege_PreIntro_Shot01_Turn_Knights2_2)
	
	if(SGroup_Exists("sg_preintro_01_crossbowmen1")) then
		SGroup_DestroyAllSquads(sg_preintro_01_crossbowmen1)
	end
	if(SGroup_Exists("sg_preintro_01_crossbowmen2")) then
		SGroup_DestroyAllSquads(sg_preintro_01_crossbowmen2)
	end
	if(SGroup_Exists("sg_preintro_01_crossbowmen3")) then
		SGroup_DestroyAllSquads(sg_preintro_01_crossbowmen3)
	end
	if(SGroup_Exists("sg_preintro_01_crossbowmen_target1")) then
		SGroup_DestroyAllSquads(sg_preintro_01_crossbowmen_target1)
	end
	if(SGroup_Exists("sg_preintro_01_crossbowmen_target2")) then
		SGroup_DestroyAllSquads(sg_preintro_01_crossbowmen_target2)
	end
	if(SGroup_Exists("sg_preintro_01_crossbowmen_target3")) then
		SGroup_DestroyAllSquads(sg_preintro_01_crossbowmen_target3)
	end
	if(SGroup_Exists("sg_preintro_01_knights")) then
		SGroup_DestroyAllSquads(sg_preintro_01_knights)
	end
	if(SGroup_Exists("sg_preintro_01_knights2")) then
		SGroup_DestroyAllSquads(sg_preintro_01_knights2)
	end
	if(SGroup_Exists("sg_preintro_01_menatarms1")) then
		SGroup_DestroyAllSquads(sg_preintro_01_menatarms1)
	end
	
end

----------

function AdvancedCombat_PreIntro_Shot02_Units()
	
	local sbp_manatarms_hre = BP_GetSquadBlueprint("unit_manatarms_3_hre")
	local sbp_spearman_abb = BP_GetSquadBlueprint("unit_spearman_3_abb")
	local sbp_archer_abb = BP_GetSquadBlueprint("unit_archer_3_abb")
	local sbp_horseman_abb = BP_GetSquadBlueprint("unit_horseman_3_abb")
	
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_02_menatarms1, {sbp = sbp_manatarms_hre, numSquads = 8 }, mkr_preintro_02_player_heavy_infantry_spawn)
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_02_menatarms2, {sbp = sbp_manatarms_hre, numSquads = 8 }, mkr_preintro_02_player_heavy_infantry_spawn_02)
	
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_02_spearmen1, {sbp = sbp_spearman_abb, numSquads = 6 }, mkr_preintro_02_enemy_spearmen_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_02_archers1, {sbp = sbp_archer_abb, numSquads = 8 }, mkr_preintro_02_enemy_archer_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_02_horsemen1, {sbp = sbp_horseman_abb, numSquads = 8 }, mkr_preintro_02_enemy_horsemen_spawn)
	
	SGroup_SetAvgHealth(sg_preintro_02_archers1, .5)
	
	for i = 1, SGroup_Count(sg_preintro_02_spearmen1) do
		local squad = SGroup_GetSquadAt(sg_preintro_02_spearmen1, i)
		Squad_SetHealth(squad, .5)
	end
	for i = 1, SGroup_Count(sg_preintro_02_horsemen1) do
		local squad = SGroup_GetSquadAt(sg_preintro_02_horsemen1, i)
		Squad_SetHealth(squad, .5)
	end
	
	Cmd_Ability(sg_preintro_02_menatarms1, BP_GetAbilityBlueprint("core_formation_spread"))
	Cmd_FormationMove(sg_preintro_02_menatarms1, mkr_preintro_02_player_heavy_infantry_rally_01, false)
	Cmd_FormationAttackMove(sg_preintro_02_menatarms1, mkr_preintro_02_player_heavy_infantry_rally_01, true)
	
	Cmd_Ability(sg_preintro_02_menatarms2, BP_GetAbilityBlueprint("core_formation_spread"))
	Cmd_FormationMove(sg_preintro_02_menatarms2, mkr_preintro_02_player_heavy_infantry_rally_02, false)
	Cmd_FormationAttackMove(sg_preintro_02_menatarms2, mkr_preintro_02_player_heavy_infantry_rally_02, true)
	
	
	Cmd_Ability(sg_preintro_02_spearmen1, BP_GetAbilityBlueprint("core_formation_spread"))
	Cmd_Ability(sg_preintro_02_archers1, BP_GetAbilityBlueprint("core_formation_spread"))
	Cmd_Ability(sg_preintro_02_horsemen1, BP_GetAbilityBlueprint("core_formation_spread"))
	Cmd_FormationMove(sg_preintro_02_spearmen1, mkr_preintro_02_player_heavy_infantry_rally_02, false)
	
	Cmd_FormationMove(sg_preintro_02_horsemen1, mkr_preintro_02_enemy_horsemen_rally, false)
	Cmd_FormationAttackMove(sg_preintro_02_spearmen1, mkr_preintro_02_player_heavy_infantry_rally_02, true)
	Cmd_FormationAttackMove(sg_preintro_02_horsemen1, mkr_preintro_02_player_heavy_infantry_rally_01, true)
	
	
	local leftArcPos = Util_GetPosition(mkr_preintro_02_enemy_archer_spawn)
	local rightArcPos = Util_GetPosition(mkr_preintro_02_enemy_archer_rally)
	ArcFormation(leftArcPos, rightArcPos, sg_preintro_02_archers1, 0, false, 0)
	
	
	Rule_AddOneShot(AdvancedCombat_PreIntro_Shot02_ArcherMove, 3)
	Rule_AddOneShot(AdvancedCombat_PreIntro_Shot02_ArcherAttack, 4.5)
end

function AdvancedCombat_PreIntro_Shot02_ArcherMove()
	Cmd_FormationMove(sg_preintro_02_archers1, mkr_preintro_02_enemy_archer_rally, false)
end

function AdvancedCombat_PreIntro_Shot02_ArcherAttack()
	Cmd_Attack(sg_preintro_02_archers1, sg_preintro_02_menatarms2, false)
end


function AdvancedCombat_PreIntro_Shot02_Cleanup()
	
	Rule_Remove(AdvancedCombat_PreIntro_Shot02_ArcherMove)
	Rule_Remove(AdvancedCombat_PreIntro_Shot02_ArcherAttack)
	
	if(SGroup_Exists("sg_preintro_02_menatarms1")) then
		SGroup_DestroyAllSquads(sg_preintro_02_menatarms1)
	end
	if(SGroup_Exists("sg_preintro_02_menatarms2")) then
		SGroup_DestroyAllSquads(sg_preintro_02_menatarms2)
	end
	if(SGroup_Exists("sg_preintro_02_spearmen1")) then
		SGroup_DestroyAllSquads(sg_preintro_02_spearmen1)
	end
	if(SGroup_Exists("sg_preintro_02_archers1")) then
		SGroup_DestroyAllSquads(sg_preintro_02_archers1)
	end
	if(SGroup_Exists("sg_preintro_02_horsemen1")) then
		SGroup_DestroyAllSquads(sg_preintro_02_horsemen1)
	end
	
end

----------

function AdvancedCombat_PreIntro_Shot03_Units()
	
	local sbp_crossbowman_hre = BP_GetSquadBlueprint("unit_crossbowman_3_hre")
	local sbp_manatarms_abb = BP_GetSquadBlueprint("unit_manatarms_3_abb")
	
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_03_crossbowmen_Upper, {sbp = sbp_crossbowman_hre, numSquads = 8 }, mkr_preintro_03_player_crossbowmen_spawn_upper)
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_03_crossbowmen_Lower, {sbp = sbp_crossbowman_hre, numSquads = 8 }, mkr_preintro_03_player_crossbowmen_spawn_lower)
	
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_03_menatarms1, {sbp = sbp_manatarms_abb, numSquads = 4 }, mkr_preintro_03_enemy_heavy_infantry_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_03_menatarms1, {sbp = sbp_manatarms_abb, numSquads = 4 }, mkr_preintro_03_enemy_heavy_infantry_spawn_02)
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_03_menatarms1, {sbp = sbp_manatarms_abb, numSquads = 8 }, mkr_preintro_03_enemy_heavy_infantry_spawn_03)
	
	SGroup_SetAvgHealth(sg_preintro_03_menatarms1, .7)
	Modify_ReceivedDamage(sg_preintro_03_crossbowmen_Upper, .5)
	Modify_ReceivedDamage(sg_preintro_03_crossbowmen_Lower, .5)
	
	if(sg_preintro_03_crossbowmen_Lower ~= nil and sg_preintro_03_menatarms1 ~= nil) then
		Cmd_Attack(sg_preintro_03_menatarms1, sg_preintro_03_crossbowmen_Lower, false)
		Cmd_Attack(sg_preintro_03_crossbowmen_Upper, sg_preintro_03_menatarms1, false)
	end
	
	Rule_AddOneShot(AdvancedCombat_PreIntro_Shot03_Start, .5)
	
	
	
end
crossbowsSplit = false
function AdvancedCombat_PreIntro_Shot03_Start()
	
	if(sg_preintro_03_crossbowmen_Lower ~= nil and sg_preintro_03_menatarms1 ~= nil) then
		Cmd_Attack(sg_preintro_03_crossbowmen_Lower, sg_preintro_03_menatarms1, false)
		
		if(sg_preintro_03_crossbowmen_Upper ~= nil and crossbowsSplit == false) then
			Cmd_Attack(sg_preintro_03_crossbowmen_Upper, sg_preintro_03_menatarms1, false)
		end
		
		
		Rule_AddInterval(AdvancedCombat_PreIntro_Shot03_Retreat_Crossbows_Start, .25)
	end
	
end


function AdvancedCombat_PreIntro_Shot03_SplitCrossbowmen()
	
	if(sg_preintro_03_crossbowmen_Upper ~= nil and sg_preintro_03_crossbowmen_Lower ~= nil and sg_preintro_03_menatarms1 ~= nil) then
		
		crossbowsSplit = true
		Cmd_Move(sg_preintro_03_crossbowmen_Upper, mkr_preintro_03_player_crossbowmen2_rally_01, false)
		Cmd_Attack(sg_preintro_03_menatarms1, sg_preintro_03_crossbowmen_Lower, false)
	end
end

function AdvancedCombat_PreIntro_Shot03_MenAtArms_SwitchTarget()
	if(sg_preintro_03_crossbowmen_Upper ~= nil and sg_preintro_03_crossbowmen_Lower ~= nil and sg_preintro_03_menatarms1 ~= nil) then
		Cmd_Attack(sg_preintro_03_menatarms1, sg_preintro_03_crossbowmen_Upper, false)
	end
end

function AdvancedCombat_PreIntro_Shot03_CrossbowmenUpper_Retreat()
	if(sg_preintro_03_crossbowmen_Upper ~= nil and sg_preintro_03_crossbowmen_Lower ~= nil and sg_preintro_03_menatarms1 ~= nil) then
		Cmd_Move(sg_preintro_03_crossbowmen_Upper, mkr_preintro_03_player_crossbowmen2_rally_02, false)
		
	end
end


--------------------------------
--------------------------------





function AdvancedCombat_PreIntro_Shot03_Retreat_Crossbows_Start()
	
	if(sg_preintro_03_crossbowmen_Lower ~= nil and sg_preintro_03_menatarms1 ~= nil) then
		if(SGroup_Count(sg_preintro_03_crossbowmen_Lower) > 0 and SGroup_Count(sg_preintro_03_menatarms1) > 0) then
			if(Util_GetDistance(sg_preintro_03_crossbowmen_Lower, sg_preintro_03_menatarms1) < 20) then
				Rule_AddOneShot(AdvancedCombat_PreIntro_Shot03_Retreat_Crossbows, 0)
				Rule_RemoveMe()
			end
		end
	end
end

lastCrossbowAttackTime = 0
crossbowTargetMarker = 1
function AdvancedCombat_PreIntro_Shot03_Retreat_Crossbows()
	local crossbowReloadTime = 1.5
	local nextWaypoint = mkr_preintro_03_player_crossbowmen_rally_01
	
	if(sg_preintro_03_crossbowmen_Lower ~= nil) then
		if(SGroup_Count(sg_preintro_03_crossbowmen_Lower) > 0 and SGroup_Count(sg_preintro_03_menatarms1) > 0) then
			if(Util_GetDistance(sg_preintro_03_crossbowmen_Lower, mkr_preintro_03_player_crossbowmen_rally_05) < 7) then
				
			else
				if(sg_preintro_03_crossbowmen_Lower ~= nil and sg_preintro_03_menatarms1 ~= nil) then
					if(Util_GetDistance(sg_preintro_03_crossbowmen_Lower, sg_preintro_03_menatarms1) < 19 or crossbowTargetMarker > 1) then
						if(Util_GetDistance(sg_preintro_03_crossbowmen_Lower, mkr_preintro_03_player_crossbowmen_rally_04) < 9) then
							
							if(crossbowTargetMarker ~= 5) then
								
								if(sg_preintro_03_crossbowmen_Upper ~= nil) then
									Cmd_Attack(sg_preintro_03_crossbowmen_Upper, sg_preintro_03_menatarms1, false)
									Rule_AddOneShot(AdvancedCombat_PreIntro_Shot03_CrossbowmenUpper_Retreat, 2)
								end
							end
							crossbowTargetMarker = 5
						elseif(Util_GetDistance(sg_preintro_03_crossbowmen_Lower, mkr_preintro_03_player_crossbowmen_rally_03) < 7) then
							
							crossbowTargetMarker = 4
						elseif(Util_GetDistance(sg_preintro_03_crossbowmen_Lower, mkr_preintro_03_player_crossbowmen_rally_02) < 7) then
							if(crossbowTargetMarker ~= 3) then
								--split off group of crossbowmen
								Rule_AddOneShot(AdvancedCombat_PreIntro_Shot03_SplitCrossbowmen, 0)
							end
							crossbowTargetMarker = 3
						elseif(Util_GetDistance(sg_preintro_03_crossbowmen_Lower, mkr_preintro_03_player_crossbowmen_rally_01) < 7) then
							if(crossbowTargetMarker ~= 2) then
							end
							crossbowTargetMarker = 2
							
						end
						
						if(crossbowTargetMarker == 5) then
							nextWaypoint = mkr_preintro_03_player_crossbowmen_rally_05
							Rule_RemoveMe()
						elseif(crossbowTargetMarker == 4) then
							nextWaypoint = mkr_preintro_03_player_crossbowmen_rally_04
							--move but don't attack
							Rule_AddOneShot(AdvancedCombat_PreIntro_Shot03_Move_Crossbows, crossbowReloadTime)
							
						elseif(crossbowTargetMarker == 3) then
							nextWaypoint = mkr_preintro_03_player_crossbowmen_rally_03
							Rule_AddOneShot(AdvancedCombat_PreIntro_Shot03_Attack_Crossbows, crossbowReloadTime)
							
						elseif(crossbowTargetMarker == 2) then
							nextWaypoint = mkr_preintro_03_player_crossbowmen_rally_02
							Rule_AddOneShot(AdvancedCombat_PreIntro_Shot03_Attack_Crossbows, crossbowReloadTime)
							
						elseif(crossbowTargetMarker == 1) then
							Rule_AddOneShot(AdvancedCombat_PreIntro_Shot03_Attack_Crossbows, crossbowReloadTime)
							
						end
						
					end
					
					--if reload time has passed, issue a new move order
					local currentTime = World_GetGameTime()
					if(currentTime > lastCrossbowAttackTime + crossbowReloadTime) then
						Cmd_Move(sg_preintro_03_crossbowmen_Lower, nextWaypoint, false)
						
						if(sg_preintro_03_crossbowmen_Upper ~= nil and crossbowsSplit == false) then
							Cmd_Move(sg_preintro_03_crossbowmen_Upper, nextWaypoint, false)
						end
						lastCrossbowAttackTime = World_GetGameTime()
					end
					
					
					if(crossbowTargetMarker == 3 or crossbowTargetMarker == 4) then
						--split off group of crossbowmen
						Cmd_Attack(sg_preintro_03_menatarms1, sg_preintro_03_crossbowmen_Lower, false)
						
					end
					if(crossbowTargetMarker == 5) then
						--split off group of crossbowmen
						AdvancedCombat_PreIntro_Shot03_MenAtArms_SwitchTarget()
						
					end
				end
			end
		end
	end
end

function AdvancedCombat_PreIntro_Shot03_Move_Crossbows()
	
	Rule_AddOneShot(AdvancedCombat_PreIntro_Shot03_Retreat_Crossbows, .7)
end

function AdvancedCombat_PreIntro_Shot03_Attack_Crossbows()
	
	if(sg_preintro_03_crossbowmen_Lower ~= nil and sg_preintro_03_menatarms1 ~= nil) then
	
		--attack with men at arms
		if(crossbowTargetMarker < 5) then
			Cmd_Attack(sg_preintro_03_menatarms1, sg_preintro_03_crossbowmen_Lower, false)
		end
		
		--attack with crossbowmen that are not under attack
		for i = 1, SGroup_Count(sg_preintro_03_crossbowmen_Lower) do
			local squad = SGroup_GetSquadAt(sg_preintro_03_crossbowmen_Lower, i)
			
			if(Squad_IsUnderAttack(squad, 2) == false) then
				if(crossbowTargetMarker < 3) then
					SGroup_Single(sg_single, squad)
					Cmd_Attack(sg_single, sg_preintro_03_menatarms1, false)
				end
			end
		end
		
		if(sg_preintro_03_crossbowmen_Upper ~= nil and crossbowsSplit == false) then
			--attack with crossbowmen that are not under attack
			for i = 1, SGroup_Count(sg_preintro_03_crossbowmen_Upper) do
				local squad = SGroup_GetSquadAt(sg_preintro_03_crossbowmen_Upper, i)
				
				if(Squad_IsUnderAttack(squad, 2) == false) then
					SGroup_Single(sg_single, squad)
					Cmd_Attack(sg_single, sg_preintro_03_menatarms1, false)
				end
			end
		end
		Rule_AddOneShot(AdvancedCombat_PreIntro_Shot03_Retreat_Crossbows, .65)
	end
end


----------



function AdvancedCombat_PreIntro_Shot03_Cleanup()

	
	Rule_Remove(AdvancedCombat_PreIntro_Shot03_Start)
	Rule_Remove(AdvancedCombat_PreIntro_Shot03_MenAtArms_SwitchTarget)
	Rule_Remove(AdvancedCombat_PreIntro_Shot03_SplitCrossbowmen)
	Rule_Remove(AdvancedCombat_PreIntro_Shot03_Retreat_Crossbows_Start)
	Rule_Remove(AdvancedCombat_PreIntro_Shot03_Retreat_Crossbows)
	Rule_Remove(AdvancedCombat_PreIntro_Shot03_Move_Crossbows)
	Rule_Remove(AdvancedCombat_PreIntro_Shot03_Attack_Crossbows)
	Rule_Remove(AdvancedCombat_PreIntro_Shot03_CrossbowmenUpper_Retreat)
	
	
	
	if(SGroup_Exists("sg_preintro_03_crossbowmen_Upper")) then
		SGroup_DestroyAllSquads(sg_preintro_03_crossbowmen_Upper)
	end
	if(SGroup_Exists("sg_preintro_03_crossbowmen_Lower")) then
		SGroup_DestroyAllSquads(sg_preintro_03_crossbowmen_Lower)
	end
	if(SGroup_Exists("sg_preintro_03_menatarms1")) then
		SGroup_DestroyAllSquads(sg_preintro_03_menatarms1)
	end
	
end

