function AdvancedCombat_PreIntro_Shot04_Units()
	
	local sbp_knight_hre = BP_GetSquadBlueprint("unit_knight_3_hre")
	local sbp_crossbowmen_abb = BP_GetSquadBlueprint("unit_crossbowman_3_abb")
	local sbp_spearmen_abb = BP_GetSquadBlueprint("unit_spearman_3_abb")
	
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_04_knights, {sbp = sbp_knight_hre, numSquads = 7 }, mkr_preintro_04_player_heavy_cavalry_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_04_crossbowmen, {sbp = sbp_crossbowmen_abb, numSquads = 12 }, mkr_preintro_04_enemy_heavy_ranged_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_04_spearmen, {sbp = sbp_spearmen_abb, numSquads = 12 }, mkr_preintro_04_enemy_spearmen_spawn)
	
	Cmd_FormationMove(sg_preintro_04_knights, mkr_preintro_04_player_heavy_cavalry_spawn, false, false, mkr_preintro_04_player_heavy_cavalry_rally_01)
	Cmd_AttackMove(sg_preintro_04_knights, mkr_preintro_04_player_heavy_cavalry_rally_01, true)
	
	Cmd_Ability(sg_preintro_04_crossbowmen, BP_GetAbilityBlueprint("core_formation_line"))
	Cmd_FormationMove(sg_preintro_04_crossbowmen, mkr_preintro_04_player_heavy_cavalry_rally_01, false)
	
	Rule_AddOneShot(AdvancedCombat_PreIntro_Shot04_Retreat_Right_Crossbowmen, 11)
	Rule_AddOneShot(AdvancedCombat_PreIntro_Shot04_Retreat_Crossbowmen, 14)
	Rule_AddOneShot(AdvancedCombat_PreIntro_Shot04_Attack_Spearmen, 10)--12.5
	Rule_AddOneShot(AdvancedCombat_PreIntro_Shot04_Attack_Spearmen2, 15)--19
end


function AdvancedCombat_PreIntro_Shot04_Retreat_Right_Crossbowmen()
		
	for i = 1, SGroup_Count(sg_preintro_04_crossbowmen) do
		
		if(sg_preintro_04_crossbowmen ~= nil) then
			local squad = SGroup_GetSquadAt(sg_preintro_04_crossbowmen, i)
			if(squad ~= nil) then
				SGroup_Single(sg_single, squad)
				if(SGroup_Count(sg_single) > 0) then
					if(Squad_GetHealth(squad) > 0) then
						if(Util_GetDistance(sg_single, mkr_preintro_04_enemy_heavy_ranged_right) < 8) then
							Cmd_Move(sg_single, mkr_preintro_04_enemy_heavy_ranged_rally, false)
						end
					end
				end
			end
		end
	end
end

function AdvancedCombat_PreIntro_Shot04_Retreat_Crossbowmen()
	
	if(SGroup_Exists("sg_preintro_04_crossbowmen")) then
		Cmd_Move(sg_preintro_04_crossbowmen, mkr_preintro_04_enemy_heavy_ranged_rally, false)
		
		Rule_AddInterval(AdvancedCombat_PreIntro_Shot04_Retreat_Crossbowmen2, .1)
	end
	
	--regroup knights
	if(SGroup_Exists("sg_preintro_04_knights") and SGroup_Exists("sg_preintro_04_spearmen")) then
		local knightsCenter = Util_GetPosition(sg_preintro_04_knights)
		if(knightsCenter ~= nil) then
			--Cmd_FormationMove(sg_preintro_04_knights, mkr_preintro_04_player_heavy_cavalry_attack, false)
			--Cmd_FormationAttackMove(sg_preintro_04_knights, mkr_preintro_04_enemy_spearmen_spawn, false)
			Cmd_Attack(sg_preintro_04_knights, sg_preintro_04_spearmen, false)
			--Rule_AddInterval(AdvancedCombat_PreIntro_Shot04_EndHoldPosition, .1)
		end
	end
end

function AdvancedCombat_PreIntro_Shot04_EndHoldPosition()
	
	if(SGroup_Exists("sg_preintro_04_spearmen")) then
		if(SGroup_IsUnderAttack(sg_preintro_04_spearmen, ANY, 1)) then
			Cmd_AttackMove(sg_preintro_04_spearmen, mkr_preintro_04_player_heavy_cavalry_attack, false)
			Rule_RemoveMe()
		end
	end
end

function AdvancedCombat_PreIntro_Shot04_Retreat_Crossbowmen2()
	
	if(SGroup_Exists("sg_preintro_04_crossbowmen")) then
		if(SGroup_Count(sg_preintro_04_crossbowmen) > 0) then
			if(Util_GetDistance(sg_preintro_04_crossbowmen, mkr_preintro_04_enemy_heavy_ranged_rally) < 7) then
				
				for i = 1, SGroup_Count(sg_preintro_04_crossbowmen) do
					local squad = SGroup_GetSquadAt(sg_preintro_04_crossbowmen, i)
					if(squad ~= nil) then
						
						SGroup_Single(sg_single, squad)
						
						Cmd_Move(sg_single, mkr_preintro_04_enemy_heavy_ranged_rally_02, false)
						Cmd_Move(sg_single, mkr_preintro_04_enemy_heavy_ranged_rally_03, true)
						Cmd_AttackMove(sg_single, mkr_preintro_04_enemy_spearmen_rally, true)
						
					end
				end
				
				if(SGroup_Exists("sg_preintro_04_knights")) then
					Cmd_AttackMove(sg_preintro_04_knights, mkr_preintro_04_enemy_heavy_ranged_rally_03, false)
				end
				
				--Rule_AddOneShot(AdvancedCombat_PreIntro_Shot04_Attack_Crossbowmen, 2.5)
				Rule_RemoveMe()
			end
		end
	end
end

function AdvancedCombat_PreIntro_Shot04_Attack_Spearmen()
	
	if(SGroup_Exists("sg_preintro_04_spearmen")) then
		
		local leftArcPos = Util_GetPosition(mkr_preintro_04_enemy_spearmen_left)
		local rightArcPos = Util_GetPosition(mkr_preintro_04_enemy_spearmen_right)
		ArcFormation(leftArcPos, rightArcPos, sg_preintro_04_spearmen, .35, false, 0)
		
		--Rule_AddOneShot(AdvancedCombat_PreIntro_Shot04_Hold_Spearmen, 1)
	end
end

function AdvancedCombat_PreIntro_Shot04_Hold_Spearmen()
		
	for i = 1, SGroup_Count(sg_preintro_04_spearmen) do
		local squad = SGroup_GetSquadAt(sg_preintro_04_spearmen, i)
		if(squad ~= nil) then
			
			if(Squad_HasDestination(squad)) then
				SGroup_Single(sg_single, squad)
				
				local squadPosition = Squad_GetDestination(squad)
				squadPosition["z"] = squadPosition["z"] + 1
				Cmd_Move(sg_single, squadPosition, true)
				Cmd_HoldPosition(sg_single, squadPosition, true)
				
			end
		end
	end
	--LocalCommand_SquadExt(localPlayer, sg_preintro_04_spearmen, SCMD_HoldPosition, 1, true)
	
end


function AdvancedCombat_PreIntro_Shot04_Attack_Spearmen2()
	
	if(SGroup_Exists("sg_preintro_04_spearmen")) then
		Cmd_Ability(sg_preintro_04_spearmen, BP_GetAbilityBlueprint("core_formation_line"))
		
		Cmd_FormationAttackMove(sg_preintro_04_spearmen, mkr_preintro_04_enemy_spearmen_rally, false)
	
	end
end

function AdvancedCombat_PreIntro_Shot04_Attack_Crossbowmen()
	
	if(SGroup_Exists("sg_preintro_04_crossbowmen") and SGroup_Exists("sg_preintro_04_knights")) then
		Cmd_AttackMove(sg_preintro_04_crossbowmen, mkr_preintro_04_enemy_spearmen_rally, true)
	end
	
end

function AdvancedCombat_PreIntro_Shot04_Cleanup()
	Rule_Remove(AdvancedCombat_PreIntro_Shot04_Retreat_Right_Crossbowmen)
	Rule_Remove(AdvancedCombat_PreIntro_Shot04_Retreat_Crossbowmen)
	Rule_Remove(AdvancedCombat_PreIntro_Shot04_EndHoldPosition)
	Rule_Remove(AdvancedCombat_PreIntro_Shot04_Retreat_Crossbowmen2)
	Rule_Remove(AdvancedCombat_PreIntro_Shot04_Attack_Spearmen)
	Rule_Remove(AdvancedCombat_PreIntro_Shot04_Hold_Spearmen)
	Rule_Remove(AdvancedCombat_PreIntro_Shot04_Attack_Spearmen2)
	Rule_Remove(AdvancedCombat_PreIntro_Shot04_Attack_Crossbowmen)
	
	
	if(SGroup_Exists("sg_preintro_04_knights")) then
		SGroup_DestroyAllSquads(sg_preintro_04_knights)
	end
	if(SGroup_Exists("sg_preintro_04_crossbowmen")) then
		SGroup_DestroyAllSquads(sg_preintro_04_crossbowmen)
	end
	if(SGroup_Exists("sg_preintro_04_spearmen")) then
		SGroup_DestroyAllSquads(sg_preintro_04_spearmen)
	end
	
end

----------

function AdvancedCombat_PreIntro_Shot05_Units()
	
	local sbp_knight_abb = BP_GetSquadBlueprint("unit_knight_3_abb")
	local sbp_manatarms_abb = BP_GetSquadBlueprint("unit_manatarms_3_abb")
	
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_05_knights1, {sbp = sbp_knight_abb, numSquads = 5 }, mkr_preintro_05_enemy_heavy_cavalry_spawn_02)
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_05_knights2, {sbp = sbp_knight_abb, numSquads = 5 }, mkr_preintro_05_enemy_heavy_cavalry_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_05_menatarms, {sbp = sbp_manatarms_abb, numSquads = 10 }, mkr_preintro_05_enemy_heavy_infantry_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_05_menatarms2, {sbp = sbp_manatarms_abb, numSquads = 10 }, mkr_preintro_05_enemy_heavy_infantry_spawn_02)
	
	Cmd_FormationMove(sg_preintro_05_menatarms, mkr_preintro_05_enemy_heavy_infantry_rally, false)
	Cmd_FormationMove(sg_preintro_05_menatarms2, mkr_preintro_05_enemy_heavy_infantry_rally_02, false)
	
	Cmd_Ability(sg_preintro_05_knights1, BP_GetAbilityBlueprint("core_formation_wedge"))
	Cmd_Ability(sg_preintro_05_knights2, BP_GetAbilityBlueprint("core_formation_wedge"))
	
	for i = 1, SGroup_Count(sg_preintro_05_knights1) do
		local squad = SGroup_GetSquadAt(sg_preintro_05_knights1, i)
		SGroup_Single(sg_single, squad)
		for i2 = 0, 10 do
			local circlePos1 = Util_GetPosition(mkr_preintro_05_enemy_heavy_cavalry_circle)
			local circleRad1 = (i2 * 30) - 120
			circleRad1 = circleRad1 * (3.14159 / 360)
			circlePos1["x"] = circlePos1["x"] + ((20 + i) * math.cos(circleRad1))
			circlePos1["z"] = circlePos1["z"] + ((20 + i) * math.sin(circleRad1))
			Cmd_FormationMove(sg_single, circlePos1, true)
		end
		Cmd_FormationMove(sg_single, mkr_preintro_05_enemy_heavy_cavalry_rally_02, true)
	end
	
	for i = 1, SGroup_Count(sg_preintro_05_knights2) do
		local squad = SGroup_GetSquadAt(sg_preintro_05_knights2, i)
		SGroup_Single(sg_single, squad)
		for i2 = 0, 11 do
			local circlePos1 = Util_GetPosition(mkr_preintro_05_enemy_heavy_cavalry_circle)
			local circleRad1 = (-i2 * 30) - 210
			circleRad1 = circleRad1 * (3.14159 / 360)
			circlePos1["x"] = circlePos1["x"] + ((15 + i) * math.cos(circleRad1))
			circlePos1["z"] = circlePos1["z"] + ((15 + i) * math.sin(circleRad1))
			Cmd_FormationMove(sg_single, circlePos1, true)
		end
		Cmd_FormationMove(sg_single, mkr_preintro_05_enemy_heavy_cavalry_rally_02, true)
	end
	
	SGroup_AddGroup(sg_preintro_05_knights, sg_preintro_05_knights1)
	SGroup_AddGroup(sg_preintro_05_knights, sg_preintro_05_knights2)
	Rule_AddOneShot(AdvancedCombat_PreIntro_Shot05_Formation, 12)
end


function AdvancedCombat_PreIntro_Shot05_Formation()
	
	if(SGroup_Exists("sg_preintro_05_knights")) then
		Cmd_FormationMove(sg_preintro_05_knights, mkr_preintro_05_enemy_heavy_cavalry_rally, false, false, mkr_preintro_06_player_heavy_cavalry_spawn)
	end
end

function AdvancedCombat_PreIntro_Shot05_Cleanup()
	
	Rule_Remove(AdvancedCombat_PreIntro_Shot05_Formation)
	
	if(SGroup_Exists("sg_preintro_05_knights")) then
		SGroup_DestroyAllSquads(sg_preintro_05_knights)
	end
	if(SGroup_Exists("sg_preintro_05_knights1")) then
		SGroup_DestroyAllSquads(sg_preintro_05_knights1)
	end
	if(SGroup_Exists("sg_preintro_05_knights2")) then
		SGroup_DestroyAllSquads(sg_preintro_05_knights2)
	end
	if(SGroup_Exists("sg_preintro_05_menatarms")) then
		SGroup_DestroyAllSquads(sg_preintro_05_menatarms)
	end
	if(SGroup_Exists("sg_preintro_05_menatarms2")) then
		SGroup_DestroyAllSquads(sg_preintro_05_menatarms2)
	end
end

----------

function AdvancedCombat_PreIntro_Shot06_Units()
	
	local sbp_knight_hre = BP_GetSquadBlueprint("unit_knight_3_hre")
	local sbp_crossbowmen_hre = BP_GetSquadBlueprint("unit_crossbowman_3_hre")
	local sbp_spearmen_hre = BP_GetSquadBlueprint("unit_spearman_3_hre")
	
	local sbp_knight_abb = BP_GetSquadBlueprint("unit_knight_3_abb")
	local sbp_manatarms_abb = BP_GetSquadBlueprint("unit_manatarms_3_abb")
	
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_06_enemy_knights, {sbp = sbp_knight_abb, numSquads = 10 }, mkr_preintro_06_enemy_heavy_cavalry_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_06_enemy_menatarms, {sbp = sbp_manatarms_abb, numSquads = 10 }, mkr_preintro_06_enemy_heavy_infantry_spawn)
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro_06_enemy_menatarms2, {sbp = sbp_manatarms_abb, numSquads = 10 }, mkr_preintro_06_enemy_heavy_infantry_spawn_02)
	
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_06_knights, {sbp = sbp_knight_hre, numSquads = 5 }, mkr_preintro_06_player_heavy_cavalry_spawn)
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_06_knights2, {sbp = sbp_knight_hre, numSquads = 5 }, mkr_preintro_06_player_heavy_cavalry_spawn_02)
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_06_crossbowmen, {sbp = sbp_crossbowmen_hre, numSquads = 10 }, mkr_preintro_06_player_heavy_ranged_spawn)
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_06_spearmen1, {sbp = sbp_spearmen_hre, numSquads = 10 }, mkr_preintro_06_player_spearmen_spawn)
	UnitEntry_DeploySquads(villagePlayer, sg_preintro_06_spearmen2, {sbp = sbp_spearmen_hre, numSquads = 10 }, mkr_preintro_06_player_spearmen2_spawn)
	
	Cmd_FormationMove(sg_preintro_06_enemy_knights, mkr_preintro_06_enemy_heavy_cavalry_rally, false)
	Cmd_FormationMove(sg_preintro_06_enemy_menatarms, mkr_preintro_06_enemy_heavy_cavalry_rally, false)
	Cmd_FormationMove(sg_preintro_06_enemy_menatarms2, mkr_preintro_06_enemy_heavy_cavalry_rally, false)
	
	Cmd_FormationMove(sg_preintro_06_enemy_knights, mkr_preintro_06_enemy_heavy_cavalry_rally_02, true)
	Cmd_FormationMove(sg_preintro_06_enemy_menatarms, mkr_preintro_06_enemy_heavy_cavalry_rally_02, true)
	Cmd_FormationMove(sg_preintro_06_enemy_menatarms2, mkr_preintro_06_enemy_heavy_cavalry_rally_02, true)
	
	Cmd_FormationAttackMove(sg_preintro_06_enemy_knights, mkr_preintro_06_player_heavy_ranged_rally, true)
	Cmd_FormationAttackMove(sg_preintro_06_enemy_menatarms, mkr_preintro_06_player_heavy_ranged_rally, true)
	Cmd_FormationAttackMove(sg_preintro_06_enemy_menatarms2, mkr_preintro_06_player_heavy_ranged_rally, true)
	
	Rule_AddOneShot(AdvancedCombat_PreIntro_Shot06_Attack_Start, 9)
	Rule_AddOneShot(AdvancedCombat_PreIntro_Shot06_Knight_Attack_Start, 7)
end

function AdvancedCombat_PreIntro_Shot06_Attack_Start()
	
	Cmd_FormationMove(sg_preintro_06_crossbowmen, mkr_preintro_06_player_heavy_ranged_rally, false)
	
	Cmd_Ability(sg_preintro_06_spearmen1, BP_GetAbilityBlueprint("core_formation_line"))
	Cmd_FormationMove(sg_preintro_06_spearmen1, mkr_preintro_06_player_spearmen_rally, false)
	Cmd_FormationMove(sg_preintro_06_spearmen1, mkr_preintro_06_player_spearmen_rally_02, true, false, mkr_preintro_06_player_spearmen_facing)
	
	Cmd_Ability(sg_preintro_06_spearmen2, BP_GetAbilityBlueprint("core_formation_line"))
	Cmd_FormationMove(sg_preintro_06_spearmen2, mkr_preintro_06_player_spearmen2_rally, false)
	Cmd_FormationMove(sg_preintro_06_spearmen2, mkr_preintro_06_player_spearmen2_rally_02, false, false, mkr_preintro_06_player_spearmen2_facing)
	
	Rule_AddInterval(AdvancedCombat_PreIntro_Shot06_Retreat_Crossbows_Start, .2)
	Rule_AddOneShot(AdvancedCombat_PreIntro_Shot06_Cheer, 3.75)
	Rule_AddOneShot(AdvancedCombat_PreIntro_Shot06_Hold, 7)
	Rule_AddOneShot(AdvancedCombat_PreIntro_Shot06_Attack_Knights, 11)
	Rule_AddOneShot(AdvancedCombat_PreIntro_Shot06_Attack_Knights2, 12)
	
end


function AdvancedCombat_PreIntro_Shot06_Knight_Attack_Start()
	
	Cmd_Ability(sg_preintro_06_knights, BP_GetAbilityBlueprint("core_formation_wedge"))
	Cmd_FormationMove(sg_preintro_06_knights, mkr_preintro_06_player_heavy_cavalry_rally, false, false)
	
	Cmd_Ability(sg_preintro_06_knights2, BP_GetAbilityBlueprint("core_formation_wedge"))
	Cmd_FormationMove(sg_preintro_06_knights2, mkr_preintro_06_player_heavy_cavalry_rally_02, false, false)
	Cmd_FormationMove(sg_preintro_06_knights2, mkr_preintro_06_player_heavy_cavalry_rally_03, true, false, mkr_preintro_06_player_heavy_cavalry_attack)
	
end

function AdvancedCombat_PreIntro_Shot06_Cheer()
	
	if(sg_preintro_06_spearmen1 ~= nil and sg_preintro_06_spearmen2 ~= nil) then
		-- Make units cheer
		SGroup_EnableCheering(sg_preintro_06_spearmen1, true, 2.5, WALLA_CAMP_CHARGE_MEDIUM)
		SGroup_EnableCheering(sg_preintro_06_spearmen2, true, 2.5, WALLA_CAMP_CHARGE_MEDIUM)
	
	end
end

function AdvancedCombat_PreIntro_Shot06_Hold()
	
	if(sg_preintro_06_spearmen1 ~= nil and sg_preintro_06_spearmen2 ~= nil) then
		
		for i = 1, SGroup_Count(sg_preintro_06_spearmen1) do
			local squad = SGroup_GetSquadAt(sg_preintro_06_spearmen1, i)
			local squadPosition = Util_GetPosition(squad)
			SGroup_Single(sg_single, squad)
			
			squadPosition["z"] = squadPosition["z"] - 1
			Cmd_HoldPosition(sg_single, squadPosition, false)
			Cmd_HoldPosition(sg_single, squadPosition, true)
		end
		
		for i = 1, SGroup_Count(sg_preintro_06_spearmen2) do
			local squad = SGroup_GetSquadAt(sg_preintro_06_spearmen2, i)
			local squadPosition = Util_GetPosition(squad)
			SGroup_Single(sg_single, squad)
			
			squadPosition["z"] = squadPosition["z"] - 1
			Cmd_HoldPosition(sg_single, squadPosition, false)
			Cmd_HoldPosition(sg_single, squadPosition, true)
		end
	end
end

function AdvancedCombat_PreIntro_Shot06_Retreat_Crossbows_Start()
	
	if(sg_preintro_06_crossbowmen ~= nil and sg_preintro_06_enemy_knights ~= nil) then
		if(SGroup_Count(sg_preintro_06_crossbowmen) > 0 and SGroup_Count(sg_preintro_06_enemy_knights) > 0) then
			if(Util_GetDistance(sg_preintro_06_crossbowmen, sg_preintro_06_enemy_knights) < 20) then
				Rule_AddOneShot(AdvancedCombat_PreIntro_Shot06_Retreat_Crossbows, 0)
				Rule_AddOneShot(AdvancedCombat_PreIntro_Shot06_Attack_Spearmen, 3.5)
				Rule_AddOneShot(AdvancedCombat_PreIntro_Shot06_Crossbows_Line, 7)
				
				Rule_AddOneShot(AdvancedCombat_PreIntro_Shot06_Spearmen_Middle, 1.75)
				
				Rule_RemoveMe()
			end
		end
	end
end

function AdvancedCombat_PreIntro_Shot06_Retreat_Crossbows()

	if(SGroup_Count(sg_preintro_06_crossbowmen) > 0) then
		if(Util_GetDistance(sg_preintro_06_crossbowmen, mkr_preintro_06_player_heavy_ranged_spawn) < 5) then
			Rule_RemoveMe()
		else
			if(sg_preintro_06_crossbowmen ~= nil and sg_preintro_06_enemy_knights ~= nil) then
				if(SGroup_Count(sg_preintro_06_crossbowmen) > 0 and SGroup_Count(sg_preintro_06_enemy_knights) > 0) then
					if(Util_GetDistance(sg_preintro_06_crossbowmen, sg_preintro_06_enemy_knights) < 22) then
						Cmd_Ability(sg_preintro_06_crossbowmen, BP_GetAbilityBlueprint("core_formation_line"))
						Cmd_FormationMove(sg_preintro_06_crossbowmen, mkr_preintro_06_player_heavy_ranged_spawn, false)
						
						Rule_AddOneShot(AdvancedCombat_PreIntro_Shot06_Attack_Crossbows, 2.5)
					end
				end
			end
		end
	end
end

function AdvancedCombat_PreIntro_Shot06_Attack_Crossbows()
	
	if(sg_preintro_06_crossbowmen ~= nil and sg_preintro_06_enemy_knights ~= nil) then
		Cmd_Attack(sg_preintro_06_crossbowmen, sg_preintro_06_enemy_knights, false)
		Rule_AddOneShot(AdvancedCombat_PreIntro_Shot06_Retreat_Crossbows, .5)
	end
end

function AdvancedCombat_PreIntro_Shot06_Crossbows_Line()
	
	if(sg_preintro_06_crossbowmen ~= nil) then
		local leftArcPos = Util_GetPosition(mkr_preintro_06_player_spearmen2_rally_02)
		local rightArcPos = Util_GetPosition(mkr_preintro_06_player_spearmen_rally_02)
		leftArcPos["z"] = leftArcPos["z"] + 5
		rightArcPos["z"] = rightArcPos["z"] + 5
		ArcFormation(leftArcPos, rightArcPos, sg_preintro_06_crossbowmen, .5, false, 0)
	end
end

function AdvancedCombat_PreIntro_Shot06_Spearmen_Middle()
	
	--Cmd_FormationMove(sg_preintro_06_spearmen1, mkr_preintro_06_player_spearmen_rally_02, false, false, mkr_preintro_06_player_heavy_cavalry_attack_02)
	--Cmd_FormationMove(sg_preintro_06_spearmen2, mkr_preintro_06_player_spearmen2_rally_02, false, false, mkr_preintro_06_player_heavy_cavalry_attack_02)
	
	if(sg_preintro_06_spearmen1 ~= nil and sg_preintro_06_spearmen2 ~= nil) then
		SGroup_AddGroup(sg_preintro_06_spearmen_combined, sg_preintro_06_spearmen1)
		SGroup_AddGroup(sg_preintro_06_spearmen_combined, sg_preintro_06_spearmen2)
		
		SGroup_FilterByProximity(sg_preintro_06_spearmen_combined, Marker_GetPosition(mkr_preintro_06_player_spearmen_middle), FILTER_KEEP, 8)
		if(SGroup_Count(sg_preintro_06_spearmen_combined) > 0) then
			
			local spearmenDest = Marker_GetPosition(mkr_preintro_06_player_spearmen_middle)
			
			spearmenDest["z"] = spearmenDest["z"] + 1.75
			Cmd_FormationMove(sg_preintro_06_spearmen_combined, spearmenDest, false, false, mkr_preintro_06_enemy_heavy_cavalry_rally_02)
			
			spearmenDest["z"] = spearmenDest["z"] - .5
			Cmd_FormationMove(sg_preintro_06_spearmen_combined, spearmenDest, true, false, mkr_preintro_06_enemy_heavy_cavalry_rally_02)
			
			--[[
			local leftArcPos = spearmenDest
			leftArcPos["z"] = leftArcPos["z"] + 15
			local rightArcPos = spearmenDest
			rightArcPos["z"] = rightArcPos["z"] - 15
			
			ArcFormation(leftArcPos, rightArcPos, sg_preintro_06_spearmen_combined, 0, false, 0)
			--]]
			
			Cmd_FormationAttackMove(sg_preintro_06_spearmen_combined, mkr_preintro_06_player_spearmen_middle, true, false, mkr_preintro_06_enemy_heavy_cavalry_rally_02)
			
			Rule_AddOneShot(AdvancedCombat_PreIntro_Shot06_Spearmen_HoldMiddle, 2)
		end
	end
end

function AdvancedCombat_PreIntro_Shot06_Spearmen_HoldMiddle()
	if(SGroup_Count(sg_preintro_06_spearmen_combined) > 0) then
		
		for i = 1, SGroup_Count(sg_preintro_06_spearmen_combined) do
			local squad = SGroup_GetSquadAt(sg_preintro_06_spearmen_combined, i)
			local squadPosition = Util_GetPosition(squad)
			
			SGroup_Single(sg_single, squad)
			
			Cmd_HoldPosition(sg_single, squadPosition, false)
			--squadPosition["z"] = squadPosition["z"] - .5
			--Cmd_HoldPosition(sg_single, squadPosition, true)
		end
	end
end

function AdvancedCombat_PreIntro_Shot06_Attack_Spearmen()
	
	Cmd_FormationAttackMove(sg_preintro_06_spearmen1, mkr_preintro_06_enemy_heavy_cavalry_rally_02, false)
	Cmd_FormationAttackMove(sg_preintro_06_spearmen2, mkr_preintro_06_enemy_heavy_cavalry_rally_02, false)
	
	if(sg_preintro_06_spearmen1 ~= nil and sg_preintro_06_enemy_menatarms ~= nil) then
		Cmd_Attack(sg_preintro_06_enemy_menatarms, sg_preintro_06_spearmen1, false)
	end
	if(sg_preintro_06_spearmen2 ~= nil and sg_preintro_06_enemy_menatarms2 ~= nil) then
		Cmd_Attack(sg_preintro_06_enemy_menatarms2, sg_preintro_06_spearmen2, false)
	end
	
end

function AdvancedCombat_PreIntro_Shot06_Attack_Knights()
	
	Cmd_Ability(sg_preintro_06_knights, BP_GetAbilityBlueprint("core_formation_wedge"))
	Cmd_FormationAttackMove(sg_preintro_06_knights, sg_preintro_06_enemy_menatarms, true)
	
end

function AdvancedCombat_PreIntro_Shot06_Attack_Knights2()
	
	Cmd_Ability(sg_preintro_06_knights2, BP_GetAbilityBlueprint("core_formation_wedge"))
	Cmd_FormationMove(sg_preintro_06_knights2, mkr_preintro_06_player_heavy_cavalry_rally_03, false)
	Cmd_FormationMove(sg_preintro_06_knights2, mkr_preintro_06_player_heavy_cavalry_attack_02, true)
	Cmd_FormationMove(sg_preintro_06_knights2, mkr_preintro_06_player_heavy_cavalry_attack_03, true)
	Cmd_AttackMove(sg_preintro_06_knights2, mkr_preintro_06_player_spearmen2_rally_02, true)
	
end

function AdvancedCombat_PreIntro_Shot06_Cleanup()
	Rule_Remove(AdvancedCombat_PreIntro_Shot06_Attack_Start)
	Rule_Remove(AdvancedCombat_PreIntro_Shot06_Knight_Attack_Start)
	Rule_Remove(AdvancedCombat_PreIntro_Shot06_Cheer)
	Rule_Remove(AdvancedCombat_PreIntro_Shot06_Hold)
	Rule_Remove(AdvancedCombat_PreIntro_Shot06_Retreat_Crossbows_Start)
	Rule_Remove(AdvancedCombat_PreIntro_Shot06_Retreat_Crossbows)
	Rule_Remove(AdvancedCombat_PreIntro_Shot06_Attack_Crossbows)
	Rule_Remove(AdvancedCombat_PreIntro_Shot06_Crossbows_Line)
	Rule_Remove(AdvancedCombat_PreIntro_Shot06_Spearmen_Middle)
	Rule_Remove(AdvancedCombat_PreIntro_Shot06_Spearmen_HoldMiddle)
	Rule_Remove(AdvancedCombat_PreIntro_Shot06_Attack_Spearmen)
	Rule_Remove(AdvancedCombat_PreIntro_Shot06_Attack_Knights)
	Rule_Remove(AdvancedCombat_PreIntro_Shot06_Attack_Knights2)
	
			
	if(SGroup_Exists("sg_preintro_06_enemy_knights")) then
		SGroup_DestroyAllSquads(sg_preintro_06_enemy_knights)
	end
	if(SGroup_Exists("sg_preintro_06_enemy_menatarms")) then
		SGroup_DestroyAllSquads(sg_preintro_06_enemy_menatarms)
	end
	if(SGroup_Exists("sg_preintro_06_enemy_menatarms2")) then
		SGroup_DestroyAllSquads(sg_preintro_06_enemy_menatarms2)
	end
	
	if(SGroup_Exists("sg_preintro_06_knights")) then
		SGroup_DestroyAllSquads(sg_preintro_06_knights)
	end
	if(SGroup_Exists("sg_preintro_06_knights2")) then
		SGroup_DestroyAllSquads(sg_preintro_06_knights2)
	end
	if(SGroup_Exists("sg_preintro_06_crossbowmen")) then
		SGroup_DestroyAllSquads(sg_preintro_06_crossbowmen)
	end
	if(SGroup_Exists("sg_preintro_06_spearmen1")) then
		SGroup_DestroyAllSquads(sg_preintro_06_spearmen1)
	end
	if(SGroup_Exists("sg_preintro_06_spearmen2")) then
		SGroup_DestroyAllSquads(sg_preintro_06_spearmen2)
	end
	if(SGroup_Exists("sg_preintro_06_spearmen_combined")) then
		SGroup_DestroyAllSquads(sg_preintro_06_spearmen_combined)
	end
end


-----------------------------------------------------------------------
-- Clean Up
-----------------------------------------------------------------------

-- Cleans up all units and buildings from the pre-intro
function AdvancedCombat_PreIntro_Clean_Scenes()
			
	-- Delete all village and enemy squads
	Player_GetAll(enemyPlayer)
	SGroup_DestroyAllSquads(sg_allsquads)
	Player_GetAll(villagePlayer)
	SGroup_DestroyAllSquads(sg_allsquads)
	Player_GetAll(localPlayer)
	SGroup_DestroyAllSquads(sg_allsquads)
	
end


-----------------------------------------------------------------------
-- Additional Functions
-----------------------------------------------------------------------

-- Destroys a squad
function Destroy(gid, idx, sid)
	Squad_Destroy(sid)
end

-- Destroy an entity
function DestroyEntity(gid, idx, eid)
	Entity_Destroy(eid)	
end



