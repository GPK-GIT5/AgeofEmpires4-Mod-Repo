import("MissionOMatic/MissionOMatic.scar")	

function Ottoman_InitObjectives()
	SOBJ_AttackNotice = {
		Title = "Attack Notice",
		Type = ObjectiveType_Battle,
		Parent = OBJ_Defend,
		IsSecret = true,
		showTitle = false,
		StartAlongsideParent = false,
	} 
	OBJ_VizierBonus = {
		Title = "$11225885", --choose a Vizier Bonus
		Type = ObjectiveType_Primary,
		PreStart = function()
			objective_started = true
		end,
		OnStart = function()
			if mission_unpaused ~= true then
				Util_StartIntel(EVENTS.Start)	
			end
		end,
		PreComplete = function()
			Objective_Start(OBJ_Defend, false, false)
			Objective_Start(OBJ_Survive)
			Objective_StartTimer(OBJ_Survive, COUNT_UP, 0)
		end,
	}
	OBJ_Defend = {
		Title = "$11223420", --Defend your town center
		Type = ObjectiveType_Primary,
	}
	OBJ_Survive = {
		KPI = nil,
		Title = "$11223421", --Survive as long as you can
		Type = ObjectiveType_Primary,
		Intel_Start = EVENTS.Unpause,
	}
	SOBJ_GoldMedal = {
		Parent = OBJ_Survive,
		StartAlongsideParent = true,
		KPI = GOLD_MEDAL_SECONDS,
		Title = Loc_FormatText("$11224301", GOLD_MEDAL_MINUTES),
		missionCompleteEvent = EVENTS.GoldMedal,
		eventQueueString = "$11166943",
		Type = ObjectiveType_Bonus,
		nextObjective = nil,
		PreComplete = function()
			Game_SendCustomChallengeEvent(player1,CE_OTTOMANSARTGOLD,1)
		end,
	}
	SOBJ_SilverMedal = {
		Parent = OBJ_Survive,
		StartAlongsideParent = true,
		KPI = SILVER_MEDAL_SECONDS,
		Title = Loc_FormatText("$11224302", SILVER_MEDAL_MINUTES),
		missionCompleteEvent = EVENTS.SilverMedal,
		eventQueueString = "$11166944",
		Type = ObjectiveType_Bonus,
		nextObjective = SOBJ_GoldMedal,
	}
	SOBJ_BronzeMedal = {
		Parent = OBJ_Survive,
		StartAlongsideParent = true,
		KPI = BRONZE_MEDAL_SECONDS,
		Title = Loc_FormatText("$11224303", BRONZE_MEDAL_MINUTES),
		missionCompleteEvent = EVENTS.BronzeMedal,
		eventQueueString = "$11166945",
		Type = ObjectiveType_Bonus,
		nextObjective = SOBJ_SilverMedal,
	}
	Objective_Register(SOBJ_AttackNotice)
	Objective_Register(OBJ_VizierBonus)
	Objective_Register(OBJ_Defend)
	Objective_Register(OBJ_Survive)
	Objective_Register(SOBJ_BronzeMedal)
	Objective_Register(SOBJ_SilverMedal)
	Objective_Register(SOBJ_GoldMedal)
	
	OBJ_CurrentMedal = SOBJ_BronzeMedal
end



