-----------------------------------------------------------------------

_preintro = {
}

-----------------------------------------------------------------------
-- Functions
-----------------------------------------------------------------------


-- Prepares the preintro shots.
function EarlyEconomy_PreIntro_Setup_Scenes()
		
	-- Get unit blueprints
	local sbp_villager_rus = BP_GetSquadBlueprint("unit_villager_1_eng")
	local sbp_tradecart_rus = BP_GetSquadBlueprint("unit_trade_cart_rus")	
	
	farmBP = EBP.RUS.BUILDING_RESOURCE_FARM_CONTROL_RUS
	townCenterBP = EBP.RUS.BUILDING_TOWN_CENTER_RUS	
	
	-- Create SGroups
	sg_preintro_player_first_farmers = SGroup_CreateIfNotFound("sg_preintro_player_first_farmers")
	sg_preintro_player_first_foresters = SGroup_CreateIfNotFound("sg_preintro_player_first_foresters")
	sg_preintro_player_hunters = SGroup_CreateIfNotFound("sg_preintro_player_hunters")
	sg_preintro_player_hunter02 = SGroup_CreateIfNotFound("sg_preintro_player_hunter02")
	sg_preintro_player_second_farmers = SGroup_CreateIfNotFound("sg_preintro_player_second_farmers")
	sg_preintro_player_farm_builder = SGroup_CreateIfNotFound("sg_preintro_player_farm_builder")
	sg_preintro_player_trader = SGroup_CreateIfNotFound("sg_preintro_player_trader")
	sg_preintro_player_trader02 = SGroup_CreateIfNotFound("sg_preintro_player_trader02")
	sg_preintro_villagercheer01 = SGroup_CreateIfNotFound("sg_preintro_villagercheer01")
	sg_preintro_player_town_center_builders = SGroup_CreateIfNotFound("sg_preintro_player_town_center_builders")
	sg_preintro_player_town_center_builders1 = SGroup_CreateIfNotFound("sg_preintro_player_town_center_builders1")
	sg_preintro_player_town_center_builders2 = SGroup_CreateIfNotFound("sg_preintro_player_town_center_builders2")
	sg_preintro_player_second_foresters = SGroup_CreateIfNotFound("sg_preintro_player_second_foresters")
				
end

-- Sets up the first shot of the intro. Villagers farm and cut trees.
function EarlyEconomy_PreIntro_Shot01_Units()
		
	-- Spawn units
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_first_farmers, {type = "scar_villager", numSquads = 3 }, mkr_preintro_01_farmers_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_first_foresters, {type = "scar_villager", numSquads = 4 }, mkr_preintro_01_forester_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_hunters, {type = "scar_villager", numSquads = 1 }, mkr_preintro_01_hunters_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_hunter02, {type = "scar_villager", numSquads = 1 }, mkr_preintro_01_hunter02_spawn)
	
	-- Assign villagers to resources
	local function _AssignFarmer(gid, idx, sid)
		SGroup_Single(sg_single, sid)
		local e_closest_farm = EGroup_GetClosestEntity(eg_farms, Util_GetPosition(sid))
		if e_closest_farm ~= nil then
			EGroup_Single(eg_single, e_closest_farm)
			LocalCommand_SquadEntity(localPlayer, sg_single, SCMD_Gather, eg_single, false)
			EGroup_Remove(eg_farms, e_closest_farm)
		else
			print("Could not find farm to assign villager to")
		end
	end	
	
	local function _AssignForester(gid, idx, sid)

		SGroup_Single(sg_single, sid)
		local entity_tree = EGroup_GetClosestEntity(eg_allWoodResources, Util_GetPosition(sid))
		if entity_tree ~= nil then
			EGroup_Single(eg_single, entity_tree)
			LocalCommand_SquadEntity(localPlayer, sg_single, SCMD_Gather, eg_single, false)
			EGroup_Remove(eg_allWoodResources, entity_tree)
		else
			print("Could not find a tree to assign villager to")
		end
		
	end	
	
	-- For every sgroup
	SGroup_ForEach(sg_preintro_player_first_farmers, _AssignFarmer)
	SGroup_ForEach(sg_preintro_player_first_foresters, _AssignForester)
	
	-- Has the villagers kill and gather from the deer
	LocalCommand_SquadSquad(localPlayer, sg_preintro_player_hunters, SCMD_Gather, sg_preintro_deer, false)
	LocalCommand_SquadSquad(localPlayer, sg_preintro_player_hunter02, SCMD_Gather, sg_preintro_deer, false)
	
end

-- Sets up the second shot of the intro. Villager is trained and builds a farm. Trader is trained and moves to the trading post.
function EarlyEconomy_PreIntro_Shot02_Units()	
	
	-- Spawn units
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_second_farmers, {type = "scar_villager", numSquads = 2 }, mkr_preintro_02_farmers_spawn)
	
	--Modify_EntityBuildTime(localPlayer, farmBP, 0.5)
		
	-- Assign villagers to resources
	local function _AssignFarmer(gid, idx, sid)
		SGroup_Single(sg_single, sid)
		local e_closest_farm = EGroup_GetClosestEntity(eg_farms, Util_GetPosition(sid))
		if e_closest_farm ~= nil then
			EGroup_Single(eg_single, e_closest_farm)
			LocalCommand_SquadEntity(localPlayer, sg_single, SCMD_Gather, eg_single, false)
			EGroup_Remove(eg_farms, e_closest_farm)
		else
			print("Could not find farm to assign villager to")
		end
	end	
	
	-- For every sgroup
	SGroup_ForEach(sg_preintro_player_second_farmers, _AssignFarmer)
	
	Rule_AddOneShot(EarlyEconomy_PreIntro_Shot02_SpawnFarmerAtTownCenter, 4)
	Rule_AddOneShot(EarlyEconomy_PreIntro_Shot02_SpawnTraderAtMarket, 11)
	
end

function EarlyEconomy_PreIntro_Shot02_SpawnFarmerAtTownCenter()	
	
	-- Spawn builder
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_farm_builder, {type = "scar_villager", numSquads = 1 }, mkr_preintro_02_farmer_spawn)
	
	local FarmFacing = Util_GetFacingFromDirection(Marker_GetPosition(mkr_preintro_02_farm), Marker_GetDirection(mkr_preintro_02_farm))
			
	-- Construct Farm
	LocalCommand_PlayerSquadConstructBuilding(localPlayer, sg_preintro_player_farm_builder, farmBP, Util_GetPosition(mkr_preintro_02_farm), FarmFacing, false)	
end

function EarlyEconomy_PreIntro_Shot02_SpawnTraderAtMarket()
	
	-- Spawn trader
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_trader, {type = "scar_trade_cart", numSquads = 1 }, mkr_preintro_02_trader_spawn)
	-- Move trader	
	Cmd_Move(sg_preintro_player_trader, mkr_preintro_02_trader_rally)	
end


-- Sets up the third shot of the intro. Villagers build a town center.
function EarlyEconomy_PreIntro_Shot03_Units() 
	
	Modify_EntityBuildTime(localPlayer, townCenterBP, 0.5)
		
	-- Spawn units
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_town_center_builders1, {type = "scar_villager", numSquads = 4 }, mkr_preintro_03_builders_spawn_east)
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_town_center_builders2, {type = "scar_villager", numSquads = 4 }, mkr_preintro_03_builders_spawn_north)
	
	SGroup_AddGroup(sg_preintro_player_town_center_builders, sg_preintro_player_town_center_builders1)
	SGroup_AddGroup(sg_preintro_player_town_center_builders, sg_preintro_player_town_center_builders2)
	
	Rule_AddOneShot(EarlyEconomy_PreIntro_Shot03_ConstructTownCenter, 0.1)	
end

function EarlyEconomy_PreIntro_Shot03_ConstructTownCenter()
	
	local TownCenterFacing = Util_GetFacingFromDirection(Marker_GetPosition(mkr_preintro_03_town_center), Marker_GetDirection(mkr_preintro_03_town_center))
	
	-- Construct Town Center
	LocalCommand_PlayerSquadConstructBuilding(localPlayer, sg_preintro_player_town_center_builders, townCenterBP, Util_GetPosition(mkr_preintro_03_town_center), TownCenterFacing, false)	
	
	--order north villagers to path around the edge of the town center
	local buildersRallyPoint = Util_GetPosition(mkr_preintro_03_builders_spawn_north)
	buildersRallyPoint["x"] = buildersRallyPoint["x"] - 1.5
	buildersRallyPoint["z"] = buildersRallyPoint["z"] - 3.5
	--Cmd_Move(sg_preintro_player_town_center_builders2, buildersRallyPoint, true)
	
	for i = 1, SGroup_Count(sg_preintro_player_town_center_builders2) do
		--isolate each unit and give it a move order
		local squad = SGroup_GetSquadAt(sg_preintro_player_town_center_builders2, i)
		SGroup_Single(sg_single, squad)
		buildersRallyPoint["z"] = buildersRallyPoint["z"] + (i * .2)
		Cmd_Move(sg_single, buildersRallyPoint, true)
	end
	
	--order north villagers to gather wood
	local entity_tree = EGroup_GetClosestEntity(eg_allWoodResources, Util_GetPosition(mkr_preintro_03_builders_spawn_east))
	if entity_tree ~= nil then
		EGroup_Single(eg_single, entity_tree)
		LocalCommand_SquadEntity(localPlayer, sg_preintro_player_town_center_builders2, SCMD_Gather, eg_single, true)
		EGroup_Remove(eg_allWoodResources, entity_tree)
	end
end

-- Sets up the fourth shot of the intro. Foresters cut wood.
function EarlyEconomy_PreIntro_Shot04_Units()
	
	-- Spawn units
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_second_foresters, {type = "scar_villager", numSquads = 5 }, mkr_preintro_04_forester_spawn)
	
	-- Assign villagers to resources	
	local function _AssignForester(gid, idx, sid)

		SGroup_Single(sg_single, sid)
		local entity_tree = EGroup_GetClosestEntity(eg_allWoodResources, Util_GetPosition(sid))
		if entity_tree ~= nil then
			EGroup_Single(eg_single, entity_tree)
			LocalCommand_SquadEntity(localPlayer, sg_single, SCMD_Gather, eg_single, false)
			EGroup_Remove(eg_allWoodResources, entity_tree)
		else
			print("Could not find a tree to assign villager to")
		end
		
	end	
	
	-- For every sgroup
	SGroup_ForEach(sg_preintro_player_second_foresters, _AssignForester)
	
end

-- Sets up the fifth shot of the intro. No actions currently.
function EarlyEconomy_PreIntro_Shot05_Units()
	
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_trader, {type = "scar_trade_cart", numSquads = 1 }, mkr_preintro_02_trader_spawn)
	-- Move trader	
	Cmd_Move(sg_preintro_player_trader, mkr_preintro_02_trader_rally)	
	
		-- Spawn trader
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_trader02, {type = "scar_trade_cart", numSquads = 1 }, mkr_preintro_02_trader_spawn)
	-- Move trader	
	Cmd_FormationMove(sg_preintro_player_trader02, mkr_player_preintro_trader02_spawn, false)	
	Cmd_FormationMove(sg_preintro_player_trader02, mkr_player_preintro_trader02_mid, true)	
	Cmd_FormationMove(sg_preintro_player_trader02, mkr_player_preintro_trader02_dest, true)	
	
	UnitEntry_DeploySquads(localPlayer, sg_preintro_villagercheer01, {type = "scar_villager", numSquads = 4 }, mkr_player_preintro_villagercheer01)
	SGroup_EnableCheering(sg_preintro_villagercheer01, true, -1 )
	
end

-- Cleans up the scene after the intro
function EarlyEconomy_PreIntro_Clean_Scenes()
	
	Rule_Remove(EarlyEconomy_PreIntro_Shot02_SpawnFarmerAtTownCenter)
	Rule_Remove(EarlyEconomy_PreIntro_Shot02_SpawnTraderAtMarket)
	Rule_Remove(EarlyEconomy_PreIntro_Shot03_ConstructTownCenter)
	
	Modify_EntityBuildTime(localPlayer, townCenterBP, 1)	
	
	-- Deletes all squads and entities used in the pre-intro
	SGroup_ForEach(sg_preintro_player_first_farmers, Despawn)
	SGroup_ForEach(sg_preintro_player_first_foresters, Despawn)
	SGroup_ForEach(sg_preintro_player_hunters, Despawn)
	SGroup_ForEach(sg_preintro_player_hunter02, Despawn)
	SGroup_ForEach(sg_preintro_player_second_farmers, Despawn)
	SGroup_ForEach(sg_preintro_player_farm_builder, Despawn)
	SGroup_ForEach(sg_preintro_player_trader, Despawn)
	SGroup_ForEach(sg_preintro_player_town_center_builders, Despawn)
	SGroup_ForEach(sg_preintro_player_town_center_builders1, Despawn)
	SGroup_ForEach(sg_preintro_player_town_center_builders2, Despawn)
	SGroup_ForEach(sg_preintro_player_second_foresters, Despawn)
	SGroup_ForEach(sg_preintro_villagercheer01, Despawn)
	SGroup_ForEach(sg_preintro_player_trader02, Despawn)
		
	local eg_player_buildings = Player_GetAllEntities(localPlayer)
	Player_GetAllEntitiesNearMarker(localPlayer, eg_player_buildings, mkr_preintro_03_town_center, 2)
	if eg_player_buildings ~= nil then
		EGroup_ForEach(eg_player_buildings, DespawnEntity)
	end
	Player_GetAllEntitiesNearMarker(localPlayer, eg_player_buildings, mkr_preintro_02_farm, 2)
	if eg_player_buildings ~= nil then
		EGroup_ForEach(eg_player_buildings, Kill)
	end
		
	-- Despawn carcasses
	DespawnCarcasses()
	
end

function EarlyEconomy_PreIntro_Shot01_Clean_Up()
end
function EarlyEconomy_PreIntro_Shot02_Clean_Up()
end
function EarlyEconomy_PreIntro_Shot03_Clean_Up()
end
function EarlyEconomy_PreIntro_Shot04_Clean_Up()
end
function EarlyEconomy_PreIntro_Shot05_Clean_Up()
end

-----------------------------------------------------------------------
-- Additional Functions
-----------------------------------------------------------------------

function Despawn(gid, idx, sid)
	
	-- Despawn
	Squad_Destroy(sid)
	
end

function DespawnEntity(gid, idx, sid)
	
	-- Despawn
	Entity_Destroy(sid)
	
end

function Kill(gid, idx, sid)
	
	-- Kill
	Entity_Kill(sid)
	
end

function DespawnCarcasses()
		
	local _DespawnCarcass = function(gid, idx, eid)
		-- Checks if the entity is a carcass and destroys it
		if Entity_IsOfType(eid, "carriable") then	
			Entity_Destroy(eid)
		end
	end
	
	eg_all_neutral = EGroup_CreateIfNotFound("eg_all_neutral")
	World_GetAllNeutralEntities(eg_all_neutral)
	EGroup_ForEach(eg_all_neutral, _DespawnCarcass)
end
