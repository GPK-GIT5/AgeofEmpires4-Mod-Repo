function Mission_Preset()
	
	-- Enable player colours
	PlayerColour_Enable()
	
	--Player Upgrades
	local playerUpgradeList = {
				
		UPG.COMMON.UPGRADE_UNIT_SPEARMAN_2,
		UPG.COMMON.UPGRADE_UNIT_SPEARMAN_3,
		UPG.COMMON.UPGRADE_UNIT_MANATARMS_4,
		UPG.COMMON.UPGRADE_UNIT_ARCHER_3,
		UPG.COMMON.UPGRADE_UNIT_HORSEMAN_3,
		UPG.COMMON.UPGRADE_UNIT_HORSEARCHER_3,
		UPG.COMMON.UPGRADE_UNIT_SPEARMAN_4,
		UPG.COMMON.UPGRADE_UNIT_ARCHER_4,
		UPG.COMMON.UPGRADE_UNIT_KNIGHT_4,
		UPG.COMMON.UPGRADE_UNIT_HORSEMAN_4,
		UPG.COMMON.UPGRADE_UNIT_CROSSBOWMAN_4,
		UPG.CHINESE.UPGRADE_UNIT_FIRELANCER_4_CHI,
		UPG.CHINESE.UPGRADE_UNIT_REPEATER_CROSSBOW_4_CHI
	}
	
	for i, bp in ipairs(playerUpgradeList) do
		Player_CompleteUpgrade(player1, bp)
	end
	
	--Player Upgrades
	local enemyUpgradeList = {
		
		UPG.MONGOL.UPGRADE_UNIT_HORSEMAN_2_MON,
		UPG.MONGOL.UPGRADE_UNIT_SPEARMAN_2_MON,
		UPG.MONGOL.UPGRADE_UNIT_SPEARMAN_3_MON,
		UPG.MONGOL.UPGRADE_UNIT_ARCHER_3_MON,
		UPG.MONGOL.UPGRADE_UNIT_KNIGHT_3_MON,
		UPG.MONGOL.UPGRADE_UNIT_HORSEMAN_3_MON,
		UPG.MONGOL.UPGRADE_UNIT_HORSEARCHER_3_MON,
		UPG.MONGOL.UPGRADE_UNIT_SPEARMAN_4_MON,
		UPG.MONGOL.UPGRADE_UNIT_ARCHER_4_MON,
		UPG.MONGOL.UPGRADE_UNIT_MANATARMS_4_MON,
		UPG.MONGOL.UPGRADE_UNIT_HORSEMAN_4_MON,
		UPG.MONGOL.UPGRADE_UNIT_HORSEARCHER_4_MON,
		UPG.MONGOL.UPGRADE_UNIT_CROSSBOWMAN_4_MON,
		UPG.MONGOL.UPGRADE_UNIT_KNIGHT_4_MON,
		UPG.MONGOL.UPGRADE_UNIT_SCORPION_4_MON,
		UPG.MONGOL.UPGRADE_UNIT_MANGONEL_4_MON,
		UPG.COMMON.UPGRADE_SIEGE_ENGINEERS,
		UPG.MONGOL.UPGRADE_SIEGE_WORKS_MON,
		UPG.MONGOL.UPGRADE_SIEGE_WORKS_IMPROVED_MON,
	}
	
	for i, bp in ipairs(enemyUpgradeList) do
		Player_CompleteUpgrade(player2, bp)
	end
	
	--Remove irrelevant production and tech
	local upgradeList = {
		UPG.COMMON.UPGRADE_UNIT_RELIGIOUS_TITHE_BARN_4,
		UPG.COMMON.UPGRADE_TECH_MILITARY_ACADEMY,
		UPG.CHINESE.UPGRADE_WALL_REPAIR_CHI,
	}
	local entityProductionList = {
		EBP.CHINESE.BUILDING_ECON_FOOD_CONTROL_CHI,
		EBP.CHINESE.BUILDING_ECON_WOOD_CONTROL_CHI,
		EBP.CHINESE.BUILDING_ECON_MINING_CAMP_CONTROL_CHI,
		EBP.CHINESE.BUILDING_RESOURCE_FARM_CHI,
		EBP.CHINESE.BUILDING_UNIT_NAVAL_CHI,
		EBP.CHINESE.BUILDING_TOWN_CENTER_CHI,
		EBP.CHINESE.BUILDING_TOWN_CENTER_CAPITAL_CHI,
		EBP.CHINESE.BUILDING_DYNASTY_GRANARY_CONTROL_CHI,
		EBP.CHINESE.BUILDING_DYNASTY_PAGODA_CONTROL_CHI,
	}
	local squadProductionList = {
		SBP.CHINESE.UNIT_TRADE_CART_CHI,
	}
	for i, bp in ipairs(entityProductionList) do
		Player_SetEntityProductionAvailability(player1, bp, ITEM_REMOVED)
	end
	for i, bp in ipairs(squadProductionList) do
		Player_SetSquadProductionAvailability(player1, bp, ITEM_REMOVED)
	end
	for i, bp in ipairs(upgradeList) do 
		Player_SetUpgradeAvailability(player1, bp, ITEM_REMOVED)
	end
	
	--Player_SetAbilityAvailability(player1, BP_GetAbilityBlueprint("age_up_imperial"), ITEM_REMOVED)
	
	Player_SetPopCapOverride(player1, 200)
	WallD_SpawnPlayerUnits()
	EGroup_DestroyAllEntities(eg_player_tc)
	
	eg_enemy_outposts = Player_GetAllEntities(player2)
	EGroup_Filter(eg_enemy_outposts, EBP.MONGOL.BUILDING_DEFENSE_OUTPOST_MON, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_enemy_outposts, UPG.MONGOL.UPGRADE_OUTPOST_CANNON_MON)
	
end

cinematicFinished = false
-- Checks if intro Event is running
function MissionOMatic_PreStart_IntroNISFinished() --override
	if(cinematicFinished == true) then
		if Event_IsAnyRunning() == false then
			
			Rule_RemoveMe()
			StartMission_ReleaseHold()
		end
	end
end

--toggle auto collect then disable the ability
function Walld_Disable_Tax()
	Cmd_Ability(sg_player_officials, BP_GetAbilityBlueprint("official_auto_collect_tax_toggle_chi"), nil, nil, true, false)
	SGroup_RemoveAbility(sg_player_officials, BP_GetAbilityBlueprint("official_auto_collect_tax_toggle_chi"))
	Cmd_Move(sg_player_officials, mkr_player_officials, false)
end


function Mission_Start()
	
	WallD_HealWalls()
	Objective_Start(OBJ_ConstructWonder)
	Objective_Start(SOBJ_SpendResources)
	Objective_Start(SOBJ_QuickBuild)
	Player_SetResource( player2, RT_Wood, 	100000000)
	Rule_AddSGroupEvent(_WallD_QueueVillagerRespawn, sg_player_villagers, GE_SquadKilled, data)
	SGroup_RemoveAbility(sg_player_villagers, BP_GetAbilityBlueprint("core_unit_death"))
	
	
	SGroup_RemoveAbility(sg_player_officials, BP_GetAbilityBlueprint("core_unit_death"))
	SGroup_RemoveAbility(sg_player_officials, BP_GetAbilityBlueprint("official_collect_tax_target_chi"))
	SGroup_RemoveAbility(sg_player_officials, BP_GetAbilityBlueprint("official_drop_off_tax_target_chi"))
	
	FOW_PlayerRevealAll(player2)
	
	hint_wonderWarning = HintPoint_Add(mkr_player_wonder, true, "$11220635", 5) --"Prepare Defenses before Completing the Wonder"
	hint_gatehint_left = HintPoint_Add(mkr_gatehint_left, true, "$11220636", 5) --"Enemies will attack this gate!"
	hint_gatehint_right = HintPoint_Add(mkr_gatehint_right, true, "$11220636", 5) --"Enemies will attack this gate!"

	--group to hold archers attacking the walls and not currently in a rovingArmy
	sg_idleRanged = SGroup_CreateIfNotFound("sg_idleRanged")
	
	Rule_AddInterval(WallD_CheckArchersBlocked, 1)
	
end
		
