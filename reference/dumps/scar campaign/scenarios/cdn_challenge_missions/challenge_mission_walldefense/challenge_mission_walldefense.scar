function WallD_PatrolWaves()
	
	local moduleData = {}
	
	int_halfWave = math.floor(waveSentCount/2)
	
	if waveSentCount % 2 or waveSentCount == 0 then 
		local units = patrolWaveUnits[int_halfWave]
		local target = {}
		
		target = {mkr_mongol_horse_patrol_2}
		if waveSentCount % 4 or waveSentCount == 0 then
			target = {mkr_mongol_horse_patrol_3}
		end
		
		target = {mkr_mongol_horse_patrol_2}
		if waveSentCount % 4 or waveSentCount == 0 then
			target = {mkr_mongol_horse_patrol_3}
		end
		
		local patrolName = "PatrolWave_" .. math.floor(waveSentCount/2)
		
		--add a custom onBlockedFunction to prevent archers from building rams
		moduleData = {
			descriptor = patrolName, 				
			type = "RovingArmy",
			player = player2,
			targetingType = ARMY_TARGETING_DISCARD,
			attackMove = attackMoveStyle_attackEverything,
			targets = target,
			spawnLocation = mkr_mongol_horse_patrol_spawn,
			onDeathDissolve = true,
			units = units,
		}
		
		local newModule = RovingArmy_Init(moduleData)
		FOW_PlayerRevealSGroup(player1, newModule.sgroup, 20, -1)
		
		
		--set group to use spread formation
		if scartype(newModule.sgroup) == ST_SGROUP and SGroup_CountSpawned(newModule.sgroup) > 0 then
			Cmd_Ability(newModule.sgroup, BP_GetAbilityBlueprint("core_formation_spread"))
		end
	
	end	
end

function WallD_RangedWaves()
	
	local moduleData = {}
	
	int_halfWave = math.floor(waveSentCount/2)
	
	if waveSentCount % 2 or waveSentCount == 0 then 
		local units = rangedWaveUnits[int_halfWave]
		local target = {}
		
		local routeIndex = (waveSentCount % 2)+1
		
		local rangedSpawn = mkr_mongol_ranged_spawn1
		target = {mkr_ranged_path_1_1, mkr_ranged_path_1_2}
		if routeIndex == 1 then
			target = {mkr_ranged_path_2_1, mkr_ranged_path_2_2}
			rangedSpawn = mkr_mongol_ranged_spawn2
		end
		
		local patrolName = "RangedWave_" .. math.floor(waveSentCount/2)
		
		
		--add a custom onBlockedFunction to prevent archers from building rams
		moduleData = {
			descriptor = patrolName, 				
			type = "RovingArmy",
			player = player2,
			targetingType = ARMY_TARGETING_DISCARD,
			attackMove = attackMoveStyle_attackEverything,
			targets = target,
			spawnLocation = rangedSpawn,
			onDeathDissolve = true,
			units = units,
			cavalryCanBuildRams = false,
			onBlockedFunction = WallD_ArchersBlocked,
		}
		
		local newModule = RovingArmy_Init(moduleData)
		FOW_PlayerRevealSGroup(player1, newModule.sgroup, 20, -1)
		
		
		--set group to use spread formation
		if scartype(newModule.sgroup) == ST_SGROUP and SGroup_CountSpawned(newModule.sgroup) > 0 then
			Cmd_Ability(newModule.sgroup, BP_GetAbilityBlueprint("core_formation_spread"))
		end
		
		newModule.onBlockedFunction = WallD_ArchersBlocked
		if newModule.onBlockedFunction == nil then
			newModule.onBlockedFunction = WallD_ArchersBlocked
		end
	end
end

function WallD_CheckRangedName(currentArmyName)
	
	for i=1,24 do
		local localName = "RangedWave_" .. math.floor(i/2)
		if(currentArmyName == localName) then
			return true
		end
	end
	
	return false
end

wallDArcherSplitTime = 0
function WallD_CheckArchersBlocked()
	
	-- Next, go through existing modules
	-- We need to copy this table, or else we'll be removing stuff from t_allModules while iterating through it
	local allModules = Clone(t_allModules, false)
	-- Extract everyone not in the Return module from their modules
	local moduleCount = 0
	
	for index, module in pairs(allModules) do
		moduleCount = moduleCount + 1
	end
	
	local splitUnits = false
	
	
	
	if(moduleCount > 1) then
		for i=1,moduleCount do
			local moduleA = allModules[i]
			local isRangedModule = WallD_CheckRangedName(moduleA.descriptor)
			if moduleA.player == player2 and isRangedModule == true then
				if scartype(moduleA.sgroup) == ST_SGROUP and SGroup_CountSpawned(moduleA.sgroup) > 0 then
					
					local unitsInCombat2 = false
					local unitsMoving = false
					local unitsAttacking = false
					for i2 = 1, SGroup_CountSpawned(moduleA.sgroup) do
						local squad2 = SGroup_GetSquadAt(moduleA.sgroup, i2)	
						if(Squad_IsUnderAttack(squad2, 3)) then
							unitsInCombat2 = true
						end
						if(Squad_IsMoving(squad2) == true) then
							unitsMoving = true
						end
						if(Squad_IsAttacking(squad2, 5) == true) then
							unitsAttacking = true
						end
					end
					
					
					if(unitsInCombat2 == true and unitsMoving == false) then
						--actually split the units away from the roving army
						WallD_ArchersBlocked(moduleA)
						splitUnits = true
					end
					
				end
			end
		end
	end
	
	--delay merging back idle ranged units if any have just split off
	if(splitUnits == true) then
		wallDArcherSplitTime = World_GetGameTime() + 3
	end
	
	
	
	WallD_CheckIdleRanged()
	
end


function WallD_CheckIdleRanged()
	local foundValidTarget = false
	local hasMergedRanged = false
	local anyUnitsIdle = true
	local anyUnitsAttacking = false
	if(SGroup_CountSpawned(sg_idleRanged) > 0) then
		
		local unitsInCombat = false
		for i = 1, SGroup_CountSpawned(sg_idleRanged) do
			local squad = SGroup_GetSquadAt(sg_idleRanged, i)	
			if(Squad_IsUnderAttack(squad, 3)) then
				unitsInCombat = true
			end
		end
		
		if(unitsInCombat == true) then
			
			-- Create SGroups
			local sg_attackers = SGroup_CreateIfNotFound("sg_attackers")
			local sg_attackersAll = SGroup_CreateIfNotFound("sg_attackersAll")
			local sg_single2 = SGroup_CreateIfNotFound("sg_single2")
			
			Player_GetAllSquadsNearMarker(player1, sg_attackers, SGroup_GetPosition(sg_idleRanged), 50)
			Player_GetAllSquadsNearMarker(player1, sg_attackersAll, SGroup_GetPosition(sg_idleRanged), 50)
			
			--prefer to attack ranged units
			SGroup_Filter(sg_attackers, "ranged", FILTER_KEEP)
			
			for i = SGroup_CountSpawned(sg_idleRanged), 1, -1 do
				local squad = SGroup_GetSquadAt(sg_idleRanged, i)
				local attackSearchRange = 50
				if(Squad_IsMoving(squad) == true) then
					anyUnitsIdle = false
				end
				local isAttacking = false
				if(Squad_IsAttacking(squad, 5) == true) then
					anyUnitsAttacking = true
					isAttacking = true
				end
				
				local sg_attackTargetGroup = SGroup_CreateIfNotFound("sg_attackTargetGroup")
				Squad_GetAttackTargets(squad, sg_attackTargetGroup)
				if(SGroup_CountSpawned(sg_attackTargetGroup) == 0) then
					isAttacking = false
				end
				
				if(Squad_IsMoving(squad) == false and isAttacking == false) then
					SGroup_Single(sg_single, squad)
					
					--try prefered targets
					if (SGroup_Count(sg_attackers) > 0) then
						local s_closest_attacker = SGroup_GetClosestSquad(sg_attackers, Util_GetPosition(squad))
						if s_closest_attacker ~= nil then	
							--only attack if the unit is close enough
							if(Util_GetDistance(s_closest_attacker, Util_GetPosition(squad)) < attackSearchRange) then
								
								SGroup_Single(sg_single2, s_closest_attacker)
								Cmd_Attack(sg_single, sg_single2, false)
								foundValidTarget = true
							end
						end
					end
					--try all nearby targets
					if (foundValidTarget == false and SGroup_Count(sg_attackersAll) > 0) then
						local s_closest_attacker = SGroup_GetClosestSquad(sg_attackersAll, Util_GetPosition(squad))
						if s_closest_attacker ~= nil then	
							--only attack if the unit is close enough
							if(Util_GetDistance(s_closest_attacker, Util_GetPosition(squad)) < attackSearchRange) then
								
								SGroup_Single(sg_single2, s_closest_attacker)
								Cmd_Attack(sg_single, sg_single2, false)
								foundValidTarget = true
							end
						end
					end
					--attack move if no valid targets
					if(foundValidTarget == false) then
						Cmd_AttackMove(sg_single, mkr_player_wonder, false)
					end
					
					
				end
			end
			
			
		end
		
		local patrolName = "RangedWave_0"
		--if no targets are found, merge squad back into a roving army
		if(foundValidTarget == false and anyUnitsAttacking == false and anyUnitsIdle == true) then
			--only merge if enough time has passed
			if(World_GetGameTime() > wallDArcherSplitTime) then
				--RovingArmy_AddSGroup(MissionOMatic_FindModule(patrolName), sg_idleRanged)
				hasMergedRanged = true
				
				--now remove from idle group
				--SGroup_Clear(sg_idleRanged)
			end
		end
	end
	
	if(hasMergedRanged == true) then
		wallDArcherSplitTime = World_GetGameTime() + 3
	end
end

--? @shortdesc A function invoked when raiders become blocked
function WallD_ArchersBlocked(module)
	
		
	if scartype(module.sgroup) == ST_SGROUP and SGroup_CountSpawned(module.sgroup) > 0 then
		--
		SGroup_AddGroup(sg_idleRanged, module.sgroup)
		--RovingArmy_Disband(module)
		RovingArmy_RemoveSGroup(module, module.sgroup)
		--
	end
	
	
end

