function WallD_HealWalls()
	
	eg_player_walls = Player_GetAllEntities(player3)
	EGroup_Filter(eg_player_walls, "wall", FILTER_KEEP)
	
	if EGroup_IsEmpty(eg_player_walls) ~= true then
		EGroup_SetPlayerOwner(eg_player_walls, player1)
	end
	
	EGroup_Clear(eg_temp)
	eg_temp = Player_GetAllEntities(player1)
	EGroup_Filter(eg_temp, "wall", FILTER_KEEP)
	
	EGroup_SetAvgHealth(eg_temp, 1)

end

function WallD_WallsDamagedCheck()
	eg_temp = Player_GetAllEntities(player1)
	EGroup_Filter(eg_temp, "wall", FILTER_KEEP)
	
	if (EGroup_GetAvgHealth(eg_temp) < 0.995) then
		
		Util_StartIntel(EVENTS.WallsDamaged)
		
		Rule_RemoveMe()
	end
end

function WallD_ApproachingWaveContains(bp)
	sg_northgate = SGroup_CreateIfNotFound("sg_northgate")
	sg_southgate = SGroup_CreateIfNotFound("sg_southgate")
	
	World_GetSquadsNearMarker(player2, sg_northgate, mkr_player_gatenorth, OT_Player) 
	World_GetSquadsNearMarker(player2, sg_southgate, mkr_player_gatesouth, OT_Player) 
	
	SGroup_AddGroup(sg_northgate, sg_southgate)
	
	return SGroup_ContainsBlueprints(sg_northgate, bp, ANY)
end

--Gives the player resources periodically after the challenge has started
function WallD_TrickleResources()
		
		Player_AddResource(player1, RT_Gold, math.floor(200/12)*trickleIncomeMult, RES_Resourcing)
		Player_AddResource(player1, RT_Food, math.floor(200/12)*trickleIncomeMult, RES_Resourcing)
		Player_AddResource(player1, RT_Wood, math.floor(150/12)*trickleIncomeMult, RES_Resourcing)
		Player_AddResource(player1, RT_Stone, math.floor(150/12)*trickleIncomeMult, RES_Resourcing)
end

function _WallD_QueueVillagerRespawn(context, data)
	Rule_AddOneShot(WallD_VillagerRespawn, 30)
end

function WallD_VillagerRespawn()
	if SGroup_CountSpawned(sg_player_villagers) < 8 then 		
		if Player_GetPopulationPercentage(player1, CT_Personnel) < 1 then
			SGroup_Clear(sg_temp)
			UnitEntry_DeploySquads(player1, sg_player_villagers, {{type = "scar_villager", numSquads = 1, sgroup = sg_temp}}, mkr_playervillagerrespawn)
			Rule_AddSGroupEvent(_WallD_QueueVillagerRespawn, sg_temp, GE_SquadKilled, data)
			SGroup_RemoveAbility(sg_temp, BP_GetAbilityBlueprint("core_unit_death"))			
			if bool_CTACooldown == false then
				bool_CTACooldown = true
				EventCues_CallToAction("$11220632", CTA_CELEBRATE, nil, nil,   mkr_playervillagerrespawn, 20) --Villagers have returned!
				Rule_AddOneShot(WallD_ResetVillagerCTA, 60)
			end			
		else
			int_unspawnedVillagers = int_unspawnedVillagers or 0
			int_unspawnedVillagers = int_unspawnedVillagers+1
			
			if Rule_Exists(WallD_SpawnUnspawnedVillagers) ~= true then
				Rule_AddInterval(WallD_SpawnUnspawnedVillagers, 2)
			end
		end		
	end
end

function WallD_SpawnUnspawnedVillagers()
	if Player_GetPopulationPercentage(player1, CT_Personnel) < 1 then 
		if int_unspawnedVillagers > 0 and SGroup_CountSpawned(sg_player_villagers) ~= 8 then
			local int_availablePop = Player_GetCurrentPopulationCap(player1, CT_Personnel) - Player_GetCurrentPopulation(player1, CT_Personnel)
			local int_spawnableVillagers = int_unspawnedVillagers
			if int_availablePop < int_spawnableVillagers then
				int_spawnableVillagers = int_unspawnedVillagers - int_availablePop
			end
			SGroup_Clear(sg_temp)
			UnitEntry_DeploySquads(player1, sg_player_villagers, {{type = "scar_villager", numSquads = int_spawnableVillagers, sgroup = sg_temp}}, mkr_playervillagerrespawn)
			Rule_AddSGroupEvent(_WallD_QueueVillagerRespawn, sg_temp, GE_SquadKilled, data)
			SGroup_RemoveAbility(sg_temp, BP_GetAbilityBlueprint("core_unit_death"))
			if int_spawnableVillagers > 0 and bool_CTACooldown == false then
				bool_CTACooldown = true
				EventCues_CallToAction("$11220632", CTA_CELEBRATE, nil, nil,   mkr_playervillagerrespawn, 12) --Villagers have returned!
				Rule_AddOneShot(WallD_ResetVillagerCTA, 60)
			end
			int_unspawnedVillagers = int_unspawnedVillagers - int_spawnableVillagers
		else 
			Rule_RemoveMe()
		end
	end
end

function WallD_ResetVillagerCTA()
	bool_CTACooldown = false
end

function WallD_TraderLoop()
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player3, sg_player_traders, {{type = "scar_trade_cart", numSquads = 1, sgroup = sg_temp}}, mkr_playertrader_spawn)
	Cmd_Move(sg_temp, mkr_playertraders_target)
	Rule_AddOneShot(_WallD_DelayTraderDepart, 8, {squad = SGroup_GetSquadAt(sg_temp, 1)})
end

function _WallD_DelayTraderDepart(context, data)
	SGroup_Clear(sg_single)
	SGroup_Single(sg_single, data.squad)
	Cmd_MoveToAndDestroy(sg_single, mkr_playertrader_spawn, true)
end

------------------------
-- VO Reminder functions
------------------------

function WallD_RamCheck()
	
	if World_GetGameTime() > lastEventTime + eventCD then
		if WallD_ApproachingWaveContains(SBP.MONGOL.UNIT_RAM_3_MON) then
			Util_StartIntel(EVENTS.Rams)
			
			lastEventTime = World_GetGameTime()
			Rule_RemoveMe()
		end
	end
end

function WallD_TowerCheck()
	
	if World_GetGameTime() > lastEventTime + eventCD then
		if WallD_ApproachingWaveContains(SBP.MONGOL.UNIT_SIEGE_TOWER_3_MON) then
			Util_StartIntel(EVENTS.SiegeTowers)
			
			lastEventTime = World_GetGameTime()
			Rule_RemoveMe()
		end
	end
end

function WallD_MangonelCheck()
	
	if World_GetGameTime() > lastEventTime + eventCD then
		if WallD_ApproachingWaveContains(SBP.MONGOL.UNIT_MANGONEL_3_MON) then
			Util_StartIntel(EVENTS.Mangonels)
			
			lastEventTime = World_GetGameTime()
			Rule_RemoveMe()
		end
	end
end

function WallD_TrebuchetCheck()
	
	if World_GetGameTime() > lastEventTime + eventCD then
		if WallD_ApproachingWaveContains(SBP.MONGOL.UNIT_TREBUCHET_4_CW_MON) or WallD_ApproachingWaveContains(SBP.MONGOL.UNIT_BOMBARD_4_MON) then
			Util_StartIntel(EVENTS.Trebuchets)
			
			lastEventTime = World_GetGameTime()
			Rule_RemoveMe()
		end
	end
end

function WallD_SpendResources1()
	
	if World_GetGameTime() > lastEventTime + eventCD then
		if World_GetGameTime() > resourceReminderTime + resourceReminderCD then
			if Player_GetResource(player1, RT_Food) > 500 and Player_GetResource(player1, RT_Wood) > 500 and Player_GetResource(player1, RT_Gold) > 500 then
				Util_StartIntel(EVENTS.SpendResources1)
				
				lastEventTime = World_GetGameTime()
				resourceReminderTime = World_GetGameTime()
				Rule_RemoveMe()
			end
		end
	end	
end

function WallD_SpendResources2()
	
	if World_GetGameTime() > lastEventTime + eventCD then
		if World_GetGameTime() > resourceReminderTime + resourceReminderCD then
			if Player_GetResource(player1, RT_Food) > 500 and Player_GetResource(player1, RT_Wood) > 500 and Player_GetResource(player1, RT_Gold) > 500 then
				Util_StartIntel(EVENTS.SpendResources2)
				
				lastEventTime = World_GetGameTime()
				resourceReminderTime = World_GetGameTime()
				Rule_RemoveMe()
			end
		end
	end	
end