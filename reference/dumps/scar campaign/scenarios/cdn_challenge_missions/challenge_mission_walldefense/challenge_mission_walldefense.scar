function WallD_InitObjectives()
	
	OBJ_ConstructWonder = {
		
		Title = "$11220626",
		Type = ObjectiveType_Battle,
		
		PreStart = function()
			Player_SetResource( player1, RT_Food, 	3000)
			Player_SetResource( player1, RT_Wood, 	2400)
			Player_SetResource( player1, RT_Gold, 	2400)
			Player_SetResource( player1, RT_Stone, 	600)
			
			player_speedProduction = Modify_PlayerProductionRate(player1, 1000)
		end,
		OnStart = function()			
		end,
		IsComplete = function()
						
			return EGroup_GetAvgHealth(eg_player_wonder) == 1.0
		end,
		OnComplete = function()
			
			Modifier_Remove(player_speedProduction)
			WallD_StartBronze()
			Objective_Start(OBJ_Victory)
			Rule_AddInterval(WallD_TraderLoop, 10)
			Objective_Complete(SOBJ_SpendResources)
			Objective_Complete(SOBJ_QuickBuild)
			
			HintPoint_Remove(hint_wonderWarning)
			HintPoint_Remove(hint_gatehint_left)
			HintPoint_Remove(hint_gatehint_right)
			
		end,
	}
	
	
	SOBJ_SpendResources = {
		
		Title = "$11220633", --Spend your resources on your defenses, traders will deliver more after the Wonder is completed.
		Type = ObjectiveType_Tip,
		--Parent = OBJ_ConstructWonder,
		StartAlongsideParent = true,
		showTitle = false,
	}
	SOBJ_QuickBuild= {
		
		Title = "$11220634", --Units and technology will instantly complete until the Wonder is built.
		Type = ObjectiveType_Tip,
		--Parent = OBJ_ConstructWonder,
		StartAlongsideParent = true,
		showTitle = false,
	}
	
	OBJ_Victory = {
		
		Title = "$11220625",
		Type = ObjectiveType_Battle,
		
		PreStart = function()
		end,
		OnStart = function()
			Objective_StartTimer(OBJ_Victory, COUNT_DOWN, waveDuration, 0)
			Rule_AddInterval(WallD_TrickleResources, 5)
			Rule_AddOneShot(WallD_BronzeComplete, bronzeTime)
			Rule_AddOneShot(WallD_SilverComplete, silverTime)
			Rule_AddOneShot(WallD_TimerComplete, waveDuration)
			Missionomatic_ChallengeInit({ kpiType = "countDown", goalBronze = bronzeTime, goalSilver = silverTime, goalGold = goldTime })
		end,
		IsComplete = function()
			return EGroup_IsEmpty(eg_player_wonder)
		end,
		OnComplete = function()
			Mission_Complete()
		end,
	}
	Objective_Register(OBJ_ConstructWonder)
	Objective_Register(SOBJ_SpendResources)
	Objective_Register(SOBJ_QuickBuild)
	Objective_Register(OBJ_Victory)
	
end

function WallD_SpawnPlayerUnits()
	
	UnitEntry_DeploySquads(player1, sg_player_villagers, { type = "scar_villager", numSquads = 4 }, mkr_playervillagers1)
	UnitEntry_DeploySquads(player1, sg_player_villagers, { type = "scar_villager", numSquads = 4 }, mkr_playervillagers2)

	UnitEntry_DeploySquads(player1, sg_player_officials, { type = "scar_official", numSquads = 3 }, mkr_player_officials)
	
	--this needs to be called on the next frame
	Rule_AddOneShot(Walld_Disable_Tax, 0)
	
end

function WallD_SpawnWaves(unitList)
	waveSGroups = {}	
	
	-- Spawn sgroups from unit list
	for k, v in ipairs(unitList) do
		local spawnLocation = {
			{
				mkr_mongol_spawnnorth1,
				mkr_mongol_spawnnorth2,
				mkr_mongol_spawnnorth3,
				mkr_mongol_spawnnorth4,
			},
			{
				mkr_mongol_spawnsouth1,
				mkr_mongol_spawnsouth2,
				mkr_mongol_spawnsouth3,
				mkr_mongol_spawnsouth4,
			}
		}
		
		-- Alternate north/south spawns
		
			-- Alternate north/south routes
		local numLanes = 2
		
		local routeIndex = (k % numLanes)+1
		
		local spawnRoute = spawnLocation[routeIndex]
		
		local spawnNumber = math.floor((k/2)+0.5)
		
		local newSGroup = SGroup_CreateUnique()
		
		UnitEntry_DeploySquads(player2, newSGroup, v, spawnRoute[spawnNumber])
		FOW_PlayerRevealSGroup(player1, newSGroup, 20, -1)
			
		table.insert(waveSGroups, newSGroup)
		
		waveSpawnedCount = waveSpawnedCount + 1
	end	
	
	Rule_AddInterval(WallD_SendWave, waveSpawnInterval)
end

function WallD_SendWave() -- Send spawned sgroups in a new roving module
	
	local early_routeList = {
		{
			mkr_mongol_rallynorth,
			mkr_player_gatenorth,	
		},
		{
			mkr_mongol_rallysouth,
			mkr_player_gatesouth,
		},		
	}
	
		local late_routeList = {
		{
			mkr_mongol_rallynorth,
			mkr_mongol_north_alt_left,
			mkr_mongol_north_alt_gate,
			mkr_player_gatenorth,

		},
		{
			mkr_mongol_rallysouth,
			mkr_mongol_south_alt_left,
			mkr_mongol_south_alt_gate,
			mkr_player_gatesouth,

		},
		{
			mkr_mongol_rallynorth,
			mkr_mongol_north_alt_right,
			mkr_mongol_north_alt_gate,
			mkr_player_gatenorth,

		},
		{
			mkr_mongol_rallysouth,
			mkr_mongol_south_alt_right,
			mkr_mongol_south_alt_gate,
			mkr_player_gatesouth,

		},		
	}
	
	local routeList = {
		
	}
	
	-- Alternate north/south routes
	local choosenRouteList = early_routeList
	local numLanes = 2
	if waveSentCount > 16 then
		numLanes = 4
		choosenRouteList = late_routeList
	end
	
	local routeIndex = (waveSentCount % numLanes)+1
		
	-- Initialize a new module, and add the next sgroup
	local moduleData = {
		descriptor = "Wave" .. tostring(waveSentCount), 				
		type = "RovingArmy",
		player = player2,
		targetingType = ARMY_TARGETING_DISCARD,
		onlyAtTargetForFinal = true,
		attackMoveEnRoute = attackMoveStyle_ignoreEverything,
		attackMoveAtTarget = attackMoveStyle_targetWonder,		
		targets = choosenRouteList[routeIndex],
	}		
	local newModule = RovingArmy_Init(moduleData)
	RovingArmy_AddSGroup(newModule, waveSGroups[1], true)
	
	--set group to use spread formation
	if scartype(newModule.sgroup) == ST_SGROUP and SGroup_CountSpawned(newModule.sgroup) > 0 then
		Cmd_Ability(newModule.sgroup, BP_GetAbilityBlueprint("core_formation_spread"))
		
	end
	
	table.insert(waveModuleTable, newModule)
	table.remove(waveSGroups, 1)
	
	if medalWaveCount == 1 then
		EventCues_CallToAction("$11220627", CTA_ALARM, EVENTS.WaveStart, nil, waveModuleTable[1].sgroup, 20) -- Enemy attacks have begun to approach
	end
	
	print("Sending wave " .. waveSentCount)
	
	
	if waveSentCount == 1 then -- Add hooks for contextual vo events
		Rule_AddInterval(WallD_RamCheck, 4)
		Rule_AddInterval(WallD_WallsDamagedCheck, 4)
		Rule_AddInterval(WallD_TowerCheck, 4)
		Rule_AddInterval(WallD_MangonelCheck, 4)
		Rule_AddInterval(WallD_TrebuchetCheck, 4)
	end	
	
	WallD_PatrolWaves()	
	WallD_RangedWaves()	
	
	-- Increment wavecount, and kill Rule if we've launched the last wave
	waveSentCount = waveSentCount + 1
	medalWaveCount = medalWaveCount + 1
				
	if #waveSGroups == 0 then
		Rule_RemoveMe()
	end
end

