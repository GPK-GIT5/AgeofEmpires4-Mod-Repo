-------------------------------------------------------------------------
---- Challenge Mission: Early Economy - Tutorial Elements
-------------------------------------------------------------------------

import("training/coretrainingconditions.scar")
import("training/coretraininggoals.scar")

Core_RegisterModule("EarlyEconomyTrainingGoals")

--------------------------------------------------------------------------------------
-- Variables for the dynamic training hints - Feel free to adjust this.
__t_challengeStartIdleTC = 15
__t_challengeIntervalIdleTC = 5
__t_challengeIdleTCRepeatMax = -1
__t_challengeStartIdleVillager = 10
__t_challengeIntervalIdleVillager = 5
__t_challengeIdleVillagerRepeatMax = -1
__t_challengeStartIdleScout = 20
__t_challengeIntervalIdleScout = 10
__t_challengeIdleScoutRepeatMax = -1
__n_challengeScoutAreasToExplore = 3
local __n_challengeScoutRepeatMaxCurrentSession = 0
--------------------------------------------------------------------------------------


local exploredWest = false
local exploredEast = false
local exploredNorthWest = false
local exploredNorth = false 
local exploredSouth = false
local areasExplored = 0

local goal_sequence_villager_training = "train_villager"
local goal_sequence_idle_villager = "idle_villager"
local goal_sequence_idle_scout = "idle_scout"

local training_goals_early_economy = 
{ 
	goal_sequence_villager_training,
	goal_sequence_idle_villager,
	goal_sequence_idle_scout	
} 

function TrainingGoal_EnableEarlyEconomyGoals()
	for i, goalSequenceID in ipairs(training_goals_early_economy) do
		Training_EnableGoalSequenceByID(goalSequenceID, true)
	end
end

function TrainingGoal_DisableEarlyEconomyGoals()
	for i, goalSequenceID in ipairs(training_goals_early_economy) do
		Training_EnableGoalSequenceByID(goalSequenceID, false)
	end
end

function EarlyEconomyTrainingGoals_InitVillagerTraining_Xbox()
	
	-- Train a villager
	local selectTCGoal = Training_Goal("Entity",
		{ID="Select your Town Center to train Villagers.", Message= "$11202187", DataTemplate="GenericTrainingDataTemplate"},
		UserHasSelectedTownCenter)
	
	local openRadialGoal = Training_Goal("Entity",
		{ID= "Press RT to open the radial menu.", Message= "$1000968", DataTemplate="GenericTrainingDataTemplate"}, 
		UserHasOpenedContextualRadial)
	
	local buildVillGoal = Training_Goal("PBG",
		{ID= "Select this option to queue production of additional Villagers.", Message= "$11249020", DataTemplate="GenericTrainingDataTemplate"}, 
		TCHasStartedToTrainAVillager)
	
	local trainVillagerSequence = Training_GoalSequence(goal_sequence_villager_training,
		__t_challengeIdleTCRepeatMax, 0,
		UserHasIdleTownCenter_Xbox, 
		nil,--NoIdleVillagers, 
		nil,
		nil,
		true,
		{selectTCGoal, openRadialGoal, buildVillGoal})
	Training_AddGoalSequence(trainVillagerSequence)
end

function EarlyEconomyTrainingGoals_InitVillagerTraining()
	
	-- Train a villager
	local selectTCGoal = Training_Goal("Entity",
		{ID="Select your Town Center to train Villagers.", Message= "$11202187", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedTownCenter)
	
	local buildVillGoal = Training_Goal("PBG",
		{ID= "Click here to queue up additional Villagers.", Message= "$11202188", DataTemplate="LeftClickTrainingDataTemplate"}, 
		TCHasStartedToTrainAVillager)
	
	local trainVillagerSequence = Training_GoalSequence(goal_sequence_villager_training,
		__t_challengeIdleTCRepeatMax, 0,
		UserHasIdleTownCenter, 
		nil,--NoIdleVillagers, 
		nil,
		nil,
		true,
		{selectTCGoal, buildVillGoal})
	Training_AddGoalSequence(trainVillagerSequence)
end

function EarlyEconomyTrainingGoals_OnInit()
	
	-- Disable core training goals for testing purposes
	-- TrainingGoal_DisableCoreControlGoals()
	-- TrainingGoal_DisableCoreEconGoals()
	
	-------------------------------------------------------------------------
	---- Goal Sequences
	-------------------------------------------------------------------------
	
	if UI_IsXboxControllerUI() then
		EarlyEconomyTrainingGoals_InitVillagerTraining_Xbox()
	else
		EarlyEconomyTrainingGoals_InitVillagerTraining()   
	end
	
	-- Use idle Villager
	local selectNextIdleVillagerGoal = Training_Goal("PBG",
		{ID= "Select the next idle Villager and assign it to a job.", Message= "$11202189", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedAnIdleVillager)
	local selectNextIdleVillagerSequence = Training_GoalSequence(goal_sequence_idle_villager,
		__t_challengeIdleVillagerRepeatMax, 0,
		SelectNextIdleIfVillagersIdle, 
		NoIdleVillagers, 
		nil,
		nil,
		true,
		{selectNextIdleVillagerGoal})
	Training_AddGoalSequence(selectNextIdleVillagerSequence)
	
	-- Use idle scout
	local selectScoutGoal = Training_Goal("Squad",
		{ID= "Do not forget about your Scout. You must explore to find more resources.", Message= "$11202190", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedAScout)
	local selectScoutSequence = Training_GoalSequence(goal_sequence_idle_scout,
		__t_challengeIdleScoutRepeatMax, 0,
		UserHasIdleScout, 
		EnoughMarkersExplored, 
		nil,
		nil,
		true,
		{selectScoutGoal})
	Training_AddGoalSequence(selectScoutSequence)
	
end


-----------------------------------------------------------------------
-- Functions, Goals, & Predicates
-----------------------------------------------------------------------

-- Predicate - When the player's Town Center is idle it will prompt the player to select it.
function UserHasIdleTownCenter_Xbox(goalSequence)
	
	-- For every player
	for i, player in pairs(PLAYERS) do
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			if player._challenge ~= nil then
				local currentTime = Timer_GetElapsed(goalSequence.timerID)
				local timeElapsed = World_GetGameTime() - player._challenge.startTime
				
				-- give the player some time at the start
				if timeElapsed >= __t_challengeStartIdleVillager then
					
					local currentTime = Timer_GetElapsed(goalSequence.timerID)
					if currentTime > __t_challengeIntervalIdleVillager then
						local localPlayer = Game_GetLocalPlayer()
						local villagerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", localPlayer)
						
						Player_GetAll(localPlayer)
						EGroup_Filter(eg_allentities, "town_center", FILTER_KEEP)
						EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
						local aTownCenterExists = EGroup_Count(eg_allentities) > 0

						if aTownCenterExists then
							local townCenter = EGroup_GetEntityAt(eg_allentities, 1)	
							local villagerCost = Player_GetSquadBPCost(localPlayer, villagerBP)
							local foodResources = Player_GetResource(localPlayer, RT_Food)
							
							-- Check if the player still needs to train villagers
							if Objective_IsComplete(_challenge.victory.objectiveVillagers) then
								return false						
							end
							
							-- Check if the town center is producing a villager
							if Entity_IsProducingSquad(townCenter, villagerBP) then
								return false
							end
							
							-- Check if the player has the resources and population space to train more villagers
							if foodResources >= villagerCost.food and Player_GetCurrentPopulation(localPlayer, CT_Personnel) < Player_GetCurrentPopulationCap(localPlayer, CT_Personnel) then
								goalSequence.goals[1].key = Entity_GetID(townCenter)
								goalSequence.goals[2].key = Entity_GetID(townCenter)
								goalSequence.goals[3].key = villagerBP
								return true
							end
						end
					end
				end
			end
		end
	end
	
	return false
	
end

