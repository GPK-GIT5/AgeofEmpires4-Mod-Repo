-- IsComplete - Check whether the user is training a Villager.
function UserIsTrainingVillager(goalSequence)
	local localPlayer = Game_GetLocalPlayer()
	local villagerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", localPlayer)
	
	Player_GetAll(localPlayer)
	EGroup_Filter(eg_allentities, "town_center", FILTER_KEEP)
	EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
	local aTownCenterExists = EGroup_Count(eg_allentities) > 0

	if aTownCenterExists then
		local townCenter = EGroup_GetEntityAt(eg_allentities, 1)
	
		if Entity_IsProducingSquad(townCenter, villagerBP) then
			return true
		end
	end
	
	return false
end

-- IsComplete - Check whether the player has selected the Town Center.
function UserHasSelectedTownCenter(goal)
	Misc_GetSelectedEntities(eg_currentSelection, false)
	if EGroup_Count(eg_currentSelection) == 1 then
		local entity = EGroup_GetEntityAt(eg_currentSelection, 1)
		if Entity_GetID(entity) == goal.key then
			return true
		end
	end
	
	return false
end

-- IsComplete - Check whether the player has started to train a Villager at the selected Town Center.
function TCHasStartedToTrainAVillager(goal)
	local villagerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", Game_GetLocalPlayer())
	
	Misc_GetSelectedEntities(eg_currentSelection, false)
	if EGroup_Count(eg_currentSelection) == 1 then
		local townCenter = EGroup_GetEntityAt(eg_currentSelection, 1)
		return Entity_IsProducingSquad(townCenter, villagerBP)
	end
	
	return false
end

----------------------------------------------------------------------------------------------

-- Predicate - If a villager is idle for a certain amount of time it prompts the player to click on the "population button".
function SelectNextIdleIfVillagersIdle(goalSequence)
	
	-- For every player
	for i, player in pairs(PLAYERS) do
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			if player._challenge ~= nil then
				local timeElapsed = World_GetGameTime() - player._challenge.startTime
				
				-- give the player some time at the start
				if timeElapsed >= __t_challengeStartIdleVillager then
					
					local villagerIsIdle = false
					local localPlayer = Game_GetLocalPlayer()
					local villagerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", localPlayer)
					local squads = Player_GetSquads(localPlayer)
					
					goalSequence.goals[1].idleVillagers = {}
					
					for i = 1, SGroup_Count(squads) do
						local squad = SGroup_GetSquadAt(squads, i)
						
						if Squad_IsIdle(squad) and Squad_GetBlueprint(squad) == villagerBP then
							villagerIsIdle = true
							break
						end
					end
					
					if villagerIsIdle then
						if Timer_IsPaused(goalSequence.timerID) then
							Timer_Resume(goalSequence.timerID)
						end
					else
						if not Timer_IsPaused(goalSequence.timerID) then
							Timer_Pause(goalSequence.timerID)
						end
					end
					
					local currentTime = Timer_GetElapsed(goalSequence.timerID)
					if currentTime > __t_challengeIntervalIdleVillager and villagerIsIdle then
						goalSequence.goals[1].key = "PopulationButton"
						return true
					end
					
					goalSequence.goals[1].key = nil
				end
			end
		end
	end
	
	return false
end


----------------------------------------------------------------------------------------------

-- Predicate - If a Scout is idle it will prompt the player to use it.
function UserHasIdleScout(goalSequence)
	
	-- For every player
	for i, player in pairs(PLAYERS) do
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			if player._challenge ~= nil then
				local timeElapsed = World_GetGameTime() - player._challenge.startTime
				local currentTime = Timer_GetElapsed(goalSequence.timerID)
				-- give the player some time at the start
				if timeElapsed >= __t_challengeStartIdleScout then
					
					local scoutIsIdle = false
					local localPlayer = Game_GetLocalPlayer()
					local scoutBP = Cardinal_ConvertTypeToSquadBlueprint("scout", localPlayer)
					local squads = Player_GetSquads(localPlayer)
					
					goalSequence.goals[1].idleScout = {}
					
					local scout = nil
					for i = 1, SGroup_Count(squads) do
						local squad = SGroup_GetSquadAt(squads, i)
						
						if Squad_IsIdle(squad) and Squad_GetBlueprint(squad) == scoutBP then
							scoutIsIdle = true
							scout = SGroup_GetSquadAt(squads, i)
							break
						end
					end
					
					if scoutIsIdle then
						if Timer_IsPaused(goalSequence.timerID) then
							Timer_Resume(goalSequence.timerID)
						end
					else
						if not Timer_IsPaused(goalSequence.timerID) then
							Timer_Pause(goalSequence.timerID)
						end
					end
					
					local currentTime = Timer_GetElapsed(goalSequence.timerID)
					if currentTime > __t_challengeIntervalIdleScout and scoutIsIdle and __n_challengeScoutRepeatMaxCurrentSession < 5 then
						goalSequence.goals[1].key = Squad_GetID(scout)
						__n_challengeScoutRepeatMaxCurrentSession = __n_challengeScoutRepeatMaxCurrentSession + 1
						return true
					end
					
					goalSequence.goals[1].key = nil
				end
			end
		end
	end
	return false	
end

-- Ignore - Checks whether the player has explored __n_challengeScoutAreasToExplore areas.
function EnoughMarkersExplored(goalSequence)
	
	local westMarker = Marker_GetPosition(mkr_exploration_west)
	local eastMarker = Marker_GetPosition(mkr_exploration_east)
	local northwestMarker = Marker_GetPosition(mkr_exploration_northwest)
	local northMarker = Marker_GetPosition(mkr_exploration_north)
	local southMarker = Marker_GetPosition(mkr_exploration_south)
	
	if Player_CanSeePosition(localPlayer, westMarker) and exploredWest == false then
		areasExplored = areasExplored + 1
		exploredWest = true
	end
	if Player_CanSeePosition(localPlayer, eastMarker) and exploredEast == false then
		areasExplored = areasExplored + 1
		exploredEast = true
	end
	if Player_CanSeePosition(localPlayer, northwestMarker) and exploredNorthWest == false then
		areasExplored = areasExplored + 1
		exploredNorthWest = true
	end
	if Player_CanSeePosition(localPlayer, northMarker) and exploredNorth == false then
		areasExplored = areasExplored + 1
		exploredNorth = true
	end
	if Player_CanSeePosition(localPlayer, southMarker) and exploredSouth == false then
		areasExplored = areasExplored + 1
		exploredSouth = true
	end
	
	if areasExplored >= __n_challengeScoutAreasToExplore then
		return true
	end
	return false
end
