-----------------------------------------------------------------------

--_preintro = {}

-----------------------------------------------------------------------
-- Functions
-----------------------------------------------------------------------


-- Prepares the intro shots.
function EarlyEconomy_PreIntro_Setup_Scenes()
	
	-- Create SGroups
	eg_all_neutral = EGroup_CreateIfNotFound("eg_all_neutral")
	eg_sheep_corpse = SGroup_CreateIfNotFound("eg_sheep_corpse")
	eg_deer_corpse = EGroup_CreateIfNotFound("eg_deer_corpse")
	sg_preintro_player_villagers = SGroup_CreateIfNotFound("sg_preintro_player_villagers")
	sg_preintro_player_villagers02 = SGroup_CreateIfNotFound("sg_preintro_player_villagers02")
	sg_preintro_player_trained_villager = SGroup_CreateIfNotFound("sg_preintro_player_trained_villager")
	sg_preintro_player_first_sheep = SGroup_CreateIfNotFound("sg_preintro_player_first_sheep")
	sg_preintro_player_scout = SGroup_CreateIfNotFound("sg_preintro_player_scout")
	sg_preintro_player_second_sheep = SGroup_CreateIfNotFound("sg_preintro_player_second_sheep")
	sg_preintro_player_house_builders = SGroup_CreateIfNotFound("sg_preintro_player_house_builders")
	sg_preintro_player_mill_builders = SGroup_CreateIfNotFound("sg_preintro_player_mill_builders")
	sg_preintro_player_lumber_camp_builders = SGroup_CreateIfNotFound("sg_preintro_player_lumber_camp_builders")
	sg_preintro_first_deer = SGroup_CreateIfNotFound("sg_preintro_first_deer")
	sg_preintro_player_hunters = SGroup_CreateIfNotFound("sg_preintro_player_hunters")
	sg_preintro_player_hunter02 = SGroup_CreateIfNotFound("sg_preintro_player_hunter02")
	sg_preintro_player_hunter03 = SGroup_CreateIfNotFound("sg_preintro_player_hunter03")
	sg_preintro_second_deer = SGroup_CreateIfNotFound("sg_preintro_second_deer")
	sg_preintro_player_landmark_builders = SGroup_CreateIfNotFound("sg_preintro_player_landmark_builders")
	sg_preintro_player_landmark_builders01 = SGroup_CreateIfNotFound("sg_preintro_player_landmark_builders01")
	sg_preintro_player_landmark_builders02 = SGroup_CreateIfNotFound("sg_preintro_player_landmark_builders02")
	
	houseBP = EBP.ENGLISH.BUILDING_HOUSE_CONTROL_ENG
	millBP = EBP.ENGLISH.BUILDING_ECON_FOOD_CONTROL_ENG
	lumberCampBP = EBP.ENGLISH.BUILDING_ECON_WOOD_CONTROL_ENG
	landmarkBP = EBP.ENGLISH.BUILDING_LANDMARK_AGE1_WESTMINSTER_HALL_ENG
			
end

-- Sets up the first shot of the intro. A sheep moves to the town center, villagers kill it, and gather from it.
function EarlyEconomy_PreIntro_Shot01_Units()
	
	-- Deploy units
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_villagers, {type = "scar_villager", numSquads = 1 }, mkr_preintro_01_villager_spawn)	
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_villagers02, {type = "scar_villager", numSquads = 1 }, mkr_preintro_01_villager02_spawn)	
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_first_sheep, {{sbp = BP_GetSquadBlueprint("gaia_herdable_sheep"), numSquads = 1 }}, mkr_preintro_01_sheep_spawn)
	
	for i = 1, 4 do
		UnitEntry_DeploySquads(localPlayer, sg_preintro_first_deer, {{sbp = BP_GetSquadBlueprint("gaia_huntable_deer"), numSquads = 1 }}, Util_GetRandomPosition(mkr_preintro_03_deer_spawn))
	end
	--for i = 1, 3 do
		--UnitEntry_DeploySquads(localPlayer, sg_preintro_second_deer, {{sbp = BP_GetSquadBlueprint("gaia_huntable_deer"), numSquads = 1 }}, Util_GetRandomPosition(mkr_preintro_04_deer_spawn))
	--end
	
	local _ChangeToGaia = function(gid, idx, eid)
		Squad_SetWorldOwned(eid)
	end
	
	SGroup_ForEach(sg_preintro_player_first_sheep, _ChangeToGaia)
	
	-- Moves the sheep closer to the Town Center
	Cmd_Move(sg_preintro_player_first_sheep, mkr_preintro_01_sheep_rally)
	
	-- Has the villagers kill and gather from the sheep
	Rule_AddOneShot(EarlyEconomy_PreIntro_Shot01_ButcherSheep, 0)
	Rule_AddOneShot(EarlyEconomy_PreIntro_Shot01_TrainVillager, 11)
	
end

function EarlyEconomy_PreIntro_Shot01_ButcherSheep()	
	LocalCommand_SquadSquad(localPlayer, sg_preintro_player_villagers, SCMD_Gather, sg_preintro_player_first_sheep, false)	
	LocalCommand_SquadSquad(localPlayer, sg_preintro_player_villagers02, SCMD_Gather, sg_preintro_player_first_sheep, false)
end

function EarlyEconomy_PreIntro_Shot01_TrainVillager()	
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_trained_villager, {type = "scar_villager", numSquads = 1 }, mkr_preintro_01_villager_spawn)	
	LocalCommand_SquadSquad(localPlayer, sg_preintro_player_trained_villager, SCMD_Gather, sg_preintro_player_first_sheep, false)
end

-- Sets up the second shot of the intro. Scout finds sheep and herds them to the town center. Then moves towards the deer.
function EarlyEconomy_PreIntro_Shot02_Units()
	
	-- Spawns the scout and sheep
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_scout, {type = "scar_scout", numSquads = 1 }, mkr_preintro_02_scout_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_second_sheep, {{sbp = BP_GetSquadBlueprint("gaia_herdable_sheep"), numSquads = 1 }}, mkr_preintro_02_second_sheep_spawn)
	
	-- Moves the scout to the Town Center

	Rule_AddOneShot(EarlyEconomy_PreIntro_Shot02_ScoutMoves, 3)
	Rule_AddInterval(EarlyEconomy_PreIntro_Shot02_HaltSheep, 1)	
	
end

function EarlyEconomy_PreIntro_Shot02_ScoutMoves()
	Cmd_FormationMove(sg_preintro_player_scout, mkr_preintro_02_scout_waypoint1, true)	
	Cmd_FormationMove(sg_preintro_player_scout, mkr_preintro_02_scout_waypoint2, true)
	Cmd_FormationMove(sg_preintro_player_scout, mkr_preintro_03_deer_spawn, true)
end

function EarlyEconomy_PreIntro_Shot02_HaltSheep()
	if Prox_MarkerSGroup(mkr_preintro_02_scout_waypoint2, sg_preintro_player_scout, PROX_SHORTEST) < 4 then	
		Cmd_Move(sg_preintro_player_scout, mkr_preintro_02_scout_rally, true)
		Cmd_Stop(sg_preintro_player_second_sheep)
		Cmd_Move(sg_preintro_player_second_sheep, mkr_preintro_02_second_sheep_rally, true)
		Rule_RemoveMe()
	end
	
end

-- Sets up the third shot of the intro. Villagers build a house, a mill, and a lumber camp.
function EarlyEconomy_PreIntro_Shot03_Units()
	-- Spawn builders and deer
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_house_builders, {type = "scar_villager", numSquads = 1}, mkr_preintro_03_villagers_construct_house)
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_mill_builders, {type = "scar_villager", numSquads = 2}, mkr_preintro_03_villagers_construct_mill)
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_lumber_camp_builders, {type = "scar_villager", numSquads = 1}, mkr_preintro_03_villagers_construct_lumber_camp)
	
	local HouseFacing = Util_GetFacingFromDirection(Marker_GetPosition(mkr_preintro_03_house), Marker_GetDirection(mkr_preintro_03_house))
	local MillFacing = Util_GetFacingFromDirection(Marker_GetPosition(mkr_preintro_03_mill), Marker_GetDirection(mkr_preintro_03_mill))
	local LumberCampFacing = Util_GetFacingFromDirection(Marker_GetPosition(mkr_preintro_03_lumber_camp), Marker_GetDirection(mkr_preintro_03_lumber_camp))
			
	-- Construct House
	LocalCommand_PlayerSquadConstructBuilding(localPlayer, sg_preintro_player_house_builders, houseBP, Util_GetPosition(mkr_preintro_03_house), HouseFacing, false)
	--Modify_EntityBuildTime(localPlayer, houseBP, 0.7)
	
	-- Construct Mill
	LocalCommand_PlayerSquadConstructBuilding(localPlayer, sg_preintro_player_mill_builders, millBP, Util_GetPosition(mkr_preintro_03_mill), MillFacing, false)
	--Modify_EntityBuildTime(localPlayer, millBP, 0.7)
	
	-- Construct Lumber Camp
	LocalCommand_PlayerSquadConstructBuilding(localPlayer, sg_preintro_player_lumber_camp_builders, lumberCampBP, Util_GetPosition(mkr_preintro_03_lumber_camp), LumberCampFacing, false)
	--Modify_EntityBuildTime(localPlayer, lumberCampBP, 0.7)
			
end

-- Sets up the fourth shot of the intro. Hunters shoot a deer and collect from it.
function EarlyEconomy_PreIntro_Shot04_Units()
	
	for i = 1, 3 do
		UnitEntry_DeploySquads(localPlayer, sg_preintro_second_deer, {{sbp = BP_GetSquadBlueprint("gaia_huntable_deer"), numSquads = 1 }}, Util_GetRandomPosition(mkr_preintro_04_deer_spawn))
	end
		
	-- Spawns the hunters
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_hunters, {type = "scar_villager", numSquads = 1 }, mkr_preintro_04_hunter_spawn)
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_hunter03, {type = "scar_villager", numSquads = 2 }, mkr_preintro_04_hunter03_spawn)
	
	-- Has the villagers kill and gather from the deer
	LocalCommand_SquadSquad(localPlayer, sg_preintro_player_hunters, SCMD_Gather, sg_preintro_second_deer, false)
	LocalCommand_SquadSquad(localPlayer, sg_preintro_player_hunter03, SCMD_Gather, sg_preintro_second_deer, false)
	
end

-- Sets up the fifth shot of the intro. Villagers start building a Landmark.
function EarlyEconomy_PreIntro_Shot05_Units()
		
	-- Spawns the builders
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_landmark_builders01, {type = "scar_villager", numSquads = 3}, mkr_preintro_05_landmark_builders_east)
	UnitEntry_DeploySquads(localPlayer, sg_preintro_player_landmark_builders02, {type = "scar_villager", numSquads = 4}, mkr_preintro_05_landmark_builders_west)
	
	SGroup_AddGroup(sg_preintro_player_landmark_builders, sg_preintro_player_landmark_builders01)
	SGroup_AddGroup(sg_preintro_player_landmark_builders, sg_preintro_player_landmark_builders02)
	
	local LandmarkFacing = Util_GetFacingFromDirection(Marker_GetPosition(mkr_preintro_05_landmark), Marker_GetDirection(mkr_preintro_05_landmark))
	
	-- Builds the Landmark
	LocalCommand_PlayerSquadConstructBuilding(localPlayer, sg_preintro_player_landmark_builders, landmarkBP, Util_GetPosition(mkr_preintro_05_landmark), LandmarkFacing, false)
	Modify_EntityBuildTime(localPlayer, landmarkBP, 0.25)
	
--move workers away from landmark once building is complete
	Cmd_Move(sg_preintro_player_landmark_builders02, mkr_preintro_05_landmark_builders_west, true)
	Cmd_FormationMove(sg_preintro_player_landmark_builders02, mkr_preintro_05_landmark_builders_west, true, false, mkr_preintro_05_landmark)
	
	Cmd_Move(sg_preintro_player_landmark_builders01, mkr_preintro_05_landmark_builders_corner, true)
	Cmd_FormationMove(sg_preintro_player_landmark_builders01, mkr_preintro_05_landmark_builders_corner, true, false, mkr_preintro_05_landmark)
	
end

-- Sets up the sixth shot of the intro. Landmark builders cheer.
function EarlyEconomy_PreIntro_Shot06_Units()
	
	SGroup_EnableCheering(sg_preintro_player_landmark_builders02, true, 10)
	Rule_AddOneShot(EarlyEconomy_PreIntro_Shot06_Cheer, 2.5)
end

function EarlyEconomy_PreIntro_Shot06_Cheer()
	
	if(sg_preintro_player_landmark_builders01 ~= nil) then
		SGroup_EnableCheering(sg_preintro_player_landmark_builders01, true, 7)
	end
end
-----------------------------------------------------------------------
-- Clean Up
-----------------------------------------------------------------------

-- Cleans up all units and buildings from the pre-intro
function EarlyEconomy_PreIntro_Clean_Scenes()
		
	Rule_Remove(EarlyEconomy_PreIntro_Shot01_ButcherSheep)	
	Rule_Remove(EarlyEconomy_PreIntro_Shot01_TrainVillager)	
	Rule_Remove(EarlyEconomy_PreIntro_Shot02_HaltSheep)	
	Rule_Remove(EarlyEconomy_PreIntro_Shot06_Cheer)	
	
	-- Deletes all added gaia objects
	SGroup_ForEach(sg_preintro_first_deer, Destroy)
	SGroup_ForEach(sg_preintro_second_deer, Destroy)
		
	-- Delete all player squads and entities 	
	Player_GetAll(localPlayer)
	EGroup_Filter(eg_allentities, "town_center", FILTER_REMOVE)		
	EGroup_ForEach(eg_allentities, DestroyEntity)
	SGroup_ForEach(sg_allsquads, Destroy)
	
	-- Despawn carcasses
	DespawnCarcasses()
	
	-- Reset build times
	Modify_EntityBuildTime(localPlayer, millBP, 1)
	Modify_EntityBuildTime(localPlayer, lumberCampBP, 1)
	Modify_EntityBuildTime(localPlayer, houseBP, 1)
	Modify_EntityBuildTime(localPlayer, landmarkBP, 1)
	
end

-- Clean up all entities and squads from the first scene
function EarlyEconomy_PreIntro_Shot01_Clean_Up()
end

-- Clean up all entities and squads from the second scene
function EarlyEconomy_PreIntro_Shot02_Clean_Up()
	-- Destroy herders and sheep
	SGroup_ForEach(sg_preintro_player_villagers, Destroy)
	SGroup_ForEach(sg_preintro_player_trained_villager, Destroy)
	SGroup_ForEach(sg_preintro_player_first_sheep, Destroy)
	
	-- Destroy carcasses
	DespawnCarcasses()
	
	-- Destroy scout and sheep
	SGroup_ForEach(sg_preintro_player_scout, Destroy)
	SGroup_ForEach(sg_preintro_player_second_sheep, Destroy)	

end

-- Clean up all entities and squads from the third scene
function EarlyEconomy_PreIntro_Shot03_Clean_Up()
	
	-- Destroy the builders and deer
	SGroup_ForEach(sg_preintro_player_house_builders, Destroy)
	SGroup_ForEach(sg_preintro_player_mill_builders, Destroy)
	SGroup_ForEach(sg_preintro_player_lumber_camp_builders, Destroy)
	
	-- Destroy carcasses
	DespawnCarcasses()
end

-- Clean up all entities and squads from the fourth scene
function EarlyEconomy_PreIntro_Shot04_Clean_Up()
	
	-- Destroy the hunters and spawned deer
	SGroup_ForEach(sg_preintro_player_hunters, Destroy)
	SGroup_ForEach(sg_preintro_player_hunter02, Destroy)
	SGroup_ForEach(sg_preintro_player_hunter03, Destroy)
	
	-- Destroy carcasses
	DespawnCarcasses()
	
	SGroup_ForEach(sg_preintro_first_deer, Destroy)
	SGroup_ForEach(sg_preintro_second_deer, Destroy)
	
	--EGroup_ForEach(eg_preintro_mill02, Destroy)
	
	EGroup_Destroy(eg_preintro_mill02)
	
	Player_GetAllEntitiesNearMarker(localPlayer, eg_temp, mkr_preintro_03_mill, 10)
    EGroup_Filter(eg_temp, {"mill"}, FILTER_KEEP)
    EGroup_DestroyAllEntities(eg_temp)
end

-- Clean up all entities and squads from the fifth scene
function EarlyEconomy_PreIntro_Shot05_Clean_Up()
	
end

-- Clean up all entities and squads from the sixth scene
function EarlyEconomy_PreIntro_Shot06_Clean_Up()
end


-----------------------------------------------------------------------
-- Additional Functions
-----------------------------------------------------------------------

-- Destroys a squad
function Destroy(gid, idx, eid)
	Squad_Destroy(eid)
end

-- Destroy an entity
function DestroyEntity(gid, idx, eid)
	Entity_Destroy(eid)	
end
	
function DespawnCarcasses()
		
	local _DespawnCarcass = function(gid, idx, eid)
		-- Checks if the entity is a carcass and destroys it
		if Entity_IsOfType(eid, "carriable") then	
			Entity_Destroy(eid)
		end
	end
	
	World_GetAllNeutralEntities(eg_all_neutral)
	EGroup_ForEach(eg_all_neutral, _DespawnCarcass)
end



