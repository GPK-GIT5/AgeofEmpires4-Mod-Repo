--
-- 
-- Objective Capture Town
--

function Capture_EnemiesTownInit()

	local location = LOCATION("FrenchCity")
	
	OBJ_CaptureEnemiesTown = {
		
		Title = "$a9c8269841ca40e8b2fea8b17a35e883:11", --Capture Enemy town
		Type = ObjectiveType_Capture,  --type of objective (ObjectiveType_Optional, ObjectiveType_Battle, ObjectiveType_Information)
	--	Intel_Start = EVENTS.CaptureTown, --voice over start before objective
		Intel_Complete = EVENTS.CaptureTown, --voice over start after objective completes

		OnStart = function()
			Location_SetCapturable(LOCATION("FrenchCity"), true)
			
		end,

		OnComplete = CaptureTown_OnComplete,
	}
	
	SOBJ_DefeatTownRebels = {
		
		Title = "$a9c8269841ca40e8b2fea8b17a35e883:12", -- Defeat Middlethorpe rebels
		Type = ObjectiveType_Capture,
		Parent = OBJ_CaptureEnemiesTown,
	}
	SOBJ_LocationTown = {
		Title = "$a9c8269841ca40e8b2fea8b17a35e883:6", -- Enemy Town name
		Type = ObjectiveType_Capture,
		Parent = OBJ_CaptureEnemiesTown,
	}
	
	Objective_Register(OBJ_CaptureEnemiesTown)
	Objective_Register(SOBJ_DefeatTownRebels)
	Objective_Register(SOBJ_LocationTown)
	
	location.objectivePrimary = OBJ_CaptureEnemiesTown
	location.objectiveSecondary = SOBJ_DefeatTownRebels
	location.objectiveCapture = SOBJ_LocationTown
	
	
end



function CaptureTown_OnComplete()
	Rule_AddOneShot(ObjectiveCompleteNow, 3)
end

function ObjectiveCompleteNow()
	Objective_Start(OBJ_DestroyBuildings)
	--Mission_Complete()
	
end