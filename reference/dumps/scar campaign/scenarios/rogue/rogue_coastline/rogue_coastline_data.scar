import("cardinal.scar")
import("MissionOMatic/MissionOMatic.scar")

function GetRecipe()
	
	local recipe = {
		modules = {
			
		},
		onStart = { 
			intelEvent = "", 
			expositionCamera = {}, 
			titleCard = { icon = "icons/campaign/campaign_angevin_the_conquest", location = LOC("Location, year") },
			actions = {},
		},
	}
	
	return recipe
end

--? @shortdesc Returns unit data for a given budget, using a custom table
function Rogue_Coastline_GetCustomUnitData(budget, unit_types)
	
	local unit = Table_GetRandomItem(unit_types)
	local unit_data = {sbp = unit.sbp, numSquads = math.ceil(budget / unit.value)}
	return unit_data
end

--? @shortdesc Inits unit data tables
function Rogue_Coastline_InitUnitTables()
	
	t_mercenary_types_regular = {
		SBP.BYZANTINE.UNIT_JAVELIN_3_MERC_BYZ,
		SBP.BYZANTINE.UNIT_GBETO_3_MERC_BYZ,
		SBP.BYZANTINE.UNIT_LONGBOWMAN_3_MERC_BYZ,
		SBP.BYZANTINE.UNIT_CROSSBOWMAN_3_MERC_BYZ,
		SBP.BYZANTINE.UNIT_REPEATER_CROSSBOWMAN_3_MERC_BYZ,
	}
	
	t_mercenary_types_elite_inf = {
		SBP.BYZANTINE.UNIT_GRENADIER_4_MERC_BYZ,
		SBP.BYZANTINE.UNIT_LANDSKNECHT_4_MERC_BYZ,
		SBP.BYZANTINE.UNIT_STRELTSY_4_MERC_BYZ,
		SBP.BYZANTINE.UNIT_GHULAM_4_MERC_BYZ,
	}
	
end

