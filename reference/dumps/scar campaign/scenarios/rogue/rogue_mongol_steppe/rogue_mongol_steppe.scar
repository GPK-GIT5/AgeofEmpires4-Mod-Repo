		--Squad_Destroy(SGroup_GetSquadAt(sg_sheep_far, index))
	--end
end

function Steppe_SpawnGuards()
	guard_reserve = 0
	--local unit_names = { "spearman", "archer", "horseman" }
	Steppe_SpawnGuard("a", TARGET_ORDER_PATROL)
	Steppe_SpawnGuard("b", TARGET_ORDER_LOOP)
	Steppe_SpawnGuard("c", TARGET_ORDER_PATROL)
	Steppe_SpawnGuard("d", TARGET_ORDER_LOOP)
	Steppe_SpawnGuard("e", TARGET_ORDER_PATROL)
	Steppe_SpawnGuard("f", TARGET_ORDER_PATROL)
	Steppe_SpawnGuard("g", TARGET_ORDER_PATROL)
	Steppe_SpawnGuard("h", TARGET_ORDER_PATROL)
end

function Steppe_SpawnGuard(name, targetOrder)
	local unit_table = Steppe_GetGuardUnits()
	local markers = AllMarkers_InSequence("mkr_guard_"..name.."_")
	local army_params = {
		player = ROGUE_ENEMY_ALLY_PLAYER,
		units = unit_table,
		targets = markers,
		targetOrder = targetOrder,
		
	}
	local army = Army_Init(army_params)
	Modify_UnitSpeedWhenNotInCombat(army.sgroup, WALK_SPEED, MUT_Set)
end

function Steppe_GetGuardUnits()
	local unit_value = GetIntegerInExponentialRange(160, 720)
	guard_reserve = guard_reserve + unit_value
	local unit_name = "knight"
	if guard_reserve < 240 then
		unit_name = "horseman"
	end
	local race_unit_type = wave_race_unit_types[unit_name]
	local numSquads = math.floor(guard_reserve / race_unit_type.cost)
	if numSquads < 1 then
		numSquads = 1
	end
	local actual_value = numSquads * race_unit_type.cost
	guard_reserve = guard_reserve - actual_value
	return {{ type = race_unit_type.unit_type.scar_type, numSquads = numSquads }}
end

function ValidateContainsCavalry(wave_template)
	for _, subwave_template in ipairs(wave_template.subwave_templates) do
		for _, unit_row in ipairs(subwave_template.unit_table) do
			local archtype = unit_types[unit_row.unit_name].archtype
			if archtype.name == "cavalry" then
				return true
			end
		end
	end
	return false
end