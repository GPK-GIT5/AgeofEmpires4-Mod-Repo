function SortMarkersByDistance(mkr_1, mkr_2)
	local dist_sqrd_1 = World_DistanceSquaredPointToPoint(wonder_position, Marker_GetPosition(mkr_1))
	local dist_sqrd_2 = World_DistanceSquaredPointToPoint(wonder_position, Marker_GetPosition(mkr_2))
	return dist_sqrd_1 < dist_sqrd_2 
end

function Steppe_SpawnSites()
	wonder_position = Marker_GetPosition(mkr_wonder)
	
	-- SITE PICKUPS --
	
	-- organize close and far
	local site_pickup_markers = AllMarkers_FromName("mkr_site_pickup", "")
	table.sort(site_pickup_markers, SortMarkersByDistance)
	local site_pickup_markers_close = {}
	local site_pickup_markers_far = {}
	for i, marker in ipairs(site_pickup_markers) do
		if i < (#site_pickup_markers / 2) then
			table.insert(site_pickup_markers_close, marker)	
		else
			table.insert(site_pickup_markers_far, marker)	
		end
	end
	Table_Shuffle(site_pickup_markers_close)
	Table_Shuffle(site_pickup_markers_far)
	
	-- close relics
	local close_relics = 2
	for i = 1, close_relics do
		Site_CreateRelic(site_pickup_markers_close[1])
		table.remove(site_pickup_markers_close, 1)
	end
	-- close pickups
	local close_pickups = 13
	for i = 1, close_pickups do
		Site_CreatePickup(site_pickup_markers_close[1])
		table.remove(site_pickup_markers_close, 1)
	end
	 -- far relics
	local far_relics = 2
	for i = 1, far_relics do
		Site_CreateRelic(site_pickup_markers_far[1])
		table.remove(site_pickup_markers_far, 1)
	end
	-- far pickups
	local far_pickups = 13
	for i = 1, far_relics do
		Site_CreatePickup(site_pickup_markers_far[1])
		table.remove(site_pickup_markers_far, 1)
	end
	
	-- SITES --
	
	for i, marker in ipairs(side_objective_markers) do -- only contains unused objectives
		Marker_Create("mkr_site", "", Marker_GetPosition(marker), Marker_GetDirection(marker), 20)
	end

	-- organize close and far
	local site_markers = AllMarkers_FromName("mkr_site", "")
	table.sort(site_markers, SortMarkersByDistance)
	local site_markers_close = {}
	local site_markers_far = {}
	for i, marker in ipairs(site_markers) do
		if i <= (#site_markers * (3/4)) then
			table.insert(site_markers_close, marker)	
		else
			table.insert(site_markers_far, marker)	
		end
	end
	Table_Shuffle(site_markers_close)
	Table_Shuffle(site_markers_far)
	
	-- close POIs
	local close_pois = 10
	for i = 1, close_pois do
		local site_marker = site_markers_close[1]
		Marker_Create("mkr_poi_t1", "", Marker_GetPosition(site_marker), Marker_GetDirection(site_marker), 45)
		table.remove(site_markers_close, 1)
	end
	-- close camps
	for _, site_marker in ipairs(site_markers_close) do
		Site_CreateCampSmall(site_marker)
	end
	-- far POIs
	local far_pois = 4
	for i = 1, far_pois do
		local site_marker = site_markers_far[1]
		Marker_Create("mkr_poi_t2", "", Marker_GetPosition(site_marker), Marker_GetDirection(site_marker), 45)
		table.remove(site_markers_far, 1)
	end
	-- far camps
	for _, site_marker in ipairs(site_markers_far) do
		Site_CreateCampLarge(site_marker)
	end
	
	
	-- SPAWN PICKUPS AND RELICS --
	local pickup_markers = AllMarkers_FromName("mkr_pickup", "")
	for _, marker in ipairs(pickup_markers) do
		local pickup_ebp = Table_GetRandomItem(pickup_ebps)
		CreateEntity(ROGUE_ENEMY_ALLY_PLAYER, pickup_ebp, marker, nil, DIRECTION_BACK)
	end
	
	local relic_markers = AllMarkers_FromName("mkr_relic", "")
	for _, marker in ipairs(relic_markers) do
		CreateEntity(nil, BP_GetEntityBlueprint("relic"), marker, nil, DIRECTION_BACK)
	end
	
	Sites_Debug()
end

function Steppe_DeleteSheep()
	local close_sheep_count = 6
	local close_sheep_deleted = SGroup_CountSpawned(sg_sheep_close) - close_sheep_count
	for i = 1, close_sheep_deleted do
		local index = World_GetRand(1, SGroup_CountSpawned(sg_sheep_close))
		Squad_Destroy(SGroup_GetSquadAt(sg_sheep_close, index))
	end
	
	--local far_sheep_count = 40
