import("MissionOMatic/MissionOMatic.scar")		-- this imports the Cardinal scripts as well
import("rogue_mongol_steppe_raiders.scar")
import("rogue/rogue.scar")

function Mission_PreInit()
	content_pack = CONTENT_PACK_ROGUE
	mission_name = "Watch Your Steppe"
	print("------------------------------------------------------------------------")
	print("------------- "..mission_name.." - Initializing -------------")
	print("------------------------------------------------------------------------")
	rogue_wave_strength = 0.9
	WAVE_STAGING_DURATION = 5
end

function Mission_SetupPlayers()
	Rogue_SetupPlayers_A()
	
	Rogue_AddHumanPlayer(1, COLOR_BLUE)
	Rogue_AddEnemyWavePlayer(2,  "$11143414", COLOR_RED)
	Rogue_AddAllyPlayer(3, 	     "$11096698", COLOR_YELLOW)
	Rogue_AddEnemyAllyPlayer(4,  "$11143414", COLOR_RED)
	Rogue_AddEnemyRaiderPlayer(5,"$11270310", COLOR_ORANGE)
	Rogue_AddNeutralPlayer(6,    "$11096698", COLOR_YELLOW)
	
	Rogue_SetupPlayers_B()
end

function Mission_Preset()
	Rogue_AddLane("west", true, ValidateContainsCavalry)
	Rogue_AddLane("north", false, ValidateContainsCavalry)
	Rogue_AddLane("east", true, ValidateContainsCavalry)
	
	Rogue_UseDefaultSchedule(true, false, 1.0)
	
	Rogue_SimulateEvents()	
	
	ResourceSpots_InitData({0,20,0,0,0,0,0})
	ResourceSpots_Init("mkr_resource", "gaia", 6)
	
	Steppe_InitializeRaiders()
	Sites_Init("archer", "manatarms", "crossbowman")
	Steppe_SpawnSites()
	
	-- Points of interest
	local t_unit_types_mon = {
		{sbp = BP_GetSquadBlueprint("unit_militia_rogue_mon"), value = 60, tier = 1},
		{sbp = SBP.MONGOL.UNIT_ARCHER_2_MON, value = 80, tier = 1},
		{sbp = SBP.MONGOL.UNIT_SPEARMAN_2_MON, value = 80, tier = 1},
		{sbp = SBP.MONGOL.UNIT_CROSSBOWMAN_3_MON, value = 120, tier = 2},
		{sbp = SBP.MONGOL.UNIT_MANATARMS_3_MON, value = 120, tier = 2},
	}
	
	-- Points of interest
	Rogue_POI_Init(ROGUE_ENEMY_ALLY_PLAYER, t_unit_types_mon, nil, 10, 4)
	
	-- Defensive points of interest
	Rogue_POI_Spawn("mkr_poi_def", t_poi_types_def, 1, 1)
	
	Steppe_DeleteSheep()
	Steppe_SpawnGuards()
end

function Mission_Start()	
	Rogue_SetupPlayers_C()
end

function Mission_Unpause()
	--Outlaws_InitRaiding()
	Steppe_UnpauseRaiders()
end

