--[[ 
	Order of operations:
		Mission_SetupPlayers() 		-- Called by OnGameSetup() on frame1
		Mission_SetupVariables()
		Mission_SetDifficulty()
		Mission_SetupRestrictions()
		Mission_Preset()
		Objectives are registered
		Intro Movie
		Intro NIS
		Mission_Start()
]]--
