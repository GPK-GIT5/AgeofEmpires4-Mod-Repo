-- 
-- Mission-O-Matic - Custom metrics
--
-- Used by the reporting system to provide metrics specified by the recipe 
--



--[[ 
	
	Metric measuring functions follow this specification:
	
		function Metric_<name>_Init(metric)			<-- Optional
		
			-- this function gets called during initialization, and you can use it to set up some tracking functions during the game if you need that
			
		end
	
	
		function Metric_<name>_Calculate(metric)	<-- Required
		
			-- this function gets called at the end of the mission, and should return the results for the metric
			
		end
	
	The <name> element in the function names should be the name of your new metric. The metric can then be used by specifying that same name in a recipe
	Both of these functions receive the table from the recipe corresponding to that individial metric. You can store info in that table during the mission.		
	
--]]





function MissionOMatic_InitializeCustomMetric(metric)

	-- some metrics need to be able to initialize a tracking system at the start of the mission; this kicks that process off...
	
	local metricName = "Metric_"..metric.metric.."_Init"
	local metricFunction = _G[metricName]
	
	if scartype(metricFunction) == ST_FUNCTION then
		
		metricFunction(metric)

	end

end




function MissionOMatic_CalculateCustomMetrics()

	local metrics = {}
	
	if scartype(MissionRecipe.metrics) == ST_TABLE then
	
		for index, metric in pairs(MissionRecipe.metrics) do 	
			
			local entry = {
				descriptor = metric.descriptor
			}
			
			local metricName = "Metric_"..metric.metric.."_Calculate"
			local metricFunction = _G[metricName]
			
			if scartype(metricFunction) == ST_FUNCTION then
				
				entry.result = metricFunction(metric)
			
				table.insert(metrics, entry)
				
			end
			
		end
		
	end
	
	return metrics
	
end





--
-- GetResource
--

function Metric_GetResource_Calculate(metric)

	local player = World_GetPlayerAt(1)
	if metric.player ~= nil then 
		player = PARTICIPANT(metric.player).id 
	end
	
	local resourceAmount = Player_GetResource(player, metric.resourceType)
	
	return resourceAmount
	
end




