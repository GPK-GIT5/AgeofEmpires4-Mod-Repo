function Action_AddObjectiveHintpoint_Do(action, context)

	-- figure out the location
	local position = nil
	
	if scartype(action.location) == ST_STRING or scartype(action.location) == ST_TABLE then
		local location = LOCATION(action.location)
		position = location.position
	elseif scartype(action.marker) == ST_MARKER then
		position = action.marker
	elseif scartype(action.where) == ST_TABLE then
		position = ResolveSpawnLocation(action.where)
	end
	
	if destinationMarker ~= nil then
		Objective_AddUIElements(context.objective, position, true, action.text)
	end
	
end

--
-- UNIT ACTIONS
