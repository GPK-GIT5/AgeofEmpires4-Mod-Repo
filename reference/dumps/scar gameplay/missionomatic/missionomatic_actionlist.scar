end

function Action_RevealDestination_Do(action, context) 
	
	local destinationMarker = nil
	
	if scartype(action.location) == ST_STRING or scartype(action.location) == ST_TABLE then
		location = LOCATION(action.location)
		destinationMarker = location.position
	elseif scartype(action.marker) == ST_MARKER then
		destinationMarker = action.marker
	end
	
	local radius = action.radius or 20	
	
	if destinationMarker ~= nil then
		FOW_RevealArea(Util_GetPosition(destinationMarker), radius, action.duration or 5)
	end
	
end

function Action_RevealUnits_Do(action, context)
	
	if scartype(action.sgroup) == ST_SGROUP then
		
		local duration = action.duration or 10
