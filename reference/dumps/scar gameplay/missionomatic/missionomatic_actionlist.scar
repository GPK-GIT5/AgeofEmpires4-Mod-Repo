	end
	
end

--? @shortdesc Spawns a new entity at a given location (only once, since many entities don't like overlapping)
function Action_SpawnBuilding_Do(action, context)

	local spawnLocation = ResolveSpawnLocation(action.spawnLocation)
	
	if scartype(action.building) ~= ST_NIL then
		Util_CreateEntities(action.player, playerBuildings, action.building, spawnLocation, 1)
	end
	
end

--? @shortdesc Spawns new units at a given location
function Action_SpawnUnits_Do(action, context)

	local spawnLocation = ResolveSpawnLocation(action.spawnLocation)
	
	local options = {}
	if action.zeroPopulation ~= nil then 
		options.zeroPopulation = action.zeroPopulation
	end
	if action.spawnInFormation ~= nil then 
		options.spawnInFormation = action.spawnInFormation
	end
	
	if scartype(action.units) == ST_TABLE then
 		UnitEntry_DeploySquads(action.player, action.sgroup, action.units, spawnLocation, nil, nil, options)
	end
	
end

--? @shortdesc Spawns new units and adds them to a given module
function Action_SpawnUnitsToModule_Do(action, context)

	SpawnUnitsToModule(action.units, action.module, action.spawnLocation)
	
end

--? @shortdesc Adds all the units in a battalion to a given module
function Action_AddBattalionToModule_Do(action, context)

	-- Figure out what module to add to - often this won't be tied to a location at all
	local targetModule = MissionOMatic_FindModule(action.module)
	local sourceBattalion = MissionOMatic_FindBattalion(action.battalionPlayer)
	if targetModule ~= nil and sourceBattalion then
	
		if targetModule.player.descriptor == sourceBattalion.player then
			Prefab_DoAction(targetModule, 'AddSGroup', sourceBattalion.sgroup)
			if scartype(sourceBattalion.sgroup_gen) == ST_SGROUP and SGroup_Count(sourceBattalion.sgroup_gen) > 0 then
				Prefab_DoAction(targetModule, 'AddSGroup', sourceBattalion.sgroup_gen)
			end
		else
			print("WARNING: AddBattalionToModule player mismatch, cannot add units owned by "..tostring(sourceBattalion.player).." to module owned by "..tostring(targetModule.player.descriptor))
		end
		
	else
		print("WARNING: AddBattalionToModule called on module: "..tostring(targetModule)..", battalion: "..tostring(sourceBattalion))
	end
	
end

--? @shortdesc Dissolves a module
function Action_DissolveModule_Do(action, context)

	local sourceModule = MissionOMatic_FindModule(action.source)
	if sourceModule ~= nil then
		Prefab_DoAction(sourceModule, "Disband")
	end
	
end
--? @shortdesc Dissolves a module and folds its units into another module
function Action_DissolveModuleIntoModule_Do(action, context)
	
	DissolveModuleIntoModule(action.source, action.target)
	
end

function Action_EnableModule_Do(action, context)

	local module = MissionOMatic_FindModule(action.module)	
	Prefab_DoAction(module, "Enable")
	
end
function Action_DisableModule_Do(action, context)

	local module = MissionOMatic_FindModule(action.module)	
	Prefab_DoAction(module, "Disable")
	
end
function Action_ModuleAction_Do(action, context)

	local module = MissionOMatic_FindModule(action.module)	
	Prefab_DoAction(module, action.action, action.parameters)
	
end


--
-- RESOURCES
--

--? @shortdesc Adds resources to a given player
function Action_AddResources_Do(action, context)
	
	local player = action.player
	
	if scartype(player) == ST_INTEGER then
		player = World_GetPlayerAt(action.player)
	end
	
	if scartype(action.resources) == ST_TABLE and player ~= nil then
		Player_AddResources(player, action.resources)
	end
	
end


function Action_SetResources_Do(action, context)
	
	local player = action.player
	
	if scartype(player) == ST_INTEGER then
		player = World_GetPlayerAt(action.player)
	end
	
	if scartype(action.resources) == ST_TABLE and player ~= nil then
		
		local i = Player_GetResources(player)
	
		for k, v in pairs(action.resources) do
			i[k] = action.resources[k]
		end
		
		Player_SetResources(player, i)
		
	end

end

