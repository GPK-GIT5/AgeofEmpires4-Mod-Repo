--? @shortdesc Starts a rule which will monitor the mission for trade cart deaths belonging to the specified players, and has a 1/3 chance of dropping a random resource pickup. 
--? @args Table players 
function TrackTradeCartsForPlayers(players)
	assert(scartype(players) == ST_TABLE, "players must be a table")
	assert(scartype(players[1]) == ST_PLAYER, "players must be a table of players")
	g_tracked_players = players
	Rule_AddGlobalEvent(CheckIfTradeCart, GE_SquadKilled)
end

function CheckIfTradeCart(context)
	local victim = context.victim
	if Squad_IsOfType(victim, "scar_trade_cart") and Table_Contains(g_tracked_players, Squad_GetPlayerOwner(victim)) then
		local position = Squad_GetPosition(victim)
		local pickup = BP_GetEntityBlueprint(Table_GetRandomItem({"resource_pickup_gold", "resource_pickup_stone", "resource_pickup_food", "resource_pickup_wood"}))
		Util_CreateEntities(nil, nil, pickup, position, 1, nil, true)
	end
end

--? @shortdesc Will spawn and garrison (default: 3) units into every entity of the provided egroup. Useful for filling outposts.
--? @args EGroup egroup, Player player, String opt_scarType, Int opt_count
function SpawnGarrisonsIntoEGroup(egroup, player, opt_scarType, opt_count)
	
	local opt_scarType = opt_scarType or "scar_spearman"
	local opt_count = opt_count or 3
	
	local _loadOutpost = function(gid, idx, eid)
		SGroup_Clear(sg_temp)
		EGroup_Clear(eg_temp)
		
		UnitEntry_DeploySquads(player, sg_temp, {type = opt_scarType, numSquads = opt_count}, Entity_GetPosition(eid))
		Player_GetAllEntitiesNearMarker(player, eg_temp, Entity_GetPosition(eid), 1)
		Cmd_Garrison(sg_temp, eg_temp, nil, nil, true)
		
		SGroup_Clear(sg_temp)
		EGroup_Clear(eg_temp)
	end
	
	EGroup_ForEach(egroup, _loadOutpost)	
end

function ClearProductionQueueForEGroup(egroup)
	for i = 1 , EGroup_Count(egroup) do
		ClearProductionQueueForEntity(EGroup_GetEntityAt(egroup, i))
	end
end

function ClearProductionQueueForEntity(entity)
	if Entity_HasProductionQueue(entity) then			
		local queueSize = Entity_GetProductionQueueSize(entity)
		for i = queueSize-1, 0, -1 do 
			Entity_CancelProductionQueueItem(entity, i)
		end			
	end
end

function EnableProductionForEGroup(egroup, enable)
	for i = 1 , EGroup_Count(egroup) do
		Entity_EnableProductionQueue(EGroup_GetEntityAt(egroup, i), enable)
	end
end

--position can be anything that resolves to a position (pos, marker, squad, entity, sgroup, egroup)
--direction must be a direction
--facing can be anything that resolves to a position (pos, marker, squad, entity, sgroup, egroup)
function GetSpacialData(position, direction, facing, usePosAsFallbackIfMarker, useDefault)
	assert(scartype(position) == ST_SCARPOS or scartype(position) == ST_MARKER, "invalid position")
	assert(not(direction and facing), "you can optionally provide facing OR direction, but not both")
	assert(direction == nil or scartype(direction) == ST_SCARPOS, "invalid direction")
	assert(scartype(usePosAsFallbackIfMarker) == ST_BOOLEAN)
	assert(scartype(useDefault) == ST_BOOLEAN)
	local r = {}
	r.position = Util_GetPosition(position)
	if facing then
		r.facing = Util_GetPosition(facing)
		r.direction = World_Pos(r.facing.x - r.position.x, 0, r.facing.z - r.position.z)
	elseif direction then
		r.direction = direction	
		r.facing = World_Pos(r.position.x + r.direction.x * 100, 0, r.position.z + r.direction.z * 100)
	elseif usePosAsFallbackIfMarker and scartype(position) == ST_MARKER then
		r.direction = Marker_GetDirection(position)
		r.facing = World_Pos(r.position.x + r.direction.x * 100, 0, r.position.z + r.direction.z * 100)
	elseif useDefault then
		r.direction = World_Pos(-1, 0, -1)
		r.facing = World_Pos(r.position.x + r.direction.x * 100, 0, r.position.z + r.direction.z * 100)
	end
	return r
end

--? @shortdesc Units will be spawned in formation with default facing. If position has type ST_MARKER, that will be 
--? used to determine facing. You may optionally provide direction OR facing, but not both. This will override facing.
--? @extdesc units - A table where each row describes a type of unit to be spawned
--? position - Can be a position or marker
--? sgroup (optional) - Units will be added to it. If a string is provided, an sgroup will be created with that name
--? direction (optional) - Is type ST_SCARPOS, but is actually a direction/vector, as returned by Marker_GetDirection
--? facing (optional) - Can be anything that resolves to a position (pos, marker, entity, squad, sgroup, egroup) 
--? @args Player player, Table units, Position position, SGroup sgroup, Direction direction, Position facing
--? @result sgroup
function CreateUnits(player, units, position, sgroup, direction, facing)
	assert(player ~= nil, "invalid player")
	assert(scartype(position) == ST_SCARPOS or scartype(position) == ST_MARKER, "invalid position")
	assert(direction == nil or scartype(direction) == ST_SCARPOS, "invalid direction")
	assert(not(direction and facing), "you can optionally provide facing OR direction, but not both")
	
	local sd = GetSpacialData(position, direction, facing, true, true)
	local sg_spawned_units = SGroup_CreateUnique("sg_spawned_units")
	UnitEntry_DeploySquads(player, sg_spawned_units, units, sd.position, nil, nil, {facing = sd.facing })
	Formation_PlaceSquadsInFormation(sg_spawned_units, sd.position, sd.direction)
	if sgroup then
		if scartype(sgroup) == ST_STRING then
			sgroup = SGroup_CreateUniqueWithPrefix(sgroup)
		end
		SGroup_AddGroup(sgroup, sg_spawned_units)
	end
	SGroup_Destroy(sg_spawned_units)
	return sgroup
end

--? @shortdesc Units will be spawned in formation with given formationName with default facing. If position has type ST_MARKER, that
--? will be used to determine facing. You may optionally provide direction OR facing, but not both. This will override facing.
--? @extdesc units - A table where each row describes a type of unit to be spawned
--? position - Can be a position or marker
--? formation - Can be FORMATION_BOX, FORMATION_LINE, FORMATION_SPREAD, or FORMATION_WEDGE
--? sgroup (optional) - Units will be added to it. If a string is provided, an sgroup will be created with that name
--? direction (optional) - Is type ST_SCARPOS, but is actually a direction/vector, as returned by Marker_GetDirection
--? facing (optional) - Can be anything that resolves to a position (pos, marker, entity, squad, sgroup, egroup) 
--? @args Player player, Table units, Position position, SGroup sgroup, Direction direction, Position facing
--? @result sgroup
function CreateUnitsWithFormation(player, units, position, formation, sgroup, direction, facing)
	assert(scartype(position) == ST_SCARPOS or scartype(position) == ST_MARKER, "invalid position")
	assert(direction == nil or scartype(direction) == ST_SCARPOS, "invalid direction")
	assert(not(direction and facing), "you can optionally provide facing OR direction, but not both")
	
	local sd = GetSpacialData(position, direction, facing, true, true)
	local sg_spawned_units = SGroup_CreateUnique("sg_spawned_units")
	UnitEntry_DeploySquads(player, sg_spawned_units, units, sd.position, nil, nil, {facing = sd.facing })
	Formation_PlaceSquadsInFormationByFormationName(sg_spawned_units, sd.position, sd.direction, formation.group_spot_generator)
	if formation.ability then
		Cmd_Ability(sg_spawned_units, formation.ability)
	end
	if sgroup then
		if scartype(sgroup) == ST_STRING then
			sgroup = SGroup_CreateUniqueWithPrefix(sgroup)
		end
		SGroup_AddGroup(sgroup, sg_spawned_units)
	end
	SGroup_Destroy(sg_spawned_units)
	return sgroup
end

function Entity_GetHoldSlotsAvailable(entity)
	return Entity_GetMaxHoldSquadSlots(entity) - Entity_GetFilledHoldSquadSlots(entity)
end

function Squad_GetHoldSlotsAvailable(squad)
	local entity = Squad_GetFirstEntity(squad)
	return Entity_GetMaxHoldSquadSlots(entity) - Entity_GetFilledHoldSquadSlots(entity)
end

function EGroup_GetHoldSlotsAvailable(egroup)
	local count = 0
	for i = 1, EGroup_CountSpawned(egroup) do
		local entity = EGroup_GetEntityAt(egroup, i)
		count = count + Entity_GetHoldSlotsAvailable(entity)
	end
	return count
end

function EGroup_CountActiveLandmarks(eg_landmarks)
	local active_landmarks = 0
	for i = 1, EGroup_CountSpawned(eg_landmarks) do
		local landmark = EGroup_GetSpawnedEntityAt(eg_landmarks, i)
		if Entity_IsAlive(landmark) and Entity_GetStateModelBool(landmark, "landmark_active") then
			active_landmarks = active_landmarks + 1
		end
	end
	return active_landmarks
end

function SGroup_GetHoldSlotsAvailable(sgroup)
	local count = 0
	for i = 1, SGroup_CountSpawned(sgroup) do
		local squad = SGroup_GetSquadAt(sgroup, i)
		count = count + Squad_GetHoldSlotsAvailable(squad)
	end
	return count
end

function SGroup_GetResourceCost(sgroup)
	local total_cost = 0
	for i = 1, SGroup_CountSpawned(sgroup) do
		local squad = SGroup_GetSpawnedSquadAt(sgroup, i)
		local squad_cost = Player_GetSquadBPCost(player1, Squad_GetBlueprint(squad))
		total_cost = total_cost + squad_cost.food + squad_cost.gold + squad_cost.stone + squad_cost.wood
	end
	return math.floor(total_cost)
end

--? @shortdesc combines food, wood, gold, and stone into a single value
function TotalCost(cost_table)
	return cost_table.food + cost_table.wood + cost_table.gold + cost_table.stone
end

--? @shortdesc Units will be spawned inside the entities of eg_holds. Use EGroup_GetHoldSlotsAvailable to check if eg_holds has space.
--? @extdesc If sgroup is provided, spawned units will be added to it. If sgroup is a string, a new sgroup will be created with that name.
--? @result sgroup 
function CreateUnitsInsideEGroup(player, units, eg_holds, sgroup)
	local open_slots = EGroup_GetHoldSlotsAvailable(eg_holds)
	local unit_table_count = UnitTable_CountUnits(units) 
	assert(unit_table_count <= open_slots, "Not enough room in hold, use EGroup_GetHoldSlotsAvailable to check for space")
	
	if scartype(sgroup) == ST_STRING then
		sgroup = SGroup_CreateUniqueWithPrefix(sgroup)
	end
	local remaining_units = Clone(units)
	for i = 1, EGroup_CountSpawned(eg_holds) do
		local entity_hold = EGroup_GetSpawnedEntityAt(eg_holds, i)
		local open_slots = Entity_GetHoldSlotsAvailable(entity_hold)
		if open_slots > 0 then
			if #remaining_units == 0 then
				break
			end
			local unitTableSubset = UnitTable_GetSubsetByCount(remaining_units, open_slots, true)
			CreateUnitsInsideEntity(player, unitTableSubset, entity_hold, sgroup)
		end
	end
	return sgroup
end

--? @shortdesc Units will be spawned inside the squads of sg_holds. Use SGroup_GetHoldSlotsAvailable to check if sg_holds has space.
--? @extdesc If sgroup is provided, spawned units will be added to it. If sgroup is a string, a new sgroup will be created with that name.
--? @result sgroup
function CreateUnitsInsideSGroup(player, units, sg_holds, sgroup)
	local open_slots = SGroup_GetHoldSlotsAvailable(sg_holds)
	assert(UnitTable_CountUnits(units) <= open_slots, "Not enough room in hold, use SGroup_GetHoldSlotsAvailable to check for space")
	
	if scartype(sgroup) == ST_STRING then
		sgroup = SGroup_CreateUniqueWithPrefix(sgroup)
	end
	local remaining_units = Clone(units)
	for i = 1, SGroup_CountSpawned(sg_holds) do
		local squad_hold = SGroup_GetSpawnedSquadAt(sg_holds, i)
		local entity_hold = Squad_GetFirstEntity(squad_hold)
		local open_slots = Entity_GetHoldSlotsAvailable(entity_hold)
		if open_slots > 0 then
			if #remaining_units == 0 or UnitTable_CountUnits(remaining_units) <= 0 then
				break
			end
			local unitTableSubset = UnitTable_GetSubsetByCount(remaining_units, open_slots, true)
			CreateUnitsInsideSquad(player, unitTableSubset, squad_hold, sgroup)
		end
	end
	return sgroup
end
	
--? @shortdesc Units will be spawned inside entity_hold. Use Entity_GetHoldSlotsAvailable to check if entity_hold has space.
--? @extdesc If sgroup is provided, spawned units will be added to it. If sgroup is a string, a new sgroup will be created with that name.
--? @result sgroup
function CreateUnitsInsideEntity(player, units, entity_hold, sgroup)
	local open_slots = Entity_GetHoldSlotsAvailable(entity_hold)
	assert(UnitTable_CountUnits(units) <= open_slots, "Not enough room in hold, use Entity_GetHoldSlotsAvailable to check for space")
	
	if scartype(sgroup) == ST_STRING then
		sgroup = SGroup_CreateUniqueWithPrefix(sgroup)
	end
	local sg_spawned_units = SGroup_CreateUnique("sg_spawned_units")
	eg_createUnitsInsideEntity = EGroup_CreateIfNotFound("eg_createUnitsInsideEntity")
	EGroup_Single(eg_createUnitsInsideEntity, entity_hold)

	-- We have room in the hold and the unit will instantly be garrisoned after spawn, so we don't have to worry about
	-- spawning it in a pathable spot or in formation.
	local options = {
		ignorePathfindingPos = true,
		ignoreFormation = true,
	}
	UnitEntry_DeploySquads(player, sg_spawned_units, units, eg_createUnitsInsideEntity, nil, nil, options)
	if sgroup then
		SGroup_AddGroup(sgroup, sg_spawned_units)
	end
	SGroup_Destroy(sg_spawned_units) --destroy group for units
	return sgroup
end

--? @shortdesc Units will be spawned inside squad_hold. Use Squad_GetHoldSlotsAvailable to check if squad_hold has space.
--? @extdesc If sgroup is provided, spawned units will be added to it. If sgroup is a string, a new sgroup will be created with that name.
--? @result sgroup
function CreateUnitsInsideSquad(player, units, squad_hold, sgroup)
	local open_slots = Squad_GetHoldSlotsAvailable(squad_hold)
	assert(UnitTable_CountUnits(units) <= open_slots, "Not enough room in hold, use Squad_GetHoldSlotsAvailable to check for space")
	
	if scartype(sgroup) == ST_STRING then
		sgroup = SGroup_CreateUniqueWithPrefix(sgroup)
	end
	local sg_spawned_units = SGroup_CreateUnique("sg_spawned_units")
	sg_createUnitsInsideSquad = SGroup_CreateIfNotFound("sg_createUnitsInsideSquad")
	SGroup_Single(sg_createUnitsInsideSquad, squad_hold)

	-- We have room in the hold and the unit will instantly be garrisoned after spawn, so we don't have to worry about
	-- spawning it in a pathable spot or in formation.
	local options = {
		ignorePathfindingPos = true,
		ignoreFormation = true,
	}
	UnitEntry_DeploySquads(player, sg_spawned_units, units, sg_createUnitsInsideSquad, nil, nil, options)
	if sgroup then
		SGroup_AddGroup(sgroup, sg_spawned_units)
	end
	SGroup_Destroy(sg_spawned_units) --destroy group for units
	return sgroup
end

--? @shortdesc Entity will be spawned with default facing. If position has type ST_MARKER, that will be used to determine facing.
--? You may optionally provide direction OR facing, but not both. This will override facing.
--? @extdesc player - Set to nil if you want the entity to be world owned 
--? ebp - An EntityBluePrint object describing the entity type
--? position - Can be a position or marker
--? egroup (optional) - The entity will be added to it. If a string is provided, an egroup will be created with that name
--? direction (optional) - Is type ST_SCARPOS, but is actually a direction/vector, as returned by Marker_GetDirection
--? facing (optional) - Can be anything that resolves to a position (pos, marker, entity, squad, sgroup, egroup)
--? isConstructing (optional) - Defaults to false. If the entity is a building, set this to true to spawn it in a construction state. 
--? @args Player player, EBP ebp, Position position, SGroup sgroup, Direction direction, Position facing, Boolean isConstructing
--? @result egroup
function CreateEntity(player, ebp, position, egroup, direction, facing, isConstructing)
	assert(scartype(ebp) == ST_PBG, "invalid ebp")
	assert(scartype(position) == ST_SCARPOS or scartype(position) == ST_MARKER, "invalid position")
	assert(not(direction and facing), "you can optionally provide facing OR direction, but not both")
	assert(direction == nil or scartype(direction) == ST_SCARPOS, "invalid direction")
	
	local isConstructing = isConstructing or false
	local sd = GetSpacialData(position, direction, facing, false, false)
	local entity = nil
	if sd.facing then
		if player then
			entity = Entity_CreateFacing(ebp, player, sd.position, sd.facing, true)
		else
			entity = Entity_CreateENVFacing(ebp, sd.position, sd.facing, true)
		end
	else
		if player then
			entity = Entity_Create(ebp, player, sd.position, true)	
		else
			entity = Entity_CreateENV(ebp, sd.position, true)
		end
	end
	Entity_SnapToGridAndGround(entity, false) --interpolate == false means it will be instant
	Entity_Spawn(entity) -- spawn the entity
	if Entity_IsBuilding(entity) == true and isConstructing == false then
		Entity_ForceConstruct(entity)
	end
	if egroup then
		if scartype(egroup) == ST_STRING then
			egroup = EGroup_CreateUniqueWithPrefix(egroup)
		end
		EGroup_Add(egroup, entity)
	end
	return egroup
end

--? @shortdesc Issues a move command to the sgroup. 
--? @extdesc position - can be anything that resolves to a position (pos, marker, entity, squad, sgroup, egroup)
--? queued (optional) - defaults to false. set to true if you want the command to be exectuted after other commands.
--? @args SGroup sgroup, Position position, Bool queued
function SGroup_Move(sgroup, position, queued)
	assert(scartype(sgroup) == ST_SGROUP)
	assert(position ~= nil)
	assert(queued == nil or scartype(queued) == ST_BOOLEAN)
	if SGroup_CountSpawned(sgroup) > 0 then
		if queued == nil then queued = false end
		local player = Util_GetPlayerOwner(sgroup)
		position = Util_GetPosition(position)
		
		LocalCommand_BeginSendingSquadCommandsAsFormation(player, queued)
		LocalCommand_SquadMovePos(player, sgroup, position, queued, false, false, 0)
		LocalCommand_EndSendingSquadCommandsAsFormation()
	end
end

--? @shortdesc Issues a move command to the sgroup. The sgroup will be destroyed after reaching the destination. If position
--? is a marker, that 
--? @extdesc position - can be anything that resolves to a position (pos, marker, entity, squad, sgroup, egroup)
--? queued (optional) - defaults to false. set to true if you want the command to be exectuted after other commands.
--? @args SGroup sgroup, Position position, Bool queued
function SGroup_MoveToAndDestroy(sgroup, position, queued, distance)
	if SGroup_CountSpawned(sgroup) > 0 then
		SGroup_Move(sgroup, position, queued)
		DestroySquadsWhenArrived(sgroup, position, distance)
	end
end

--? @shortdesc Issues a move command to the sgroup. If position has type ST_MARKER, that will be used to determine facing.
--? You may optionally provide direction OR facing, but not both. This will override facing.
--? One of these 3 means of providing direction must be used, or an assert will be triggered.
--? @extdesc position - Can be a position or marker
--? direction (optional) - Is type ST_SCARPOS, but is actually a direction/vector, as returned by Marker_GetDirection
--? facing (optional) - Can be anything that resolves to a position (pos, marker, entity, squad, sgroup, egroup)
--? queued (optional) - defaults to false. set to true if you want the command to be exectuted after other commands.
--? @args SGroup sgroup, Position position, Direction direction, facing, Bool queued
function SGroup_MoveAndFace(sgroup, position, direction, facing, queued)
	assert(scartype(sgroup) == ST_SGROUP, "invalid sgroup")
	assert(scartype(position) == ST_SCARPOS or scartype(position) == ST_MARKER, "invalid position")
	assert(scartype(position) == ST_MARKER or direction or facing, "you must provide some means of determing direction")
	assert(not(direction and facing), "you can optionally provide facing OR direction, but not both")
	assert(direction == nil or scartype(direction) == ST_SCARPOS, "invalid direction")
	assert(queued == nil or scartype(queued) == ST_BOOLEAN)
	if SGroup_CountSpawned(sgroup) > 0 then
		if queued == nil then queued = false end
		local player = Util_GetPlayerOwner(sgroup)
		local sd = GetSpacialData(position, direction, facing, true, false)
		LocalCommand_BeginSendingSquadCommandsAsFormation(player, queued)
		LocalCommand_SquadMovePosFacing(player, sgroup, sd.position, sd.facing, queued, false, false, 0)
		LocalCommand_EndSendingSquadCommandsAsFormation()
	end
end

--? @shortdesc Issues an attackMove command to the sgroup. 
--? @extdesc position - can be anything that resolves to a position (pos, marker, entity, squad, sgroup, egroup)
--? queued (optional) - defaults to false. set to true if you want the command to be exectuted after other commands.
--? @args SGroup sgroup, Position position, Bool queued
function SGroup_AttackMove(sgroup, position, queued)
	assert(scartype(sgroup) == ST_SGROUP, "invalid sgroup")
	assert(position ~= nil, "position is NIL")
	assert(queued == nil or scartype(queued) == ST_BOOLEAN)
	if SGroup_CountSpawned(sgroup) > 0 then
		if queued == nil then queued = false end
		local player = Util_GetPlayerOwner(sgroup)
		position = Util_GetPosition(position)
		LocalCommand_BeginSendingSquadCommandsAsFormation(player, queued)
		LocalCommand_SquadPos(player, sgroup, SCMD_AttackMove, position, queued)
		LocalCommand_EndSendingSquadCommandsAsFormation()
	end
end

--? @shortdesc Orders an sgroup to attack an entity.
--? @extdesc targetEntity - must be an entity
--? queued (optional) - defaults to false. set to true if you want the command to be exectuted after other commands
--? @args SGroup sgroup, Entity targetEntity, Bool queued 
function SGroup_AttackEntity(sgroup, targetEntity, queued)
	assert(scartype(sgroup) == ST_SGROUP, "invalid sgroup")
	assert(scartype(targetEntity) == ST_ENTITY)
	assert(queued == nil or scartype(queued) == ST_BOOLEAN)
	if SGroup_CountSpawned(sgroup) > 0 then
		if queued == nil then queued = false end
		local player = Util_GetPlayerOwner(sgroup)
		local eg_target = EGroup_CreateUnique("eg_target")
		EGroup_Single(eg_target, targetEntity)
		LocalCommand_SquadEntityAttack(player, sgroup, eg_target, false, false, "", queued)
		EGroup_Destroy(eg_target)
	end
end

--? @shortdesc Orders an sgroup to attack the nearest entity in an egroup. The entire sgroup will attack
--? the nearest entity to their average position.
--? @extdesc targetEGroup - must be an egroup with > 0 entities
--? queued (optional) - defaults to false. set to true if you want the command to be exectuted after other commands
--? @args SGroup sgroup, EGroup targetEGroup, Bool queued
function SGroup_AttackNearestEntityInEGroup(sgroup, targetEGroup, queued)
	assert(scartype(sgroup) == ST_SGROUP, "invalid sgroup")
	assert(scartype(targetEGroup) == ST_EGROUP and EGroup_CountSpawned(targetEGroup) > 0)
	assert(queued == nil or scartype(queued) == ST_BOOLEAN)
	if SGroup_CountSpawned(sgroup) > 0 then
		if queued == nil then queued = false end
		local player = Util_GetPlayerOwner(sgroup)
		local averagePosition = SGroup_GetAvgPosition(sgroup)
		local eg_target = EGroup_GetClosestEntities(targetEGroup, 1, averagePosition)
		LocalCommand_SquadEntityAttack(player, sgroup, eg_target, false, false, "", queued)
		EGroup_Destroy(eg_target)
	end
end

--? @shortdesc Orders an sgroup to attack an egroup. Each squad will individually attack the nearest target to 
--? themselves from targetEGroup. 
--? @extdesc targetEGroup - must be an egroup with > 0 entities
--? queued (optional) - defaults to false. set to true if you want the command to be exectuted after other commands
--? @args SGroup sgroup, EGroup targetEGroup, Bool queued
function SGroup_AttackNearestEntitiesInEGroup(sgroup, targetEGroup, queued)
	assert(scartype(sgroup) == ST_SGROUP)
	assert(scartype(targetEGroup) == ST_EGROUP and EGroup_CountSpawned(targetEGroup) > 0)
	assert(queued == nil or scartype(queued) == ST_BOOLEAN)
	if SGroup_CountSpawned(sgroup) > 0 then
		if queued == nil then queued = false end
		local player = Util_GetPlayerOwner(sgroup)
		LocalCommand_SquadEntityAttack(player, sgroup, targetEGroup, false, false, "", queued)
	end
end

--? @shortdesc Orders an sgroup to attack a squad
