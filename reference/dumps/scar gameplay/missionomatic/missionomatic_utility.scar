--? @shortdesc Assigns a group of villagers to construct a building. This will only work if the player has enough resources. 
--? @args SGroup sg_villagers, EBP ebp, Position/Marker pos
function AssignVillagersToConstructBuilding(sg_villagers, ebp, pos)
	local player = Util_GetPlayerOwner(sg_villagers)
	local position = Util_GetPosition(pos)
	local direction = World_Pos(-1, 0, -1)
	local facing = World_Pos(position.x + direction.x * 100, 0, position.z + direction.z * 100)
	LocalCommand_PlayerSquadConstructBuilding(player, sg_villagers, ebp, position, facing, false)
end

--? @shortdesc Grabs villagers and gets them moving around to look busy. Meant for non-player/AI villagers only. Should be run as an Interval Rule.
--? @args In the interval data table provide playerID and a location marker, and optional sgroup, and optional egroup
--? @extdesc Example: Rule_AddInterval(IdleVillagers_MakeBusy, 5, {marker = mkr_town, player = player2, sgroup = sg_spare_villagers})
function IdleVillagers_MakeBusy(context, data) --marker, player, optional sgroup, optional egroup
	
	assert(data.marker ~= nil, "No Marker assigned for IdleVillagers_MakeBusy")
	assert(data.player ~= nil, "No Player assigned for IdleVillagers_MakeBusy")
	
	--Get a list of valid buildings to move to (no defense buildings or walls)
	if data.egroup == nil then
		EGroup_Clear(eg_temp)
		Player_GetAllEntitiesNearMarker(data.player, eg_temp, data.marker)
		EGroup_Filter(eg_temp, "defensive_structure", FILTER_REMOVE)
	else
		EGroup_Clear(eg_temp)
		EGroup_Duplicate(data.egroup, eg_temp)
		EGroup_Filter(eg_temp, "defensive_structure", FILTER_REMOVE)
	end
	
	local _Wander = function(gid, idx, sid)	
		--Don't issue a command if the unit is under attack
		if Squad_IsUnderAttack(sid, 1) == false then
			--Don't issue a command if the unit is already moving
			if Squad_IsMoving(sid) == false and Squad_IsConstructing(sid) == false then 
				SGroup_Single(sg_single, sid)
				local targetEntity = EGroup_GetRandomSpawnedEntity(eg_temp) --Stores a random build as target
				Cmd_FormationMove(sg_single, targetEntity, false) --Move current squad (villager) to target
			end
		end
	end
	
	--Prunes busy villagers from the idle list
	local _IdleCheck = function(gid, idx, sid)
		if Squad_IsIdle(sid) ~= true then SGroup_Remove(gid, sid) end
	end

	--Cancel if there are no valid move-tos
	if EGroup_CountSpawned(eg_temp) > 1 then
		--If no sgroup was assigned, grab all idle villagers
		if data.sgroup ~= nil then
			if SGroup_CountSpawned(data.sgroup) > 0 then
				SGroup_Clear(sg_temp)
				SGroup_Duplicate(data.sgroup, sg_temp)
				SGroup_ForEach(sg_temp, _IdleCheck)
				SGroup_ForEach(sg_temp, _Wander)
			else
				Rule_RemoveMe()
			end
		else
			Player_GetAllSquadsNearMarker(data.player, sg_temp, data.marker)
			SGroup_Filter(sg_temp, "scar_villager", FILTER_KEEP)
			SGroup_ForEach(sg_temp, _IdleCheck)
			SGroup_ForEach(sg_temp, _Wander)
		end
	else
		Rule_RemoveMe()
	end
	
end

--? @returns the average position of all squads in an sgroup. Returns nil if there are no squads
function SGroup_GetAvgPosition(sgroup)
	local avgPosition = nil
	local numSquads = SGroup_Count(sgroup)
	
	if numSquads > 0 then
		local x_total = 0
		local y_total = 0
		local z_total = 0
		
		local ConsiderSquad = function(gid, idx, sid)
			local position = Squad_GetPosition(sid)
			x_total = x_total + position.x
			y_total = y_total + position.y
			z_total = z_total + position.z
		end
		
		SGroup_ForEach(sgroup, ConsiderSquad)
		avgPosition = World_Pos(x_total / numSquads, y_total / numSquads, z_total / numSquads)
	end
	return avgPosition
end

--? @disables the hold extension in the given sgroup
function SGroup_DisableHold(sgroup)
	local _DisableHold = function(gid, idx, sid)
		if Squad_IsAlive(sid) then
			Squad_SetExtEnabled(sid, "hold_ext", false)
		end
	end
	SGroup_ForEach(sgroup, _DisableHold)
end

function SendReinforceNotification(where, text, intel)
	
	if text == nil then text = 11172066 end 		-- Reinforcements Have Arrived!
	--UI_CreateMinimapBlip(where, 12, "objective_secondary")
	EventCues_CallToAction(text, CTA_CELEBRATE, intel, nil, where, 20)
end

function PositionWithOffset(position, x_offset, z_offset)
	if scartype(position) == ST_SCARPOS or scartype(position) == ST_MARKER then
		local new_pos = Util_GetPosition(position)
		new_pos.x = new_pos.x + x_offset
		new_pos.z = new_pos.z + z_offset
		return new_pos
	else
		print("INVALID POSITION")		
		return nil
	end
end

----? @shortdesc Wraps the input in a table and returns it. Does nothing if it was already a table.
function NormalizeTable(input)
	if input == nil then 
		return {}
	end

	if scartype(input) == ST_TABLE then
		return input
	else
		return { input }
	end
end

--? @shortdesc Prepares a command to be issued in a second or so, once a sim frame has ticked; usually used when units were just spawned by a previous command
--? @args SGroup sgroup, Marker/Position/SGroup/Table destination, Boolean attackMove, Number delay, Boolean destroyOnArrive, Function onDestroyCallback
function MissionOMatic_SGroupCommandDelayed(sgroup, destination, attackMove, delay, destroyOnArrive, onDestroyCallback)
	
	-- Make sure we've got a numerical delay that's more than zero
	if delay == nil then
		delay = 1
	end
	assert(scartype(delay) == ST_NUMBER and delay > 0, "Delayed move requires non-zero, non-nil delay")
	
	-- Are we passing in one thing with a position, or a table?
	if Util_HasPosition(destination) then
		-- Make sure whatever we passed in is converted to a table
		destination = { destination }
	end
	
	if scartype(destination) == ST_TABLE then
		Rule_AddOneShot(MissionOMatic_SGroupCommandDelayed_B, delay, {
			sgroup = sgroup,
			moveTable = destination,
			attackMove = attackMove,
			destroyOnArrive = destroyOnArrive,
			onDestroyCallback = onDestroyCallback,
		})
	else
		fatal("Invalid destination(s) passed to command function, must have position or be a table")
	end
	
end

--? @shortdesc Helper function that actually sends units somewhere once they're ready to go
function MissionOMatic_SGroupCommandDelayed_B(context, data)

	-- The delay could have been long enough for the SGroup to be totally killed off, so check for that before doing anything
	if scartype(data.sgroup) ~= ST_SGROUP or SGroup_Count(data.sgroup) <= 0 or Util_GetPlayerOwner(data.sgroup) == nil then
		if scartype(data.sgroup) ~= ST_SGROUP then
			print(string.format("Delayed Formation Move failed; sgroup is %s", scartype_tostring(data.sgroup)))	
		elseif SGroup_Count(data.sgroup) <= 0 then
			print(string.format("Delayed Formation Move failed; sgroup %s is empty", SGroup_GetName(data.sgroup)))
		elseif Util_GetPlayerOwner(data.sgroup) == nil then
			print(string.format("Delayed Formation Move failed; sgroup %s has invalid NIL player owner", SGroup_GetName(data.sgroup)))	
		end
		-- Early out
		return
	end
	
	-- Now we can actually issue the orders
	if scartype(data.moveTable) == ST_TABLE then
		-- Go through the whole table
		for idx = 1, #(data.moveTable), 1 do
			local notLast = #(data.moveTable) > 1
			local thisDestination = data.moveTable[idx]
			-- Sometimes a group that had units when it was set as a destination no longer has units, because they died. That will cause an FSE, so check for that.
			local isInvalidSGroup = scartype(thisDestination) == ST_SGROUP and SGroup_Count(thisDestination) <= 0
			local isInvalidEGroup = scartype(thisDestination) == ST_EGROUP and EGroup_Count(thisDestination) <= 0
			if isInvalidSGroup == false and isInvalidEGroup == false then
				if (data.attackMove == true) then
					if idx == #(data.moveTable) and data.destroyOnArrive == true then
						Cmd_FormationAttackMove(data.sgroup, thisDestination, notLast, true, data.onDestroyCallback)
					else
						Cmd_FormationAttackMove(data.sgroup, thisDestination, notLast)
					end
				else
					if idx == #(data.moveTable) and data.destroyOnArrive == true then
						Cmd_FormationMoveToAndDestroy(data.sgroup, thisDestination, notLast, nil, data.onDestroyCallback)
					else
						Cmd_FormationMove(data.sgroup, thisDestination, notLast)
					end
				end
			else
				--print(string.format("Passed destination group %s now empty; skipping", thisDestination))
			end
		end
	end
	
end

--? @shortdesc Function that reveals FOW on units in an SGroup in a way that follows them
function MissionOMatic_RevealMovingSGroup(sgroupToReveal)
	
	-- Add these to be watched, setting up the rule if necessary
	if SGroup_Count(sgroupToReveal) > 0 then
		
		-- Make sure the tracking SGroup exists
		if scartype(sg_tracking_revealed) ~= ST_SGROUP then
			sg_tracking_revealed = SGroup_CreateIfNotFound("sg_tracking_revealed")
		end
		
		-- Add to global group
		SGroup_AddGroup(sg_tracking_revealed, sgroupToReveal)
		
		-- Add the rule if it doesn't already exist
		if Rule_Exists(MissionOMatic_RevealMovingTarget_Rule) == false then
			Rule_AddInterval(MissionOMatic_RevealMovingTarget_Rule, 0.125)
		end
		
	end
	
end

--? @shortdesc Finds any goal sequence that has a certain key, and toggles its state
--? @args VALUE searchKey, BOOLEAN value
function Missionomatic_DisableTrainingByGoalKey(searchKey)
	
	-- Don't explode if we put in something invalid
	if _TrainingGoals == nil or #_TrainingGoals <= 0 or searchKey == nil then
		return	
	end
	
	if scartype(t_pausedTrainingSequences) ~= ST_TABLE then
		t_pausedTrainingSequences = {}
	end
	
	-- Search all goalSequences for goals that have this key
	for iSeq, goalSequence in pairs(_TrainingGoals) do
		for iGoal, goal in pairs (goalSequence.goals) do
			if goal.key == searchKey then
				-- Blast it
				Training_EndGoalSequence(goalSequence, false)
				-- Ideally we'd use EnableGoalSequence to set it to disabled, then re-enable it later if requested
				-- Unfortunately the disabling didn't work, and there's no available bandwidth for anyone to explain how the training system works
				-- A deep dive into the script is too much time for the work we have left to do and the C++ functions involved are opaque
				-- TODO: Ideally this should allow us to turn things back on again after they've been turned off
			end
		end
		-- We do want to go through every single goal sequence, since there may be multiple sequences with this key
	end
	
end

--? @shortdesc Adds a training hint to a certain kind of squad that is resolved by selecting a squad of that type
function MissionOMatic_HintOnSquadSelect(stringEnglish, locID, goalSequenceString, squadFilter, extraCheckBool)

	-- BYPASS FUNCTION
	local function _Predicate_Selected(goal)
		Player_GetAll(World_GetPlayerAt(1))
		SGroup_Filter(sg_allsquads, squadFilter, FILTER_KEEP)
		
		-- We may want to pass in other, extra filters
		if scartype(extraCheckBool) == ST_FUNCTION then
			local _ExtraCheck = function(gid, idx, sid)
				if extraCheckBool(sid) == false then
					SGroup_Remove(sg_allsquads, sid)
				end
			end
			SGroup_ForEach(sg_allsquads, _ExtraCheck)
		end
		
		-- Ultimately, we want something to be selected!
		return Misc_IsSGroupSelected(sg_allsquads, ANY)
	end
	
	-- TRIGGER FUNCTION
	local function _Trigger_NotSelectedRecently(goalSequence)
		if ABriefPeriodOfTimeHasPassed(goalSequence) then
			Player_GetAll(World_GetPlayerAt(1))
			SGroup_Filter(sg_allsquads, squadFilter, FILTER_KEEP)
			if SGroup_Count(sg_allsquads) > 0 then
				local squad = SGroup_GetSpawnedSquadAt(sg_allsquads, 1)
				goalSequence.goals[goalSequence.currentGoalIndex].key = squad
				return true
			end
		end
		return false
	end
	
	-- OTHER STUFF
	local GoalUI = {
		ID = stringEnglish,
		Message = locID, 
		DataTemplate = "LeftClickTrainingDataTemplate",
	}
	local GoalDoThing = Training_Goal(
		nil, 
		GoalUI, 
		_Predicate_Selected
	)
	local GoalSequenceUseAura = Training_GoalSequence(
		goalSequenceString, 								-- id
		1, 													-- repeatMax
		0, 													-- remindMax
		_Trigger_NotSelectedRecently, 						-- trigger
		CampaignTraining_TimeoutIgnorePredicate, 			-- ignore
		nil,										 		-- remind
		_Predicate_Selected, 								-- bypass
		true, 												-- canRegress
		{GoalDoThing}										-- goals
	)
	Training_AddGoalSequence(GoalSequenceUseAura)
	
	Training_EnableGoalSequenceByID(goalSequenceString, true)
	
end

--? @shortdesc Adds a training hint to a certain kind of squad that is resolved by selecting a squad of that type
function MissionOMatic_HintOnHover_Xbox(funcTrigger, stringEnglish, locID, goalSequenceString)

	--
	-- GOAL #1
	--
	-- Completion function
	local function _Predicate_Selected(goal)
		-- If it's there's a keyType, prioritize that
		if scartype(goal.keyType) == ST_STRING then
			Misc_GetSelectedSquads(sg_temp, false)
			for idx = 1, SGroup_Count(sg_temp) do
				if Squad_IsOfType(SGroup_GetSquadAt(sg_temp, idx), goal.keyType) then
					return true
				end
			end
		-- If there's a keyEntity, look for that!
		elseif goal.keyIsEntity == true then
			local keyEntity = Entity_FromID(goal.key)
			if scartype(keyEntity) == ST_ENTITY then
				Misc_GetSelectedEntities(eg_temp, false)
				for idx = 1, EGroup_Count(eg_temp) do
					if EGroup_GetEntityAt(eg_temp, idx) == keyEntity then
						return true
					end
				end
			end
		-- Otherwise, look for a squad!
		else
			local keySquad = Squad_FromID(goal.key)
			if scartype(keySquad) == ST_SQUAD then
				Misc_GetSelectedSquads(sg_temp, false)
				for idx = 1, SGroup_Count(sg_temp) do
					if SGroup_GetSquadAt(sg_temp, idx) == keySquad then
						return true
					end
				end
			end
		end
		return false
	end
	
	-- Structure
	local GoalSelectSquad = Training_Goal("Squad", 
		{
			ID = stringEnglish,
			Message = locID,
			DataTemplate = "GenericTrainingDataTemplate",
		},
		_Predicate_Selected)
	
	
	-- GOAL #2
	--
	-- Radial Menu
	local GoalOpenRadial = Training_Goal("Squad",
		{
			ID = "Press RT to display the Radial Menu",
			Message = "$999680", 
			DataTemplate = "GenericTrainingDataTemplate",
		}, 
		UserHasOpenedContextualRadial)
	
	
	-- GOAL #3
	--
	-- Item in structure
	local GoalViewAbility = Training_Goal("PBG",
		{
			ID = stringEnglish,
			Message = locID, 
			DataTemplate = "RadialTrainingDataTemplate",
		}, 
		_Missionomatic_GoalPredicate_HoveredOverBP)
	
	--
	-- GOAL SEQUENCE
	--
	local GoalSequence = Training_GoalSequence(
		goalSequenceString, 								-- id
		1, 													-- repeatMax
		1, 													-- remindMax
		funcTrigger, 										-- trigger
		CampaignTraining_TimeoutIgnorePredicate, 			-- ignore
		nil,												-- remind
		_Missionomatic_SequencePredicate_HoveredOverBP,		-- bypass
		true, 												-- canRegress
		{GoalSelectSquad, GoalOpenRadial, GoalViewAbility}					-- goals
	)
	
	Training_AddGoalSequence(GoalSequence)
	
	Training_EnableGoalSequenceByID(goalSequenceString, true)
	
end

function MissionOMatic_HintOnHover(funcTrigger, stringEnglish, locID, goalSequenceString)

	--
	-- GOAL #1
	--
	-- Completion function
	local function _Predicate_Selected(goal)
		-- If it's there's a keyType, prioritize that
		if scartype(goal.keyType) == ST_STRING then
			Misc_GetSelectedSquads(sg_temp, false)
			for idx = 1, SGroup_Count(sg_temp) do
				if Squad_IsOfType(SGroup_GetSquadAt(sg_temp, idx), goal.keyType) then
					return true
				end
			end
		-- If there's a keyEntity, look for that!
		elseif goal.keyIsEntity == true then
			local keyEntity = Entity_FromID(goal.key)
			if scartype(keyEntity) == ST_ENTITY then
				Misc_GetSelectedEntities(eg_temp, false)
				for idx = 1, EGroup_Count(eg_temp) do
					if EGroup_GetEntityAt(eg_temp, idx) == keyEntity then
						return true
					end
				end
			end
		-- Otherwise, look for a squad!
		else
			local keySquad = Squad_FromID(goal.key)
			if scartype(keySquad) == ST_SQUAD then
				Misc_GetSelectedSquads(sg_temp, false)
				for idx = 1, SGroup_Count(sg_temp) do
					if SGroup_GetSquadAt(sg_temp, idx) == keySquad then
						return true
					end
				end
			end
		end
		return false
	end
	
	-- Structure
	local GoalSelectSquad = Training_Goal("Squad", 
		{
			ID = stringEnglish,
			Message = locID,
			DataTemplate = "LeftClickTrainingDataTemplate",
		},
		_Predicate_Selected)
	
	--
	-- GOAL #2
	--
	-- Item in structure
	local GoalViewAbility = Training_Goal("PBG",
		{
			ID = stringEnglish,
			Message = locID, 
			DataTemplate = "GenericTrainingDataTemplate",
		}, 
		_Missionomatic_GoalPredicate_HoveredOverBP)
	
	--
	-- GOAL SEQUENCE
	--
	local GoalSequence = Training_GoalSequence(
		goalSequenceString, 								-- id
		1, 													-- repeatMax
		1, 													-- remindMax
		funcTrigger, 										-- trigger
		CampaignTraining_TimeoutIgnorePredicate, 			-- ignore
		nil,												-- remind
		_Missionomatic_SequencePredicate_HoveredOverBP,		-- bypass
		true, 												-- canRegress
		{GoalSelectSquad, GoalViewAbility}					-- goals
	)
	
	Training_AddGoalSequence(GoalSequence)
	
	Training_EnableGoalSequenceByID(goalSequenceString, true)
	
end

--? @shortdesc After a timer, OnHover hints should go away
function _Missionomatic_Hint_UserHasTimedOut(goalSequence)

	if CampaignTraining_TimeoutIgnorePredicate(goalSequence) then
		return true
	else
		if goalSequence.goals[1].key ~= nil and Squad_IsValid(goalSequence.goals[1].key) == false then 
			return true
		end
	end
	
end

--? @shortdesc A predicate for detecting whether a BP has been hovered over
function _Missionomatic_SequencePredicate_HoveredOverBP(goalSequence)
	
	-- there is a variable number of goals depending on if we are on xbox or pc, but the one we want is always the last
	local index = #goalSequence.goals
	
	if UI_IsXboxControllerUI() then
		-- if we are on Xbox we don't want to bypass unless the player has the right unit selected and the menu open
		local target_unit = goalSequence.goals[1].key
		if scartype(target_unit) == ST_SQUAD then
			if (Misc_IsSquadSelected(target_unit) and (UI_GetActiveRadialMenuType() == RMT_ContextualRadialMenu)) == false then
				return false
			end
		elseif scartype(target_unit) == ST_ENTITY then
			if (Misc_IsEntitySelected(target_unit) and (UI_GetActiveRadialMenuType() == RMT_ContextualRadialMenu)) == false then
				return false
			end
		end			
	end
	
	return _Missionomatic_GoalPredicate_HoveredOverBP(goalSequence.goals[index])

end

--? @shortdesc A predicate for detecting whether a BP has been hovered over
function _Missionomatic_GoalPredicate_HoveredOverBP(goal)
	

	local timerSpan = 20
	local bp = goal.key
	if training_previousAbilityBlueprint == bp or _MissionOMatic_IsUpgrading(bp) == true then
		return true
	end
	
	if goal.timerID == nil then
		goal.timerID = Training_GetNewTimerID()
		Timer_Start(goal.timerID, timerSpan)
	elseif Timer_Exists(goal.timerID) == false then
		Timer_Start(goal.timerID, timerSpan)
	end
	
	-- on Xbox we want to dismiss the hint after a bit of time rather than worrying about actual hovering
	if UI_IsXboxControllerUI() then
		return Timer_GetElapsed(goal.timerID) > __t_trainingRadialInterval 
	end

	
	local currentTime = Timer_GetElapsed(goal.timerID)
	if goal.temp.lastTimeWithoutLooking == nil then 
		goal.temp.lastTimeWithoutLooking = 0 
	end
	
	if scartype(bp) ~= ST_TABLE then 
		bp = {bp}
	end
	
	if Table_Contains(bp, training_currentHoverBlueprint) then
		if currentTime - goal.temp.lastTimeWithoutLooking > 1 then 
			return true
		end
		
		return false
	end
	
	goal.temp.lastTimeWithoutLooking = currentTime
	return false
	
end

--? @shortdesc For checking whether a hinted BP is already being produced
function _MissionOMatic_IsUpgrading(bp)
	
	local soughtBP = bp
	if scartype(bp) == ST_TABLE then
		soughtBP = bp[1]
	end
	
	Player_GetAll(World_GetPlayerAt(1))
	EGroup_Filter(eg_allentities, "wall", FILTER_REMOVE)
	EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
	
	local _HasSoughtBP = function(gid, index, eid)
		local queueSize = Entity_GetProductionQueueSize(eid)
		if queueSize > 0 then
			for i = 0, queueSize - 1 do
				if Entity_GetProductionQueueItem(eid, i) == bp then
					return true
				end
			end
		end
	end
	
	if EGroup_CountSpawned(eg_allentities) > 0 then
		return EGroup_ForEachAllOrAny(eg_allentities, ANY, _HasSoughtBP)
	end
	
end

--? @shortdesc A predicate for detecting whether an ability has been hovered over
function _Missionomatic_TrainingPredicate_IgnoreHover(goalSequence)

	if CampaignTraining_TimeoutIgnorePredicate(goalSequence) then
		return true
	end
	
	local cannotSeeKey = UserCannotSeeSquadKey(goalSequence)
	if cannotSeeKey then
		-- For breakpointing
		return true
	end
	return cannotSeeKey
	
end

--? @shortdesc Monitors abilities that have been flagged for usage-based hint resolution
function _MissionOMatic_WatchForAbility(context, data)
	
	for key, value in pairs(g_hintAbilityWatch) do
		if g_hintAbilityWatch[key] == false and context.ability == BP_GetAbilityBlueprint(key) then
			print(string.format("Hint-watched ability %s cast", key))
			g_hintAbilityWatch[key] = true
		end
	end
	
end

--? @shortdesc Adds a training hint to a certain kind of squad that is resolved by selecting a squad of that type
function MissionOMatic_HintOnAbilityUsed(stringEnglish, locID, goalSequenceString, abilityString, leftClick)

	-- We want to know if this ability was used, so let's set a flag
	g_hintAbilityWatch = g_hintAbilityWatch or {}
	g_hintAbilityWatch[abilityString] = false

	-- Start the rule if it wasn't already running
	if Rule_Exists(_MissionOMatic_WatchForAbility) == false then
		Rule_AddGlobalEvent(_MissionOMatic_WatchForAbility, GE_AbilityExecuted)
	end
	
	-- BYPASS FUNCTION
	local function _Predicate_WasAbilityUsed(goal)
		-- This should be true as soon as the ability gets used, false otherwise
		if g_hintAbilityWatch[abilityString] == true then
			print(string.format("Tracked ability %s use detected", abilityString))
		end
		-- Don't just return it - return whether it's true. Otherwise it could return nil sometimes.
		return g_hintAbilityWatch[abilityString] == true
	end
	
	-- TRIGGER FUNCTION
	local function _Trigger_OnscreenCaster(goalSequence)
		if ABriefPeriodOfTimeHasPassed(goalSequence) then
			local squads = Player_GetSquads(g_playerMongol)
			for idx = 1, SGroup_Count(squads) do
				local squad = SGroup_GetSquadAt(squads, idx)
				if squad ~= nil and Squad_HasAbility(squad, BP_GetAbilityBlueprint(abilityString)) == true and Misc_IsSquadOnScreen(squad, 100) then
					goalSequence.goals[goalSequence.currentGoalIndex].key = squad
					return true
				end
			end
		end
		return false
	end
	
	-- OTHER STUFF
	local templateString = "RightClickTrainingDataTemplate"
	if leftClick == true then
		templateString = "LeftClickTrainingDataTemplate"
	end
	
	local GoalUseAbility = Training_Goal(
		nil, 
		{
			ID = stringEnglish,
			Message = locID, 
			DataTemplate = templateString,
		}, 
		_Predicate_WasAbilityUsed
	)
	local GoalSequenceUseAura = Training_GoalSequence(
		goalSequenceString, 								-- id
		1, 													-- repeatMax
		0, 													-- remindMax
		_Trigger_OnscreenCaster, 							-- trigger
		nil, 												-- ignore
		nil,										 		-- remind
		nil, 												-- bypass
		false, 												-- canRegress
		{GoalUseAbility}									-- goals
	)
	Training_AddGoalSequence(GoalSequenceUseAura)
	
	Training_EnableGoalSequenceByID(goalSequenceString, true)
	
end

-- Called every sim tick
function MissionOMatic_RevealMovingTarget_Rule()
	-- Only do this if we have stuff to reveal
	if scartype(sg_tracking_revealed) == ST_SGROUP and SGroup_Count(sg_tracking_revealed) > 0 then
		
		-- This is how we'll reveal squads
		local _RevealSquad = function(gid, idx, sid)
			FOW_RevealSquad(sid, 20, 0.125)
			if Squad_IsAlive(sid) and Squad_Count(sid) > 0 then
				FOW_RevealSquad(sid, 20, 0.125)
			else
				SGroup_Remove(sg_tracking_revealed, sid)
			end
		end
		
		-- Go through them all!
		SGroup_ForEach(sg_tracking_revealed, _RevealSquad)
		
		-- If the SGroup is empty, remove this rule
		if SGroup_Count(sg_tracking_revealed) <= 0 then
			Rule_RemoveMe()
		end
		
	end
end

function log(string)
	print(World_GetGameTimeFormatted().."   "..string)
end

--? @shortdesc Returns the game time as a string. Formatted as mm:ss 
--? @result String time
function World_GetGameTimeFormatted()
	local minutes = math.floor(World_GetGameTime()) // 60
	local seconds = math.floor(World_GetGameTime()) % 60
	local minutes_string = tostring(minutes)
	if minutes < 10 then
		minutes_string = "0"..minutes_string
	end
	if seconds < 10 then 
		return minutes_string..":0"..seconds	
	else 
		return minutes_string..":"..seconds 
	end
end

--? @shortdesc Returns the game time as a string. Formatted as mm:ss 
--? @result String time
function FormatSeconds(seconds)
	local m = math.floor(seconds) // 60
	local s = math.floor(seconds) % 60
	local m_string = tostring(m)
	if m < 10 then
		m_string = "0"..m_string
	end
	if s < 10 then 
		return m_string..":0"..s
	else 
		return m_string..":"..s 
	end
end

--? @shortdesc Spawns a specific pickup at a specific location
--? @args MARKER/POSITION position, STRING resource, NIL/NUMBER amount
function Missionomatic_SpawnPickup(position, resource, value)
	
	-- Sanity checks
	if scartype(position) ~= ST_MARKER and scartype(position) ~= ST_SCARPOS then
		fatal(string.format("Trying to spawn a %s pickup worth %s at %s, but position is invalid!", resource, value, position))
	end
	
	-- The pickup itself
	local pickupEBP = BP_GetEntityBlueprint("resource_pickup_"..resource)
		
	-- For storing the pickup
	eg_newPickup = EGroup_CreateIfNotFound("eg_newPickup")
	EGroup_Clear(eg_newPickup)
	
	-- Do the things!
	eg_newPickup = Util_CreateEntities(nil, eg_newPickup, pickupEBP, position, 1)
	
	-- For setting the resource - there's a default though
	if scartype(value) == ST_NUMBER then
		local _SetResource = function(gid, idx, eid)
			Entity_SetStateModelFloat(eid, "resource_pickup_amount_"..resource, value)
		end
		EGroup_ForEach(eg_newPickup, _SetResource)
	end
	
end

--? @shortdesc Sets all gates in an EGroup to be either locked or unlocked
--? @args EGROUP egroup, BOOLEAN locked
function Missionomatic_SetGateLock(egroup, locked)

	EGroup_Filter(egroup, "gate", FILTER_KEEP)
	print(string.format("GATELOCK-A: Trying to set gates in %s to locked=%s", EGroup_GetName(egroup), locked))
	local autoGroup = EGroup_CreateUnique("disable_auto")
	
	local _FilterCurrentState = function(gid, idx, eid)
		local isAuto = Entity_GetStateModelBool(eid, "gate_auto_mode_enabled")
		-- As of current implementation, auto=true means locked=false, auto=false means locked=true
		-- So if auto and locked match, the gate isn't in the state we're requesting
		-- Keep it and toggle it
		if isAuto == locked then
			EGroup_Add(autoGroup, eid)
		end
	end
	EGroup_ForEach(egroup, _FilterCurrentState)
	Cmd_Ability(autoGroup, BP_GetAbilityBlueprint("core_gate_auto_toggle"))
	print(string.format("GATELOCK-A: Toggled auto lock on %s gates", EGroup_Count(autoGroup)))
	
	-- "core_gate_lock_toggle" appears to have been deprecated by recent gate changes, though it still exists
	-- Leaving these commented out in case we need to restart doing this delayed behaviour
	-- Originally done because it takes a frame for the autolock to actually take effect
	--Rule_AddOneShot(Missionomatic_SetGateLock_B, 1, { egroup = lockGroup, locked = locked, })
	
end

--? @shortdesc Follow-up gate locking function, because you can't call two commands on an Entity in the same frame
function Missionomatic_SetGateLock_B(context, data)
	
	-- Do a second filter, in case things have changed in the meantime; if it's already at the target state, remove it so we don't flip it back
	local _FilterCurrentState = function(gid, idx, eid)
		local isLocked = Entity_GetStateModelBool(eid, "gate_locked")
		if isLocked == data.locked then
			EGroup_Remove(data.egroup, eid)
		end
	end
	EGroup_ForEach(data.egroup, _FilterCurrentState)
	
	Cmd_Ability(data.egroup, BP_GetAbilityBlueprint("core_gate_lock_toggle"))
	print(string.format("GATELOCK-B: Toggled gate lock on %s gates to %s", EGroup_Count(data.egroup), data.locked))
	
end

--? @shortdesc Initialize a player for use in campaign missions. Sets defaults for Player Names, Ages, and Colors, if not defined. Returns a World_GetPlayerAt value.
--? @args Int playerSlot, Table playerData
function Missionomatic_InitPlayer(playerSlot, playerData)
	
	-- Load playerData or defaults
	local playerID = World_GetPlayerAt(playerSlot)
	local name = playerData.name or "$11168064"
	local currentAge = playerData.currentAge or AGE_DARK
	local maxAge = playerData.maxAge or currentAge
	local playerColorSlot = playerData.playerColorSlot or playerData.color or playerSlot
	local playerUIColorSlot =  playerData.playerUIColorSlot or playerData.color or playerColorSlot	
	
	Setup_SetPlayerName(playerID, name)
	Player_SetCurrentAge(playerID, currentAge)
	Player_SetMaximumAge(playerID, maxAge)
	Game_SetPlayerColour(playerID, playerColorSlot)
	
	return playerID
end

--? @shortdesc Plays a walla charge sound on the sgroup, respecting the size of the sgroup 
--? @args SGroup sgroup
function Sound_PlayWallaChargeOnSGroup(sgroup)
	local sgroup_size = SGroup_CountSpawned(sgroup)
	if sgroup_size > 25 then
		Sound_PlayOnSquad(WALLA_CAMP_CHARGE_LARGE, sgroup)
	elseif sgroup_size > 15 then
		Sound_PlayOnSquad(WALLA_CAMP_CHARGE_MEDIUM, sgroup)
	elseif sgroup_size > 5 then
		Sound_PlayOnSquad(WALLA_CAMP_CHARGE_SMALL, sgroup)
	end
	
end

