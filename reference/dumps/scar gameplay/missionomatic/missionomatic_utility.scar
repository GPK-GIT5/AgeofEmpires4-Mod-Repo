function AddPendingDissolve(targetModule, sourceSGroup, updateIdealComposition, pause)
	local pendingDissolve = {
			targetModule = targetModule,
			sourceSGroup = sourceSGroup,
			updateIdealComposition = updateIdealComposition,
			pause = pause,
		}
	table.insert(t_pendingDissolveModules, pendingDissolve)	
end
	
function RemovePendingDissolve(targetModule, sourceSGroup)

	for i, v in pairs(t_pendingDissolveModules) do
		if v ~= nil and v.targetModule == targetModule and v.sourceSGroup == sourceSGroup then
			t_pendingDissolveModules[i] = nil
			break
		end
	end		
end

function PlayECAM(eventName)

	local actions = {
		action = "ExpositionCamera",
		eventName = eventName,
	}
	
	ActionList_PlayActions(actions)

end

function PlaySpeech(eventName)

	local actions = {
		action = "PlaySpeechEvent",
		eventName = eventName,
	}
	
	ActionList_PlayActions(actions)

end




--
--
-- Unit Tables
--
--


--? @shortdesc Takes an SGroup and returns a UnitTable that reflects the SGroup's makeup 
--? @args SGroupID sgroup
--? @result UnitTable
function UnitTable_GenerateFromSGroup(sgroup)

	local unitTable = {}
	
	local _AddSquad = function(gid, idx, sid)
		
		local unitType = MissionOMatic_GetTypeForBlueprint(Squad_GetBlueprint(sid))
		if unitType ~= nil then 
			UnitTable_AddUnitsByType(unitTable, unitType, 1)
		end
		 
	end
	SGroup_ForEach(sgroup, _AddSquad)
	
	return unitTable

end

function UnitTable_GetSlowestUnitSpeed(unitTable, player)
	local slowest_speed = 9999
	for i, unitRow in ipairs(unitTable) do
		if numSquads > 0 then
			local sbp
			if unitRow.sbp then
				sbp = unitRow.sbp	
			else
				sbp = Cardinal_ConvertTypeToSquadBlueprint(unitRow.type, player)
			end	
			local ebp = EBP_GetFromSBP(sbp)
			local speed = BP_GetEntityBPDefaultSpeed(ebp, true, player)
			if speed < slowest_speed then
				slowest_speed = speed
			end
		end
	end
	assert(slowest_speed < 9999, "unitTable has no units")
	return slowest_speed
end


--? @shortdesc Returns the count of the units in a UnitTable 
--? @args Table unitTable
--? @result Integer 
function UnitTable_CountUnits(unitTable)
	if unitTable.sbp or unitTable.type then
		return unitTable.numSquads or 1
	end
	
	local count = 0 
	for index, unitRow in pairs(unitTable) do 		
		count = count + (unitRow.numSquads or 1)
	end
	return count 
end

--? @shortdesc Checks if 2 unit rows have the same unitType or sbp
--? @args Table unitRowA, table unitRowB
function UnitTable_RowsHaveSameType(unitRowA, unitRowB)
	if unitRowA.type and unitRowA.type == unitRowB.type then
		return true	
	end
	if unitRowA.sbp and unitRowA.sbp == unitRowB.sbp then
		return true	
	end
	return false
end

--? @shortdesc Add units of a specific type to a UnitTable
--? @args Table unitTable, String type[, Int amount]
function UnitTable_AddUnitsByType(unitTable, unitType, number, tag)
	number = number or 1
	
	for index, unitRow in pairs(unitTable) do 
		if unitRow.type == unitType then
			unitRow.numSquads = unitRow.numSquads + number
			return		-- we adjusted the number for an existing entry, so we are done
		end
	end
	table.insert(unitTable, { type = unitType, numSquads = number, tag = tag })
end

--? @shortdesc Add units of a specific sbp to a UnitTable
--? @args Table unitTable, SBP sbp[, Int amount]
function UnitTable_AddUnitsBySBP(unitTable, sbp, number, tag)
	number = number or 1

	for index, unitRow in pairs(unitTable) do 
		if unitRow.sbp == sbp then
			unitRow.numSquads = unitRow.numSquads + number
			return		-- we adjusted the number for an existing entry, so we are done
		end
	end
	table.insert(unitTable, { sbp = sbp, numSquads = number, tag = tag })
end

--? @shortdesc Removes units of a specific type from a UnitTable
--? @args Table unitTable, String type[, Int amount]
function UnitTable_RemoveUnitsByType(unitTable, unitType, number)
	number = number or 1
	
	for index, unitRow in pairs(unitTable) do 
		if unitRow.type == unitType then
			unitRow.numSquads = unitRow.numSquads - number
			if unitRow.numSquads <= 0 then 
				table.remove(unitTable, index)
			end
			return		-- we adjusted the number for an existing entry, so we are done
		end
	end
end


--? @shortdesc Removes units of a specific type from a UnitTable
--? @args Table unitTable, SBP sbp[, Int amount]
function UnitTable_RemoveUnitsBySBP(unitTable, sbp, number)
	number = number or 1
	
	for index, unitRow in pairs(unitTable) do 
		if unitRow.sbp == sbp then
			unitRow.numSquads = unitRow.numSquads - number
			if unitRow.numSquads <= 0 then 
				table.remove(unitTable, index)
			end
			return		-- we adjusted the number for an existing entry, so we are done
		end
	end
end

--? @shortdesc Add all of the units in a UnitTable to another UnitTable
--? @args Table unitTable, Table unitsToAdd
function UnitTable_AddUnits(unitTable, unitsToAdd)
	for index, unitRow in pairs(unitsToAdd) do 
		if unitRow.type then
			UnitTable_AddUnitsByType(unitTable, unitRow.type, unitRow.numSquads, unitRow.tag)
		elseif unitRow.sbp then
			UnitTable_AddUnitsBySBP(unitTable, unitRow.sbp, unitRow.numSquads, unitRow.tag)
		end
	end
	
end

--? @shortdesc Remove all of the units in a UnitTable from another UnitTable
--? @args Table unitTable, Table unitsToRemove
function UnitTable_RemoveUnits(unitTable, unitsToRemove)
	for index, unitRow in pairs(unitsToRemove) do 
		if unitRow.type then
			UnitTable_RemoveUnitsByType(unitTable, unitRow.type, unitRow.numSquads)
		elseif unitRow.sbp then
			UnitTable_RemoveUnitsBySBP(unitTable, unitRow.sbp, unitRow.numSquads)
		end
	end
end

function UnitTable_GetSingleUnit(unitTable)
	for i, unitRow in ipairs(unitTable) do
		if unitRow.numSquads > 0 then
			return {{ type = unitRow.type, sbp = unitRow.sbp, numSquads = 1 }}
		end
	end
	return nil
end

function UnitTable_PopSingleUnit(unitTable)
	local returnedUnitTable = nil
	for i, unitRow in ipairs(unitTable) do
		if unitRow.numSquads > 0 then
			returnedUnitTable = {{ type = unitRow.type, sbp = unitRow.sbp, numSquads = 1 }}
			unitRow.numSquads = unitRow.numSquads - 1
		end
		if unitRow.numSquads == 0 then
			table.remove(unitTable, i)
		end
		if returnedUnitTable then
			return returnedUnitTable
		end
	end
	return nil
end

function UnitTable_GetSubsetByCount(unitTable, count, b_removeFromOriginal)
	local unitTableSubset = {}
	for i, unitRow in ipairs(unitTable) do
		-- Sometimes this function is called multiple times on the same unit table,
		-- particularly if there are multiple transport holds being distributed to
		-- So if this row has numSquads=0, that's fine, just continue
		if unitRow.numSquads > 0 then
			local numSquadsDelta = math.min(unitRow.numSquads, count)
			if b_removeFromOriginal then
				unitRow.numSquads = unitRow.numSquads - numSquadsDelta
			end
			-- Don't add things if they would have zero squads!
			if numSquadsDelta > 0 then
				UnitTable_AddUnitRowWithCustomData(unitTableSubset, { type = unitRow.type, sbp = unitRow.sbp, numSquads = numSquadsDelta })
			end
			-- Stop if there's no more room for units
			count = count - numSquadsDelta
			if count == 0 then
				break
			end
		end
		--assert(unitRow.numSquads > 0, string.format("(%s, %s) unitRow's numSquads should be > 0, but is %s", unitRow.type, BP_GetName(unitRow.sbp), unitRow.numSquads))
	end
	return unitTableSubset
end

--? @shortdesc Count how many units of a given type there are in the UnitTable
--? @args Table unitTable, String type
function UnitTable_CountUnitsOfType(unitTable, unitType)
	local count = 0
	for i, unitRow in ipairs(unitTable) do
		if unitRow.type == unitType then
			count = count + unitRow.numSquads
		end
	end
	return count
end

--? @shortdesc Count how many units of a given type there are in the UnitTable
--? @args Table unitTable, SBP sbp
function UnitTable_CountUnitsOfSBP(unitTable, sbp)
	local count = 0
	for i, unitRow in ipairs(unitTable) do
		if unitRow.sbp == sbp then
			count = count + unitRow.numSquads
		end
	end
	return count
end

--? @shortdesc Similar to UnitTable_AddUnits, but preserves all custom data within each unit row
function UnitTable_AddUnitsWithCustomData(unitTable, unitsToAdd)
	for index, unitRow in ipairs(unitsToAdd) do 
		UnitTable_AddUnitRowWithCustomData(unitTable, unitRow)
	end
end

function UnitTable_AddUnitRowWithCustomData(unitTable, unitRowToAdd)
	unitRowToAdd.numSquads = unitRowToAdd.numSquads or 1
	
	for i, unitRow in ipairs(unitTable) do 
		unitRow.numSquads = unitRow.numSquads or 1
		if UnitRows_AreMatching(unitRow, unitRowToAdd) then
			unitRow.numSquads = unitRow.numSquads + unitRowToAdd.numSquads
			return
		end
	end
	table.insert(unitTable, unitRowToAdd)
end

function UnitRows_AreMatching(unitRowA, unitRowB)
	for key, value in pairs(unitRowA) do
		if key ~= "numSquads" and value ~= unitRowB[key] then
			return false
		end
	end
	return true
end

function UnitTable_GetResourceCost(units, player)
	local total_cost = 0
	for _, unitRow in ipairs(units) do
		local sbp
		if unitRow.sbp then
			sbp = unitRow.sbp
		elseif unitRow.type then
			sbp = Cardinal_ConvertTypeToSquadBlueprint(unitRow.type, player)
		else
			fatal("invalid unitRow")
		end
		local squad_cost = Player_GetSquadBPCost(player, sbp)
		local numSquads = unitRow.numSquads or 1
		total_cost = total_cost + (squad_cost.wood + squad_cost.food + squad_cost.gold + squad_cost.stone) * numSquads
	end
	return total_cost
end



--
--
-- Miscellaneous utilities
--
--



--? @shortdesc Converts an angle in degrees (0-360) to a short string representing a compass heading. 0 degrees is north; 90 degrees is east.
--? @args NUMBER angle
--? @result STRING ('n' for north, 'ne' for north-east, etc)
function AngleToCardinalDirection(angle)	-- the use of "cardinal" here is the classic meaning, not our project codename! (nice coincidence, though)
	
	local cardinaldirections = {	-- start with the representation of "north" and work around the compass clockwise
		"n",
		"ne",
		"e",
		"se",
		"s",
		"sw",
		"w",
		"nw",
	}
	
	local slice_angle = 360 / #cardinaldirections
	
	angle = angle + (slice_angle / 2)		-- add half a slice wedge to the angle, so instead of looking between -22.5 deg and 22.5 deg for slice one, we're now looking between 0 and 45 (assuming eight slices)
	angle = math.fmod(angle, 360)			-- account for the case where that takes us up past 360
	if angle < 0 then
		angle = angle + 360
	end
	return cardinaldirections[math.ceil(angle / slice_angle)]
	
end

--? @shortdesc Finds a marker with a given core name and a cardinal heading
--? @args STRING markerName, NUMBER markerDir (angle in degrees)
--? @result MARKER
function GetMarkerWithDirection(markerName, markerDir)

	local longSearchString = "mkr_"..markerName.."_"..AngleToCardinalDirection(markerDir)
	local shortSearchString = "mkr_"..markerName	
	
	if Marker_Exists(longSearchString, "") then
		return Marker_FromName(longSearchString, "")
	end
	
	if Marker_Exists(shortSearchString, "") then
		return Marker_FromName(shortSearchString, "")
	end
	
	fatal("Could not find a marker with the name "..longSearchString.." or "..shortSearchString)

end

--? @shortdesc takes a marker or locationName, and returns a marker. If it's a scarPos, return it
function ResolveSpawnLocation(where)
	
	if scartype(where) == ST_STRING then 
		local location = LOCATION(where)
		assert(location, "SpawnLocation string does not correspond to a valid location")
		return location.marker
		
	elseif scartype(where) == ST_MARKER then
		return where
		
	elseif scartype(where) == ST_SCARPOS then
		return where
		
	elseif scartype(where) == ST_TABLE then
		assert(false, "SpawnLocation no longer accepts tables, provide a marker or location instead")	
		
	else
		assert(false, string.format("SpawnLocation %s must be a marker, position, or location name, but is instead %s", where, scartype_tostring(where)))
	end
end


-- Take a table and turn it into a string, so we can write it out to a file and load it back in as Lua
function Table_SerializeToString(data, indent_level)

	indent_level = indent_level or 1
	
	-- opening brace
	local string = "{\n"
	
	-- table contents, one line at a time
	for index, value in pairs(data) do 
		
		if scartype(value) == ST_STRING or scartype(value) == ST_NUMBER or scartype(value) == ST_BOOLEAN or scartype(value) == ST_ENUM or scartype(value) == ST_TABLE then 
		
			for i = 1, indent_level do				-- start the line with an appropriate number of tabs
				string = string.."\t"
			end
			
			if scartype(index) == ST_STRING then	-- only use the key if it's a string from a dictionary-style array (this avoids using number indicies from array-style tables as keys)
				string = string..index.." = "
			end
			
			if scartype(value) == ST_STRING then	-- append the value itself (converted to a string)
				string = string..[["]]..value..[["]]
			elseif scartype(value) == ST_TABLE then
				string = string..Table_SerializeToString(value, indent_level + 1)
			elseif scartype(value) == ST_ENUM then
				string = string..Enum_ToString(value)
			else
				string = string..tostring(value)
			end
			
			string = string..",\n"					-- finally, append a comma and a newline
			
		end
		
	end

	-- closing brace
	for i = 1, indent_level - 1 do
		string = string.."\t"
	end
	string = string.."}"
	
	
	return string
	
end

--? @shortdesc Returns a suitable SCAR squadType for a given blueprint 
--? @extdesc Can also pass in a squadID and it will use that squad's blueprint
--? @args SquadID/SBP blueprint
--? @result String
function MissionOMatic_GetTypeForBlueprint(bp)

	if scartype(bp) == ST_SQUAD then 
		bp = Squad_GetBlueprint(bp)
	end

	for index, unit in pairs(t_allUnitTypes) do 
		if Squad_IsSBPOfType(bp, unit.unitType) then
			return unit.unitType
		end
	end
	
end

--? @shortdesc Dissolves a module and folds its units into another module
function DissolveModuleIntoModule(sourceModuleName, targetModuleName, updateIdealComposition, pause)
	-- Figure out what module to add to - often this won't be tied to a location at all
	local targetModule = MissionOMatic_FindModule(targetModuleName)
	local sourceModule = MissionOMatic_FindModule(sourceModuleName)
	if targetModule ~= nil and sourceModule ~= nil then
		local sg_source = SGroup_CreateUnique()
		if targetModule.player == sourceModule.player then
--			print("Disbanding "..tostring(sg_source))
--			print("Stopping encounter "..tostring(sourceModuleName))
			Prefab_DoAction(sourceModule, "Disband", sg_source)
			Rule_AddOneShot(DissolveModuleIntoModule_B, 0.25, {targetModule = targetModule, sourceSGroup = sg_source, updateIdealComposition = updateIdealComposition, pause = pause})
			AddPendingDissolve(targetModule, sg_source, updateIdealComposition, pause)				
		end
		
	end
end

function DissolveModuleIntoModule_B(context, data)
--	print("Dissolving unit count "..tostring(SGroup_CountSpawned(data.sourceSGroup)))
	RemovePendingDissolve(data.targetModule, data.sourceSGroup)
	Prefab_DoAction(data.targetModule, "AddSGroup", data.sourceSGroup, data.updateIdealComposition, data.pause)
	SGroup_Destroy(data.sourceSGroup)
end

--? @shortdesc Ensures that all pending dissolves are processed 
--? @args nil
--? @result nil
function VerifyAllDissolves()
	if t_pendingDissolveModules ~= nil then
		for i, v in pairs(t_pendingDissolveModules) do
			if v ~= nil then
				--	print("Adding sgroup "..tostring(v.sourceSGroup))
				Prefab_DoAction(v.targetModule, "AddSGroup", v.sourceSGroup, v.updateIdealComposition, v.pause)
				SGroup_Destroy(v.sourceSGroup)
				t_pendingDissolveModules[i] = nil
			end
		end	
	end
	-- ensure that there are no leftover step Bs
	Rule_Remove(DissolveModuleIntoModule_B)
end

--? @shortdesc Transfers all units from one module to another module, without destroying the source module 
--? @args String sourceModule, String targetModule[, Boolean pause] 
--? @result nil
function TransferModuleIntoModule(sourceModuleName, targetModuleName, pause)
	-- Figure out what module to add to - often this won't be tied to a location at all
	local targetModule = MissionOMatic_FindModule(targetModuleName)
	local sourceModule = MissionOMatic_FindModule(sourceModuleName)
	if targetModule ~= nil and sourceModule ~= nil then
	
		if targetModule.player == sourceModule.player then
			local sourceSGroup = Prefab_DoAction(sourceModule, "GetSGroup")
			Prefab_DoAction(targetModule, "AddSGroup", sourceSGroup, pause)
			Prefab_DoAction(sourceModule, "RemoveSGroup", sourceSGroup)
		end
	end
end

--? @shortdesc Transfers all units from one army to another 
--? @args Army sourceArmy, Army targetArmy 
function TransferArmyIntoArmy(sourceArmy, targetArmy)
	assert(sourceArmy and targetArmy)
	assert(sourceArmy.player == targetArmy.player)
	local sg_transfer = SGroup_CreateUniqueWithPrefix("sg_transfer")
	Army_GetSquads(sourceArmy, sg_transfer)
	Army_RemoveSGroup(sourceArmy, sg_transfer)
	Army_AddSGroup(targetArmy, sg_transfer)
	SGroup_Destroy(sg_transfer)
end

--? @shortdesc Spawns groups of units at a numbered sequence of markers
function SpawnUnitGroups(player, sgroupName, unitsTable, markerName, destroyFirst)
	for i = 1, #unitsTable do
		
		local markerNameFull = markerName..tostring(i)
		if not Marker_Exists(markerNameFull, "") then return end
		local marker = Marker_FromName(markerNameFull, "")
		
		local sgroupNameFull = sgroupName..tostring(i)
		if not SGroup_Exists(sgroupNameFull) then return end
		local sgroup = SGroup_FromName(sgroupNameFull)
		
		local units = unitsTable[i]
		
		if destroyFirst == true then
			SGroup_DestroyAllSquads(sgroup)
		end
		UnitEntry_DeploySquads(player, sgroup, units, marker)
	end
end

--? @shortdesc Spawns units at the specified location, and adds them to the module.
--? @args Table units, Module module, MarkerID/String spawnLocation[, Boolean pause] 
--? @result sgroup of the module
function SpawnUnitsToModule(units, module, spawnLocation, pause)
	local module = module
	if scartype(module) == ST_STRING then
		module = MissionOMatic_FindModule(module)
	end
	local player = module.player
	
	local spawn
	if spawnLocation then
		spawn = ResolveSpawnLocation(spawnLocation)
	else
		spawn = ResolveSpawnLocation(module.spawnLocation)
	end
	
	 
	local sg_throw_away = SGroup_CreateUnique("sg_throw_away")
	UnitEntry_DeploySquads(player, sg_throw_away, units, spawn)
	Prefab_DoAction(module, "AddSGroup", sg_throw_away, pause)
	SGroup_Destroy(sg_throw_away)
	return module.sgroup
end

--? @shortdesc assigns each tradecart to trade
function AssignTradecartsToTrade(sg_trade_carts, eg_building)
	if sg_trade_carts ~= nil and eg_building ~= nil and EGroup_Count(eg_building) == 1 and SGroup_Count(sg_trade_carts) >= 1 then
		local FuncTrade = function(gid, idx, sid)
			SGroup_Single(sg_single, sid)
			--local entity_settlement = EGroup_GetEntityAt(eg_settlement, 1)
			LocalCommand_SquadEntity(Util_GetPlayerOwner(sid), sg_single, SCMD_Trade, eg_building, false)	
		end
		SGroup_ForEach(sg_trade_carts, FuncTrade)
	else
		assert(sg_trade_carts, "sg_trade_carts is not defined")
		assert(eg_building, "eg_building is not defined")
		assert(EGroup_Count(eg_building) == 1, "eg_building must have 1 building")
		assert(SGroup_Count(sg_trade_carts) >= 1, "sg_trade_carts must have 1 or more trade carts")
	end
end

