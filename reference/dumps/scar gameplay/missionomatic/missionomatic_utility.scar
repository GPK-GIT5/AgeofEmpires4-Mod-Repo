		if queued == nil then queued = false end
		local player = Util_GetPlayerOwner(sgroup)
		LocalCommand_SquadSquadAttack(player, sgroup, targetSGroup, false, false, "", queued)
	end
end

--? @shortdesc Monitors the sgroup, and destroys each squad when it arrives at the destination 
--? @extdesc if distance is provided, that will be the arrival threshold. If not, but where is a 
--? marker with a proximity shape, that will be used for arrival. If not, 10m (2.5tiles) will be used
--? @args SGroup sgroup, AnythingThatResolvesToAPosition where, float distance
function DestroySquadsWhenArrived(sgroup, where, distance)
	local position
	local distance_squared = nil
	local marker = nil
	if scartype(distance) == ST_NUMBER then
		position  = Util_GetPosition(where)
		distance_squared = distance * distance
	elseif scartype(where) == ST_MARKER and Marker_HasProximityShape(where) then
		marker = where
	else
		position = Util_GetPosition(where)
		distance_squared = 100
	end
	
	local data = { 
		sgroup = SGroup_CreateUniqueWithPrefix("_DestroySGroupWhenArrived"),
		position = position,
		distance_squared = distance_squared,
		marker = marker
	}
	SGroup_AddGroup(data.sgroup, sgroup)
	
	g_SquadsToDestroyData = g_SquadsToDestroyData or {}
	table.insert(g_SquadsToDestroyData, data)
	
	if Rule_Exists(_MonitorSquadsAndDestroyWhenArrived) == false then
		Rule_AddInterval(_MonitorSquadsAndDestroyWhenArrived, 0.5)
	end
end

--? @shortdesc Returns a position at the edge of the building's footprint. The optional parameter 'offset' specifies
--? which side of the building should be used. Possible parameters are OFFSET_FRONT, OFFSET_BACK, OFFSET_LEFT,
--? OFFSET_RIGHT, OFFSET_FRONT_LEFT, OFFSET_FRONT_RIGHT, OFFSET_BACK_LEFT, OFFSET_BACK_RIGHT
--? @args Entity/EGroup building, OFFSET offset
--? @result Position
function Building_GetSpawnPosition(building, offset)
	if offset == nil then
		offset = OFFSET_FRONT
	end
	if scartype(building) == ST_EGROUP then
		building = EGroup_GetEntityAt(building, 1)
	end
	local building_position = Entity_GetPosition(building)
	local building_heading = Entity_GetHeading(building)
	local building_radius = 6
	if Entity_IsOfType(building, "town_center") then
		building_radius = 8
	end
	if offset % 2 == 1 then
		building_radius = building_radius * 1.4142 --sqrt(2) --buildings are square, not round. so corners are farther out 
	end
	building_radius = building_radius + 0.5 --adding a bit of buffer room because it looks better
	local position = World_GetOffsetPosition(building_position, building_heading, offset, building_radius)
	local y = World_GetHeightAt(position.x, position.z)
	return World_Pos(position.x, y, position.z)
end

function _MonitorSquadsAndDestroyWhenArrived(context, data)
	
	local _squadHasArrived = function(squad, destroy_data)
		if destroy_data.marker then
			if Marker_InProximity(destroy_data.marker, Squad_GetPosition(squad)) then
				return true
			end
		else
			if World_DistanceSquaredPointToPoint(Squad_GetPosition(squad), destroy_data.position) <= destroy_data.distance_squared then
				return true
			end
		end
		return false
	end
	
	for i = #g_SquadsToDestroyData, 1, -1 do
		local destroy_data = g_SquadsToDestroyData[i]
		for i = SGroup_CountSpawned(destroy_data.sgroup), 1, -1 do
			local squad = SGroup_GetSquadAt(destroy_data.sgroup, i)
			if _squadHasArrived(squad, destroy_data) then
				Squad_Destroy(squad)
			end
		end
		if SGroup_CountSpawned(destroy_data.sgroup) == 0 then
			SGroup_Destroy(destroy_data.sgroup)
			table.remove(g_SquadsToDestroyData, i)
		end
	end
	if #g_SquadsToDestroyData == 0 then
		Rule_RemoveMe()
	end
end