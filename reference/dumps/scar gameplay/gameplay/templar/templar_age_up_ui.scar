-----------------------------------------------------------------------
-- Scripting framework 
-----------------------------------------------------------------------

Core_RegisterModule("TemplarAgeUpUI")

-----------------------------------------------------------------------
-- Callbacks
-----------------------------------------------------------------------

-- Callback invoked by Core::OnInit()
function TemplarAgeUpUI_OnInit()
	
	-- Check if any player is using the Templar civ
		for i = 1, World_GetPlayerCount() do
			local raceName = Player_GetRaceName(World_GetPlayerAt(i))
			if raceName == _templar_civ then
				TemplarAgeUpUI_CreateDataContext()
				return
			end				
		end
	
	Core_UnregisterModule("TemplarAgeUpUI")	
end

-- Callback invoked by Core_OnGameRestore()
function TemplarAgeUpUI_OnGameRestore()
	TemplarAgeUpUI_CreateDataContext()
end

-----------------------------------------------------------------------
-- Private/Internal functions
-----------------------------------------------------------------------

function TemplarAgeUpUI_CreateDataContext()
	race = Player_GetRace(Game_GetLocalPlayer())
	
	for i = 1,9 do
		_templarAgeUp.data_context.commanderies[i].squads = {}
		
		uiinfo = BP_GetSquadUIInfo(BP_GetSquadBlueprint(_templarAgeUp.squads[i]), race)
		squad = {
			icon = uiinfo.iconName,
			extra = uiinfo.extraText,
			name = uiinfo.screenName,
			help = uiinfo.helpText,
			productionTime = BP_GetEntityBPBuildTime(BP_GetEntityBlueprint(_templarAgeUp.entities[i])),
			cost = CreateCostData(_templarAgeUp.entities[i]),
		}
		_templarAgeUp.data_context.commanderies[i].squads[1] = squad
	end
	
	uiinfo = BP_GetSquadUIInfo(BP_GetSquadBlueprint(_templarAgeUp.venice_second_squad), race)
	second_squad = {
		icon = uiinfo.iconName,
		extra = uiinfo.extraText,
		name = uiinfo.screenName,
		help = uiinfo.helpText,
		productionTime = BP_GetEntityBPBuildTime(BP_GetEntityBlueprint(_templarAgeUp.venice_second_squad)),
		cost = CreateCostData(_templarAgeUp.venice_second_squad),
	}
	_templarAgeUp.data_context.commanderies[9].squads[2] = second_squad
	
	uiinfo = BP_GetSquadUIInfo(BP_GetSquadBlueprint(_templarAgeUp.venice_third_squad), race)
	third_squad = {
		icon = uiinfo.iconName,
		extra = uiinfo.extraText,
		name = uiinfo.screenName,
		help = uiinfo.helpText,
		productionTime = BP_GetEntityBPBuildTime(BP_GetEntityBlueprint(_templarAgeUp.venice_third_squad)),
		cost = CreateCostData(_templarAgeUp.venice_third_squad),
	}
	_templarAgeUp.data_context.commanderies[9].squads[3] = third_squad
	
	UI_SetDataContext("TemplarAgeUpDataContext", _templarAgeUp.data_context)
end