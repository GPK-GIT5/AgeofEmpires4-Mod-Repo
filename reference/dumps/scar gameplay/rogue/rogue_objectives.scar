			local currentDefenders = SGroup_CountSpawned(objTable.sgroup)
			Objective_SetProgressBar(objTable, 1-(currentDefenders/objTable.total_defenders))
			
			if currentDefenders == 0 then
				return true
			end
			if SGroup_CountSpawned(objTable.inner_army_1.sgroup) == 0 and 
				SGroup_CountSpawned(objTable.inner_army_1.sgroup) == 0 and 
				objTable.outer_army.has_been_reassigned ~= true then
					local target = { position = objTable.nook.position, attackBuildings = BUILDINGS_ALL }
					Army_SetTarget(objTable.outer_army, target)
					objTable.outer_army.has_been_reassigned = true
			end			
		end,
		PreComplete = function(objTable)
			sideObjectivesCompleted = sideObjectivesCompleted + 1
			EGroup_SetPlayerOwner(objTable.eg_main, ROGUE_HUMAN_PLAYERS[1])
