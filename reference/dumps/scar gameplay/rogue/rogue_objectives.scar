			local archer_count = GetNumSquadsFromValue(ROGUE_ENEMY_ALLY_PLAYER, "scar_archer", archer_value)
			local knight_count = GetNumSquadsFromValue(ROGUE_ENEMY_ALLY_PLAYER, "scar_knight", knight_value)
			
