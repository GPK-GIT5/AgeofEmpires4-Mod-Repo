import("missionomatic/missionomatic.scar")
import("rogue/rogue_misc.scar")

function Rogue_Objectives_Precache()
	local rogue_player = PLAYERS[1].id
	local wonder_ebp = Cardinal_ConvertTypeToEntityBlueprint("wonder_imperial_age", rogue_player, false)
	Scar_PrecachePrematchResource(wonder_ebp)
	
	local rogue_player_ally = PLAYERS[3].id
	local military_college_ebp = Cardinal_ConvertTypeToEntityBlueprint("scar_military_college", rogue_player_ally, false)
	Scar_PrecachePrematchResource(military_college_ebp)
	
	local siege_workshop_ebp = Cardinal_ConvertTypeToEntityBlueprint("scar_siegeworkshop", rogue_player_ally, false)
	Scar_PrecachePrematchResource(siege_workshop_ebp)
	
	local alliedTC = Cardinal_ConvertTypeToEntityBlueprint("scar_town_center", rogue_player_ally)
	Scar_PrecachePrematchResource(alliedTC)
	
	local alliedOutpost = Cardinal_ConvertTypeToEntityBlueprint("scar_outpost", rogue_player_ally)
	Scar_PrecachePrematchResource(alliedOutpost)
	
	local alliedHouse = Cardinal_ConvertTypeToEntityBlueprint("scar_house", rogue_player_ally)
	Scar_PrecachePrematchResource(alliedHouse)
end


function OnEndlessModeStingerStopped(stingerId)
	if Game_RogueModeEndlessModeRequested() then
		-- enter endless mode
	else
		Mission_CompleteSkipOutro()
	end
end


function OnGoldMedalAquired()
	local kpiInformation = {kpi = states.game.second, side_obj = sideObjectivesCompleted}
	Game_StoreTableData("rogue", kpiInformation)
	for _, player in ipairs(ROGUE_HUMAN_PLAYERS) do
		Game_SendCustomChallengeEvent(player, CE_ROGUESIDEOBJECTIVECOMPLETE, sideObjectivesCompleted)
	end
	-- Endless mode stinger
	UI_StingerPlay(Loc_GetString(11161277), Loc_Empty(), "", "stinger_game_complete", "RogueModeEndlessModeStinger", OnEndlessModeStingerStopped)	
end

function Rogue_InitObjectives()
	if rogue_objectives_initialized == true then
		return
	end
	rogue_objectives_initialized = true
	
	----------------------------------------------------------------	
	------------------------ MAIN OBJECTIVES -----------------------
	----------------------------------------------------------------	

	eg_player_wonder = EGroup_CreateIfNotFound("eg_player_wonder")
	local wonder_ebp = Cardinal_ConvertTypeToEntityBlueprint("wonder_imperial_age", ROGUE_HUMAN_PLAYERS[1], false)
	CreateEntity(ROGUE_HUMAN_PLAYERS[1], wonder_ebp, mkr_wonder, eg_player_wonder, DIRECTION_FRONT, nil , false)
	Entity_RemoveAbility(EGroup_GetEntityAt(eg_player_wonder, 1), BP_GetAbilityBlueprint("core_building_scuttle"))
	local tent_ebp
	if mission_name == "Watch Your Steppe" then
		tent_ebp = EBP.MONGOL.BUILDING_HOUSE_MON
	else
		tent_ebp = BP_GetEntityBlueprint("building_military_tent_a_rogue")
	end
	
	if ROGUE_STRESS_TEST then
		EGroup_SetInvulnerable(eg_player_wonder, true, -1)
		SGroup_Clear(sg_temp)
		for _, offset in ipairs({ {20,0}, {-20,0}, {0,20}, {0,-20} }) do
			local position = PositionWithOffset(Marker_GetPosition(mkr_wonder), offset[1], offset[2])
			
			local unit_table = {{ type = "scar_knight", numSquads = 50 }}
			CreateUnits(ROGUE_HUMAN_PLAYERS[1], unit_table, position, sg_temp)
		end
		SGroup_SetInvulnerable(sg_temp, true, -1)
	end
	
	ALLY_ARMY_SIZE = 25
	
	OBJ_PROTECT_WONDER = {
		Title = "$11268890", --Defend Your Wonder
		Type = ObjectiveType_Primary,
		showTitle = true,
		IsComplete = function(objTable)
			if Game_RogueModeConquerorEnabled() then
				if states.game.second >= SURVIVAL_TIME_CONQUEROR and EGroup_CountSpawned(eg_player_wonder) == 0 then
					Objective_Complete(OBJ_PROTECT_WONDER, false, false)
				end
			else
				if states.game.second >= 1500 and EGroup_CountSpawned(eg_player_wonder) == 0 then
					Objective_Complete(OBJ_PROTECT_WONDER, false, false)
				end
			end
		end,
		PreComplete = function(objTable)
			local kpiInformation = {kpi = states.game.second, side_obj = sideObjectivesCompleted}
			Game_StoreTableData("rogue", kpiInformation)
			player_has_been_killed = true
			for _, player in ipairs(ROGUE_HUMAN_PLAYERS) do
				Game_SendCustomChallengeEvent(player, CE_ROGUESIDEOBJECTIVECOMPLETE, sideObjectivesCompleted)
			end
			Mission_Complete()
		end,
		IsFailed = function(objTable)
			if Game_RogueModeConquerorEnabled() then
				if states.game.second < SURVIVAL_TIME_CONQUEROR then
					return EGroup_CountSpawned(eg_player_wonder) <= 0
				end
			else
				if states.game.second < 1500 then
					return EGroup_CountSpawned(eg_player_wonder) <= 0
				end
			end
		end,
		OnFail = function(objTable)
			local kpiInformation = {kpi = states.game.second, side_obj = sideObjectivesCompleted}
			Game_StoreTableData("rogue", kpiInformation)
			for _, player in ipairs(ROGUE_HUMAN_PLAYERS) do
				Game_SendCustomChallengeEvent(player, CE_ROGUESIDEOBJECTIVECOMPLETE, sideObjectivesCompleted)
			end
			Mission_Fail()
		end,
	}
	SOBJ_CONQUEROR = {
		Parent = OBJ_PROTECT_WONDER,
		StartAlongsideParent = true,
		KPI = SURVIVAL_TIME_CONQUEROR,
		Title = "$11270504", --Conqueror (45m)
		showTitle = false,
		event_queue_string = "$11270505", --Conqueror Medal Awarded
		event_queue_sound ="sfx_ui_rogue_objective_completed_gold_play", --conqueror sfx?
		Type = ObjectiveType_Primary,
		next_objective = nil,
		PreComplete = OnGoldMedalAquired,
		PopupDataTemplateOverride = "RogueConquerorMedalTemplate"
	}	
	SOBJ_GOLD = {
		Parent = OBJ_PROTECT_WONDER,
		StartAlongsideParent = true,
		KPI = SURVIVAL_TIME_GOLD,
		Title = "$11268891", --Gold (45m)
		showTitle = false,
		event_queue_string = "$11268892", --Gold Medal Awarded
		event_queue_sound ="sfx_ui_rogue_objective_completed_gold_play",
		Type = ObjectiveType_Primary,
		next_objective = nil,
		PreComplete = OnGoldMedalAquired,
		PopupDataTemplateOverride = "RogueGoldMedalTemplate"
	}	
	SOBJ_SILVER = {
		Parent = OBJ_PROTECT_WONDER,
		StartAlongsideParent = true,
		KPI = SURVIVAL_TIME_SILVER,
		Title = "$11268894", --Silver (35m)
		event_queue_string = "$11268895", --Silver Medal Awarded
		event_queue_sound ="sfx_ui_rogue_objective_completed_silver_play",
		Type = ObjectiveType_Primary,
		next_objective = SOBJ_GOLD,
		PopupDataTemplateOverride = "RogueSivlerMedalTemplate"
	}	
	SOBJ_BRONZE = {
		Parent = OBJ_PROTECT_WONDER,
		StartAlongsideParent = true,
		KPI = SURVIVAL_TIME_BRONZE,
		Title = "$11268896", --Bronze (25m)
		event_queue_string = "$11268897", --Bronze Medal Awarded
		event_queue_sound ="sfx_ui_rogue_objective_completed_bronze_play",
		Type = ObjectiveType_Primary,
		next_objective = SOBJ_SILVER,
		PopupDataTemplateOverride = "RogueBronzeMedalTemplate"
	}
	
	for _, player in ipairs(ROGUE_HUMAN_PLAYERS) do
		Objective_Register(OBJ_PROTECT_WONDER, player)	
		
		if Game_RogueModeConquerorEnabled() then
			Objective_Register(SOBJ_CONQUEROR, player)
		else
			Objective_Register(SOBJ_BRONZE, player)
			Objective_Register(SOBJ_SILVER, player)
			Objective_Register(SOBJ_GOLD, player)
		end
	end
	
	if Game_RogueModeConquerorEnabled() then
		current_medal_objective = SOBJ_CONQUEROR
	else
		current_medal_objective = SOBJ_BRONZE
	end
	
	----------------------------------------------------------------	
	------------------------ SIDE OBJECTIVES -----------------------
	----------------------------------------------------------------	
	
	OBJ_DESTROY_MERCENARY = {
		Title = "$11268898", --Optional: Capture the Mercenary Base
		Type = ObjectiveType_Capture,
		TelemetryTitle = "destroy_mercenary",
		short_name = "destroy_mercenary",
		long_name = "Capture the Mercenary Base",
		showTitle = true,
		IsSecret = false,
		claimNook = true,
		PreStart = function(objTable)
			local nook = objTable.nook
			Nook_CleanArea(nook)
			CreateEntity(nil, BP_GetEntityBlueprint("rogue_sideobj_merc_01"), nook.position, nil, DIRECTION_FRONT, nil, false)
			
			objTable.eg_main = EGroup_CreateUniqueWithPrefix("eg_main_mercenary")
			Nook_CreateEntitiesAtMarkers(nook, ROGUE_NEUTRAL_PLAYER, BP_GetEntityBlueprint("building_rogue_mercenary_house"), "mkr_sideobj_main", objTable.eg_main, nil, false, true)
			Objective_AddUIElements(objTable, nook.position, true, "$11268899", false, 0) --Capture Mercenary HQ
										
			Nook_CreateEntitiesAtMarkers(nook, ROGUE_ENEMY_ALLY_PLAYER, "scar_barracks", "mkr_sideobj_barracks")
			Nook_CreateEntitiesAtMarkers(nook, ROGUE_ENEMY_ALLY_PLAYER, "scar_house", "mkr_sideobj_house")
			Nook_CreateEntitiesAtMarkers(nook, ROGUE_ENEMY_ALLY_PLAYER, tent_ebp, "mkr_sideobj_tent")

			local maa_value = GetIntegerInExponentialRange(600, 1250) --Two armies spawn, so use half the scaling value.
			local archer_value = GetIntegerInExponentialRange(400, 1000) --Two armies spawn, so use half the scaling value.
			local maa_count = GetNumSquadsFromValue(ROGUE_ENEMY_ALLY_PLAYER, "scar_manatarms", maa_value)
			local archer_count = GetNumSquadsFromValue(ROGUE_ENEMY_ALLY_PLAYER, "scar_archer", archer_value)
			local unit_table = {
				{ type = "scar_manatarms", numSquads = maa_count },
				{ type = "scar_archer", numSquads = archer_count },
			}
			objTable.army_01 = Nook_SpawnArmy(nook, ROGUE_ENEMY_ALLY_PLAYER, unit_table, "mkr_sideobj_army_01")
			objTable.army_02 = Nook_SpawnArmy(nook, ROGUE_ENEMY_ALLY_PLAYER, unit_table, "mkr_sideobj_army_02")
			Players_RevealArea(ROGUE_HUMAN_PLAYERS, nook.position, 35)
		end,
		IsComplete = function(objTable)
			return SGroup_CountSpawned(objTable.army_01.sgroup) == 0 and SGroup_CountSpawned(objTable.army_02.sgroup) == 0
		end,
		PreComplete = function(objTable)
			sideObjectivesCompleted = sideObjectivesCompleted + 1
			EGroup_SetPlayerOwner(objTable.eg_main, ROGUE_HUMAN_PLAYERS[1])
		end, 
	}	
	OBJ_DESTROY_BUILDINGS = {
		Title = "$11268901", --Optional: Raid Enemy Buildings
		Type = ObjectiveType_Battle,
		TelemetryTitle = "destroy_buildings",
		short_name = "destroy_buildings",
		long_name = "Destroy the Enemy Buildings",
		showTitle = true,
		IsSecret = false,
		claimNook = false,
		OnStart = function(objTable)
			DestroyBuildingsObjective_Start(objTable)
			
			Player_GetAll(ROGUE_ENEMY_ALLY_PLAYER)
			EGroup_Filter(eg_allentities, "resource_pickup", FILTER_REMOVE)
			EGroup_Filter(eg_allentities, "tent", FILTER_REMOVE)
			EGroup_Filter(eg_allentities, "keep", FILTER_REMOVE)
			EGroup_Filter(eg_allentities, "point_of_interest", FILTER_REMOVE)
			EGroup_RemoveGroup(eg_allentities, eg_destroy_obj_exclude)
			Modify_OnFireHealthPercentage(eg_allentities, MUT_Multiplication, 3.5)
			local RaidTargetHealthReduction = GetFloatInExponentialRange(0.15, 0.75)
			Modify_EntityMaxHealth(eg_allentities, RaidTargetHealthReduction, MUT_Multiplication)
			
		end,
		IsComplete = function(objTable)
			if objTable.enemy_building_egroups ~= nil and #objTable.enemy_building_egroups > 0 then
				local allEmpty = true
				for i = 1, #objTable.enemy_building_egroups do
					if EGroup_CountSpawned(objTable.enemy_building_egroups[i]) > 0 then
						allEmpty = false
					end
				end
				return allEmpty
			end
		end,
		PreComplete = function(objTable)
			--Removed the Perk Point bonus for this mission specific objective
			--sideObjectivesCompleted = sideObjectivesCompleted + 1
		end, 
	}
	OBJ_SAVE_ALLY = {
		Title = "$11268903", --Optional: Save the Ally Landmark
		Type = ObjectiveType_Capture,
		TelemetryTitle = "save_ally",
		short_name = "save_ally",
		long_name = "Save the Ally Landmark",
		showTitle = true,
		IsSecret = false,
		claimNook = true,
		PreStart = function(objTable)
			local nook = objTable.nook
			Nook_CleanArea(nook)
			CreateEntity(nil, BP_GetEntityBlueprint("rogue_sideobj_rescue_01"), nook.position, nil, DIRECTION_FRONT, nil, false)
			
			objTable.eg_main = EGroup_CreateIfNotFound("eg_main_rescue")
			eg_main_rescue = EGroup_CreateIfNotFound("eg_main_rescue")
			local alliedRogueObjectiveSBP = Cardinal_ConvertTypeToEntityBlueprint("rogue_objective", ROGUE_ALLY_PLAYER)
			Nook_CreateEntitiesAtMarkers(nook, ROGUE_NEUTRAL_PLAYER, alliedRogueObjectiveSBP, "mkr_sideobj_main", objTable.eg_main)
			Modify_EntityMaxHealth(objTable.eg_main, 20, MUT_Multiplication)
			EGroup_SetTargetingType(objTable.eg_main, Targeting_Manual)				
			Objective_AddUIElements(objTable, nook.position, true, "$11268904", false, 0) --Rescue the Allied Landmark
			
			eg_dead_allied_buildings = EGroup_CreateIfNotFound("eg_dead_allied_buildings")
			
			local alliedTC = Cardinal_ConvertTypeToEntityBlueprint("scar_town_center", ROGUE_ALLY_PLAYER)
			local alliedOutpost = Cardinal_ConvertTypeToEntityBlueprint("scar_outpost", ROGUE_ALLY_PLAYER)
			local alliedHouse = Cardinal_ConvertTypeToEntityBlueprint("scar_house", ROGUE_ALLY_PLAYER)
			Nook_CreateEntitiesAtMarkers(nook, ROGUE_NEUTRAL_PLAYER, alliedTC, "mkr_sideobj_town_center", eg_dead_allied_buildings, nil, false, false)
			Nook_CreateEntitiesAtMarkers(nook, ROGUE_NEUTRAL_PLAYER, alliedOutpost, "mkr_sideobj_outpost", eg_dead_allied_buildings, nil, false, false)
			Nook_CreateEntitiesAtMarkers(nook, ROGUE_NEUTRAL_PLAYER, alliedHouse, "mkr_sideobj_house", eg_dead_allied_buildings, nil, false, false)
			
			local _SetAlliedBuildingsDead = function(gid, index, eid)
				if Entity_IsOfType(eid, "scar_town_center") or Entity_IsOfType(eid, "scar_outpost") then
					Entity_SetHealth(eid, 0.0001)
				else
					Entity_SetHealth(eid, World_GetRand(1, 15)/100)
				end
				Entity_SetTargetingType(eid, Targeting_None)
			end			
			
			EGroup_ForEach(eg_dead_allied_buildings, _SetAlliedBuildingsDead)
			
			local maa_value = GetIntegerInExponentialRange(1000, 1500)
			local maa_numSquads = GetNumSquadsFromValue(ROGUE_ENEMY_ALLY_PLAYER, "scar_manatarms", maa_value)
			local unit_table = {{ type = "scar_manatarms", numSquads = maa_numSquads }}
			objTable.torchSgroup = SGroup_CreateUnique("sg_torchers")
			objTable.inner_army = Nook_SpawnArmy(nook, ROGUE_ENEMY_ALLY_PLAYER, unit_table, "mkr_sideobj_army_01")
			SGroup_AddGroup(objTable.torchSgroup, objTable.inner_army.sgroup)
			
			_monitorTorchers = function(context, data)
				local markerCheckRadius = 33.4
				local objTable = data.objTable
				local objectiveDestroyed = EGroup_CountSpawned(objTable.eg_main) == 0
				
				local _attackHumanPlayer = function()
					if SGroup_ContainsSGroup(objTable.inner_army.sgroup, objTable.torchSgroup, ALL) == false then
						Army_AddSGroup(objTable.inner_army, objTable.torchSgroup)
					end
				end
				
				local _attackObjective = function()
					if SGroup_ContainsSGroup(objTable.inner_army.sgroup, objTable.torchSgroup, ANY) == true then
						Army_RemoveSGroup(objTable.inner_army, objTable.torchSgroup)
					end
					
					if SGroup_CountSpawned(objTable.torchSgroup) > 0 then
						SGroup_AttackEntity(objTable.torchSgroup, EGroup_GetEntityAt(objTable.eg_main, 1))
					end
				end
					 
				if objectiveDestroyed then
					_attackHumanPlayer()
				end
				
				-- Objective is no longer in progress
				if Objective_IsComplete(objTable) or Objective_IsFailed(objTable) then
					Rule_RemoveMe()
					return
				end
				
				if objectiveDestroyed then
					return
				end
				
				-- Check if any player squads have come close
				local torchGroupMarker = objTable.inner_army.targets[1].position
				SGroup_Clear(sg_temp)
				Players_GetAllSquadsNearMarker(ROGUE_HUMAN_PLAYERS, sg_temp, torchGroupMarker, markerCheckRadius)
				
				if SGroup_CountSpawned(sg_temp) > 0 then
					_attackHumanPlayer()
					return
				end
				
				-- Check if any player buildings have been created nearby (including training dummies)
				EGroup_Clear(eg_temp)
				Players_GetAllEntitiesNearMarker(ROGUE_HUMAN_PLAYERS, eg_temp, torchGroupMarker, markerCheckRadius)
				local entityCount = EGroup_CountSpawned(eg_temp)
				
				for i = 1, entityCount do
					local entity = EGroup_GetEntityAt(eg_temp, i)
					local distance = Util_GetDistance(entity, torchGroupMarker)
					
					--[[
						Players_GetAllEntitiesNearMarker uses proper collision checking to determine which entities are
						within a cylinder of the specified radius. The army uses distance checking to determine if it
						should engage a target. Because of this, it's possible for a unit's collider to be within the
						cylinder, but its centre point to be outside. This is especially true for buildings.
						
						This additional check ensures that the entity is actually close enough that the army will engage it.
					]]--
					if distance <= markerCheckRadius then
						_attackHumanPlayer()
						return
					end
				end
				
				-- No player units, target the objective
				_attackObjective()
			end
						
			local knight_value = GetIntegerInExponentialRange(320, 1500)
			local knight_numSquads = GetNumSquadsFromValue(ROGUE_ENEMY_ALLY_PLAYER, "scar_knight", knight_value)
			unit_table = {{ type = "scar_knight", numSquads = knight_numSquads }}
			objTable.outer_army = Nook_SpawnArmy(nook, ROGUE_ENEMY_ALLY_PLAYER, unit_table, "mkr_sideobj_army_02", TARGET_ORDER_LOOP, nil, nil, true)
			
			objTable.sgroup = SGroup_CreateUniqueWithPrefix("sg_rescue_enemies")
			SGroup_AddGroup(objTable.sgroup, objTable.inner_army.sgroup)
			SGroup_AddGroup(objTable.sgroup, objTable.outer_army.sgroup)
			
			objTable.max_health = EGroup_GetTotalHealth(objTable.eg_main)
			Objective_SetProgressBar(objTable, 1)
			
			Rule_AddInterval(_monitorTorchers, 1, {objTable = objTable})
			Players_RevealArea(ROGUE_HUMAN_PLAYERS, nook.position, 35)
		end,
		IsComplete = function(objTable)
			if SGroup_CountSpawned(objTable.sgroup) == 0 then
				return true
			end
			if SGroup_CountSpawned(objTable.inner_army.sgroup) == 0 and 
				SGroup_CountSpawned(objTable.torchSgroup) == 0 and
				objTable.outer_army.has_been_reassigned ~= true then
					Army_AddSGroup(objTable.inner_army, objTable.outer_army.sgroup)
					Army_RemoveSGroup(objTable.outer_army, objTable.outer_army.sgroup)
					SGroup_AddGroup(objTable.torchSgroup, objTable.inner_army.sgroup)
					objTable.outer_army.has_been_reassigned = true
			end
		end,
		PreComplete = function(objTable)
			sideObjectivesCompleted = sideObjectivesCompleted + 1
			SaveAlly_PreComplete(objTable)
			EGroup_SetTargetingType(objTable.eg_main, Targeting_None)
			EGroup_SetAvgHealth(objTable.eg_main, 1)
			for _, player in ipairs(ROGUE_HUMAN_PLAYERS) do
				Game_SendCustomChallengeEvent(player, CE_ROGUEPEOPLESCHAMPIONCOMPLETED, 1)
			end
		end, 
		IsFailed = function(objTable)
			Objective_SetProgressBar(objTable, EGroup_GetTotalHealth(objTable.eg_main)/objTable.max_health)
			if EGroup_GetAvgHealth(objTable.eg_main) <= 0 then
				return true
			end
		end,
	}
	OBJ_HARVEST_METEORITE = {
		Title = "$11268907", --Optional: Harvest the Meteorite
		Type = ObjectiveType_Build,
		TelemetryTitle = "harvest_meteorite",
		short_name = "harvest_meteorite",
		long_name = "Harvest the Meteorite",
		showTitle = true,
		IsSecret = false,
		claimNook = true,
		PreStart = function(objTable)
			local nook = objTable.nook
			Nook_CleanArea(nook)
			CreateEntity(nil, BP_GetEntityBlueprint("rogue_sideobj_meteor_01"), nook.position, nil, DIRECTION_FRONT, nil, false)
			
			objTable.eg_main = EGroup_CreateIfNotFound("eg_main_meteorite")
			Nook_CreateEntitiesAtMarkers(nook, ROGUE_ENEMY_WAVE_PLAYER, "resource_meteorite_rogue", "mkr_sideobj_main", objTable.eg_main, false, false, false)
			Objective_AddUIElements(objTable, nook.position, true, "$11268908", false, 0) --Harvest the Meteorite
			if Game_RogueModeConquerorEnabled() then
				local meteorEID = EGroup_GetEntityAt(objTable.eg_main, 1)
				Entity_SetRemainingResourceDepositAmount(meteorEID, Entity_GetRemainingResourceDepositAmount(meteorEID) * 0.5)
			end
			
			local value = GetIntegerInExponentialRange(1250, 3000)
			local numSquads = GetNumSquadsFromValue(ROGUE_ENEMY_ALLY_PLAYER, "scar_manatarms", value)
			local unit_table = {{type = "scar_manatarms", numSquads = numSquads}}
			Nook_SpawnArmy(nook, ROGUE_ENEMY_ALLY_PLAYER, unit_table, "mkr_sideobj_army_01", TARGET_ORDER_RANDOM, nil, 8)
			
			value = GetIntegerInExponentialRange(500, 1000)
			numSquads = GetNumSquadsFromValue(ROGUE_ENEMY_ALLY_PLAYER, "scar_knight", value)
			unit_table = {{ type = "scar_knight", numSquads = numSquads }}
			Nook_SpawnArmy(nook, ROGUE_ENEMY_ALLY_PLAYER, unit_table, "mkr_sideobj_army_02", TARGET_ORDER_LOOP, nil, nil)
			Players_RevealArea(ROGUE_HUMAN_PLAYERS, nook.position, 35)
		end,
		IsComplete = function(objTable)
			if EGroup_CountSpawned(objTable.eg_main) > 0 then
				local meteorite = EGroup_GetEntityAt(objTable.eg_main, 1)
				return Entity_GetRemainingResourceDepositAmount(meteorite) == 0
			else
				return true
			end
		end,
		PreComplete = function(objTable)
			sideObjectivesCompleted = sideObjectivesCompleted + 1
			Players_UnRevealArea(ROGUE_HUMAN_PLAYERS, objTable.nook.position)
		end, 
	}
	OBJ_BUILD_BONFIRE = {
		Title = "$11268910", --Optional: Rebuild the Bonfire
		Type = ObjectiveType_Build,
		TelemetryTitle = "build_bonfire",
		short_name = "build_bonfire",
		long_name = "Build the Bonfire",
		showTitle = true,
		IsSecret = false,
		claimNook = true,
		PreStart = function(objTable)
			local nook = objTable.nook
			Nook_CleanArea(nook)
			CreateEntity(nil, BP_GetEntityBlueprint("rogue_sideobj_bonfire_01"), nook.position, nil, DIRECTION_FRONT, nil, false)
			
			objTable.eg_main = EGroup_CreateIfNotFound("eg_main_bonfire")	
			Nook_CreateEntitiesAtMarkers(nook, ROGUE_HUMAN_PLAYERS[1], BP_GetEntityBlueprint("building_rogue_bonfire"), "mkr_sideobj_main", objTable.eg_main, 0, false, true)
			Entity_SetHealth(EGroup_GetEntityAt(objTable.eg_main, 1),0.001)
			Objective_AddUIElements(objTable, nook.position, true, "$11268911", false, 0) --Rebuild the Bonfire
			
			if mission_name == "Watch Your Steppe" then
				Nook_CreateEntitiesAtMarkers(nook, ROGUE_ENEMY_ALLY_PLAYER, tent_ebp, "mkr_sideobj_tent", nil, 0, false, false)
			else
				Nook_CreateEntitiesAtMarkers(nook, ROGUE_HUMAN_PLAYERS[1], tent_ebp, "mkr_sideobj_tent", nil, 0, false, true)
			end
					
			local value = GetIntegerInExponentialRange(250, 1000)
			local numSquads = GetNumSquadsFromValue(ROGUE_ENEMY_ALLY_PLAYER, "scar_manatarms", value)
			local unit_table = {{type = "scar_manatarms", numSquads = numSquads}}
			Nook_SpawnArmy(nook, ROGUE_ENEMY_ALLY_PLAYER, unit_table, "mkr_sideobj_army_01", TARGET_ORDER_RANDOM, nil, 8)
			
			value = GetIntegerInExponentialRange(750, 1500)
			numSquads = GetNumSquadsFromValue(ROGUE_ENEMY_ALLY_PLAYER, "scar_horseman", value)
			unit_table = {{ type = "scar_horseman", numSquads = numSquads }}
			Nook_SpawnArmy(nook, ROGUE_ENEMY_ALLY_PLAYER, unit_table, "mkr_sideobj_army_02", TARGET_ORDER_LOOP, nil, nil)
			
			Objective_SetProgressBar(objTable, 0)
			Players_RevealArea(ROGUE_HUMAN_PLAYERS, nook.position, 35)
			
			Rule_Add(MonitorBonfire, { objTable = objTable })
		end,
		PreComplete = function(objTable)	
			local nook = objTable.nook
			for _, player in ipairs(ROGUE_HUMAN_PLAYERS) do
				Game_SendCustomChallengeEvent(player, CE_ROGUEPEOPLESCHAMPIONCOMPLETED, 1)
			end
			EventCues_CallToAction("$11268912", CTA_CELEBRATE, nil, nil, objTable.eg_main, 30, "icons/cta/illustrations/player_reinforcement_arrived") --BONFIRE LIT
			sideObjectivesCompleted = sideObjectivesCompleted + 1
			EGroup_SetAnimatorState(objTable.eg_main, "bonfire_lit", "on")
			LocalCommand_EntityAbility(ROGUE_HUMAN_PLAYERS[1], objTable.eg_main, BP_GetAbilityBlueprint("bonfire_festival_food_rogue"), true, false)
		end, 
	}
