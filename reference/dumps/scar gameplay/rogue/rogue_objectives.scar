function Rogue_ApplyForcedObjectives()
	forced_objective_names = {}
	for _, command_line_option in ipairs({ "objective_1", "objective_2" }) do
		if Misc_IsCommandLineOptionSet(command_line_option) then
			local objective_name = Misc_GetCommandLineString(command_line_option)
			table.insert(forced_objective_names, objective_name)
		end
	end
end

function Rogue_ChooseObjectives()
	chosen_objectives = {}
	started_objectives = {}
	side_objective_markers = AllMarkers_FromName("mkr_side_objective", "")
	for i = 1, SIDE_OBJECTIVE_COUNT do
		
		if #t_RogueSideObjectives > 0 then
			local objective
			if #forced_objective_names > 0 then
				local forced_objective_name = forced_objective_names[1]
				objective = Rogue_GetObjectiveWithName(forced_objective_name)
				objective.forced = true
				table.remove(forced_objective_names, 1)
			else
				local index = World_GetRand(1, #t_RogueSideObjectives)
				objective = t_RogueSideObjectives[index]
			end
			Table_RemoveFirstItem(t_RogueSideObjectives, objective)
			if objective.forced then
				print("Objective - "..objective.long_name.." (forced)")
			else
				print("Objective - "..objective.long_name)
			end
			
			if side_objective_markers ~= nil and #side_objective_markers > 0 then
				if objective.claimNook == true then
					local index = World_GetRand(1, #side_objective_markers)
					local objective_marker = side_objective_markers[index]
					table.remove(side_objective_markers, index)
					
					objective.nook = Nook_Init(objective_marker)
				end
				for _, player in ipairs(ROGUE_HUMAN_PLAYERS) do
					Objective_Register(objective, player)
				end
				table.insert(chosen_objectives, objective)
			end
		end
	end
	if Game_RogueModeConquerorEnabled() then
		if side_objective_markers ~= nil and #side_objective_markers > 0 then
			if OBJ_ENEMY_TREBUCHETS.claimNook == true then
				local index = World_GetRand(1, #side_objective_markers)
				local objective_marker = side_objective_markers[index]
				table.remove(side_objective_markers, index)
				
				OBJ_ENEMY_TREBUCHETS.nook = Nook_Init(objective_marker)
			end
				for _, player in ipairs(ROGUE_HUMAN_PLAYERS) do
					Objective_Register(OBJ_ENEMY_TREBUCHETS, player)
				end
			table.insert(chosen_objectives, OBJ_ENEMY_TREBUCHETS)
		end
	end
end

function Rogue_StartObjectives()
	Objective_Start(OBJ_DUMMY)
	Objective_Start(OBJ_PROTECT_WONDER, true)
	Objective_StartTimer(OBJ_PROTECT_WONDER, COUNT_UP, 0)
	print("Main Objective Started")
	
	Rule_AddOneShot(Rogue_StartSideObjective, 6)
	Rule_Add(Rogue_MonitorWaveWarningUI)
end

function Rogue_MonitorWaveWarningUI()
	if wave_warning_timer_element then
		Objective_RemoveUIElements(OBJ_DUMMY, wave_warning_timer_element)
		wave_warning_timer_element = nil
	end
	if wave_warning_minimap_element == nil then
		wave_warning_minimap_element = Objective_AddUIElements(OBJ_DUMMY, wave_warning_position, true, nil, false, 0)
	end
	local first_round_spawn_time = rounds[1].spawn_at
	local remaining_time = first_round_spawn_time - World_GetGameTime()
	if remaining_time <= 0  then
		Objective_RemoveUIElements(OBJ_DUMMY, wave_warning_minimap_element)
		Rule_RemoveMe()
		return
	end
	--local time_string = FormatSeconds(math.ceil(remaining_time))
	wave_warning_timer_element = Objective_AddUIElements(OBJ_DUMMY, wave_warning_position, false, Loc_FormatText("$11268922", Loc_FormatTime_M_S(math.ceil(remaining_time), true)), true, 0) --"Waves Starting in "
end

function Rogue_StartSideObjective()
	if #chosen_objectives > 0 then
		local objective = chosen_objectives[1]
		table.insert(started_objectives, chosen_objectives[1])
		table.remove(chosen_objectives, 1)
		
		Objective_Start(objective, false)
		print("Side Objective Started - "..objective.long_name)
		Sound_Play2D("sfx_campaign_scripted_ui_objective_counter_update")
		
		if #chosen_objectives > 0 then
			Rule_AddOneShot(Rogue_StartSideObjective, 0.75)
		end
	end
end
	
function Rogue_GetObjectiveWithName(name)
	for _, objective in ipairs(t_RogueSideObjectives) do
		if objective.short_name == name then
			return objective
		end
	end
	fatal("could not find objective with name "..name)
end

-------------------------------------------------------------------
----------------------------- Nook --------------------------------
-------------------------------------------------------------------

function Nook_Init(marker)
	local nook = {}
	nook.marker = marker
	nook.position = Marker_GetPosition(marker)
	nook.radius = Marker_GetProximityRadius(marker)
	return nook
end

function Nook_CreateEntitiesAtMarkers(nook, player, ebp, marker_name, egroup, delay, is_ghost, set_invulnerable)
	local use_custom_facing = false
	if scartype(ebp) == ST_STRING then
		if EBP_Exists(ebp) then
			if ebp == "building_military_tent_a_rogue" then
				use_custom_facing = true
			end
			ebp = BP_GetEntityBlueprint(ebp)
		else
			ebp = Cardinal_ConvertTypeToEntityBlueprint(ebp, player)
		end
	end
	assert(scartype(ebp) == ST_PBG, "Could not figure out unit type")
	local markers = Nook_GetMarkersWithName(nook, marker_name)
	assert(#markers > 0, "Nook could not find any markers with name: "..marker_name)
	for _, marker in ipairs(markers) do
		local data = { 
			player = player, 
			ebp = ebp, 
			egroup = egroup, 
			position = Marker_GetPosition(marker), 
			direction = Marker_GetDirection(marker),
			set_invulnerable = set_invulnerable,
			use_custom_facing = use_custom_facing,
		}
		if is_ghost then
			if delay ~= nil and delay > 0 then
				Rule_AddOneShot(Nook_CreateGhost, delay, data)
			else
				Nook_CreateGhost(nil, data)
			end
		else
			if scartype(delay) == ST_NUMBER and delay > 0 then
				Rule_AddOneShot(Nook_CreateEntity, delay, data)
			else
				Nook_CreateEntity(nil, data)
			end
		end
	end
end

function Nook_CleanArea(nook)
	for _, player in ipairs({ ROGUE_ENEMY_WAVE_PLAYER, ROGUE_ENEMY_ALLY_PLAYER }) do
		EGroup_Clear(eg_temp)
		Player_GetAllEntitiesNearMarker(player, eg_temp, nook.marker)
		EGroup_DestroyAllEntities(eg_temp)
		
		SGroup_Clear(sg_temp)
		Player_GetAllSquadsNearMarker(player, sg_temp, nook.marker)
		SGroup_DestroyAllSquads(sg_temp)
	end
end

function Nook_CreateGhost(context, data)
	EGroup_Clear(eg_temp)
	local facing 
	if data.use_custom_facing then
		facing = PositionWithOffset(data.position, -data.direction.x, -data.direction.z)
	else
		facing = Util_GetOffsetPosition(data.position, OFFSET_FRONT, 10)
	end
	LocalCommand_PlayerPlaceAndConstructEntitiesPlanned(data.player, data.ebp, data.position, facing, true, false)
	Player_GetAllEntitiesNearMarker(data.player, eg_temp, data.position, 10)
	EGroup_FilterUnderConstruction(eg_temp, FILTER_KEEP)
	if data.egroup ~= nil then
		EGroup_AddEGroup(data.egroup, eg_temp)
	end
	if data.set_invulnerable then
		EGroup_SetInvulnerable(eg_temp, true, -1)
		EGroup_SetTargetingType(eg_temp, Targeting_None)
	end
end

function Nook_CreateEntity(context, data)
	local facing
	if data.use_custom_facing then
		facing = PositionWithOffset(data.position, -data.direction.x, -data.direction.z)
	else
		facing = Util_GetOffsetPosition(data.position, OFFSET_FRONT, 10)
	end
	EGroup_Clear(eg_temp)
	CreateEntity(data.player, data.ebp, data.position, eg_temp, nil, facing, false)
	if data.set_invulnerable then
		EGroup_SetInvulnerable(eg_temp, true, -1)
		EGroup_SetTargetingType(eg_temp, Targeting_None)
	end
	if data.egroup then
		EGroup_AddEGroup(data.egroup, eg_temp)
	end
end

function Nook_GetMarkersWithName(nook, marker_name)
	local results = {}
	if Marker_Exists(marker_name, "") then
		local markers = AllMarkers_FromName(marker_name, "")
		for _, marker in ipairs(markers) do
			if World_DistanceSquaredPointToPoint(Marker_GetPosition(marker), nook.position) <= (nook.radius ^ 2) then
				table.insert(results, marker)
			end
		end
	end
	return results
end

function Nook_SpawnArmy(nook, player, unit_table, marker_name, target_order, sgroup, idleTime, ignore_buildings, onComplete)
	local army_target_index = 1
	local targets = {}
	while true do
		local index_string = tostring(army_target_index)
		if army_target_index < 10 then
			index_string = "0"..index_string
		end
		army_target_index = army_target_index + 1
		local full_marker_name = marker_name.."_"..index_string
		local markers = Nook_GetMarkersWithName(nook, full_marker_name)
		assert(#markers < 2, "Nook found multiple markers with name: "..full_marker_name)
		if #markers > 0 then
			local marker = markers[1]
			local target = { position = Marker_GetPosition(marker), direction = Marker_GetDirection(marker) }
			table.insert(targets, target)
		else
			break
		end
	end
	local params = {
		player = player,
		--spawn = targets[1],
		targets = targets,
		targetOrder = target_order,
		onDeathDissolve = true,
		onCompleteFunction = onComplete,
		units = unit_table,
		idleTime = idleTime,
	}
	if ignore_buildings then
		params.attackBuildings = BUILDINGS_NONE
	end
	if #targets == 1 then
		params.useCustomDirection = true
	end
	
	local army = Army_Init(params)
	return army
end

-------------------------------------------------------------------
--------------------------- College -------------------------------
-------------------------------------------------------------------

function College_Init(objTable)
	college = {}
	college.egroup = objTable.eg_main
	college.units_in_training = {}
	EGroup_SetPlayerOwner(college.egroup, ROGUE_HUMAN_PLAYERS[1])
	local entity = EGroup_GetSpawnedEntityAt(college.egroup, 1)
	objTable.training_time = Entity_GetStateModelFloat(entity, "train_unit_obj_duration_rogue")
	Rule_AddEntityEvent(_College_OnAbilityUsed, entity, GE_AbilityExecuted, {objTable = objTable, entity =  entity})
	
	College_ReminderNeeded =  true
	Rule_AddOneShot(College_ObjectiveUI_Reminder, 5, {college = college, objTable = objTable})
end

function College_ObjectiveUI_Reminder(context, data)
	if College_ReminderNeeded then
		local college = data.college 
		local objTable = data.objTable 
		college.UI_element = Objective_AddUIElements(objTable, college.egroup, false, "$11268923", true, 0) --Activate to begin training
	end
end

function _College_OnAbilityUsed(context, data)
	Rule_RemoveEntityEvent(_College_OnAbilityUsed, data.entity)
	College_ReminderNeeded = false
	local objTable = data.objTable
	objTable.training_start_time = World_GetGameTime()
	Rule_Add(College_Countdown, {objTable = objTable})
end

function College_Countdown(context, data)
	local objTable = data.objTable
	local countdownTime = objTable.training_time - (World_GetGameTime() - objTable.training_start_time)
	Objective_SetProgressBar(objTable, 1 - (countdownTime / objTable.training_time))
	if college.UI_element ~= nil then
		Objective_RemoveUIElements(data.objTable, college.UI_element)
	end
	college.UI_element = Objective_AddUIElements(data.objTable, college.egroup, false, "$11268924", true, 0) --Training Progress
	
	if countdownTime == 0 then
		Rule_RemoveMe()
		if college.UI_element ~= nil then
			Objective_RemoveUIElements(data.objTable, college.UI_element)
		end
	end	
end

function College_AddUnit(squad)
	local unit_in_training = {}
	unit_in_training.entered_at = World_GetGameTime()
	unit_in_training.sbp = Squad_GetBlueprint(squad)
	unit_in_training.squad_id = Squad_GetID(squad)
	unit_in_training.position = Squad_GetPosition(squad)
	college.units_in_training[Squad_GetID(squad)] = unit_in_training
end

function College_ReleaseUnit(unit_in_training)
	SGroup_Clear(sg_temp)
	SGroup_Add(sg_temp, Squad_FromID(unit_in_training.squad_id))
	Cmd_UngarrisonSquad(sg_temp, nil, false)
	Modify_EntityMaxHealth(sg_temp, 2, MUT_Multiplication)
	college.units_in_training[unit_in_training.squad_id] = nil
end

function DestroyBuildingsObjective_Start(objTable)
	objTable.enemy_building_egroups = {}
	objTable.building_kill_target = 20
	objTable.building_kill_count = 0
	REWARD_PER_BUILDING_DESTROYED = Rogue_DifVar({25, 25, 25, 20, 20, 15, 15, 10})
	
	raid_rewards = {
		{icon = "icons/resources/resource_wood_icon", resource = RT_Wood},
		{icon = "icons/resources/resource_food_icon", resource = RT_Food},
		{icon = "icons/resources/resource_gold_icon", resource = RT_Gold},
		{icon = "icons/resources/resource_stone_icon", resource = RT_Stone},
		
	}
	
	for _, player in ipairs({ ROGUE_ENEMY_WAVE_PLAYER, ROGUE_ENEMY_ALLY_PLAYER, ROGUE_ENEMY_RAIDER_PLAYER }) do
		local egroup = EGroup_CreateUniqueWithPrefix("objective_enemy_buildings")
		Player_GetAll(player, egroup)
		EGroup_Filter(egroup, { "wall", "stone_wall_tower" }, FILTER_REMOVE)
		EGroup_Filter(egroup, "resource_pickup", FILTER_REMOVE)
		EGroup_Filter(egroup, "point_of_interest", FILTER_REMOVE)
		if eg_destroy_obj_exclude ~= nil then
			EGroup_RemoveGroup(egroup, eg_destroy_obj_exclude)
		end
		if #started_objectives > 0 then
			for i = 1, #started_objectives do
				if started_objectives[i].eg_main ~= nil and 
					EGroup_CountSpawned(started_objectives[i].eg_main) then
						EGroup_RemoveGroup(egroup, started_objectives[i].eg_main)
				end
			end
		end
		table.insert(objTable.enemy_building_egroups, egroup)
		Rule_AddEGroupEvent(DestroyBuildingsObjective_OnKill, egroup, GE_EntityKilled, { objTable = objTable })
	end

end

function DestroyBuildingsObjective_OnKill(context, data)
	local objTable = data.objTable
	local entity = context.victim
	local position = Entity_GetPosition(entity)
		
	local thisRaidReward = REWARD_PER_BUILDING_DESTROYED
	
	if Entity_IsOfType(context.victim, "landmark") then
		thisRaidReward = thisRaidReward * 10
	elseif Entity_IsOfType(context.victim, "castle") then
		thisRaidReward = thisRaidReward * 5
	elseif Entity_IsOfType(context.victim, "house") then
		thisRaidReward = thisRaidReward * 2
	elseif Entity_IsOfType(context.victim, "tent") or Entity_IsOfType(context.victim, "farm") then
		thisRaidReward = thisRaidReward
	else
		thisRaidReward = thisRaidReward * 3
	end
	
	local RandomRaidReward = Table_GetRandomItem(raid_rewards)
	
	UI_CreatePositionKickerMessage(position, Loc_FormatInteger(thisRaidReward), RandomRaidReward.icon, "", 5, 0, 5)
	UI_CreateEventCue(Loc_FormatText("$11270162", thisRaidReward), Loc_Empty(), "high_priority", RandomRaidReward.icon, "sfx_campaign_resource_pickup_gold", ECV_Queue)
	Player_AddResource(ROGUE_HUMAN_PLAYERS[1], RandomRaidReward.resource, thisRaidReward)
	--Sound_Play2D()
	--objTable.building_kill_count = objTable.building_kill_count + 1
	--if objTable.building_kill_count > objTable.building_kill_target then
		--objTable.building_kill_count = objTable.building_kill_target
	--end
	--Objective_SetCounter(objTable, objTable.building_kill_count, objTable.building_kill_target)
	--if objTable.building_kill_count == objTable.building_kill_target then
		--Objective_Complete(objTable, true, true)
		--for _, egroup in ipairs(objTable.enemy_building_egroups) do
			--Rule_RemoveEGroupEvent(DestroyBuildingsObjective_OnKill, egroup)
		--end
	--end
end

function SaveAlly_PreComplete(objTable)
	SAVE_ALLY_DELAY = 4 * 60
	SAVE_ALLY_WAIT = 30	
	ally_destination = ally_lane.ally_block_targets[#(ally_lane.ally_block_targets)].marker
	local params = {
		player = ROGUE_ALLY_PLAYER,
		spawn = mkr_ally_spawn,
		targets = ally_lane.ally_block_targets,
		targetOrder = TARGET_ORDER_LINEAR,
		onDeathDissolve = false,
		units = { type = "scar_manatarms", numSquads = ALLY_ARMY_SIZE }
	}
	ally_army = Army_Init(params)
	EventCues_CallToAction("$11268905", CTA_CELEBRATE, nil, nil, ally_army.sgroup, 30, "icons/cta/illustrations/player_reinforcement_arrived") --ALLIES ARRIVED
	Rule_AddInterval(SaveAlly_Monitor, 1)
	ally_check_at = World_GetGameTime() + SAVE_ALLY_DELAY
end

function SaveAlly_Monitor(context, data)
	if ally_reinforcements == nil then
		local missing_unit_count = ALLY_ARMY_SIZE - SGroup_CountSpawned(ally_army.sgroup)
		if World_GetGameTime() >= ally_check_at and ally_reinforce_at == nil then
			if missing_unit_count > 0 then
				ally_reinforce_at = World_GetGameTime() + SAVE_ALLY_WAIT
			end
		end
		if ally_reinforce_at and World_GetGameTime() >= ally_reinforce_at then
			local component_linear = math.min(missing_unit_count, 5)
			local component_root 
			if missing_unit_count >= 5 then
				component_root = (missing_unit_count - 5) ^ 0.65
			else
				component_root = 0
			end
			local numSquads = component_linear + component_root
			
			local params = {
				player = ROGUE_ALLY_PLAYER,
				spawn = mkr_ally_spawn,
				targets = ally_lane.ally_block_targets,
				targetOrder = TARGET_ORDER_LINEAR,
				combatRange = 50,
				onDeathDissolve = true,
				units = { type = "scar_manatarms", numSquads = numSquads }
			}
			ally_reinforcements = Army_Init(params)
			ally_check_at = World_GetGameTime() + SAVE_ALLY_DELAY
			ally_reinforce_at = nil
		end
	end
		
	if ally_reinforcements ~= nil then
		if ally_reinforcements.sgroup and SGroup_CountSpawned(ally_reinforcements.sgroup) > 0 then
			if Util_GetDistanceSquared(ally_reinforcements.sgroup, ally_destination) < 100 then
				TransferArmyIntoArmy(ally_reinforcements, ally_army)
				Rule_AddOneShot(SaveAlly_Reform, 2)
				ally_reinforcements = nil
			end
		else
			ally_reinforcements = nil
		end
	end
end

function SaveAlly_Reform()
	SGroup_AttackMove(ally_army.sgroup, ally_destination)
	SGroup_MoveAndFace(ally_army.sgroup, ally_destination, nil, nil, true)
end

function MonitorBonfire(context, data)
	local objTable = data.objTable
	if EGroup_CountSpawned(objTable.eg_main) > 0 then
		local bonfireHealth = EGroup_GetAvgHealth(objTable.eg_main)
		Objective_SetProgressBar(objTable, bonfireHealth) 
		if bonfireHealth >= 1 then
			Objective_Complete(objTable, true, true)
			Rule_RemoveMe()
		end
	else
		assert(true, "BONFIRE is missing! It may have died. This should never happen. Please report.")
	end
end

function Rogue_MonitorTrebuchetAttacks(context, data)
	local objTable = data.objTable
	rogueTrebuchetAttacksCounter = rogueTrebuchetAttacksCounter or 1
	if SGroup_CountSpawned(objTable.sg_main) > 0 then
		
		eg_rogue_trebtarget = EGroup_CreateIfNotFound("eg_rogue_trebtarget")
		eg_playerentities_unfiltered = EGroup_CreateIfNotFound("eg_playerentities_unfiltered")
		EGroup_Clear(eg_rogue_trebtarget)

		Player_GetAll(ROGUE_HUMAN_PLAYERS[1])		
		
		EGroup_Filter(eg_allentities, {"landmark", "wonder"}, FILTER_REMOVE)
		EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
					
		local _RemoveUntargetables = function(gid, index, eid)
			if Entity_GetTargetingType(eid) == Targeting_None then
				EGroup_Remove(gid, eid)
			end
			if Entity_GetHealthPercentage(eid) <= 0.2 then
				EGroup_Remove(gid, eid)
			end
		end
		EGroup_ForEach(eg_allentities, _RemoveUntargetables)
	
		EGroup_Duplicate(eg_allentities, eg_playerentities_unfiltered)
		local chosenTarget = nil

		if eg_allentities ~= nil and EGroup_CountSpawned(eg_allentities) > 0 then
			--Attack 1 is always a house
			if rogueTrebuchetAttacksCounter <= 1 then 
				EGroup_Filter(eg_allentities, {"house", "economy_building"}, FILTER_KEEP)
				if EGroup_CountSpawned(eg_allentities) > 0 then
					chosenTarget = EGroup_GetRandomSpawnedEntity(eg_allentities)
					if chosenTarget ~= nil then
						EGroup_Add(eg_rogue_trebtarget, chosenTarget)
					end
				end
			else
				EGroup_Filter(eg_allentities, {"house", "economy_building", "outpost", "castle"}, FILTER_REMOVE)
				if EGroup_CountSpawned(eg_allentities) > 0 then
					chosenTarget = EGroup_GetRandomSpawnedEntity(eg_allentities)
					if chosenTarget ~= nil then
						EGroup_Add(eg_rogue_trebtarget, chosenTarget)
					end
				end
			end
		end
		
		--If a valid target is selected attack.
		--Else if Wonder is final valid target, choose it.
		local distanceToTarget = 0
		local targetPos = nil
		local trebPos = Util_GetPosition(objTable.sg_main)
		if EGroup_CountSpawned(eg_rogue_trebtarget) < 1 then
			targetPos = Util_GetPosition(mkr_wonder)
		else
			targetPos = Util_GetPosition(eg_rogue_trebtarget)
		end
		Cmd_Attack(objTable.sg_main, targetPos, false)	
		distanceToTarget = Util_GetDistance(objTable.sg_main, targetPos)
		
		Rule_AddOneShot(Rogue_StopEnemyTrebFiring, 10, {objTable = objTable})
		rogueTrebuchetAttacksCounter = rogueTrebuchetAttacksCounter + 1
		
		for i = 1, distanceToTarget/5 do
			local nextSpot = World_GetOffsetPositionRelativeToFacingTarget(trebPos, targetPos, i*5)
			FOW_PlayerRevealArea(ROGUE_HUMAN_PLAYERS[1], nextSpot, 5, 0.125)
		end
		
		if Objective_IsComplete(objTable) == false then
			Rule_AddOneShot(Rogue_MonitorTrebuchetAttacks, Rogue_GetTrebNextShotDelay(), {objTable = objTable})
			Rule_Add(Rogue_MonitorTrebAttackTimer, {objTable = objTable})
		end
	end
end

function _Rogue_SetTrebFacing(context, data)
	objTable = data.objTable
	nook = objTable.nook
	
	local wonderFacing = Util_GetFacingFromDirection(nook.position, Util_GetDirectionFromAtoB(nook.position, mkr_wonder))
	
	--Cmd_Ability(objTable.inner_army_3.sgroup, BP_GetAbilityBlueprint("core_formation_spread"), nil, nil, true, true)
	--Cmd_FormationMove(objTable.inner_army_3.sgroup, nook.position, true, false, wonderFacing)
	SGroup_MoveAndFace(objTable.sg_main, nook.position, nil, wonderFacing, true)
	
end

function Rogue_StopEnemyTrebFiring(context, data)
	Cmd_Stop(data.objTable.sg_main)
end

function Rogue_MonitorTrebAttackTimer(context, data)
	objTable = data.objTable
	
	rogueTrebTimerID = rogueTrebTimerID or nil
	rogueTrebTimerStart = rogueTrebTimerStart or 0
	rogueTrebNextShotTime = rogueTrebNextShotTime or 0
	local remaining_time = 0
	
	if rogueTrebTimerID == nil then		
		rogueTrebTimerStart = World_GetGameTime()
		rogueTrebNextShotTime = rogueTrebTimerStart + Rogue_GetTrebNextShotDelay()
		remaining_time = rogueTrebNextShotTime - World_GetGameTime()
	else
		Objective_RemoveUIElements(objTable, rogueTrebTimerID)
		remaining_time = rogueTrebNextShotTime - World_GetGameTime()
	end
	
	if remaining_time <= 0 or Objective_IsComplete(objTable) then
		Rule_RemoveMe()
		rogueTrebTimerID = nil
	else
		rogueTrebTimerID = Objective_AddUIElements(objTable, objTable.nook.position, false, Loc_FormatText("$11271501", Loc_FormatTime_M_S(math.ceil(remaining_time), true)), true, 8) --"Firing in "
	end
	
end

function Rogue_GetTrebNextShotDelay()
	local rogueTrebMaxShotTime = Rogue_DifVar({3600, 3600, 3600, 3600, 120, 100, 80, 60})
	local rogueTrebMinShotTime = Rogue_DifVar({3600, 3600, 3600, 3600, 60, 50, 40, 30})
	local TREB_MAX_SPEED_AT = 35 * 60
	local currentGameTime = World_GetGameTime()
	local gameTimeProgress = currentGameTime/TREB_MAX_SPEED_AT
	local rogueTrebAcceleratedTime = gameTimeProgress * (rogueTrebMaxShotTime - rogueTrebMinShotTime)
	local nextTrebShotTime = rogueTrebMaxShotTime
	if gameTimeProgress > 1 then
		nextTrebShotTime = rogueTrebMinShotTime
	else 
		nextTrebShotTime = rogueTrebMaxShotTime - rogueTrebAcceleratedTime
	end
	return nextTrebShotTime
end

function Rogue_MonitorEnemyTrebHealth(context, data)
	objTable = data.objTable
	
	if Objective_IsComplete(objTable) or SGroup_CountSpawned(objTable.sg_main) < 1 or EGroup_CountSpawned(objTable.eg_tents) < 1 then
		Rule_RemoveMe()
	else
		if SGroup_GetAvgHealth(objTable.sg_main) < 1 and SGroup_CountSpawned(objTable.sg_repairvills) < 1 then
			
			local _SpawnVillPerTent = function(gid, index, eid)
				SGroup_Clear(sg_single)
				CreateUnits(ROGUE_ENEMY_ALLY_PLAYER, {type = "scar_villager", numSquads = 1}, Util_GetPosition(eid), sg_single)
				SGroup_AddGroup(objTable.sg_repairvills, sg_single)
			end
			EGroup_ForEach(objTable.eg_tents, _SpawnVillPerTent)
			
			Player_AddResource(ROGUE_ENEMY_ALLY_PLAYER, RT_Wood, 50000)
			Cmd_Ability(objTable.sg_repairvills, BP_GetAbilityBlueprint("villager_repair"), objTable.sg_main)
			
		elseif SGroup_GetAvgHealth(objTable.sg_main) >= 1 and SGroup_CountSpawned(objTable.sg_repairvills) > 0 and SGroup_IsIdle(objTable.sg_repairvills, ANY) then
			local _DespawnVillPerTent = function(gid, index, sid)
				SGroup_Clear(sg_single)
				SGroup_Add(sg_single, sid)
				Cmd_Move(sg_single, EGroup_GetRandomSpawnedEntity(objTable.eg_tents), false, true)
			end
			SGroup_ForEach(objTable.sg_repairvills, _DespawnVillPerTent)
		elseif SGroup_GetAvgHealth(objTable.sg_main) < 1 and SGroup_CountSpawned(objTable.sg_repairvills) > 0 and SGroup_IsIdle(objTable.sg_repairvills, ANY) then
			Player_AddResource(ROGUE_ENEMY_ALLY_PLAYER, RT_Wood, 50000)
			Cmd_Ability(objTable.sg_repairvills, BP_GetAbilityBlueprint("villager_repair"), objTable.sg_main)
		end
	end
end


