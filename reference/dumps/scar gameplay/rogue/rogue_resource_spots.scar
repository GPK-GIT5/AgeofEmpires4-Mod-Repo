			ebp_icon = BP_GetEntityBlueprint("gaia_deer_dummy_minimap_icon"),
			count_min = 4,
			count_max = 8,
			weight = resource_weights[2]
		},
		{
			name = "boar",
			resource_class = "gaia",
			sbp = SBP.GAIA.GAIA_HUNTABLE_BOAR,
			ebp_icon = BP_GetEntityBlueprint("gaia_boar_dummy_minimap_icon"),
			count_min = 1,
			count_max = 1,
			weight = resource_weights[3]
		},
		{
			name = "food",
			resource_class = "pickup",
			ebp = BP_GetEntityBlueprint("resource_pickup_food_rogue"),
			count_min = 1,
			count_max = 1,
			weight = resource_weights[4]
		},
		{
			name = "wood",
			resource_class = "pickup",
			ebp = BP_GetEntityBlueprint("resource_pickup_wood_rogue"),
			count_min = 1,
			count_max = 1,
			weight = resource_weights[5]
		},
		{
			name = "gold",
			resource_class = "pickup",
			ebp = BP_GetEntityBlueprint("resource_pickup_gold_rogue"),
			count_min = 1,
			count_max = 1,
			weight = resource_weights[6]
		},
		{
			name = "stone",
			resource_class = "pickup",
			ebp = BP_GetEntityBlueprint("resource_pickup_stone_rogue"),
			count_min = 1,
			count_max = 1,
			weight = resource_weights[7]
		},
		{
			name = "food_naval",
			resource_class = "pickup_naval",
			ebp = BP_GetEntityBlueprint("resource_pickup_naval_food_rogue"),
			count_min = 1,
