import("cardinal.scar")
import("MissionOMatic/MissionOMatic.scar")

-----------------------------------------------------------------
--------- Generates randomized resource spots
-----------------------------------------------------------------

--? @shortdesc Sets the weighted distribution of resource spawns on the current map.
--? Order of types follows: Sheep, Deer, Boar, Food (pickups), Wood, Gold, Stone
--? @args table Weight Integers
