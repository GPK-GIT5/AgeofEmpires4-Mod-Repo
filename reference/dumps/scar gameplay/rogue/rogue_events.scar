import("rogue/rogue_rounds.scar")
import("rogue/rogue_tech_tree.scar")
import("rogue/rogue_factions.scar")
import("rogue/rogue_roamers.scar")
import("rogue/rogue_misc.scar")

EVENT_TYPE_START_GATHERING = 1
EVENT_TYPE_ROUND_ARRIVE = 2
EVENT_TYPE_AGE_UP = 3
EVENT_TYPE_INCREASE_MAX_LANES = 4
EVENT_TYPE_UNLOCK_LANE = 5
EVENT_TYPE_ROUND_SPAWN = 6
EVENT_TYPE_SUBWAVE_LAUNCH = 7
EVENT_TYPE_GRANT_COMBAT_UPGRADES = 8
EVENT_TYPE_SPAWN_ROAMERS = 9
EVENT_TYPE_INCREASE_MIN_LANES = 10

------------------------------------------------------------
----------------------- INIT EVENT -------------------------
------------------------------------------------------------

function Event_InitStartGathering(time)
	ValidateInteger(time)
	local event = {}
	event.time = time
	event.name = "start gathering"
	event.event_type = EVENT_TYPE_START_GATHERING
	Events_InsertEventAtCorrectTime(states.sim.events, event)
	Events_InsertEventAtCorrectTime(states.game.events, event)
end

function Event_InitRoundSpawn(time, round)
	ValidateInteger(time)
	local event = {}
	event.time = time
	event.name = "round spawn"
	event.event_type = EVENT_TYPE_ROUND_SPAWN
	event.round = round
	Events_InsertEventAtCorrectTime(states.game.events, event)
end

function Event_InitSubwaveLaunch(time, subwave)
	ValidateInteger(time)
	local event = {}
