--
-- "Pickups"
--
--  Prefab Script
--

import("Prefabs/Schemas/Pickups.scar")


--? @group scardoc;Prefabs


-- Initializer function should ALWAYS be named after the prefab name with _Init appended on the end
function pickups_Init(data)

	local instance = Prefab_GetInstance(data)
	
	pickups_SpawnAllPickups(instance)
	
end

function pickups_SpawnAllPickups(data)
	
	local instance = Prefab_GetInstance(data)
	
	local diff = Game_GetSPDifficulty()
	
	local __tempPickupEG = EGroup_CreateUnique("__tempPickupEG")
	
	for k,v in pairs(instance.pickuplist) do
		if v.presentOnDifficulty == "All" or 
		  (v.presentOnDifficulty == "Easy" and diff == 0) or
		  (v.presentOnDifficulty == "Easy / Normal" and (diff == 0 or diff == 1)) or
		  (v.presentOnDifficulty == "Normal" and diff == 1) or
		  (v.presentOnDifficulty == "Normal / Hard" and (diff == 1 or diff == 2)) or
		  (v.presentOnDifficulty == "Hard" and diff == 2) then
			Util_CreateEntities(nil, {__tempPickupEG, v.egroup}, v.blueprint, v.pickup_location, 1)
		end
	end
	
end
