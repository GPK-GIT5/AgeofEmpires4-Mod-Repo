--
-- WorldBuilder prefab
-- "HealthTrigger"
--


-- Schema

healthtrigger_schema = {		-- schema ALWAYS named the prefab name with schema on the end

	type = "prefab", 
	name = "healthtrigger",																						-- name the prefab uses to identify itself
	description = "Health Trigger",																			-- name to display for this prefab
	script = "HealthTrigger.scar",																	-- script associated with this prefab, needs to be imported into the prefab data script
	proxy = "art/gameplay/designer_objects/placeholder_templates/health_a",			-- some identifying visual we can see in the WB - something to click on, too, in order to select the prefab
	itemSchema = {
	
		-- trigger zone
		{
			type = ST_STRING,
			name = "active",
			description = "Trigger Active:",
			options = {"Immediately", "Manually"},
			default = "Immediately",
		},
		{
			type = ST_STRING,
			name = "trigger_type",
			description = "Trigger Type",
			options = {"SGroup", "EGroup"},
			default = "EGroup",
		},
		{
			type = ST_EGROUP,
			name = "egroup",
			description = "EGroup",
		},
		{
			type = ST_SGROUP,
			name = "sgroup",
			description = "SGroup",
		},
		{
			type = ST_STRING,
			name = "check_operator",
			description = "Operator",
			options = {"<", "<=", "==", ">=", ">"},
			default = "<=",                     
		},
		{
			type = ST_NUMBER,
			name = "health_percentage",                 
			description = "Health Percentage",          
			default = 0.5,                     
		},
		
		-- list of things to trigger
		{
			type = ST_TABLE,
			name = "things_to_trigger",
			description = "Things to trigger",
			multiplicity = "multiple",
			itemSchema = {
				{
					type = ST_STRING,
					name = "trigger_type",
					description = "Trigger a",
					options = {"Prefab", "Scar Function", "Call Intel Table"},
					default = "Prefab",
				},
				{
					type = ST_PREFAB,			-- to be ST_PREFAB eventually
					name = "trigger_prefab",
					description = "  named:",
					compatibility = "triggerable",
					requirement = {"trigger_type", "Prefab"},
				},
				{
					type = ST_STRING,
					name = "trigger_scar",
					description = "  named:",
					variableName = true,
					requirement = {"trigger_type", "Scar Function"},
				},
				
				{
					type = ST_NUMBER,
					name = "delay",
					description = "Delay:",
					default = 0,
				},
				{																					-- call SCAR function
					type = ST_STRING,
					name = "trigger_callinteltable",
					description = "    named:",
					variableName = true,
					requirement = {"trigger_type", "Call Intel Table"},
				},
			},
		},
 
	},
}