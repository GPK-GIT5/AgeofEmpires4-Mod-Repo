--
-- WorldBuilder prefab
-- "Pickups"
--

-- Schema

pickups_schema = {		-- schema ALWAYS named the prefab name with schema on the end
	
	type = "Prefab",
	name = "pickups",																						-- name the prefab uses to identify itself
	description = "Pickups",																				-- name to display for this prefab
	script = "Pickups.scar",																		-- script associated with this prefab, needs to be imported into the prefab data script
	compatibility = {
		"triggerable",
	},
	proxy = "art/gameplay/designer_objects/placeholder_templates/pickup_a",				-- some identifying visual we can see in the WB - something to click on, too, in order to select the prefab
	itemSchema = {
		{
			type = ST_TABLE,
			name = "pickuplist",
			description = "Pickup List",
			multiplicity = "multiple",
			itemSchema = {
				{
					type = ST_MARKER,
					name = "pickup_location",
					description = "Pickup location",
					colour = "blue",
					tooltip = "Location of the pickup",
					hasDirection = true,
				},
				{
					type = ST_PBG,
					name = "blueprint",
					blueprintType  = "entity",
					description = "Pickup",
					show = true,
					showAlways = true,
					lockedTo = "pickup_location",
				},
				{
					type = ST_STRING,
					name = "presentOnDifficulty",
					description = "Is this pickup present",
					options = {"All", "Easy", "Normal", "Hard", "Easy / Normal", "Normal / Hard"},
					show = true,
					colour = "DarkCyan",
					lockedTo = "pickup_location",
					default = "All",
				},
				{
					type = ST_EGROUP,
					name = "egroup",
					description = "Pickup EGroup",
					
				}
			},
		},
	},	
}