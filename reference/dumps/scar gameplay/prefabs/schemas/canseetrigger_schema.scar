--
-- WorldBuilder prefab
-- "CanSeeTrigger"
--


-- Schema

canseetrigger_schema = {		-- schema ALWAYS named the prefab name with schema on the end

	type = "prefab", 
	name = "canseetrigger",																						-- name the prefab uses to identify itself
	description = "Can See Trigger",																			-- name to display for this prefab
	script = "CanSeeTrigger.scar",																	-- script associated with this prefab, needs to be imported into the prefab data script
	compatibility = {
		"trigger_zone",
	},
	proxy = "art/gameplay/designer_objects/placeholder_templates/encounter_see_a",			-- some identifying visual we can see in the WB - something to click on, too, in order to select the prefab
	itemSchema = {
	
		{
			type = ST_STRING,
			name = "active",
			description = "Trigger Active:",
			options = {"Immediately", "Manually"},
			default = "Immediately",
		},
		
		
		-- trigger zone
		{
			type = ST_PLAYER,
			name = "trigger_player",
			description = "Trigger player:",
			default = "Player1",                     
		},
		{
			type = ST_STRING,
			name = "trigger_type",
			description = "    can see:",
			options = {"Marker", "SGroup", "EGroup"},
			default = "Marker",                     
		},
		{
			type = ST_MARKER,
			name = "trigger_marker",
			description = "Location",
			colour = "white",
			default = true,
			hasRange = false,
			requirement = {"trigger_type", "Marker"},
		},
		{
			type = ST_SGROUP,
			name = "trigger_sgroup",
			description = "    named:",
			requirement = {"trigger_type", "SGroup"},
		},
		{
			type = ST_EGROUP,
			name = "trigger_egroup",
			description = "    named:",
			requirement = {"trigger_type", "EGroup"},
		},


		
		-- repeatability
		{
			type = ST_BOOLEAN,
			name = "repeatable",
			description = "Repeatable trigger",
			default = false,
		},
		{
			type = ST_STRING,
			name = "repeat_type",
			description = "Repeat after:",
			options = {"Timed Delay", "Leave and Come Back"},
			default = "Timed Delay",
			requirement = {"repeatable", true},
		},
		{
			type = ST_NUMBER,
			name = "repeat_delay",
			description = "Delay (seconds):",
			default = 1,
			requirement = {"repeat_type", "Timed Delay"},
		},
		{
			type = ST_NUMBER,
			name = "repeat_count",
			description = "Number of repeats:",
			tooltip = "# of times trigger can repeat.  (Use 0 to repeat indefinitely)",
			integer = true,
			default = 0,
			requirement = {"repeatable", true},
		},
		
		-- list of things to trigger
		{
			type = ST_TABLE,
			name = "things_to_trigger",
			description = "Things to trigger",
			multiplicity = "multiple",
			itemSchema = {
				{
					type = ST_STRING,
					name = "trigger_type",
					description = "Trigger a",
					options = {"Prefab", "Scar Function", "Speech Event"},
					default = "Prefab",
				},
				{
					type = ST_PREFAB,																				-- trigger Prefab
					name = "trigger_prefab",
					description = "  named:",
					compatibility = "triggerable",
					requirement = {"trigger_type", "Prefab"},
				},
				{
					type = ST_STRING,																				-- call SCAR function
					name = "trigger_scar",
					description = "  named:",
					variableName = true,
					requirement = {"trigger_type", "Scar Function"},
				},
				
				{	
					type = ST_STRING,																				-- trigger Intel Event
					name = "trigger_intelevent",
					description = "    EVENTS.",
					variableName = true,
					requirement = {"trigger_type", "Speech Event"},
				},
				
				{
					type = ST_NUMBER,
					name = "delay",
					description = "Delay:",
					default = 0,
				},
			},
		},
 
	},
}