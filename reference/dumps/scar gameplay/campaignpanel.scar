--
-- XP3 Campaign Tribute and Reinforcement Panel
-- 
-- Shared script for implementing standard tribute and reinforcement panels in campaign missions.
--
-- Details can be found here:
--     http://relicwiki/display/CARD/Campaign+Panels (in the EE, you can Control-click on this link to go there)
--

import("Cardinal.scar")


CAMPAIGNPANEL_CANCEL = false			-- if the callbackFunction returns this const, the system will not charge the player the resource costs (i.e. for some reason, the callback decided that the action should be abandoned)
REMOVE_DATA = "#!REMOVE"				-- magic string, used to force a value to nil when mergine tables in the updateData functions (since you can't pass in nil as a value for a key in a table and merge that in!)




function CampaignPanel_Init()
	
	if _t_campaignPanel == nil then 
		
		_t_campaignPanel = {
			
			uiCreated = false,
			dirty = false,

			tributePanelCallback = nil,
			tributePanelSortFunction = _TributePanel_DefaultSortFunction,
			
			reinforcementPanelCallback = nil, 
			reinforcementPanelSortFunction = _ReinforcementPanel_DefaultSortFunction,
			
			commands = {
				
				-- general
				togglePanel = UI_CreateCommand("_CampaignPanel_Toggle"),
				
				-- tribute panel
				sendTribute = UI_CreateCommand("_TributePanel_Send_ButtonCallback"),
				clearTribute = UI_CreateCommand("_TributePanel_Clear_ButtonCallback"),
				increaseTribute = UI_CreateCommand("_TributePanel_IncreaseTribute_ButtonCallback"),
				decreaseTribute = UI_CreateCommand("_TributePanel_DecreaseTribute_ButtonCallback"),
				
				-- reinforcements panel
				buyItem = UI_CreateCommand("_ReinforcementPanel_BuyItem_ButtonCallback"),
				
			},
			
			ageStrings = {
				Loc_GetString("$11180928"),	-- I
				Loc_GetString("$11180929"),	-- II
				Loc_GetString("$11180930"),	-- III
				Loc_GetString("$11180931"),	-- IV
			},
			
		}
		
		
		-- set the initial data context passed through to the UI
		_t_campaignPanel.uiData = {
			
			state = {
				open = false,
				enabled = false,
				tributePanelEnabled = false,
				reinforcementPanelEnabled = false,
			},
			toggleCommand = _t_campaignPanel.commands.togglePanel,		
			toggleButtonTooltip = "$11161242",		-- Players & Tribute
			
			reinforcementPanel = {
				items = {},
			},
		
			tributePanel = {
				players = {},
				sendTributeCommand = _t_campaignPanel.commands.sendTribute,
				clearTributeCommand = _t_campaignPanel.commands.clearTribute,	
			},
		}
		
		
		-- create the XAML interface and push it to the UI
		_CampaignPanel_CreateUI()
		_CampaignPanel_SetDirty(true)
		
		-- register the network events used by this panel
		Network_RegisterEvent("_TributePanel_Send_ReceieveNetworkMessage")
		Network_RegisterEvent("_ReinforcementPanel_BuyItem_ReceieveNetworkMessage")

		-- monitor for certain events that may require the panel to update
		Rule_AddGlobalEvent(_CampaignPanel_OnUpgradeComplete, GE_UpgradeComplete)			-- if the player ages up, update the age in the tribute panel
		Rule_AddGlobalEvent(_CampaignPanel_OnPlayerNameChanged, GE_PlayerNameChanged)		-- if the player changes name, update the tribute panel. Note: This doesn't appear to be triggered if the script calls Setup_SetPlayerName(player, newName)
		
		-- make sure we recreate the UI if coming in from a savegame
		Game_SetGameRestoreCallback(_CampaignPanel_OnGameRestore)
		
	end
	
end




--
--
-- TRIBUTE panel
--
--


--? @shortdesc Initialize the Tribute Panel system
--? @extdesc Callback function will receive the parameters (sendingPlayer, receivingPlayer, tributeData) with the tributeData table containing details of amount of each resource, etc.
--? @args Function callbackFunction
function TributePanel_Init(callbackFunction)
	
	CampaignPanel_Init()		-- initialize the system (if it hasn't been initialized already)
	
	-- set the user callback (buttons are actually hooked up to this system's callback function, but that will in turn call the user one)
	_t_campaignPanel.tributePanelCallback = callbackFunction
	
end


--? @shortdesc Create a tribute panel. It will be disabled to start, so you'll need to call TributePanel_Enable() for it to appear.
--? @args Player/Table ownerPlayers, Player/Table recipientPlayers, ResourceType/Table allowedResourceTypes[, Real taxRate]
function TributePanel_Create(owner, recipientPlayers, allowedResourceTypes, taxRate)
		
	if _CampaignPanel_IsLocalPlayer(owner) then 
		
		-- normalize the recipientPlayers parameter
		if recipientPlayers == nil then 
			fatal("TributePanel_Create: Need to specify which players should appear in the panel (either a single player, a table of players, or ALL)")
		elseif recipientPlayers == ALL then	
			recipientPlayers = {}
			for index = 1, World_GetPlayerCount() do 
				table.insert(recipientPlayers, World_GetPlayerAt(index))
			end
		elseif scartype(recipientPlayers) == ST_PLAYER then 
			recipientPlayers = {recipientPlayers}
		end
		
		-- normalize the allowedResourceTypes parameter
		if allowedResourceTypes == nil then 
			fatal("TributePanel_Create: Need to specify which resources you should be able to tribute in the panel (either a single RT_ResourceType, a table of RT_ResourceTypes, or ALL)")
		elseif allowedResourceTypes == ALL then
			allowedResourceTypes = {RT_Food, RT_Wood, RT_Gold, RT_Stone}
		elseif scartype(allowedResourceTypes) ~= ST_TABLE then 
			allowedResourceTypes = {allowedResourceTypes}
		end
		
		-- normalize the taxRate parameter (needs to be nil to make it go away in the UI, so blank it out if someone specifies 0)
		if taxRate == 0 then
			taxRate = nil 
		end
		
		local tributePanel = _t_campaignPanel.uiData.tributePanel
		
		tributePanel.players = {}
		tributePanel.sendTributeCommand = _t_campaignPanel.commands.sendTribute	
		tributePanel.clearTributeCommand = _t_campaignPanel.commands.clearTribute	
		
		for index, player in ipairs(recipientPlayers) do 
			
			local playerData = _TributePanel_CreateRecipientPlayerData(player, allowedResourceTypes)
			table.insert(tributePanel.players, playerData)
			
		end
		
		if taxRate ~= nil then 
			tributePanel.taxRate = taxRate * 100
		end
		
		
		_TributePanel_UpdateTotals()
		
		_CampaignPanel_SetDirty()
		
	end
	
end


--? @shortdesc Enable the Tribute Panel and make it visible. This is different to opening the panel, for which you should use ReinforcementPanel_Open() 
function TributePanel_Enable(owner)

	if _CampaignPanel_IsLocalPlayer(owner) then 
		
		local state = _t_campaignPanel.uiData.state
		
		state.tributePanelEnabled = true
		state.enabled = true
		
		_CampaignPanel_SetToggleButtonTooltip()
		_CampaignPanel_SetDirty()
		
		if Rule_Exists(_CampaignPanel_Manager) == false then  
			Rule_Add(_CampaignPanel_Manager)
		end
		
	end
	
end


--? @shortdesc Disable the Tribute Panel and make it disappear completely. This is different to closing the panel, for which you should use ReinforcementPanel_Close()
function TributePanel_Disable(owner)
	
	if _CampaignPanel_IsLocalPlayer(owner) then 

		local state = _t_campaignPanel.uiData.state

		state.tributePanelEnabled = false
		state.enabled = state.tributePanelEnabled or state.reinforcementPanelEnabled
		
		if state.enabled == false then 
			state.open = false			 				-- set the panel to closed if it was open
		end
		
		_CampaignPanel_SetToggleButtonTooltip()
		_CampaignPanel_SetDirty(true)					-- force an update now (as we're removing the updater rule)
		
		if state.enabled == false and Rule_Exists(_CampaignPanel_Manager) == true then  
			Rule_Remove(_CampaignPanel_Manager)
		end
		
	end
	
end


--? @shortdesc Return whether the Tribute Panel is currently enabled or not. THIS IS NOT MP-SAFE.
--? @result Boolean
function TributePanel_IsEnabled()
	
	local state = _t_campaignPanel.uiData.state
	
	return state.tributePanelEnabled
	
end


--? @shortdesc Force open the Tribute Panel.
function TributePanel_Open(owner)

	if _CampaignPanel_IsLocalPlayer(owner) then 
		
		local state = _t_campaignPanel.uiData.state
		
		if state.tributePanelEnabled == true then 
			_CampaignPanel_SetValue(state, "open", true)
		end
		
	end
	
end


--? @shortdesc Force close the Tribute Panel.
function TributePanel_Close(owner)

	if _CampaignPanel_IsLocalPlayer(owner) then 

		local state = _t_campaignPanel.uiData.state
		
		if state.tributePanelEnabled == true then 
			_CampaignPanel_SetValue(state, "open", false)
		end
		
	end
	
end


--? @shortdesc Return whether the Tribute Panel is currently open or not. THIS IS NOT MP-SAFE.
--? @result Boolean
function TributePanel_IsOpen()

	local state = _t_campaignPanel.uiData.state
	
	if state.tributePanelEnabled == false then
		return false
	else
		return state.open
	end
	
end


--? @shortdesc Add a new player as a potential recipient in the Tribute Panel. 
--? @args PlayerID/Table owner, PlayerID/Table recipient, ResourceType/Table allowedResourceTypes
function TributePanel_AddRecipient(owner, recipient, allowedResourceTypes)
	
	if _CampaignPanel_IsLocalPlayer(owner) then 

		if scartype(recipient) ~= ST_TABLE then 
			recipient = {recipient}
		end
	
		if allowedResourceTypes == nil then 
			fatal("TributePanel_AddRecipient: Need to specify which resources should be available for this recipient (either a single RT_ResourceType, a table of RT_ResourceTypes, or ALL)")			
		elseif allowedResourceTypes == ALL then
			allowedResourceTypes = {RT_Food, RT_Wood, RT_Gold, RT_Stone}
		elseif scartype(allowedResourceTypes) ~= ST_TABLE then 
			allowedResourceTypes = {allowedResourceTypes}
		end
	
		local tributePanel = _t_campaignPanel.uiData.tributePanel
		
		for index, newPlayer in pairs(recipient) do 
			
			-- check that the new player isn't already in the list
			local newPlayerIndex = World_GetPlayerIndex(newPlayer)
			local alreadyInList = false
			for index, player in ipairs(tributePanel.players) do 	
				if player.playerIndex == newPlayerIndex then 
					alreadyInList = true 
					break
				end
			end
			
			if alreadyInList == false then 
				
				local newPlayerData = _TributePanel_CreateRecipientPlayerData(newPlayer, allowedResourceTypes)
				table.insert(tributePanel.players, newPlayerData)
				
				_TributePanel_SortItems()
			
				_CampaignPanel_SetDirty()
				
			end
			
		end
		
	end
	
end


--? @shortdesc Remove a player as a potential recipient in the Tribute Panel.
--? @args PlayerID/Table owner, PlayerID recipient
function TributePanel_RemoveRecipient(owner, recipient)
	
	if _CampaignPanel_IsLocalPlayer(owner) then 

		if scartype(recipient) ~= ST_TABLE then 
			recipient = {recipient}
		end
		
		for index, player in pairs(recipient) do 
			
			local playerIndex = World_GetPlayerIndex(player)
			
			-- search through the player list, removing them if they match
			for index = #_t_campaignPanel.uiData.tributePanel.players, 1, -1 do 
				local player = _t_campaignPanel.uiData.tributePanel.players[index]
				if player.playerIndex == playerIndex then 
					table.remove(_t_campaignPanel.uiData.tributePanel.players, index) 
					_CampaignPanel_SetDirty()
				end
				
			end
			
		end
		
	end
	
end


--? @shortdesc Enable sending resources of a specific type in the Tribute Panel.
--? @args PlayerID/Table owner, PlayerID/Table recipient, ResourceType resource
function TributePanel_EnableResourceType(owner, recipient, resourceType)
	
	if _CampaignPanel_IsLocalPlayer(owner) then 

		if recipient == nil then 
			fatal("TributePanel_EnableResourceType: Need to specify which players you want to enable the resource type for (either ALL, a single player, or a table of players)")
		elseif scartype(recipient) == ST_PLAYER then 
			recipient = {recipient}
		end
		
		for index, entry in ipairs(_t_campaignPanel.uiData.tributePanel.players) do 	
			
			local player = World_GetPlayerAt(entry.playerIndex)
			
			if recipient == ALL or Table_Contains(recipient, player) then
				for index, resource in ipairs(entry.resources) do 
					if resource.resourceType == resourceType then
						
						if Game_GetLocalPlayer() == player then 
							-- leave as is 
						elseif resource.resourceType == RT_Stone and Player_GetRace(player) == RACE.MONGOL then 
							-- leave as is 
						else
							
							resource.isEnabled = true
							resource.blockedReason = nil
							
							_CampaignPanel_SetDirty()
							
						end
						
					end
				end
			end
			
		end
		
	end
	
end


--? @shortdesc Disable sending resources of a specific type in the Tribute Panel.
--? @args PlayerID/Table owner, PlayerID/Table recipients, ResourceType resource[, LocString reason]
function TributePanel_DisableResourceType(owner, recipient, resourceType, reason)
	
	if _CampaignPanel_IsLocalPlayer(owner) then 

		if recipient == nil then 
			fatal("TributePanel_EnableResourceType: Need to specify which players you want to enable the resource type for (either ALL, a single player, or a table of players)")
		elseif scartype(recipient) == ST_PLAYER then 
			recipient = {recipient}
		end
		
		for index, entry in ipairs(_t_campaignPanel.uiData.tributePanel.players) do 	
			
			local player = World_GetPlayerAt(entry.playerIndex)
			
			if recipient == ALL or Table_Contains(recipient, player) then
				for index, resource in ipairs(entry.resources) do 
					if resource.resourceType == resourceType then
						
						if Game_GetLocalPlayer() == player then 
							-- leave as is 
						elseif resource.resourceType == RT_Stone and Player_GetRace(player) == RACE.MONGOL then 
							-- leave as is 
						else
							
							resource.isEnabled = false
							
							if reason == nil then 
								resource.blockedReason = Loc_Empty()
							else
								resource.blockedReason = Loc_GetString(reason)
							end
							
							_CampaignPanel_SetDirty()
							
						end
						
					end
				end
			end
			
		end
		
	end
	
end



--? @shortdesc Specify a custom sort function to sort items in the tribute panel. The function takes two items as parameters (a and b) and returns true if they are in the correct order, a coming before b.
--? @extdesc The default sort function is _TributePanel_DefaultSortFunction(a, b) in reinforcementpanel.scar
--? @args PlayerID/Table owner, Function sortFunc
function TributePanel_SetSortFunction(owner, newSortFunction)
	
	if _CampaignPanel_IsLocalPlayer(owner) then 

		_t_campaignPanel.tributePanelSortFunction = newSortFunction
		
		_TributePanel_SortItems()
		_CampaignPanel_SetDirty()
		
	end
	
end


-- trigger a re-sort on the items in the panel's items table
function _TributePanel_SortItems()
	
	table.sort(_t_campaignPanel.uiData.tributePanel.players, _t_campaignPanel.tributePanelSortFunction)
	
end


-- this is the standard sort function, which is hooked up by default
function _TributePanel_DefaultSortFunction(a, b)
	
	return a.playerIndex < b.playerIndex

end




function _TributePanel_CreateRecipientPlayerData(player, allowedResourceTypes)

	local playerData = {
		playerIndex = World_GetPlayerIndex(player),
		playerName = Loc_GetString(Player_GetDisplayName(player)),
		playerColor = UI_GetColourAsString(Player_GetUIColour(player)),
		civIcon = string.format("pack://application:,,,/WPFGUI;component/%s.png", string.gsub(World_GetRaceIcon(Player_GetRace(player)), "\\", "/" )),
		age = Player_GetCurrentAge(player),
		ageString = _t_campaignPanel.ageStrings[Player_GetCurrentAge(player)],
		resources = {
			{ key = "food",   resourceType = RT_Food,  resourceIcon = "pack://application:,,,/WPFGUI;component/icons/resources/resource_food_icon.png",  tooltipTitle = Loc_FormatText("$11164967", Player_GetDisplayName(player)) },
			{ key = "wood",   resourceType = RT_Wood,  resourceIcon = "pack://application:,,,/WPFGUI;component/icons/resources/resource_wood_icon.png",  tooltipTitle = Loc_FormatText("$11164968", Player_GetDisplayName(player)) },
			{ key = "gold",   resourceType = RT_Gold,  resourceIcon = "pack://application:,,,/WPFGUI;component/icons/resources/resource_gold_icon.png",  tooltipTitle = Loc_FormatText("$11164969", Player_GetDisplayName(player)) },
			{ key = "stone",  resourceType = RT_Stone, resourceIcon = "pack://application:,,,/WPFGUI;component/icons/resources/resource_stone_icon.png", tooltipTitle = Loc_FormatText("$11164970", Player_GetDisplayName(player)) },
		},
	}
	
	for index, resource in ipairs(playerData.resources) do
		
		resource.increaseTributeCommand = _t_campaignPanel.commands.increaseTribute  
		resource.decreaseTributeCommand = _t_campaignPanel.commands.decreaseTribute
		
		local playerIndex = World_GetPlayerIndex(player)
		local resourceType = resource.resourceType
		resource.commandParameter = playerIndex..","..resourceType
		
		resource.amount = 0
		
		if Game_GetLocalPlayer() == player then 
			resource.isVisible = false 
		elseif resource.resourceType == RT_Stone and Player_GetRace(player) == RACE.MONGOL then 
			resource.isEnabled = false 
			resource.blockedReason = Loc_GetString("$11165018")		-- Requirement: Not Mongol
		elseif Table_Contains(allowedResourceTypes, resource.resourceType) == false then
			resource.isEnabled = false 
			resource.blockedReason = Loc_Empty()
		else
			resource.isEnabled = true
		end
		
	end
	
	return playerData 
	
end




-- callback to increase tribute
function _TributePanel_IncreaseTribute_ButtonCallback(commandParameter)		-- UI button callbacks are LOCAL ONLY, but this doesn't alter the sim (it only adjusts the local UI) so it is okay
	
	-- the incoming "commandParameter" is in the format "1,3" where the first number is the player index and the second number is the resource type
	-- (resource types, such as RT_Wood, are just consts for number indexes)
	
	local parameters = string.split(commandParameter)
	local playerIndex = tonumber(parameters[1])
	local resourceType = tonumber(parameters[2])
	local taxRate = _t_campaignPanel.uiData.tributePanel.taxRate
	
	for index, player in ipairs(_t_campaignPanel.uiData.tributePanel.players) do 
		if player.playerIndex == playerIndex then 
			for index, resource in pairs(player.resources) do
				if resource.resourceType == resourceType then 
					
					local newAmount = resource.amount + 100

					if newAmount > 9999 then 
						newAmount = 9999 
					end
					
					local newAmountWithTax = newAmount
					if taxRate ~= nil then 
						newAmountWithTax = newAmount * (1 + (taxRate / 100))
					end
					
					if Player_GetResource(Game_GetLocalPlayer(), resourceType) < newAmountWithTax then
						return 
					end
						
					resource.amount = newAmount
					
				end
			end
		end
	end

	_TributePanel_UpdateTotals()
	
	_CampaignPanel_SetDirty()
	
end

-- callback to decrease tribute
function _TributePanel_DecreaseTribute_ButtonCallback(commandParameter)		-- UI button callbacks are LOCAL ONLY, but this doesn't alter the sim (it only adjusts the local UI) so it is okay
	
	-- the incoming "commandParameter" is in the format "1,3" where the first number is the player index and the second number is the resource type
	-- (resource types, such as RT_Wood, are just consts for number indexes)
	
	local parameters = string.split(commandParameter)
	local playerIndex = tonumber(parameters[1])
	local resourceType = tonumber(parameters[2])
	
	for index, player in ipairs(_t_campaignPanel.uiData.tributePanel.players) do 
		if player.playerIndex == playerIndex then 
			for index, resource in pairs(player.resources) do
				if resource.resourceType == resourceType then 
					resource.amount = resource.amount - 100
					if resource.amount < 0 then 
						resource.amount = 0 
					end
				end
			end
		end
	end

	_TributePanel_UpdateTotals()
	
	_CampaignPanel_SetDirty()
	
end

-- update total resource amounts and tax rates, etc
function _TributePanel_UpdateTotals()
	
	local totalAmount = 0
		
	for index, player in pairs(_t_campaignPanel.uiData.tributePanel.players) do
		for index, resource in ipairs(player.resources) do 
			totalAmount = totalAmount + resource.amount
		end
	end
	
	_t_campaignPanel.uiData.tributePanel.totalAmount = totalAmount
	
	-- calculate tax if necessary
	if _t_campaignPanel.uiData.tributePanel.taxRate ~= nil then 
		_t_campaignPanel.uiData.tributePanel.totalTax = math.floor(_t_campaignPanel.uiData.tributePanel.totalAmount * (_t_campaignPanel.uiData.tributePanel.taxRate / 100))
		_t_campaignPanel.uiData.tributePanel.totalAmountWithTax = _t_campaignPanel.uiData.tributePanel.totalAmount + _t_campaignPanel.uiData.tributePanel.totalTax
	end
	
end



function _TributePanel_Send_ButtonCallback()		-- UI button callbacks are LOCAL ONLY, so need to route anything that is sim-altering across the network

	-- double-check to see if the player has enough resources to send tribute
	local totalAmount = {food = 0, wood = 0, gold = 0, stone = 0}
	
	for index, player in ipairs(_t_campaignPanel.uiData.tributePanel.players) do 
		for index, resource in ipairs(player.resources) do
			totalAmount[resource.key] = totalAmount[resource.key] + resource.amount 
		end
	end
	
	local taxRate = _t_campaignPanel.uiData.tributePanel.taxRate
	if taxRate ~= nil then
		totalAmount.food  = totalAmount.food  * (1 + (taxRate/100))
		totalAmount.wood  = totalAmount.wood  * (1 + (taxRate/100))
		totalAmount.gold  = totalAmount.gold  * (1 + (taxRate/100))
		totalAmount.stone = totalAmount.stone * (1 + (taxRate/100))
	end
	
	local sendingPlayer = Game_GetLocalPlayer()
	if Player_GetResource(sendingPlayer, RT_Food) < totalAmount.food or Player_GetResource(sendingPlayer, RT_Wood) < totalAmount.wood or 
		Player_GetResource(sendingPlayer, RT_Gold) < totalAmount.gold or Player_GetResource(sendingPlayer, RT_Stone) < totalAmount.stone then
		
		return 	-- player doesn't have enough resources, let's bail out of this send routine 
		
	end
		
	
	-- create a message detailing the tribute and broadcast it (so we're back in the land of determinism) - see below for details of the message format
	local message = ""
																															   --
	for index, player in ipairs(_t_campaignPanel.uiData.tributePanel.players) do 											   --
																															   --
		local taxRate = _t_campaignPanel.uiData.tributePanel.taxRate or 0													   --
																															   --
		-- arrange resources by key, instead of the arbitrarily-ordered array of resources in the UI data					   --
		local tribute = {}																									   --
		for index, resource in ipairs(player.resources) do																	   --
			tribute[resource.key] = resource.amount 																		   --
		end																													   --
																															   --
		-- append this info to the message																					   --
		if message ~= "" then 				-- add a seperator between players if this isn't the first one					   --
			message = message .. "|"																						   --
		end																													   --
																															   --
		message = message .. player.playerIndex ..",".. tribute.food ..",".. tribute.wood ..","..							   --
														 tribute.gold ..",".. tribute.stone ..",".. taxRate					   --
																															   --
	end																														   --
																															   --
	-- broadcast the message																								   --
	Network_CallEvent("_TributePanel_Send_ReceieveNetworkMessage", message)													   --
																															   --
	-- reset the tribute UI																									   --
	_TributePanel_Clear_ButtonCallback()																					   --
																															   --
end																															   --
																															   --
																															   --
-- the corresponding function to catch the network messages when sending tribute											   --
function _TributePanel_Send_ReceieveNetworkMessage(sendingPlayer, message)													   --
																															   --
	--[[																													   --
																												   -		   --
		Network Message format:                                                                     			 ---		  --
	                                                                                             		   	   ---------------
		"2,0,0,100,0,0|3,100,0,0,0,0|4,0,100,0,0,0"   <-- Example message                           			 ---
	                                                                                                			   -
		- message can consist of multiple player-to-player tributes, each seperated with a "|"      	  
		- each of these tributes is a comma-seperated string in the format "receivingPlayerIndex,foodAmount,woodAmount,goldAmount,stoneAmount,taxRate"
	 	- the sending player is the one who broadcast the message (which comes in as the sendingPlayer parameter) so is not part of the message
	 	
	]]

	local tributeData = {}
	
	-- unpack message into a more manageable data structure
	local playerTributes = string.split(message, "|")						-- message can consist of multiple player-to-player tributes, each seperated with a "|"
	
	for index, playerTribute in ipairs(playerTributes) do 
		local parts = string.split(playerTribute)							-- each of these tributes is a comma-seperated string in the format "receivingPlayerIndex,foodAmount,woodAmount,goldAmount,stoneAmount,taxRate"
		local tribute = {
			sendingPlayer = sendingPlayer,
			receivingPlayer = World_GetPlayerAt(parts[1]),
			food = tonumber(parts[2]),
			wood = tonumber(parts[3]),
			gold = tonumber(parts[4]),
			stone = tonumber(parts[5]),
			taxRate = tonumber(parts[6]),
		}	
		table.insert(tributeData, tribute)
	end

	-- transfer resources between players, according to this data structure
	for index, tribute in ipairs(tributeData) do 		

		local sendingPlayer = tribute.sendingPlayer
		local receivingPlayer = tribute.receivingPlayer

		_TributePanel_TransferResources(sendingPlayer, receivingPlayer, RT_Food,  tribute.food,  tribute.taxRate)
		_TributePanel_TransferResources(sendingPlayer, receivingPlayer, RT_Wood,  tribute.wood,  tribute.taxRate)
		_TributePanel_TransferResources(sendingPlayer, receivingPlayer, RT_Gold,  tribute.gold,  tribute.taxRate)
		_TributePanel_TransferResources(sendingPlayer, receivingPlayer, RT_Stone, tribute.stone, tribute.taxRate)
		
		-- if any resources at all were sent to this player...
		if tribute.food > 0 or tribute.wood > 0 or tribute.gold > 0 or tribute.stone > 0 then 
			
			-- activate callback
			if scartype(_t_campaignPanel.tributePanelCallback) == ST_FUNCTION then 
				_t_campaignPanel.tributePanelCallback(sendingPlayer, receivingPlayer, tribute)
			end
			
			-- show event cues for sender and receiver 
			if Game_GetLocalPlayer() == sendingPlayer then 
			
				-- Sender gets a message that tribute was sent
				_TributePanel_ShowEventCue(Loc_FormatText("$11164677", Player_GetDisplayName(receivingPlayer)))						-- "Tribute sent to %1PLAYER_NAME%"
				
			elseif Game_GetLocalPlayer() == receivingPlayer then 
				
				-- Receiver gets details of what was sent to them, and by whom
				if tribute.food > 0 then 
					_TributePanel_ShowEventCue(Loc_FormatText("$11161258", tribute.food, Player_GetDisplayName(sendingPlayer)))		-- "%1AMOUNT% food received from %2PLAYER_NAME%"
				end
				if tribute.wood > 0 then 
					_TributePanel_ShowEventCue(Loc_FormatText("$11161259", tribute.wood, Player_GetDisplayName(sendingPlayer)))		-- "%1AMOUNT% wood received from %2PLAYER_NAME%"
				end
				if tribute.gold > 0 then 
					_TributePanel_ShowEventCue(Loc_FormatText("$11161261", tribute.gold, Player_GetDisplayName(sendingPlayer)))		-- "%1AMOUNT% gold received from %2PLAYER_NAME%"
				end					
				if tribute.stone > 0 then 
					_TributePanel_ShowEventCue(Loc_FormatText("$11161260", tribute.stone, Player_GetDisplayName(sendingPlayer)))	-- "%1AMOUNT% stone received from %2PLAYER_NAME%"
				end
				
			end
			
		end
		
	end
	
end


-- clear any values in the buttons in the tribute panel
function _TributePanel_Clear_ButtonCallback()		-- UI button callbacks are LOCAL ONLY, but this doesn't alter the sim (it only adjusts the local UI) so it is okay
	
	for index, player in ipairs(_t_campaignPanel.uiData.tributePanel.players) do 
		for index, resource in pairs(player.resources) do
			resource.amount = 0 
		end
	end

	_TributePanel_UpdateTotals()
	
	_CampaignPanel_SetDirty()
	
end


-- actually add and remove the resources from the relevant players as necessary (including calculating tax)
function _TributePanel_TransferResources(sendingPlayer, receivingPlayer, resourceType, amount, taxRate)

	if amount > 0 then 

		local amountWithTax = amount
		if taxRate ~= nil and taxRate ~= 0 then 
			amountWithTax = math.floor(amount * (1 + (taxRate / 100)))
		end

		Player_AddResource(sendingPlayer, resourceType, -amountWithTax)
		Player_AddResource(receivingPlayer, resourceType, amount)

	end
	
end


-- show an event cue in the default style
function _TributePanel_ShowEventCue(message)
	
	local lifetime = 10.0	
	local sfx = "sfx_ui_tribute_received_play"
	local icon = ""
	local color = {r = 255, g = 255, b = 255, a = 255}
	local template = "low_priority"
	local style = ECV_Queue
	
	UI_CreateEventCueClickable(-1, lifetime, 0, 0, message, 0, template, icon, sfx, color.r, color.g, color.b, color.a, style, nothing)	
	
end




--
--
-- REINFORCEMENT panel
--
--


--? @shortdesc Create a reinforcement panel. It will be disabled to start, so you'll need to call ReinforcementPanel_Enable() for it to appear.
--? @extdesc Callback function will receive the parameters (player, id) with the id of the item selected
--? @args Function callbackFunction
function ReinforcementPanel_Init(callbackFunction)

	 CampaignPanel_Init()		-- initialize the system (if it hasn't been initialized already)
	
	-- set the user callback (buttons are actually hooked up to this system's callback function, but that will in turn call the user one)
	_t_campaignPanel.reinforcementPanelCallback = callbackFunction
	
end


--? @shortdesc Create a reinforcement panel. It will be disabled to start, so you'll need to call ReinforcementPanel_Enable() for it to appear.
--? @args PlayerID/Table owner, Table panelData
function ReinforcementPanel_Create(owner, panelData)
	
	if _CampaignPanel_IsLocalPlayer(owner) then 

		-- set our internal data to a copy of the data passed in
		_t_campaignPanel.uiData.reinforcementPanel = Clone(panelData)
		_CampaignPanel_LocalizeAllStrings(_t_campaignPanel.uiData.reinforcementPanel)	
		
		
		-- merge in some extra data fields required by the UI potion to function
		local panelExtras = {																				-- merge in some extra values in the main table (values for representing state, commands, etc)
			title = REQUIRED_DATA,		-- triggers an error if there's no title specified	
			items = {},
			toggleCommand = _t_campaignPanel.commands.togglePanel,		
		}
		Table_FillWithDefaultValues(_t_campaignPanel.uiData.reinforcementPanel, panelExtras, "ReinforcementPanel_Create")
		
		for index, item in ipairs(_t_campaignPanel.uiData.reinforcementPanel.items) do 						-- merge in some extra values for each item in the list (commands, etc)
			
			local itemExtras = {
				id = REQUIRED_DATA,		-- triggers an error if there's no id specified	
				title = REQUIRED_DATA,	-- triggers an error if there's no title specified	
				button = REQUIRED_DATA,	-- triggers an error if there's no button specified	
				buttonCommand = _t_campaignPanel.commands.buyItem,
				sortIndex = 1000 + index,
			}
			Table_FillWithDefaultValues(item, itemExtras, "ReinforcementPanel_Create - Item "..index)		
			
			if scartype(item.id) == ST_LOCSTRING or (scartype(item.id) == ST_STRING and string.sub(item.id, 1, 1) == "$") then 
				fatal("ReinforcementPanel_Create: Item's id was a LocString, where it needs to be a plain Lua string")
			elseif (scartype(item.id) == ST_STRING and string.find(item.id, "|") ~= nil) then 
				fatal("ReinforcementPanel_Create: Item's id contains a | character. You cannot use that character in an item's id string")
			end
			
		end
		
		_ReinforcementPanel_SortItems()

		_CampaignPanel_SetDirty()
		
	end
	
end


--? @shortdesc Enable the Reinforcement Panel and make it visible. This is different to opening the panel, for which you should use ReinforcementPanel_Open() 
--? @args PlayerID/Table owner
function ReinforcementPanel_Enable(owner)
	
	if _CampaignPanel_IsLocalPlayer(owner) then 

		local state = _t_campaignPanel.uiData.state
		
		state.reinforcementPanelEnabled = true
		state.enabled = true
		
		_CampaignPanel_SetToggleButtonTooltip()	
		_CampaignPanel_SetDirty()
		
		if Rule_Exists(_CampaignPanel_Manager) == false then  
			Rule_Add(_CampaignPanel_Manager)
		end
		
	end
	
end


--? @shortdesc Disable the Reinforcement Panel and make it disappear completely. This is different to closing the panel, for which you should use ReinforcementPanel_Close()
--? @args PlayerID/Table owner
function ReinforcementPanel_Disable(owner)

	if _CampaignPanel_IsLocalPlayer(owner) then 
		
		local state = _t_campaignPanel.uiData.state
		
		state.reinforcementPanelEnabled = false 
		state.enabled = state.tributePanelEnabled or state.reinforcementPanelEnabled 	
		
		if state.enabled == false then 
			state.open = false 							-- set the panel to closed if it was open
		end
		
		_CampaignPanel_SetToggleButtonTooltip()
		_CampaignPanel_SetDirty(true)					-- force an update now (as we're removing the updater rule)
		
		if state.enabled == false and Rule_Exists(_CampaignPanel_Manager) == true then  
			Rule_Remove(_CampaignPanel_Manager)
		end
		
	end
	
end


--? @shortdesc Return whether the Reinforcement Panel is currently enabled or not.
--? @result Boolean
function ReinforcementPanel_IsEnabled()
	
	local state = _t_campaignPanel.uiData.state
	
	return state.reinforcementPanelEnabled
	
end


--? @shortdesc Force open the Reinforcement Panel.
--? @args PlayerID/Table owner
function ReinforcementPanel_Open(owner)
	
	if _CampaignPanel_IsLocalPlayer(owner) then 

		local state = _t_campaignPanel.uiData.state
		
		if state.reinforcementPanelEnabled == true then 
			_CampaignPanel_SetValue(state, "open", true)
		end

	end

end


--? @shortdesc Force close the Reinforcement Panel.
--? @args PlayerID/Table owner
function ReinforcementPanel_Close(owner)

	if _CampaignPanel_IsLocalPlayer(owner) then 

		local state = _t_campaignPanel.uiData.state
		
		if state.reinforcementPanelEnabled == true then 
			_CampaignPanel_SetValue(state, "open", false)
		end
		
	end
	
end


--? @shortdesc Return whether the Reinforcement Panel is currently open or not.
--? @result Boolean
function ReinforcementPanel_IsOpen()

	local state = _t_campaignPanel.uiData.state
	
	if state.reinforcementPanelEnabled == false then
		return false
	else
		return state.open
	end

end


--? @shortdesc Add a new item to the Reinforcement Panel.  
--? @args PlayerID/Table owner, Table newItem
function ReinforcementPanel_AddItem(owner, newItem)
	
	if _CampaignPanel_IsLocalPlayer(owner) then 

		local item = Clone(newItem)
		
		local itemDefaults = {
			id = REQUIRED_DATA,		-- triggers an error if there's no id specified	
			title = REQUIRED_DATA,	-- triggers an error if there's no title specified	
			button = REQUIRED_DATA,	-- triggers an error if there's no button specified	
			buttonCommand = _t_campaignPanel.buttonCommand,
			sortIndex = 1000 + #_t_campaignPanel.uiData.items + 1,
		}
		Table_FillWithDefaultValues(item, itemDefaults, "ReinforcementPanel_AddItem")		
		
		if scartype(item.id) == ST_LOCSTRING or (scartype(item.id) == ST_STRING and string.sub(item.id, 1, 1) == "$") then 
			fatal("ReinforcementPanel_AddItem: Item's id was a LocString, where it needs to be a plain Lua string")
		elseif (scartype(item.id) == ST_STRING and string.find(item.id, "|") ~= nil) then 
			fatal("ReinforcementPanel_AddItem: Item's id contains a | character. You cannot use that character in an item's id string")
		end
		
		_CampaignPanel_LocalizeAllStrings(item)	
		
		table.insert(_t_campaignPanel.uiData.reinforcementPanel.items, item)
		
		_ReinforcementPanel_SortItems()
		
		_CampaignPanel_SetDirty()	
		
	end
	
end


--? @shortdesc Remove an existing item from the Reinforcement Panel.  
--? @args PlayerID/Table owner, String id
function ReinforcementPanel_RemoveItem(owner, id)

	if _CampaignPanel_IsLocalPlayer(owner) then 

		for index = #_t_campaignPanel.uiData.items, 1, -1 do
			local item = _t_campaignPanel.uiData.items[index]
			if item.id == id then 
				table.remove(_t_campaignPanel.uiData.reinforcementPanel.items, index)
			end
		end
		
		_CampaignPanel_SetDirty()
		
	end
	
end


--? @shortdesc Update the Reinforcement Panel with new data 
--? @extdesc The updateData table has the same syntax as the panelData, but should just contain the elements you want to update. Keys you want to remove entirely should be set to the const REMOVE_DATA (because you can't set a table entry value to nil). You should use ReinforcementPanel_UpdateItem() to update an item's data, rather than this function. 
--? @args PlayerID/Table owner, Table updateData
function ReinforcementPanel_Update(owner, updateData)
	
	if _CampaignPanel_IsLocalPlayer(owner) then 

		_CampaignPanel_LocalizeAllStrings(updateData)	
		_ReinforcementPanel_ApplyUpdates(_t_campaignPanel.uiData.reinforcementPanel, updateData)
		
		_CampaignPanel_SetDirty()
		
	end
	
end


--? @shortdesc Update an existing item in the Reinforcement Panel with new data 
--? @extdesc The updateData table has the same syntax as an item, but should just contain the elements you want to update. Keys you want to remove entirely should be set to the const REMOVE_DATA (because you can't set a table entry value to nil)
--? @args PlayerID/Table owner, String id, Table updateData
function ReinforcementPanel_UpdateItem(owner, id, updateData)
	
	if _CampaignPanel_IsLocalPlayer(owner) then 

		_CampaignPanel_LocalizeAllStrings(updateData)	
		
		for index, item in pairs(_t_campaignPanel.reinforcementPanel.uiData.items) do
			if item.id == id then 
				_ReinforcementPanel_ApplyUpdates(item, updateData)
			end
		end
		
		_ReinforcementPanel_SortItems()
		
		_CampaignPanel_SetDirty()
		
	end
	
end



function _ReinforcementPanel_ApplyUpdates(oldData, newData)
	for index, value in pairs(newData) do
		if scartype(value) == ST_TABLE then 
			_ReinforcementPanel_ApplyUpdates(oldData[index], value)
		elseif value == REMOVE_DATA then 
			oldData[index] = nil
		else
			oldData[index] = value
		end
	end
end


--? @shortdesc Specify an item's id to disable that item, and optionally provide a reason to display to the user.
--? @args PlayerID/Table owner, String id[, LocString reason]
function ReinforcementPanel_DisableItem(owner, id, reason)

	if _CampaignPanel_IsLocalPlayer(owner) then 

		for index, item in ipairs(_t_campaignPanel.uiData.reinforcementPanel.items) do
			if item.id == id then 
				item.buttonDisabled = true 
				item.buttonDisabledManually = true
				if reason ~= nil then 
					item.buttonDisabledReason = Loc_GetString(reason)
				else
					item.buttonDisabledReason = Loc_GetString("$2933") -- "Disabled"
				end
			end
		end
		
		_CampaignPanel_SetDirty()
		
	end
	
end

--? @shortdesc Specify an item's id to enable that item and remove any blocks added with ReinforcementPanel_DisableItem(). Note that resource cost and popcap checking still applies.
--? @args PlayerID/Table owner, String id 
function ReinforcementPanel_EnableItem(owner, id)
	
	if _CampaignPanel_IsLocalPlayer(owner) then 

		for index, item in ipairs(_t_campaignPanel.uiData.reinforcementPanel.items) do
			if item.id == id then 
				
				item.buttonDisabledManually = nil
				item.buttonDisabledReason = nil
				
				-- we leave the buttonDisabled flag as it is - this will get recalculated in the UpdateUI function by checking associated resource costs and popcap room
				
			end
		end
		
		_CampaignPanel_SetDirty()
		
	end
	
end


--? @shortdesc Specify a custom sort function to sort items in the reinforcement panel. The function takes two items as parameters (a and b) and returns true if they are in the correct order, a coming before b.
--? @extdesc The default sort function is _ReinforcementPanel_DefaultSortFunction(a, b) in reinforcementpanel.scar
--? @args PlayerID/Table owner, Function sortFunc
function ReinforcementPanel_SetSortFunction(owner, newSortFunction)
	
	if _CampaignPanel_IsLocalPlayer(owner) then 

		_t_campaignPanel.reinforcementPanelSortFunction = newSortFunction
		
		_ReinforcementPanel_SortItems()
		_CampaignPanel_SetDirty()

	end
	
end


-- trigger a re-sort on the items in the panel's items table
function _ReinforcementPanel_SortItems()
	
	table.sort(_t_campaignPanel.uiData.reinforcementPanel.items, _t_campaignPanel.reinforcementPanelSortFunction)
	
end


-- this is the standard sort function, which is hooked up by default
function _ReinforcementPanel_DefaultSortFunction(a, b)
	
	if a.sortIndex ~= nil and b.sortIndex ~= nil then
		return a.sortIndex < b.sortIndex
	elseif a.sortIndex ~= nil and b.sortIndex == nil then 
		return true 		-- second item has no sortIndex, so item A comes first
	else
		return nil 
	end

end









function _ReinforcementPanel_BuyItem_ButtonCallback(id)		-- UI button callbacks are LOCAL ONLY, so need to route anything that is sim-altering across the network
	
	local localPlayer = Game_GetLocalPlayer()
	
	for index, item in ipairs(_t_campaignPanel.uiData.reinforcementPanel.items) do 
		
		if item.id == id then 
			
			-- double check player has enough resources to cover costs
			if scartype(item.cost) == ST_TABLE then 
				if (item.cost.food ~= nil and Player_GetResource(localPlayer, RT_Food) < item.cost.food) or
					(item.cost.wood ~= nil and Player_GetResource(localPlayer, RT_Wood) < item.cost.wood) or
					(item.cost.gold ~= nil and Player_GetResource(localPlayer, RT_Gold) < item.cost.gold) or
					(item.cost.stone ~= nil and Player_GetResource(localPlayer, RT_Stone) < item.cost.stone) or
					(item.cost.population ~= nil and (Player_GetCurrentPopulationCap(localPlayer, CT_Personnel) - Player_GetCurrentPopulation(localPlayer, CT_Personnel)) < item.cost.population) then					
					
					return 
					
				end
			end
			
			-- create a message detailing the item brought and broadcast it (so we're back in the land of determinism) - see below for details of the message format
			local cost = {food = 0, wood = 0, gold = 0, stone = 0}
			if scartype(item.cost) == ST_TABLE then 																						--
				if item.cost.food ~= nil then cost.food = item.cost.food end 																--
				if item.cost.wood ~= nil then cost.wood = item.cost.wood end 																--
				if item.cost.gold ~= nil then cost.gold = item.cost.gold end 																--
				if item.cost.stone ~= nil then cost.stone = item.cost.stone end
				if item.cost.population ~= nil then cost.population = item.cost.population end
			end 																															--
																																			--
			local message = id .."|".. cost.food ..",".. cost.wood ..",".. cost.gold ..",".. cost.stone	..",".. cost.population									--
																																			--
			-- broadcast the message
			Network_CallEvent("_ReinforcementPanel_BuyItem_ReceieveNetworkMessage", message)												--
																																			--
		end																																	--
																																			--
	end																																		--
																																			--
																																			--
end																																			--
																																			--
																																			--
-- the corresponding function to catch the network messages when buying items																--
function _ReinforcementPanel_BuyItem_ReceieveNetworkMessage(sendingPlayer, message)															--
																																			--
	--[[																																	--
																															    -			--
		Network Message format:																								  ---		   --
	 																														---------------
		"itemID|200,0,100,0"   <-- Example message																			  ---
	 																														    -
		- message has two parts, seperated with a "|"																		  
		- first part is the item ID that was purchased
		- second part is the cost of the item, comma-seperated, in the format "foodAmount,woodAmount,goldAmount,stoneAmount"
	 
	]]


	-- unpack message into a more manageable data structure
	local elements = string.split(message, "|")								-- message has two parts, seperated with a "|"
	local id = elements[1]													-- first part is the item ID that was purchased
	local costArray = string.split(elements[2])								-- second part is the cost of the item, comma-seperated, in the format "foodAmount,woodAmount,goldAmount,stoneAmount"
	local cost = {
		food  = tonumber(costArray[1]),
		wood  = tonumber(costArray[2]),
		gold  = tonumber(costArray[3]),
		stone = tonumber(costArray[4]),
		population = tonumber(costArray[5]),
	}
	
	
	-- check resources again
	local popSpace = Player_GetCurrentPopulationCap(sendingPlayer, CT_Personnel) - Player_GetCurrentPopulation(sendingPlayer, CT_Personnel)
	
	if Player_GetResource(sendingPlayer, RT_Food) < cost.food or
	   Player_GetResource(sendingPlayer, RT_Wood) < cost.wood or
	   Player_GetResource(sendingPlayer, RT_Gold) < cost.gold or
	   Player_GetResource(sendingPlayer, RT_Stone) < cost.stone or
	   popSpace < cost.population then
		 return
	end
	
	-- call the callback
	local callbackResult
	if scartype(_t_campaignPanel.reinforcementPanelCallback) == ST_FUNCTION then 
		callbackResult = _t_campaignPanel.reinforcementPanelCallback(sendingPlayer, id)
	end

	-- subtract costs
	if callbackResult ~= CAMPAIGNPANEL_CANCEL then 
	
		if cost.food ~= nil then Player_AddResource(sendingPlayer, RT_Food, -cost.food) end
		if cost.wood ~= nil then Player_AddResource(sendingPlayer, RT_Wood, -cost.wood) end
		if cost.gold ~= nil then Player_AddResource(sendingPlayer, RT_Gold, -cost.gold) end
		if cost.stone ~= nil then Player_AddResource(sendingPlayer, RT_Stone, -cost.stone) end
				
	end
			
			
	
end



--
--
-- SHARED script for campaign panel (the panel is one and the same, the different APIs enable and disable different parts of it)
--
--


-- does this update apply to the local player
function _CampaignPanel_IsLocalPlayer(player)
	
	if player == ALL then 
		return true 
	else
		
		local localPlayer = Game_GetLocalPlayer()
		
		if scartype(player) == ST_TABLE then 
			return Table_Contains(player, localPlayer)
		else
			return player == localPlayer 
		end
		
	end
end


-- toggle the panel open and closed (the UI's toggle button hooked up to this)
function _CampaignPanel_Toggle()
	local state = _t_campaignPanel.uiData.state
	if state.enabled == true then 
		state.open = not state.open
		_CampaignPanel_SetDirty(true)		-- force an update now for extra responsiveness to the toggle button
	end
end


-- set the title that appears in the tooltip of the toggle button
-- (it uses the reinforcement panel's title if that part is enabled, a fixed "Tribute" title otherwise)
function _CampaignPanel_SetToggleButtonTooltip()

	local uiData = _t_campaignPanel.uiData
	local state = uiData.state
	
	if state.tributePanelEnabled == true and state.reinforcementPanelEnabled == true then 
		uiData.toggleButtonTooltip = uiData.reinforcementPanel.title			
	elseif state.tributePanelEnabled == true and state.reinforcementPanelEnabled == false then
		uiData.toggleButtonTooltip = Loc_GetString("$11161242")		-- Players & Tribute			
	elseif state.tributePanelEnabled == false and state.reinforcementPanelEnabled == true then
		uiData.toggleButtonTooltip = uiData.reinforcementPanel.title			
	end
			
end


-- event callback for GE_UpgradeComplete
-- if this was a landmark / age upgrade, then we need to update player ages in the tribute panel
function _CampaignPanel_OnUpgradeComplete(context)

	if BP_IsUpgradeOfType(context.upgrade, "wonder_age_upgrade") then
		
		local tributePanel = _t_campaignPanel.uiData.tributePanel
		
		for index, player in ipairs(tributePanel.players) do	
			
			local playerID = World_GetPlayerAt(player.playerIndex)
			local age = Player_GetCurrentAge(playerID)
			
			player.age = age
			player.ageString = _t_campaignPanel.ageStrings[age]
			
		end		

		_CampaignPanel_SetDirty()
		
	end
	
end


-- event callback for GE_PlayerNameChanged
-- we need to update the names on the tribute panel
function _CampaignPanel_OnPlayerNameChanged(context)
	
	local tributePanel = _t_campaignPanel.uiData.tributePanel
	
	for index, player in ipairs(tributePanel.players) do	
		local playerID = World_GetPlayerAt(player.playerIndex)
		player.playerName = Loc_GetString(Player_GetDisplayName(playerID))
	end		
	
	_CampaignPanel_SetDirty()
	
end


-- callback when game is restored from a savegame
function _CampaignPanel_OnGameRestore()
	
	if _t_campaignPanel.uiCreated == true then
		
		_t_campaignPanel.uiCreated = false	-- coming in from a savegame - the UI won't have been saved so we need to clear this flag and then recreate the UI
		_CampaignPanel_CreateUI()
		_CampaignPanel_OnPlayerNameChanged()
		
	end
	
end


-- convert any string that looks like a LocString into localized text. The string can a ST_LOCSTRING (i.e. something spat out by any of the Loc functions) or a plain Lua string in the format "$xxxx".
function _CampaignPanel_LocalizeAllStrings(data)

	for index, value in pairs(data) do 
		
		if scartype(value) == ST_TABLE and value["__Value"] == nil then
			_CampaignPanel_LocalizeAllStrings(value)
		elseif scartype(value) == ST_LOCSTRING or (scartype(value) == ST_STRING and string.sub(value, 1, 1) == "$") then 
			data[index] = Loc_GetString(value)
		end
		
	end
	
end


-- write a value into the uiDataContext table and set the dirty flag if it actually changed vs the old value (this dirty flag will trigger a deferred push of this updated data table to the UI)
function _CampaignPanel_SetValue(table, key, newValue)
	
	local oldValue = table[key]
	
	if scartype(newValue) == ST_LOCSTRING and scartype(oldValue) == ST_LOCSTRING then 
		if oldValue.LocString ~= newValue.LocString then 
			table[key] = newValue
			_CampaignPanel_SetDirty()
		end
	elseif oldValue ~= newValue then 
		table[key] = newValue
		_CampaignPanel_SetDirty()
	end
	
end


-- mark the panel data as dirty (i.e. it has changed), and therefore needs to be pushed to the UI in order to refresh it
function _CampaignPanel_SetDirty(forceUpdateNow)
	
	_t_campaignPanel.dirty = true 
	
	if forceUpdateNow == true then 
		_CampaignPanel_UpdateDataContext()
	end
	
end


-- this function continuously runs and checks whether the costs (specifically the isSufficient flags) need to be updated
function _CampaignPanel_Manager()

	--
	-- Tribute panel updates
	--
	
	if _t_campaignPanel.uiData.state.tributePanelEnabled == true then 
		
		for index, entry in ipairs(_t_campaignPanel.uiData.tributePanel.players) do 
			
			local player = World_GetPlayerAt(entry.playerIndex)
			
			-- check player colour, see if that has changed			
			_CampaignPanel_SetValue(entry, "playerColor", UI_GetColourAsString(Player_GetUIColour(player)))
				
		end
		
	end
	
	
	--
	-- Reinforcement panel updates
	--
	
	if _t_campaignPanel.uiData.state.reinforcementPanelEnabled == true then 
		
		local localPlayer = Game_GetLocalPlayer()
		
		
		-- get the player's current resources and popcap related data
		local playerResources = {
			food = Player_GetResource(localPlayer, RT_Food),
			wood = Player_GetResource(localPlayer, RT_Wood),
			gold = Player_GetResource(localPlayer, RT_Gold),
			stone = Player_GetResource(localPlayer, RT_Stone),
		}
		
		local playerPopulation = {
			population = Player_GetCurrentPopulation(localPlayer, CT_Personnel),
			capacity = Player_GetCurrentPopulationCap(localPlayer, CT_Personnel),
		}
		playerPopulation.room = playerPopulation.capacity - playerPopulation.population
		
		
		-- go through the items and check their costs vs current resource levels
		for index, item in ipairs(_t_campaignPanel.uiData.reinforcementPanel.items) do
			
			if scartype(item.cost) == ST_TABLE then 
				
				-- check the costs of the item vs the player's resource levels, and set the isInsufficient flags accordingly
				if item.cost.food ~= nil then 
					_CampaignPanel_SetValue(item.cost, "food_isInsufficient", playerResources.food < item.cost.food) 
				end
				
				if item.cost.wood ~= nil then 
					_CampaignPanel_SetValue(item.cost, "wood_isInsufficient", playerResources.wood < item.cost.wood) 
				end
				
				if item.cost.gold ~= nil then 
					_CampaignPanel_SetValue(item.cost, "gold_isInsufficient", playerResources.gold < item.cost.gold) 
				end
				
				if item.cost.stone ~= nil then 
					_CampaignPanel_SetValue(item.cost, "stone_isInsufficient", playerResources.stone < item.cost.stone) 
				end
				
				if item.cost.population ~= nil then 
					_CampaignPanel_SetValue(item.cost, "population_isInsufficient", playerPopulation.room < item.cost.population) 
				end
				
				-- if the item isn't disabled via ReinforcementPanel_DisableItem(), manage the enabled/disabled status for costs and population
				if item.buttonDisabledManually ~= true then
					
					if item.cost.food_isInsufficient == true or item.cost.wood_isInsufficient == true or item.cost.gold_isInsufficient == true or item.cost.stone_isInsufficient == true then
						_CampaignPanel_SetValue(item, "buttonDisabledReason", Loc_GetString("$38077")) -- Not enough Resources
						_CampaignPanel_SetValue(item, "buttonDisabled", true)
					elseif item.cost.population_isInsufficient == true then
						_CampaignPanel_SetValue(item, "buttonDisabledReason", Loc_GetString("$11182639")) -- Not enough Population capacity
						_CampaignPanel_SetValue(item, "buttonDisabled", true)
					else
						_CampaignPanel_SetValue(item, "buttonDisabledReason", nil)
						_CampaignPanel_SetValue(item, "buttonDisabled", nil)
					end
					
				end
				
			end
			
		end
		
	end
	
	
	_CampaignPanel_UpdateDataContext()		-- this will only trigger a push of the data context if some data was changed (i.e. the data is falgged as "dirty")
	
end


-- actually push the data context to the UI
function _CampaignPanel_UpdateDataContext(force)

	if _t_campaignPanel.dirty == true or force == true then 
		
		UI_SetDataContext("DiplomacyUI", _t_campaignPanel.uiData)
		_t_campaignPanel.dirty = false
		
	end
	
end


-- create the XAML description of the UI and push it to the UI system
function _CampaignPanel_CreateUI()
	
	if _t_campaignPanel.uiCreated == false then 
		
		if UI_IsXboxUI() == true then
			--_CampaignPanel_CreateUI_Xbox()		-- commented out and replaced with PC until we actually add the Xbox version!
			_CampaignPanel_CreateUI_PC()
		else
			_CampaignPanel_CreateUI_PC()
		end
		
	end
	
end

		
function _CampaignPanel_CreateUI_PC()
			
	local Xaml =
[[<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:esControls="clr-namespace:WPFGUI.Shared.Controls;assembly=EngineUI"
      xmlns:esUtility="clr-namespace:WPFGUI.Shared.Utility;assembly=EngineUI"
	  xmlns:sharedConverters="clr-namespace:WPFGUI.Shared.Converters;assembly=EngineUI"
	  xmlns:utility="clr-namespace:WPFGUI.Shared.Utility;assembly=EngineUI"
	  Width="550"
	  Margin="0,10,13,0" HorizontalAlignment="Right"
	  VerticalAlignment="Top"
	  SnapsToDevicePixels="True"
	  Visibility="{Binding [state][enabled], Converter={StaticResource BoolToVis}}">
	<Grid.Resources>
		
		
		<!--  Tribute tooltip style  -->
		<Style x:Key="TributeToolTipStyle" TargetType="{x:Type ToolTip}">
			<Setter Property="HasDropShadow" Value="True" />
			<Setter Property="OverridesDefaultStyle" Value="True" />
			<Setter Property="SnapsToDevicePixels" Value="true" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="{x:Type ToolTip}">
						<ContentPresenter />
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
		
		
		<!-- Resource button style - a clone of HUDBaseButtonStyle but IsEnabled setter changes Opacity instead of Visibility of background -->
		<Style x:Key="DiplomacyResourceButtonStyle" TargetType="Button">
			<Setter Property="IsTabStop" Value="False" />
	        <Setter Property="SnapsToDevicePixels" Value="true" />
	        <Setter Property="OverridesDefaultStyle" Value="true" />
	        <Setter Property="HorizontalAlignment" Value="Left" />
	        <Setter Property="Width" Value="47" />
	        <Setter Property="Height" Value="47" />
			<Setter Property="esUtility:AudioAttachedProperty.PreviewMouseLeftButtonUpSound"
	                Value="sfx_ui_hud_inGame_button_play" />
	        <Setter Property="Template">
	            <Setter.Value>
	                <ControlTemplate TargetType="Button">
	                    <Border Name="ResourceButton">
	                        <Grid>
								<Border Background="{DynamicResource TertiaryColorLightBrush}">
									<Border>
										<Border.Background>
											<RadialGradientBrush Center="0.5,0" GradientOrigin="0.5,0" RadiusX="0.7" RadiusY="0.6">
										        <GradientStop Offset="0" Color="{DynamicResource TertiaryColorExtraLight}" />
										        <GradientStop Offset="1" Color="{DynamicResource TertiaryColorExtraLightTransparent}" />
										    </RadialGradientBrush>
										</Border.Background>
									</Border>
                                </Border>
								
	                            <Rectangle Name="Base" Fill="#33505050" />
	                            
								<Rectangle Name="Rollover" Fill="{StaticResource ButtonHighlightBrush}" Visibility="Collapsed" />
	                            
								<Rectangle Name="Highlight" Fill="#FF93BED7" Visibility="Collapsed" />
								
	                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
	                        </Grid>
	                    </Border>
	                    <ControlTemplate.Triggers>
	                        <Trigger Property="IsMouseOver" Value="true">
	                            <Setter TargetName="Rollover" Property="Visibility" Value="Visible" />
	                        </Trigger>
	                        <Trigger Property="IsPressed" Value="true">
	                            <Setter TargetName="Highlight" Property="Visibility" Value="Visible" />
	                        </Trigger>
	                        <Trigger Property="IsEnabled" Value="false">
								 <Setter TargetName="ResourceButton" Property="Opacity" Value="{StaticResource ButtonDisabledOpacity}" />
	                        </Trigger>
	                    </ControlTemplate.Triggers>
	                </ControlTemplate>
	            </Setter.Value>
	        </Setter>
	    </Style>
		
		
		<Style x:Key="DiplomacyHorizontalSeparatorStyle" TargetType="Rectangle">
            <Setter Property="Fill" Value="#616C8C"/>
            <Setter Property="Height" Value="1.2"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
		
		
		<Style x:Key="DiplomacyVerticalSeparatorStyle" TargetType="Rectangle">
            <Setter Property="Effect" Value="{StaticResource DiplomacyTextDropShadow}" />
            <Setter Property="Fill" Value="{DynamicResource Gray80Brush}" />
            <Setter Property="Margin" Value="8,0" />
            <Setter Property="Width" Value="1.2" />
        </Style>
		
		
	</Grid.Resources>
	
	<Grid.RowDefinitions>
		<RowDefinition Height="Auto" />
		<RowDefinition Height="Auto" />
	</Grid.RowDefinitions>
	
	
	
	<!--  Panel toggle button  -->
	<Button Grid.Row="0"
			Margin="0,0,0,2" HorizontalAlignment="Right"
			VerticalAlignment="Top" Panel.ZIndex="2"
			esControls:TagAdorner.AlignmentMode="Relative"
			esControls:TagAdorner.ArrowDataTemplate="{StaticResource hudPage:TagArrowDataTemplate}"
			esControls:TagAdorner.DataTemplate="{StaticResource TagDataTemplate}"
			esControls:TagAdorner.HorizontalAnchor="Left" esControls:TagAdorner.HorizontalPlacement="Left"
			esControls:TagAdorner.TargetDataTemplate="{StaticResource hudPage:EmptyTagDataTemplate}"
			esControls:TagAdorner.VerticalAnchor="Bottom" esControls:TagAdorner.VerticalPlacement="Bottom"
			Style="{StaticResource DiplomacyButtonStyle}"
			Command="{Binding [toggleCommand]}"
			ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="86400000"
			Visibility="{Binding [state][enabled], Converter={StaticResource BoolToVis}}">
		<Button.ToolTip>
			<ToolTip MaxWidth="300"
					 Placement="Bottom"
					 Style="{StaticResource TributeToolTipStyle}"
					 VerticalOffset="6"
					 Content="{Binding}"
					 DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}" >
				<ContentControl Style="{StaticResource HUDTooltipBorderStyle}">
					<TextBlock Style="{StaticResource HUDGray80BodyTextBlock14ptStyle}"
							   Text="{Binding [toggleButtonTooltip]}"
							   TextWrapping="Wrap" />
				</ContentControl>
			</ToolTip>
		</Button.ToolTip>
		<esControls:TagAdorner.IsTagged>
			<MultiBinding Converter="{StaticResource IsTaggedConverter}" ConverterParameter="DiplomacyButton">
				<Binding Path="TagVersion" Source="{x:Static model:HUDModel.Instance}" />
			</MultiBinding>
		</esControls:TagAdorner.IsTagged>
		<esControls:TagAdorner.Data>
			<MultiBinding Converter="{StaticResource TagDataConverter}" ConverterParameter="DiplomacyButton">
				<Binding Path="TagVersion" Source="{x:Static model:HUDModel.Instance}" />
			</MultiBinding>
		</esControls:TagAdorner.Data>
	</Button>

	
	<!--  Panel  -->
	<Grid Grid.Row="1"
		  Panel.ZIndex="1"
		  Visibility="{Binding [state][open], Converter={StaticResource BoolToVis}}">
		<ContentControl Template="{StaticResource CanvasTertiaryVerticalGradientBackgroundBox}">
			<ContentControl Template="{StaticResource TexturedTertiaryThickDoubleBorders}">
				<Grid Style="{StaticResource FlowControl}">
					
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />						<!--  Tribute panel  -->
						<RowDefinition Height="Auto" />						<!--  Reinforcement panel  -->
					</Grid.RowDefinitions>

					
					
					<!--  Tribute panel  -->
					<Grid Grid.Row="0" Style="{StaticResource FlowControl}"
						  Visibility="{Binding [state][tributePanelEnabled], Converter={StaticResource BoolToVis}}">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />				<!-- Header labels -->
							<RowDefinition Height="Auto" />				<!-- Seperator -->
							<RowDefinition Height="*" />				<!-- Player list -->
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
				
						<Grid Grid.Row="0" Margin="0,0,0,3">
				            <Grid.ColumnDefinitions>
				                <ColumnDefinition MaxWidth="315" />
				                <ColumnDefinition Width="200" />
				            </Grid.ColumnDefinitions>
							
							<!--  Header labels  -->
				            <esControls:Marquee Grid.Row="0" Grid.Column="0">
								<!-- "PLAYER" -->
				                <TextBlock Style="{StaticResource HUDPrimaryColorGradientVerticalSubtitleTextBlock14ptStyle}"
				                           Text="{esUtility:LocString $11164878}" /> 
				            </esControls:Marquee>
				
				            <Grid Grid.Row="0" Grid.Column="1">
				                <Grid.ColumnDefinitions>
				                    <ColumnDefinition Width="*" />
				                    <ColumnDefinition Width="Auto" />
				                    <ColumnDefinition Width="*" />
				                </Grid.ColumnDefinitions>
				
				                <esControls:Marquee Grid.Column="1" MarqueeType="Alternate" Speed="60">
									<!-- "TRIBUTE" -->
				                    <TextBlock HorizontalAlignment="Center"
				                               Style="{StaticResource HUDPrimaryColorGradientVerticalSubtitleTextBlock14ptStyle}"
				                               Text="{esUtility:LocString $11164880}" />
				                </esControls:Marquee>
				            </Grid>
						</Grid>
						
						<Rectangle Grid.Row="1"
				                   Style="{StaticResource DiplomacyHorizontalSeparatorStyle}" />
				
						<!-- Player list -->
						<ItemsControl Grid.Row="2" ItemsSource="{Binding [tributePanel][players]}" IsTabStop="False">
							<ItemsControl.ItemTemplate>
								<DataTemplate>								
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*" />
											<ColumnDefinition Width="200" />
										</Grid.ColumnDefinitions>
				                        <Grid.RowDefinitions>
				                            <RowDefinition Height="Auto" />
				                            <RowDefinition Height="Auto" />
				                        </Grid.RowDefinitions>
										
										<!-- Player name & details -->
										<Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,2,0,4">
											<Grid.RowDefinitions>
												<RowDefinition Height="Auto" />
												<RowDefinition Height="Auto" />
											</Grid.RowDefinitions>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="Auto" />
												<ColumnDefinition Width="Auto" />
												<ColumnDefinition Width="*" />
											</Grid.ColumnDefinitions>
											
											<TextBlock Grid.ColumnSpan="3" Margin="0,0,0,1"
				                                       Foreground="{Binding [playerColor]}"
				                                       Text="{Binding [playerName]}" >
												<TextBlock.Style>
													<Style BasedOn="{StaticResource HUDDiplomacyPlayerNameTextBlockStyle}" TargetType="TextBlock">
														<Style.Triggers>
															<DataTrigger Binding="{Binding [isEliminated]}" Value="true">
																<Setter Property="TextDecorations" Value="Strikethrough" />
															</DataTrigger>
														</Style.Triggers>
													</Style>
												</TextBlock.Style>
											</TextBlock>
				
				                            <Image Grid.Row="1" Grid.Column="0"
				                                   Height="14" Margin="0,0,3,0"
				                                   VerticalAlignment="Center"
				                                   Effect="{StaticResource DropShadowTextStyle}"
				                                   Source="{Binding [civIcon]}" />
				
				                            <Rectangle Grid.Row="1" Grid.Column="1"
				                                       Style="{StaticResource DiplomacyVerticalSeparatorStyle}" />
				
				                            <TextBlock Grid.Row="1" Grid.Column="2" Margin="2,0,0,0"
				                                       Style="{StaticResource HUDDiplomacyAgeSubTitleTextBlockStyle}"
				                                       Text="{Binding [ageString]}" HorizontalAlignment="Left"/>
										</Grid>
										
										
										<!-- Resource amount buttons -->
										<ItemsControl Grid.Column="1" IsTabStop="False"
													  VerticalAlignment="Center" HorizontalAlignment="Right"
													  ItemsSource="{Binding [resources]}" >
											<ItemsControl.ItemsPanel>
												<ItemsPanelTemplate>
													<esControls:SpacedStackPanel Orientation="Horizontal" Spacing="3" />
												</ItemsPanelTemplate>
											</ItemsControl.ItemsPanel>
											<ItemsControl.ItemTemplate>
												<DataTemplate>   
													
													<!-- Resource button -->
													<Button Command="{Binding [increaseTributeCommand]}"
															CommandParameter="{Binding [commandParameter]}"
															esControls:ButtonHelper.RightClickCommand="{Binding [decreaseTributeCommand]}"
															esControls:ButtonHelper.CommandParameter="{Binding [commandParameter]}"
															ToolTipService.InitialShowDelay="0"
				                                			ToolTipService.ShowDuration="86400000"
															ToolTipService.ShowOnDisabled="True"													
															IsEnabled="{Binding [isEnabled]}"						
															Visibility="{Binding [isVisible], Converter={StaticResource BoolToVis}}"						
															Style="{StaticResource DiplomacyResourceButtonStyle}">
														<Button.Content>
															<Grid>
																<Image Source="{Binding [resourceIcon]}" Width="32">
																	<Image.Effect>
																		<DropShadowEffect BlurRadius="6" Direction="-71.5"
													                                      Opacity="0.6" ShadowDepth="3"
													                                      Color="Black" />
																	</Image.Effect>
																	<Image.Style>
																		<Style>
															                <Style.Triggers>
																				<DataTrigger Binding="{Binding [isEnabled]}" Value="false">
															                    	<Setter Property="Image.Opacity" Value="0.44" />
															                    </DataTrigger>
															                 </Style.Triggers>
																		</Style>
																	</Image.Style>
																</Image>
													
				            									<!-- StringFormat=N0 not supported, so using CastToIntOperator converter instead. -->
																<TextBlock Text="{Binding [amount], Converter={StaticResource CastToIntOperator}}"
																		Visibility="{Binding [amount], Converter={StaticResource NumberToVis}}"
																		Style="{StaticResource HUDWhiteDiplomacyScoreTextBlockStyle}"
																		HorizontalAlignment="Center" />
															</Grid>
														</Button.Content>
														
														<!-- Tooltip -->
														<Button.ToolTip>
															<ToolTip Style="{StaticResource TributeToolTipStyle}" 
																	Placement="Left" 
																	Content="{Binding}" 
																	DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}" >
																<ToolTip.ContentTemplate>
																	<DataTemplate>
																		<ContentControl Style="{StaticResource HUDTooltipBorderStyle}" Width="{StaticResource HUDTooltipMaxWidthSmall}">
																			<Grid>
																				<Grid.ColumnDefinitions>
																					<ColumnDefinition Width="{StaticResource HUDTooltipGutterWidthGridLength}" />
																					<ColumnDefinition Width="*" />
																				</Grid.ColumnDefinitions>											
																				<StackPanel Orientation="Vertical" Grid.Column="1">
																					<!-- "Tribute" -->
																					<TextBlock Text="{esUtility:LocString $11164972}"
																							Style="{StaticResource HUDPrimaryColorLightTitleTextBlock18ptStyle}" />
																					<Grid HorizontalAlignment="Left">
																						<Border Background="{StaticResource ButtonBackgroundBrush}" Opacity="0.5" />
																						
																						<TextBlock Text="{esUtility:LocString $11164971}"
																								   Style="{StaticResource HUDWhiteBaseTextBlock14ptStyle}"
																								   TextWrapping="Wrap"
																								   Margin="6,2,7,2" />
																					</Grid>																			
																					<TextBlock Text="{Binding [tooltipTitle]}" 
																							Style="{StaticResource HUDGray80ParagraphTextBlock14ptStyle}" 
																							Margin="{StaticResource SmallMarginTop}" />
																					<TextBlock Text="{Binding [blockedReason]}" 
																							Style="{StaticResource HUDErrorColorLightParagraphTextBlock14ptStyle}" 
																							Margin="{StaticResource SmallMarginTop}"
																							Visibility="{Binding [blockedReason], Converter={StaticResource NotNullToVis}}"/>
																				</StackPanel>
																			</Grid>
																		</ContentControl>													
																	</DataTemplate>
																</ToolTip.ContentTemplate>
															</ToolTip>
														</Button.ToolTip>
													</Button>
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>
										
										<Rectangle Grid.Row="1" Grid.ColumnSpan="2"
												   Style="{StaticResource DiplomacyHorizontalSeparatorStyle}" />
									</Grid>
								</DataTemplate>
							</ItemsControl.ItemTemplate>		
						</ItemsControl>
						
						<!-- Total Resources and buttons -->
						<Grid Grid.Row="3" Margin="0,7,0,0">
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto" />
								<RowDefinition Height="Auto" />
							</Grid.RowDefinitions>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							
							<!-- Total resource -->
							<TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
									   Text="{Binding [tributePanel][totalAmount], Converter={StaticResource LocalizedStringConverter}, ConverterParameter=$11164616}"
									   Style="{StaticResource nHUDBodyTextBlockStyle}"
									   Visibility="{Binding [tributePanel][totalAmount], Converter={StaticResource GreaterCompare}, ConverterParameter=0, FallbackValue=Collapsed}"/>
							
							<!-- Tax -->
							<StackPanel Grid.Row="1" Grid.Column="0"
 									    Visibility="{Binding [tributePanel][totalAmount], Converter={StaticResource GreaterCompare}, ConverterParameter=0, FallbackValue=Collapsed}">
								<TextBlock Style="{StaticResource nHUDBodyTextBlockStyle}"
										   Visibility="{Binding [tributePanel][taxRate], Converter={StaticResource NotNullToVis}, FallbackValue=Collapsed}">
									<TextBlock.Text>
										<!-- "Tax (%1TAX_PERCENT:.0%%%): %2TAX_AMOUNT%" -->	
										<MultiBinding Converter="{StaticResource LocalizedStringMultiConverter}" ConverterParameter="$11164617">	
											<Binding Path="[tributePanel][taxRate]" />
											<Binding Path="[tributePanel][totalTax]" />
										</MultiBinding>
									</TextBlock.Text>
								</TextBlock>
							</StackPanel>
							
							<!-- Total cost -->
							<StackPanel Grid.Row="1" Grid.Column="1"
									    Visibility="{Binding [tributePanel][totalAmount], Converter={StaticResource GreaterCompare}, ConverterParameter=0, FallbackValue=Collapsed}">
									<TextBlock Style="{StaticResource nHUDBodyTextBlockStyle}"
									   Visibility="{Binding [tributePanel][taxRate], Converter={StaticResource NotNullToVis}, FallbackValue=Collapsed}"
									   Text="{Binding [tributePanel][totalAmountWithTax], Converter={StaticResource LocalizedStringConverter}, ConverterParameter=$11164618}"
									   HorizontalAlignment="Right"
									   Margin="5,0,12,0">
								</TextBlock>
							</StackPanel>
							
							<!-- Buttons -->			
							<StackPanel Grid.Row="0" Grid.Column="2" Grid.RowSpan="2" 
										Orientation="Horizontal" 
										HorizontalAlignment="Right" VerticalAlignment="Center">
							
								<!-- Send button -->
								<Button Content="{esUtility:LocString $11161243}"
										Command="{Binding [tributePanel][sendTributeCommand]}"
										Style="{StaticResource HUDPrimaryRaisedTextButton}"
										Margin="0,0,12,0" IsTabStop="False"
										IsEnabled="{Binding [tributePanel][totalAmount], Converter={StaticResource GreaterCompare}, ConverterParameter=0}"
										esUtility:AudioAttachedProperty.PreviewMouseLeftButtonUpSound="sfx_ui_hud_inGame_tribute_send_play" />

								<!-- Clear button -->
								<Button Content="{esUtility:LocString $11161244}" IsTabStop="False"
										Command="{Binding [tributePanel][clearTributeCommand]}"
										Style="{StaticResource HUDSecondaryRaisedTextButton}" 
										IsEnabled="{Binding [tributePanel][totalAmount], Converter={StaticResource GreaterCompare}, ConverterParameter=0}"
										esUtility:AudioAttachedProperty.PreviewMouseLeftButtonUpSound="sfx_ui_hud_inGame_tribute_clear_play" />
								
							</StackPanel>
						</Grid>
					</Grid>	
					
					
					
					<!--  Reinforcement panel  -->
					<Grid Grid.Row="1"
						  Visibility="{Binding [state][reinforcementPanelEnabled], Converter={StaticResource BoolToVis}}">
						<Grid.Style>
							<Style>
								<Style.Triggers>
									<DataTrigger Binding="{Binding [state][tributePanelEnabled]}" Value="True">
								       	<Setter Property="Margin" Value="0,20,0,0" /> <!-- Extra padding if both this and the tribute section above are enabled -->
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</Grid.Style>
						<Grid Style="{StaticResource FlowControl}">
							
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto" />						<!--  Header  -->
								<RowDefinition Height="Auto" />						<!--  Separator (for alignment)  -->
								<RowDefinition Height="*" />						<!--  Item List  -->
								<RowDefinition Height="Auto" />						<!--  Summation  -->
								<RowDefinition Height="Auto" />						<!--  Blurb  -->
							</Grid.RowDefinitions>
							
							<!--  Panel Title  -->
							<StackPanel Grid.Row="0" Margin="0,0,0,8">
								<TextBlock HorizontalAlignment="Center"
										   Style="{StaticResource HUDPrimaryColorGradientVerticalSubtitleTextBlock14ptStyle}"
										   Text="{Binding [reinforcementPanel][title]}" />
							</StackPanel>
							
							<Separator Grid.Row="1"
									   HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
									   Style="{StaticResource PrimarySeperatorStyle}" />
							
							<!--  Item List  -->
							<ItemsControl Grid.Row="2"
										  Margin="0,5"
										  ItemsSource="{Binding [reinforcementPanel][items]}"
										  Visibility="{Binding [reinforcementPanel][items], Converter={StaticResource NotNullToVis}, FallbackValue=Collapsed}">
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<StackPanel>
											<Grid Margin="0,10">
												<Grid.RowDefinitions>
													<RowDefinition Height="Auto" />
												</Grid.RowDefinitions>
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="*" />
													<ColumnDefinition Width="*" />
													<ColumnDefinition Width="Auto" />
												</Grid.ColumnDefinitions>
										
												<!--  Item: Title  -->
												<StackPanel Grid.Column="0" 
														VerticalAlignment="Center">
													<TextBlock Style="{StaticResource nHUDBaseTextBlockStyle}" 
															   Text="{Binding [title]}" />
												</StackPanel>
												
												<!--  Item: Subtitle  -->
												<StackPanel Grid.Column="1" 
														Margin="0,0,10,0"
														HorizontalAlignment="Right" 
														VerticalAlignment="Center"
														Visibility="{Binding [subtitle], Converter={StaticResource NotNullToVis}, FallbackValue=Collapsed}">
													<TextBlock ToolTipService.InitialShowDelay="0" esControls:TextBlockExtensions.AutoToolTip="True"
		                                                       ToolTipService.ShowDuration="86400000" TextTrimming="CharacterEllipsis" Style="{StaticResource nHUDBodyTextBlockStyle}" 
															   Text="{Binding [subtitle]}">												
		                                                <TextBlock.ToolTip>
		                                                    <ToolTip MaxWidth="{StaticResource HUDTooltipMaxWidthSmall}" Style="{StaticResource HUDBaseAutoTooltipStyle}" />
		                                                </TextBlock.ToolTip>
													</TextBlock>
												</StackPanel>
											
												<!--  Item: Buy Button  -->
												<StackPanel Grid.Column="2"
															HorizontalAlignment="Center" VerticalAlignment="Center">
													<Button Width="135"
															Height="30"
															HorizontalContentAlignment="Center"
															Command="{Binding [buttonCommand]}"
															CommandParameter="{Binding [id]}"
															Content="{Binding [button]}"
															IsEnabled="{Binding [buttonDisabled], Converter={StaticResource NullConverter}}"
															Style="{StaticResource HUDPrimaryRaisedTextButton}"
															ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="86400000"
															ToolTipService.ShowOnDisabled="True">
													
														<!--  Item: Buy Button Tooltip -->
														<Button.ToolTip>
															<ToolTip Content="{Binding}"
																	 DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
																	 Placement="Left"
																	 Style="{StaticResource TributeToolTipStyle}">
																<ToolTip.ContentTemplate>
																	<DataTemplate>
																		<ContentControl Width="{StaticResource HUDTooltipMaxWidthSmall}" Style="{StaticResource HUDTooltipBorderStyle}">
																			<Grid>
		
																				<Grid.ColumnDefinitions>
														                            <ColumnDefinition Width="Auto" />
														                            <ColumnDefinition Width="{StaticResource HUDTooltipGutterWidthGridLength}" />
														                            <ColumnDefinition Width="{StaticResource HUDTooltipContentColumnFixedWidth}" />
																				</Grid.ColumnDefinitions>
																				
																				<!--  First Column: Costs -->
																				<StackPanel Grid.Column="0" Margin="0,3" Orientation="Vertical">
																					
																					<!-- Food -->
											                                        <StackPanel Margin="{StaticResource ExtraSmallMarginBottom}" Orientation="Horizontal" Visibility="{Binding [cost][food], Converter={StaticResource NotNullToVis}, FallbackValue=Collapsed}">
											                                            <Image Width="26" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="UniformToFill">
											                                                <Image.Style>
											                                                    <Style BasedOn="{StaticResource {x:Type Image}}" TargetType="{x:Type Image}">
											                                                        <Setter Property="Source" Value="pack://application:,,,/WPFGUI;component/icons/resources/resource_food_icon.png" />
											                                                        <Style.Triggers>
											                                                            <DataTrigger Binding="{Binding [cost][food_isInsufficient]}" Value="True">
											                                                                <Setter Property="Source" Value="pack://application:,,,/WPFGUI;component/icons/resources/resource_food_icon_insufficient.png" />
											                                                            </DataTrigger>
											                                                        </Style.Triggers>
											                                                    </Style>
											                                                </Image.Style>
											                                            </Image>
		
											                                            <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="{Binding [cost][food], Converter={StaticResource CastToIntOperator}}">
											                                                <TextBlock.Style>
											                                                    <Style BasedOn="{StaticResource nHUDBaseHeavyTextBlockStyle}" TargetType="{x:Type TextBlock}">
											                                                        <Style.Triggers>
											                                                            <DataTrigger Binding="{Binding [cost][food_isInsufficient]}" Value="True">
											                                                                <Setter Property="Foreground" Value="{DynamicResource ErrorColorLightBrush}" />
											                                                            </DataTrigger>
											                                                        </Style.Triggers>
											                                                    </Style>
											                                                </TextBlock.Style>
											                                            </TextBlock>
											                                        </StackPanel>
																					
																					<!-- Wood -->
											                                        <StackPanel Margin="{StaticResource ExtraSmallMarginBottom}" Orientation="Horizontal" Visibility="{Binding [cost][wood], Converter={StaticResource NotNullToVis}, FallbackValue=Collapsed}">
											                                            <Image Width="26" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="UniformToFill">
											                                                <Image.Style>
											                                                    <Style BasedOn="{StaticResource {x:Type Image}}" TargetType="{x:Type Image}">
											                                                        <Setter Property="Source" Value="pack://application:,,,/WPFGUI;component/icons/resources/resource_wood_icon.png" />
											                                                        <Style.Triggers>
											                                                            <DataTrigger Binding="{Binding [cost][wood_isInsufficient]}" Value="True">
											                                                                <Setter Property="Source" Value="pack://application:,,,/WPFGUI;component/icons/resources/resource_wood_icon_insufficient.png" />
											                                                            </DataTrigger>
											                                                        </Style.Triggers>
											                                                    </Style>
											                                                </Image.Style>
											                                            </Image>
		
											                                            <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="{Binding [cost][wood], Converter={StaticResource CastToIntOperator}}">
											                                                <TextBlock.Style>
											                                                    <Style BasedOn="{StaticResource nHUDBaseHeavyTextBlockStyle}" TargetType="{x:Type TextBlock}">
											                                                        <Style.Triggers>
											                                                            <DataTrigger Binding="{Binding [cost][wood_isInsufficient]}" Value="True">
											                                                                <Setter Property="Foreground" Value="{DynamicResource ErrorColorLightBrush}" />
											                                                            </DataTrigger>
											                                                        </Style.Triggers>
											                                                    </Style>
											                                                </TextBlock.Style>
											                                            </TextBlock>
											                                        </StackPanel>
		
																					<!-- Gold -->
											                                        <StackPanel Margin="{StaticResource ExtraSmallMarginBottom}" Orientation="Horizontal" Visibility="{Binding [cost][gold], Converter={StaticResource NotNullToVis}, FallbackValue=Collapsed}" >
											                                            <Image Width="26" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="UniformToFill">
											                                                <Image.Style>
											                                                    <Style BasedOn="{StaticResource {x:Type Image}}" TargetType="{x:Type Image}">
											                                                        <Setter Property="Source" Value="pack://application:,,,/WPFGUI;component/icons/resources/resource_gold_icon.png" />
											                                                        <Style.Triggers>
											                                                            <DataTrigger Binding="{Binding [cost][gold_isInsufficient]}" Value="True">
											                                                                <Setter Property="Source" Value="pack://application:,,,/WPFGUI;component/icons/resources/resource_gold_icon_insufficient.png" />
											                                                            </DataTrigger>
											                                                        </Style.Triggers>
											                                                    </Style>
											                                                </Image.Style>
											                                            </Image>
		
											                                            <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="{Binding [cost][gold], Converter={StaticResource CastToIntOperator}}">
											                                                <TextBlock.Style>
											                                                    <Style BasedOn="{StaticResource nHUDBaseHeavyTextBlockStyle}" TargetType="{x:Type TextBlock}">
											                                                        <Style.Triggers>
											                                                            <DataTrigger Binding="{Binding [cost][gold_isInsufficient]}" Value="True">
											                                                                <Setter Property="Foreground" Value="{DynamicResource ErrorColorLightBrush}" />
											                                                            </DataTrigger>
											                                                        </Style.Triggers>
											                                                    </Style>
											                                                </TextBlock.Style>
											                                            </TextBlock>
											                                        </StackPanel>
		
																					<!-- Stone -->
											                                        <StackPanel Margin="{StaticResource ExtraSmallMarginBottom}" Orientation="Horizontal" Visibility="{Binding [cost][stone], Converter={StaticResource NotNullToVis}, FallbackValue=Collapsed}">
											                                            <Image Width="26" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="UniformToFill">
											                                                <Image.Style>
											                                                    <Style BasedOn="{StaticResource {x:Type Image}}" TargetType="{x:Type Image}">
											                                                        <Setter Property="Source" Value="pack://application:,,,/WPFGUI;component/icons/resources/resource_stone_icon.png" />
											                                                        <Style.Triggers>
											                                                            <DataTrigger Binding="{Binding [cost][stone_isInsufficient]}" Value="True">
											                                                                <Setter Property="Source" Value="pack://application:,,,/WPFGUI;component/icons/resources/resource_stone_icon_insufficient.png" />
											                                                            </DataTrigger>
											                                                        </Style.Triggers>
											                                                    </Style>
											                                                </Image.Style>
											                                            </Image>
		
											                                            <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="{Binding [cost][stone], Converter={StaticResource CastToIntOperator}}">
											                                                <TextBlock.Style>
											                                                    <Style BasedOn="{StaticResource nHUDBaseHeavyTextBlockStyle}" TargetType="{x:Type TextBlock}">
											                                                        <Style.Triggers>
											                                                            <DataTrigger Binding="{Binding [cost][stone_isInsufficient]}" Value="True">
											                                                                <Setter Property="Foreground" Value="{DynamicResource ErrorColorLightBrush}" />
											                                                            </DataTrigger>
											                                                        </Style.Triggers>
											                                                    </Style>
											                                                </TextBlock.Style>
											                                            </TextBlock>
											                                        </StackPanel>
		
																					<!-- Time -->
											                                        <StackPanel Margin="3,0,0,4" Orientation="Horizontal" Visibility="{Binding [cost][time], Converter={StaticResource NotNullToVis}, FallbackValue=Collapsed}">
											                                            <Image Width="16" Height="16" Margin="2,0,2,0" VerticalAlignment="Center">
											                                                <Image.Style>
											                                                    <Style BasedOn="{StaticResource {x:Type Image}}" TargetType="{x:Type Image}">
											                                                        <Setter Property="Source" Value="pack://application:,,,/WPFGUI;component/icons/shared/elapsed_time_icon.png" />
		
											                                                    </Style>
											                                                </Image.Style>
											                                            </Image>
		
											                                            <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="{Binding [cost][time], Converter={StaticResource TimeFormat}}">
											                                                <TextBlock.Style>
											                                                    <Style BasedOn="{StaticResource nHUDBaseHeavyTextBlockStyle}" TargetType="{x:Type TextBlock}" />
											                                                </TextBlock.Style>
											                                            </TextBlock>
											                                        </StackPanel>
		
																					<!-- Population -->
											                                        <StackPanel Margin="6,0,0,4" Orientation="Horizontal" Visibility="{Binding [cost][population], Converter={StaticResource GreaterCompare}, ConverterParameter=1, FallbackValue=Collapsed}">
											                                            <Image Width="20" Height="23" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="UniformToFill">
											                                                <Image.Style>
											                                                    <Style BasedOn="{StaticResource {x:Type Image}}" TargetType="{x:Type Image}">
											                                                        <Setter Property="Source" Value="pack://application:,,,/WPFGUI;component/icons/resources/resource_popcap.png" />
											                                                        <Style.Triggers>
											                                                            <DataTrigger Binding="{Binding [cost][population_isInsufficient]}" Value="True">
											                                                                <Setter Property="Source" Value="pack://application:,,,/WPFGUI;component/icons/resources/resource_popcap_reached.png" />
											                                                            </DataTrigger>
											                                                        </Style.Triggers>
											                                                    </Style>
											                                                </Image.Style>
											                                            </Image>
		
											                                            <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="{Binding [cost][population], Converter={StaticResource CastToIntOperator}}">
											                                                <TextBlock.Style>
											                                                    <Style BasedOn="{StaticResource nHUDBaseHeavyTextBlockStyle}" TargetType="{x:Type TextBlock}">
											                                                        <Style.Triggers>
											                                                            <DataTrigger Binding="{Binding [cost][population_isInsufficient]}" Value="True">
											                                                                <Setter Property="Foreground" Value="{DynamicResource ErrorColorLightBrush}" />
											                                                            </DataTrigger>
											                                                        </Style.Triggers>
											                                                    </Style>
											                                                </TextBlock.Style>
											                                            </TextBlock>
											                                        </StackPanel>
		
																				</StackPanel>
																				
																				<!--  Second Column is just a gutter -->
																				
																				<!--  Third Column: Title and Description -->
																				<StackPanel Grid.Column="2" Orientation="Vertical">
																					
																					<!--  Title -->
																					<TextBlock Style="{StaticResource nHUDTitleTextBlockStyle}"
																							   Text="{Binding [tooltip][title]}" 
																							   Visibility="{Binding [tooltip][title], Converter={StaticResource NotNullToVis}}" />
																					
																					<!--  Subtitle -->
																					<TextBlock Style="{StaticResource nHUDSubtitleTextBlockStyle}"
																							   Text="{Binding [tooltip][subtitle]}" 
																							   Visibility="{Binding [tooltip][subtitle], Converter={StaticResource NotNullToVis}}" />
		
																					<!--  Description -->
																					<TextBlock Margin="{StaticResource SmallMarginTop}"
																							   Style="{StaticResource nHUDBodyTextBlockStyle}"
																							   Text="{Binding [tooltip][description]}"
																							   Visibility="{Binding [tooltip][description], Converter={StaticResource NotNullToVis}, FallbackValue=Collapsed}" />
																					
																					<!--  Button Disabled Reason -->
																					<TextBlock Margin="{StaticResource SmallMarginTop}"
																							   Style="{StaticResource nHUDBaseHeavyErrorTextBlockStyle}"
																							   Text="{Binding [buttonDisabledReason]}"
																							   Visibility="{Binding [buttonDisabledReason], Converter={StaticResource NotNullToVis}, FallbackValue=Collapsed}" />
																					
																				</StackPanel>
																			</Grid>
																		</ContentControl>
																	</DataTemplate>
																</ToolTip.ContentTemplate>
															</ToolTip>
														</Button.ToolTip>
													</Button>
												</StackPanel>
											</Grid>
											<Separator HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
													   Style="{StaticResource PrimarySeperatorStyle}" />
										</StackPanel>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
		
							<!--  Summation  -->
							<Grid Grid.Row="3" Margin="0,5" VerticalAlignment="Center"
										Visibility="{Binding [reinforcementPanel][summation], Converter={StaticResource NotNullToVis}, FallbackValue=Collapsed}">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="*" />
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Margin="0,0,8,0" HorizontalAlignment="Left"
										   Style="{StaticResource nHUDBaseTextBlockStyle}"
										   Text="{Binding [reinforcementPanel][summation][title]}" />
								<TextBlock  Grid.Column="1" HorizontalAlignment="Right"
										   Style="{StaticResource nHUDBaseTextBlockStyle}"
										   Text="{Binding [reinforcementPanel][summation][value]}" />
							</Grid>
		
							<!--  Blurb  -->
							<TextBlock Grid.Row="4"
									   Style="{StaticResource nHUDBodyTextBlockStyle}"
									   Text="{Binding [reinforcementPanel][blurb]}"
									   TextWrapping="Wrap"
									   Visibility="{Binding [reinforcementPanel][blurb], Converter={StaticResource NotNullToVis}, FallbackValue=Collapsed}" />
		
						</Grid>
					</Grid>
				</Grid>
			</ContentControl>
		</ContentControl>
	</Grid>
</Grid>]]
		
	UI_AddChild("", "XamlPresenter", "DiplomacyUI", { IsHitTestVisible = true, Xaml = Xaml, uiData = UI_CreateDataContext(_t_campaignPanel.uiData)})		
	UI_AddCommandBinding("hud_game", "toggle_diplomacy_panel", "_CampaignPanel_Toggle")		-- hook the reinforcement panel up to the toggle_diplomacy_panel key binding
		
	_t_campaignPanel.uiCreated = true
		

end
	
	
function _CampaignPanel_CreateUI_Xbox()

	-- create the Xbox equivalent UI

	UI_AddChild("", "XamlPresenter", "DiplomacyUI", { IsHitTestVisible = true, Xaml = Xaml, uiData = UI_CreateDataContext(_t_campaignPanel.uiData)})		
		
	_t_campaignPanel.uiCreated = true
	
end



