function AIFormationPhaseEncounter_EndReason_ToString(reason)
	
	if reason == AIFormationPhaseEncounter_EndReason_Invalid then
		return "Invalid"
	elseif reason == AIFormationPhaseEncounter_EndReason_AtDestination then 
		return "AtDestination"
	elseif reason == AIFormationPhaseEncounter_EndReason_Timeout then
		return "Timeout"
	elseif reason == AIFormationPhaseEncounter_EndReason_CombatThreshold then
		return "CombatThreshold"
	elseif reason == AIFormationPhaseEncounter_EndReason_ShouldFallback then
		return "ShouldFallback"
	elseif reason == AIFormationPhaseEncounter_EndReason_EnemiesAtTargetCleared then
		return "EnemiesAtTargetCleared"
	elseif reason == AIFormationPhaseEncounter_EndReason_WasAttacked then
		return "WasAttacked"
	elseif reason == AIFormationPhaseEncounter_EndReason_CannotReachDestination then
		return "CannotReachDestination"
	elseif reason == AIFormationPhaseEncounter_EndReason_Torndown then
		return "Torndown"
	elseif reason == AIFormationPhaseEncounter_EndReason_SelfSquadsEmpty then
		return "SelfSquadsEmpty"
	elseif reason == AIFormationPhaseEncounter_EndReason_Success then
		return "Success"
	elseif reason == AIFormationPhaseEncounter_EndReason_Failure then
		return "Failure"
	else
		return "<Unknown EndReason>"
	end
end

function AIFormationPhaseEncounter_NotificationType_ToString(notification_type)
	if notification_type == AIEncounterNotification_Failure then 
		return "Failure"
	elseif notification_type == AIEncounterNotification_Success then 
		return "Success"
	elseif notification_type == AIEncounterNotification_Transition then 
		return "Transition"
	elseif notification_type == AIEncounterNotification_StateTreeExit then 
		return "StateTreeExit"
	else
		return "Unknown"
	end
end
