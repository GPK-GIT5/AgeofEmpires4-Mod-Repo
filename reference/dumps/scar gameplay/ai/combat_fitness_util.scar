import("Cardinal.scar")
import("ai/ai_encounter_util.scar")

function notify(contextDataTable)
	print("Encounter ended. Reason: " .. AIFormationPhaseEncounter_EndReason_ToString(contextDataTable.encounterStage))
	assert(contextDataTable.notificationType == AIEncounterNotification_StateTreeExit)
end

function LaunchEncounter(player, squads, position)
	currentEncounterID = AI_GetAndReserveNextTaskID(player);
	currentCallbackID = EventRule_GetNextUniqueRuleID();

	local sgroup_list_tunings = {
		ai_best_available_squads = squads
	} 
	
	local position_list_tunings = {
		ai_best_military_targets = { position }
	}
	
	local formupPosition = SGroup_GetPosition(squads)
	marker_list_tunings = { ai_best_formup_targets = {formupPosition}}
	
	
	local entitytype_list_tunings = {}
	
	local combat_coordinator_pbg_tunings = {
		ai_phase_encounter_coordinator_bag = BP_GetAIFormationCoordinatorBlueprint("ai\\ai_formation_coordinator\\campaign\\ai_formation_coordinator_campaign_default_attarget"),
		ai_phase_encounter_coordinator_bag_enroute = BP_GetAIFormationCoordinatorBlueprint("ai\\ai_formation_coordinator\\campaign\\ai_formation_coordinator_campaign_default_attarget"),
		ai_phase_encounter_path_bag = nil
	}
	
	local bool_tunings = {
		ai_phase_encounter_clear_enemy_squads = true,
		ai_phase_encounter_clear_enemy_squads_enroute = true,
		ai_phase_encounter_clear_enemy_buildings = true,
		ai_phase_encounter_clear_enemy_buildings_enroute = true,
		ai_phase_encounter_exit_on_partial_path = false,
		ai_phase_encounter_disable_cavalry_build_rams = false,
		ai_phase_encounter_should_hold_position = false
	}

	local float_tunings = {
		ai_phase_encounter_combat_area = 50,
		ai_phase_encounter_combat_area_enroute = 50,
		ai_phase_encounter_combat_leash = 50,
		ai_phase_encounter_combat_leash_enroute = 50,
		ai_phase_encounter_destination_area = 10,
		ai_phase_encounter_destination_combat_area = 45, --35
		ai_phase_encounter_enemy_scan_range_enroute = 50,
		ai_phase_encounter_enemy_scan_range = ai_phase_encounter_destination_combat_area, -- for best result, make this match the combat area
		ai_phase_encounter_destination_required_squads_percent_enroute = 1.0,
		ai_phase_encounter_destination_required_squads_percent = 1.0,
		ai_phase_encounter_archer_reposition_time_interval = 20.0,
		ai_phase_encounter_cached_path_update_interval_secs = 0.0,
		ai_phase_encounter_combat_fitness_threshold = 0,
		ai_phase_encounter_fallback_combat_rating = -1,
		ai_phase_encounter_fallback_squad_health_threshold =-1,
		ai_phase_encounter_idle_at_end_seconds = 30.0
	}
	
	local int_tunings = {
		ai_phase_encounter_override_encounter_id = currentEncounterID,
		ai_phase_encounter_notify_rule_id = currentCallbackID,
	}
	
	local phaseEncounterTuningsPBG = BP_GetAIStateModelTuningsBlueprint("ai\\ai_statemodel_tunings\\campaign_attack_default")
	
	
	AIStateTree_SpawnRootControllerWithStateModelTunings(
		player, 
		"campaign_encounters\\scar_encounters\\AttackDefault",
		false,
		phaseEncounterTuningsPBG, 
		sgroup_list_tunings, 
		nil,
		position_list_tunings, 
		{}, 
		entitytype_list_tunings,
		combat_coordinator_pbg_tunings,
		bool_tunings, 
		float_tunings,
		int_tunings)
	
	UnsavedEventRule_AddRuleIDEvent(notify, currentCallbackID, GE_AIPlayer_EncounterNotification)
end

function LaunchSimpleAttackMove(player, squads, position)
	Cmd_AttackMove(squads, position)
end

function LaunchSimpleAbility(squads, ability, target)
	Cmd_Ability(squads, ability, target)
end

function LaunchFireShipAbility(squads, target)
	local UseAbility = function(gid, idx, sid)
		local squadBP = Squad_GetBlueprint(sid)
		local bpName = BP_GetName(squadBP)
		
		local abilityName = "fireship_target"
		local ability = BP_GetAbilityBlueprint(abilityName)
		Cmd_Ability(sid, ability, target)
	end
	
	SGroup_ForEach(squads, UseAbility)
end

--? @shortdesc Returns the total health of all units in a entity group, excluding entities that currently cannot be damaged.
--? @extdesc This uses the "proper" measure of health for panel buildings, so should accurately reflect what the user sees.
--? @args EGroupID egroup
--? @result Real
function EGroup_GetTotalHealthFromCanBeDamagedOnly( egroupid )

	local tally = 0.0
	
	local GetItemHealth = function( groupid, itemindex, itemid )
		if Entity_CanCurrentlyBeDamaged(itemid) then
			tally = tally + Entity_GetHealth(itemid)
		end
	end
	EGroup_ForEach( egroupid, GetItemHealth )
	
	return tally
	
end

function TotalHealthOfPlayer(player)
	local entity1ID = "combat_fitness_util_e1"
	local entityG1 = EGroup_CreateIfNotFound(entity1ID)
	Player_GetAll(player, entityG1)
	
	local squad1ID = "combat_fitness_util_s1"
	local squad1 =  SGroup_CreateIfNotFound(squad1ID)
	Player_GetAll(player, squad1)
	
	local currentHealth = SGroup_GetTotalHealth(squad1) + EGroup_GetTotalHealthFromCanBeDamagedOnly(entityG1)
	
	return currentHealth
end

-- Param healthHistory {'player1':{time: health},'player1':{time: health}}
function FightIsFinished(player1, player2, healthHistory, damageTimeout)
	local health1 = TotalHealthOfPlayer(player1)
	local health2 = TotalHealthOfPlayer(player2)
	
	if health1 == 0 or health2 == 0 then
		return {true, health1, health2}
	end
	
	if HistoryLength(healthHistory['player1']) >= damageTimeout then --assume both histories are same len
		local player1TookDamage = DamagedInLastPeriod(damageTimeout, healthHistory['player1'], health1)
		local player2TookDamage = DamagedInLastPeriod(damageTimeout, healthHistory['player2'], health2)
		
		if not player1TookDamage and player2TookDamage then
			return {true, health1, 0}
		end
		if  player1TookDamage and not player2TookDamage then
			return {true, 0, health2}
		end
	end
	
	return {false, health1, health2}
end

function AppendHealthHistory(player, history) 
	local currentTime = World_GetGameTime()
	history[currentTime] = TotalHealthOfPlayer(player)
end

function HistoryLength(healthHistory)
	local historyDuration = 0
	local currentTime = World_GetGameTime()
	
	for time, health in pairs(healthHistory) do
		local timeSince = (currentTime - time)
		historyDuration = math.max(historyDuration, timeSince)
	end
	
	return historyDuration
end

-- returns true if damage has occured within the supplied period
function DamagedInLastPeriod(period, healthHistory, currentHealth)
	
	local currentTime = World_GetGameTime()
	
	for time, health in pairs(healthHistory) do
		local timeSince = (currentTime - time)
		local entryWithinPeriod = timeSince <= period
		if entryWithinPeriod  then
			if health ~= currentHealth then
				return true
			end
		end
	end

	return false
end
	
function SGroup_CanTargetSGroup(attackGroup, targetGroup)

	local canTarget = false
	
	local _CanTarget = function(sgroup, index, squad)
		if canTarget then
			return
		end
			
		for j = 1, SGroup_Count(targetGroup) do
			local targetSquad = SGroup_GetSquadAt(targetGroup, j)
			if Squad_CanTargetSquad(squad, targetSquad, false --[[checkFOW]]) then
				canTarget = true
				break;
			end
		end
	end
	SGroup_ForEach(attackGroup, _CanTarget)
	
	return canTarget
end
	
function SGroup_CanTargetEGroup(attackGroup, targetGroup)

	local canTarget = false
	
	local _CanTarget = function(sgroup, index, squad)
		if canTarget then
			return
		end
			
		for j = 1, EGroup_Count(targetGroup) do
			local targetEntity = EGroup_GetEntityAt(targetGroup, j)
			if Squad_CanTargetEntity(squad, targetEntity, false --[[checkFOW]]) then
				canTarget = true
				break;
			end
		end
	end
	SGroup_ForEach(attackGroup, _CanTarget)
	
	return canTarget
end

function ComputeScore(initialA, initialB, finalA, finalB)
	if finalA == 0.0 and finalB == 0.0 then
		return 0.5
	end
	
	-- Handle rare cases of divide by zero.
	if initialA == 0.0 and initialB == 0.0 then
		return 0.5
	elseif initialA == 0.0 then
		return 0.0 -- initialB ~= 0.0. Assume B wins.
	elseif initialB == 0.0 then
		return 1.0 -- initialA ~= 0.0. Assume A wins.
	end
	
	local score = 0.5 - ((initialA - finalA)/(2*initialA)) + ((initialB - finalB)/(2*initialB))
	return score
end

function ContainsAnyFilterWord(word, filterList)
	for i, fil in pairs(filterList) do
		if string.find(word, fil) then
			return true
		end
	end
	
	return false
end

function ContainsAllFilterWord(word, filterList)
	for i, fil in pairs(filterList) do
		if not string.find(word, fil) then
			return false
		end
	end
	
	return true
end

function CreateSpawnCombination(spawnPossibilities, onlyOneAllowedWords, spawnSize, chunkLimit, onlyOneUnitType, distribution)
	local result = {}
	local selectedList = {}
	local loopNum = 0

	-- Are we given a distribution?
	local distributionKeys = nil
	if distribution ~= nil then
		-- iterate over whole table to get all keys
		distributionKeys = {}
		for key in pairs(distribution) do
			table.insert(distributionKeys, key)
		end
	end
	
	while spawnSize > 0 do
		local possibility = nil
		
		if distributionKeys == nil then
			possibility = Table_GetRandomItem(spawnPossibilities)
		else
			indices = distribution[distributionKeys[World_GetRand(1, #distributionKeys)]]
			index = Table_GetRandomItem(indices)
			possibility = spawnPossibilities[index]
		end
		
		-- There might be units that are in the archetype mapping but can't be spawned. 
		-- for those, the entry in spawnPossibilities is set to false.
		if not (possibility == false) then 
			local unitType = possibility[1]
			local squadBP = possibility[2]
			
			local onlyOneAllowed = ContainsAnyFilterWord(unitType, onlyOneAllowedWords)
			local oneAlreadySpawned = ContainsAnyFilterWord(unitType, selectedList)
			local canSpawnMoreOfThisUnit = not onlyOneAllowed or not oneAlreadySpawned
			
			if canSpawnMoreOfThisUnit then
				local chunk = 1 
				if onlyOneUnitType then
					chunk = spawnSize
				elseif not onlyOneAllowed then 
					chunk = math.min(World_GetRand(1, spawnSize), chunkLimit)
				end
				spawnSize = spawnSize - chunk
				table.insert(result, { chunk, unitType, squadBP })
				table.insert(selectedList, unitType)
			end
		end
			
		assert(loopNum < 1000, "Inf loop detected")
		loopNum = loopNum + 1
	end
	
	return result
end

function PrintSpawnCombination(label, combination, printFunc)
	local func = printFunc or print
	func(label)
	for i, info in pairs(combination) do
		local chunk = info[1]
		local unitType = info[2]
		func("  " .. chunk .. " x " .. unitType)
	end
end

