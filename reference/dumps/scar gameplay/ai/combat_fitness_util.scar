function CreateBuildingCombination(player, maxNumBuildings)
	local result = {}
	local numBuildings = World_GetRand(1, maxNumBuildings)
	
	for j = 1, numBuildings do
		-- 50/50 chance to spawn a town center or combat building
		if (World_GetRand(1, 99) < 50) then
			table.insert(result, townCenterCombo[World_GetRand(1, #townCenterCombo)])
		else
			table.insert(result, combatBuildingCombo[World_GetRand(1, #combatBuildingCombo)])
		end
	end
	
	return result
end

function PrintBuildingCombination(combination, printFunc)
	local func = printFunc or print
	for i, building in pairs(combination) do
		func("  1 x " .. BP_GetName(building[1]))
		for j, upgrade in pairs(building[2]) do
			func("    with " .. BP_GetName(upgrade))
		end
	end
end

function SpawnBuildings(player, buildingCombination, buildingPositions, damagedChance1In, optionalTowardsPosition)
	local entity1ID = "combat_fitness_util_e1"
	local entityG1 = EGroup_CreateIfNotFound(entity1ID)
	
	for i, combination in pairs(buildingCombination) do
		EGroup_Clear(entityG1)
		Util_CreateEntities(player, entityG1, combination[1], buildingPositions[i], 1, optionalTowardsPosition, true, false)
		
		-- print(EGroup_Count(entityG1))
		for j, upgrade in pairs(combination[2]) do
			Cmd_InstantUpgrade(entityG1, upgrade) 
		end
		
		for j = 1, EGroup_Count(entityG1), 1 do
			local healthPercentage = 1
			
			if damagedChance1In > 0 then
				local isDamaged =  World_GetRand(1,damagedChance1In) == 1
				if isDamaged then 
					healthPercentage = World_GetRand(1,10) * 0.1
				end
			end
			
			Entity_SetHealth(EGroup_GetEntityAt(entityG1, j), healthPercentage)
		end
	end
end

-- This helper checks if a PBG is already loaded to avoid a force reload
function CreateAndSpawnSquad(pbg, player, pos, posToward, loadedPBGNames)
	local spawnedSquad
	
	local pbgName = BP_GetName(pbg)
	if (loadedPBGNames[pbgName] ~= nil) then
		spawnedSquad = Squad_CreateAndSpawnToward(pbg, player, 0, pos, posToward)
	else
		spawnedSquad = Squad_CreateAndSpawnTowardCheat(pbg, player, 0, pos, posToward)
		loadedPBGNames[pbgName] = true
	end
	
	return spawnedSquad
end

function SpawnCombination(player, pos, combination, damagedChance1In, loadedPBGNames)
	
	if #combination == 0 then
		return
	end
	
	for i = 1, #combination do
		local chunk = combination[i][1]
		local squadBP = combination[i][3]
		
		while chunk > 0 do
			local spawnedSquad = CreateAndSpawnSquad(squadBP, player, pos, pos, loadedPBGNames)
			chunk = chunk - 1
			
			local healthPercentage = 1 
		
			if damagedChance1In > 0 then
				local isDamaged = World_GetRand(1,damagedChance1In) == 1
				if isDamaged then 
					healthPercentage = World_GetRand(1,10) * 0.1
				end
			end
			
			Squad_SetHealth(spawnedSquad, healthPercentage)
		end 
	end
end

function GenUpgradeCombination(potentialUpgrades, numUpgrades, unitCombination, buildingCombination)
	if numUpgrades == 1 then  
		result = { Table_GetRandomItem(potentialUpgrades) }
	elseif numUpgrades > 1 then
		result = Table_GetRandomItem(potentialUpgrades, numUpgrades)
	end
	
	-- Check if we have unit specific upgrades we should include
	local hasMonk = false
	local hasMonkAbb = false
	local hasMonkHre = false
	local hasMonkMon = false
	local hasMonkSul = false
	local hasWarship = false
	local hasBombardChi = false
	local hasManAtArmsChi = false
	local hasGunpowderChi = false
	local hasTrebuchetEng = false
	local hasCavalryFre = false
	local hasKeepOrTower = false
	local hasKeepOrTowerSul = false
	local hasDefensesHre = false
	local hasDefensesSul = false
	local hasTowerElephantSul = false
	local hasAnyBuildingsSul = false
	
	for i = 1, #unitCombination do
		local unitType = unitCombination[i][2]
		local unitBP = unitCombination[i][3]
		
		-- Check for monk upgrades
		local isCurrentBPMonk = Squad_IsSBPOfType(unitBP, "monk")
		hasMonk = hasMonk or isCurrentBPMonk
		if isCurrentBPMonk then
			-- Check for civ specific monk upgrades
			hasMonkAbb = hasMonkAbb or string.find(unitType, "_abb") ~= nil
			hasMonkHre = hasMonkHre or string.find(unitType, "_hre") ~= nil
			hasMonkMon = hasMonkMon or string.find(unitType, "_mon") ~= nil
			hasMonkSul = hasMonkSul or string.find(unitType, "_sul") ~= nil
		end
		
		-- Check for warship upgrades
		hasWarship = hasWarship or Squad_IsSBPOfType(unitBP, "naval_warship")
			
		-- Check for civ specific upgrades
		if string.find(unitType, "_chi") ~= nil then
			hasBombardChi = hasBombardChi or Squad_IsSBPOfType(unitBP, "bombard")
			hasManAtArmsChi = hasManAtArmsChi or Squad_IsSBPOfType(unitBP, "manatarms")
			hasGunpowderChi = hasGunpowderChi or Squad_IsSBPOfType(unitBP, "gunpowder")
		elseif string.find(unitType, "_eng") ~= nil then
			hasTrebuchetEng = hasTrebuchetEng or string.find(unitType, "unit_trebuchet") ~= nil
		elseif string.find(unitType, "_fre") ~= nil then
			hasCavalryFre = hasCavalryFre or Squad_IsSBPOfType(unitBP, "cavalry")
		elseif string.find(unitType, "_sul") ~= nil then
			hasTowerElephantSul = hasTowerElephantSul or Squad_IsSBPOfType(unitBP, "cavalry_tower_elephant")
		end
	end
	
	for i = 1, #buildingCombination do
		local buildingBP = buildingCombination[i][1]
		local buildingName = BP_GetName(buildingBP)
		
		-- Murder holes (Boiling Oil) only affect Keeps and Towers
		local isCurrentBPKeepOrTower = Entity_IsEBPOfType(buildingBP, "castle") or Entity_IsEBPOfType(buildingBP, "tower")
		hasKeepOrTower = hasKeepOrTower or isCurrentBPKeepOrTower
			
		-- Check for civ specific upgrades
		if string.find(buildingName, "_hre") then
			hasDefensesHre = hasDefensesHre or string.find(buildingName, "defense_tower") ~= nil
		elseif string.find(buildingName, "_sul") then
			hasDefensesSul = hasDefensesSul or
				Entity_IsEBPOfType(buildingBP, "castle") or
				Entity_IsEBPOfType(buildingBP, "outpost") or
				Entity_IsEBPOfType(buildingBP, "tower")
			hasKeepOrTowerSul = hasKeepOrTowerSul or isCurrentBPKeepOrTower
			hasAnyBuildingsSul = true
		end
	end
	
	local upgrades = {}
	if hasMonkAbb then
		table.insert(upgrades, "upgrade_unit_religious_piety_4_abb")
		table.insert(upgrades, "upgrade_unit_religious_herbal_medicine_4_abb")
	elseif hasMonkHre then
		table.insert(upgrades, "upgrade_unit_religious_piety_4_hre")
		table.insert(upgrades, "upgrade_unit_religious_herbal_medicine_4_hre")
	elseif hasMonkMon then
		table.insert(upgrades, "upgrade_unit_religious_piety_4_mon")
		table.insert(upgrades, "upgrade_unit_religious_herbal_medicine_4")
		table.insert(upgrades, "upgrade_unit_religious_herbal_medicine_4_improved_mon")
	elseif hasMonkSul then
		table.insert(upgrades, "upgrade_unit_religious_piety_4_sul")
		table.insert(upgrades, "upgrade_unit_religious_zealous_4_sul")
		table.insert(upgrades, "upgrade_unit_religious_herbal_medicine_4_sul")
	elseif hasMonk then
		table.insert(upgrades, "upgrade_unit_religious_piety_4")
		table.insert(upgrades, "upgrade_unit_religious_herbal_medicine_4")
	end
	
	if hasWarship then
		table.insert(upgrades, "upgrade_naval_galley_cannon")
	end
	if hasBombardChi then
		table.insert(upgrades, "upgrade_reload_drills_chi")
	end
	if hasManAtArmsChi then
		table.insert(upgrades, "upgrade_manatarms_battle_hardened_chi")
	end
	if hasGunpowderChi then
		table.insert(upgrades, "upgrade_gunpowder_damage_chi")
	end
	if hasTrebuchetEng then
		table.insert(upgrades, "upgrade_trebuchet_aoe_eng")
	end
	if hasCavalryFre then
		table.insert(upgrades, "upgrade_cavalry_bloodline_fre")
		table.insert(upgrades, "upgrade_landmark_cavalry_bloodline_fre")
	end

	if hasAnyBuildingsSul then
		table.insert(upgrades, "upgrade_tech_university_architecture_4_sul")
	elseif #buildingCombination > 0 then
		table.insert(upgrades, "upgrade_tech_university_architecture_4")
	end
	
	if hasKeepOrTowerSul then
		table.insert(upgrades, "upgrade_tech_university_murder_holes_4_sul")
	elseif hasKeepOrTower then
		table.insert(upgrades, "upgrade_tech_university_murder_holes_4") 
	end
	
	if hasDefensesHre then
		table.insert(upgrades, "upgrade_reinforced_defenses_hre")
	end
	if hasDefensesSul then
		table.insert(upgrades, "upgrade_landmark_keep_defense_sul")
	end
	if hasTowerElephantSul then
		table.insert(upgrades, "upgrade_landmark_siege_elephant_sul")
	end
	
	-- Get upgrade blueprints
	local result = {} 
	for i, v in ipairs(upgrades) do
		table.insert(result, BP_GetUpgradeBlueprint(v))
	end
	
	return result
end

function ApplyPlayerUpgrades(player, upgrades)
	for i, upgrade in pairs(upgrades) do
		Player_CompleteUpgrade(player, upgrade)
	end
end

function GetAllBPs(BPType, filter)
	local result = {}
	local count = BP_GetPropertyBagGroupCount(BPType)
	local id = 0
	local index = 1
	

	for id = 0, count-1 do
		local name = BP_GetPropertyBagGroupPathName(BPType, id )
		
		name = string.lower(name)
		
		local a,b = string.find( name, filter )
		
		if ( b ~= nil ) then
			result[index] = name;
			index = index + 1
		end
	end
	
	return result
end

function GenerateBPOptions(BPType, allowedRaces, filterWords, chosenWords)
	local sbps = {}
	-- Determine a list of units we can spawn
	for i, raceName in pairs(allowedRaces) do
		local sbpsTmp = GetAllBPs(BPType, "races\\" .. raceName)
		
		for k,v in ipairs(sbpsTmp) do
			table.insert(sbps, v)
		end 
	end

	-- filter the list
	local filteredList = {}
	local tempSbpsCopy = {}
	for i, unitType in pairs(sbps) do
		
		local filtered = false
		
		for k, filter in pairs(filterWords) do
			if string.find(unitType, filter) then
				filtered = true
				break
			end	
		end
		
		local chosen = true
		if #chosenWords > 0 then
			chosen = false
			
			for k, choice in pairs(chosenWords) do
				if string.find(unitType, choice) then
					chosen = true
					break
				end	
			end
		end

		if not filtered and chosen then
			local squadBP = BP_GetSquadBlueprint(unitType)
			table.insert(tempSbpsCopy, { unitType, squadBP })
		else
			table.insert(filteredList, unitType)
		end
	end
	
	if #filteredList > 0 then
		print("Blueprints excluded during GenerateBPOptions: ")
		for i, v in ipairs(filteredList) do
			print("  " .. v)
		end
	end

	return tempSbpsCopy
end

function FilterBPOptions(spawnPossibilities, requiredWords)
	local result = {}
	
	for i, possibility in pairs(spawnPossibilities) do
		if possibility ~= false then 
			local unitType = possibility[1]
			local hasRequired = (#requiredWords == 0) or ContainsAllFilterWord(unitType, requiredWords)
			
			if hasRequired then
				table.insert(result, possibility)
			end
		end
	end
	
	return result
end

function GenerateArchetypeMapping(spawnPossibilities)

	-- Build archetype + member name lookup table
	local archetypeMemberNames = {}
	
	local AddArchetype = function(name, pbgs)
		archetypeMemberNames[name] = {}
		for j, archetypeMember in pairs(pbgs) do
			local archetypeMemberName = BP_GetName(archetypeMember)
			table.insert(archetypeMemberNames[name], archetypeMemberName) 
		end
	end

	-- Add squad archetypes	
	local archetypeNames = AI_CombatFitnessGetSquadArchetypeNames()
	for i, archetypeName in pairs(archetypeNames) do
		local archetypePBGs = AI_CombatFitnessGetSquadArchetypePBGs(archetypeName)
		AddArchetype(archetypeName, archetypePBGs)
	end
	
	-- Add healers
	local healerPBGs = AI_CombatFitnessGetHealerPBGs()
	AddArchetype("monk", healerPBGs)

	-- Build archetype mapping (archetypeName + indices to spawnPossibilities)
	local archetypeMap = {}

	local badIndices = {}
	
	for i, possibility in pairs(spawnPossibilities) do
		local unitType = possibility[1]
		
		-- Add index under the corresponding archetype
		local matched = false
		for archetypeName, memberNames in pairs(archetypeMemberNames) do
			for k, memberName in pairs(memberNames) do
				if string.find(unitType, memberName) then
					if archetypeMap[archetypeName] ~= nil then
						table.insert(archetypeMap[archetypeName], i)
					else
						archetypeMap[archetypeName] = { i }
					end
					print("[" .. archetypeName .. "] <- " .. unitType.." index "..i)
					matched = true
					break
				end
			end	
		end
		
		-- There are some unused units that haven't been removed from the blueprints list, we'll print those in the log 
		-- and then remove them from the set of things we can spawn so it doesn't break our training data set.
		if not matched then
			table.insert(badIndices,  #badIndices+1, i)
			print("No match found for index " .. i .. " " ..unitType)
		end
	end
	 
	for i = #badIndices, 1, -1 do 
		print ("removing index " .. badIndices[i])
		spawnPossibilities[badIndices[i]] = false
	end
	
	-- Make sure we have entries for all the archetypes
	for archetypeName, memberNames in pairs(archetypeMemberNames) do
		if archetypeMap[archetypeName] == nil then
			print("No entries found for " .. archetypeName .. "!")
		end
	end
	
	return archetypeMap
end

function SelectArchetypeMapping(archetypeMap, archetypeFilterWords)
	local result = {}
	for archetype, pbgIndices in pairs(archetypeMap) do
		for i, word in ipairs(archetypeFilterWords) do
			if string.find(archetype, word) then
				result[archetype] = pbgIndices
				break
			end
		end
	end
	return result
end

function CleanupPlayer(player)
	local entityID = "combat_fitness_util_e"
	local entityG = EGroup_CreateIfNotFound(entityID)
	Player_GetAll(player, entityG)
	EGroup_DestroyAllEntities(entityG)
	
	local squadID = "combat_fitness_util_s"
	local squadG =  SGroup_CreateIfNotFound(squadID)
	Player_GetAll(player, squadG) 
	SGroup_DestroyAllSquads(squadG)
	
	Player_RemoveAllUpgrades(player)
end

function Cleanup(player1, player2)
	CleanupPlayer(player1)
	CleanupPlayer(player2)
end

-- Testing methods

function CalcOneVOneSquadFitness(teamAPlayer, teamBPlayer, teamAPBGName, teamBPBGName)
	local sg_dummy = SGroup_CreateIfNotFound("dummy")
	local eg_dummy = EGroup_CreateIfNotFound("dummy")
	local teamA = {BP_GetSquadBlueprint(teamAPBGName)}
	local teamB = {BP_GetSquadBlueprint(teamBPBGName)}
	return AI_CalculateCombatFitnessEstimate(sg_dummy,eg_dummy, teamA, sg_dummy,eg_dummy, teamB, teamAPlayer, teamBPlayer, true)
end

function CalcNVNSquadFitness(teamAPlayer, teamBPlayer, teamAPBGName, teamANum, teamBPBGName, teamBNum)
	local createTable = function (element, dim)
		result = {}
		for i = 1,dim,1 do table.insert(result, element) end
		return result
	end
	
	local sg_dummy = SGroup_CreateIfNotFound("dummy")
	local eg_dummy = EGroup_CreateIfNotFound("dummy")
	local teamA = createTable(BP_GetSquadBlueprint(teamAPBGName), teamANum)
	local teamB = createTable(BP_GetSquadBlueprint(teamBPBGName), teamBNum)
	return AI_CalculateCombatFitnessEstimate(sg_dummy,eg_dummy, teamA, sg_dummy,eg_dummy, teamB, teamAPlayer, teamBPlayer, true)
end

function TestCharacterization(player1, player2, filterList, stdPrint, failurePrint)
	local numCharacterized = 0
	local numCharacterizedPoorly = 0
	local numUnCharacterized = 0
	local numIgnored = 0
	
	for id = 0, BP_GetPropertyBagGroupCount( PBG_SquadProperties ) -1 do
		local name = BP_GetPropertyBagGroupPathName( PBG_SquadProperties, id )
		
		local filtered =  ContainsAnyFilterWord(name, filterList)
		
		if filtered then
			numIgnored = numIgnored + 1
		else
			local characterized =  AI_CombatFitnessCharacterizesSquad(player1, BP_GetSquadBlueprint(name))
			
			if characterized then 
				numCharacterized = numCharacterized + 1
				local oneVoneScore = CalcOneVOneSquadFitness(player1, player2, name, name)
				
				-- Poor characterized is not a failure
				if math.abs(oneVoneScore - 0.5) > 0.1 then
					stdPrint('Poorly characterized:' .. name .. ' Score:' .. oneVoneScore)
					numCharacterizedPoorly = numCharacterizedPoorly + 1
				end
			else
				failurePrint('Uncharacterized:' .. name)
				numUnCharacterized = numUnCharacterized + 1
			end
		end
	end
	
	stdPrint("numCharacterized: " .. numCharacterized)
	stdPrint("numCharacterizedPoorly: " .. numCharacterizedPoorly)
	stdPrint("numUnCharacterized: " .. numUnCharacterized)
	stdPrint("numIgnored: " .. numIgnored)

	return numUnCharacterized == 0
end