--
-- Unit Entry system delegates
--

function Project_UnitEntry_PreprocessDeployment(deployment)

	local units = deployment.units
	
	-- filter out units according to "difficulty" parameter
	for index = #units, 1, -1 do
	
		local unit = units[index]
		
		if unit.difficulty ~= nil then	
			
			if scartype(unit.difficulty) == ST_NUMBER then
				if unit.difficulty ~= Game_GetSPDifficulty() then
					table.remove(units, index)
				end
			elseif scartype(unit.difficulty) == ST_TABLE then 
				if Table_Contains(unit.difficulty, Game_GetSPDifficulty()) == false then
					table.remove(units, index)
				end
			end
			
		end
		
	end
	

	---- perform any type-to-blueprint extrapolation
	for index = #units, 1, -1 do 
	
		local unit = units[index]
		
		if unit.sbp == nil and unit.type ~= nil then
			
			local thisType = unit.type
			
			unit.sbp = Cardinal_ConvertTypeToSquadBlueprint(unit.type, deployment.player)
			unit.type = nil 	
			
			if unit.sbp == nil then					-- if there wasn't a valid SBP, remove this item for now
				print("UnitEntry error - could not convert type "..tostring(thisType).." to a valid blueprint. This item was removed from the spawn list.")
				table.remove(units, index)		
			end
			
		end
		
	end


	-- temp: map old-style upgrades (plural) field to upgrade (singular) - everything other field is singular, so people kept missing out the "s"
	for index, unit in pairs(units) do 
		if unit.upgrades ~= nil and unit.upgrade == nil then
			unit.upgrade = unit.upgrades
			unit.upgrades = nil
		end
		if unit.entityUpgrades ~= nil and unit.entityUpgrade == nil then
			unit.entityUpgrade = unit.entityUpgrades
			unit.entityUpgrades = nil
		end
	end
	
end

function Project_UnitEntry_StartDeployment(deployment)

	local units = Clone(deployment.units, false) -- make a one-layer deep copy of the units table

	while #units > 1 do 
		
		local referenceUnit = units[1]
		table.remove(units, 1)
		
		local unitsAtSameLocation = {
			referenceUnit,
		}
		
		local sgroup = SGroup_Create("temp group")		
		SGroup_Add(sgroup, referenceUnit.squadID)
		
		for i = #units, 1, -1 do
			local unit = units[i] 
			if unit.spawn == referenceUnit.spawn and unit.facing == referenceUnit.facing then
				
				table.insert(unitsAtSameLocation, unit)
				SGroup_Add(sgroup, unit.squadID)
				
				table.remove(units, i)
				
			end
			
		end
		
		if SGroup_Count(sgroup) >= 2 then 

			local spawn_location = referenceUnit.spawn or deployment.spawn
			local spawn_direction = Util_ScarPos(1, 0, 0)
			
			if scartype(spawn_location) == ST_STRING then		
				spawn_location = Marker_FromName(spawn_location, "")
			end
			if scartype(spawn_location) == ST_MARKER then
				spawn_direction = Marker_GetDirection(spawn_location)
				spawn_location = Marker_GetPosition(spawn_location)
			end
			
			if referenceUnit.facing ~= nil then
				-- If unit has a facing option, override marker direction
				spawn_direction = Util_GetDirectionFromAtoB(spawn_location, referenceUnit.facing)
			elseif deployment.options.facing ~= nil then
				-- If spawn has a facing option, override marker direction
				spawn_direction = Util_GetDirectionFromAtoB(spawn_location, deployment.options.facing)
			end
			
			Formation_PlaceSquadGroupsInFormation({sgroup}, spawn_location, spawn_direction)
			
			for index, unit in ipairs(unitsAtSameLocation) do 
				local position = Squad_GetPositionDeSpawned(unit.squadID)
				--local heading = Squad_GetHeading(unit.squadID)							-- not used for the moment, see below
				unit.spawn = position
				unit.facing = Util_GetFacingFromDirection(position, spawn_direction)		-- FIXME: getting the heading from the squad doesn't seem to work, so just using the formation heading for now
			end
			
		end
		
		SGroup_Destroy(sgroup)
		
	end

	
end

function Project_UnitEntry_SpawnUnit(unit, deployment)
	
	if Squad_IsOfType(unit.squadID, "scar_scout") and (unit.forceMaleScout == true or (unit.forceMaleScout == nil and Player_GetRace(deployment.player) ~= RACE.MONGOL) ) then
		Squad_AddAbility(unit.squadID, BP_GetAbilityBlueprint("scout_male_attachment"))
	end
	
	if Squad_Count(unit.squadID) >= 1 and Squad_IsInHoldEntity(unit.squadID) == false and Squad_IsInHoldSquad(unit.squadID) == false then
		local entity = Squad_GetFirstEntity(unit.squadID)
		local desiredPos = Util_GetPosition(unit.spawn)
		Entity_SetPositionWithinCell(entity, desiredPos)
	end
	
end

function Project_UnitEntry_SpawnUnit_Finish(unit, deployment)
	
	if unit.holdPosition == true or deployment.options.holdPosition == true then
		local sgroup = SGroup_CreateUnique("")
		local squad = Squad_FromID(unit.squadWorldID)
		SGroup_Single(sgroup, squad)
		Cmd_HoldPosition(sgroup, nil, true)
		SGroup_Destroy(sgroup)
	end
		
end

function Project_UnitEntry_EndDeployment(deployment)

	--
	-- find all units with a destination and give them a new *formation* move command
	--
	
	local destination_groups = {}
	
	-- find groups of units with common destinations
	for index, unit in pairs(deployment.units) do 
		
		if unit.squadWorldID ~= nil and Squad_IsValid(unit.squadWorldID) then 
			
			local destination = unit.destination or deployment.options.destination
			local destinationFacing = unit.destinationFacing or deployment.options.destinationFacing

			if scartype(destination) == ST_MARKER or scartype(destination) == ST_SCARPOS then 
				
				local squad = Squad_FromID(unit.squadWorldID)
				if Squad_HasDestination(squad) == false or Util_GetDistance(destination, Squad_GetDestination(squad)) <= 3 then  
				
					local addedToExistingGroup = false
					
					-- search to see if it's destination is the same as another we already checked
					for i, group in pairs(destination_groups) do 
						
						if group.destination == destination and group.destinationFacing == destinationFacing then 
							SGroup_Add(group.sgroup, squad)			-- if so, add this squad to that group
							addedToExistingGroup = true
							break
						end
						
					end
					
					-- if it wasn't, create a new entry for squads going to this new destination
					if addedToExistingGroup == false then 
						
						local newGroup = {
							sgroup = SGroup_CreateUnique(),			-- create the new entry, and group
							destination = destination,
							destinationFacing = destinationFacing,
						}
						table.insert(destination_groups, newGroup)
						
						SGroup_Add(newGroup.sgroup, squad)			-- add this squad to the new group
						
					end
					
				end
				
			end
		end
		
	end

	-- delay a rule by a sim-tick which will then give formation-move orders to these groups
	if #destination_groups >= 1 then 
		Rule_AddOneShot(_EndDeployment_DelayedMove, 0.125, {destination_groups = destination_groups, deployment = deployment})
	end
	
end

function _EndDeployment_DelayedMove(context, data)

	-- reissue move orders to units but using the formation move function	
	for index, group in pairs(data.destination_groups) do 

		if SGroup_CountSpawned(group.sgroup) >= 2 then 			-- don't bother if there's only one unit heading there
			Cmd_FormationMove(group.sgroup, group.destination, nil, nil, group.destinationFacing)
		end		
		
		SGroup_Destroy(group.sgroup)
		
	end
	

end
	


--? @shortdesc Warps all members of an SGroup immediately to a marker but puts them in formation
--? @args SGroupID sgroup, MarkerID marker[, MarkerID/Pos facing]
--? @result Void
function SGroup_FormationWarpToMarker(sgroup, marker, facing)
	
	if scartype(marker) == ST_MARKER and facing == nil then
		facing = Util_GetFacingFromDirection(Marker_GetPosition(marker), Marker_GetDirection(marker))
	end

	SGroup_FormationWarpToPos(sgroup, Util_GetPosition(marker), facing)
	
end

--? @shortdesc Warps all members of an SGroup immediately to a new position but puts them in formation
--? @args SGroupID sgroup, Position pos[, MarkerID/Pos facing]
--? @result Void
function SGroup_FormationWarpToPos(sgroup, pos, facing)

	if SGroup_CountSpawned(sgroup) >= 1 then 
		
		local direction = nil
		pos = Util_GetPosition(pos)
		
		if facing == nil then 
			direction = Squad_GetHeading(SGroup_GetSpawnedSquadAt(sgroup, 1))
		else
			direction = Util_GetDirectionFromAtoB(pos, facing)
		end
		
		Cmd_FormationStop(sgroup)

		Formation_PlaceSquadGroupsInFormation({sgroup}, pos, direction)
	
	end
	
end



--
----
------ Type-to-Blueprint Extrapolator
----
--


--? @shortdesc Converts a squad type (or set of types) into a suitable squad blueprint 
--? @extdesc The types listed are used to track down a specific blueprint, and the list can be augmented with information from the provided player if it isn't specified directly (for things like civilization)
--? @args SquadType/Table typeList, PlayerID player[, Bool returnAsTable] 
--? @result SquadBlueprint
function Cardinal_ConvertTypeToSquadBlueprint(typeList, player, returnAsTable)

	Cardinal_TypeToBlueprint_Init()
	
	returnAsTable = returnAsTable or false
	
	if scartype(typeList) ~= ST_TABLE then 
		typeList = {typeList}
	end
	
	
	-- find the appropriate civilization type
	local civ = Cardinal_TypeToBlueprint_GetCivData(typeList)
	if civ == nil then	
		civ = Cardinal_TypeToBlueprint_GetCivData(player)	-- no civ specified, so use the player's civ
	end
	
	-- find the appropriate age type (and default to a "base" type if none found)
	local age = Cardinal_TypeToBlueprint_GetAgeData(typeList)
	if age == nil then
		age = {
			unitType = "scar_base",
			cacheIndex = "base",
			level = AGE_NONE,
		}
	end

	-- get remaining items from the list (stripping out civ and age now we have those broken out)
	local unitTypes = {}
	for index, item in pairs(typeList) do 
		if item ~= civ.unitType and item ~= age.unitType then
			table.insert(unitTypes, item)
		end
	end


	-- create an index string
	local typeIndex = Cardinal_TypeToBlueprint_GenerateTypeIndexString(unitTypes)
	local ageIndex = age.cacheIndex

	-- choose the correct cache depending on the civ
	local civCache = t_TypeToBlueprint_Cache[civ.cacheIndex].sbps

	
	
	if civCache[typeIndex] == nil then
		Cardinal_TypeToBlueprint_CacheSquadBlueprints(unitTypes)		-- we haven't searched for this combo before, generate the list now	
	end
	
	local result = nil
	
	if #civCache[typeIndex][ageIndex] >= 1 then
		result = civCache[typeIndex][ageIndex]
	elseif #civCache[typeIndex]["base"] >= 1 then
		result = civCache[typeIndex]["base"]
	end
	
	if returnAsTable then
		return result or {}
	end
	
	if result ~= nil then
		return result[1]
	end
end

--? @shortdesc Converts an entity type (or set of types) into a suitable entity blueprint 
--? @extdesc The types listed are used to track down a specific blueprint, and the list can be augmented with information from the provided player if it isn't specified directly (for things like civilization)
--? @args EntityType/Table typeList, PlayerID player[, Bool returnAsTable] 
--? @result EntityBlueprint
function Cardinal_ConvertTypeToEntityBlueprint(typeList, player, returnAsTable)

	Cardinal_TypeToBlueprint_Init()
	
	returnAsTable = returnAsTable or false
	
	if scartype(typeList) ~= ST_TABLE then 
		typeList = {typeList}
	end
	
	
	-- find the appropriate civilization type
	local civ = Cardinal_TypeToBlueprint_GetCivData(typeList)
	if civ == nil then	
		civ = Cardinal_TypeToBlueprint_GetCivData(player)	-- no civ specified, so use the player's civ
	end
	
	-- find the appropriate age type (and default to a "base" type if none found)
	local age = Cardinal_TypeToBlueprint_GetAgeData(typeList)
	if age == nil then
		age = {
			unitType = "scar_base",
			cacheIndex = "base",
			level = AGE_NONE,
		}
	end

	-- get remaining items from the list (stripping out civ and age now we have those broken out)
	local unitTypes = {}
	for index, item in pairs(typeList) do 
		if item ~= civ.unitType and item ~= age.unitType then
			table.insert(unitTypes, item)
		end
	end


	-- create an index string
	local typeIndex = Cardinal_TypeToBlueprint_GenerateTypeIndexString(unitTypes)
	local ageIndex = age.cacheIndex

	-- choose the correct cache depending on the civ
	local civCache = t_TypeToBlueprint_Cache[civ.cacheIndex].ebps

	
	
	if civCache[typeIndex] == nil then
		Cardinal_TypeToBlueprint_CacheEntityBlueprints(unitTypes)		-- we haven't searched for this combo before, generate the list now	
	end
	
	local result = nil
	
	if #civCache[typeIndex][ageIndex] >= 1 then
		result = civCache[typeIndex][ageIndex]
	elseif #civCache[typeIndex]["base"] >= 1 then
		result = civCache[typeIndex]["base"]
	end
	
	if returnAsTable then
		return result or {}
	end
	
	if result ~= nil then
		return result[1]
	end
end



function Cardinal_TypeToBlueprint_Init()
	
	-- initialize the civ data
	if t_TypeToBlueprint_Civs == nil or t_TypeToBlueprint_Ages == nil then
	
		t_TypeToBlueprint_Ages = {
			{unitType = "scar_age1",		cacheIndex = "age1",	level = AGE_DARK	},
			{unitType = "scar_age2",		cacheIndex = "age2",	level = AGE_FEUDAL	},
			{unitType = "scar_age3",		cacheIndex = "age3",	level = AGE_CASTLE	},
			{unitType = "scar_age4",		cacheIndex = "age4",	level = AGE_IMPERIAL},
			{unitType = "scar_all_ages",	cacheIndex = "all"},
		}
		
		t_TypeToBlueprint_Civs = {
			-- this is now auto-generated by the script below
		}

		local GetUnderlyingRace = function(race)		-- campaign has some races that are just proxies that point to one of the existing armyBPs underneath - this function matches the underlying race to the proxy
			if race == RACE.LITHUANIA or race == RACE.HUNGARY or race == RACE.POLAND or race == RACE.BOHEMIA then 
				return RACE.HRE
			elseif race == RACE.DANES or race == RACE.SAXONS then
				return RACE.ENGLISH
			elseif race == RACE.IL_KHANATE_CMP then
				return RACE.MONGOL
			elseif race == RACE.MAMLUK_CMP or race == RACE.SALADIN_CMP or race == RACE.SELJUK_CMP or race == RACE.FATIMID_CMP  then
				return RACE.AYYUBID_CMP
			elseif race == RACE.ANTIOCH_CMP or race == RACE.CYPRUS_CMP then
				return RACE.CRUSADER_CMP
			else
				return race
			end
		end		
		
		for index, raceID in pairs(RACE) do 	-- go through the pre-populated table of raceIDs
			if index ~= "__skipsave" then
				local raceData = {
					raceID = raceID, 
					name = BP_GetName(raceID),	
					cacheIndex = BP_GetName(GetUnderlyingRace(raceID)), 
					unitType = "race_"..BP_GetName(raceID),
				}
				table.insert(t_TypeToBlueprint_Civs, raceData)
			end
		end
		
	end

	-- initialize the cache table
	if t_TypeToBlueprint_Cache == nil then 

		t_TypeToBlueprint_Cache = {}
		
		for index, civ in pairs(t_TypeToBlueprint_Civs) do
			t_TypeToBlueprint_Cache[civ.cacheIndex] = {
				sbps = {},
				ebps = {},
			}
		end
		
	end
	
	
end



function Cardinal_TypeToBlueprint_CacheSquadBlueprints(unitTypes)

	local squadBlueprintList = BP_GetSquadBlueprintsWithType(unitTypes)	-- this is hideously expensive, which is why we're sorting and caching all the results
	local typeIndex = Cardinal_TypeToBlueprint_GenerateTypeIndexString(unitTypes)	

	-- prep an empty entry
	for index, civCache in pairs(t_TypeToBlueprint_Cache) do 
		civCache.sbps[typeIndex] = {
			base = {},
			age1 = {},
			age2 = {},
			age3 = {},
			age4 = {},
			unspecified = {},
			all = {},
		}
	end

	-- sort blueprints into appropriate buckets for each item's race and age
	for index, bp in pairs(squadBlueprintList) do 
		
		-- get civ data for this blueprint
		local bpName = BP_GetName(bp)

		if  BP_GetSquadTypeExtRaceCount(bpName) >= 1 then
		
			local race = BP_GetSquadTypeExtRaceBlueprintAtIndex(bpName, 0)
			
			if race ~= nil then		-- some common units may not have a race, so ignore them
				
				local civData = Cardinal_TypeToBlueprint_GetCivData(race)
				local civIndex = civData.cacheIndex		
		
				-- get age data for this blueprint
				local ageIndex = "unspecified"
				for i, age in pairs(t_TypeToBlueprint_Ages) do 
					if Squad_IsSBPOfType(bp, age.unitType) then
						ageIndex = age.cacheIndex
						break
					end
				end
				
				table.insert(t_TypeToBlueprint_Cache[civIndex].sbps[typeIndex][ageIndex], bp)
				table.insert(t_TypeToBlueprint_Cache[civIndex].sbps[typeIndex].all, bp)
				
			end
		end		
	end
		
	-- fill in any gaps
	for index, civCache in pairs(t_TypeToBlueprint_Cache) do
	
		local cache = civCache.sbps[typeIndex]
		
		-- for all of these blueprints, make the "base" age point at the lowest possible age unit.
		if #cache.base == 0 then
		
			if #cache.age1 >= 1 then 
				cache.base = Clone(cache.age1)
			elseif #cache.age2 >= 1 then 
				cache.base = Clone(cache.age2)
			elseif #cache.age3 >= 1 then 
				cache.base = Clone(cache.age3)
			elseif #cache.age4 >= 1 then 
				cache.base = Clone(cache.age4)
			elseif #cache.unspecified >= 1 then 
				cache.base = Clone(cache.unspecified)
			end
			
		end
		
		-- now fill in any age entries that are empty (copy in whatever is the highest of the ages underneath, falling back to base if necessary)
		
		
	end
	
	

	

end



function Cardinal_TypeToBlueprint_CacheEntityBlueprints(unitTypes)

	local entityBlueprintList = BP_GetEntityBlueprintsWithType(unitTypes)	-- this is hideously expensive, which is why we're sorting and caching all the results
	local typeIndex = Cardinal_TypeToBlueprint_GenerateTypeIndexString(unitTypes)	

	-- prep an empty entry
	for index, civCache in pairs(t_TypeToBlueprint_Cache) do 
		civCache.ebps[typeIndex] = {
			base = {},
			age1 = {},
			age2 = {},
			age3 = {},
			age4 = {},
			unspecified = {},
			all = {},
		}
	end

	-- sort blueprints into appropriate buckets for each item's race and age
	for index, bp in pairs(entityBlueprintList) do
		
		local bpName = BP_GetName(bp)
		
		if BP_GetEntityTypeExtRaceCount(bpName) >=1 then
			
			local race = BP_GetEntityTypeExtRaceBlueprintAtIndex(bpName, 0)
			
			if race ~= nil then
			
				local civData = Cardinal_TypeToBlueprint_GetCivData(race)
				local civIndex = civData.cacheIndex		
		
				-- get age data for this blueprint
				local ageIndex = "unspecified"
				---------------------------------------------------
				--Removing this while Entities do not have ages in their types--
				---------------------------------------------------
				--for i, age in pairs(t_TypeToBlueprint_Ages) do 
					--if Entity_IsEBPOfType(bp, age.unitType) then
						--ageIndex = age.cacheIndex
						--break
					--end
				--end
				---------------------------------------------------
				
				table.insert(t_TypeToBlueprint_Cache[civIndex].ebps[typeIndex][ageIndex], bp)
				table.insert(t_TypeToBlueprint_Cache[civIndex].ebps[typeIndex].all, bp)
			
			end
		end
	end
		
	-- fill in any gaps
	for index, civCache in pairs(t_TypeToBlueprint_Cache) do
	
		local cache = civCache.ebps[typeIndex]
		
		-- for all of these blueprints, make the "base" age point at the lowest possible age unit.
		if #cache.base == 0 then
		
			if #cache.age1 >= 1 then 
				cache.base = Clone(cache.age1)
			elseif #cache.age2 >= 1 then 
				cache.base = Clone(cache.age2)
			elseif #cache.age3 >= 1 then 
				cache.base = Clone(cache.age3)
			elseif #cache.age4 >= 1 then 
				cache.base = Clone(cache.age4)
			elseif #cache.unspecified >= 1 then 
				cache.base = Clone(cache.unspecified)
			end
			
		end
		
		-- now fill in any age entries that are empty (copy in whatever is the highest of the ages underneath, falling back to base if necessary)
		
		
	end
	
	

	

end

-- take a table of unit types and make something that can be used as a string index
function Cardinal_TypeToBlueprint_GenerateTypeIndexString(unitTypes)

	table.sort(unitTypes)			-- sort the table alphabetically, so they're always in the same order
	local typeIndex = ""
	
	for index, unitType in ipairs(unitTypes) do 
		if typeIndex ~= "" then	typeIndex = typeIndex..":" end	-- add a seperator if this isn't the first item
		typeIndex = typeIndex..unitType							-- add on this unit type to the final index string
	end

	return typeIndex

end





-- return the civ data table relating to a particular thing
function Cardinal_TypeToBlueprint_GetAgeData(item)


	if scartype(item) == ST_STRING then					-- age unitType (i.e. "scar_age1")
	
		for i, age in pairs(t_TypeToBlueprint_Ages) do 
			if age.unitType == item then
				return age
			end
		end
	
	elseif scartype(item) == ST_TABLE then				-- table of unitTypes, see if any of these are an age unitType
		
		for index, unitType in pairs(item) do 
			for i, age in pairs(t_TypeToBlueprint_Ages) do 
				if age.unitType == unitType then
					return age
				end
			end
		end
		
	elseif scartype(item) == ST_NUMBER then				-- age level (i.e. AGE_DARK)
	
		for i, age in pairs(t_TypeToBlueprint_Ages) do 
			if age.level == item then
				return age
			end
		end
	
	end
	
end





-- return the civ data table relating to a particular thing
function Cardinal_TypeToBlueprint_GetCivData(item) 

	if scartype(item) == ST_PLAYER then					-- player ID
		
		local playerCiv = Player_GetRace(item)
		
		for index, civ in pairs(t_TypeToBlueprint_Civs) do 
			if civ.raceID == playerCiv then 
				return civ
			end
		end
		
	elseif scartype(item) == ST_PBG then				-- race ID
	
		for index, civ in pairs(t_TypeToBlueprint_Civs) do 
			if civ.raceID == item then 
				return civ
			end
		end
		
	elseif scartype(item) == ST_STRING then				-- a civilization name
		
		for index, civ in pairs(t_TypeToBlueprint_Civs) do 
			if civ.name == item or civ.unitType == item then 
				return civ
			end
		end
		
	elseif scartype(item) == ST_TABLE then 				-- table of unit types
	
		for index, unitType in pairs(item) do 
			for i, civ in pairs(t_TypeToBlueprint_Civs) do 
				if civ.unitType == unitType then
					return civ
				end
			end
		end
	
	end
	
end

--? @shortdesc Enables or disables all Xbox UI elements except those passed in. Useful for bringing back most but not all elements in missions that don't use the full HUD. t_flagsToIgnore needs to be a table of visual flag enums (e.g. VF_XboxUIContextualRadial). No effect if not on a controller.
--? @args Bool b_enable, Array t_flagsToIgnore
function Cardinal_EnablePartialXboxUI (b_enable, t_flagsToIgnore)
	
	-- do nothing if we aren't on a controller
	if not UI_IsXboxUI() then
		return
	end
	
	-- list of all the individual Xbox UI flags
	local t_flagsToEnable = {
		VF_XboxUIBuildQueue,
		VF_XboxUIContextualRadial,
		VF_XboxUIControlGroups,
		VF_XboxUIFindMenu,
		VF_XboxUIMinimapFocus,
		VF_XboxUIQueueModifier,
		VF_XboxUIQuickCommands,
		VF_XboxUIQuickFind,
		VF_XboxUIResourceCard,
		VF_XboxUISelectAllOnScreen,
		VF_XboxUISiteMenu,
		VF_XboxUIVillagerPriorities, 
	}
	
	
	local function RemoveItemsFromMasterList (t_items, t_masterList)
		local j = 1 -- this serves as the current earliest free location in the cut down table
		local n = #t_masterList -- this stores the original size of the table so we can freely cut from the table
		
		for i = 1,n do
			-- if the current item is in the exclusion list, then make it nil
			if Table_Contains(t_items, t_masterList[i]) then
				t_masterList[i] = nil
			else
				--if not, check if the we are in the current earliest available position
				--if so, do nothing
				--if not, move the current item to that position and then wipe it from its current position
				if i ~= j then
					t_masterList[j] = t_masterList[i]
					t_masterList[i] = nil
				end
				-- either way, we now increment the earliest available position
				j = j + 1
			end
		end
	end
	
	-- if we didn't get a list of flags to ingnore, then toggle the whole xbox UI
	if t_flagsToIgnore == nil or #t_flagsToIgnore == 0 then
		Game_SetVisibility(VF_XboxUI, b_enable)
	else
		RemoveItemsFromMasterList(t_flagsToIgnore, t_flagsToEnable)
		for k,v in pairs (t_flagsToEnable) do
			Game_SetVisibility (v, b_enable)
		end
	end

end

--? @shortdesc Prints out a series of strings, forcing them to use fixed spacing. This allows the printing
--? of many lines, where the items will always line up with each other.
--? @args A table of tables, where each item (sub-table) contains 2 things. The first is a string, and the
--? second is an integer describing how much width that string is allowed to take up
function printColumns(items)
	local full_string = ""
	for i, item in ipairs(items) do
		local str = item[1]
		local width = item[2]
		if width == nil then
			width = string.len(str) + 1
		end
		local truncated_str = string.sub(str, 1, width-1)
		local truncated_str_len = string.len(truncated_str)
		local buffer = ""
		for i = 1, (width - truncated_str_len) do
			buffer = buffer.." "
		end
		full_string = full_string..truncated_str
		if i ~= #items then
			full_string = full_string..buffer
		end
	end
	print(full_string)
end