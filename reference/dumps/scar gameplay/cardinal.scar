-----------------------------------------------------------------------
-- Debug Helpers
-----------------------------------------------------------------------

local CARDINAL_ALERT_MUTED = "cardinal_alert_muted"
local CARDINAL_ALERT_CURRENT_MESSAGE = "cardinal_alert_muted_current_msg"

function cardinal_alert(msg)
	
	-- if rtm or dev, do nothing
	if Game_IsRTM() then
		return
	end
	
	if Misc_IsCommandLineOptionSet("campaign_debug") then
		
		if _G[CARDINAL_ALERT_MUTED]==nil then
			_G[CARDINAL_ALERT_MUTED] = {}
		end
		
		-- check if this message is muted
		local ismuted = _G[CARDINAL_ALERT_MUTED][msg]
		if ismuted then
			-- do nothing
			print("Muted Alert: ".. msg)
			
		else
			-- store this so we can check them in the callbacks
			_G[CARDINAL_ALERT_CURRENT_MESSAGE] = msg
			
			UI_MessageBoxSetText("ALERT", msg)
			UI_MessageBoxSetButton(DB_Button1, "CONTINUE", "Continue", "", true)
			UI_MessageBoxSetButton(DB_Button2, "MUTE AND CONTINUE", "Mute and Continue", "", true)
			UI_MessageBoxShow(DC_Default, DebugMessageUI_ButtonClicked)
			
		end -- ismuted
		
	else -- campaign_debug
		
		-- not in campaign debug and not RTM, so let the user see the FSE so it can be reported as bug
		error("Check Callstack. Error: "..msg)
	
	end -- !campaign_debug
end

function DebugMessageUI_ButtonClicked(button)
	
	if _G[CARDINAL_ALERT_MUTED]~=nil then
		_G[CARDINAL_ALERT_MUTED] = {}
	end
	
	local msg = _G[CARDINAL_ALERT_CURRENT_MESSAGE]
	
	if button == DB_Button1 then
		
		_G[CARDINAL_ALERT_MUTED][msg] = false
		_G[CARDINAL_ALERT_CURRENT_MESSAGE] = nil
	
	elseif button == DB_Button2 then
	
		_G[CARDINAL_ALERT_MUTED][msg] = true
		_G[CARDINAL_ALERT_CURRENT_MESSAGE] = nil
	
	end
end


-----------------------------------------------------------------------
-- Core callbacks
-----------------------------------------------------------------------


function Project_OnGameSetup()

end



function Project_Preset()

end



function Project_InitComplete()


	--
	-- Initialize the mission objectives found in g_missionData.objectives
	--
	
	if scartype(__t_Objectives) == ST_TABLE then
		
		for index, objective in pairs(__t_Objectives) do 

			-- if this objective has a cheat key function, add it to the menu
			if scartype(objective.Cheat) == ST_FUNCTION then
				
				local cheatObjectiveTitle = "Skip to objective \""..Loc_ToAnsi(objective.Title).."\""
				local cheatObjectiveID = tostring(objective.ID)
				
				if objective.CheatTitle ~= nil then
					cheatObjectiveTitle = objective.CheatTitle
				end
				
				CheatMenu_AddMenuItem(cheatObjectiveTitle, true, "objective", cheatObjectiveID)

			end
			
		end
		
	end
	

end



function Project_Start()

	--	
	-- run the title card sequence
	--
	
	if scartype(g_missionData.titleCards) == ST_TABLE then

		local date = g_missionData.titleCards.date
		local location = g_missionData.titleCards.location
		local icon = g_missionData.titleCards.icon or "icons/campaign/campaign_angevin_the_conquest"
		
		Game_SubTextFadeWithIcon(location or 0, date or 0, 0, 0.5, 4, 0.5, icon)	-- not wrapped in an event as there may be speech going on
		
	end
	
	-- TEMP: Setup Broadcast functions
	Setup_BroadcastInit()

end




-- called when a mission cheat menu is activated
function Project_ActivateMenuItem(mode, value)

	if mode == "objective" then
	
		-- obj-mode requires the cheat system to go through the mission restart process
		
		CheatMenu_SetValues(mode, value)		-- set the persistent values to catch on the other side...
		CheatMenu_RestartGame()					-- ...and restart the mission
		
	end

end


-- called when a game is run/restarted with some cheat codes
function Project_StartWithCheat(mode, value)

	if mode == "objective" then
		
		local id = tonumber(value)
		local objective = __FindObjectiveTable(id)						-- find the actual objective from the id passed in
		
		if scartype(objective.Cheat) == ST_FUNCTION then
			objective.Cheat()											-- call the cheat setup script
		end
		
		if objective.Parent ~= nil then									-- if this objective has a parent objective, cheat that one first!
			Objective_Start(objective.Parent, false, false)
		end
		
		Objective_Start(objective)										-- start the objective
		
	end

end

function OnReplayStingerEnded(stingerId)
	-- Hack: There is a issue that LiveObserverSynchronization halts simulation ticking after game ends. 
	-- Because of that, Core_DelayedGameOver as a one shot rule won't be fired, then the game will never end.
	-- Force to end match until we fix the bug.
	if UI_IsLiveReplayGame() then
		World_SetGameOver(WR_NONE)
	end
end

function Project_PreGameOver(reason)
	Misc_SetDefaultCommandsEnabled(false)
	
	-- play replay game over stinger
	if UI_IsReplay() then
		Taskbar_SetVisibility(false)	
		-- TODO: Play replay game over stinger sound
		-- Sound_Play2D(replayGameOverStingerSound)
		UI_StingerPlay(Loc_GetString(11181699), Loc_Empty(), "", "stinger_game_complete", "", OnReplayStingerEnded)
		Sound_Play2D(MUS_STING_STOP_ALL_REPLAY)
	end			
end

-- Called when Core_SetGameOver() is invoked.
function Project_OnGameOver()
	
end

function OnStingerEnded(stingerId)
end

-- (Temporary) Displays game over screen.
--
-- Usage: Rule_AddOneShot(_gameOver_message, 1, {_player = Game_GetLocalPlayer(), _icon = "icons\\dev\\dev_placeholder_conquest", _endType = "CONQUEST", _message = "Conquest Victory!", _sound = "victory_stab_play", _videoURI = "victory_v_standalone"})
function _gameOver_message(id, data)
	print("GAME OVER")
	
	-- no player specified game over stinger for replay. 	
	-- the unique replay game over stinger is played in Project_PreGameOver() above
	if UI_IsReplay() then
		return
	end	
	
	local player = data._playerID	
	if player == Game_GetLocalPlayer() then
		-- hide all other UI
		Taskbar_SetVisibility(false)
		
		local gameoverSound = data._sound
		if gameoverSound ~= nil then
			Sound_Play2D(gameoverSound)
		end		
		
		local title = data._endType
		if scartype(title) ~= ST_LOCSTRING then
			title = Loc_Empty()
		end		
		local message = data._message
		if scartype(message) ~= ST_LOCSTRING then
			message = Loc_Empty()
		end		
		local icon = data._icon
		if scartype(icon) ~= ST_STRING then
			icon = ""
		end		
		local video = data._videoURI
		if scartype(video) ~= ST_STRING then
			video = ""
		end
		local callback = data._callback
		if scartype(callback) ~= ST_FUNCTION then
			callback = OnStingerEnded
		end
		local dataTemplate = ""
		UI_StingerPlay(title, message, icon, video, dataTemplate, callback)
	end	
end



-----------------------------------------------------------------------
-- Utility Functions
-----------------------------------------------------------------------

--? @shortdesc Returns a number corresponding to the player's latest age upgrade. 
--? @extdesc The result is a number from 1 to 4, but they are also mapped onto these constants: AGE_DARK, AGE_FEUDAL, AGE_CASTLE or AGE_IMPERIAL
--? @args PlayerID player
--? @result Int
function Player_GetCurrentAge(playerID)		

	if Player_HasUpgrade(playerID, BP_GetUpgradeBlueprint("imperial_age")) then
		return AGE_IMPERIAL
	elseif Player_HasUpgrade(playerID, BP_GetUpgradeBlueprint("castle_age")) then
		return AGE_CASTLE
	elseif Player_HasUpgrade(playerID, BP_GetUpgradeBlueprint("feudal_age")) then
		return AGE_FEUDAL
	else
		return AGE_DARK
	end
	
end

--? @shortdesc Sets the current age of a player 
--? @extdesc Age can be a number from 1 to 4, or any one of these: AGE_DARK, AGE_FEUDAL, AGE_CASTLE or AGE_IMPERIAL
--? @args PlayerID player, Int age
function Player_SetCurrentAge(playerID, age)		

	local feudalAge = BP_GetUpgradeBlueprint("feudal_age")
	local castleAge = BP_GetUpgradeBlueprint("castle_age")
	local imperialAge = BP_GetUpgradeBlueprint("imperial_age")
	
	if age >= AGE_IMPERIAL then 
		if Player_HasUpgrade(playerID, imperialAge) == false then
			Player_CompleteUpgrade(playerID, imperialAge)
		end
	else
		if Player_HasUpgrade(playerID, imperialAge) == true then
			Player_RemoveUpgrade(playerID, imperialAge)
		end
	end

	if age >= AGE_CASTLE then 
		if Player_HasUpgrade(playerID, castleAge) == false then
			Player_CompleteUpgrade(playerID, castleAge)
		end
	else
		if Player_HasUpgrade(playerID, castleAge) == true then
			Player_RemoveUpgrade(playerID, castleAge)
		end
	end
	
	if age >= AGE_FEUDAL then 
		if Player_HasUpgrade(playerID, feudalAge) == false then
			Player_CompleteUpgrade(playerID, feudalAge)
		end
	else
		if Player_HasUpgrade(playerID, feudalAge) == true then
			Player_RemoveUpgrade(playerID, feudalAge)
		end
	end
	
	-- TEMP - the Age UI doesn't seem to catch Player_CompleteUpgrade() events, so call the update manually
	if scartype(_currentAgeUI) == ST_TABLE and _currentAgeUI.started == true then 
		CurrentAgeUI_UpdateContent()
	end
	
end


--? @shortdesc Sets the maximum age a player can progress to 
--? @extdesc Age can be a number from 1 to 4, or any one of these: AGE_DARK, AGE_FEUDAL, AGE_CASTLE or AGE_IMPERIAL. You cannot build the landmark building at the end of the maximum age.
--? @args PlayerID player, Int age
function Player_SetMaximumAge(playerID, maximumAge)

	-- No need to do anything if the maximum age is Imperial Age
	if maximumAge >= 4 then
		return
	end
	
	local prefixes = {
		chinese = "chi_",
		english = "eng_",
		french = "fre_",
		hre = "hre_",
		mongol = "mon_",
		il_khanate_cmp = "mon_",
		rus = "rus_",
		sultanate = "sul_",
		abbasid = "abb_",
		ayyubid_cmp = "abb_",
		fatimid_cmp = "abb_",
		mamluk_cmp = "abb_",
		saladin_cmp = "abb_",
		seljuk_cmp = "abb_",
		normans = "nrm_",
		crusader_cmp = "cru_",
		antioch_cmp = "cru_",
		cyprus_cmp = "cru_",
		ottoman = "sul_",		-- No specific menus were made for the Ottomans, so yes, they use Sultanate menus
	}
	
	local raceName = Player_GetRaceName(playerID)
	local prefix = prefixes[raceName]
	
	-- Nil check to ensure the race prefix exists
	if prefix ~= nil then 
		
		-- Remove the construction menus for the locked out ages
		if maximumAge < 2 then 
			Player_SetConstructionMenuAvailability(playerID, prefix.."age2", ITEM_REMOVED)
		else
			Player_SetConstructionMenuAvailability(playerID, prefix.."age2", ITEM_DEFAULT)
		end
		
		if maximumAge < 3 then 
			Player_SetConstructionMenuAvailability(playerID, prefix.."age3", ITEM_REMOVED)
		else
			Player_SetConstructionMenuAvailability(playerID, prefix.."age3", ITEM_DEFAULT)
		end
		
		if maximumAge < 4 then 
			Player_SetConstructionMenuAvailability(playerID, prefix.."age4", ITEM_REMOVED)
		else
			Player_SetConstructionMenuAvailability(playerID, prefix.."age4", ITEM_DEFAULT)
		end
		
		-- Special logic needed for the Abbasids because they age up with upgrades instead of landmarks
		if prefix == "abb_" then
			
			-- The initial upgrade is the one available in the Dark age
			if maximumAge < 2 then 
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_CULTURE_WING, ITEM_REMOVED)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_ECONOMY_WING, ITEM_REMOVED)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_MILITARY_WING, ITEM_REMOVED)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_TRADE_WING, ITEM_REMOVED)
			else
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_CULTURE_WING, ITEM_DEFAULT)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_ECONOMY_WING, ITEM_DEFAULT)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_MILITARY_WING, ITEM_DEFAULT)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_TRADE_WING, ITEM_DEFAULT)
			end

			-- Subsequent upgrades are named for the age in which they're available, not the age they lead to
			if maximumAge < 3 then 
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_CULTURE_WING_FEUDAL, ITEM_REMOVED)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_ECONOMY_WING_FEUDAL, ITEM_REMOVED)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_MILITARY_WING_FEUDAL, ITEM_REMOVED)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_TRADE_WING_FEUDAL, ITEM_REMOVED)
			else
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_CULTURE_WING_FEUDAL, ITEM_DEFAULT)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_ECONOMY_WING_FEUDAL, ITEM_DEFAULT)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_MILITARY_WING_FEUDAL, ITEM_DEFAULT)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_TRADE_WING_FEUDAL, ITEM_DEFAULT)
			end
			
			if maximumAge < 4 then
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_CULTURE_WING_CASTLE, ITEM_REMOVED)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_ECONOMY_WING_CASTLE, ITEM_REMOVED)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_MILITARY_WING_CASTLE, ITEM_REMOVED)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_TRADE_WING_CASTLE, ITEM_REMOVED)
				-- The player is allowed to research further wings in the Imperial too
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_CULTURE_WING_IMPERIAL, ITEM_REMOVED)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_ECONOMY_WING_IMPERIAL, ITEM_REMOVED)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_MILITARY_WING_IMPERIAL, ITEM_REMOVED)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_TRADE_WING_IMPERIAL, ITEM_REMOVED)
			else
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_CULTURE_WING_CASTLE, ITEM_DEFAULT)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_ECONOMY_WING_CASTLE, ITEM_DEFAULT)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_MILITARY_WING_CASTLE, ITEM_DEFAULT)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_TRADE_WING_CASTLE, ITEM_DEFAULT)
				
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_CULTURE_WING_IMPERIAL, ITEM_DEFAULT)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_ECONOMY_WING_IMPERIAL, ITEM_DEFAULT)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_MILITARY_WING_IMPERIAL, ITEM_DEFAULT)
				Player_SetUpgradeAvailability(playerID, UPG.ABBASID.UPGRADE_ADD_TRADE_WING_IMPERIAL, ITEM_DEFAULT)
			end
		else
		-- Everyone else needs to remove the relevant landmarks
			if maximumAge < 2 then 
				Player_SetConstructionMenuAvailability(playerID, prefix.."age1_wonders", ITEM_REMOVED)
			else
				Player_SetConstructionMenuAvailability(playerID, prefix.."age1_wonders", ITEM_DEFAULT)
			end
			
			if maximumAge < 3 then 
				Player_SetConstructionMenuAvailability(playerID, prefix.."age2_wonders", ITEM_REMOVED)
			else
				Player_SetConstructionMenuAvailability(playerID, prefix.."age2_wonders", ITEM_DEFAULT)
			end
			
			if maximumAge < 4 then 
				Player_SetConstructionMenuAvailability(playerID, prefix.."age3_wonders", ITEM_REMOVED)
			else
				Player_SetConstructionMenuAvailability(playerID, prefix.."age3_wonders", ITEM_DEFAULT)
			end
		end
				
	end
		
	Player_SetStateModelInt(playerID, "player_max_age", maximumAge)
	
end


--? @shortdesc Returns a number corresponding to the maximum age a player can reach 
--? @extdesc The result is a number from 1 to 4, but they are also mapped onto these constants: AGE_DARK, AGE_FEUDAL, AGE_CASTLE or AGE_IMPERIAL
--? @args PlayerID player
--? @result Int
function Player_GetMaximumAge(playerID)

	return Player_GetStateModelInt(playerID, "player_max_age")
	
end

--? @shortdesc Sets a table of players to all have the same relationships to one another
--? @args TABLE players, Int relationship
--? @result Void
function Player_SetMutualRelationships(players, relationshipStatus)

	-- Can't do anything if there are fewer than 2 valid players in this table
	if scartype(players) ~= ST_TABLE then
		fatal("SetMutualRelationships: No table found for setting mutual relationships")
		return
	end
	
	-- Make sure the table is valid
	for idx = #players, 1, -1 do
		if scartype(players[idx]) ~= ST_PLAYER then
			table.remove(players, idx)
		end
	end
	
	-- Can't do anything if there are fewer than 2 valid players in this table
	if #players < 2 then
		fatal("SetMutualRelationships: Invalid table of players for mutual relationship setting")
		return
	end
	
	local playersCopy = Table_Copy(players)
	
	-- Go through all player-pairs and set mutual relationship
	for ii = 1, #players do
		for jj = ii + 1, #players do
			if players[ii] ~= players[jj] then
				Player_SetRelationship(players[ii], players[jj], relationshipStatus)
				Player_SetRelationship(players[jj], players[ii], relationshipStatus)
			end
		end 
	end 
	
end

--? @shortdesc Move a squad group in a formation to a given position.
--? @extdesc The sgroup can optionally be deleted on arriving within proximity of the marker or within a radius of 10 if there is no marker proximity.
--? @args SGroupID sgroup, Pos/SGroupID/EGroupID/MarkerID destination, [Boolean queued, Boolean deleteOnArrival, Position facingPosition]
--? @result Void
function Cmd_FormationMove(sgroup, destination, queued, deleteOnArrival, facingPosition)
	if queued == nil then queued = false end
	local player = Util_GetPlayerOwner(sgroup)
	
	if not SGroup_IsEmpty(sgroup) and player ~= nil then

		LocalCommand_BeginSendingSquadCommandsAsFormation(player, queued)
		
		if scartype(destination) == ST_SGROUP and offset == nil and player ~= nil then
			LocalCommand_SquadSquad(player,	sgroup,	SCMD_Move, destination,	queued)
		else
			
			if facingPosition ~= nil then	
				LocalCommand_SquadMovePosFacing(player, sgroup, Util_GetPosition(destination), Util_GetPosition(facingPosition), queued, false,	false, 0.0)
			else
				LocalCommand_SquadMovePos(player, sgroup, Util_GetPosition(destination), queued, false, false, 0.0)
			end
			
		end

		LocalCommand_EndSendingSquadCommandsAsFormation()
		
		if deleteOnArrival then
			assert(scartype(deleteOnArrival) == ST_BOOLEAN, "The deleteWhenNearMarker argument of Cmd_FormationMove has changed from a marker to a boolean")
			_AddSquadToBeDeletedOnArrival(sgroup, destination)
		end
	end
end

--? @shortdesc Stops formation of squads
--? @args SGroupID sgroup
--? @result Void
function Cmd_FormationStop(sgroup)

	if queued == nil then queued = false end
	local player = Util_GetPlayerOwner(sgroup)
	
	if not SGroup_IsEmpty(sgroup) and player ~= nil then

		LocalCommand_BeginSendingSquadCommandsAsFormation(player, queued)
		Cmd_Stop(sgroup)
		LocalCommand_EndSendingSquadCommandsAsFormation()
		
	end
	
end

--? @shortdesc Move a squad group in a formation to a given position and delete it when it arrives, potentially calling back a function.
--? @args SGroupID sgroup, Pos/SGroupID/EGroupID/MarkerID destination, [Boolean queued, Position facingPosition, Function callback, Table callbackData]
--? @result Void
function Cmd_FormationMoveToAndDestroy(sgroupid, markerid, queued, facingPosition, callback, callbackData)
	if(SGroup_Count(sgroupid) == 0) then
		fatal("Cannot issue Cmd_FormationMoveToAndDestroy on empty group")
	end
	
	if queued == nil then
		queued = false
	end
	
	Cmd_FormationMove(sgroupid, markerid, queued, false, facingPosition)
	
	_AddSquadToBeDeletedOnArrival(sgroupid, markerid, "delete", callback, callbackData)
end

--? @shortdesc Attack-move a squad group in a formation to a given position
--? @extdesc The sgroup can optionally be deleted on arriving within proximity of the marker or within a radius of 10 if there is no marker proximity.
--? @args SGroupID sgroup, Pos/SGroupID/EGroupID/MarkerID destination, [Boolean queued, Boolean deleteOnArrival, Function deleteCallback, Table deleteCallbackData]
--? @result Void
function Cmd_FormationAttackMove(sgroupid, destination, queued, deleteOnArrival, deleteCallback, deleteCallbackData)

	if queued == nil then queued = false end
	local player = Util_GetPlayerOwner(sgroupid)
	
	if not SGroup_IsEmpty(sgroupid) and player ~= nil then
		
		if scartype(destination) == ST_MARKER then
			destination = Marker_GetPosition(destination)
		elseif scartype(destination) == ST_EGROUP then
			destination = EGroup_GetPosition(destination)
		elseif scartype(destination) == ST_ENTITY then
			destination = Entity_GetPosition(destination)
		elseif scartype(destination) == ST_SGROUP then
			destination = SGroup_GetPosition(destination)
		elseif scartype(destination) == ST_SQUAD then
			destination = Squad_GetPosition(destination)
		end
		
		LocalCommand_BeginSendingSquadCommandsAsFormation(player, queued)
	    Cmd_AttackMove(sgroupid, destination, queued)
	    LocalCommand_EndSendingSquadCommandsAsFormation()
		
		if deleteOnArrival then
			assert(scartype(deleteOnArrival) == ST_BOOLEAN, "The deleteWhenNearMarker argument of Cmd_FormationAttackMove has changed from a marker to a boolean")
			_AddSquadToBeDeletedOnArrival(sgroupid, destination, "delete", deleteCallback, deleteCallbackData)
		end
	end
end

