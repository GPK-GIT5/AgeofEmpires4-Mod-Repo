import("training.scar")

Core_RegisterModule("FrenchTrainingGoals")

--local goal_deploy_pavise = "deploy_pavise"
--local goal_toggle_resource = "goal_toggle_resource"

local training_goals_french =
{
	--goal_deploy_pavise,
	--goal_toggle_resource,
}

function TrainingGoal_EnableFrenchGoals()
	for i, goalSequenceID in ipairs(training_goals_french) do
		Training_EnableGoalSequenceByID(goalSequenceID, true)
	end
end

function TrainingGoal_DisableFrenchGoals()
	for i, goalSequenceID in ipairs(training_goals_french) do
		Training_EnableGoalSequenceByID(goalSequenceID, false)
	end
end

function FrenchTrainingGoals_OnInit()
end

function FrenchTrainingGoals_OnGameOver()
end