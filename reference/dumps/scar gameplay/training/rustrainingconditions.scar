import("training.scar")
import("cardinal.scar")

function UserHasSelectedAScout(goal)
	local scoutBP = Cardinal_ConvertTypeToSquadBlueprint("scar_scout", Game_GetLocalPlayer())
	Misc_GetSelectedSquads(sg_currentSelection, false)
	for i = 1, SGroup_Count(sg_currentSelection) do
		local squad = SGroup_GetSquadAt(sg_currentSelection, i)
		if Squad_GetBlueprint(squad) == scoutBP then
			return true
		end
	end
	
	return false
end

function UserHasViewedHuntingAbility(goal)
	if _g_tempHuntingTimer == nil then
		_g_tempHuntingTimer = Training_GetNewTimerID()
		Timer_Start(_g_tempHuntingTimer, 6)
	else
		local currentTime = Timer_GetRemaining(_g_tempHuntingTimer)
		if currentTime <= 0 then
			Timer_End(_g_tempHuntingTimer)
			_g_tempHuntingTimer = nil
			return true	
		end
	end
end

function HasIdleScoutHuntingOnScreen(goalSequence)
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	if currentTime > __t_trainingLongInterval then	
		local localPlayer = Game_GetLocalPlayer()
		Player_GetAll(localPlayer)
		local scoutBP = Cardinal_ConvertTypeToSquadBlueprint("scar_scout", localPlayer)
		local squads = Player_GetSquads(localPlayer)
		
		goalSequence.goals[1].key = nil
		goalSequence.goals[2].key = nil
		
		for i = 1, SGroup_Count(squads) do
			local squad = SGroup_GetSquadAt(squads, i)
			
			if squad ~= nil and Squad_GetBlueprint(squad) == scoutBP then
				if Misc_IsSquadOnScreen(squad, 100) and Squad_IsIdle(squad) and Player_GetStateModelFloat(localPlayer, "master_hunter_bounty_total_rus") <= 0 then
					goalSequence.goals[1].key = Squad_GetID(squad)
					goalSequence.goals[2].key = "RusBountyTag"
					break
				end
			end
		end
		
		if goalSequence.goals[1].key ~= nil then
			return true
		end
	end
	
	return false
end

function UserHasHunted(goalSequence)
	local localPlayer = Game_GetLocalPlayer()
	if Player_GetStateModelFloat(localPlayer, "master_hunter_bounty_total_rus") > 0 then
			return true
	end
	
	return false
end

