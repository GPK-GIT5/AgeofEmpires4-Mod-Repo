DEBUG_OUTPUT = false -- Toggle debug print to console and other debug displays.
function INTERVAL_FROM_MINUTES( minutes ) return minutes * 60 end

-- Global data table that can be referenced in script functions.
_match = {
	options = {},
	is_cheat_enabled = false,
	is_diplomacy_enabled = false,
	is_tribute_enabled = true,
	is_nomad_start = false,
	speed = {						-- modifier multipliers 
		build = 1,
		repair = 1,
		gather = 1,		
		upgrade = 1,
		production = 1,
		modifiers = {},
	},
	werewolfEvent = {
		wave_interval = INTERVAL_FROM_MINUTES( 6 ),
		sgroup_name = "werewolf_squad",
		blueprint_name = {"gaia_werewolf_1", "gaia_werewolf_2", "gaia_werewolf_3", "gaia_werewolf_4"},
		spawn_positions = {},						-- Old method. Valid spawn positions for werewolves, grouped by closest player index.
		spawn_markers = {},						    -- New method. Valid spawn positions for werewolves, grouped by closest player index.
		spawn_position_count = {},					-- Spawn count per player, both new and old method.
		spawn_distance_cutoff_percent = 0.1,			-- Amount of max distance to use as the cutoff point for spawn positions.
		wave_count = 1,								-- Keep track of how many waves there has been.
		wave_start_count_perplayer = {2, 3, 5},		-- Number of werewolves to start with.
		wave_count_perplayer = 3,					-- Number of werewolves to spawn on the next wave.
		wave_start_multiplier = {0.3, 0.5, 0.5},	-- Starting values of the wave increase multiplier.
		wave_multiplier = 0.5,						-- How much to increase the next wave by as a percentage. 1 = doube, 0.5 = increase by half.
		wave_multiplier_decay = {0.8, 0.75, 0.75},	-- With each wave increase multiply the wave_multiplier amount by this value to reduce the increase over time.
		
		atmosphere = "seasonal_variations/full_moon",
		atmosphere_transition_duration_seconds = 3,
		atmosphere_transitions = {"initial_atmosphere", "night_atmosphere"},
		},
	moonSurgeEventPrompt = {
		event_start_prompt_loc = "$11266159",
		event_end_prompt_loc = "$11266160",
		event_start_prompt_template = "medium_priority",
		event_end_prompt_template = "medium_priority",
		event_start_prompt_sfx = "sfx_ui_event_queue_med_priority_play",
		event_end_prompt_sfx = "sfx_ui_event_queue_med_priority_play",
		event_prompt_position = ECV_Title,
		event_prompt_lifestime = 5,
	},
	all_egroup_name = "all_werewolves_entities",
}

