    "tstl_pipeline": {
      "description": "TypeScript-to-Lua transpilation workflow for game modding",
      "install": "npm install -D typescript-to-lua typescript",
      "cli": "npx tstl",
      "config": "tsconfig.json with tstl.luaTarget",
      "targets": ["JIT", "5.4", "5.3", "5.2", "5.1", "5.0", "universal"],
      "aoe4_types": "@aoemods/aoetypes",
      "library_mode": "tstl.buildMode = 'library' with compilerOptions.declaration = true"
    },
