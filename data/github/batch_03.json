      "description": "Constraints on Lua code running in AoE4's SCAR engine",
      "lua_version": "5.1-compatible (LuaJIT subset)",
      "no_require": "Files loaded via import/Scar_DoFile, not require",
      "no_package_manager": "All code must be self-contained in mod assets",
      "globals_expected": "SCAR expects callbacks and rule functions as globals",
      "naming_convention": "PascalCase for functions (Relic convention)"
    },
    "luals_annotation_system": {
      "description": "LuaLS type annotation system (diverged from EmmyLua at v3.0.0)",
      "prefix": "---",
      "core_annotations": ["@type", "@param", "@return", "@class", "@field", "@alias", "@enum"],
      "advanced_annotations": ["@generic", "@overload", "@operator", "@cast", "@as"],
      "scope_annotations": ["@private", "@protected", "@package", "@deprecated", "@nodiscard"],
      "type_expressions": {
        "union": "TYPE1|TYPE2",
        "array": "TYPE[]",
        "dictionary": "{[string]:TYPE}",
        "table": "table<K,V>",
        "function": "fun(PARAM:TYPE):RETURN"
      }
    },
