      }
    },
    "scar_runtime": {
      "description": "9 Scar_ functions — module loading and debug",
      "module_loading": "Scar_DoFile(path) — primary module loader, no require available",
      "runtime_eval": "Scar_DoString(lua_code) — execute string at runtime",
      "hot_reload": "Scar_Reload() — reload all SCAR scripts",
      "constraint": "No require/import — all files loaded via Scar_DoFile in global scope"
    },
    "essence_toolchain": {
      "description": "C# library for AoE4 Essence engine file formats",
      "repo": "aoemods/AOEMods.Essence",
      "formats": {
        "sga": { "read": true, "write": true, "convert": "directory" },
        "rrtex": { "read": true, "write": false, "convert": "png/jpg/bmp/tga/gif" },
