        "PropertyBagGroup": { "fields": { "PropertyBagGroupID": "number", "PropertyBagGroupModPackID": "number", "PropertyBagGroupType": "number" } }
      },
      "opaque_types": ["Squad", "SGroup", "EGroup", "ScarMarker", "EntityBlueprint", "SquadBlueprint", "AbilityBlueprint", "UpgradeBlueprint", "RaceBlueprint", "Modifier", "PresetColour", "PlayerState", "ResourceAmount", "DecoratorVisibility", "VisibilityFlag", "TargetingType", "EasingType", "TerrainSplatObject", "AIEncounter", "AIEntity", "AIPlayer", "AISquad", "ReticuleBlueprint", "BriefingActorBlueprint", "KillPlayerReason", "AddResourceReason", "ModifierApplicationType"]
