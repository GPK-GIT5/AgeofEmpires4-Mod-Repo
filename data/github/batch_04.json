    "eventrule_architecture": {
      "description": "Event-driven callback system with 4 scope levels",
      "function_count": 22,
      "scope_levels": {
        "global": { "add": "EventRule_AddEvent", "remove": "EventRule_RemoveEvent" },
        "player": { "add": "EventRule_AddPlayerEvent", "remove": "EventRule_RemovePlayerEvent" },
        "entity": { "add": "EventRule_AddEntityEvent", "remove": "EventRule_RemoveEntityEvent" },
        "squad": { "add": "EventRule_AddSquadEvent", "remove": "EventRule_RemoveSquadEvent" }
      },
      "data_variants": "All Add* have *Data variants for callback data passthrough",
      "lifecycle": ["RemoveMe (self-remove)", "RemoveAll", "RemoveRuleIDEvent"],
      "flow_control": ["Pause", "Unpause", "PauseAll", "UnpauseAll", "Refresh"],
      "critical_correction": "No Rule_* prefix exists — all functions use EventRule_* prefix"
    },
