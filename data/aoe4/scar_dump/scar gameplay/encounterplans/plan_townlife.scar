


function TownLifePlan_RegisterPlan()
	
	local townLifePlan = {
		
		name = "TownLife",
		
		phases = {
			
			Main = {
				startFunction = TownLifePlan_MainPhase_Start,
				endFunction = TownLifePlan_MainPhase_End,
			},
			
		},
		
		start = "Main",
		requiresSquadsToStart = false,
		
		defaultGoalData = {
			
			target = REQUIRED,		-- not exactly a value, but this will throw an error if the user leaves this out
			
			canBuild = false,
			
		},		
		
	}
	
	Encounter_RegisterPlan(townLifePlan)
	
end






----
---- Main Phase
----

function TownLifePlan_MainPhase_Start(encounter, options)

	local goal = encounter.goal 

	local aiEncounter = AI_CreateRestoreEncounter(encounter.player, AIEncounterType_TownLife, encounter.encounterID)

	AIEncounter_ResourceGuidance_SquadGroup(aiEncounter, encounter.sgroup)
	AIEncounter_ResourceGuidance_EntityGroup(aiEncounter, encounter.egroup)	
	
	-- set the area for the town life encounter
	AIEncounter_TargetGuidance_SetTarget(aiEncounter, goal.target)
	AIEncounter_TargetGuidance_SetTargetArea(aiEncounter, math.max(goal.range, 15))
	AIEncounter_TargetGuidance_SetTargetLeash(aiEncounter, math.max(goal.range, 15))

	-- disable the constriction ability if canBuild is set to false
	if goal.canBuild == false then
		AIEncounter_EngagementGuidance_EnableConstruction(aiEncounter, false)	
	end
	
	-- trigger the encounter
	AIEncounter_Notify_SetPlayerEventEncounterID(aiEncounter, encounter.callbackID)
	AIEncounter_Trigger(aiEncounter)
	
end


function TownLifePlan_MainPhase_End(encounter)


end
