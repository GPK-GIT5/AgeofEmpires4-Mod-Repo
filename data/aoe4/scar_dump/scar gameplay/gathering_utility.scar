-- Imported for use of convenient temp egroups.
import("scarutil.scar")

--? @shortdesc Gathers resources of various types and puts them into the provided egroups
--? @args 
--? out_eg_allWoodResources: egroup that will be populated with all wood resources
--? out_eg_allStoneResources: egroup that will be populated with all stone resources
--? out_eg_allGoldResources: egroup that will be populated with all gold resources
--? out_eg_allBerries: egroup that will be populated with all berries
--? out_eg_allSheep: egroup that will be populated with all sheep
--? out_eg_allDeer: egroup that will be populated with all deer
--? out_eg_allShoreFish: egroup that will be populated with all shore fish
--? out_eg_allCattle: egroup that will be populated with all Mali Cattle
--? out_eg_allDeepFish: egroup that will be populated with all deep fish
--? @result no return value. Populates the egroups passed in.
function Gathering_FindAllResources(
		out_eg_allWoodResources,
		out_eg_allStoneResources,
		out_eg_allGoldResources,
		out_eg_allBerries,
		out_eg_allSheep,
		out_eg_allDeer,
		out_eg_allShoreFish,
		out_eg_allCattle,
		out_eg_allDeepFish
	)
	World_GetAllNeutralEntities(eg_temp)
	for i = 1, World_GetPlayerCount() do
		EGroup_AddEGroup(eg_temp, Player_GetAllEntities(World_GetPlayerAt(i)))
	end
	
	EGroup_FilterResource(eg_temp, "tree", out_eg_allWoodResources)
	EGroup_FilterResource(eg_temp, "stone", out_eg_allStoneResources)
	EGroup_FilterResource(eg_temp, "gold", out_eg_allGoldResources)
	EGroup_FilterResource(eg_temp, "forage_bush", out_eg_allBerries)
	EGroup_FilterResource(eg_temp, "shore_fish", out_eg_allShoreFish)
	EGroup_FilterResource(eg_temp, "deep_water_fish", out_eg_allDeepFish)
	EGroup_FilterResource(eg_temp, "scar_deer", out_eg_allDeer)
	EGroup_FilterResource(eg_temp, "scar_sheep", out_eg_allSheep)
	EGroup_FilterResource(eg_temp, "animal_cattle_mal", out_eg_allCattle)
end

--? @shortdesc Returns all sheep on the map. Returns live sheep and corpses. 
--? @extdesc This is very expensive, since it will search all entities to find sheep. If you only want sheep
--? that have existed since the game started, consider caching the results of Gathering_FindAllResources
--? at match start and using that.
--? This function allocates an egroup. The caller is responsible for destroying it if needed.
--? @result EGroup written to the parameter passed 
function Gathering_FindAllSheep(out_eg_allSheep)
	-- Note: The egroup system very inconsistently enforces a rule that entities belonging to squads should
	-- not be put into egroups. However, functions like World_GetAllNeutralEntities, EGroup_AddEGroup, and 
	-- EGroup_Duplicate will add entities to an egroup without checking for squad ownership.
	-- The below code relies on this exception. By the time of writing, the use case of doing this for
	-- sheep and deer gathering has been well exercised. As well, we are planning to eventually remove the
	-- distinction between entity and squad groups. Thus, this code puts entities owned by squads into
	-- an egroup.
	World_GetAllNeutralEntities(out_eg_allSheep)
	for i = 1, World_GetPlayerCount() do
		EGroup_AddEGroup(out_eg_allSheep, Player_GetAllEntities(World_GetPlayerAt(i)))
	end
	EGroup_Filter(out_eg_allSheep, "scar_sheep", FILTER_KEEP)
end

--? @shortdesc Returns all deer on the map. Returns live deer and corpses.
--? @extdesc this is very expensive, since it will search all entities to find deer. If you only want deer
--? that have existed since the game started, consider caching the results of Gathering_FindAllResources
--? at match start and using that.
--? This function allocates an egroup. The caller is responsible for destroying it if needed.
--? @result EGroup written to the parameter passed 
function Gathering_FindAllDeer(out_eg_allDeer)
	-- Note: The egroup system very inconsistently enforces a rule that entities belonging to squads should
	-- not be put into egroups. However, functions like World_GetAllNeutralEntities, EGroup_AddEGroup, and 
	-- EGroup_Duplicate will add entities to an egroup without checking for squad ownership.
	-- The below code relies on this exception. By the time of writing, the use case of doing this for
	-- sheep and deer gathering has been well exercised. As well, we are planning to eventually remove the
	-- distinction between entity and squad groups. Thus, this code puts entities owned by squads into
	-- an egroup.
	World_GetAllNeutralEntities(out_eg_allDeer)
	EGroup_Filter(out_eg_allDeer, "scar_deer", FILTER_KEEP)
end

