--? @shortdesc Returns all cattle on the map. Returns live cattle and corpses.
--? @extdesc this is very expensive, since it will search all entities to find cattle. If you only want cattle
--? that have existed since the game started, consider caching the results of Gathering_FindAllResources
--? at match start and using that.
--? This function allocates an egroup. The caller is responsible for destroying it if needed.
--? @result EGroup written to the parameter passed
function Gathering_FindAllCattle(out_eg_allCattle)
	-- Note: The egroup system very inconsistently enforces a rule that entities belonging to squads should
	-- not be put into egroups. However, functions like World_GetAllNeutralEntities, EGroup_AddEGroup, and 
	-- EGroup_Duplicate will add entities to an egroup without checking for squad ownership.
	-- The below code relies on this exception. By the time of writing, the use case of doing this for
	-- sheep and deer gathering has been well exercised. As well, we are planning to eventually remove the
	-- distinction between entity and squad groups. Thus, this code puts entities owned by squads into
	-- an egroup.
	World_GetAllNeutralEntities(out_eg_allCattle)
	for i=1, World_GetPlayerCount() do
		EGroup_AddEGroup(out_eg_allCattle, Player_GetAllEntities(World_GetPlayerAt(i)))
	end
	EGroup_Filter(out_eg_allCattle, "animal_cattle_mal", FILTER_KEEP)
end

--? @shortdesc Returns all farms on the map owned by player.
--? @extdesc this is very expensive, since it will search all entities to find farms.
--? This function allocates an egroup. The caller is responsible for destroying it if needed.
--? @args PlayerID player
--? @result EGroup 
function Gathering_FindAllFarms(player)
	local eg_allFarms = EGroup_CreateUnique("eg_allFarms")
	Player_GetAll(player, eg_allFarms)
	EGroup_Filter(eg_allFarms, "farm", FILTER_KEEP)
	return eg_allFarms
end

--? @shortdesc Send villager a gather command targeting entity entity_deposit
--? @args 
--? player: player that owns villager
--? villager: squad to receive gather command
--? entity_deposit: entity to gather from
function VillagerGatherFromEntityDeposit(player, villager, entity_deposit)
	SGroup_Single(sg_single, villager)
	EGroup_Single(eg_single, entity_deposit)
	LocalCommand_SquadEntity(player, sg_single, SCMD_Gather, eg_single, false)
end

--? @shortdesc Send villager a gather command targeting squad squad_deposit
--? @args 
--? player: player that owns villager
--? villager: squad to receive gather command
--? squad_deposit: squad to gather from
function VillagerGatherFromSquadDeposit(player, villager, squad_deposit)
	SGroup_Single(sg_single, villager)
	SGroup_Single(sg_blah, squad_deposit)
	LocalCommand_SquadSquad(player, sg_single, SCMD_Gather, sg_blah, false)
end

--? @shortdesc Assigns villagers to gather from some resource deposits. dropoff_types can be a table of EBPs or string types.
--? @extdesc villagers will find closest resource to themselves, unless search_from_dropoff is true. In that case,
--? villagers will identify the closest dropoff, and then find the closest resource to that.
--? @args
--? SGroup sg_villagers: should be non-empty
--? SGroup/EGroup resourceDeposits
--? Table dropoff_types: a list of unit_class enums (corresponding to type ext)
--? Bool search_from_dropoff
--? Bool one_villager_per_deposit
function Gathering_AssignVillagersToGather(sg_villagers, resourceDeposits, dropoff_types, search_from_dropoff, one_villager_per_deposit)
	local deposits = EGroup_CreateUnique("eg_deposits")
	EGroup_Duplicate(resourceDeposits, deposits)
	
	local player = Util_GetPlayerOwner(sg_villagers)
	local eg_dropoffs = EGroup_CreateUnique("eg_dropoffs")
	Player_GetAll(player, eg_dropoffs)
	EGroup_Filter(eg_dropoffs, dropoff_types, FILTER_KEEP)
	EGroup_FilterUnderConstruction(eg_dropoffs, FILTER_REMOVE)
	EGroup_FilterSquads(eg_dropoffs, FILTER_REMOVE) --filters packed mongol buildings 
	
	if EGroup_CountSpawned(eg_dropoffs) > 0 or search_from_dropoff == false then
		if scartype(deposits) == ST_EGROUP then
			
			local gatherFromEGroup = function(sgroup, villager_index, villager)
				if EGroup_CountSpawned(deposits) > 0 then
					local entity_deposit = nil
					--find closest deposit
					if search_from_dropoff then
						local dropoff = EGroup_GetClosestEntity(eg_dropoffs, Util_GetPosition(villager))
						entity_deposit = EGroup_GetClosestEntity(deposits, Util_GetPosition(dropoff))
					else
						entity_deposit = EGroup_GetClosestEntity(deposits, Util_GetPosition(villager))	
					end
					--issue gather command
					if Entity_IsPartOfSquad(entity_deposit) then
						VillagerGatherFromSquadDeposit(player, villager, Entity_GetSquad(entity_deposit))
					else
						VillagerGatherFromEntityDeposit(player, villager, entity_deposit)
					end
					--remove entity_deposit from list
					if one_villager_per_deposit then
						EGroup_Remove(deposits, entity_deposit)		
					end
					return false
				else
					return true
				end
			end
			
			SGroup_ForEach(sg_villagers, gatherFromEGroup)
			
		elseif scartype(deposits) == ST_SGROUP then
			
			local gatherFromSGroup = function(sgroup, villager_index, villager)
				if SGroup_CountSpawned(deposits) > 0 then
					local squad_deposit = nil
					--find closest deposit
					if search_from_dropoff then
						local dropoff = EGroup_GetClosestEntity(eg_dropoffs, Util_GetPosition(villager))
						squad_deposit = SGroup_GetClosestSquad(deposits, Util_GetPosition(dropoff))
					else
						squad_deposit = SGroup_GetClosestSquad(deposits, Util_GetPosition(villager))	
					end
					--issue gather command
					VillagerGatherFromSquadDeposit(player, villager, squad_deposit)
					--remove squad_deposit from list
					if one_villager_per_deposit then
						SGroup_Remove(deposits, squad_deposit)		
					end
					return false
				else
					return true
				end
			end
			
			SGroup_ForEach(sg_villagers, gatherFromSGroup)
			
		end
	end	
	EGroup_Destroy(eg_dropoffs)
	EGroup_Destroy(deposits)
end

--? @shortdesc assigns each villager to gather gold.
--? @extdesc villagers will find closest resource to themselves, unless search_from_dropoff is true. In that case,
--? villagers will identify the closest droppoff, and then find the closest resource to that.
--? @args
--? SGroup sg_villagers: Villagers to assign to gather. Should be non-empty.
--? EGroup eg_stoneDeposits: all gold deposits to consider
--? Bool search_from_dropoff
--? Bool one_villager_per_mine
function Gathering_AssignVillagersToGold(sg_villagers, eg_goldDeposits, search_from_dropoff, one_villager_per_mine)
	local dropoff_types = {"gold_mining_camp", "ger", "town_center"}
	Gathering_AssignVillagersToGather(sg_villagers, eg_goldDeposits, dropoff_types, search_from_dropoff, one_villager_per_mine)
end

