import("cardinal.scar")
import("missionomatic/missionomatic.scar")


function Favors_ApplyFavors()
	if favors_have_been_applied ~= true then
		--print("----- Applying Favors -----")
		favors_have_been_applied = true
		for _, player in ipairs(ROGUE_HUMAN_PLAYERS) do
			-- Forward Outposts
			if Player_HasUpgrade(player, BP_GetUpgradeBlueprint("forward_outposts_1")) then
				print("Player has forward_outposts 1")
				_apply_forward_outposts(player, 1)
			elseif Player_HasUpgrade(player, BP_GetUpgradeBlueprint("forward_outposts_2")) then
				print("Player has forward_outposts 2")
				_apply_forward_outposts(player, 2)
			elseif Player_HasUpgrade(player, BP_GetUpgradeBlueprint("forward_outposts_3")) then
				print("Player has forward_outposts 3")
				_apply_forward_outposts(player, 3)
			elseif Player_HasUpgrade(player, BP_GetUpgradeBlueprint("forward_outposts_4")) then
				print("Player has forward_outposts 4")
				_apply_forward_outposts(player, 4)
			end
			-- Township
			if Player_HasUpgrade(player, BP_GetUpgradeBlueprint("township_1")) then
				print("Player has township 1")
				_apply_township(player, 1)
			elseif Player_HasUpgrade(player, BP_GetUpgradeBlueprint("township_2")) then
				print("Player has township 2")
				_apply_township(player, 2)
			elseif Player_HasUpgrade(player, BP_GetUpgradeBlueprint("township_3")) then
				print("Player has township 3")
				_apply_township(player, 3)
			elseif Player_HasUpgrade(player, BP_GetUpgradeBlueprint("township_4")) then
				print("Player has township 4")
				_apply_township(player, 4)
			end
		end
	end
end

function _apply_forward_outposts(player, level)
	t_OutpostMkr = AllMarkers_FromName("mkr_player_outpost", "")
	playerOutpost = Cardinal_ConvertTypeToEntityBlueprint("scar_outpost", player, false)
	EGroup_Clear(eg_temp)
	for i = 1, #t_OutpostMkr do
		local markerPos = Util_GetPosition(t_OutpostMkr[i])
		CreateEntity(player, playerOutpost, markerPos, eg_temp, World_Pos(0, 0, 1), nil , false)
	end	
	if level == 2 then
		if Player_GetRace(player) == RACE.CHINESE or Player_GetRace(player) == RACE.CHINESE_HA_01 then
			EGroup_CompleteUpgrade(eg_temp, UPG.CHINESE.UPGRADE_OUTPOST_HANDCANNONSLITS_CHI)
		elseif Player_GetRace(player) == RACE.MONGOL or Player_GetRace(player) == RACE.MONGOL_HA_GOL then
			EGroup_CompleteUpgrade(eg_temp, UPG.MONGOL.UPGRADE_OUTPOST_ARROWSLITS_MON)
		elseif Player_GetRace(player) == RACE.RUS then
			EGroup_CompleteUpgrade(eg_temp, UPG.RUS.UPGRADE_WOODEN_CASTLE_ARROWSLITS_RUS)
		else
			EGroup_CompleteUpgrade(eg_temp, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
		end
	end
	if level == 3 then
		if Player_GetRace(player) == RACE.BYZANTINE or Player_GetRace(player) == RACE.BYZANTINE_HA_MAC then
			EGroup_CompleteUpgrade(eg_temp, UPG.BYZANTINE.UPGRADE_OUTPOST_MANGONEL_BYZ)
		elseif Player_GetRace(player) == RACE.MONGOL or Player_GetRace(player) == RACE.MONGOL_HA_GOL then
			EGroup_CompleteUpgrade(eg_temp, UPG.MONGOL.UPGRADE_OUTPOST_SPRINGALD_MON)
		elseif Player_GetRace(player) == RACE.RUS then
			EGroup_CompleteUpgrade(eg_temp, UPG.RUS.UPGRADE_WOODEN_CASTLE_SPRINGALD_RUS)
		else
			EGroup_CompleteUpgrade(eg_temp, UPG.COMMON.UPGRADE_OUTPOST_SPRINGALD)
		end
	end
	if level == 4 then
		if Player_GetRace(player) == RACE.MONGOL or Player_GetRace(player) == RACE.MONGOL_HA_GOL then
			EGroup_CompleteUpgrade(eg_temp, UPG.MONGOL.UPGRADE_OUTPOST_CANNON_MON)
		elseif Player_GetRace(player) == RACE.RUS then
			EGroup_CompleteUpgrade(eg_temp, UPG.RUS.UPGRADE_WOODEN_CASTLE_SPRINGALD_RUS)
		else
			EGroup_CompleteUpgrade(eg_temp, UPG.COMMON.UPGRADE_OUTPOST_CANNON)
		end
	end
end

function _apply_township(player, level)
	playerRace = Player_GetRaceName(player)
	
	if playerRace == "mongol" or playerRace == "mongol_ha_gol" then
		mongolsGer = Cardinal_ConvertTypeToEntityBlueprint("ger", player, false)
	end
	
	if level >=1 then
		if playerRace == "mongol" or playerRace == "mongol_ha_gol" then
			-- TODO Add +50 Wood
		else
			if playerRace == "malian" then
				t_HouseMKr = AllMarkers_FromName("mkr_player_mal_house", "") 
			else
				t_HouseMKr = AllMarkers_FromName("mkr_player_house", "")
			end
			playerHouse = Cardinal_ConvertTypeToEntityBlueprint("scar_house", player, false)
			_apply_township_place_buildings(player, t_HouseMKr, playerHouse)
		end		
	end
	
	if level >=2 then
		t_MillMKr = AllMarkers_FromName("mkr_player_mill", "")
		if playerRace == "mongol" or playerRace == "mongol_ha_gol" then
			playerMill = mongolsGer
		else
			playerMill = Cardinal_ConvertTypeToEntityBlueprint("scar_gristmill", player, false)
		end		
		--_apply_township_place_buildings(player, t_MillMKr, playerMill)
		
		if playerRace == "sultanate_ha_tug" then
			_apply_township_place_worker_elephant(player, t_MillMKr)
		else
			_apply_township_place_buildings(player, t_MillMKr, playerMill)
		end
	end
	
	if level >=3 then
		t_LumberMkr = AllMarkers_FromName("mkr_player_lumbercamp", "")
		
		if playerRace == "mongol" or playerRace == "mongol_ha_gol" then
			playerLumber = mongolsGer
		else
			playerLumber = Cardinal_ConvertTypeToEntityBlueprint("scar_lumbercamp", player, false)
		end
		
		if playerRace == "sultanate_ha_tug" then
			_apply_township_place_worker_elephant(player, t_LumberMkr)
		elseif playerRace ~= "templar" then
			_apply_township_place_buildings(player, t_LumberMkr, playerLumber)
		end
	end
	
	if level >=4 then
		if playerRace == "japanese" then
			t_MiningMkr = AllMarkers_FromName("mkr_player_jpn_forge", "")
		else
			t_MiningMkr = AllMarkers_FromName("mkr_player_mine", "")
		end
		
		if playerRace == "mongol" or playerRace == "mongol_ha_gol" then
			playerMining = mongolsGer
		else
			playerMining = Cardinal_ConvertTypeToEntityBlueprint("scar_miningcamp", player, false)
		end
		
		if playerRace == "sultanate_ha_tug" then
			_apply_township_place_worker_elephant(player, t_MiningMkr)
		else
			_apply_township_place_buildings(player, t_MiningMkr, playerMining)
		end
	end
	
end

function _apply_township_place_worker_elephant(player, marker)
	for i = 1, #marker do
		local markerPos = Util_GetPosition(marker[i])
		UnitEntry_DeploySquads(player, nil, {sbp = SBP.SULTANATE_HA_TUG.UNIT_WORKER_ELEPHANT_2_SUL_HA_TUG, numSquads = 1}, markerPos)
	end
end

function _apply_township_place_buildings(player, marker, building)
	for i = 1, #marker do
		local markerPos = Util_GetPosition(marker[i])
		CreateEntity(player, building, markerPos, nil, World_Pos(0, 0, 1), nil , false)
	end	
end

