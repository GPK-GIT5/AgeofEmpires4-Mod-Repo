import("cardinal.scar")

function Rogue_SetupPlayers_A()
	factions = {}
end

function Rogue_AddHumanPlayer(player_index, color)
	ROGUE_HUMAN_FACTIONS = ROGUE_HUMAN_FACTIONS or {}
	ROGUE_HUMAN_PLAYERS = ROGUE_HUMAN_PLAYERS or {}
	
	human_faction_index = human_faction_index or 0
	human_faction_index = human_faction_index + 1
	
	local faction = {}
	faction.player_index = player_index
	faction.player = World_GetPlayerAt(player_index)
	faction.color = color
	faction.type = "human"
	faction.is_enemy = false
	faction.is_human = true
	faction.unit_upgrade_level = 1
	faction.gets_combat_upgrades_from_events = false
	faction.has_tech_tree = false
	table.insert(factions, faction)
	
	table.insert(ROGUE_HUMAN_FACTIONS, faction)
	table.insert(ROGUE_HUMAN_PLAYERS, faction.player)
end

function Rogue_AddEnemyWavePlayer(player_index, name, color)
	local faction = {}
	faction.player_index = player_index
	faction.player = World_GetPlayerAt(player_index)
	faction.color = color
	faction.type = "enemy_wave"
	faction.name = name
	faction.is_enemy = true
	faction.is_human = false
	faction.unit_upgrade_level = 1
	faction.gets_combat_upgrades_from_events = true
	faction.has_tech_tree = true
	table.insert(factions, faction)
	
	ROGUE_ENEMY_WAVE_FACTION = faction
	ROGUE_ENEMY_WAVE_PLAYER = faction.player
end

