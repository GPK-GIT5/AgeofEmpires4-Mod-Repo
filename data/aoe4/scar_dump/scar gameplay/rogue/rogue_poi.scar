--? @shortdesc Changes the owner of an sgroup by replacing it with new squads, so that player upgrades are applied
function Rogue_POI_SetSgroupOwner(sgroup, player)
	
	local _Replace = function(gid, idx, sid)
		local sbp = Squad_GetBlueprint(sid)
		local pos = Util_GetPosition(sid)
		local direction = Util_GetDirection(sid)
		local facing = Util_GetFacingFromDirection(pos, direction)
		UnitEntry_DeploySquads(player, nil, {sbp = sbp, numSquads = 1}, pos, nil, nil, {facing = facing})
		Squad_Destroy(sid)
	end

	SGroup_ForEach(sgroup, _Replace)
end

function Rogue_POI_SetDefaults(poi_table)
	
	for i = 1, #poi_table do
		
		if poi_table[i].sbp_ally ~= nil and poi_table[i].ally_count == nil then
			poi_table[i].ally_count = 1
		end
		
		if poi_table[i].is_available == nil then poi_table[i].is_available = true end
		if poi_table[i].force_spawn == nil then poi_table[i].force_spawn = false end
		if poi_table[i].checks_command_string == nil then poi_table[i].checks_command_string = false end
		if poi_table[i].is_champion == nil then poi_table[i].is_champion = false end
		if poi_table[i].is_special_siege == nil then poi_table[i].is_special_siege = false end
		
		if Misc_IsCommandLineOptionSet(poi_table[i].name) then
			poi_table[i].force_spawn = true
				
			if poi_table[i].checks_command_string then
				local commandLineString = Misc_GetCommandLineString(poi_table[i].name)
				if commandLineString ~= nil and commandLineString ~= "" then
					
					if poi_table[i].is_champion then
						if poi_table[i].sbp_ally ~= nil then
							poi_table[i].sbp_ally = Rogue_POI_GetChampionByName(commandLineString)
						elseif poi_table[i].sbp_ally_center ~= nil then
							poi_table[i].sbp_ally_center = Rogue_POI_GetChampionByName(commandLineString)
						end
					elseif is_special_siege then
						if poi_table[i].sbp_ally ~= nil then
							poi_table[i].sbp_ally = Rogue_POI_GetSiegeByName(commandLineString)
						end
					end
				end
			end
		end
	end
	
	return poi_table
end

--? @shortdesc Checks if a poi type includes a particular entity type
function Rogue_POI_Includes(type_data, entity_type)
	
	if type_data.includes == nil then
		return false
	end
	
	for i = 1, #type_data.includes do
		if type_data.includes[i] == entity_type then
			return true
		end
	end
	return false
end

--? @shortdesc Returns unit data for a given budget
function Rogue_POI_GetUnitData(budget_total, tier)
	
	local budget_half = budget_total * 0.5
	
	local unit1 = Rogue_POI_GetRandomUnitType(tier)
	local unit2 = Rogue_POI_GetRandomUnitType(tier)
	
	local unit_data = nil
	
	if unit1.sbp ~= nil and unit2.sbp ~= nil then
		unit_data = {
			{sbp = unit1.sbp, numSquads = math.ceil(budget_half / unit1.value)},
			{sbp = unit2.sbp, numSquads = math.ceil(budget_half / unit2.value)},
		}
	else
		unit_data = {
			{type = unit1.scar_type, numSquads = math.ceil(budget_half / unit1.value)},
			{type = unit2.scar_type, numSquads = math.ceil(budget_half / unit2.value)},
		}
	end
	
	return unit_data
end

--? @shortdesc Returns random unit entry from unit types
function Rogue_POI_GetRandomUnitType(tier)
	
	local chosen_index = 1
	local highest_score = 0
	
	for i = 1, #t_unit_types do
		
		local unit_type = t_unit_types[i]
		local score = World_GetRand(1,100)
		
		if unit_type.score_multiplier ~= nil then
			score = score * unit_type.score_multiplier
		end
		
		if unit_type.tier ~= tier then
			score = 0
		end
		
		if score > highest_score then
			highest_score = score
			chosen_index = i
		end
	end
	
	return t_unit_types[chosen_index]
end

function Rogue_POI_GetRandomPointType(tier)
	
	local chosen_index = -1
	
	-- check for force spawning
	for i = 1, #t_poi_types do
		if t_poi_types[i].force_spawn == true and t_poi_types[i].is_available == true and chosen_index == -1 and t_poi_types[i].tier == tier then
			chosen_index = i
			t_poi_types[i].is_available = false
		end
	end
	
	
	if chosen_index == -1 then
		
		local t_poi_pool = {} -- selection pool
		
		for i = 1, #t_poi_types do
			
			local poi_type = t_poi_types[i]
			local type_available = poi_type.is_available
			
			-- check for excluded civs
			if poi_type.excluded_civs ~= nil then
				for civ_index = 1, #poi_type.excluded_civs do
					if Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1]) == poi_type.excluded_civs[civ_index] then
						type_available = false
					end
				end
			end
			
			-- check for champion max
			if poi_type.is_champion and poi_champion_count >= POI_CHAMPION_MAX then
				type_available = false
			end
			
			if poi_type.tier ~= tier then
				type_available = false
			end
			
			if type_available then
				if poi_type.weight ~= nil then
					for a = 1, poi_type.weight do
						table.insert(t_poi_pool, i)
					end
				else
					table.insert(t_poi_pool, i)
				end
			end
		end
		
		chosen_index = Table_GetRandomItem(t_poi_pool)
		
		if t_poi_types[chosen_index].can_repeat == nil then
			t_poi_types[chosen_index].is_available = false
		end
	end
	
	-- update champion count
	if t_poi_types[chosen_index].is_champion then
		poi_champion_count = poi_champion_count + 1
	end
	
	return t_poi_types[chosen_index]

end

function Rogue_POI_GetRandomDirection()
	return Table_GetRandomItem(t_poi_directions)
end

--? @shortdesc Sets standard radius on POI markers
function Rogue_POI_SetRadii(marker_name)
	
	local poi_markers = AllMarkers_FromName(marker_name, "")
	for i, poi_marker in ipairs(poi_markers) do
		Marker_SetProximityCircle(poi_marker, POI_MARKER_RADIUS)
	end
end

--? @shortdesc Spawns points of interest
function Rogue_POI_Spawn(marker_name, custom_poi_types, tier, count_used)
	
	local poi_enemy_local = POI_ENEMY
	local poi_markers_tmp = AllMarkers_FromName(marker_name, "")
	
	if #poi_markers_tmp == 0 then
		return
	end
	
	if count_used == nil then count_used = #poi_markers_tmp end
	local poi_markers = {}
	
	if count_used == 1 then
		table.insert(poi_markers, Table_GetRandomItem(poi_markers_tmp))
	else
		poi_markers = Table_GetRandomItem(poi_markers_tmp, count_used)
	end
	
	local ebp_house = nil
	local ebp_mining_camp = nil
	local ebp_lumber_camp = nil
	local ebp_mill = nil
	local ebp_farm = nil
	local sbp_villager = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", ROGUE_HUMAN_PLAYERS[1])
	local sbp_worker_elephant = nil
	
	if Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1]) == "mongol" or Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1]) == "mongol_ha_gol" then
		ebp_mining_camp = Cardinal_ConvertTypeToEntityBlueprint("scar_house", ROGUE_HUMAN_PLAYERS[1])
		ebp_mill = ebp_mining_camp
		ebp_lumber_camp = ebp_mining_camp
	elseif Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1]) == "sultanate_ha_tug" then
		ebp_farm = Cardinal_ConvertTypeToEntityBlueprint("farm", ROGUE_HUMAN_PLAYERS[1])
		ebp_house = Cardinal_ConvertTypeToEntityBlueprint("scar_house", ROGUE_HUMAN_PLAYERS[1])
		sbp_worker_elephant = Cardinal_ConvertTypeToSquadBlueprint("worker_elephant", ROGUE_HUMAN_PLAYERS[1])
	else
		ebp_farm = Cardinal_ConvertTypeToEntityBlueprint("farm", ROGUE_HUMAN_PLAYERS[1])
		ebp_house = Cardinal_ConvertTypeToEntityBlueprint("scar_house", ROGUE_HUMAN_PLAYERS[1])
		ebp_mining_camp = Cardinal_ConvertTypeToEntityBlueprint("scar_miningcamp", ROGUE_HUMAN_PLAYERS[1])
		ebp_mill = Cardinal_ConvertTypeToEntityBlueprint("scar_gristmill", ROGUE_HUMAN_PLAYERS[1])
		ebp_lumber_camp = Cardinal_ConvertTypeToEntityBlueprint("scar_lumbercamp", ROGUE_HUMAN_PLAYERS[1])
	end
	
	if custom_poi_types ~= nil then
		t_poi_types = custom_poi_types
	end
	
	for i, poi_marker in ipairs(poi_markers) do
		
		local ally_created = false
		
		-- get type
		local type_data = Rogue_POI_GetRandomPointType(tier)
		
		print("POI Chosen: "..type_data.name)
		
		-- check for enemy override
		if type_data.enemy_override ~= nil then
			poi_enemy_local = type_data.enemy_override
		end
		
		-- determine title
		local title_entry = type_data.title
		
		if type_data.alt_titles ~= nil then
			
			for alt_index = 1, #type_data.alt_titles do
				
				local title_table = type_data.alt_titles[alt_index]
				local civ_name = title_table[1]
				local title_string = title_table[2]
				
				if Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1]) == civ_name then
					title_entry = title_string
				end
			end
		end
		
		-- create instance data
		poi_count = poi_count + 1
		local poi_instance = {
			index = poi_count,
			type_data = type_data,
			type_name = type_data.name,
			is_discovered = false,
			is_liberated = false,
			is_champion = type_data.is_champion,
			is_keep = type_data.is_keep,
			skip_title = type_data.skip_title,
			marker = poi_marker,
			title = title_entry,
			hpid_title = nil,
			hp_height = type_data.hp_height,
			eg_ally = EGroup_CreateUniqueWithPrefix("eg_poi_ally"),
			sg_ally = SGroup_CreateUniqueWithPrefix("sg_poi_ally"),
			sg_enemy = SGroup_CreateUniqueWithPrefix("sg_poi_enemy"),
		}
		
		-- reveal if force spawned
		if type_data.force_spawn == true then
			Players_RevealArea(ROGUE_HUMAN_PLAYERS, Util_GetPosition(poi_marker), 30)
		end
		
		local nonWorldOwner = type_data.ebpOwner or nil
		-- create main entity
		CreateEntity(nonWorldOwner, type_data.ebp, poi_marker, nil, DIRECTION_FRONT) --Previously Rogue_POI_GetRandomDirection() 
		
		-- create shore entity for coastal poi
		if type_data.is_coastal then
			-- find closest shore marker
			local shore_markers = AllMarkers_FromName("mkr_poi_shore_site", "")
			local shore_marker = Util_GetClosestMarker(poi_marker, shore_markers)
			local shore_owner = nil
			local eg_shore = nil
			
			if Rogue_POI_Includes(type_data, "dock") then
				shore_owner = ROGUE_NEUTRAL_PLAYER
				eg_shore = poi_instance.eg_ally
			end
			
			if type_data.ebp_shore ~= nil then
				CreateEntity(shore_owner, type_data.ebp_shore, shore_marker, eg_shore)
			end
			
			-- shore ally
			if type_data.sbp_ally_shore ~= nil then
				CreateUnits(ROGUE_NEUTRAL_PLAYER, {sbp = type_data.sbp_ally_shore, numSquads = type_data.ally_count}, shore_marker, poi_instance.sg_ally)
				ally_created = true
			end
		end
		
		-- create houses
		if Rogue_POI_Includes(type_data, "house") then
			if ebp_house ~= nil then
				local house_markers = AllMarkers_FromName("mkr_poi_house", "")
				
				for a, house_marker in ipairs(house_markers) do
					CreateEntity(ROGUE_NEUTRAL_PLAYER, ebp_house, house_marker, poi_instance.eg_ally)
					Marker_Destroy(house_marker)
				end
			end
		end
		
		-- create food dropoff
		if Rogue_POI_Includes(type_data, "gristmill") then
	
			local dropoff_marker = Marker_FromName("mkr_poi_dropoff", "")
			
			if Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1]) == "sultanate_ha_tug" then
				UnitEntry_DeploySquads(ROGUE_NEUTRAL_PLAYER, poi_instance.sg_ally, {sbp = sbp_worker_elephant, numSquads = 1 }, dropoff_marker)
			else
				CreateEntity(ROGUE_NEUTRAL_PLAYER, ebp_mill, dropoff_marker, poi_instance.eg_ally)
			end
			Marker_Destroy(dropoff_marker)
		end
		
		-- create farms
		if Rogue_POI_Includes(type_data, "farm") then
			if ebp_farm ~= nil then
				local farm_markers = AllMarkers_FromName("mkr_poi_farm", "")
				
				for a, farm_marker in ipairs(farm_markers) do
					CreateEntity(ROGUE_NEUTRAL_PLAYER, ebp_farm, farm_marker, poi_instance.eg_ally)
					Marker_Destroy(farm_marker)
				end
			end
		end
		
		-- create lumber camp
		if Rogue_POI_Includes(type_data, "lumber_camp") then
			
			local dropoff_marker = Marker_FromName("mkr_poi_dropoff", "")
			
			if Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1]) == "sultanate_ha_tug" then
				UnitEntry_DeploySquads(ROGUE_NEUTRAL_PLAYER, poi_instance.sg_ally, {sbp = sbp_worker_elephant, numSquads = 1 }, dropoff_marker)
			else
				CreateEntity(ROGUE_NEUTRAL_PLAYER, ebp_lumber_camp, dropoff_marker, poi_instance.eg_ally)
			end
			Marker_Destroy(dropoff_marker)
		end
		
		-- create mining camp
		if Rogue_POI_Includes(type_data, "mining_camp") then
			
			-- stone deposit
			local stone_deposit_marker = Marker_FromName("mkr_poi_stone_deposit", "")
			local eg_deposit_stone = EGroup_CreateUniqueWithPrefix("eg_deposit_stone")
			CreateEntity(nil, type_data.ebp_deposit_stone, stone_deposit_marker, eg_deposit_stone)
			Marker_Destroy(stone_deposit_marker)
			
			-- dropoff
			local dropoff_marker_jpn = Marker_FromName("mkr_poi_dropoff_jpn", "")
			local dropoff_marker = Marker_FromName("mkr_poi_dropoff", "")
			
			if Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1]) == "japanese" or Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1]) == "japanese_ha_sen" then
				CreateEntity(ROGUE_NEUTRAL_PLAYER, ebp_mining_camp, dropoff_marker_jpn, poi_instance.eg_ally)
			elseif Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1]) == "sultanate_ha_tug" then
				UnitEntry_DeploySquads(ROGUE_NEUTRAL_PLAYER, poi_instance.sg_ally, {sbp = sbp_worker_elephant, numSquads = 1 }, dropoff_marker)
			else
				CreateEntity(ROGUE_NEUTRAL_PLAYER, ebp_mining_camp, dropoff_marker, poi_instance.eg_ally)
			end
			
			Marker_Destroy(dropoff_marker_jpn)
			Marker_Destroy(dropoff_marker)
		end
		
		-- create keep
		if Rogue_POI_Includes(type_data, "keep") then
			local ebp_keep = Cardinal_ConvertTypeToEntityBlueprint("scar_keep", ROGUE_HUMAN_PLAYERS[1])
			CreateEntity(ROGUE_NEUTRAL_PLAYER, ebp_keep, poi_marker, poi_instance.eg_ally, DIRECTION_FRONT)
		end
		
		-- create outpost
		if Rogue_POI_Includes(type_data, "outpost") then
			
			local ally_outpost_markers = AllMarkers_FromName("mkr_poi_ally_outpost", "")
						
			local ebp_outpost = Cardinal_ConvertTypeToEntityBlueprint("scar_outpost", ROGUE_HUMAN_PLAYERS[1])
			for i = 1, #ally_outpost_markers do
				CreateEntity(ROGUE_NEUTRAL_PLAYER, ebp_outpost, ally_outpost_markers[i], poi_instance.eg_ally)
				Marker_Destroy(ally_outpost_markers[i])
			end
			
			if Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1]) == "rus" then
				Cmd_InstantUpgrade(poi_instance.eg_ally, UPG.RUS.UPGRADE_WOODEN_CASTLE_SPRINGALD_RUS)
			elseif Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1]) == "mongol" then
				Cmd_InstantUpgrade(poi_instance.eg_ally, UPG.MONGOL.UPGRADE_OUTPOST_SPRINGALD_MON)
			elseif Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1]) == "mongol_ha_gol" then
				Cmd_InstantUpgrade(poi_instance.eg_ally, UPG.MONGOL.UPGRADE_OUTPOST_SPRINGALD_MON)
			elseif Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1]) == "byzantine" then
				Cmd_InstantUpgrade(poi_instance.eg_ally, UPG.COMMON.UPGRADE_OUTPOST_STONE)
				Cmd_InstantUpgrade(poi_instance.eg_ally, UPG.BYZANTINE.UPGRADE_OUTPOST_MANGONEL_BYZ)
			elseif Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1]) == "byzantine_ha_mac" then
				Cmd_InstantUpgrade(poi_instance.eg_ally, UPG.COMMON.UPGRADE_OUTPOST_STONE)
				Cmd_InstantUpgrade(poi_instance.eg_ally, UPG.BYZANTINE.UPGRADE_OUTPOST_MANGONEL_BYZ)
			else
				Cmd_InstantUpgrade(poi_instance.eg_ally, UPG.COMMON.UPGRADE_OUTPOST_STONE)
				Cmd_InstantUpgrade(poi_instance.eg_ally, UPG.COMMON.UPGRADE_OUTPOST_SPRINGALD)
			end
		end
		
		-- create monastery
		if Rogue_POI_Includes(type_data, "monastery") then
			local ebp_monastery = Cardinal_ConvertTypeToEntityBlueprint("scar_monastery", ROGUE_HUMAN_PLAYERS[1])
			CreateEntity(ROGUE_NEUTRAL_PLAYER, ebp_monastery, poi_marker, poi_instance.eg_ally)
		end
		
		-- create stable
		if Rogue_POI_Includes(type_data, "stable") then
			local ebp_stable = Cardinal_ConvertTypeToEntityBlueprint("scar_stable", ROGUE_HUMAN_PLAYERS[1])
			CreateEntity(ROGUE_NEUTRAL_PLAYER, ebp_stable, poi_marker, poi_instance.eg_ally)
		end
		
		-- create barracks
		if Rogue_POI_Includes(type_data, "barracks") then
			local ebp_barracks = Cardinal_ConvertTypeToEntityBlueprint("scar_barracks", ROGUE_HUMAN_PLAYERS[1])
			CreateEntity(ROGUE_NEUTRAL_PLAYER, ebp_barracks, poi_marker, poi_instance.eg_ally)
		end
		
		-- create archery range
		if Rogue_POI_Includes(type_data, "archery_range") then
			local ebp_archery_range = Cardinal_ConvertTypeToEntityBlueprint("scar_archeryrange", ROGUE_HUMAN_PLAYERS[1])
			CreateEntity(ROGUE_NEUTRAL_PLAYER, ebp_archery_range, poi_marker, poi_instance.eg_ally)
		end
		
		-- spawn wolves
		if Marker_Exists("mkr_poi_wolf", "") then
			
			local wolf_markers = AllMarkers_FromName("mkr_poi_wolf", "")
			local sg_wolves = SGroup_CreateUnique("sg_wolves")
			
			for i, wolf_marker in ipairs(wolf_markers) do
				UnitEntry_DeploySquads(ROGUE_ENEMY_WAVE_PLAYER, sg_wolves, {{sbp = SBP.GAIA.GAIA_HUNTABLE_WOLF, numSquads = 1 }}, wolf_marker)
				Marker_Destroy(wolf_marker)
			end
			
			SGroup_AddGroup(poi_instance.sg_enemy, sg_wolves)
			
			local _ChangeToGaia = function(gid, idx, sid)
				Squad_SetWorldOwned(sid)
			end
			SGroup_ForEach(sg_wolves, _ChangeToGaia)
		end
		
		-- center ally
		if Marker_Exists("mkr_poi_ally_center", "") then
			local ally_marker_center = Marker_FromName("mkr_poi_ally_center", "")
			if type_data.sbp_ally_center ~= nil then
				UnitEntry_DeploySquads(ROGUE_NEUTRAL_PLAYER, poi_instance.sg_ally, {sbp = type_data.sbp_ally_center, numSquads = 1}, ally_marker_center)
			end
			Marker_Destroy(ally_marker_center)
		end
		
		-- create allied squads
		if Marker_Exists("mkr_poi_ally", "") then
			
			local ally_markers = AllMarkers_FromName("mkr_poi_ally", "")
			
			if type_data.ally_list ~= nil then
				
				local marker_index = 1
				for ally_index = 1, #type_data.ally_list do
					
					local unit_sbp = type_data.ally_list[ally_index]
					
					ally_created = true
					CreateUnits(ROGUE_NEUTRAL_PLAYER, {sbp = unit_sbp, numSquads = 1}, ally_markers[marker_index], poi_instance.sg_ally)
					
					marker_index = marker_index + 1
					if marker_index > #ally_markers then
						marker_index = 1
					end
				end
				
				for i, ally_marker in ipairs(ally_markers) do
					Marker_Destroy(ally_marker)
				end
			end
			
			
			for i, ally_marker in ipairs(ally_markers) do
				
				if type_data.ally_count ~= nil then
					
					UnitEntry_DeploySquads(ROGUE_NEUTRAL_PLAYER, poi_instance.sg_ally, {sbp = type_data.sbp_ally, numSquads = type_data.ally_count}, ally_marker)
					
					-- spawn sheep
					if type_data.sheep_count ~= nil then
						
						poi_instance.sg_ally_sheep = SGroup_CreateUniqueWithPrefix("sg_sheep")
						
						for sheep_index = 1, type_data.sheep_count do
							local pos = Util_GetOffsetPosition(ally_marker, sheep_index, 4)
							UnitEntry_DeploySquads(ROGUE_NEUTRAL_PLAYER, poi_instance.sg_ally_sheep, {{sbp = SBP.GAIA.GAIA_HERDABLE_SHEEP, numSquads = 1 }}, pos)
						end
					end
					
					ally_created = true
					Marker_Destroy(ally_marker)
					
				elseif type_data.units_data_ally ~= nil then
					
					CreateUnits(ROGUE_NEUTRAL_PLAYER, type_data.units_data_ally, ally_marker, poi_instance.sg_ally)
					ally_created = true
					Marker_Destroy(ally_marker)
				end
			end
		end
			
		-- Prevent attacks on captors
		if ally_created then
			Cmd_HoldPosition(poi_instance.sg_ally)
			if type_data.civilian_ally == nil then
				Modify_WeaponEnabled(poi_instance.sg_ally, "hardpoint_01", false)
			end
		end
		
		-- check for preplaced tents
		if EGroup_Exists("eg_poi_tents") then
			if EGroup_CountSpawned(eg_poi_tents) > 0 then
				Util_SetPlayerOwner(eg_poi_tents, poi_enemy_local)
			end
		end
		
		-- create pickups
		if Marker_Exists("mkr_poi_pickup", "") then
			
			local pickup_markers = AllMarkers_FromName("mkr_poi_pickup", "")
			poi_instance.eg_pickups =  EGroup_CreateUniqueWithPrefix("eg_poi_pickups_")
			
			for i, marker in ipairs(pickup_markers) do
				
				if type_data.ebp_pickup ~= nil then
					Util_CreateEntities(poi_enemy_local, poi_instance.eg_pickups, type_data.ebp_pickup, marker, 1)
				elseif type_data.rand_pickups == true then
					local randomPickup = Table_GetRandomItem({
							BP_GetEntityBlueprint("resource_pickup_gold_rogue"),
							BP_GetEntityBlueprint("resource_pickup_food_rogue"),
							BP_GetEntityBlueprint("resource_pickup_wood_rogue")
						})
					Util_CreateEntities(poi_enemy_local, poi_instance.eg_pickups, randomPickup, marker, 1)
				end
				Marker_Destroy(marker)
			end
		end
		
		-- create armies
		local poi_army_markers = AllMarkers_FromName("mkr_poi_army", "")
		local units_data = nil
		
		if type_data.units_data == nil then
			
			local budget = type_data.reward_value
			
			-- adjust budget slightly for difficulty
			budget = GetIntegerInExponentialRange((0.65 * budget), budget)
			
			-- adjust budget based on the number of army markers
			budget = math.floor(budget / #poi_army_markers)
			
			units_data = Rogue_POI_GetUnitData(budget, tier)
		else
			units_data = type_data.units_data
		end
		
		for i, marker in ipairs(poi_army_markers) do
			
			if type_data.is_naval == nil then
				
				poi_army_count = poi_army_count + 1
				
				local player_army = poi_enemy_local
				
				if type_data.guard_owner ~= nil then
					player_army = type_data.guard_owner
				end
				
				-- create army
				local camp_army_params = {
					name = "poi_army"..tostring(poi_army_count),
					player = player_army,
					spawn = marker,
					targetOrder = TARGET_ORDER_PATROL,
					targets = {Util_GetPosition(marker)},
					units = units_data
				}
				local army = Army_Init(camp_army_params)
				local sgroup = Army_GetSGroup(army)
				
				SGroup_AddGroup(poi_instance.sg_enemy, sgroup) 
			else
				UnitEntry_DeploySquads(poi_enemy_local, poi_instance.sg_enemy, units_data, marker)
			end

			Marker_Destroy(marker)
		end
		
		--Runs a custom POI Init funciton if one is declared
		if type_data.customInitFunc ~= nil then
			type_data.customInitFunc(poi_instance)
		end
		
		--Passes through a custom Liberation function if it exists
		if type_data.customLiberationFunc ~= nil then
			poi_instance.customLiberationFunc = type_data.customLiberationFunc
		end
		
		table.insert(t_poi_instances, poi_instance)
	end
	
	Rule_AddOneShot(Rogue_POI_StartTracking, 0.25)
end

function Rogue_POI_StartTracking()
	Rule_AddInterval(Rogue_POI_Track, 1)
end

function Rogue_POI_Track()
	local all_liberated = true
	
	for i, poi_instance in ipairs(t_poi_instances) do
		
		if poi_instance.is_discovered == false then
			
			all_liberated = false
			
			if Players_AreSquadsNearMarker(ROGUE_HUMAN_PLAYERS, poi_instance.marker) then
				
				Players_RevealArea(ROGUE_HUMAN_PLAYERS, Util_GetPosition(poi_instance.marker), 20, 20)
				poi_instance.is_discovered = true
				
				if poi_instance.skip_title == nil then
					
					local title_height = 6
					if poi_instance.hp_height ~= nil then
						title_height = poi_instance.hp_height
					end
					
					poi_instance.hpid_title = HintPoint_Add(poi_instance.marker, true, poi_instance.title, title_height, HPAT_Hint)
				end
			end
			
		elseif poi_instance.is_liberated == false then
			
			all_liberated = false
			
			if poi_instance.customLiberationFunc ~= nil then
				
				if poi_instance.customLiberationFunc(poi_instance) == true then
					HintPoint_Remove(poi_instance.hpid_title)
					poi_instance.is_liberated = true
				end				
				
			else
				if SGroup_CountSpawned(poi_instance.sg_enemy) == 0 then
					
					Rogue_POI_SetSgroupOwner(poi_instance.sg_ally, ROGUE_HUMAN_PLAYERS[1])
					
					if EGroup_IsHoldingAny(poi_instance.eg_ally) then
						poi_tempSGroup = SGroup_CreateUnique("poi_tempSGroup")
						EGroup_GetSquadsHeld(poi_instance.eg_ally, poi_tempSGroup)
						Rule_AddOneShot(Rogue_POI_SetOwnerDelayed, 0.25)
					end
					Util_SetPlayerOwner(poi_instance.eg_ally, ROGUE_HUMAN_PLAYERS[1])
					
					-- check for sheep
					if poi_instance.sg_ally_sheep ~= nil then
						Util_SetPlayerOwner(poi_instance.sg_ally_sheep, ROGUE_HUMAN_PLAYERS[1])
					end
					
					-- increment keep count
					if poi_instance.is_keep then
						local totalKeeps = Player_GetStateModelInt(ROGUE_HUMAN_PLAYERS[1], "total_keep_count")
						Player_SetStateModelInt(ROGUE_HUMAN_PLAYERS[1], "total_keep_count", totalKeeps + 1)
					end
					
					-- increment champion challenge
					if poi_instance.is_champion then
						print("Champion Rescued!")
						Game_SendCustomChallengeEvent(ROGUE_HUMAN_PLAYERS[1], CE_ROGUECHAMPIONSCHAMPIONCOMPLETED, 1)
					end
					
					if poi_instance.skip_title == nil then
						HintPoint_Remove(poi_instance.hpid_title)
					end
						
					poi_instance.is_liberated = true

				end
			end
		end
	end
	
	if all_liberated == true then
		Rule_RemoveMe()	
	end

end

function Rogue_POI_SetOwnerDelayed()
	if poi_tempSGroup ~= nil then
		SGroup_SetPlayerOwner(poi_tempSGroup, ROGUE_HUMAN_PLAYERS[1])
		SGroup_Destroy(poi_tempSGroup)
		poi_tempSGroup = nil
	end
end

