--? @shortdesc Returns champion sbp based on player civ
function Rogue_POI_GetFavoredChampion()
	
	local player_civ = Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1])
	
	for i = 1, #t_poi_civ_settings do
		if t_poi_civ_settings[i].civ_name == player_civ then
			local champion_name = Table_GetRandomItem(t_poi_civ_settings[i].favored_champions)
			return Rogue_POI_GetChampionByName(champion_name)
		end
	end
	
	-- return random by default
	return Rogue_POI_GetRandomChampion()
end

--? @shortdesc Returns random champion sbp
function Rogue_POI_GetRandomChampion()
	local random_champion = Table_GetRandomItem(t_champion_types)
	return random_champion.sbp
end

--? @shortdesc Returns special siege sbp based on player civ
function Rogue_POI_GetFavoredSiege()
	
	local player_civ = Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1])
	
	for i = 1, #t_poi_civ_settings do
		if t_poi_civ_settings[i].civ_name == player_civ then
			local siege_name = Table_GetRandomItem(t_poi_civ_settings[i].favored_siege)
			return Rogue_POI_GetSiegeByName(siege_name)
		end
	end
	
	-- return random by default
	return Rogue_POI_GetRandomSiege()
end

--? @shortdesc Returns random special siege sbp
function Rogue_POI_GetRandomSiege()
	local random_siege = Table_GetRandomItem(t_siege_types)
	return random_siege.sbp
end

--? @shortdesc Returns siege sbp by short name
function Rogue_POI_GetSiegeByName(siege_name)
	
	for i = 1, #t_siege_types do
		if t_siege_types[i].name == siege_name then
			return t_siege_types[i].sbp
		end
	end
end

--? @shortdesc Returns champion sbp by short name
function Rogue_POI_GetChampionByName(champion_name)
	
	for i = 1, #t_champion_types do
		if t_champion_types[i].name == champion_name then
			return t_champion_types[i].sbp
		end
	end
end

--? @shortdesc Returns naval sbp based on player civ
function Rogue_POI_GetFavoredNaval()
	
	local player_civ = Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1])
	local sbp_naval = nil
	
	for i = 1, #t_poi_civ_settings do
		if t_poi_civ_settings[i].civ_name == player_civ then
			local naval_type = Table_GetRandomItem(t_poi_civ_settings[i].favored_naval)
			sbp_naval = Cardinal_ConvertTypeToSquadBlueprint(naval_type, ROGUE_HUMAN_PLAYERS[1])
			return sbp_naval
		end
	end
	
	-- return default
	sbp_naval = BP_GetSquadBlueprint("unit_naval_combat_warship_4_rogue")
	return sbp_naval
end

function Rogue_POI_GetUnitTypesByCiv()
	
	local player_civ = Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1])
	local default_types = {"scar_spearman", "scar_archer"}
	
	for i = 1, #t_poi_civ_settings do
		if t_poi_civ_settings[i].civ_name == player_civ then
			return t_poi_civ_settings[i].scar_types
		end
	end
	return default_types
end

function Rogue_POI_GetFavoredTypesByCiv()
	
	local player_civ = Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1])
	local default_types = {"scar_spearman", "scar_archer"}
	
	for i = 1, #t_poi_civ_settings do
		if t_poi_civ_settings[i].civ_name == player_civ then
			return t_poi_civ_settings[i].favored_types
		end
	end
	return default_types
end

function Rogue_POI_GetSpecialUnitByCiv()
	
	local player_civ = Player_GetRaceName(ROGUE_HUMAN_PLAYERS[1])
	local sbp_default = SBP.HRE_HA_01.UNIT_KNIGHT_4_HRE_HA_01
	
	for i = 1, #t_poi_civ_settings do
		if t_poi_civ_settings[i].civ_name == player_civ then
			return t_poi_civ_settings[i].special_unit
		end
	end
	return sbp_default
end

function Rogue_POI_GetRandomUnitDataByCiv(budget)
	local scar_types = Rogue_POI_GetUnitTypesByCiv()
	local unit_type = Table_GetRandomItem(scar_types)
	return Rogue_POI_GetUnitDataByType(unit_type, budget)
end

--? @shortdesc Gets unit data by type for the human player
function Rogue_POI_GetUnitDataByType(unit_type, budget)
	
	local unit_sbp = Cardinal_ConvertTypeToSquadBlueprint(unit_type, ROGUE_HUMAN_PLAYERS[1])
	
	local total_cost = 0
	local cost = Player_GetSquadBPCost(ROGUE_HUMAN_PLAYERS[1], unit_sbp)
	
	total_cost = cost.food + cost.wood + cost.gold + cost.stone + cost.merc_byz
	
	local unit_data = {sbp = unit_sbp, numSquads = math.ceil(budget / total_cost)}
	return unit_data
end

function Rogue_POI_GetAllyUnitsByValue(units, budget)
	
	local unit_list = {}
	while budget > 0 do
		
		local unit = Table_GetRandomItem(units)
		local unit_sbp = unit
		
		if scartype(unit) == ST_STRING then
			unit_sbp = Cardinal_ConvertTypeToSquadBlueprint(unit, ROGUE_HUMAN_PLAYERS[1])
		end
		
		local total_cost = 0
		local cost = Player_GetSquadBPCost(ROGUE_HUMAN_PLAYERS[1], unit_sbp)
		
		total_cost = cost.food + cost.wood + cost.gold + cost.stone + cost.merc_byz
		
		table.insert(unit_list, unit_sbp)
		
		budget = budget - total_cost
	end
	
	return unit_list
end


