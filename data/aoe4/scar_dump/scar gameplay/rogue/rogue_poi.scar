import("cardinal.scar")

function Rogue_Poi_Precache()
	
	POI_CHAMPION_MAX = 3
	POI_MARKER_RADIUS = 45
	
	local rogue_player = PLAYERS[1].id
	
	Rogue_POI_InitUnitTables()
	
	local ebp_monastery = Cardinal_ConvertTypeToEntityBlueprint("scar_monastery", rogue_player)
	Scar_PrecachePrematchResource(ebp_monastery)
	
	local ebp_keep = Cardinal_ConvertTypeToEntityBlueprint("scar_keep", rogue_player)
	if ebp_keep ~= nil then Scar_PrecachePrematchResource(ebp_keep) end
	
	local sbp_monk = Cardinal_ConvertTypeToSquadBlueprint("scar_monk", rogue_player)
	Scar_PrecachePrematchResource(sbp_monk)
	
	local sbp_manatarms = Cardinal_ConvertTypeToSquadBlueprint("scar_manatarms", rogue_player)
	Scar_PrecachePrematchResource(sbp_manatarms)
	
	local sbp_handcannon = Cardinal_ConvertTypeToSquadBlueprint("scar_handcannon", rogue_player)
	if sbp_handcannon ~= nil then Scar_PrecachePrematchResource(sbp_handcannon) end
	
	local sbp_crossbowman = Cardinal_ConvertTypeToSquadBlueprint("scar_crossbowman", rogue_player)
	if sbp_crossbowman ~= nil then Scar_PrecachePrematchResource(sbp_crossbowman) end
	
	local sbp_knight = Cardinal_ConvertTypeToSquadBlueprint("scar_knight", rogue_player)
	if sbp_knight ~= nil then Scar_PrecachePrematchResource(sbp_knight) end
	
	-- ensure special_unit for player civ is precached
	local player_civ = Player_GetRaceName(rogue_player)
	for i = 1, #t_poi_civ_settings do
		if t_poi_civ_settings[i].civ_name == player_civ then
			if t_poi_civ_settings[i].special_unit ~= nil then
				Scar_PrecachePrematchResource(t_poi_civ_settings[i].special_unit)
			end
		end
	end
end

--? @shortdesc Inits points of interest
function Rogue_POI_Init(enemy_player, custom_unit_types, extra_poi_types, count_used_t1, count_used_t2)
	
	POI_ENEMY = enemy_player
	
	poi_count = 0
	poi_army_count = 0
	
	poi_champion_count = 0
	
	poi_tempSGroup = nil
	
	Rogue_POI_InitData(custom_unit_types, extra_poi_types)
	
	Rogue_POI_Spawn("mkr_poi_t1", nil, 1, count_used_t1)
	Rogue_POI_Spawn("mkr_poi_t2", nil, 2, count_used_t2)
	
end

