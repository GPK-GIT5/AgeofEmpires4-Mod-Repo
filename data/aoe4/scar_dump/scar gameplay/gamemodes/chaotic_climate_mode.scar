	options = {},
	is_cheat_enabled = false,
	is_diplomacy_enabled = false,
	is_tribute_enabled = true,
	is_castermode_HUD_loaded = false,
	
	speed = {						-- modifier multipliers 
		build = 1,
		repair = 1,
		gather = 1,		
		upgrade = 1,
		production = 1,
		modifiers = {},
	},
	
	climate = {
		initial_delay_time = INTERVAL_FROM_MINUTES(0.5),
		season_duration_time = INTERVAL_FROM_MINUTES(1), 
		season_cooldown_time = INTERVAL_FROM_MINUTES(1),
		season_duration_rule_id = 0,
		season_cooldown_rule_id = 0,
		is_season_active = false,
		ui_widget_id = "ChaoticClimate_Widget",
		season_index = 0,
		active_effect = "",
		active_effect_ui_info = "",
		seasons = {"summer_atmosphere", "autumn_atmosphere", "winter_atmosphere", "spring_atmosphere"},
		
		forage_season = {
			sheep_to_spawn = 0,
