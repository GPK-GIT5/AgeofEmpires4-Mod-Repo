			boar_to_spawn = 0,
			sheep_blueprint = "gaia_herdable_sheep",
			deer_blueprint = "gaia_huntable_deer",
			boar_blueprint = "gaia_huntable_boar",
			init_sheep_spawn_points = {},
			init_deer_spawn_points = {},
