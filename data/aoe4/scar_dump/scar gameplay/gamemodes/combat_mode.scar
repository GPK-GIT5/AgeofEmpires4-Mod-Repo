-- Callback involked by OnInit() in core.scar
function CombatMode_OnInit()

	UI_AllTerritoryHide()
	
	CombatMode_SetTeamLineOfSight()
	
	-- Set player behaviour when eliminated
	_allow_spectators = false

	local options = {}
	Setup_GetWinConditionOptions(options)

--[[	
