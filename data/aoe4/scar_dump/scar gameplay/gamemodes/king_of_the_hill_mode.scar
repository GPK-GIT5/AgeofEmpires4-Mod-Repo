_match = {
	options = {},
	is_cheat_enabled = false,
	is_diplomacy_enabled = false,
	is_tribute_enabled = true,
	is_nomad_start = false,
	
	speed = {						-- modifier multipliers 
		build = 1,
		repair = 1,
		gather = 1,		
		upgrade = 1,
		production = 1,
		modifiers = {},
	},
	
	hill_info = {
		blueprint_name = "capture_point",
		spawn_markers = {},
		spawn_positions = {}, -- Only used if new spawn method is disabled.
		spawn_distance_cutoff_percent = 0.2,
		initial_spawn_time = INTERVAL_FROM_MINUTES(3),
		active_time = INTERVAL_FROM_MINUTES(5),
		time_between_spawns = INTERVAL_FROM_MINUTES(3),
		hill_entity = nil,
		reward_interval_per_player = {90, 60, 30},		-- How frequently player should receive rewards based on preset options.
