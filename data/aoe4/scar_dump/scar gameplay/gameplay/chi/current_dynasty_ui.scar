_gold_icon = "/WPFGUI;component/icons/resources/resource_gold_icon.png"
_stone_icon = "/WPFGUI;component/icons/resources/resource_stone_icon.png"

function CreateCostData(entityName)
	cost = BP_GetEntityBPCost(BP_GetEntityBlueprint(entityName))
	costData = {
	{
		cost = cost.food,
		icon = _food_icon,
	},
	{
		cost = cost.wood,
		icon = _wood_icon,
	},
	{
		cost = cost.gold,
		icon = _gold_icon,
	},
	{
		cost = cost.stone,
		icon = _stone_icon,
	},
	}
	return costData
end	

-----------------------------------------------------------------------
-- Scripting framework 
-----------------------------------------------------------------------

Core_RegisterModule("DynastyUI")


-----------------------------------------------------------------------
-- Callbacks
-----------------------------------------------------------------------

-- Callback invoked by Core::OnInit()
function DynastyUI_OnInit()
	
	-- If it is not a replay match then check only for local player if they are using the Chinese civ, if it is a replay then check if any player is using the Chinese civ
	if(UI_IsReplay() == false) then
		local raceName = Player_GetRaceName(Game_GetLocalPlayer())	
		if raceName == _chinese_civ or raceName == _historic_chinese_civ then
			DynastyUI_SetCivData(raceName)
			DynastyUI_CreateDataContext()
			return
		end
	else
		for i = 1, World_GetPlayerCount() do
			local raceName = Player_GetRaceName(World_GetPlayerAt(i))
			if raceName == _chinese_civ or raceName == _historic_chinese_civ then
				DynastyUI_SetCivData(raceName)
				DynastyUI_CreateDataContext()
				return
			end				
		end
	end	
	
	Core_UnregisterModule("DynastyUI")	
end


-- Called by _StartMission() in core.scar
function DynastyUI_Start()	
	DynastyUI_CreateUI()
	DynastyUI_Update()
	Rule_AddGlobalEvent(DynastyUI_OnConstructionComplete, GE_ConstructionComplete)
	Rule_AddGlobalEvent(DynastyUI_OnEntityKilled, GE_EntityKilled)	
	Rule_AddGlobalEvent(DynastyUI_OnLocalPlayerChanged, GE_LocalPlayerChanged)	
	--Commenting out the OnUpgradeComplete function as it is causing Fatal Scar Errors.
	--local raceName = Player_GetRaceName(Game_GetLocalPlayer())	
	--if raceName == _historic_chinese_civ then
	--	Rule_AddGlobalEvent(DynastyUI_OnUpgradeComplete, GE_UpgradeComplete)	
	--end
end


-- Callback invoked by Core_OnGameOver()
-- Stops rules rules and removes UI elements associated with CurrentAgeUI module before end mission/match screen is displayed.
function DynastyUI_OnGameOver()	
	Rule_RemoveGlobalEvent(DynastyUI_OnConstructionComplete)
	Rule_RemoveGlobalEvent(DynastyUI_OnEntityKilled)
	Rule_RemoveGlobalEvent(DynastyUI_OnLocalPlayerChanged, GE_LocalPlayerChanged)	
	DynastyUI_Show(false)
end

-- Callback invoked by Core_OnGameRestore()
function DynastyUI_OnGameRestore()
	_dynasty.is_ui_created = false	-- coming in from a savegame - the UI won't have been saved so we need to clear this flag and then recreate the UI
	DynastyUI_CreateUI()
	--DynastyUI_UpdateUI()	
end

-- Callback triggered by global event GE_ConstructionComplete 
function DynastyUI_OnConstructionComplete(context)
	if context.player == Game_GetLocalPlayer() then 
		-- Delay a couple ticks so state tree finishes deferred data model updates
		Rule_AddOneShot(DynastyUI_Update, 0.5)
	end	
end


-- Global event callback for GE_EntityKilled
function DynastyUI_OnEntityKilled(context)	
	-- Account for buildings in the district of a tier 3 Spirit Way landmark being destroyed,
	-- in which case access to all previous dynasties is removed if it drops to tier 2.	
	if context.victimOwner == Game_GetLocalPlayer()
		and Entity_IsBuilding(context.victim) 
		and Entity_GetBuildingProgress(context.victim) >= 1.0 then
		-- Delay a couple ticks so state tree finishes deferred data model updates
		Rule_AddOneShot(DynastyUI_Update, 0.5)
	end
end

-- Callback invoked by Core_SetPlayerDefeated() when a player is eliminated.
function DynastyUI_OnPlayerDefeated(player, reason)
	if player.isLocal then 
		DynastyUI_Show(false)
	end
end

-- Global event callback for GE_LocalPlayerChanged
function DynastyUI_OnLocalPlayerChanged(context)
	local raceName = Player_GetRaceName(Game_GetLocalPlayer())
	DynastyUI_SetCivData(raceName)
	DynastyUI_CreateDataContext()
	DynastyUI_Update()
end

-- Callback triggered by global event GE_UpgradeComplete 
function DynastyUI_OnUpgradeComplete(context)
	--Commenting out due to Fatal Scar Errors
	--if BP_GetName(Entity_GetBlueprint(context.executer)) == _historic_dynasty_swap_landmark then
		-- Delay a couple ticks so state tree finishes deferred data model updates
		--Rule_AddOneShot(DynastyUI_Update, 0.5)
	--end 
end


-----------------------------------------------------------------------
-- Private/Internal functions
-----------------------------------------------------------------------

function DynastyUI_Show(show_ui)
	if _dynasty.is_ui_created then 
		_dynasty.data_context.is_ui_visible = show_ui
		UI_SetDataContext(_dynasty.ui, _dynasty.data_context)		
	end
end


function DynastyUI_CreateUI()	
	if UI_IsXboxUI() then
		DynastyUI_CreateXboxUI()
		return
	end
	
	if not _dynasty.is_ui_created then
		
		local xaml = [[<StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom"  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
				<ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource ChineseDynasties}" />
			</StackPanel>
		]]
		
		UI_AddChild("ScarDefault", "XamlPresenter", _dynasty.ui, { IsHitTestVisible = true, Xaml = xaml, DataContext = UI_CreateDataContext(_dynasty.data_context) })
		_dynasty.is_ui_created = true
	end
end

function DynastyUI_SetCivData(raceName)	
	if (raceName == _chinese_civ) then
			if (Game_HasMatchTypeFlag(MTF_ROGUE)) then
				_required_wonders = _dynasty.rogueWonders
				for i, upgrade in pairs(_dynasty.upgrades) do
					_dynasty.upgrades[i] = _dynastyUpgrades[i]
				end
				for i, squad in pairs(_dynasty.squads) do
					_dynasty.squads[i] = _dynastySquads[i]
				end
				for i, building in pairs(_dynasty.buildings) do
					_dynasty.buildings[i] = _dynastyBuildings[i]
				end
				for i, dynasty in pairs(_dynasty.data_context.dynasties) do
					dynasty.locked_bg = _defaultBackgrounds[i].locked_bg
					dynasty.active_bg = _defaultBackgrounds[i].active_bg
					dynasty.gold_outline = _defaultBackgrounds[i].gold_outline
				end
			else
				_required_wonders = _dynasty.wonders
				for i, upgrade in pairs(_dynasty.upgrades) do
					_dynasty.upgrades[i] = _dynastyUpgrades[i]
				end
				for i, squad in pairs(_dynasty.squads) do
					_dynasty.squads[i] = _dynastySquads[i]
				end
				for i, building in pairs(_dynasty.buildings) do
					_dynasty.buildings[i] = _dynastyBuildings[i]
				end
				for i, dynasty in pairs(_dynasty.data_context.dynasties) do
					dynasty.locked_bg = _defaultBackgrounds[i].locked_bg
					dynasty.active_bg = _defaultBackgrounds[i].active_bg
					dynasty.gold_outline = _defaultBackgrounds[i].gold_outline
				end
			end
	else
		_required_wonders = _dynasty.historicWonders
		for i, upgrade in pairs(_dynasty.upgrades) do
			_dynasty.upgrades[i] = _dynastyUpgrades[i] .. _historic_index_1
		end
		for i, squad in pairs(_dynasty.squads) do
			_dynasty.squads[i] = nil
		end
		for i, building in pairs(_dynasty.buildings) do
			_dynasty.buildings[i] = _dynastyBuildings[i] .. _historic_index_1
		end
		for i, dynasty in pairs(_dynasty.data_context.dynasties) do
			dynasty.locked_bg = _historicBackgrounds[i].locked_bg
			dynasty.active_bg = _historicBackgrounds[i].active_bg
			dynasty.gold_outline = _historicBackgrounds[i].gold_outline
		end
	end
end

function DynastyUI_ToggleDropdown(context)
	local townCenterSelected = Game_HasOnlySelectedEntitiesOfType("town_center")
	if ((not UI_IsXboxControllerUI()) or (UI_IsXboxControllerUI() and townCenterSelected)) then
		_dynasty.data_context.is_dropdown_visible = not _dynasty.data_context.is_dropdown_visible
		UI_SetDataContext(_dynasty.ui, _dynasty.data_context)	
		if(_dynasty.data_context.is_dropdown_visible) then
			UI_AddEventHandler("Scar", "HUDPageBase.Cancel", "DynastyUI_HideDropdown")
		else
			UI_RemoveEventHandler("Scar", "HUDPageBase.Cancel", "DynastyUI_HideDropdown")
		end
	end
end

-- callback invoked by pressing the ESC key while Dynasty panel is open
function DynastyUI_HideDropdown(context)
	if(_dynasty.data_context.is_dropdown_visible) then
		DynastyUI_ToggleDropdown()
	end
end


function DynastyUI_CreateDataContext()
	race = Player_GetRace(Game_GetLocalPlayer())
	
	for i = 1,4 do
		uiinfo = BP_GetUpgradeUIInfo(BP_GetUpgradeBlueprint(_dynasty.upgrades[i]))
		upgrade = {
			locked = true,
			extra = uiinfo.extraText,
			name = uiinfo.screenName,
			help = uiinfo.helpText,
		}
		_dynasty.data_context.dynasties[i].upgrade = upgrade
	end
	
	for i = 1,3 do
		uiinfo = BP_GetEntityUIInfo(BP_GetEntityBlueprint(_dynasty.buildings[i]))
		cost = BP_GetEntityBPCost(BP_GetEntityBlueprint(_dynasty.buildings[i]))
		building = {
			icon = uiinfo.iconName,
			extra = uiinfo.extraText,
			name = uiinfo.screenName,
			help = uiinfo.helpText,
			productionTime = BP_GetEntityBPBuildTime(BP_GetEntityBlueprint(_dynasty.buildings[i])),
			cost = CreateCostData(_dynasty.buildings[i]),
		}
		_dynasty.data_context.dynasties[i].building = building
		
		if (_dynasty.squads[i] ~= nil) then
			uiinfo = BP_GetSquadUIInfo(BP_GetSquadBlueprint(_dynasty.squads[i]), race)
			squad = {
				icon = uiinfo.iconName,
				extra = uiinfo.extraText,
				name = uiinfo.screenName,
				help = uiinfo.helpText,
				productionTime = BP_GetEntityBPBuildTime(BP_GetEntityBlueprint(_dynasty.squads[i])),
				cost = CreateCostData(_dynasty.squads[i]),
			}
			_dynasty.data_context.dynasties[i + 1].squad = squad
		end
		
		_dynasty.data_context.dynasties[i + 1].wonders = {
			{},
			{},
		}
		for w = 1,2 do
			uiinfo = BP_GetEntityUIInfo(BP_GetEntityBlueprint(_required_wonders[i][w]))
			wonder = {
				icon = uiinfo.iconName,
				extra = uiinfo.extraText,
				name = uiinfo.screenName,
				help = uiinfo.helpText,
				built = false,
				productionTime = BP_GetEntityBPBuildTime(BP_GetEntityBlueprint(_required_wonders[i][w])),
				cost = CreateCostData(_required_wonders[i][w]),
			}
			_dynasty.data_context.dynasties[i + 1].wonders[w] = wonder
		end
	end
end
-----------------------------------------------------------------------
-- Rules
-----------------------------------------------------------------------

function DynastyUI_Update()
	local local_player_id = Game_GetLocalPlayer()
	
	-- Reset all active values
	_dynasty.data_context.dynasties[_dynasty.tang].active = false
	_dynasty.data_context.dynasties[_dynasty.song].active = false
	_dynasty.data_context.dynasties[_dynasty.yuan].active = false
	_dynasty.data_context.dynasties[_dynasty.ming].active = false
	
	-- Update active dynasties
	if Player_GetStateModelBool(local_player_id, "district_spec_permanent_dynasty_bonuses_chi") then
		-- Show all bonuses if player has specialization for stacking dynasty bonuses 
		if Player_GetStateModelBool(local_player_id, "dynasty_3_was_completed_chi") then
			_dynasty.data_context.dynasties[_dynasty.ming].active = true
		end
		if Player_GetStateModelBool(local_player_id, "dynasty_2_was_completed_chi")  then
			_dynasty.data_context.dynasties[_dynasty.yuan].active = true
		end
		if Player_GetStateModelBool(local_player_id, "dynasty_1_was_completed_chi") then
			_dynasty.data_context.dynasties[_dynasty.song].active = true	
		end
		_dynasty.data_context.dynasties[_dynasty.tang].active = true
	else
		-- Show only bonuses specific to the player's current dynasty
		if Player_GetStateModelFloat(local_player_id, "current_dynasty_chi") == 3.0 then
			_dynasty.data_context.dynasty_name = Loc_GetString(11170335)
			_dynasty.data_context.dynasties[_dynasty.ming].active = true
			_dynasty.data_context.dynasties[_dynasty.ming].unlocked = true
			_dynasty.data_context.current_dynasty = _dynasty.data_context.dynasties[_dynasty.ming]
		elseif Player_GetStateModelFloat(local_player_id, "current_dynasty_chi") == 2.0 then
			_dynasty.data_context.dynasty_name = Loc_GetString(11170334)
			_dynasty.data_context.dynasties[_dynasty.yuan].active = true
			_dynasty.data_context.dynasties[_dynasty.yuan].unlocked = true
			_dynasty.data_context.current_dynasty = _dynasty.data_context.dynasties[_dynasty.yuan]
		elseif Player_GetStateModelFloat(local_player_id, "current_dynasty_chi") == 1.0 then
			_dynasty.data_context.dynasty_name = Loc_GetString(11170333)
			_dynasty.data_context.dynasties[_dynasty.song].active = true
			_dynasty.data_context.dynasties[_dynasty.song].unlocked = true
			_dynasty.data_context.current_dynasty = _dynasty.data_context.dynasties[_dynasty.song]
		else	
			_dynasty.data_context.dynasty_name = Loc_GetString(11170332)
			_dynasty.data_context.dynasties[_dynasty.tang].active = true
			_dynasty.data_context.current_dynasty = _dynasty.data_context.dynasties[_dynasty.tang]
		end	
	end
	
	-- Set if wonder was built
	for i = 1,3 do
		for w = 1,2 do
			built = Player_HasEntity(local_player_id, BP_GetEntityBlueprint(_required_wonders[i][w]))
			_dynasty.data_context.dynasties[i + 1].wonders[w].built = built
			if built then
				Player_SetConstructionMenuAvailability(local_player_id, _dynasty.modal_menus[i], ITEM_REMOVED)
			end
		end
	end
	
	if _dynasty.is_ui_created then 
		UI_SetDataContext(_dynasty.ui, _dynasty.data_context)	
	end
end

function DynastyUI_CreateXboxUI()
	if not _dynasty.is_ui_created then
		
		local xaml = [[<Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Panel.ZIndex="999">
				<ContentPresenter Content="{Binding}" ContentTemplate="{DynamicResource XboxChineseDynasties}" />
			</Grid>
		]]
		
		UI_AddChild("ScarAlwaysVisible", "XamlPresenter", _dynasty.ui, { IsHitTestVisible = true, Xaml = xaml, DataContext = UI_CreateDataContext(_dynasty.data_context) })
		_dynasty.is_ui_created = true
	end
end