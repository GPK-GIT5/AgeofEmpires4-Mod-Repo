function MissionOMatic_SetupPlayer(player)			-- called during OnGameSetup - just creates the player for now

	if _nextOpenPlayerSlot == nil then
		_nextOpenPlayerSlot = 2
	end
	
	if MissionRecipe.playAs == player.descriptor then 
		player.id = Setup_Player(1, (player.displayName or 0), player.civilization, 1)
		player.index = 1
	else
		player.id = Setup_Player(_nextOpenPlayerSlot, (player.displayName or 0), player.civilization, _nextOpenPlayerSlot)
		player.index = _nextOpenPlayerSlot
		_nextOpenPlayerSlot = _nextOpenPlayerSlot + 1
	end

	-- set age 
	if player.startingAge ~= nil then
		Player_SetCurrentAge(player.id, player.startingAge)
		player.startingAge = nil		-- clear out this info - you should get it by using Player_GetCurrentAge, not from here!
	end
	if player.maximumAge ~= nil then 
		Player_SetMaximumAge(player.id, player.maximumAge)
		player.maximumAge = nil
	end
	
end

function MissionOMatic_InitializePlayers()			-- called during OnInit - finishes off the initialization

	for index, player in pairs(MissionRecipe.players) do 
		MissionOMatic_InitializePlayer(player)
	end
	
end	
	
function MissionOMatic_InitializePlayer(player)

	local playerDataTable = Core_GetPlayersTableEntry(player.id)
	playerDataTable.missionomatic = player

	if player.existingPlayerIndex ~= nil then
		player.tempSGroup = SGroup_CreateUnique("")
		player.tempEGroup = EGroup_CreateUnique("")
		Player_GetAll(World_GetPlayerAt(player.existingPlayerIndex), player.tempSGroup, player.tempEGroup)
	end
	
	
	if scartype(player.upgrades) == ST_TABLE then
		for index, item in pairs(player.upgrades) do 
			Player_CompleteUpgrade(player.id, BP_GetUpgradeBlueprint(item))
		end
	end
	
	if scartype(player.availability) == ST_TABLE then
		for index, item in pairs(player.availability) do 
			
			-- SBPs
			if item.sbp == nil then
				if scartype(item.sbp) == ST_STRING then 
					if SBP_Exists(item.sbp) then
						item.sbp = BP_GetSquadBlueprint(item.sbp)
					else
						item.sbp = Cardinal_ConvertTypeToSquadBlueprint(item.sbp, player.id)
					end
				end
				if item.sbp ~= nil then 
					Player_SetSquadProductionAvailability(player.id, item.sbp, item.availability)
				end
			end
			
			-- EBPs
			if item.ebp == nil then
				if scartype(item.ebp) == ST_STRING then 
					if EBP_Exists(item.ebp) then 
						item.ebp = BP_GetEntityBlueprint(item.ebp)
					else
						item.ebp = Cardinal_ConvertTypeToEntityBlueprint(item.ebp, player.id)
					end
				end
				if item.ebp ~= nil then 
					Player_SetEntityProductionAvailability(player.id, item.ebp, item.availability)
				end
			end
			
			-- UPGRADEs
			if item.upgrade == nil then
				if scartype(item.upgrade) == ST_STRING then 
					item.upgrade = BP_GetEntityBlueprint(item.upgrade)
				end
				if item.upgrade ~= nil then 
					Player_SetUpgradeAvailability(player.id, item.upgrade, item.availability)
				end
			end

		end
	end
	
end

function MissionOMatic_InitializeTeams()

	if MissionRecipe.teams == nil then
		MissionRecipe.teams = {}
	end

	local _FindRelationshipFromRecipe = function(p1, p2)
	
		if p1.missionomatic == nil or p2.missionomatic == nil then
			return R_NEUTRAL
		end
		
		if MissionRecipe.teams ~= nil then
			for index, team in pairs(MissionRecipe.teams) do 
			
				local p1_isOnTeam = Table_Contains(team, p1.missionomatic.descriptor)
				local p2_isOnTeam = Table_Contains(team, p2.missionomatic.descriptor)
				
				if p1_isOnTeam or p2_isOnTeam then
					if index == "neutral" then
						return R_NEUTRAL	
					elseif p1_isOnTeam and p2_isOnTeam then
						return R_ALLY	-- we found a team table entry with BOTH players in it, so these players are on the same team
					end
				end
				
			end
		end
		
		return R_ENEMY	-- we didn't find anything, so fall back to the two players being enemies
		
	end
	

	for i1, p1 in pairs(PLAYERS) do 
		for i2, p2 in pairs(PLAYERS) do 

			if p1 == p2 then
				-- that's the same player - ignore!
			else
				local relationship = _FindRelationshipFromRecipe(p1, p2)
				Player_SetRelationship(p1.id, p2.id, relationship)
			end
			
			if p1.missionomatic ~= nil and p1.missionomatic.existingPlayerIndex ~= nil then
				SGroup_SetPlayerOwner(p1.missionomatic.tempSGroup, p1.id)
				EGroup_SetPlayerOwner(p1.missionomatic.tempEGroup, p1.id)
				p1.missionomatic.existingPlayerIndex = nil
				SGroup_Destroy(p1.missionomatic.tempSGroup)
				EGroup_Destroy(p1.missionomatic.tempEGroup)
				p1.missionomatic.tempSGroup = nil
				p1.missionomatic.tempEGroup = nil
			end

		end
	end

end

--? @shortdesc Get the relationship between two players in the mission. These players can be referenced in any way that MissionOMatic_GetPlayer() can process. 
--? @args Player p1, Player p2
--? @result Relationship
function MissionOMatic_GetRelationship(p1, p2)

	p1 = MissionOMatic_GetPlayer(p1)
	p2 = MissionOMatic_GetPlayer(p2)
	
	return Player_ObserveRelationship(p1.id, p2.id)
	
end

--? @shortdesc Finds the player data table for one of the players in the mission, identifying them from a String ("descriptor"), PlayerID, Squad/SGroup or Entity/EGroup
--? @extdesc If you pass in a PlayerTable that has already been resolved it returns it straight back  
--? @args String/PlayerID/Object identifier
--? @result PlayerTable
function MissionOMatic_GetPlayer(identifier)

	if scartype(identifier) == ST_TABLE and scartype(identifier.id) == ST_PLAYER then
		return identifier
	end
	
	-- convert most object reference types to a player
	if scartype(identifier) == ST_SQUAD or 
	   scartype(identifier) == ST_SGROUP or 
	   scartype(identifier) == ST_ENTITY or 
	   scartype(identifier) == ST_EGROUP then
		
		identifier = Util_GetPlayerOwner(identifier)
		
	end
	
	for index, player in pairs(PLAYERS) do 
		
		if scartype(identifier) == ST_STRING then			-- search by descriptor
			if player.missionomatic.descriptor == identifier then
				return player.missionomatic
			end
		
		elseif scartype(identifier) == ST_PLAYER then		-- search by playerID
			if player.id == identifier then
				return player.missionomatic
			end
			
		end
		
	end

	-- not found
	return nil 
	
end
PARTICIPANT = MissionOMatic_GetPlayer

--
-- Modules
--

function MissionOMatic_InitializeModule(module)
	
	local initFunc = _G[module.type.."_Init"]
	if scartype(initFunc) == ST_FUNCTION then
		initFunc(module)
	else
		if scartype(module.type) == ST_STRING then
			assert(false, "Module has an invalid type "..module.type)
		else
			assert(false, "Module has an invalid type")
		end
		
	end
	
end

--? @shortdesc Finds the module data table, identifying it from a String
function MissionOMatic_FindModule(descriptor, context)

	if scartype(descriptor) == ST_STRING then
		
		for index, module in pairs(t_allModules) do
			if module.descriptor == descriptor then
				return module 
			end
		end
		
	elseif scartype(descriptor) == ST_TABLE then 
		
		if descriptor.prefabName ~= nil then 	-- this is just the simplest way to check if it's actually a module table
			return descriptor 
		end
		
	end
	
	if scartype(context) == ST_TABLE then	-- use the context and try and figure out the "self" source module from that
		
		if scartype(context.self) == ST_STRING then
			return MissionOMatic_FindModule(context.self)
		elseif scartype(context.self) == ST_TABLE then
			return context.self
		end
		
	end
	
end

--? @shortdesc Finds the location data table, identifying it from a String
function MissionOMatic_FindLocation(descriptor, context)

	if scartype(descriptor) == ST_STRING then
		
		for index, location in pairs(t_allLocationPrefabs) do
			if location.descriptor == descriptor then
				return location 
			end
		end
		
	elseif scartype(descriptor) == ST_TABLE then 
		
		if descriptor.prefabName == "Location" then 	-- this is just the simplest way to check if it's actually a Location table
			return descriptor 
		end
		
	end	
end

function MissionOMatic_StartPlaybill()
	
	local playbill = MissionRecipe.playbill
	
	if scartype(playbill) == ST_TABLE then
		
		Playbill_Start(playbill)
		
	end
	
end

