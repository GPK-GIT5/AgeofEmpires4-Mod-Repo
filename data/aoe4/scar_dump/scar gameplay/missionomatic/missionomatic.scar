CONTENT_PACK_VANILLA_CAMPAIGN = 1
CONTENT_PACK_ART_OF_WAR = 2
CONTENT_PACK_ABBASID_CAMPAIGN = 3
CONTENT_PACK_ROGUE = 4


--? @group MissionOMatic

function MissionOMatic_OnInit()
	--print("MissionOMatic OnInit")
	
	if content_pack == nil then
		content_pack = CONTENT_PACK_VANILLA_CAMPAIGN
	end
	
	if content_pack ~= CONTENT_PACK_ROGUE then
		Game_FadeToBlack(FADE_OUT, 0)
	end
	
	Game_SetGameRestoreCallback(VerifyAllDissolves)
	
	MissionOMatic_InitMusicSettings()
	Sound_Play2D("mus_shared_set_gamemode_state_to_campaign") -- sets a state in wwise to mute the stinger when landmarks get destroyed in campaign
	
	sg_startingUnits = SGroup_CreateIfNotFound("sg_startingUnits")
	eg_startingBuildings = EGroup_CreateIfNotFound("eg_startingBuildings")

	sg_scriptSpawnedUnits = SGroup_CreateIfNotFound("sg_scriptSpawnedUnits")
	eg_scriptSpawnedBuildings = EGroup_CreateIfNotFound("eg_scriptSpawnedBuildings")
	
	sg_ignoreForUnitComposition = SGroup_CreateIfNotFound("sg_ignoreForUnitComposition")
	sg_waveManagerStagedUnits = SGroup_CreateIfNotFound("sg_waveManagerStagedUnits")
	
	eg_allWoodResources = EGroup_CreateIfNotFound("eg_allWoodResources")
	eg_allStoneResources = EGroup_CreateIfNotFound("eg_allStoneResources")
	eg_allGoldResources = EGroup_CreateIfNotFound("eg_allGoldResources")
	eg_allBerriesAtStart = EGroup_CreateIfNotFound("eg_allBerriesAtStart")
	eg_allDeerAtStart = EGroup_CreateIfNotFound("eg_allDeerAtStart")
	eg_allsheepAtStart = EGroup_CreateIfNotFound("eg_allSheepAtStart")
	eg_allShoreFishResources = EGroup_CreateIfNotFound("eg_allShoreFishResources")
	eg_allDeepFishResources = EGroup_CreateIfNotFound("eg_allDeepFishResources")
	eg_allCattleAtStart = EGroup_CreateIfNotFound("eg_allCattleAtStart")
	
	if scartype(Mission_SetupPlayers) == ST_FUNCTION then
		Mission_SetupPlayers()
	end

	MissionOMatic_SetupCheatMenu()
	
	Gathering_FindAllResources(
		eg_allWoodResources, 
		eg_allStoneResources,
		eg_allGoldResources,
		eg_allBerriesAtStart,
		eg_allsheepAtStart,
		eg_allDeerAtStart,
		eg_allShoreFishResources,
		eg_allCattleAtStart,
		eg_allDeepFishResources
	)
	if content_pack ~= CONTENT_PACK_ROGUE then
		_Wave_Init()
		LeaderTent_InitSystem()
		WaveGenerator_InitSystem()
	end
	Army_InitSystem()
	
	g_missionObjectives = {}
	
	t_allModules = {}
	t_attackModules = {}
	t_rovingArmyModules = {}
	t_defendModules = {}
	t_townLifeModules = {}
	t_unitSpawnerModules = {}
	t_siegeModules = {}
	t_villagerLifePrefabs = {}
	
	-- disable the shroud and territory lines
	UI_AllTerritoryHide()
	
	if content_pack == CONTENT_PACK_VANILLA_CAMPAIGN then
		-- disable the rebuildable landmarks feature
		print("landmarks cannot be rebuilt")
		for index = 1, World_GetPlayerCount() do 
			Player_SetStateModelBool(World_GetPlayerAt(index), "disable_landmark_rebuild", true)
		end
	else
		--print("landmarks can be rebuilt")
	end
	
	-- enable resource pickups
	Player_SetStateModelBool(World_GetPlayerAt(1), "player_can_interact_with_resource_pickups", true)
	
	-- enable wolves attacking scouts
	if content_pack ~= CONTENT_PACK_ROGUE then
		Player_SetStateModelBool(World_GetPlayerAt(1), "scout_can_be_attacked_by_wolf", true)
	end
	
	_MissionOMatic_CustomDebriefTitle = nil 
	
end

function MissionOMatic_Preset()	-- start spawning the units and initializing the modules
	--print("MissionOMatic Preset")
	if scartype(GetRecipe) == ST_FUNCTION then
		MissionRecipe = GetRecipe()
	end
	
	if scartype(MissionRecipe.audioSettings) == ST_TABLE then 
		g_missionData.campaignName = MissionRecipe.audioSettings.campaignName
		g_missionData.missionName = MissionRecipe.audioSettings.missionName
	end
			
	-- initialize locations
	if scartype(MissionRecipe.locations) == ST_TABLE then
		for index, location in ipairs(MissionRecipe.locations) do 
			MissionOMatic_InitializeLocation(location)
		end
	end
	if content_pack ~= CONTENT_PACK_ROGUE then
		MissionOMatic_InitializeLocationMonitoring()	-- this ensures that new entities get associated with locations as they are constructed
	end
	
	-- initialize modules
	if scartype(MissionRecipe.modules) == ST_TABLE then
		for index, module in ipairs(MissionRecipe.modules) do
			local diff = Game_GetSPDifficulty()
			if module.difficulty == nil or module.difficulty == diff or (scartype(module.difficulty) == ST_TABLE and Table_Contains(module.difficulty, Game_GetSPDifficulty())) then
				MissionOMatic_InitializeModule(module)	
			end
		end
	end
	
	-- create battalions
	if scartype(MissionRecipe.battalions) == ST_TABLE then
		for index, battalion in ipairs(MissionRecipe.battalions) do 
			MissionOMatic_InitializeBattalion(battalion)
		end
	end
	
	-- initialize objectives
	if scartype(MissionRecipe.objectives) == ST_TABLE then
		for index, objective in ipairs(MissionRecipe.objectives) do 
			MissionOMatic_InitializeObjective(objective)
		end
	end
	
	-- initialize metrics
	if scartype(MissionRecipe.metrics) == ST_TABLE then
		for index, metric in ipairs(MissionRecipe.metrics) do 
			MissionOMatic_InitializeCustomMetric(metric)
		end
	end
	
end

function MissionOMatic_PreStart()
	--print("MissionOMatic PreStart")
	if scartype(MissionRecipe) == ST_TABLE then 
		
		if scartype(MissionRecipe.preStart) == ST_TABLE then 
			if scartype(MissionRecipe.preStart.actions) == ST_TABLE then
				ActionList_PlayActions(MissionRecipe.preStart.actions, nil, MissionOMatic_PreStart_Done, nil)
				StartMission_Hold()
			end
		end
		
		if scartype(MissionRecipe.introNIS) == ST_FUNCTION then
			
			if _SpeechEvent_AudioMuted ~= true then
				Sound_Play2D("mute_gameplay_all_speech")
				_SpeechEvent_AudioMuted = true
			end
			Event_StartEx(MissionRecipe.introNIS, EVENT_NIS, _SpeechEvent_RestoreGameplayAudio) 			-- high priority
			
			Rule_Add(MissionOMatic_PreStart_IntroNISFinished)
			StartMission_Hold()
			
		end
		
	end
	

end

function MissionOMatic_PreStart_IntroNISFinished()
	if Event_IsAnyRunning() == false then 
		Rule_RemoveMe()
		StartMission_ReleaseHold()
	end
end

function MissionOMatic_PreStart_Done()
	StartMission_ReleaseHold()
end


function MissionOMatic_PlayTitleCard(location, date, icon)
	
	local location = location or 0
	local date = date or 0
	local icon = icon or ""
				
	Game_SubTextFadeWithIcon(location, date, 0, 0.5, 3, 0.5, icon)	-- not wrapped in an event as there may be speech going on
	
	CTRL.Event_Delay(3)
	CTRL.WAIT()
	
end

function MissionOMatic_Start()
	local difficulty_string = Util_DifVar({"0 - Story (GD_EASY in scar)", "1 - Easy (GD_NORMAL in scar)", "2 - Intermediate (GD_HARD in scar)", "3 - Hard (GD_EXPERT in scar)"})
	--print("Starting with difficulty "..difficulty_string)
	-- gather all of the units and buildings that exist at the start of the mission (so these can be excluded by certain conditions later on)
	for index, player in ipairs(PLAYERS) do
		Player_GetAll(player.id)
		SGroup_AddGroup(sg_startingUnits, sg_allsquads)
		EGroup_AddEGroup(eg_startingBuildings, eg_allentities)
	end
	
	if content_pack ~= CONTENT_PACK_ROGUE then
		Game_FadeToBlack(FADE_IN, 1)
	end
	
	-- A few things depend on the mission recipe
	if scartype(MissionRecipe) == ST_TABLE then 

		if scartype(MissionRecipe.onStart) == ST_TABLE then
		
			if scartype(MissionRecipe.onStart.actions) == ST_TABLE then 
				ActionList_PlayActions(MissionRecipe.onStart.actions)
			end
			
		end
		
		-- Move the camera to wherever the player's units entered the map
		local cameraStartPosition = nil
		
		-- First, check for an explicit definition
		if scartype(MissionRecipe.cameraStartMarker) == ST_STRING then
			cameraStartPosition = Util_GetPosition(Marker_FromName(MissionRecipe.cameraStartMarker, ""))
		elseif scartype(MissionRecipe.cameraStartMarker) == ST_MARKER then
			cameraStartPosition = Util_GetPosition(MissionRecipe.cameraStartMarker)
		end
		
		-- Now use whatever we found
		if scartype(cameraStartPosition) ~= ST_NIL then
			Camera_MoveTo(cameraStartPosition, false)
		end
		
	end
	
	-- trigger starting objectives and mission-wide playbills
	if Rule_Exists(MissionOMatic_TriggerStartingObjectives) == false then -- if this isn't queued up for later, start the objectives now
		MissionOMatic_TriggerStartingObjectives()
	end
	MissionOMatic_StartPlaybill()
	
end

