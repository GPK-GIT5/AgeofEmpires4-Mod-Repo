function MissionOMatic_EndMission(win)

	if win == true and MissionRecipe.onWin ~= nil and MissionRecipe.onWin.actions ~= nil then
		
		ActionList_PlayActions(MissionRecipe.onWin.actions)
		
	elseif win == false and MissionRecipe.onLose ~= nil and MissionRecipe.onLose.actions ~= nil then
		
		ActionList_PlayActions(MissionRecipe.onLose.actions)
		
	else
	
		--local report = MissionOMatic_GenerateMissionReport(win)

		
		CardinalMissionData = {
			report = {
				win = win,
				gameLength = World_GetGameTime(),
			},
		}
		
		Game_RetrieveTableData("CardinalMissionData", true) -- clear out the old store
		Game_StoreTableData("CardinalMissionData", CardinalMissionData)
		
		local winReason = WR_OBJECTIVECOMPLETE
		if (not win) then
			winReason = WR_OBJECTIVEFAILED
		end
		
		Game_EndSP(win, winReason)
	
	end
	
end



--
-- Setup default music settings for missions. These can be overriden later on a per scenario basis
--

function MissionOMatic_InitMusicSettings()

	Sound_ResetMusicIntensityMapping();
	Sound_AddMusicIntensityMappingPoint(15, 550) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(300, 4000) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(800, 9999) -- raw value max to scaled value max 

end

--
-- Tagging units - useful for getting conditions and actions to track specific units
--

function MissionOMatic_GetSGroupForTaggedUnit(tag)

	if t_taggedUnits == nil then
		t_taggedUnits = {}
	end
	
	for index, entry in pairs(t_taggedUnits) do 
			
		if entry.tag == tag then	
			return entry.sgroup
		end
		
	end
	
	local entry = MissionOMatic_CreateTag(tag)
	return entry.sgroup
	
end

function MissionOMatic_GetEntryForTaggedUnit(tag)

	if t_taggedUnits == nil then
		t_taggedUnits = {}
	end
	
	for index, entry in pairs(t_taggedUnits) do 
			
		if entry.tag == tag then	
			return entry
		end
		
	end
	
	local entry = MissionOMatic_CreateTag(tag)
	return entry
	
end

function MissionOMatic_TagUnit(squad, tag)

	if t_taggedUnits == nil then
		t_taggedUnits = {}
	end
	
	local entry = MissionOMatic_GetEntryForTaggedUnit(tag)

	if entry == nil then
		entry = MissionOMatic_CreateTag(tag)
	end
	
	if scartype(squad) == ST_SGROUP then
		SGroup_AddGroup(entry.sgroup, squad)
	elseif scartype(squad) == ST_SQUAD then
		SGroup_Add(entry.sgroup, squad)
	end
	
end

function MissionOMatic_SquadHasTag(squad, tag)

	local sgroup = MissionOMatic_GetSGroupForTaggedUnit(tag)
	
	if sgroup ~= nil and scartype(squad) == ST_SQUAD then
		return SGroup_ContainsSquad(sgroup, Squad_GetID(squad), true)
	end
	
	return false
end

function MissionOMatic_UntagUnit(squad, tag)

	if t_taggedUnits == nil then
		t_taggedUnits = {}
	end
	
	local entry = MissionOMatic_GetSGroupForTaggedUnit(tag)

	if entry == nil then
		
		entry = {
			tag = tag,
			sgroup = SGroup_CreateUnique("Tagged Unit"),
		}
		table.insert(t_taggedUnits, entry)
	
	end
	
	if scartype(squad) == ST_SGROUP then
		SGroup_RemoveGroup(entry.sgroup, squad)
	elseif scartype(squad) == ST_SQUAD then
		SGroup_Remove(entry.sgroup, squad)
	end
	
end

function MissionOMatic_ClearTag(tag)

	if t_taggedUnits == nil then
		t_taggedUnits = {}
	end
	
	for index, entry in pairs(t_taggedUnits) do 
			
		if entry.tag == tag then	
			SGroup_Clear(entry.sgroup)
		end
		
	end
	
end

function MissionOMatic_CreateTag(tag)

	if t_taggedUnits == nil then
		t_taggedUnits = {}
	end

	for index, entry in pairs(t_taggedUnits) do 
		if entry.tag == tag then	
			return entry
		end
	end 
	
	local entry = {
		tag = tag,
		sgroup = SGroup_CreateUnique("Tagged Unit - "..tag),
	}
	table.insert(t_taggedUnits, entry)
	
	return entry	
	
end





--
-- Hooks into the Core UnitEntry system
--

function MissionOMatic_UnitEntry_CreateUnit(unit, deployment)

	-- look for the "tag" key and apply missionomatic tags as appropriate
	if scartype(unit.tag) == ST_STRING then			
		MissionOMatic_TagUnit(unit.squadID, unit.tag)
	end
	
	SGroup_Add(sg_scriptSpawnedUnits, unit.squadID) 
end



function MissionOMatic_UnitEntry_SpawnUnit(unit, deployment)	
	
 	-- look for the "zeroPopulation" key (as a unit option or a deployment option) and apply a modifier to nix the unit's popcap
 	if unit.zeroPopulation == true or deployment.options.zeroPopulation == true then
		local modifier = Modifier_Create(MAT_Entity, "entity_popcap_modifier", MUT_Multiplication, false, 0, "")
		Modifier_ApplyToSquad(modifier, unit.squadID, 0)
	end
	
end


--
-- This is called when the user requests to quit the mission - reset campaign state as necessary
--

function MissionOMatic_OnLeaveGameMatchRequested()

	-- agraham: temporary Neil, please shell out to the campaign mission to clear feFlow_is_playing_campaign
	-- also - currently post screen says "victory" we need to set a variable in store to indicate quit instead

	local temp = Game_RetrieveTableData("campaign_temp", false)
	temp.feFlow_is_playing_campaign = false
	Game_StoreTableData("campaign_temp", temp)

	-- go back to last saved campaign data so we see breifing again
	Game_LoadTextDataStore("campaign", "")

end



--
-- Cheat Menu
--

function MissionOMatic_SetupCheatMenu()

	CheatMenu_RegisterCheatFunction(MissionOMatic_Cheat_ViewRecipe, "View Recipe", false)
	CheatMenu_RegisterCheatFunction(MissionOMatic_Cheat_Win, "Mission-o-Matic Win", false)
	CheatMenu_RegisterCheatFunction(MissionOMatic_Cheat_Lose, "Mission-o-Matic Lose", false)
	CheatMenu_RegisterCheatFunction(MissionOMatic_Cheat_Complete_Obj, "Complete Active Objectives", false)
	CheatMenu_RegisterCheatFunction(MissionOMatic_Cheat_Fail_Obj, "Fail Active Objectives", false)
	
	if scartype(EVENTS) == ST_TABLE then 
		for index, event in pairs(EVENTS) do
			if string.find(index, "ECAM") ~= nil then
				CheatMenu_AddMenuItem_Event("Play E-Cam "..index, false, "playECAM", index)
			else
				CheatMenu_AddMenuItem_Event("Play Speech "..index, false, "playSpeechEvent", index)
			end
		end
	end
	
end

function MissionOMatic_ActivateMenuItem(mode, value)

	if mode == "playECAM" and scartype(value) == ST_STRING then
		PlayECAM(value)
	elseif mode == "playSpeechEvent" and scartype(value) == ST_STRING then
		PlaySpeech(value)
	end	
	
end

--? @shortdesc Used to view the mission recipe that this mission was generated from
function MissionOMatic_Cheat_ViewRecipe()

	view(MissionRecipe)
	
end

--? @shortdesc Used to WIN the entire mission
function MissionOMatic_Cheat_Win()
	
	-- kill everything that isn't the player's
	for index, player in pairs(PLAYERS) do 
		if player.index ~= 1 then
			Player_GetAll(player.id)
			SGroup_Kill(sg_allsquads)
		end
	end
	
	-- complete all objectives
	for index, objective in pairs(g_missionObjectives) do 
		Obj_SetState(objective.ID, OS_Complete)
	end
	
	World_NotifyDebugEndSP(true)

	CardinalMissionData = {
		report = {
			win = true,
			gameLength = World_GetGameTime(),
		},
	}
	
	Game_RetrieveTableData("CardinalMissionData", true) -- clear out the old store
	Game_StoreTableData("CardinalMissionData", CardinalMissionData)
	
	Game_EndSP(true, WR_OBJECTIVECOMPLETE)
	
end

--? @shortdesc Used to FAIL the entire mission
function MissionOMatic_Cheat_Lose()
	
	-- kill everything player-owned
	local player = World_GetPlayerAt(1)
	Player_GetAll(player)
	SGroup_Kill(sg_allsquads)
	
	-- fail all objectives
	for index, objective in pairs(g_missionObjectives) do 
		Obj_SetState(objective.ID, OS_Failed)
	end
	
	World_NotifyDebugEndSP(false)
	
	CardinalMissionData = {
		report = {
			win = false,
			gameLength = World_GetGameTime(),
		},
	}
	
	Game_RetrieveTableData("CardinalMissionData", true) -- clear out the old store
	Game_StoreTableData("CardinalMissionData", CardinalMissionData)
	
	Game_EndSP(false, WR_OBJECTIVEFAILED)

end

--? @shortdesc Used to successfully COMPLETE all currently-active objectives
function MissionOMatic_Cheat_Complete_Obj()

	-- Complete all objectives that have STARTED
	for index, objective in pairs(__t_Objectives) do
		if objective.Type ~= OT_Secondary and Objective_IsStarted(objective) == true and Objective_IsComplete(objective) == false and Objective_IsFailed(objective) == false then
			
			-- First, figure out subobjectives, if there are any
			local subObjectives = Objective_GetSubObjectives(objective)
			local countPendingSubobjectives = 0
			
			-- First we want to extract started subobjectives
			local subobjsToComplete = {}
			-- We have to complete them separately or one subobjective might start another on completion,
			-- which could lead to that knock-on subobjective also getting completed before it becomes active
			for index, subObjective in pairs(subObjectives) do
				-- If an objective has any subobjectives that aren't yet resolved, we don't want to complete the objective itself yet
				if Objective_IsComplete(subObjective) == false and Objective_IsFailed(subObjective) == false then
					countPendingSubobjectives = countPendingSubobjectives + 1
					-- If we have a pending objective that is started, we need to complete it
					if Objective_IsStarted(subObjective) == true then
						table.insert(subobjsToComplete, subObjective)
					end
				end
			end
			
			-- Complete only the ones that were already started here
			for index, subObjective in pairs(subobjsToComplete) do
				print("CHEAT - Completing Sub: "..Loc_ToAnsi(subObjective.Title))
				Objective_Complete(subObjective)
			end
			
			-- If there weren't any subobjectives to resolve, we may have to resolve this directly
			if countPendingSubobjectives <= 0 then
				Objective_Complete(objective)
				print("CHEAT - Completing Obj: "..Loc_ToAnsi(objective.Title))
			end
		end
	end

end

--? @shortdesc Used to FAIL all currently-active objectives
function MissionOMatic_Cheat_Fail_Obj()

	-- Fail all objectives that have STARTED
	for index, objective in pairs(__t_Objectives) do
		if objective.Type ~= OT_Secondary and Objective_IsStarted(objective) == true and Objective_IsComplete(objective) == false and Objective_IsFailed(objective) == false then
			
			-- First, figure out subobjectives, if there are any
			local subObjectives = Objective_GetSubObjectives(objective)
			local countPendingSubobjectives = 0
			
			-- First we want to extract started subobjectives
			local subobjsToFail = {}
			-- We have to fail them separately or one subobjective might start another on failure,
			-- which could lead to that knock-on subobjective also getting failed before it becomes active
			for index, subObjective in pairs(subObjectives) do
				-- If an objective has any subobjectives that aren't yet resolved, we don't want to fail the objective itself yet
				if Objective_IsComplete(subObjective) == false and Objective_IsFailed(subObjective) == false then
					countPendingSubobjectives = countPendingSubobjectives + 1
					-- If we have a pending objective that is started, we need to fail it
					if Objective_IsStarted(subObjective) == true then
						table.insert(subobjsToFail, subObjective)
					end
				end
			end
			
			-- Fail only the ones that were already started here
			for index, subObjective in pairs(subobjsToFail) do
				print("CHEAT - Failing Sub: "..Loc_ToAnsi(subObjective.Title))
				Objective_Fail(subObjective)
			end
			
			-- If there weren't any subobjectives to resolve, we may have to resolve this directly
			if countPendingSubobjectives <= 0 then
				Objective_Fail(objective)
				print("CHEAT - Failing Obj: "..Loc_ToAnsi(objective.Title))
			end
		end
	end

end

-- Overrides the default player flags on Holy Order Units. MUST BE RUN DURING LOAD (run right after file imports)
function MissionOMatic_UpdateHolyOrderFlags()
	UI_OverrideUIProperty(SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEMPLAR_CRU, "flag_icon", "images\\civ_flags\\civ_icon_secondary_tem")
	UI_OverrideUIProperty(SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEMPLAR_MASTER_CRU, "flag_icon", "images\\civ_flags\\civ_icon_secondary_tem")
	UI_OverrideUIProperty(SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEUTON_CRU, "flag_icon", "images\\civ_flags\\civ_icon_secondary_teu")
	UI_OverrideUIProperty(SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEUTON_MASTER_CRU, "flag_icon", "images\\civ_flags\\civ_icon_secondary_teu")
	UI_OverrideUIProperty(SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_HOSPITALLER_CRU, "flag_icon", "images\\civ_flags\\civ_icon_secondary_hos")
	UI_OverrideUIProperty(SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_HOSPITALLER_MASTER_CRU, "flag_icon", "images\\civ_flags\\civ_icon_secondary_hos")
end