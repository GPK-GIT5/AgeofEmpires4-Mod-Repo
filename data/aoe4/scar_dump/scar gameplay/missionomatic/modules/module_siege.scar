	else
		--print(tostring(siegeModule.descriptor).." trying to render aid against "..tostring(Debug_ScartypeToString(target)))
	end
	
end

--? @shortdesc Adds units to the internal SGroups - siege weapons go into the engines group, everything else goes into crew
function Siege_AddSGroup(moduleData, sgroup)

	local siegeModule = Prefab_GetInstance(moduleData)	

	local villagerTypes = {
		"scar_villager",
		"scar_armed_villager",
	}
	
	local siegeTypes = {
		"scar_ram",
		"scar_siege_tower",
		"scar_trebuchet_cw",
		"scar_trebuchet_traction",
		"scar_mangonel",
		"scar_springald",
		"scar_ribauldequin",
		"scar_bombard",
	}
	
	local newEngines = SGroup_CreateUnique("")
	-- Remove villagers entirely
	SGroup_Filter(sgroup, villagerTypes, FILTER_REMOVE)
	SGroup_Filter(sgroup, siegeTypes, FILTER_KEEP, newEngines)
	-- Add these to the modules SGroups
	SGroup_AddGroup(siegeModule.sgroupCrew, sgroup)
	SGroup_AddGroup(siegeModule.sgroupEngines, newEngines)
	
	-- Only proceed if we have any units in the new group
	if not SGroup_IsEmpty(sgroup) or not SGroup_IsEmpty(newEngines) then
		
		-- If we've made new units, update the encounter. We've already added the units to the SGroup
		Siege_CreateEncounters(siegeModule)

	end
	
	-- Now that those units are in the module and encounter SGroups, we don't need them anymore
	SGroup_Destroy(newEngines)
	
end

function Siege_UnderAttackTest(moduleData)

	local siegeModule = Prefab_GetInstance(moduleData)	
	
	local crewUnderAttack = false
	if siegeModule.sgroupCrew ~= nil then
		crewUnderAttack = SGroup_IsUnderAttack(siegeModule.sgroupCrew, ANY, 5)
	end
	
	local enginesUnderAttack = false
	if siegeModule.sgroupEngines ~= nil then
		enginesUnderAttack = SGroup_IsUnderAttack(siegeModule.sgroupEngines, ANY, 5)
	end
	
	local result = crewUnderAttack or enginesUnderAttack
	
	return result
	
end

function Siege_TriggerUnderAttack(moduleData)

	local siegeModule = Prefab_GetInstance(moduleData)

	if siegeModule.data.attackEncounter ~= nil and siegeModule.data.attackEncounter:HasGoalTriggered() == false then
		siegeModule.data.attackEncounter:TriggerGoal()
	end
	
	if siegeModule.data.defendEncounter ~= nil and siegeModule.data.defendEncounter:HasGoalTriggered() == false then
		siegeModule.data.defendEncounter:TriggerGoal()
	end
	
	print(siegeModule.descriptor.." under attack")
	
end

function Siege_TriggerAttackOver(moduleData)

	local siegeModule = Prefab_GetInstance(moduleData)

	if siegeModule.data.attackEncounter ~= nil and siegeModule.data.attackEncounter:HasGoalTriggered() == true then
		siegeModule.data.attackEncounter:RestartGoal()
	end
	
	if siegeModule.data.defendEncounter ~= nil and siegeModule.data.defendEncounter:HasGoalTriggered() == true then
		siegeModule.data.defendEncounter:RestartGoal()
	end
	
	print(siegeModule.descriptor.." attack over")
	
end

--? @shortdesc Returns true if all the Siege module's units are dead
function Siege_IsDefeated(moduleData)

	local siegeModule = Prefab_GetInstance(moduleData)
	
	return SGroup_CountSpawned(siegeModule.sgroupCrew) <= 0 and SGroup_CountSpawned(siegeModule.sgroupEngines) <= 0
	
end