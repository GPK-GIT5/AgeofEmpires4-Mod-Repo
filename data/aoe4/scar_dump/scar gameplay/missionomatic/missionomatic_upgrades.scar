ai_never_learn = {
	UPG.COMMON.UPGRADE_TECH_UNIVERSITY_MURDER_HOLES_4,
}

--? @shortdesc Learns and hides upgrades for each player in mission based on individual CurrentAge and MaxAge. 
--? @args PlayerID playerID, Bool includeCurrentAge[, Table exceptions], string race
function PlayerUpgrades_Auto(playerID, includeCurrentAge, exceptions, race)
	local includeCurrentAge = includeCurrentAge or false
	local currentAge = Player_GetCurrentAge(playerID)
	local exceptions = exceptions or {}
	local race = race or _PlayerUpgrades_GetRaceName(playerID)

	
	if playerID == World_GetPlayerAt(1) then -- If a Human in a Build mission, give them the CurrentAge-1 upgrades so they have something to build
		--Special case: Mongols get Incendiary Arrows by default
		if race == "mongol" then
			Player_CompleteUpgrade(playerID, UPG.MONGOL.UPGRADE_RANGED_INCENDIARY_MON)
		end
		--Special case: French apply appropriate Melee Damage upgrade. This is already happening as a Civ thing, we're just adding this to cover the event queue at mission start.
		if race == "french" then
			if currentAge >= 2 then
				Player_CompleteUpgrade(playerID, UPG.COMMON.UPGRADE_MELEE_DAMAGE_I)
			end
			if currentAge >= 3 then
				Player_CompleteUpgrade(playerID, UPG.COMMON.UPGRADE_MELEE_DAMAGE_II)
			end
			if currentAge >= 4 then
				Player_CompleteUpgrade(playerID, UPG.COMMON.UPGRADE_MELEE_DAMAGE_III)
			end
		end
		
		if not includeCurrentAge then
			currentAge = currentAge-1
		end
		PlayerUpgrades_LearnAllUnits(playerID, currentAge, exceptions, race)
		PlayerUpgrades_LearnAllResearch(playerID, currentAge, exceptions, race)
		
		PlayerUpgrades_ApplyHealthBonuses(World_GetPlayerAt(1))
		
	else -- For AI players
		
		-- insert ai_never_learn techs into exceptions list
		for i,v in ipairs(ai_never_learn) do
			table.insert(exceptions, v)
		end
			
			
		PlayerUpgrades_LockAllUpgrades(playerID, 1, race)
		PlayerUpgrades_LearnAllUnits(playerID, currentAge, exceptions, race)
		
		-- Split research upgrades by difficulty
		PlayerUpgrades_LearnAllResearch(playerID, Util_DifVar({currentAge-2, currentAge-2, currentAge-1, currentAge}), exceptions, race)
		
		-- Dont let the AI research any exceptions
		_PlayerUpgrades_LockExceptions(playerID, exceptions)
		
		Modify_PlayerPopCap(playerID, 1000, MUT_Addition)
		Modify_PlayerMaxPopCap(playerID, 1000, MUT_Addition)
		
		-- Learn Siege Engineers and award wood to AI to support ram construction
		Player_CompleteUpgrade(playerID, UPG.COMMON.UPGRADE_SIEGE_ENGINEERS)
		Player_AddResource(playerID, RT_Wood, 10000)
	end
	PlayerUpgrades_HideAgeUpAbilities(playerID, Player_GetMaximumAge(playerID))
	PlayerUpgrades_HideAllUpgrades(playerID, Player_GetMaximumAge(playerID), race)
end

--? @shortdesc Check if special health bonuses should be applied to the player
function PlayerUpgrades_ApplyHealthBonuses(player)
		
	-- health bonuses differ between XBox and KBM
	if UI_IsXboxControllerUI() then
		
		local health_upgrade_names = {
			"console_health_bonus_story",
			"console_health_bonus_easy",
			"console_health_bonus_intermediate",
			"console_health_bonus_hard"
		}
		
		local health_upgrade_name = Util_DifVar(health_upgrade_names)
		Player_CompleteUpgrade(player, BP_GetUpgradeBlueprint(health_upgrade_name))
	else
		if Game_GetSPDifficulty() == GD_EASY then
			Player_CompleteUpgrade(player, BP_GetUpgradeBlueprint("story_mode_health_bonus"))
		end
	end
end

--? @shortdesc Learns all unit upgrades for player up to and including desiredAge. 
--? @args PlayerID playerID, Int desiredAge[, Table exceptions], string race
function PlayerUpgrades_LearnAllUnits(playerID, desiredAge, exceptions, race)
	if desiredAge >= 1 then
		_PlayerUpgrades_UpgradeByRaceAndAge(playerID, race, "AGE_DARK", unit_upgrades, exceptions)
	end
	if desiredAge >= 2 then
		_PlayerUpgrades_UpgradeByRaceAndAge(playerID, race, "AGE_FEUDAL", unit_upgrades, exceptions)
	end
	if desiredAge >= 3 then
		_PlayerUpgrades_UpgradeByRaceAndAge(playerID, race, "AGE_CASTLE", unit_upgrades, exceptions)
	end
	if desiredAge >= 4 then
		_PlayerUpgrades_UpgradeByRaceAndAge(playerID, race, "AGE_IMPERIAL", unit_upgrades, exceptions)
	end
end		

--? @shortdesc Learns all research upgrades for player up to and including desiredAge. 
--? @args PlayerID playerID, Int desiredAge[, Table exceptions], string race
function PlayerUpgrades_LearnAllResearch(playerID, desiredAge, exceptions, race)
	if desiredAge >= 1 then
		_PlayerUpgrades_UpgradeByRaceAndAge(playerID, race, "AGE_DARK", research_upgrades, exceptions)
	end
	if desiredAge >= 2 then
		_PlayerUpgrades_UpgradeByRaceAndAge(playerID, race, "AGE_FEUDAL", research_upgrades, exceptions)
	end
	if desiredAge >= 3 then
		_PlayerUpgrades_UpgradeByRaceAndAge(playerID, race, "AGE_CASTLE", research_upgrades, exceptions)
	end
	if desiredAge >= 4 then
		_PlayerUpgrades_UpgradeByRaceAndAge(playerID, race, "AGE_IMPERIAL", research_upgrades, exceptions)
	end
end
	
--? @shortdesc Lock all unit upgrades for player beyond maxAge. 
--? @args PlayerID playerID, Int desiredAge, string race
function PlayerUpgrades_LockAllUpgrades(playerID, maxAge, race)
	if maxAge <= 1 then
		_PlayerUpgrades_LockByRaceAndAge(playerID, race, "AGE_FEUDAL", research_upgrades)
	end
	if maxAge <= 2 then
		_PlayerUpgrades_LockByRaceAndAge(playerID, race, "AGE_CASTLE", research_upgrades)
	end
	if maxAge <= 3 then
		_PlayerUpgrades_LockByRaceAndAge(playerID, race, "AGE_IMPERIAL", research_upgrades)
	end
	_PlayerUpgrades_LockByRaceAndAge(playerID, race, "ALWAYS_REMOVE", research_upgrades)
end

--? @shortdesc Hides all unit upgrades for player beyond maxAge. 
--? @args PlayerID playerID, Int desiredAge, string race
function PlayerUpgrades_HideAllUpgrades(playerID, maxAge, race)
	if maxAge <= 1 then
		_PlayerUpgrades_HideByRaceAndAge(playerID, race, "AGE_FEUDAL")
	end
	if maxAge <= 2 then
		_PlayerUpgrades_HideByRaceAndAge(playerID, race, "AGE_CASTLE")
	end
	if maxAge <= 3 then
		_PlayerUpgrades_HideByRaceAndAge(playerID, race, "AGE_IMPERIAL")
	end
	_PlayerUpgrades_HideByRaceAndAge(playerID, race, "ALWAYS_REMOVE")
end

function _PlayerUpgrades_UpgradeByRaceAndAge(playerID, raceName, age, table, exceptions)
	if raceName == "mongol" then -- Mongols have separate upgrade tables for improved tech that we don't auto-learn
		for i,v in ipairs(table[raceName][age][1]) do
			if exceptions == nil or has_value(exceptions, table[raceName][age][1][i]) == false then
				Player_CompleteUpgrade(playerID, table[raceName][age][1][i])
			end
		end
	else -- Non-mongol
		for i,v in ipairs(table[raceName][age]) do 
			if exceptions == nil or has_value(exceptions, table[raceName][age][i]) == false then
				Player_CompleteUpgrade(playerID, table[raceName][age][i])
			end
		end
	end
end

function _PlayerUpgrades_LockByRaceAndAge(playerID, raceName, age, table, exceptions)
	if raceName == "mongol" then -- Mongols have separate upgrade tables for improved tech that we don't auto-learn
		for i,v in ipairs(table[raceName][age][1]) do
			if exceptions == nil or has_value(exceptions, table[raceName][age][1][i]) == false then
				Player_SetUpgradeAvailability(playerID, table[raceName][age][1][i], ITEM_LOCKED)
			end
		end
		for i,v in ipairs(table[raceName][age][2]) do
			if exceptions == nil or has_value(exceptions, table[raceName][age][2][i]) == false then
				Player_SetUpgradeAvailability(playerID, table[raceName][age][2][i], ITEM_LOCKED)
			end
		end
	else -- Non-mongol
		for i,v in ipairs(table[raceName][age]) do
			if exceptions == nil or has_value(exceptions, table[raceName][age][i]) == false then
				Player_SetUpgradeAvailability(playerID, table[raceName][age][i], ITEM_LOCKED)
			end
		end
	end
end

function _PlayerUpgrades_LockExceptions(playerID, exceptions)
	if scartype(exceptions) == ST_TABLE then
		for i,exception in ipairs(exceptions) do
			Player_SetUpgradeAvailability(playerID, exception, ITEM_LOCKED)
		end
	end
end

function _PlayerUpgrades_HideByRaceAndAge(playerID, raceName, age)
	for i,v in ipairs(unit_upgrades[raceName][age]) do
		Player_SetUpgradeAvailability(playerID, unit_upgrades[raceName][age][i], ITEM_REMOVED)
	end
	if raceName == "mongol" then -- Mongols have separate upgrade tables for improved tech that we don't auto-learn
		for i,v in ipairs(research_upgrades[raceName][age][1]) do
			Player_SetUpgradeAvailability(playerID, research_upgrades[raceName][age][1][i], ITEM_REMOVED)
		end
		for i,v in ipairs(research_upgrades[raceName][age][2]) do
			Player_SetUpgradeAvailability(playerID, research_upgrades[raceName][age][2][i], ITEM_REMOVED)
		end
	else -- Non-mongol
		for i,v in ipairs(research_upgrades[raceName][age]) do
			Player_SetUpgradeAvailability(playerID, research_upgrades[raceName][age][i], ITEM_REMOVED)
		end
	end
	for i,v in ipairs(squad_production[raceName][age]) do
		Player_SetSquadProductionAvailability(playerID, squad_production[raceName][age][i], ITEM_REMOVED)
	end
	for i,v in ipairs(entity_production[raceName][age]) do
		Player_SetEntityProductionAvailability(playerID, entity_production[raceName][age][i], ITEM_REMOVED)
	end
end

function PlayerUpgrades_HideAgeUpAbilities(playerID, desiredAge)
	if desiredAge < 2 then
		Player_SetAbilityAvailability(playerID, BP_GetAbilityBlueprint("age_up_feudal"), ITEM_REMOVED)
	end
	if desiredAge < 3 then
		Player_SetAbilityAvailability(playerID, BP_GetAbilityBlueprint("age_up_castle"), ITEM_REMOVED)
	end
	if desiredAge < 4 then
		Player_SetAbilityAvailability(playerID, BP_GetAbilityBlueprint("age_up_imperial"), ITEM_REMOVED)
	end
end

--? @shortdesc Get race name, and convert campaign-only races to base races.
function _PlayerUpgrades_GetRaceName(playerID)
	local raceName = Player_GetRaceName(playerID)
	if raceName == "bohemia" or raceName == "poland" or raceName == "hungary" or raceName == "lithuania" then
		raceName = "hre"
	elseif raceName == "novgorod" then
		raceName = "rus"
	elseif raceName == "danes" or raceName == "saxons" then
		raceName = "english"
	elseif raceName == "crusader" then
		raceName = "french"
	end
	return raceName
end
	
function has_value (tab, val)
    for index, value in ipairs(tab) do
        if value == val then
            return true
        end
    end

    return false
end



--------------------------------
------TECH TREE MANAGEMENT------
--------------------------------

--Tech Tree ENUMS

TT_INCLUDE_TIERED = 1
TT_INCLUDE_NONTIERED = 2
TT_INCLUDE_BOTH = 3

--Tech Tree Functions

--? @shortdesc Completes all tech upgrades for the provided player based on age and tier option
--? @args playerID - The Player ID of the target player,
--? age - Numerical int of the age the player will be upgraded to,
--? includeTiered - Optional, uses TT_INCLUDE_TIERED, TT_INCLUDE_NONTIERED, or TT_INCLUDE_BOTH. Defaults to TT_INCLUDE_BOTH
function TechTree_GiveAllUpgrades_ByAge(playerID, age, includeTiered, optExclusionList)
	
	includeTiered = includeTiered or TT_INCLUDE_BOTH
	
	TechTree_GiveEconUpgrades(playerID, age, includeTiered, optExclusionList)
	TechTree_GiveMilitaryUpgrades(playerID, age, includeTiered, optExclusionList)
	TechTree_GiveUnitUpgrades(playerID, age, includeTiered, optExclusionList)
	
end

--? @shortdesc Completes economic tech upgrades for the provided player based on age and tier option
--? @args playerID - The Player ID of the target player,
--? age - Numerical int of the age the player will be upgraded to,
--? includeTiered - Optional, uses TT_INCLUDE_TIERED, TT_INCLUDE_NONTIERED, or TT_INCLUDE_BOTH. Defaults to TT_INCLUDE_BOTH
--? optExclusionList - A table of Blueprints to skip/exclude from the applied upgrades, defaults to blank
function TechTree_GiveEconUpgrades(playerID, age, includeTiered, optExclusionList)
		
	includeTiered = includeTiered or TT_INCLUDE_BOTH
	local upgradeTableTypes = {}
	
	optExclusionList = _ParseExclusionList(optExclusionList)	
	
	if includeTiered == TT_INCLUDE_TIERED then
		upgradeTableTypes = _TechTree_ConstructUpgradeTable(playerID, age, {"scar_tiered_upgrade", "scar_economic_upgrade"})
	elseif includeTiered == TT_INCLUDE_NONTIERED then
		upgradeTableTypes = _TechTree_ConstructUpgradeTable(playerID, age, {"scar_nontiered_upgrade", "scar_economic_upgrade"})
	else
		upgradeTableTypes = _TechTree_ConstructUpgradeTable(playerID, age, {"scar_economic_upgrade"})
	end
		
	local upgradeTable = BP_GetUpgradesMatchingTypes(upgradeTableTypes)
	for i, upgrade in ipairs(upgradeTable) do
		if Table_Contains(optExclusionList, upgrade) == false then
			_TechTree_DebugPrintUpgrade(upgrade)
			Player_CompleteUpgrade(playerID, upgrade)
		else
			print(tostring(upgrade).." is excluded, skipping.")
		end
	end
end

--? @shortdesc Completes economic tech upgrades for the provided player based on age and tier option
--? @args playerID - The Player ID of the target player,
--? age - Numerical int of the age the player will be upgraded to,
--? includeTiered - Optional, uses TT_INCLUDE_TIERED, TT_INCLUDE_NONTIERED, or TT_INCLUDE_BOTH. Defaults to TT_INCLUDE_BOTH
--? optExclusionList - A table of Blueprints to skip/exclude from the applied upgrades, defaults to blank
function TechTree_GiveMilitaryUpgrades(playerID, age, includeTiered, optExclusionList)
	
	includeTiered = includeTiered or TT_INCLUDE_BOTH
