	optExclusionList = _ParseExclusionList(optExclusionList)
	
	if includeTiered == TT_INCLUDE_TIERED then
		upgradeTableTypes = _TechTree_ConstructUpgradeTable(playerID, age, {"scar_tiered_upgrade", "scar_military_upgrade"})
	elseif includeTiered == TT_INCLUDE_NONTIERED then
		upgradeTableTypes = _TechTree_ConstructUpgradeTable(playerID, age, {"scar_nontiered_upgrade", "scar_military_upgrade"})
	else
		upgradeTableTypes = _TechTree_ConstructUpgradeTable(playerID, age, {"scar_military_upgrade"})
	end
				
	local upgradeTable = BP_GetUpgradesMatchingTypes(upgradeTableTypes)
	for i, upgrade in ipairs(upgradeTable) do
		if Table_Contains(optExclusionList, upgrade) == false then
			_TechTree_DebugPrintUpgrade(upgrade)
			Player_CompleteUpgrade(playerID, upgrade)
		else
			print(tostring(upgrade).." is excluded, skipping.")
		end
	end
end

--? @shortdesc Completes economic tech upgrades for the provided player based on age and tier option
--? @args playerID - The Player ID of the target player,
--? age - Numerical int of the age the player will be upgraded to,
--? includeTiered - Optional, uses TT_INCLUDE_TIERED, TT_INCLUDE_NONTIERED, or TT_INCLUDE_BOTH. Defaults to TT_INCLUDE_BOTH
--? optExclusionList - A table of Blueprints to skip/exclude from the applied upgrades, defaults to blank
function TechTree_GiveUnitUpgrades(playerID, age, includeTiered, optExclusionList)
	
	includeTiered = includeTiered or TT_INCLUDE_BOTH
	local upgradeTableTypes = {}	
	
	optExclusionList = _ParseExclusionList(optExclusionList)
	
	if includeTiered == TT_INCLUDE_TIERED then
		upgradeTableTypes = _TechTree_ConstructUpgradeTable(playerID, age, {"scar_tiered_upgrade", "scar_unit_upgrade"})
	elseif includeTiered == TT_INCLUDE_NONTIERED then
		upgradeTableTypes = _TechTree_ConstructUpgradeTable(playerID, age, {"scar_nontiered_upgrade", "scar_unit_upgrade"})
	else
		upgradeTableTypes = _TechTree_ConstructUpgradeTable(playerID, age, {"scar_unit_upgrade"})
	end
		
	local upgradeTable = BP_GetUpgradesMatchingTypes(upgradeTableTypes)
	for i, upgrade in ipairs(upgradeTable) do
		if Table_Contains(optExclusionList, upgrade) == false then
			_TechTree_DebugPrintUpgrade(upgrade)
			Player_CompleteUpgrade(playerID, upgrade)
		else
			print(tostring(upgrade).." is excluded, skipping.")
		end
	end
end

function TechTree_EnableDebugPrinting()
	debug_tech_tree = true
	printedUpgrades = {}
end

function _TechTree_DebugPrintUpgrade(upgrade)
	if debug_tech_tree and Table_Contains(printedUpgrades, upgrade) == false then
		print("    "..BP_GetName(upgrade))
		table.insert(printedUpgrades, upgrade)
	end
end

function _TechTree_ConstructUpgradeTable(playerID, age, upgradeTypes)
		
	local upgradeTypeList = {}
	local playerRaceTag = _GetPlayerRaceNameType(playerID)
	local ageTypes = {"scar_dark_age_upgrade", "scar_feudal_age_upgrade", "scar_castle_age_upgrade", "scar_imperial_age_upgrade"}
		
	for i = 1, age do
		local currentTable = {}
		table.insert(currentTable, playerRaceTag)
		table.insert(currentTable, ageTypes[i])
		
		if upgradeTypes ~= nil then
			for j = 1, #upgradeTypes do
				table.insert(currentTable, upgradeTypes[j])		
			end	
		end
		
		table.insert(upgradeTypeList, currentTable)
	end
	
	return upgradeTypeList
		
end

function _GetPlayerRaceNameType(playerID)
	local playerRace = Player_GetRaceName(playerID)
	local playerRaceTag = ""
	
	if playerRace == "abbasid" then
		playerRaceTag = "abbasid_upgrade"
	elseif playerRace == "abbasid_ha_01" then
		playerRaceTag = "abbasid_ha_01_upgrade"
	elseif playerRace == "ayyubid_cmp" or 
		playerRace == "fatimid_cmp" or
		playerRace == "mamluk_cmp" or
		playerRace == "saladin_cmp" or
		playerRace == "seljuk_cmp" then
		playerRaceTag = "ayyubid_cmp_upgrade"
	elseif playerRace == "byzantine" then
		playerRaceTag = "byzantine_upgrade"
	elseif playerRace == "chinese" then
		playerRaceTag = "chinese_upgrade"
	elseif playerRace == "chinese_ha_01" then
		playerRaceTag = "chinese_ha_01_upgrade"
	elseif playerRace == "crusader_cmp" or
		playerRace == "antioch_cmp" or
		playerRace == "cyprus_cmp" then
		playerRaceTag = "crusader_cmp_upgrade"
	elseif playerRace == "english" then
		playerRaceTag = "english_upgrade"
	elseif playerRace == "french" then
		playerRaceTag = "french_upgrade"
	elseif playerRace == "french_ha_01" then
		playerRaceTag = "french_ha_01_upgrade"
	elseif playerRace == "hre" or playerRace == "hre_ha_01" then
		playerRaceTag = "hre_upgrade"
	elseif playerRace == "japanese_ha_sen" then
		playerRaceTag = "japanese_upgrade"
	elseif playerRace == "japanese" then
		playerRaceTag = "japanese_ha_sen_upgrade"
	elseif playerRace == "malian" then
		playerRaceTag = "malian_upgrade"
	elseif playerRace == "mongol" or playerRace == "il_khanate_cmp" then
		playerRaceTag = "mongol_upgrade"
	elseif playerRace == "ottoman" then
		playerRaceTag = "ottoman_upgrade"
	elseif playerRace == "rus" then
		playerRaceTag = "rus_upgrade"
	elseif playerRace == "sultanate" then
		playerRaceTag = "sultanate_upgrade"
	end
	
	return playerRaceTag
end

--? @shortdesc Hides all SBPs, EBPs, and Upgrades from ages beyond the provided playerMaxAge 
--? @args playerID - The Player ID of the target player,
--? playerMaxAge - Max age the player could reach during this mission
function TechTree_HideProductionByAge_UsingTypes(playerID, playerMaxAge)
		
	local playerRaceTag = _GetPlayerRaceNameType(playerID)	
	local upgrade_ageTypes = {{"scar_dark_age_upgrade", playerRaceTag}, {"scar_feudal_age_upgrade", playerRaceTag}, {"scar_castle_age_upgrade", playerRaceTag}, {"scar_imperial_age_upgrade", playerRaceTag}}
	local ageTypes = {{"scar_age1"}, {"scar_age2"}, {"scar_age3"}, {"scar_age4"}}
	for i = 1, playerMaxAge do
		table.remove(upgrade_ageTypes, 1)
		table.remove(ageTypes, 1)
	end
	
	_TechTree_HideUpgradesByType(playerID, upgrade_ageTypes)
		
	_TechTree_HideSquadByType(playerID, ageTypes)
	
	Player_SetMaximumAge(playerID, playerMaxAge)

end

function _TechTree_HideUpgradesByType(playerID, stringType)
	local upgradeTable = BP_GetUpgradesMatchingTypes(stringType)
	for i, upgradeID in ipairs(upgradeTable) do
		Player_SetUpgradeAvailability(playerID, upgradeID, ITEM_REMOVED)
	end
end

function _TechTree_HideEntityByType(playerID, stringType)
	local entityTable = BP_GetEntityBlueprintsWithType(stringType)
	if entityTable ~= nil then
		for i, entityID in ipairs(entityTable) do
			Player_SetEntityProductionAvailability(playerID, entityID, ITEM_REMOVED)
		end
	end
end

function _TechTree_HideSquadByType(playerID, stringType)
	local squadTable = BP_GetSquadBlueprintsWithType(stringType)
	if squadTable ~= nil then
		for i, squadID in ipairs(squadTable) do
			Player_SetSquadProductionAvailability(playerID, squadID, ITEM_REMOVED)
		end
	end
end

function _ParseExclusionList(optExclusionList)		
	if optExclusionList ~= nil then
		if scartype(optExclusionList) ~= ST_TABLE then
			optExclusionList = {optExclusionList}
		end
		for i, exclusion in ipairs(optExclusionList) do
			if scartype(exclusion) ~= ST_PBG then
				assert(false, "optExclusionList contains an invalid blueprint at index: "..i)
			end
		end
	else
		optExclusionList = {}
	end
	
	return optExclusionList
end

function FoodReserves_Init()
	Rule_AddGlobalEvent(FoodReserves_OnUpgrade, GE_UpgradeComplete)
end

function FoodReserves_OnUpgrade(context, data)
	if context.upgrade == UPG.AYYUBID_CMP.UPGRADE_FOOD_RESERVES_AYY then
		eg_food_reserves_capital_tc = Player_GetEntitiesFromBlueprint(player1, EBP.AYYUBID_CMP.BUILDING_TOWN_CENTER_CAPITAL_AYY)
		assert(EGroup_CountSpawned(eg_food_reserves_capital_tc) == 1, "FoodReserves cannot be initialized if the player doesn't have exactly 1 captial TC")
		Rule_AddInterval(FoodReserves_Monitor, 5)
		FoodReserves_Monitor()
	end
end

function FoodReserves_Monitor(context, data)
	if EGroup_CountSpawned(eg_food_reserves_capital_tc) > 0 then
		Player_AddResource(World_GetPlayerAt(1), RT_Food, 7, RES_Resourcing)
		local entity = EGroup_GetEntityAt(eg_food_reserves_capital_tc, 1)
		UI_CreateEntityKickerMessage(entity, "$11255735", "icons/resources/resource_food_icon", "", 3, 0, 8)
	end
end

	