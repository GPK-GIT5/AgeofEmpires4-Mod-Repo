--? @shortdesc Modify a player's current pop cap.
--? @extdesc Usage types are MUT_Multiplication (default) or MUT_Addition.
--? @args PlayerID player, Real amount[, ModifierUsageType usage]
function Modify_PlayerPopCap(player, amount, usage)

	usage = usage or MUT_Multiplication

	-- Create the appropriate modifier
	local modifier = Modifier_Create(MAT_Player, "personnel_cap_player_modifier", usage, false, amount, "")	
	
	local result = Modifier_ApplyToPlayer(modifier, player, 0)
	
	return result
	
end

--? @shortdesc Modifies the maximum speed for a squad when NOT IN COMBAT, one modifier per squad
--? @result void
--? @args SGroup sgroup, Real scalefactor, MUT Usage (MUT_Multiplication, MUT_Addition, MUT_Set)
function Modify_UnitSpeedWhenNotInCombat(sgroup, factor, usage)
	for i = 1, SGroup_CountSpawned(sgroup) do
		local squad = SGroup_GetSpawnedSquadAt(sgroup, i)
		local squad_id = Squad_GetID(squad)
		--remove existing modifier if it exists
		if _UnitSpeedInCombatTable[squad_id] ~= nil then
			local data = _UnitSpeedInCombatTable[squad_id]
			Modifier_Remove(data.modid)
			_UnitSpeedInCombatTable[squad_id] = nil
		end
		--add new modifier
		local data = {
			factor = factor,
			usage = usage,
			modid = nil
		}
		_UnitSpeedInCombatTable[squad_id] = data
	end
	if not Rule_Exists(UnitSpeedNotInCombat_Manager) then 
		Rule_AddInterval(UnitSpeedNotInCombat_Manager, 0.25)
	end
end

--? @shortdesc Remove UnitSpeedInCombat modifier from a squad group
--? @result void
--? @args SGroup sgroup
function Remove_UnitSpeedInCombatModifier(sgroup)
	for i = 1, SGroup_CountSpawned(sgroup) do
		local squad = SGroup_GetSpawnedSquadAt(sgroup, i)
		local squad_id = Squad_GetID(squad)
		--remove existing modifier if it exists
		if _UnitSpeedInCombatTable[squad_id] ~= nil then
			local data = _UnitSpeedInCombatTable[squad_id]
			Modifier_Remove(data.modid)
			_UnitSpeedInCombatTable[squad_id] = nil
		end
	end
end

function UnitSpeedNotInCombat_Manager(context, data)
	local function _Squad_IsInCombat(squad)
		local entity = Squad_GetFirstEntity(squad)

		-- a valid combat target means the entity is in combat
		return Entity_GetStateTreeTargeting_EntityTarget(entity, "statetree_entity_target_type", "COMBAT_TARGET") ~= nil
	end
	
	for squad_id, data in pairs(_UnitSpeedInCombatTable) do
		if Squad_IsValid(squad_id) == false then
			_UnitSpeedInCombatTable[squad_id] = nil
		else
			local squad = Squad_FromID(squad_id)
			if Squad_IsAlive(squad) == false then
				_UnitSpeedInCombatTable[squad_id] = nil
			else
				local inCombat = _Squad_IsInCombat(squad)
				if (inCombat and data.modid ~= nil) then
					Modifier_Remove(data.modid)
					data.modid = nil
				elseif (not inCombat and data.modid == nil) then
					SGroup_Single(sg_single, squad)
					local modids = Modify_UnitSpeed(sg_single, data.factor, 0, data.usage)
					data.modid = modids[1]
				end
			end
		end
	end
end



--? @shortdesc Modifies the maximum speed for a squad until it first enters combat, one modifier per squad
--? @result void
--? @args SGroup sgroup, Real scalefactor, MUT Usage (MUT_Multiplication, MUT_Addition, MUT_Set)
function Modify_UnitSpeedUntilInCombat(sgroup, factor, usage)
	if SGroup_CountSpawned(sgroup) > 0 then
		local group_data = {}
		group_data.squad_datas = {}
		group_data.normalmodifier = Modifier_Create(MAT_Entity, "speed_maximum_modifier", usage, true, factor, "")
		group_data.slowmodifier = Modifier_Create(MAT_Entity, "speed_maximum_modifier", usage, true, factor/2, "")
		group_data.sgroup = SGroup_CreateUniqueWithPrefix("sg_Modify_UnitSpeedUntilInCombat")
		SGroup_AddGroup(group_data.sgroup, sgroup)
		
		for i = 1, SGroup_CountSpawned(sgroup) do
			local squad = SGroup_GetSpawnedSquadAt(sgroup, i)
			local squad_data = {}
			squad_data.squad_id = Squad_GetID(squad)
			squad_data.is_in_mud = false
			squad_data.modid = Modifier_ApplyToSquad(group_data.normalmodifier, squad, 0)
			table.insert(group_data.squad_datas, squad_data)
		end
		
		_UnitSpeedUntilInCombatInsertIndex = _UnitSpeedUntilInCombatInsertIndex + 1
		if _UnitSpeedUntilInCombatInsertIndex > _UnitSpeedUntilInCombatBuckets then
			_UnitSpeedUntilInCombatInsertIndex = 1
		end
		table.insert(_UnitSpeedUntilInCombatTables[_UnitSpeedUntilInCombatInsertIndex], group_data)
		
		if not Rule_Exists(UnitSpeedUntilInCombat_Manager) then 
			Rule_Add(UnitSpeedUntilInCombat_Manager)
		end
	end
end


function UnitSpeedUntilInCombat_Manager(context, data)
	_UnitSpeedUntilInCombatMonitorIndex = _UnitSpeedUntilInCombatMonitorIndex + 1
	if _UnitSpeedUntilInCombatMonitorIndex > _UnitSpeedUntilInCombatBuckets then
		_UnitSpeedUntilInCombatMonitorIndex = 1
	end
	local unitSpeedUntilInCombatTable = _UnitSpeedUntilInCombatTables[_UnitSpeedUntilInCombatMonitorIndex]
	for i = #unitSpeedUntilInCombatTable, 1, -1 do
		local group_data = unitSpeedUntilInCombatTable[i]
		if SGroup_CountSpawned(group_data.sgroup) == 0 then
			UnitSpeedUntilInCombat_Exit(group_data)
			table.remove(unitSpeedUntilInCombatTable, i)
			break
		end

		for _, squad_data in ipairs(group_data.squad_datas) do
			if Squad_IsValid(squad_data.squad_id) then
				local squad = Squad_FromID(squad_data.squad_id)
				if Squad_Count(squad) > 0 then
					local entity = Squad_GetFirstEntity(squad)
					local in_combat = Entity_GetStateTreeTargeting_EntityTarget(entity, "statetree_entity_target_type", "COMBAT_TARGET") ~= nil
					
					if in_combat then
						table.remove(unitSpeedUntilInCombatTable, i)
						UnitSpeedUntilInCombat_Exit(group_data)
						break
					end
					
					if Entity_GetStateModelBool(entity, "rogue_is_slowed_by_mud") == true and squad_data.is_in_mud == false then
						Modifier_Remove(squad_data.modid)
						squad_data.modid = Modifier_ApplyToSquad(group_data.slowmodifier, squad, 0)
						squad_data.is_in_mud = true
					elseif Entity_GetStateModelBool(entity, "rogue_is_slowed_by_mud") == false and squad_data.is_in_mud == true then
						Modifier_Remove(squad_data.modid)
						squad_data.modid = Modifier_ApplyToSquad(group_data.normalmodifier, squad, 0)
						squad_data.is_in_mud = false
					end
				end
			end
		end
	end
end

function UnitSpeedUntilInCombat_Exit(group_data)
	for _, squad_data in ipairs(group_data.squad_datas) do
		Modifier_Remove(squad_data.modid)
	end
	SGroup_Destroy(group_data.sgroup)	
end

--? @shortdesc Remove UnitSpeedUntilInCombat modifier from a squad group
--? @result void
--? @args SGroup sgroup
function Remove_UnitSpeedUntilInCombatModifier(sgroup)
	for _, unitSpeedUntilInCombatTable in ipairs(_UnitSpeedUntilInCombatTables) do
		for i = #unitSpeedUntilInCombatTable, 1, -1 do
			local data = unitSpeedUntilInCombatTable[i]
			if data.sgroup == sgroup then
				Modifier_Remove(data.modid)
				SGroup_Destroy(data.sgroup)
				table.remove(unitSpeedUntilInCombatTable, i)
			end
		end
	end
end

--? @shortdesc Raise or lower the ceiling that a player's pop cap can reach. The does NOT change the current pop cap, use Modify_PlayerPopCap() for that.
--? @extdesc Usage types are MUT_Multiplication (default) or MUT_Addition.
--? @args PlayerID player, Real amount[, ModifierUsageType usage]
function Modify_PlayerMaxPopCap(player, amount, usage)

	usage = usage or MUT_Multiplication

	-- Create the appropriate modifier
	local modifier = Modifier_Create(MAT_Player, "max_personnel_cap_player_modifier", usage, false, amount, "")	
	
	local result = Modifier_ApplyToPlayer(modifier, player, 0)
	
	return result
	
end