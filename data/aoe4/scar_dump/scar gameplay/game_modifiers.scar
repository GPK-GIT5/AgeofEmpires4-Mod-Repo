import("modifiers.scar")

local _upgradeResourceCostModifiers =
{
	[RT_Action] = nil,
	[RT_Command] = nil,
	[RT_Food] = 'upgrade_cost_food_modifier',
	[RT_Wood] = 'upgrade_cost_wood_modifier',
	[RT_Gold] = 'upgrade_cost_gold_modifier',
	[RT_Stone] = 'upgrade_cost_stone_modifier'
}

local _playerResourceIncomeModifiers = 
{
	[RT_Action] = nil,
	[RT_Command] = nil,
	[RT_Food] = nil,
	[RT_Wood] = nil,
	[RT_Gold] = nil,
	[RT_Stone] = nil
}

local _playerResourceCapModifiers =
{
	[RT_Action] = nil,
	[RT_Command] = nil,
	[RT_Food] = nil,
	[RT_Wood] = nil,
	[RT_Gold] = nil,
	[RT_Stone] = nil
}

local _entityResourceCostModifiers =
{
	[RT_Action] = nil,
	[RT_Command] = nil,
	[RT_Food] = 'resource_entity_cost_food',
	[RT_Wood] = 'resource_entity_cost_wood',
	[RT_Gold] = 'resource_entity_cost_gold',
	[RT_Stone] = 'resource_entity_cost_stone'
}

local _playerResourceUpkeepModifiers = 
{
	[RT_Action] = nil,
	[RT_Command] = nil,
	[RT_Food] = nil,
	[RT_Wood] = nil,
	[RT_Gold] = nil,
	[RT_Stone] = nil
}

function Modifier_InitGame()
	Modifier_InitResourceBasedModifierTables(
		_upgradeResourceCostModifiers,
		_playerResourceIncomeModifiers,
		_playerResourceCapModifiers,
		_entityResourceCostModifiers,
		_playerResourceUpkeepModifiers)
	
	_UnitSpeedInCombatTable = {}
	
	_UnitSpeedUntilInCombatBuckets = 2 -- increasing this number improves perf, but at the cost of checking each unit group less frequently
	
	_UnitSpeedUntilInCombatTables = {}
	_UnitSpeedUntilInCombatInsertIndex = 0
	_UnitSpeedUntilInCombatMonitorIndex = 0
	for i = 1, _UnitSpeedUntilInCombatBuckets do
		table.insert(_UnitSpeedUntilInCombatTables, {})
	end
end
Scar_AddInit(Modifier_InitGame)

--? @shortdesc Modify the food resource gather rate of the group.
--? @args SGroup group, Real scalefactor, MUT Usage (MUT_Multiplication, MUT_Addition)
function Modify_FoodGatherRate(group, factor, usage)
	
	-- Create the appropriate modifier
	local usageType = MUT_Multiplication
	if usage ~= nil then
		usageType = usage
	end
	
	local modifier = Modifier_Create(MAT_Entity, "resource_entity_harvest_rate_food", usageType, false, factor, "")
	local result = {}
	
	local _ApplyModifierToSquad = function(gid, idx, sid)
		if Squad_IsAlive(sid) and Squad_Count(sid) > 0 then
			local modids = Modifier_ApplyToSquad(modifier, sid, 0)
			table.insert(result, modids)
			Modifier_AddToSquadTable(sid, modids)
		end
	end
	
	SGroup_ForEach(group, _ApplyModifierToSquad)

	return result
end

