import("training.scar")
import("training/chinesetrainingconditions.scar")
import("training/coretrainingconditions.scar")

Core_RegisterModule("ChineseTrainingGoals")

local goal_tax_gold_chi = "tax_gold_chi"
local goal_offical_tax_chi = "offical_tax_chi"
local goal_create_dynasty_chi = "create_dynasty_chi"
local goal_new_dynasty_chi = "new_dynasty_chi"
--local goal_monk_pagoda_chi = "monk_pagoda_chi"
--local goal_granary_chi = "granary_chi"
local goal_floating_tax_chi = "goal_floating_tax_chi"

local training_goals_chi =
{
	goal_tax_gold_chi,
	goal_floating_tax_chi,
	goal_create_dynasty_chi,
	goal_new_dynasty_chi,
	--goal_monk_pagoda_chi,
	--goal_granary_chi
}

function ChineseTrainingGoals_OnInit()
	
	if Player_GetRaceName(Game_GetLocalPlayer()) ~= "chinese" then
		return	
	end
	
	sg_currentSelection = SGroup_CreateIfNotFound("sg_currentSelection")
	eg_currentSelection = EGroup_CreateIfNotFound("eg_currentSelection")
	eg_nearbyDeposits = EGroup_CreateIfNotFound("eg_nearbyDeposits")
	
	training_currentConstructionBlueprint = nil
	training_currentHoverBlueprint = nil
	training_previousConstructionBlueprint = nil
	
	--UI_SetModalConstructionPhaseCallback(OnConstructionPhaseChange)
	--UI_SetModalHoverCallback(OnHoverChange)
	
	if ( UI_IsXboxControllerUI() == false ) then -- PC/KBM Hints
		
		-- No Official Excess Tax Gold
		local selectTownCenterTax = Training_Goal("Entity", 
			{ID= "Officials can be produced from the Town Center. LEFT CLICK to select Town Center.", Message= 11180965, DataTemplate="LeftClickTrainingDataTemplate"},
			UserHasSelectedTownCenter)
		local viewOfficial = Training_Goal("PBG", 
			{ID= "Officials will automatically collect tax from nearby buildings. View the Official here.", Message= 11184841, DataTemplate="LeftClickTrainingDataTemplate"}, 
			UserHasViewedOfficial)
		local townCenterViewsOfficialTax = Training_GoalSequence(goal_tax_gold_chi, 
			1, 1, --repeat max and remind max
			HasTownCenterNoOfficial, --trigger
			UserCannotSeeEntityKey, --ignore
			nil, --remind
			UserHasBuiltOfficial, --bypass 
			true, --can regress
			{selectTownCenterTax,viewOfficial})
		Training_AddGoalSequence(townCenterViewsOfficialTax)
		
		-- Excess Tax Gold on a building
		local selectBuildingFloatingTax = Training_Goal("Entity", 
			{ID= "Chinese buildings accrue Tax Gold. LEFT CLICK to select building.", Message= 11180966, DataTemplate="LeftClickTrainingDataTemplate"},
			UserHasSelectedBuildingWithTooMuchTax)
		local selectedBuildingFloating = Training_Goal("CenterLeftSecondaryInfo", 
			{ID= "This building has a lot of tax gold. Use an Imperial Official to collect from this building.", Message= 11180967, DataTemplate="GenericTrainingDataTemplate"},
			UserHasViewedFloatingBuilding)
		local BuildingFloatingTax = Training_GoalSequence(goal_floating_tax_chi,
			1, 1, --repeat max and remind max
			UserHasBuildingWithTooMuchTax, -- trigger
			UserCannotSeeEntityKey, -- ignore
			nil, -- remind
			nil, -- bypass
			false, -- can regress
			{selectBuildingFloatingTax, selectedBuildingFloating})
		Training_AddGoalSequence(BuildingFloatingTax)
		
		-- Create a Dynasty
		local selectVillager = Training_Goal("Entity", 
			{ID= "You can afford to create a Dynasty. LEFT CLICK to select Villager.", Message= 11180968, DataTemplate="LeftClickTrainingDataTemplate"},
			UserHasSelectedVillager)
		local viewLandmark = Training_Goal("PBG", 
			{ID= "Build both Landmarks from the same age to create a Dynasty.", Message= 11180969, DataTemplate="GenericTrainingDataTemplate"}, 
			UserHasViewedLandmark)
		local CreateNewDynasty = Training_GoalSequence(goal_create_dynasty_chi,
			1, 1, --repeat max and remind max
			UserCanAffordSecondLandmark, -- trigger
			UserCannotSeeSquadKey, -- ignore
			nil, -- remind
			nil, -- bypass
			false, -- can regress
			{selectVillager, viewLandmark})
		Training_AddGoalSequence(CreateNewDynasty)
		
		---- Garrison a Monk into a Pagoda
		--local PagodaGarrisoned = Training_Goal("Entity", 
		--{ID= "Pagodas generate more gold if garrisoned by Monks. Garrison a Monk here.", Message= 11180963, DataTemplate="LeftClickTrainingDataTemplate"},
		--UserGarrisonedPagoda)
		--local GarrisonPagoda = Training_GoalSequence(goal_monk_pagoda_chi,
		--1, 1, --repeat max and remind max
		--UserHasPagodaAndIdleMonk, -- trigger
		--UserCannotSeeEntityKey, -- ignore
		--nil, -- remind
		--UserHasGarrisonedPagodaBypass, -- bypass
		--false, -- can regress
		--{PagodaGarrisoned})
		--Training_AddGoalSequence(GarrisonPagoda)
		
		---- build a farm near a granary
		--local GaranaryBuilt = Training_Goal("Entity", 
		--{ID= "Build Farms near the Granary to improve their harvest rate.", Message= 11180964, DataTemplate="LeftClickTrainingDataTemplate"},
		--UserHasBuiltFarmNearGranary)
		--local BuildFarmNearGranary = Training_GoalSequence(goal_granary_chi,
		--1, 1, --repeat max and remind max
		--UserHasBuiltGranary, -- trigger
		--UserCannotSeeEntityKey, -- ignore
		--nil, -- remind
		--nil, -- bypass
		--false, -- can regress
		--{GaranaryBuilt})
		--Training_AddGoalSequence(BuildFarmNearGranary)
		
	end
end


function ChineseTrainingGoals_OnGameOver()
end