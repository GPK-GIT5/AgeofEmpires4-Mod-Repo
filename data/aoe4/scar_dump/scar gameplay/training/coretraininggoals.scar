}

local training_goals_age_up =
{
	goal_build_towards_wonder,
	goal_build_wonder
}

function TrainingGoal_EnableCoreControlGoals()
	for i, goalSequenceID in ipairs(training_goals_core_controls) do
		Training_EnableGoalSequenceByID(goalSequenceID, true)
	end
end

function TrainingGoal_DisableCoreControlGoals()
	for i, goalSequenceID in ipairs(training_goals_core_controls) do
		Training_EnableGoalSequenceByID(goalSequenceID, false)
	end
end

function TrainingGoal_EnableCoreEconGoals()
	for i, goalSequenceID in ipairs(training_goals_core_econ) do
		Training_EnableGoalSequenceByID(goalSequenceID, true)
	end
end

function TrainingGoal_DisableCoreEconGoals()
	for i, goalSequenceID in ipairs(training_goals_core_econ) do
		Training_EnableGoalSequenceByID(goalSequenceID, false)
	end
end

function TrainingGoal_EnableAgeUpGoals()
	for i, goalSequenceID in ipairs(training_goals_age_up) do
		Training_EnableGoalSequenceByID(goalSequenceID, true)
	end
end

function TrainingGoal_DisableAgeUpGoals()
	for i, goalSequenceID in ipairs(training_goals_age_up) do
		Training_EnableGoalSequenceByID(goalSequenceID, false)
	end
end

function CoreTrainingGoals_OnInit()
	print("CoreTrainingGoals_OnInit")
	sg_currentSelection = SGroup_CreateIfNotFound("sg_currentSelection")
	eg_currentSelection = EGroup_CreateIfNotFound("eg_currentSelection")
	eg_nearbyDeposits = EGroup_CreateIfNotFound("eg_nearbyDeposits")
	
	training_currentConstructionBlueprint = nil
	training_currentHoverBlueprint = nil
	training_previousConstructionBlueprint = nil
	
	training_currentAbilityBlueprint = nil
	training_previousAbilityBlueprint = nil
	
	UI_SetModalConstructionPhaseCallback(OnConstructionPhaseChange)
	UI_SetModalAbilityPhaseCallback(OnAbilityPhaseChange)
	UI_SetModalHoverCallback(OnHoverChange)
	
	-------------------------------------- Xbox Hints -------------------------------------- 
	if ( UI_IsXboxControllerUI() ) then
		
		-- Common
		local selectVillagerGoal = Training_Goal("Squad", {ID= "Press A to select a Villager.", Message = 1000990,
			DataTemplate="GenericTrainingDataTemplate"}, UserHasSelectedAVillager)
		
		-- Single Selection (note, Cursor will be replaced by squad as key)
		-- TODO: Implement reminder logic
		local singleSelectionGoal = Training_Goal("Cursor", {ID= "Press A to select a unit.", Message = 1001033,
			DataTemplate="GenericTrainingDataTemplate"}, UserHasASquadSelected)
		
		local singleSelectionGoalSequence = Training_GoalSequence(goal_single_selection, 
			1, 1, --If these are both set to -1, it will keep repeating the training
			UserHasNotSelectedAUnitRecentlyPredicate, 
			UserCannotSeeSquadKey, 
			nil, 
			UserHasAUnitSelectedPredicate, 
			false, 
			{singleSelectionGoal})
		Training_AddGoalSequence(singleSelectionGoalSequence)
		
		-- Move Unit
		local moveUnitGoal = Training_Goal("LooseReticle", {ID= "Press A on the ground to move a unit.", Message = 1001032,
			DataTemplate="GenericTrainingDataTemplate"}, UserIsMovingSpecifiedSelectedUnit)
		local moveUnitGoalSequence = Training_GoalSequence(goal_move_unit,
			1, 0, 
			UserHasNotMovedASelectedVisibleUnitRecently, 
			UserHasNoUnitSelected,
			nil, 
			UserIsMovingAnySelectedUnit,
			false, 
			{moveUnitGoal})
		Training_AddGoalSequence(moveUnitGoalSequence)
		
		-- Bandbox Select
		local bandBoxSelectGoal = Training_Goal("Squad", {ID= "HOLD A to grow a Marquee and select multiple units.", Message = 1000978,
			DataTemplate="GenericTrainingDataTemplate"}, UserHasSelectedMultipleMilitaryUnits)
		local bandBoxSelectGoalSequence = Training_GoalSequence(goal_bandbox_selection,
			1, 0, 
			UserHasMultipleUnitsOnScreen,
			nil, 
			nil, 
			UserHasSelectedMultipleMilitaryUnits,
			false, 
			{bandBoxSelectGoal})
		Training_AddGoalSequence(bandBoxSelectGoalSequence)
		
		-------------------------------------- KBM Hints --------------------------------------
	elseif ( UI_IsXboxKBMUI() ) then
		
		-- Common
		local selectVillagerGoal = Training_Goal("Squad", {ID= "LEFT CLICK to select a Villager.", Message = 11180986,
				DataTemplate="LeftClickTrainingDataTemplate"}, UserHasSelectedAVillager)
		local selectScoutGoal = Training_Goal("Squad", {ID= "Wild Sheep automatically herd themselves to Scouts. LEFT CLICK to select the Scout.", Message = 11180987,
				DataTemplate="LeftClickTrainingDataTemplate"}, UserHasSelectedAScout)
		local dropOffSheep = Training_Goal("Entity", {ID= "RIGHT CLICK on a Town Center or Mill to drop off herded Sheep.", Message = 11180988,
				DataTemplate="RightClickTrainingDataTemplate"}, UserDropOffIssued)
		
		local openVillagerCommandsTabGoal = Training_Goal("CommandsCommandCardTab",
				{ID= "Open the commands tab", Message= 1001506, DataTemplate="LeftClickTrainingDataTemplate"},
				UserHasVillagerCommandsCardTabOpen)
		local openVillagerEconomicTabGoal = Training_Goal("EconomicCommandCardTab",
				{ID= "Open the economic tab", Message= 1001507, DataTemplate="LeftClickTrainingDataTemplate"},
				UserHasVillagerEconomicCardTabOpen)
		local openVillagerMilitaryTabGoal = Training_Goal("MilitaryCommandCardTab",
				{ID= "Open the military tab", Message= 1001508, DataTemplate="LeftClickTrainingDataTemplate"},
				UserHasVillagerMilitaryCardTabOpen)
		
		-- Scout returns sheep
		local scoutReturnsSheep = Training_GoalSequence(goal_scout_returns_sheep, 
			1, 0, 
			HasAttachedScoutAndDropOffTownCenter, 
			ScoutReturnsSheepGoalsAreInvalid, 
			nil, 
			UserHasIssuedADropOff, 
			true, 
			{selectScoutGoal,dropOffSheep})
		Training_AddGoalSequence(scoutReturnsSheep)
		
		-- Pan Camera
		local panCameraGoal = Training_Goal("ControlGroupButton1Tag", 
			{ID= "Hold the MIDDLE MOUSE BUTTON and move the Mouse to pan the Camera.", Message= "$11180970", 
				DataTemplate="PanCameraTrainingDataTemplate"},
			UserHasPannedCamera)
		local panCameraGoalSequence = Training_GoalSequence(goal_pan_camera, 
			1, 0, 
			AShortPeriodOfTimeHasPassed, 
			nil,
			nil,
			UserHasPannedCamera,
			false,
			{panCameraGoal})
		Training_AddGoalSequence(panCameraGoalSequence)
		
		--Rotate Camera
		local rotateCameraGoal = Training_Goal("Cursor", 
			{ID= "ALT AND DRAG to rotate the camera.", Message= 11185668, DataTemplate="GenericTrainingDataTemplate"},
