		Training_AddGoalSequence(selectNextIdleBuilderSequence)
	
			 -- Farm Goal
		if Player_GetRaceName(Game_GetLocalPlayer()) ~= "mongol" and Player_GetRaceName(Game_GetLocalPlayer()) ~= "mongol_ha_gol" then
				-- Build a Farm
			local selectFarmGoal = Training_Goal("PBG",
