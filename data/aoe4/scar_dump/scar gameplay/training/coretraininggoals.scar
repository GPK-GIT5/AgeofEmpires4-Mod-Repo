		local rotateCamSequence = Training_GoalSequence(goal_rotate_camera,
			1, 0,
			AShortPeriodOfTimeHasPassed,
			nil,
			nil,
			UserHasRotatedCamera,
			false,
			{rotateCameraGoal})
		--Training_AddGoalSequence(rotateCamSequence)
		
		-- Single Selection (note, Cursor will be replaced by squad as key)
		-- TODO: Implement reminder logic
		local singleSelectionGoal = Training_Goal("Cursor", {ID= "LEFT CLICK to select a unit.", Message = 11180954,
				DataTemplate="LeftClickTrainingDataTemplate"},UserHasASquadSelected)
		
		local singleSelectionGoalSequence = Training_GoalSequence(goal_single_selection, 
			1, 1, --If these are both set to -1, it will keep repeating the training
			UserHasNotSelectedAUnitRecentlyPredicate, 
			UserCannotSeeSquadKey, 
			nil, 
			UserHasAUnitSelectedPredicate, 
			false, 
			{singleSelectionGoal})
		Training_AddGoalSequence(singleSelectionGoalSequence)
		
		-- Move Unit
		local moveUnitGoal = Training_Goal("Cursor", {ID= "RIGHT CLICK on the ground to move a unit.", Message = 11180989,
				DataTemplate="RightClickTrainingDataTemplate"}, UserIsMovingSpecifiedSelectedUnit)
		local moveUnitGoalSequence = Training_GoalSequence(goal_move_unit,
			1, 0, 
			UserHasNotMovedASelectedVisibleUnitRecently, 
