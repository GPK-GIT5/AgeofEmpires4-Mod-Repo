			Training_AddGoalSequence(buildAWonderGoal)
		end
			
		-- Build a Drop Off (Lumber Camp)
		if Player_GetRaceName(Game_GetLocalPlayer()) ~= "mongol" then
			local selectDropOffVillagerGoal = Training_Goal("Squad", 
