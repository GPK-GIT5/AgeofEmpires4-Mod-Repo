			TimeHasPassedAndUserCannotBuildAWonder, 	-- trigger
			UserCannotSeeSquadKey, 						-- ignore
			nil, 										-- remind
			UserCanBuildAWonder, 						-- bypass
			true, 										-- can regress
			{selectVillagerGoal, openVillagerCommandsTabGoal, lookAtWonderRequirementsGoal})
		Training_AddGoalSequence(buildTowardsAWonderGoalSequence)
		
		-- Preventing the mongol player from running this training tip.
		if Player_GetRaceName(Game_GetLocalPlayer()) ~= "mongol" and Player_GetRaceName(Game_GetLocalPlayer()) ~= "mongol_ha_gol" then
			-- Build a House
			local selectHouseGoal = Training_Goal("PBG",
				{ID= "Houses increase your population capacity. LEFT CLICK the House icon to select a House.", Message= 11184870, DataTemplate="LeftClickTrainingDataTemplate"}, 
