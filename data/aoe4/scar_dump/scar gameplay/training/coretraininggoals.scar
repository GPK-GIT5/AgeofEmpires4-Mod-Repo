			local buildHouseGoal = Training_Goal("Cursor",
				{ID= "LEFT CLICK in a valid location to start construction.", Message= 11180975, 
					DataTemplate="LeftClickTrainingDataTemplate"}, 
				UserHasStartedToBuildAHouse)
			
			local buildHouseSequence = Training_GoalSequence(goal_build_house, 
				1, 0, 
				TimeHasPassedWithoutBuildingAHouse, 
				UserCannotSeeSquadKey, 
				nil, 
				UserHasStartedToBuildAHouse,
				true, 
				{selectVillagerGoal, openVillagerEconomicTabGoal, selectHouseGoal, buildHouseGoal})
			Training_AddGoalSequence(buildHouseSequence)
		end
		
		-- Build a Landmark to Age Up
		if Player_GetRaceName(Game_GetLocalPlayer()) ~= "abbasid" and Player_GetRaceName(Game_GetLocalPlayer()) ~= "mongol_ha_gol" then
			local openWonderGoal = Training_Goal("PBG", 
				{ID= "You are ready to advance to the next Age! LEFT CLICK here to choose your Landmark.", Message= 11180976,  
				DataTemplate="LeftClickTrainingDataTemplate"}, UserHasOpenedLandmarkRadial)
