-- User has rotated the camera from the default position
function UserHasRotatedCamera(goal)
	
	-- Get camera's current orbit
	local cameraOrbit = Camera_GetOrbit()
	
	-- If camera's orbit hasn't been stored in the goal
	if scartype(goal.cameraOrbit) ~= ST_NUMBER then
		
		-- Store in goal
		goal.cameraOrbit = cameraOrbit
		
	-- If camera's orbit has been stored in goal as a number
	elseif scartype(goal.cameraOrbit) == ST_NUMBER then
		
		-- Get diff between first orbit stored and current orbit
		local diff = goal.cameraOrbit - cameraOrbit
		
		-- Check if degree of rotation is significant
		if diff >= 10 or diff <= -10 then
			
			return true
		end
	end
	
	return false
end

