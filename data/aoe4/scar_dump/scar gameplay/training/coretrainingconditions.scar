-- Also used with a goalSequence
function UserHasStartedToBuildAFarm(goal)
	-- The Player has no Farms in construction or completed
	local localPlayer = Game_GetLocalPlayer()
	Player_GetAll(localPlayer)
	EGroup_Filter(eg_allentities, "farm", FILTER_KEEP)
	local aFarmExistsOrIsUnderConstruction = EGroup_Count(eg_allentities) > 0
	if aFarmExistsOrIsUnderConstruction then
		if goal.dummyEntity ~= nil then
			Entity_DeSpawn(goal.dummyEntity)
		end
		
		return true
	end
	
	return false
end

function UserHasStartedToBuildPalisade(goal)
	return UserHasStartedToBuildABuilding("palisade_wall_bastion")
end

function UserHasStartedToBuildABarracks(goal)
	return UserHasStartedToBuildABuilding("barracks")
end

function OnConstructionPhaseChange(blueprint, phase, queueCount)
	if phase == TP_Position or phase == TP_Facing then
		training_currentConstructionBlueprint = blueprint
		training_currentConstructionPhase = "PLACING"
	elseif phase == TP_Issued then
		training_currentConstructionBlueprint = nil
		training_currentConstructionPhase = nil
		training_previousConstructionBlueprint = blueprint
	else
		training_currentConstructionBlueprint = nil
		training_currentConstructionPhase = nil
	end
end

function OnAbilityPhaseChange(blueprint, phase, queueCount)
	
	if phase == TP_Position or phase == TP_Facing then	--ability has entered the targetting phase
		training_currentAbilityBlueprint = blueprint
		training_currentAbilityPhase = "PLACING"
	elseif phase == TP_Issued then						--ability has been issued
		training_currentAbilityBlueprint = nil
		training_currentAbilityPhase = nil
		training_previousAbilityBlueprint = blueprint
	else												--ability has been cancelled
		training_currentAbilityBlueprint = nil
		training_currentAbilityPhase = nil
	end
end

function OnHoverChange(blueprint)
	training_currentHoverBlueprint = blueprint
end

function UserCanBuildAWonder(goalSequence)
	local localPlayer = Game_GetLocalPlayer()
	local wonderBPTable = Cardinal_ConvertTypeToEntityBlueprint("wonder", localPlayer, true)
	
	for i, wonderBP in pairs(wonderBPTable) do
		if Player_CanConstruct(localPlayer, wonderBP) then
			return true
		end
	end
	
	return false
end

function TimeHasPassedAndUserCannotBuildAWonder(goalSequence)
	local landmark_types = { "wonder_dark_age", "wonder_feudal_age", "wonder_castle_age" }
	local localPlayer = Game_GetLocalPlayer()
	local current_age = Player_GetCurrentAge(localPlayer)
	local maximum_age = Player_GetMaximumAge(localPlayer)
	
		if current_age < maximum_age then
		local currentTime = Timer_GetElapsed(goalSequence.timerID)
			if currentTime > __t_trainingWonderInterval --[[and not UserCanBuildAWonder(goalSequence) ]]then
				local villager = FindVillagerInSight(goalSequence)
				if villager ~= nil then
					goalSequence.goals[1].key = villager
					
					if(UI_IsXboxKBMUI()) then
						goalSequence.goals[3].key = "WondersDataTemplate"
					else
						goalSequence.goals[2].key = "WondersDataTemplate"
					end
					return true
				end
			end
		end
		
	return false
end

function UserHasLookedAtWonderRequirements(goal)
	local currentTime = Timer_GetElapsed(goal.timerID)
	if goal.temp.lastTimeWithoutLooking == nil then 
		goal.temp.lastTimeWithoutLooking = 0 
	end

	local localPlayer = Game_GetLocalPlayer()
	local wonderBPTable = Cardinal_ConvertTypeToEntityBlueprint("wonder", localPlayer, true)
	
	for i, wonderBP in pairs(wonderBPTable) do
		if training_currentHoverBlueprint == wonderBP then
			if currentTime - goal.temp.lastTimeWithoutLooking > __t_trainingBriefInterval then 
				return true
			end
			
			return false
		end
	end
	
	goal.temp.lastTimeWithoutLooking = currentTime
	return false
end

function TimeHasPassedAndUserCanBuildAWonder_Xbox(goalSequence)
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	
	if UserCanBuildAWonder(goalSequence) then
		local wonderBlueprint = nil
		local localPlayer = Game_GetLocalPlayer()
		local wonderBPTable = Cardinal_ConvertTypeToEntityBlueprint("wonder", localPlayer, true)
		
		for i, wonderBP in pairs(wonderBPTable) do
			if Player_CanConstruct(localPlayer, wonderBP) then
				wonderBlueprint = wonderBP
				break
			end
		end
		if currentTime > __t_trainingShortInterval then
			local villager = FindVillagerInSight(goalSequence)
			if villager ~= nil then
				goalSequence.goals[1].key = villager
				goalSequence.goals[2].key = villager
				return true
			end
		end
	end
end

function TimeHasPassedAndUserCanBuildAWonder(goalSequence)
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	
	--if UserCanBuildAWonder(goalSequence) and goalSequence.temp.timeWhenCouldNotBuildAWonder ~= nil then
		--if currentTime - goalSequence.temp.timeWhenCouldNotBuildAWonder > __t_trainingModerateInterval then
	if UserCanBuildAWonder(goalSequence) then
		local wonderBlueprint = nil
		local localPlayer = Game_GetLocalPlayer()
		local wonderBPTable = Cardinal_ConvertTypeToEntityBlueprint("wonder", localPlayer, true)
		
		for i, wonderBP in pairs(wonderBPTable) do
			if Player_CanConstruct(localPlayer, wonderBP) then
				wonderBlueprint = wonderBP
				break
			end
		end
		if currentTime > __t_trainingShortInterval then
			local villager = FindVillagerInSight(goalSequence)
			if villager ~= nil then
				goalSequence.goals[1].key = villager
				
				if(UI_IsXboxKBMUI()) then
					goalSequence.goals[3].key = "WondersDataTemplate"
				else
					goalSequence.goals[2].key = "WondersDataTemplate"
				end
				
				return true
			end
		end
	--else
		--goalSequence.temp.timeWhenCouldNotBuildAWonder = currentTime
	end
end

function HasAttachedScoutAndDropOffTownCenter(goalSequence)
	local currentTime = Timer_GetElapsed(goalSequence.timerID)

	local localPlayer = Game_GetLocalPlayer()
	local scoutBP = Cardinal_ConvertTypeToSquadBlueprint("scar_scout", localPlayer)
	local squads = Player_GetSquads(localPlayer)
	
	if goalSequence.goals[1].key ~= nil then
		goalSequence.goals[1].lastKey = goalSequence.goals[1].key
	end
	
	goalSequence.goals[1].key = nil
	goalSequence.goals[2].key = nil
	
	for i = 1, SGroup_Count(squads) do
		local squad = SGroup_GetSquadAt(squads, i)
		
		if squad ~= nil and Squad_GetBlueprint(squad) == scoutBP then
			if Squad_HasEntityWithNInteractors(squad, "food_generation", 3) and Squad_IsIdle(squad) and Player_CanSeeSquad(localPlayer, squad, ANY) then
				goalSequence.goals[1].key = Squad_GetID(squad)
				
				if goalSequence.goals[1].key ~= goalSequence.goals[1].lastKey then
					goalSequence.goals[1].lastActiveTime = currentTime
				end
				
				break
			end
		end
	end
	
	if goalSequence.goals[1].key == nil or goalSequence.goals[1].lastActiveTime == nil then
		goalSequence.goals[1].lastActiveTime = currentTime
	end
	
	Player_GetAll(localPlayer)
	EGroup_Filter(eg_allentities, "town_center", FILTER_KEEP)
	EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
	local aTownCenterExists = EGroup_Count(eg_allentities) > 0

	if aTownCenterExists then
		local townCenter = EGroup_GetEntityAt(eg_allentities, 1)
		goalSequence.goals[2].key = townCenter
	end
	local timeSinceActive = currentTime - goalSequence.goals[1].lastActiveTime
	if goalSequence.goals[1].key ~= nil and goalSequence.goals[2].key ~= nil and timeSinceActive > __t_trainingModerateInterval then
		return true
	end

	return false
end

function UserIsGoingToBuildAWonder(goal)
	local localPlayer = Game_GetLocalPlayer()
	local wonderBPTable = Cardinal_ConvertTypeToEntityBlueprint("wonder", localPlayer, true)
	
	for i, wonderBP in pairs(wonderBPTable) do
		if training_currentConstructionBlueprint == wonderBP then
			return true
		end
	end
	
	return false
	
end

function UserIsBuildingAWonder(goal)
	local localPlayer = Game_GetLocalPlayer()
	local wonderBPTable = Cardinal_ConvertTypeToEntityBlueprint("wonder", localPlayer, true)
	
	for i, wonderBP in pairs(wonderBPTable) do
		if training_previousConstructionBlueprint == wonderBP then
			return true
		end
	end
	
	return false
	
end

function UserHasAgedUp()
	return Player_HasUpgrade(Game_GetLocalPlayer(), BP_GetUpgradeBlueprint("feudal_age"))
end

function UserKnowsHowToBuildWonders(goal)
	return UserHasAgedUp() or UserIsBuildingAWonder(goal)
end

function UserDropOffIssued(goal)
	return goal.key == nil
end

 function UserHasIssuedADropOff(goalSequence)
	if goalSequence.goals[1].key == nil or scartype(goalSequence.goals[1].key) ~= ST_NUMBER then
		return false
	end
	
	if Squad_IsValid(goalSequence.goals[1].key) then
		local localPlayer = Game_GetLocalPlayer()
		local squad = Squad_FromID(goalSequence.goals[1].key)
		
		if not Squad_HasEntityWithNInteractors(squad, "food_generation", 1) then
			goalSequence.goals[1].key = nil
			goalSequence.goals[2].key = nil
			return true
		end
	end
		return false
end

function ScoutReturnsSheepGoalsAreInvalid(goalSequence)
	if goalSequence.goals[1].key == nil or scartype(goalSequence.goals[1].key) ~= ST_NUMBER then
		return true
	end
	
	if Squad_IsValid(goalSequence.goals[1].key) then
		local localPlayer = Game_GetLocalPlayer()
		local squad = Squad_FromID(goalSequence.goals[1].key)
		return AnyGoalKeysAreInvalid(goalSequence) or not Squad_HasEntityWithNInteractors(squad, "food_generation", 3)
	else
		return true
	end
end

function ShouldBuildDropOff(goalSequence)
	local localPlayer = Game_GetLocalPlayer()
	-- Check if player is Templar
	if Player_GetRaceName(localPlayer) == "templar" then
		-- They can't build lumber camps
		return false
	end
	
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	if currentTime > __t_trainingModerateInterval then
		local goal_offset = 0
		if UI_IsXboxKBMUI() then -- Additional goal in sequence for Xbox KBM
			goal_offset = 1
		end
		
		Player_GetAll(localPlayer)
		
		EGroup_Filter(eg_allentities, {"lumber_camp"}, FILTER_KEEP)
		local dropOffExistsOrIsUnderConstruction = EGroup_Count(eg_allentities) > 0
		
		if dropOffExistsOrIsUnderConstruction then
			return false	
		end
		
		local villagerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", localPlayer)
		local squads = Player_GetSquads(localPlayer)
		
		local distanceThreshold = 20.0
		
		goalSequence.goals[1].key = nil
		goalSequence.goals[2 + goal_offset].key = nil
		
		local gatheringWood = false
		
		for i = 1, SGroup_Count(squads) do
			
			local squad = SGroup_GetSquadAt(squads, i)
			
			if Squad_GetBlueprint(squad) == villagerBP and Squad_GetMaxEntityDropOffDistance(squad) > distanceThreshold then
				
				if Squad_IsGatheringResourceType(squad, RT_Wood) then
				
					local buildingBP = nil
					buildingBP = Cardinal_ConvertTypeToEntityBlueprint("lumber_camp", localPlayer)
			
					if buildingBP ~= nil and training_currentConstructionBlueprint == nil and Player_CanConstruct(localPlayer, buildingBP) then
						goalSequence.goals[1].key = Squad_GetID(squad)
						goalSequence.goals[2 + goal_offset].key = buildingBP
						break
					end
				end
			end
		end
		
		if goalSequence.goals[1].key ~= nil and goalSequence.goals[2 + goal_offset].key ~= nil then
			return true		
		end
	end
	
	return false
end

function HasScoutCarryingFoodAndDropOffTownCenter(goalSequence)
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	if currentTime > __t_trainingShortInterval then	
		local localPlayer = Game_GetLocalPlayer()
		Player_GetAll(localPlayer)
		local upgradeBP = BP_GetUpgradeBlueprint("upgrade_scout_forester")
		local scoutBP = Cardinal_ConvertTypeToSquadBlueprint("scar_scout", localPlayer)
		local squads = Player_GetSquads(localPlayer)
		
		-- Stop function if player does not have Scout Hunting upgrade
		if Player_HasUpgrade(localPlayer, upgradeBP) == false then
			return false
		end
		
		goalSequence.goals[1].key = nil
		goalSequence.goals[2].key = nil
		
		for i = 1, SGroup_Count(squads) do
			local squad = SGroup_GetSquadAt(squads, i)
			
			if squad ~= nil and Squad_GetBlueprint(squad) == scoutBP then
				local entity = Squad_GetFirstEntity(squad)
				if Entity_GetStateModelInt(entity, "pickup_attachments_count") > 0 then
					goalSequence.goals[1].key = Squad_GetID(squad)
					goalSequence.goals[2].firstGoalKey = goalSequence.goals[1].key
					break
				end
			end
		end
		
		-- Stop function if carrying scout was not found
		if goalSequence.goals[1].key == nil then
			return false
		end
		
		Player_GetAll(localPlayer)
		EGroup_Filter(eg_allentities, "town_center", FILTER_KEEP)
		EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
		local aTownCenterExists = EGroup_Count(eg_allentities) > 0
	
		if aTownCenterExists then
			local townCenter = EGroup_GetEntityAt(eg_allentities, 1)
			goalSequence.goals[2].key = townCenter
		end
		
		if goalSequence.goals[1].key ~= nil and goalSequence.goals[2].key ~= nil then
			return true
		end
	end
	
	return false
end

 function UserHasIssuedADeerDropOff(goalSequence) -- This was always returning true and bypassing scout drop-off goal sequence. No longer being referenced.
	if goalSequence.goals[1].key == nil or scartype(goalSequence.goals[1].key) ~= ST_NUMBER then
		return true
	end
	
	return DeerDropOffIssued(goalSequence.goals[2])
end

 function DeerDropOffIssued(goal)
	
	if goal.firstGoalKey == nil or scartype(goal.firstGoalKey) ~= ST_NUMBER then
		return true
	end
	
	if Squad_IsValid(goal.firstGoalKey) then
		local localPlayer = Game_GetLocalPlayer()
		Player_GetAll(localPlayer)
		local keySquad = Squad_FromID(goal.firstGoalKey)
		
		local isCarrying = false
		
		local entity = Squad_GetFirstEntity(keySquad)
		if Entity_GetStateModelInt(entity, "pickup_attachments_count") > 0 then
			isCarrying = true
		end
		
		if not isCarrying then
			return true
		end
	end
	
	return false
end

function UserHasSelectedAnIdleVillager(goal)
	local localPlayer = Game_GetLocalPlayer()
	local villagerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", localPlayer)
	local squads = Player_GetSquads(localPlayer)
	
	if goal.idleVillagers ~= nil then
		RemoveTagsFromElements(goal.idleVillagers)
	end
	
	goal.idleVillagers = {}
	
	Misc_GetSelectedSquads(sg_currentSelection, false)
	for i = 1, SGroup_Count(sg_currentSelection) do
		local squad = SGroup_GetSquadAt(sg_currentSelection, i)
		if Squad_GetBlueprint(squad) == villagerBP and Squad_IsIdle(squad) then
			return true
		end
	end
	
	for i = 1, SGroup_Count(squads) do
		local squad = SGroup_GetSquadAt(squads, i)
		
		if Squad_IsIdle(squad) and Squad_GetBlueprint(squad) == villagerBP then
			goal.idleVillagers[i] = {}
			goal.idleVillagers[i].element = squad
			goal.idleVillagers[i].id = 0
		end
	end
	
	if goal.idleVillagers.length then
		return true
	end
	
	return false
end

function SelectNextIdleIfVillagersIdle(goalSequence)
	local villagerIsIdle = false
	local localPlayer = Game_GetLocalPlayer()
	local villagerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", localPlayer)
	local squads = Player_GetSquads(localPlayer)
	
	goalSequence.goals[1].idleVillagers = {}
	
	for i = 1, SGroup_Count(squads) do
		local squad = SGroup_GetSquadAt(squads, i)
		
		if Squad_IsIdle(squad) and Squad_GetBlueprint(squad) == villagerBP then
			villagerIsIdle = true
			break
		end
	end
	
	if villagerIsIdle then
		if Timer_IsPaused(goalSequence.timerID) then
			Timer_Resume(goalSequence.timerID)
		end
	else
		if not Timer_IsPaused(goalSequence.timerID) then
			Timer_Pause(goalSequence.timerID)
		end
	end
	
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	if currentTime > __t_trainingLongInterval and villagerIsIdle then
		goalSequence.goals[1].key = "PopulationButton"
		return true
	end
	
	goalSequence.goals[1].key = nil
	return false
end

function AddTagsToElements(elements)
	for key,value in pairs(elements) do 
	    elements[key].id = HintPoint_Add(value.element, true, "")
	end
end

function RemoveTagsFromElements(elements)
	for key,value in pairs(elements) do 
	    HintPoint_Remove(value.id)
	end
end

function NoIdleVillagers(goalSequence)
	local villagerIsIdle = false
	local localPlayer = Game_GetLocalPlayer()
	local villagerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", localPlayer)
	local squads = Player_GetSquads(localPlayer)
	
	for i = 1, SGroup_Count(squads) do
		local squad = SGroup_GetSquadAt(squads, i)
		
		if Squad_IsIdle(squad) and Squad_GetBlueprint(squad) == villagerBP then
			villagerIsIdle = true
			break
		end
	end
	
	return not villagerIsIdle
end

