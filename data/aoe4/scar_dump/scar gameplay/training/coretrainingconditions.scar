-- Setup Siege Unit trigger
function HasSiegeUnitPredicate(goalSequence)
local currentTime = Timer_GetElapsed(goalSequence.timerID)
	
	if currentTime > __t_trainingModerateInterval then
		
		local localPlayer = Game_GetLocalPlayer()
		local sg_player_units = Player_GetSquads(localPlayer)
		
		-- Check player units
		for i = 1, SGroup_Count(sg_player_units) do
			
			local squad = SGroup_GetSquadAt(sg_player_units, i)
			
			-- Check for idle siege unit on screen
			if Squad_IsOfType(squad, "scar_mangonel") or Squad_IsOfType(squad, "scar_trebuchet_cw") or Squad_IsOfType(squad, "scar_trebuchet_traction") then
				
				if Misc_IsSquadOnScreen(squad, 100) and Squad_IsIdle(squad) then
						
					-- Assign key to idle springald, mangonel, or trebuchet
					goalSequence.goals[1].key = Squad_GetID(squad)
					return true
				end
			end
		end
		
		-- If an idle siege unit was not found
		if goalSequence.goals[1].key == nil or scartype(goalSequence.goals[1].key) ~= ST_NUMBER then
			-- End function
			return false
		end
		
	end
	
end

-- Setup Siege Unit goal completion criteria
function UserHasSelectedAnIdleSiegeUnit(goal)
	local localPlayer = Game_GetLocalPlayer()
	local sg_player_units = Player_GetSquads(localPlayer)
	
	Misc_GetSelectedSquads(sg_currentSelection, false)
		
		for i = 1, SGroup_Count(sg_currentSelection) do
			local squad = SGroup_GetSquadAt(sg_currentSelection, i)
				
			if Squad_IsOfType(squad, "scar_springald") or Squad_IsOfType(squad, "scar_mangonel") or Squad_IsOfType(squad, "scar_trebuchet_cw") or Squad_IsOfType(squad, "scar_trebuchet_traction") then 
					
				-- Player has selected a springald, mangonel, or trebuchet
				return true

			end
		
		end
	
	return false
	
end

-- Setup Siege Unit goal completion criteria
function UserHasSetupSiegeUnit(goal)
	-- Get local player
	local localPlayer = Game_GetLocalPlayer()
	-- Get local player's units
	local sg_player_units = Player_GetSquads(localPlayer)
	
	-- For every player unit
	for i = 1, SGroup_Count(sg_player_units) do
		-- Get squad
		local squad = SGroup_GetSquadAt(sg_player_units, i)
		
		if Squad_IsOfType(squad, "siege_range") then
			
			-- Get entity from squad
			local entity = Squad_GetFirstEntity(squad) 
			-- Check entity state model bool for siege setup
			if Entity_GetStateModelBool(entity, "siege_is_setup") == true then	
				
				return true
				
			end
			
		end

	end
	
	return false
	
end

-- Setup Siege Unit ignore
function UserHasSetupSiegeUnitInSight(goal)
	-- Get local player
	local localPlayer = Game_GetLocalPlayer()
	-- Get local player's units
	local sg_player_units = Player_GetSquads(localPlayer)
	
	-- For every player unit
	for i = 1, SGroup_Count(sg_player_units) do
		-- Get squad
		local squad = SGroup_GetSquadAt(sg_player_units, i)
		
		-- Check if squad is in sight
		if Squad_IsOfType(squad, "siege_range") and Misc_IsSquadOnScreen(squad, 100) then
			
			-- Get entity from squad
			local entity = Squad_GetFirstEntity(squad) 
			-- Check entity state model bool for siege setup
			if Entity_GetStateModelBool(entity, "siege_is_setup") == true then	
				
				return true
				
			end
		end
	end
	
	return false
end

