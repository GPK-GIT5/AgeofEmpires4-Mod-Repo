import("training.scar")
import("cardinal.scar")

__t_trainingLongInterval = 60
__t_trainingModerateInterval = 30
__t_trainingShortInterval = 15
__t_trainingBriefInterval = 1
__t_trainingWonderInterval = 15
__t_trainingHoverInterval = 3		-- how long a player needs to be hovering over an item for the system to recognize that they "know" this
__t_trainingRadialInterval = 5		-- similar to HoverInterval but used when looking at a radial menu on controller
__t_trainingLongDistance = 50


local _farm_size_offset = 4.0
local _construct_farm_max_sheep_requirement = 2

function GetNumGatheringSquadsAny()
	
	local localPlayer = Game_GetLocalPlayer()
	return Player_GetNumGatheringSquads(localPlayer, RT_Food)
		+ Player_GetNumGatheringSquads(localPlayer, RT_Wood)
		+ Player_GetNumGatheringSquads(localPlayer, RT_Stone)
		+ Player_GetNumGatheringSquads(localPlayer, RT_Gold)
end

function GetNumGatheringSquadsFood()
	
	local localPlayer = Game_GetLocalPlayer()
	return Player_GetNumGatheringSquads(localPlayer, RT_Food)
	
end

function FindVillagerInSight()
	local localPlayer = Game_GetLocalPlayer()
	local villagerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", localPlayer)
	local squads = Player_GetSquads(localPlayer)
	
	for i = 1, SGroup_Count(squads) do
		local squad = SGroup_GetSquadAt(squads, i)
		
		if Squad_IsIdle(squad) and Squad_GetBlueprint(squad) == villagerBP and Misc_IsSquadOnScreen(squad, 100) then
			return Squad_GetID(squad)
		end
	end
	
	return nil
end

function FindFoodGatheringVillagerInSight()
	local localPlayer = Game_GetLocalPlayer()
	local villagerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", localPlayer)
	local squads = Player_GetSquads(localPlayer)
	
	for i = 1, SGroup_Count(squads) do
		local squad = SGroup_GetSquadAt(squads, i)
		
		if Squad_GetBlueprint(squad) == villagerBP and Misc_IsSquadOnScreen(squad, 100) and Squad_IsGatheringResourceType(squad, RT_Food) then
			return Squad_GetID(squad)
		end
	end
	
	return nil
end

--? @shortdesc Find a food deposit on screen that has visible UI decorators
--? @extdesc Returns a food deposit entity and a boolean indicating if the entity itself has visible decorators. 
--?	  If not, the squad has visible decorators.
--? @result entity, boolean
function FindDecorableFoodDepositInSight()
	local localPlayer = Game_GetLocalPlayer()
	local pos_camera_target = Camera_GetPivot()
	
	-- FIXME TrentJ 21/11/2018: 100 was an arbitrary guess to approximate what's on screen. 
	-- We should probably determine the actual size of the on-screen area and use that
	local eg_food_deposits = Misc_FindDepositsOfTypeCloseToPosition(RT_Food,
		Cardinal_ConvertTypeToEntityBlueprint("villager", localPlayer), 
		pos_camera_target, 
		100) 
	
	for i = 1, EGroup_Count(eg_food_deposits), 1 do
		local deposit = EGroup_GetEntityAt(eg_food_deposits, i) 
		if Misc_IsEntityOnScreen(deposit, 1.0) then 
			if UI_GetDecoratorVisibilityEntity(deposit) == DV_Visible then
				EGroup_Clear(eg_food_deposits)
				return deposit, true
			end
			-- accept squad entities because they can display tags even if their other decorators aren't currently visible
			deposit_squad = Entity_GetSquad(deposit) 
			if deposit_squad ~= nil and UI_GetDecoratorVisibilitySquad(deposit_squad) ~= DV_Hidden then
				EGroup_Clear(eg_food_deposits)
				return deposit, false
			end				
		end
	end
	EGroup_Clear(eg_food_deposits)
	
	return nil
end

function UserHasASquadSelected(goal)
	Misc_GetSelectedSquads(sg_currentSelection, false)
	return SGroup_CountSpawned(sg_currentSelection) > 0
end

function UserCannotSeeSquadKey(goalSequence)
	local key = goalSequence.goals[goalSequence.currentGoalIndex].key
	
	if scartype(key) == ST_NUMBER then 
		return not Squad_IsValid(key)
		or Misc_IsSquadOnScreen(Squad_FromID(key), 100) == false
	end
	
	return false
end

function UserHasAUnitSelectedPredicate(goalSequence)
	Misc_GetSelectedSquads(sg_currentSelection, false)
	if SGroup_Count(sg_currentSelection) > 0 then
		return true
	end
	
	return false
end

function UserHasNotSelectedAUnitRecentlyPredicate(goalSequence)
	
	if Timer_GetElapsed(goalSequence.timerID) > __t_trainingShortInterval then
		local squads = Player_GetSquads(Game_GetLocalPlayer())
		
		for i = 1, SGroup_Count(squads) do
			local squad = SGroup_GetSquadAt(squads, i)
			if Squad_IsIdle(squad) and Misc_IsSquadOnScreen(squad, 100) then
				goalSequence.goals[goalSequence.currentGoalIndex].key = Squad_GetID(squad)
				return true
			end
		end
	end
	
	return false
end

function UserIsMovingAnySelectedUnit(goalSequence)
	
	Misc_GetSelectedSquads(sg_currentSelection, false)
	
	local count = SGroup_Count(sg_currentSelection)
	for i = 1, count do
		local squad = SGroup_GetSquadAt(sg_currentSelection, i)
		if Squad_IsMoving(squad) then
			return true
		end
	end
	
	return false
end

function UserIsMovingSpecifiedSelectedUnit(goal)
	
	if Squad_IsValid(goal.temp.selectedSquad) then
		return Squad_IsMoving(Squad_FromID(goal.temp.selectedSquad))
	end
	
	return false
end

function UserHasNotMovedASelectedVisibleUnitRecently(goalSequence)
	
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	if currentTime > 0 then 
		Misc_GetSelectedSquads(sg_currentSelection, false)
		local count = SGroup_Count(sg_currentSelection)
		for i = 1, count do
			local squad = SGroup_GetSquadAt(sg_currentSelection, i)
			
			if Squad_IsIdle(squad) 
			and Misc_IsSquadOnScreen(squad, 100) 
			then
				goalSequence.goals[goalSequence.currentGoalIndex].temp.selectedSquad = Squad_GetID(squad)
				return true
			end
		end
	end
	
	return false
end

function UserHasNoUnitSelected(goalSequence)
	
	Misc_GetSelectedSquads(sg_currentSelection, false)
	local spawnedCount = SGroup_CountSpawned(sg_currentSelection)
	return spawnedCount == 0
end

function ABriefPeriodOfTimeHasPassed(goalSequence)
	return Timer_GetElapsed(goalSequence.timerID) > __t_trainingBriefInterval
end

-- Temporary for the View Landmark Requirements hint
function ASlightPeriodOfTimeHasPassed(goalSequence)
	return Timer_GetElapsed(goalSequence.timerID) > 7
end

function AShortPeriodOfTimeHasPassed(goalSequence)
	return Timer_GetElapsed(goalSequence.timerID) > __t_trainingShortInterval
end

function AModeratePeriodOfTimeHasPassed(goalSequence)
	return Timer_GetElapsed(goalSequence.timerID) > __t_trainingModerateInterval
end

function ALongPeriodOfTimeHasPassed(goalSequence)
	return Timer_GetElapsed(goalSequence.timerID) > __t_trainingLongInterval
end

-- Also used for goalSequence. The two are interchangeable here.
function UserHasPannedCamera(goal)
	
	local targetPos = Camera_GetCurrentTargetPos()
	if goal.temp.lastTargetPos == nil then
		goal.temp.lastTargetPos = targetPos
	end
	
	if math.floor(targetPos.x) - math.floor(goal.temp.lastTargetPos.x) ~= 0 
	or math.floor(targetPos.y) - math.floor(goal.temp.lastTargetPos.y) ~= 0 then
		return true
	end
	
	return false
end

function UserIsGathering(goalSequence)

	-- Return number of gathering squads
	return GetNumGatheringSquadsAny() > 0;

end

function UserIsGatheringFood(goalSequence)

	-- Return number of Food gathering squads
	return GetNumGatheringSquadsFood() > 0;

end

function AnyGoalKeysAreInvalid(goalSequence)
	
	for i, goal in pairs(goalSequence.goals) do
		local key = goal.key
		
		if key == nil then
			return true
		end
		
		if scartype(key) == ST_NUMBER then
			if Squad_IsValid(key) and Player_CanSeeSquad(Game_GetLocalPlayer(), Squad_FromID(key), true) then
				goto next_goal_key
			end
			
			if Entity_IsValid(key) and Player_CanSeeEntity(Game_GetLocalPlayer(), Entity_FromID(key)) then
				goto next_goal_key
			end
			
			return true
		end
		
		::next_goal_key::
	end
	
	return false
end

function DistanceBetweenWorldGoalsIsLong(goalSequence)
	
	local points = {}
	for i, goal in pairs(goalSequence.goals) do
		if scartype(goal.key) == ST_NUMBER then
			if Entity_IsValid(goal.key) then
				local point = Entity_GetPosition(Entity_FromID(goal.key))
				table.insert(points, point)
			end
			
			if Squad_IsValid(goal.key) then
				local point = Squad_GetPosition(Squad_FromID(goal.key))
				table.insert(points, point)
			end
		end
	end
	
	for i, point in pairs(points) do
		for j, otherPoint in pairs(points) do
			if World_DistancePointToPoint(point, otherPoint) > __t_trainingLongDistance then
				return true
			end
		end
	end
	
end

function GatherGoalsAreInvalid(goalSequence)
	
	return AnyGoalKeysAreInvalid(goalSequence) or DistanceBetweenWorldGoalsIsLong(goalSequence)
end

function TimeHasPassedWithoutGathering(goalSequence)
	
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	if currentTime > __t_trainingShortInterval then
		-- Check if any squads are gathering Food. Note: To make generic use GetNumGatheringSquadsAny()
		if GetNumGatheringSquadsFood() == 0 then
			local localPlayer = Game_GetLocalPlayer()
			local squads = Player_GetSquads(localPlayer)
			local villagerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", localPlayer)
			
			for i = 1, SGroup_Count(squads) do
				
				local squad = SGroup_GetSquadAt(squads, i)
				
				if Squad_IsIdle(squad) and Squad_GetBlueprint(squad) == villagerBP and Misc_IsSquadOnScreen(squad, 100) then
					
					-- Assign Villager as goal sequence key
					goalSequence.goals[1].key = Squad_GetID(squad)
					
					-- Find Deposits close the Villager
					Misc_FindDepositsCloseToSquad(eg_nearbyDeposits, squad, __t_trainingLongDistance)
					
					print(string.format("DEPOSIT COUNT %d", EGroup_Count(eg_nearbyDeposits)))
					
					-- If deposit(s) were found
					if EGroup_Count(eg_nearbyDeposits) > 0 then

						-- Store resource deposit entities
						local berryDeposits = {}
						--local treeDeposits = {}
						--local stoneDeposits = {}
						--local goldDeposits = {}
						
						-- Loop through deposits
						for x = 1, EGroup_Count(eg_nearbyDeposits) do
							
							-- Get deposit entity
							local deposit = EGroup_GetEntityAt(eg_nearbyDeposits, x)
							
							-- If player can see deposit
							if Player_CanSeeEntity(localPlayer, deposit) then
									
								-- If entity is a Berry Bush
								if (Entity_IsOfType(deposit, "forage_bush")) then
									
									-- Add Berry Bush entity to berryDeposits table
									table.insert(berryDeposits, deposit)
								
								--[[ Note: This functionality supports a generic Gather hint that prioritizes Food > Wood > Stone > Gold. 
								-- If entity is a Tree
								elseif (Entity_IsOfType(deposit, "tree")) then
									
									-- Add Tree entity to treeDeposits table
									table.insert(treeDeposits, deposit)
									
								-- If entity is a Stone deposit
								elseif (Entity_IsOfType(deposit, "stone")) then
									
									-- Add Stone entity to stoneDeposits table
									table.insert(stoneDeposits, deposit)	
								
								-- If entity is a Gold deposit
								elseif (Entity_IsOfType(deposit, "gold")) then
									
									-- Add Gold entity to goldDeposits table
									table.insert(goldDeposits, deposit)
								--]]
								end
							end
						end
						
						-- Store training hint
						trainingHint = nil
						
						-- Store deposit entity and blueprint
						local pos = nil
						local bp = nil
						
						-- If at least one Berry Bush was found
						if (#berryDeposits > 0) then
							
							-- Get position of first Berry Bush
							pos = Entity_GetPosition(berryDeposits[1])
							-- Create invisible hint point
							--trainingHint = HintPoint_Add(berryDeposits[1], true, "", 0, nil, nil, nil, nil, "TrainingHintPointTemplate")
							
							local berryPos = Entity_GetPosition(berryDeposits[1])
							
							goalSequence.goals[2].key = berryPos
						
						--[[ Note: This functionality supports a generic Gather hint that prioritizes Food > Wood > Stone > Gold.
						-- If at least one Tree was found
						elseif (#treeDeposits > 0) then
															
							-- Get position of first Tree
							pos = Entity_GetPosition(treeDeposits[1])
							-- Create invisible hint point
							trainingHint = HintPoint_Add(pos, true, "", 0, HPAT_Hint, nil, nil, nil, "TrainingHintPointTemplate")

							
						-- If at least one Stone deposit was found				
						elseif (#stoneDeposits > 0) then
															
							-- Get position of first Stone deposit
							pos = Entity_GetPosition(stoneDeposits[1])
							-- Create invisible hint point
							trainingHint = HintPoint_Add(pos, true, "", 0, nil, nil, nil, nil, "TrainingHintPointTemplate")
						
							-- If at least one Gold deposit was found				
						elseif (#goldDeposits > 0) then
							
							-- Get position of first Gold deposit
							pos = Entity_GetPosition(goldDeposits[1])
							-- Create invisible hint point
							trainingHint = HintPoint_Add(pos, true, "", 0, nil, nil, nil, nil, "TrainingHintPointTemplate")
						--]]
						end
						
						-- Set the Training Hint Point as the goal's key
						--goalSequence.goals[2].key = "TrainingHintPoint"
												
						-- Return true
						return true
						
					end
				end
			end
		end
	end
	
	return false
end

