function HasUnAttachedScoutAndDeerInSight(goalSequence)
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	if currentTime > __t_trainingShortInterval then
		local localPlayer = Game_GetLocalPlayer()
		local scoutBP = Cardinal_ConvertTypeToSquadBlueprint("scar_scout", localPlayer)
		local squads = Player_GetSquads(localPlayer)
		
		for i = 1, SGroup_Count(squads) do
			local squad = SGroup_GetSquadAt(squads, i)
			
			if squad ~= nil and Squad_GetBlueprint(squad) == scoutBP then
				if Squad_IsIdle(squad) then
					goalSequence.goals[1].key = Squad_GetID(squad)
					break
				end
			end
		end
		
		if goalSequence.goals[1].key == nil or scartype(goalSequence.goals[1].key) ~= ST_NUMBER then
			return false
		end
		
		if Squad_IsValid(goalSequence.goals[1].key) and Squad_IsIdle(Squad_FromID(goalSequence.goals[1].key)) then 
			local deer_squad = FindDeerInSightIfNoneUnderAttack()
			if deer_squad ~= nil then
				goalSequence.goals[2].key = Squad_GetID(deer_squad)
				
				if Squad_IsValid(goalSequence.goals[2].key) then
					goalSequence.goals[2].data.scout = goalSequence.goals[1].key
					return true
				end
			end
		end
	end
	return false
end

function FindDeerInSightIfNoneUnderAttack()
	local localPlayer = Game_GetLocalPlayer()
	local deerBP = BP_GetSquadBlueprint("gaia_huntable_deer")
	local pos_camera_target = Camera_GetPivot()

	local eg_food_deposits = Misc_FindDepositsOfTypeCloseToPosition(RT_Food,
		Cardinal_ConvertTypeToEntityBlueprint("villager", localPlayer), 
		pos_camera_target, 
		100)
		
	local returnSquad = nil
	
	for i = 1, EGroup_Count(eg_food_deposits), 1 do
		local deposit = EGroup_GetEntityAt(eg_food_deposits, i) 
		if Misc_IsEntityOnScreen(deposit, .5) then 
			deposit_squad = Entity_GetSquad(deposit) 
			if deposit_squad ~= nil and Squad_IsAlive(deposit_squad) and Squad_GetBlueprint(deposit_squad) == deerBP then
				if not Squad_IsUnderAttack(deposit_squad, 1) and Player_CanSeeSquad(localPlayer, deposit_squad, ANY) then
					returnSquad = deposit_squad
				else
					EGroup_Clear(eg_food_deposits)
					return nil
				end
			end				
		end
	end
	EGroup_Clear(eg_food_deposits)
	
	return returnSquad
end

function UserHasIssuedAttack(goal)
	if goal.data.scout == nil or scartype(goal.data.scout) ~= ST_NUMBER then
		return false
	end
	
	if not Squad_IsValid(goal.data.scout) then
		return false
	end
	
	local deerBP = BP_GetSquadBlueprint("gaia_huntable_deer")
	local localPlayer = Game_GetLocalPlayer()
	local squads = Player_GetSquads(localPlayer)
	local scoutSquad = Squad_FromID(goal.data.scout)
	Squad_GetAttackTargets(scoutSquad, squads)
	for i = 1, SGroup_Count(squads) do
		local sgroupSquad = SGroup_GetSquadAt(squads, i)
		if sgroupSquad ~= nil and Squad_GetBlueprint(sgroupSquad) == deerBP then
			return true
		end
	end
	return false
end

function AnySquadKeyInvalidOrOffscreen(goalSequence)
	for i, goal in pairs(goalSequence.goals) do
		local key = goal.key
		if key == nil then
			return true	
		end
		
		if scartype(key) == ST_NUMBER then 
			if not Squad_IsValid(key) or Misc_IsSquadOnScreen(Squad_FromID(key), 100) == false then
				return true
			end
		end
	end
	return false
end

function AnySquadKeyInvalid(goalSequence)
	for i, goal in pairs(goalSequence.goals) do
		local key = goal.key
		if key == nil then
			return true	
		end
		
		if scartype(key) == ST_NUMBER then 
			if not Squad_IsValid(key) then
				return true
			end
		end
	end
	return false
end

function SuggestBuildFarmCriteriaMet(goalSequence)
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	if currentTime > __t_trainingModerateInterval then
		local localPlayer = Game_GetLocalPlayer()
		local farmBP = nil
		local farmBPTable = Cardinal_ConvertTypeToEntityBlueprint("farm", localPlayer,true)

		for i, ebp in pairs(farmBPTable) do 
			
		    if Entity_IsEBPOfType(ebp, "farm") then
				local bpName = BP_GetName(ebp)
				if Entity_IsEBPOfType(ebp, "pasture_mon_ha_gol") == false then
					if (string.find(bpName, "test") == nil) then
						if(string.find(bpName, "lith") == nil) then
							farmBP = ebp
						end
					end
				end
			end
		end
				
		if farmBP ~= nil and training_currentConstructionBlueprint == nil then
			
			if UI_IsXboxKBMUI() then
				goalSequence.goals[3].key = farmBP
			else
				goalSequence.goals[2].key = farmBP
			end
			
			--Instructions appear above a Villager gathering Food
			local villager = FindVillagerInSight(goalSequence)
			if villager ~= nil then
				-- The Player has no Farms in construction or completed
				Player_GetAll(localPlayer)
				EGroup_Filter(eg_allentities, "farm", FILTER_KEEP)
				local aFarmExistsOrIsUnderConstruction = EGroup_Count(eg_allentities) > 0
				if aFarmExistsOrIsUnderConstruction then
					return false
				end
				
				Player_GetAll(localPlayer)
				EGroup_Filter(eg_allentities, {"town_center","mill"}, FILTER_KEEP)
				EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
				local aDropOffExists = EGroup_Count(eg_allentities) > 0
			
				if aDropOffExists then
					
					-- Ensure the player has enough wood
					local farmCost = Player_GetEntityBPCost(localPlayer, farmBP)
					if Player_GetResource(localPlayer, RT_Wood) < farmCost.wood then
						
						return false
						
					end
					
					---- Ensure The Player has some Villagers gathering Wood
					--if Player_GetNumGatheringSquads(localPlayer, RT_Wood) == 0 then
						--return false
					--end
					
					
					--Get the closest drop off
					local villagerSquad = Squad_FromID(villager)
					local villagerPos = Squad_GetPosition(villagerSquad)
					local closestDropOff = EGroup_GetClosestEntity(eg_allentities, villagerPos)
					local closestDropOffPos = Entity_GetPosition(closestDropOff)
					
					 -- There are no more than 2 Sheep (alive) within 10 Meters of the drop off
					local eg_close_food_deposits = Misc_FindDepositsOfTypeCloseToPosition(RT_Food,
						Cardinal_ConvertTypeToEntityBlueprint("villager", localPlayer), 
						closestDropOffPos, 
						10)
						
					local sheepBP = BP_GetSquadBlueprint("gaia_herdable_sheep")
					local sheepCount = 0
					
					if EGroup_Count(eg_close_food_deposits) ~= 0 then
						for i = 1, EGroup_Count(eg_close_food_deposits), 1 do
							local deposit = EGroup_GetEntityAt(eg_close_food_deposits, i) 
							local deposit_squad = Entity_GetSquad(deposit) 
							if deposit_squad ~= nil and Squad_GetBlueprint(deposit_squad) == sheepBP then
								sheepCount = sheepCount + 1
							end		
							
							if sheepCount > _construct_farm_max_sheep_requirement then
								EGroup_Clear(eg_close_food_deposits)
								return false
							end
						end
						EGroup_Clear(eg_close_food_deposits)
					end
					
					-- There are no Berry Bushes within 50 meters of any drop off
					local eg_food_deposits = Misc_FindDepositsOfTypeCloseToPosition(RT_Food,
						Cardinal_ConvertTypeToEntityBlueprint("villager", localPlayer), 
						closestDropOffPos,
						50)
						
					if EGroup_Count(eg_food_deposits) ~= 0 then
						for i = 1, EGroup_Count(eg_food_deposits), 1 do
							local deposit = EGroup_GetEntityAt(eg_food_deposits, i) 
							local bp = Entity_GetBlueprint(deposit)
							local bpName = BP_GetName(bp)
							
							if (string.find(bpName, "dummy") ~= nil) then
								EGroup_Clear(eg_food_deposits)
								return false
							end				
						end
						EGroup_Clear(eg_food_deposits)
					end
					
				else
					return false
				end
				
				-- The Player has some Villagers harvesting food
				goalSequence.goals[1].key = villager
				return true
			end
		end
	end
	
	return false
end

-- 'trigger' for bandbox select (multiple units selected) tip
function UserHasMultipleUnitsOnScreen(goalSequence)
	
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	if currentTime > __t_trainingShortInterval then
		-- Get Local Player
		local localPlayer = Game_GetLocalPlayer()
		-- Get Local Player's units
		local sg_player_units = Player_GetSquads(localPlayer)
		-- Track number of idle units on screen
		local idleOnScreenUnitCount = 0
				
		-- For every player unit
		for i = 1, SGroup_Count(sg_player_units) do
			-- Get squad from sgroup
			local squad = SGroup_GetSquadAt(sg_player_units, i)
			
				-- If military unit is idle and on screen
				if Squad_IsOfType(squad, "military") and not Squad_IsOfType(squad, "scout") and Squad_IsIdle(squad) and Misc_IsSquadOnScreen(squad, 100) then 
					
					-- Increment idle on screen unit count
					idleOnScreenUnitCount = idleOnScreenUnitCount + 1
					
					-- Assign unit as goal sequence key
					goalSequence.goals[1].key = Squad_GetID(squad)
				
			end
			
		end
		
		-- If there are more than one idle units on screen
		if (idleOnScreenUnitCount > 1) then
			
			return true
			
		else
			
			return false
			
		end
	end
end

-- NEW Predicate for Control Group tip
function UserHasMultipleUnitsForCtrlGroupOnScreen(goalSequence)
	
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	if currentTime > __t_trainingShortInterval then
		-- Get Local Player
		local localPlayer = Game_GetLocalPlayer()
		-- Get Local Player's units
		local sg_player_units = Player_GetSquads(localPlayer)
		-- Track number of idle units on screen
		local idleOnScreenUnitCount = 0
				
		-- For every player unit
		for i = 1, SGroup_Count(sg_player_units) do
			-- Get squad from sgroup
			local squad = SGroup_GetSquadAt(sg_player_units, i)
			
				-- If military unit is idle and on screen
				if Squad_IsOfType(squad, "military") and not Squad_IsOfType(squad, "scout") and Squad_IsIdle(squad) and Misc_IsSquadOnScreen(squad, 100) then 
					
					-- Increment idle on screen unit count
					idleOnScreenUnitCount = idleOnScreenUnitCount + 1
					
					-- Assign unit as first goal sequence key
					goalSequence.goals[1].key = Squad_GetID(squad)
				
					--Assign unit as second goal sequence key
					--goalSequence.goals[2].key = Squad_GetID(squad)
				
			end
			
		end
		
		-- If there are more than one idle units on screen
		if (idleOnScreenUnitCount > 1) then
			
			return true
			
		else
			
			return false
			
		end
	end
end

-- 'isComplete' for bandbox select (user selecting multiple units (also used for bypass))
function UserHasSelectedMultipleMilitaryUnits(goal)
	
	-- Get selected squads
	Misc_GetSelectedSquads(sg_currentSelection, false)
	
	-- Track unit count
	local idleUnitCount = 0
	
	-- For every unit selected
	for i = 1, SGroup_Count(sg_currentSelection) do
		
		-- Get squad from sgroup
		local squad = SGroup_GetSquadAt(sg_currentSelection, i)
		
			-- Increment unit count
			idleUnitCount = idleUnitCount + 1
			
		end
	
	-- If more than 1 unit was selected
	if idleUnitCount > 1 then
		
		-- Goal was met
		return true
		
	else
		-- Goal was not met
		return false
	end
end
 
-- 'trigger' for Control Groups (creating a specific control group)
function UserHasSelectedMultipleMilitaryUnitsPredicate(goalSequence)
				
	-- Get selected squads
	Misc_GetSelectedSquads(sg_currentSelection, false)
	
	-- Track unit count
	local idleUnitCount = 0
	
	-- For every unit selected
	for i = 1, SGroup_Count(sg_currentSelection) do
		
		-- Get squad from sgroup
		local squad = SGroup_GetSquadAt(sg_currentSelection, i)
		
		-- If military unit is idle and on screen
		if Squad_IsOfType(squad, "military") and not Squad_IsOfType(squad, "scout") and Squad_IsIdle(squad) and Misc_IsSquadOnScreen(squad, 100) then 
		
			-- Increment unit count
			idleUnitCount = idleUnitCount + 1
				
			-- Assign unit as goal sequence key
			goalSequence.goals[1].key = Squad_GetID(squad)
		
		end
	end
				
	-- If more than 1 unit was selected
	if idleUnitCount > 1 then
		
		-- Trigger was met
		return true
		
	else
		-- Trigger was not met
		return false
	end
end

