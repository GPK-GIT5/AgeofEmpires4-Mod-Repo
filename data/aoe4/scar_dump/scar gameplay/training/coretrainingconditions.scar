-- Control Group Selection Predicate
function UserHasControlGroup(goalSequence)
local currentTime = Timer_GetElapsed(goalSequence.timerID)
	--if currentTime > __t_trainingShortInterval then
	-- Create squad/entity groups if they do not exist
	local sg_control_group = SGroup_CreateIfNotFound("sg_control_group")
	local eg_control_group = EGroup_CreateIfNotFound("eg_control_group")
	-- For all possible control groups
		for i = 0, 9 do
		-- Returns contents of specific control groups
		Misc_GetControlGroupContents(i, sg_control_group, eg_control_group)
			-- If any units are in control group
			if SGroup_Count(sg_control_group) > 0 then
				-- Create a callback that listens for control group selection
				UI_SetControlGroupSelectedCallback(ControlGroupSelectedCallback)
				-- Listen for completion (so we can clear callback after)
				Training_AddCallbacksToGoal(goalSequence.goals[1], nil, OnControlGroupSelectedComplete)
				-- Assign key to control group 1 icon
				goalSequence.goals[1].key = "ControlGroupButton1Tag"
				return true 
			end
		end
	--end
return false
end

--Callback that listens for control group selection
function ControlGroupSelectedCallback(controlGroupIndex)
	--If control group that was selected was 1
	if controlGroupIndex == 1 then
		
		user_has_selected_control_group_1 = true
		
	end
	
end

-- Run when Control Group Selection goal is completed
function OnControlGroupSelectedComplete(completeReason)
	--Removes callback that listens for control group selection (perf)
	UI_ClearControlGroupSelectedCallback()
	
end

-- Control Group Selection goal completion
function UserHasSelectedControlGroup(goal)
	-- If the player has selected control group 1
	if user_has_selected_control_group_1 == true then
		
		return true
		
	end
end

-- Ignore function
function ControlGroupDoesNotExist()
	--Create squad/entity groups if they do not exist
	local sg_control_group = SGroup_CreateIfNotFound("sg_control_group")
	local eg_control_group = EGroup_CreateIfNotFound("eg_control_group")
		
		-- Returns contents of first control group
		Misc_GetControlGroupContents(1, sg_control_group, eg_control_group)
	
		-- If no units are in the control group
		if SGroup_Count(sg_control_group) == 0 then
			return true
		end
	
	return false
end

function UserHasCreatedAnyControlGroup(goal)
	
	-- Create squad/entity groups if they do not exist
	local sg_control_group = SGroup_CreateIfNotFound("sg_control_group")
	local eg_control_group = EGroup_CreateIfNotFound("eg_control_group")
	
	-- For all possible control groups
	for i = 0, 9 do
		
		-- Returns contents of first control group
		Misc_GetControlGroupContents(1, sg_control_group, eg_control_group)
	
		-- If any units are in control group
		if SGroup_Count(sg_control_group) > 0 then
			return true
		end
		
	end
	
	return false
end

-- Build Drop-off ignore
function UserCannotBuildDropoff(goal)
		
	local localPlayer = Game_GetLocalPlayer()
	local woodResources = Player_GetResource(localPlayer, RT_Wood)
	
	-- Check if player is Mongol
	if Player_GetRaceName(Game_GetLocalPlayer()) == "mongol" then
		-- Set Ger cost
		local woodRequired = 100			
		
		-- Check if player has enough Wood to build a Ger
		if woodResources < woodRequired then
			return true
		end
		
	else
	
		-- Set Lumber Camp cost
		local woodRequired = 50
		
		-- Check if player has enough Wood to build a Lumber Camp
		if woodResources < woodRequired then
			return true
		end
	end
	return false
end

-- Only relevant when UI_IsXboxControllerUI() == true
function UserHasOpenedContextualRadial(goal)
	return UI_GetActiveRadialMenuType() == RMT_ContextualRadialMenu
end

function UserHasClosedContextualRadial(goal)
	return UI_GetActiveRadialMenuType() == RMT_Invalid
end

function UserHasOpenedDPadRightRadial(goal)

	return UI_GetActiveRadialMenuType() == RMT_ContextualRadialMenu and UI_GetActiveRelicRadialMenuDirection() == RMD_Right 
end


-- Only relevant when UI_IsXboxControllerUI() == true, also works with Xbox KBM landmark menu
function UserHasOpenedLandmarkRadial(goal)
	return UI_XboxIsLandmarkRadialOpen()
end


-- helper function to return cursor or reticle based on input type
function ReturnCursorOrReticle()
	if UI_IsXboxControllerUI() then
		return "LooseReticle"
	else
		return "Cursor"
	end
end

function UserHasCommandsCommandCardTabOpen(goal)
	return UI_GetXboxCommandCardTab() == XCCT_Command
end

function UserHasEconomicCommandCardTabOpen(goal)
	return UI_GetXboxCommandCardTab() == XCCT_Economic
end

function UserHasMilitaryCommandCardTabOpen(goal)
	return UI_GetXboxCommandCardTab() == XCCT_Military
end

function UserHasVillagerCommandsCardTabOpen(goal)
	return UserHasSelectedAVillager(goal) and UI_GetXboxCommandCardTab() == XCCT_Command
end

function UserHasVillagerEconomicCardTabOpen(goal)
	return UserHasSelectedAVillager(goal) and UI_GetXboxCommandCardTab() == XCCT_Economic
end

function UserHasVillagerMilitaryCardTabOpen(goal)
	return UserHasSelectedAVillager(goal) and UI_GetXboxCommandCardTab() == XCCT_Military
end