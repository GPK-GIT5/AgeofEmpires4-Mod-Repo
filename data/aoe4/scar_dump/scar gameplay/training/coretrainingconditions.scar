end

function TimeHasPassedWithoutBuildingAHouse(goalSequence)
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	if currentTime > __t_trainingShortInterval then
		local localPlayer = Game_GetLocalPlayer()
		
		-- If player is not at max pop cap
		if Player_GetPopulationPercentage(localPlayer, CT_Personnel) < 1 then
			return false
		end
		
		local houseBP = Cardinal_ConvertTypeToEntityBlueprint("house", localPlayer)
		
		if houseBP ~= nil 
		and training_currentConstructionBlueprint == nil 
		and Player_CanConstruct(localPlayer, houseBP) then
			if(UI_IsXboxKBMUI()) then
				goalSequence.goals[3].key = houseBP
			else
				goalSequence.goals[2].key = houseBP
			end
			
			local villager = FindVillagerInSight(goalSequence)
			if villager ~= nil then
				goalSequence.goals[1].key = villager
				return true
			end
		end
	end
	
	return false
end

