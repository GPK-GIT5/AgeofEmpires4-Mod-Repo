function Regicide_ConstructPresentation(playerID, presentationData)
	
	local player = Core_GetPlayersTableEntry(playerID)
		if player.isLocal then
			Misc_ClearSelection()
			Taskbar_SetVisibility(false)
			Obj_SetState(player._regicide.objective_id, presentationData.objective_state)
			Obj_CreatePopup(player._regicide.objective_id, presentationData.objective_popup_title, "")
			Music_PlayStinger(presentationData.objective_stinger)
			
			Rule_AddOneShot(_gameOver_message, 
				GAMEOVER_OBJECTIVE_TIME, {
					_playerID = playerID, 
					_icon = _regicide.icons.objective, 
					_endType = Loc_GetString(presentationData.end_game_title),
					_message = Loc_Empty(),
					_sound = presentationData.end_game_stinger, 
					_videoURI = presentationData.end_game_video
				})
		end
end