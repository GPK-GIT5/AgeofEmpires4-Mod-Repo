-- Japanese civ has unique buildings for combined house and farm/food_mill functions, using a separate function to find the first instance of that for the player.
-- We use this for food/production upgrade queueing at the moment. 
-- Fallback for a farmhouse that did not spawn would be nil entity, nil eid, and starting position as the position of "farmhouse"
function EmpireWars_FindFarmhouse(player)
	
	local farmhouse_id = EmpireWars_FindMatchingBuildings(player.id, nil, nil, "farmhouse_0")
	
	if TableCount(farmhouse_id) > 0 then
		local farmhouse_entity = Entity_FromID(farmhouse_id[1])
		local farmhouse_entity_position = Entity_GetPosition(farmhouse_entity)
		player.farmhouse = {
