-- Setting up the Empire Wars scenario on top of the standard mode conditions

import("cardinal.scar")
import("gathering_utility.scar")
import("gamemodes/standard_mode.scar")
import("missionomatic/missionomatic_utility.scar")



-- data table for some variables to reference later
_ew = 
{
	module = "EmpireWars",
	options = {},
	
	prelate_per_res = 1, -- HRE prelates per resource
	scholar_count = 2, -- Delhi scholars garrisoned at start
	io_per_res = 1, -- Imperial officers per assignment
	sheep_count = 6, -- Sheep per player at start
	
	-- resource variables to be able to do behavior assignments,
	eg_allWoodResources,
	eg_allStoneResources,
	eg_allGoldResources,
	eg_allForageBushes,
	eg_allSheep,
	eg_allDeer,
	eg_allShoreFish,
	eg_allCattle,
}

Core_RegisterModule(_ew.module)

function EmpireWars_OnGameSetup()
	Setup_GetWinConditionOptions(_ew.options) -- no special options right now, empty array
	
	-- Challenge tracking normally starts between _OnGameSetup and _PreInit delegates and some
	-- entities/squads are spawned before _PreInit. Pause tracking here to prevent the spawned
	-- units from counting towards challenge progress.
	Game_PauseChallengeTracking()
end


function EmpireWars_PreInit()
	for i, player in pairs(PLAYERS) do
		EmpireWars_FindBuildings(player)
		EmpireWars_SetUpStartingArea(player)
		EmpireWars_SpawnSheep(player)
		EmpireWars_SetPastureRallyPoints(player)
		EmpireWars_GrantVizierExp(player)
	end
end

function EmpireWars_OnInit()
	--initialize where we'll keep all resources
	_ew.eg_allWoodResources = EGroup_CreateIfNotFound("eg_allWoodResources")
	_ew.eg_allStoneResources = EGroup_CreateIfNotFound("eg_allStoneResources")
	_ew.eg_allGoldResources = EGroup_CreateIfNotFound("eg_allGoldResources")
	_ew.eg_allForageBushes = EGroup_CreateIfNotFound("eg_allForageBushes")
	_ew.eg_allSheep = EGroup_CreateIfNotFound("eg_allSheep")
	_ew.eg_allDeer = EGroup_CreateIfNotFound("eg_allDeer")
	_ew.eg_allShoreFish = EGroup_CreateIfNotFound("eg_allShoreFish")
	_ew.eg_allDeepFish = EGroup_CreateIfNotFound("eg_allDeepFish")
	_ew.eg_allCattle = EGroup_CreateIfNotFound("eg_allCattle")
	
	-- this has to be after we spawn sheep and any other gaia/neutral entities in preinit
	Gathering_FindAllResources(
		_ew.eg_allWoodResources,
		_ew.eg_allStoneResources,
		_ew.eg_allGoldResources,
		_ew.eg_allForageBushes,
		_ew.eg_allSheep,
		_ew.eg_allDeer,
		_ew.eg_allShoreFish,
		_ew.eg_allCattle,
		_ew.eg_allDeepFish
	)
	
	for i, player in pairs(PLAYERS) do
		EmpireWars_MaliMineSwitch(player)
		EmpireWars_SpawnVillagers(player)
		EmpireWars_SpawnPrelates(player)
		EmpireWars_SpawnScholars(player)
		EmpireWars_SpawnJoan(player)
	end
end



function EmpireWars_Start()
	for i, player in pairs(PLAYERS) do
		EmpireWars_SpawnImperialOfficers(player)		
		EmpireWars_QueueVillagers(player)
		EmpireWars_QueueUpgrades(player)
		EmpireWars_GrantUpgrades(player)
	end
	
	-- Resume challenge tracking after entities/squads have spawned but before player gains control.
	Game_ResumeChallengeTracking()
end


-- Called when Core_SetPlayerDefeated() is invoked. Signals that a player has been eliminated from play due to defeat. Reserving in case we want different messaging/different end screen
function EmpireWars_OnPlayerDefeated(player,reason)
	
end

-- When a victory condition is met, a module must call Core_OnGameOver() in order to invoke this delegate and notify all modules that the match is about to end. Generally used for clean up (removal of rules, objectives, and UI elements specific to the module).
function EmpireWars_OnGameOver()
	
end


---------------------------------------------------------------------------------------------
--Helpers - Find buildings
---------------------------------------------------------------------------------------------

-- Calls the right functions for the player based on player civ, to find the building entities and store them in the player array for later access in spawning and set up functions.
function EmpireWars_FindBuildings(player)
	
	EmpireWars_FindTownCenter(player)

	local player_civ = Player_GetRaceName(player.id)
	
	if player_civ == "mongol" then
		EmpireWars_FindGers(player)
	elseif player_civ == "mongol_ha_gol" then
		EmpireWars_FindGers(player)
		EmpireWars_FindFoodMill(player)
	else
		EmpireWars_FindFarmhouse(player)
		EmpireWars_FindMosque(player)
		EmpireWars_FindStoneMine(player)
		EmpireWars_FindFoodMill(player)
		EmpireWars_FindLumberMill(player)
		EmpireWars_FindMiningCamp(player)
	end
end

-- Finds the town center entity, eid, and position and stores them in the player array for the player.
-- Fallback for a town center that failed to spawn would be nil entity, nil eid, and starting position as the position of "town center"
-- If the player does not have any entities found, function just ends.
function EmpireWars_FindTownCenter(player)
	local town_center_entity_id = EmpireWars_FindMatchingBuildings(player.id, nil, nil, "town_center")
	
	if TableCount(town_center_entity_id) > 0 then
		local town_center_entity = Entity_FromID(town_center_entity_id[1])
		local town_center_position = Entity_GetPosition(town_center_entity)
		player.town_center = {
			entity = town_center_entity,
			entity_id = town_center_entity_id[1],
			position = town_center_position,
		}
	else
		player.town_center = {
			entity = nil,
			entity_id = nil,
			position = Player_GetStartingPosition(player.id),
		}
	end
end

-- Finds the food mill entity, eid, and position and stores them in the player array for the player.
-- Fallback for a food mill that failed to spawn would be nil entity, nil eid, and starting position as the position of "food mill"
