-- Finds the ger entities, eid, and position and stores them in the player array for the player.
-- Fallback for a ger that failed to spawn would be just the player spawn as the position for both, and nil for the entity and entityID.
-- Just Gold Ger for now. 
function EmpireWars_FindGers(player)
	
	-- Find the ger adjacent to gold
	local gold_ger_entity_id = EmpireWars_FindMatchingBuildings(player.id, nil, "ger_gold_set", "ger_gold")
	
	if TableCount(gold_ger_entity_id) > 0 then
		local gold_ger_entity = Entity_FromID(gold_ger_entity_id[1])
		local gold_ger_position = Entity_GetPosition(gold_ger_entity)
		player.gold_ger = {
			entity = gold_ger_entity,
			entity_id  = gold_ger_entity_id[1],
			position = gold_ger_position,
		}
	else
		player.gold_ger = {
			entity = nil,
			entity_id  = nil,
			position = Player_GetStartingPosition(player.id),
		}
	end
		
end

