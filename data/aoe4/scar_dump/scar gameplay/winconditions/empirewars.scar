--	Spawns villagers to idle. Uses a town center to determine spawn location. 
function EmpireWars_IdleHelper(player, villager_count, villager_bp)
	if villager_count == 0 then
		print("no idle villagers needed")
	else
		local spawn_position = Util_GetOffsetPosition(player.town_center.position, 8, 8)
		local sgroup_name = "sg_player_idle_villagers_" .. tostring(player.id)
		local sg_player_villagers_idle = SGroup_CreateIfNotFound(sgroup_name)
		
		UnitEntry_DeploySquads(player.id, sg_player_villagers_idle, {{sbp = villager_bp, numSquads = villager_count}}, spawn_position)
		
		SGroup_Destroy(sg_player_villagers_idle)
	end
end

--	Spawns and then assigns villagers to harvest berries. Uses a mill entity to offset spawn position, or in the case of Mongols, the ger.
function EmpireWars_BerryTaskHelper(player, villager_count, villager_bp)
	if villager_count == 0 then
		print("no berry villagers needed")
	else
		local spawn_position
		if Player_GetRaceName(player.id) == "mongol" and player.berry_ger ~= nil then --will be nil for 7.0
			spawn_position = Util_GetOffsetPosition(player.berry_ger.position, 5, 5)	
		else
			spawn_position = Util_GetOffsetPosition(player.food_mill.position, 5, 5)
		end
		
		local sgroup_name = "sg_player_berry_villagers_" .. tostring(player.id)
		local sg_player_villagers_berry = SGroup_CreateIfNotFound(sgroup_name)
		UnitEntry_DeploySquads(player.id, sg_player_villagers_berry, {{sbp = villager_bp, numSquads = villager_count}}, spawn_position)
		Gathering_AssignVillagersToBerries(sg_player_villagers_berry, _ew.eg_allForageBushes, true, false)
	
		SGroup_Destroy(sg_player_villagers_berry)
	end

end

