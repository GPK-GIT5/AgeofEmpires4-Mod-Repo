-- Spawns sheep near the TC or food mill (for Chinese civ) for the player
function EmpireWars_SpawnSheep(player)
	player_civ = Player_GetRaceName(player.id)

	local sheep_bp = BP_GetSquadBlueprint("gaia_herdable_sheep")
	local spawn_position
	
	if player_civ == "chinese" or player_civ == "chinese_ha_01" then
		spawn_position = Util_GetOffsetPosition(player.food_mill.position, 5, 5)
	else
		spawn_position = Util_GetOffsetPosition(player.town_center.position, 5, 10)
	end
	
	for i=1, _ew.sheep_count do 
		local offset = Util_GetOffsetPosition(spawn_position, i, .5)
		Squad_CreateAndSpawnToward(sheep_bp, player.id, 0, offset, player.town_center.position)
	end
end

-- Spawns prelates close to the food, lumber and gold collection units for the HRE civ
function EmpireWars_SpawnPrelates(player)
	local player_civ = Player_GetRaceName(player.id)
	if player_civ == "hre" then
		local bp_prelate = BP_GetSquadBlueprint("unit_monk_1_hre")
		
		--food prelates
		local spawn_position_food = Util_GetOffsetPosition(player.town_center.position, 5, 10)
		local sgroup_name_food = "sg_player_food_prelates" .. tostring(player.id)
		local sg_player_food_prelates = SGroup_CreateIfNotFound(sgroup_name_food)			
		
		UnitEntry_DeploySquads(player.id, sg_player_food_prelates, {{sbp = bp_prelate, numSquads = _ew.prelate_per_res}}, spawn_position_food)
		
		--gold prelates
		local spawn_position_gold = Util_GetOffsetPosition(player.gold_mine.position, 5, 5)						
		local sgroup_name_gold = "sg_player_gold_prelates" .. tostring(player.id)
		local sg_player_gold_prelates = SGroup_CreateIfNotFound(sgroup_name_gold)
		
		UnitEntry_DeploySquads(player.id, sg_player_gold_prelates, {{sbp = bp_prelate, numSquads = _ew.prelate_per_res}}, spawn_position_gold)
		
		SGroup_Destroy(sg_player_gold_prelates)
		SGroup_Destroy(sg_player_food_prelates)
	else
		print("no prelates needed")
	end
end



-- Spawns Imperial Officers for the Chinese civ, supervising the food mill and the lumber camp. AI doesn't have the supervise command knowledge, 
-- so to avoid stuck units only assigns IOs for supervision for Human players.
function EmpireWars_SpawnImperialOfficers(player)
	local player_civ = Player_GetRaceName(player.id)
	local bp_official
	
	if player_civ == "chinese" or player_civ == "chinese_ha_01" then
		if player_civ == "chinese" then
			bp_official = BP_GetSquadBlueprint("unit_official_1_chi")
		else
			bp_official = BP_GetSquadBlueprint("unit_official_1_chi_ha_01")
		end
		
		
		--mill official
		local spawn_position_food = Util_GetOffsetPosition(player.food_mill.position, 5, 5)
		local sgroup_name_food = "sg_player_food_officials" .. tostring(player.id)
		local sg_player_food_officials = SGroup_CreateIfNotFound(sgroup_name_food)			
		local ability_bp = BP_GetAbilityBlueprint("official_supervise_building_target_chi")
		
		UnitEntry_DeploySquads(player.id, sg_player_food_officials, {{sbp = bp_official, numSquads = _ew.io_per_res}}, spawn_position_food)
		
		local eg_single_mill = EGroup_CreateIfNotFound("eg_single_mill")
		if player.food_mill.entity ~= nil and Player_IsHuman(player.id) then
			EGroup_Single(eg_single_mill, player.food_mill.entity)
			LocalCommand_SquadEntityAbility(player.id, sg_player_food_officials, eg_single_mill, ability_bp, false, true)
		end
		
		--lumber official
		local spawn_position_lumber = Util_GetOffsetPosition(player.lumber_camp.position, 5, 5)						
		local sgroup_name_lumber = "sg_player_lumber_officials" .. tostring(player.id)
		local sg_player_lumber_officials = SGroup_CreateIfNotFound(sgroup_name_lumber)
		
		UnitEntry_DeploySquads(player.id, sg_player_lumber_officials, {{sbp = bp_official, numSquads = _ew.io_per_res}}, spawn_position_lumber)
		
		if player.lumber_camp.entity ~= nil and Player_IsHuman(player.id) then
			local eg_single_lumber_camp = EGroup_CreateIfNotFound("eg_single_lumber_camp")
			EGroup_Single(eg_single_lumber_camp, player.lumber_camp.entity)
			LocalCommand_SquadEntityAbility(player.id, sg_player_lumber_officials, eg_single_lumber_camp, ability_bp, false, true)
		end
		
		SGroup_Destroy(sg_player_food_officials)
		SGroup_Destroy(sg_player_lumber_officials)	
	else
		print("no imperial officers needed")
	end
end

-- Spawns 3 scholars and garrisons them in the town-gen mosque for Delhi civilization
function EmpireWars_SpawnScholars(player)
	local player_civ = Player_GetRaceName(player.id)
	if player_civ == "sultanate" then
		local bp_scholar = BP_GetSquadBlueprint("unit_monk_2_sul")
		if player.mosque.entity ~= nil then
			EmpireWars_Temp_CreateUnitsInsideEntity(player.id, {{sbp = bp_scholar, numSquads = _ew.scholar_count}}, player.mosque.entity, nil)
		else
			local spawn_position_mosque = Util_GetOffsetPosition(player.mosque.position, 5, 5)
			local sgroup_name_scholars = "sg_player_mosque_scholars" .. tostring(player.id)
			local sg_player_scholars = SGroup_CreateIfNotFound(sgroup_name_scholars)
			UnitEntry_DeploySquads(player.id, sg_player_scholars, {{sbp = bp_scholar, numSquads = _ew.scholar_count}}, spawn_position_mosque)
			SGroup_Destroy(sg_player_scholars)
		end
	else
		print("no scholars needed")
	end
end

function EmpireWars_SpawnJoan(player)
	local player_civ = Player_GetRaceName(player.id)
	if player_civ == "french_ha_01" then
		local bp_joan = BP_GetSquadBlueprint("unit_jeanne_d_arc_1_fre_ha_01")
		local spawn_position = Util_GetOffsetPosition(player.town_center.position, 5, 5)
		
		-- Use Squad_CreateAndSpawnToward instead of UnitEntry_DeploySquads because UnitEntry_DeploySquads doesn't trigger
		-- on spawn events, which are needed for the custom Fre HA ui to work.
		Squad_CreateAndSpawnToward(bp_joan, player.id, 1, spawn_position, player.town_center.position)
		
		--grant her enough experience to reach tier 2
		local exp_tier2 = Player_GetStateModelFloat(player.id, "jeanne_starting_experience_ew")
		Player_SetStateModelFloat(player.id, "jeanne_d_arc_total_experience", exp_tier2)
		
	end
end

