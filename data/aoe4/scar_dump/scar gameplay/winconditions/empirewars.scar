end


-- Queues various upgrades(currently: Wheelbarrow, Forestry, Enhanced Production) for Delhi civilization players
function EmpireWars_QueueUpgrades(player)
	local player_civ = Player_GetRaceName(player.id)
	if player_civ == "sultanate" then
		local mill_entity = player.food_mill.entity
		local lumber_entity = player.lumber_camp.entity
		local mosque_entity = player.mosque.entity
		
		if mill_entity ~= nil then
			local wheelbarrow_pbg = BP_GetUpgradeBlueprint("upgrade_unit_town_center_wheelbarrow_1_sul")
			local success_mill = Entity_QueueProductionItemByPBG(mill_entity, PITEM_Upgrade, wheelbarrow_pbg)
		end
		if lumber_entity ~= nil then
			local forestry_pbg = BP_GetUpgradeBlueprint("upgrade_econ_resource_wood_fell_rate_1_sul")
			local success_lumber = Entity_QueueProductionItemByPBG(lumber_entity, PITEM_Upgrade, forestry_pbg)
		end
		if mosque_entity ~= nil then
			local eproduction_pbg = BP_GetUpgradeBlueprint("upgrade_age2_scholar_military_production_sul")
			local success_mosque = Entity_QueueProductionItemByPBG(mosque_entity, PITEM_Upgrade, eproduction_pbg)
		end
	end
end
	
-- Sets up the starting area Fog of War reveal for the player
function EmpireWars_SetUpStartingArea(player)
	FOW_PlayerRevealArea(player.id, player.town_center.position, 60, 120)
	
end

-- Placeholder while we have don't have a better solution. Checks if the vein the pit mine spawned by town-gen is on a large vein vs. a large one, 
-- swaps out the small pit mine with a large pit mine entity.
function EmpireWars_MaliMineSwitch(player)
	local player_civ = Player_GetRaceName(player.id)
	if player_civ == "malian" then
		local pit_mine_eid = EmpireWars_FindMatchingBuildings(player.id, nil, nil, "pit_mine")
		if TableCount(pit_mine_eid) > 0 then
			local pit_mine_entity = Entity_FromID(pit_mine_eid[1])
			local mine_pos = Entity_GetPosition(pit_mine_entity)
			local gold_resource_entity = EGroup_GetClosestEntity(_ew.eg_allGoldResources, mine_pos)
			local gold_bp_name = BP_GetName(Entity_GetBlueprint(gold_resource_entity))
			
			-- Check if it's a large gold deposit, small one has "_small" appended
			if gold_bp_name == "resource_gold_deposit" then 
				
				--Destroy the town-gen pit mine that doesn't match this resource
				Entity_Destroy(pit_mine_entity)
				
				--Build the large pit-mine that matches resource size
				local pit_mine_entity_large = Entity_Create(BP_GetEntityBlueprint("building_open_pit_mine_mal"), player.id, mine_pos, true)
				Entity_Spawn(pit_mine_entity_large)
				Entity_ForceConstruct(pit_mine_entity_large)
			end
		end
	end
end


--? @shortdesc Returns the count of the units in a unitTable. Temporary waiting integrations.
--? @args Table UnitTable
--? @result  Integer
function EmpireWars_Temp_CountUnits(unitTable)
	local count = 0
	for index, unitRow in pairs(unitTable) do
		count = count + (unitRow.numSquads or 1)
	end
	return count
end

--? @shortdesc Units will be spawned inside entity_hold. Use Entity_GetHoldSlotsAvailable to check if entity_hold has space. Temporary waiting integrations.
--? @extdesc If sgroup is provided, spawned units will be added to it. If sgroup is a string, a new sgroup will be created with that name.
--? @result sgroup
function EmpireWars_Temp_CreateUnitsInsideEntity(player, units, entity_hold, sgroup)
	local open_slots = Entity_GetHoldSlotsAvailable(entity_hold)
	assert(EmpireWars_Temp_CountUnits(units) <= open_slots, "Not enough room in hold, use Entity_GetHoldSlotsAvailable to check for space")
	
	if scartype(sgroup) == ST_STRING then
		sgroup = SGroup_CreateUniqueWithPrefix(sgroup)
	end
	local sg_spawned_units = SGroup_CreateUnique("sg_spawned_units")
	eg_createUnitsInsideEntity = EGroup_CreateIfNotFound("eg_createUnitsInsideEntity")
	EGroup_Single(eg_createUnitsInsideEntity, entity_hold)
	UnitEntry_DeploySquads(player, sg_spawned_units, units, eg_createUnitsInsideEntity)
	if sgroup then
		SGroup_AddGroup(sgroup, sg_spawned_units)
	end
	SGroup_Destroy(sg_spawned_units) --destroy group for units
	return sgroup	
end


--? @shortdesc Returns an array of all building entityIDs spawned by town generation that match the given filters.
--? @extdesc Since this returns entityIDs, you will need to use Entity_FromID to get at the entity. Note that the entity could come back as 
--? nil if it has been destroyed since town generation ran.
--? @args 
--? Player player: cannot be nil. Will only match entities from towns owned by this player
--? String townID: can be nil. Will only match entities that were spawned as part of a town with this id. 
--? 	See the AE bag for map_gen_town to set the id. If nil, any town will match.
--? String spawnSetID: can be nil. Will only match entities that were spawned as part of a spawn set with this id. 
--? 	See the AE bag for map_gen_town to set the id. If nil, any spawn set will match.
--? String structureGroupID: can be nil. Will only match entities that were spawned as part of a structureGroupID with this id. 
--? 	See the AE bag for map_gen_town to set the id. If nil, any structure group will match.
--? @result Table that is an array of entities that matched the filters. Can be empty if there are no matches or could have multiple entities
--? if there were multiple matches structure groups or the matched structure group has multiple entities in it.
--? 
--? Example Usage: 
--? EmpireWars_FindMatchingBuildings(player, nil, nil, "house") to find any buildings labeled "house" in any town and any spawn set owned by player
--? EmpireWars_FindMatchingBuildings(player, "test_town_abb", "house_of_wisdom", "house_of_wisdom") to find any buildings labeled "house" in 
--? a town named "test_town_abb" that were ion a structure group called "house_of_wisdom" that was in a spawn_set called "house_of_wisdom"
--? EmpireWars_FindMatchingBuildings(player, nil, nil, nil) would give you every building spawned for a given player as part of town gen.
function EmpireWars_FindMatchingBuildings(player, townID, spawnSetID, structureGroupID)
	local result = {}
	
	if (_townGen == nil) then
		print("Global table _townGen wasn't found.")
		return result
	end
	
	local playerID = Player_GetID(player)
	
	for _, town in pairs(_townGen.towns) do
		if ((playerID == town.playerID) and ((townID == nil) or (townID == town.id))) then
			for _, spawnSet in pairs(town.spawnSets) do
				if ((spawnSetID == nil) or (spawnSetID == spawnSet.id)) then
					for _, structureGroup in pairs(spawnSet.structureGroups) do
						if ((structureGroupID == nil) or (structureGroupID == structureGroup.id)) then
							for _, entityID in pairs(structureGroup.entityIDs) do
								table.insert(result, entityID)
							end
						end
					end
				end
			end
		end
	end
	
	return result
end
