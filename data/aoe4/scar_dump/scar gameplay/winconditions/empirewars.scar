-- Queues count of villagers for production at player's town center. 2 for Historic HRE, 4 for everyone else 
function EmpireWars_QueueVillagers(player)
	local vil_bp =  BP_GetSquadArchetypeBlueprintForPlayer(player.id, BA_VILLAGER)
	local tc_entity = player.town_center.entity
	local vil_queue
	
	if Player_GetRaceName(player.id) == "hre_ha_01" then
		vil_queue = 2
	else
		vil_queue = 4
	end
	
	if tc_entity ~= nil then
		for i=1, vil_queue do
			local success = Entity_QueueProductionItemByPBG(tc_entity, PITEM_Spawn, vil_bp)		
		end
	end
 end

-- Grants 30 Vizier Experience to all Ottoman civ players at the start.
function EmpireWars_GrantVizierExp(player)
	local player_civ = Player_GetRaceName(player.id)
	if player_civ == "ottoman" then
		
		local exp_float = Player_GetStateModelFloat(player.id, "imperial_council_exp_ott")
		exp_float = exp_float + 30
		Player_SetStateModelFloat(player.id, "imperial_council_exp_ott", exp_float)
	end
end

-- Sets the pasture rally point close to the town center location for the Mongol civ
function EmpireWars_SetPastureRallyPoints(player)
	local player_civ = Player_GetRaceName(player.id)
	if player_civ == "mongol" then
		
		local eid_array_pasture = EmpireWars_FindMatchingBuildings(player.id, "mon_town", "pasture_set", "pasture")	
		
		local egroup_name = "pasture_egroup"
		local pasture_egroup = EGroup_CreateIfNotFound(egroup_name)
		local sheep_corral_position = Util_GetOffsetPosition(player.town_center.position, 5, 10)
		
		if eid_array_pasture ~= nil then
			for i, eid in pairs(eid_array_pasture) do
				local pasture_entity = Entity_FromID(eid)
				EGroup_Add(pasture_egroup, pasture_entity)
			end
			EGroup_SetRallyPoint(pasture_egroup, sheep_corral_position)			
		end
		EGroup_Destroy(pasture_egroup)
	end
end

function EmpireWars_GrantUpgrades(player)
	local player_civ = Player_GetRaceName(player.id)
	--Decided not to grant this upgrade to Japanese civ for the next version 7/7/23. Still up for discussion though, so leaving code here. 
	--if player_civ == "japanese" then
		--local town_center = player.town_center.entity
		--local daimyo_pbg = BP_GetUpgradeBlueprint("upgrade_capital_tier_1_jpn")
		--Entity_CompleteUpgrade(town_center, daimyo_pbg)
	--end
	if player_civ == "japanese" or player_civ == "japanese_ha_sen" then
