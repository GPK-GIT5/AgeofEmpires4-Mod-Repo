--
-- (c) Relic Entertainment 2022
--
-----------------------------------------------------------------------

-- Register delegates
Core_RegisterModule("VizierUI")

-- Any data that needs to persist with save games should be stored here
vizierData =
{
	localPlayerVizierPoints = 0,
	localPlayerID = -1
}

-- Called by OnInit_PartB() in core.scar
function VizierUI_OnInit()	
	Rule_Add(VizierUI_Update)
end

-- Called by OnGameOver() in core.scar
function VizierUI_OnGameOver()
	Rule_Remove(VizierUI_Update)
end

-- Called once every frame.
function VizierUI_Update()
	local localPlayer = Game_GetLocalPlayer()
	local localPlayerRace = Player_GetRaceName(localPlayer)
	local localPlayerID = Player_GetID(localPlayer)
	
	if localPlayerRace ~= "ottoman" then
		vizierData.localPlayerID = localPlayerID
		return
	end
	
	-- Vizier points are the command resource
	local newVizierPoints = Player_GetResource(localPlayer, RT_Command)  
		
	-- Local player changes when switching players in replay and observer mode
	if vizierData.localPlayerID == localPlayerID and newVizierPoints > vizierData.localPlayerVizierPoints then
		Sound_Play2D("sfx_ui_vizier_point_notification")
	end
	
	vizierData.localPlayerVizierPoints = newVizierPoints
	vizierData.localPlayerID = localPlayerID
end
