villagerlife_schema =
{
    type = "Prefab",
    name = "villagerlife",
    description = "Spawns and commands villagers in a radius.",
    script = "villagerlife.scar",
    compatibility = {
        "triggerable",
    },
     
    itemSchema = {
 
        {
            type = ST_PLAYER,
            name = "player",
            displayName = "Owned by Player",
            description = "Which player owns these villagers?",
            category = "Activity",
        },
        {
            type = ST_NUMBER,
            name = "roaming_count",
            displayName = "Villagers Roaming",
            description = "The number of villagers roaming in this location",
            category = "Activity",
        },
        {
            type = ST_NUMBER,
            name = "wood_count",
            displayName = "Villagers on Wood",
            description = "The number of villagers spawned to wood at this location",
            category = "Activity",
        },
        {
            type = ST_NUMBER,
            name = "food_count",
            displayName = "Villagers on Food",
            description = "The number of villagers spawned to food at this location",
            category = "Activity",
        },
        {
            type = ST_NUMBER,
            name = "stone_count",
            displayName = "Villagers on Stone",
            description = "The number of villagers spawned to stone at this location",
            category = "Activity",
        },
        {
            type = ST_NUMBER,
            name = "gold_count",
            displayName = "Villagers on Gold",
            description = "The number of villagers spawned to wood at this location",
            category = "Activity",
        },
		{
			type = ST_STRING,
			name = "villager_response",
			displayName = "Villager Response",
			options = { "none", "flee", "attack" },
			default = "none",
			description = "How should the villagers respond when they see the player?",
			category = "Activity"
		},
		{
            type = ST_MARKER,
            name = "mkr_home",
            displayName = "Home marker",
            description = "Determines the location these villagers live",
			hasRange = true, 
			showAlways = true,
        },
		{
            type = ST_MARKER,
            name = "mkr_flee",
            displayName = "Flee marker",
            description = "Where the villagers flee when the player approaches",
            hasRange = true, 
			showAlways = true,
			requirements = {
		        "villager_response", "flee"
		    },
        },
		{
            type = ST_BOOLEAN,
            name = "b_require_garrison",
            displayName = "Require garrison?",
            description = "Villagers will only flee to the primary flee position if there is a garrisonable building nearby, otherwise they will go to the backup position.",
            category = "Flee",
			default = false,
			requirements = {
		        "villager_response", "flee"
		    },
        },
		{
            type = ST_MARKER,
            name = "mkr_flee_backup",
            displayName = "Backup flee marker",
            description = "Where the villagers flee when the player approaches, if the main flee destination has no garrisonable building nearby",
            hasRange = true, 
			showAlways = true,
			requirements = {
				operator = "ALL",
		        { "villager_response", "flee" },
				{ "b_require_garrison", true },
		    },
        },
    }
}