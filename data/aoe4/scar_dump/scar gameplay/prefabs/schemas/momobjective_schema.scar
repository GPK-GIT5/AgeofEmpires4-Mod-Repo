--
-- WorldBuilder prefab
-- "Mission-o-Matic Objective"
--

-- Schema



function PrefabSchema_ConditionList(name, description)
	
	local schema = {
		type = ST_TABLE,
		name = name,
		description = description,
		multiplicity = "multiple",
		itemSchema = {
			{
				type = ST_STRING,
				name = "condition",
				description = "Condition",
				options = {
					"Boolean",
					"AskScarFunction",
					"GameTime",
					"HasReachedAge",
					"HasResources",
					"HasBuildings",
					"HasUnits",
				},
			},
			{
				type = ST_STRING,
				name = "boolean",
				description = "Boolean",
				options = {"Any", "All", "None"},
				requirement = {"condition", "Boolean"},
			},
			{
				type = ST_STRING,
				name = "functionName",
				description = "Function Name",
				requirement = {"condition", "AskScarFunction"},
			},
			
			-- things for GAMETIME condition
			{
				type = ST_STRING,
				name = "comparison",
				description = "Comparison",
				options = PrefabSchema_ComparisonOptions(),
				requirement = {"condition", "GameTime"},
			},
			

			{
				type = ST_NUMBER,
				name = "seconds",
				description = "Seconds",
				requirement = {"condition", "GameTime"},
			},
			{
				type = ST_BOOLEAN,
				name = "sinceBookmark",
				description = "Since bookmarked time",
				requirement = {"condition", "GameTime"},
			},
			{
				type = ST_STRING,
				name = "bookmark",
				description = "Bookmark",
				requirement = {"sinceBookmark", true},
			},

		
		
		},
	}
	
	return schema
	
end 

function PrefabSchema_ComparisonOptions()
	
	local options = {
		"Is Equal",
		"Is Not Equal",
		"Is Greater Than",
		"Is Greater Than or Equal",
		"Is Less Than",
		"IS Less Than or Equal",
	}
	
	return options
	
end


momobjective_schema = {		-- schema ALWAYS named the prefab name with schema on the end
	
	type = "Prefab",
	name = "momobjective",															-- name the prefab uses to identify itself
	description = "MoM Objective",													-- name to display for this prefab
	script = "momobjective.scar",													-- script associated with this prefab, needs to be imported into the prefab data script
	proxy = "art/gameplay/designer_objects/placeholder_templates/pickup_a",			-- some identifying visual we can see in the WB - something to click on, too, in order to select the prefab
	itemSchema = {
		{	
			type = ST_STRING,
