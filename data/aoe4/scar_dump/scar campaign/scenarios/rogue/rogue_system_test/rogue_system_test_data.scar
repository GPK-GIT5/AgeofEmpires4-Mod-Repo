import("cardinal.scar")
import("rogue/rogue.scar")

function GetRecipe()
	local recipe = {
		modules = {},
		onStart = { 
			intelEvent = "", 
			expositionCamera = {}, 
			titleCard = { icon = "icons/campaign/campaign_angevin_the_conquest", location = LOC("Location, year") },
			actions = {},
		},
	}	
	return recipe
end


function RogueTest_InitChampionData()
	
	sg_roguetest1 = SGroup_CreateIfNotFound("sg_roguetest1")
	sg_roguetest2 = SGroup_CreateIfNotFound("sg_roguetest2")
	
	t_test_units = {
		{sbp = SBP.ENGLISH.UNIT_SPEARMAN_3_ENG, numSquads = 10},
		{sbp = SBP.ENGLISH.UNIT_MANATARMS_3_ENG, numSquads = 10},
		{sbp = SBP.ENGLISH.UNIT_HORSEMAN_3_ENG, numSquads = 10},
		{sbp = SBP.ENGLISH.UNIT_CROSSBOWMAN_3_ENG, numSquads = 10},
		{sbp = SBP.ENGLISH.UNIT_ARCHER_3_ENG, numSquads = 10},
	}
end

