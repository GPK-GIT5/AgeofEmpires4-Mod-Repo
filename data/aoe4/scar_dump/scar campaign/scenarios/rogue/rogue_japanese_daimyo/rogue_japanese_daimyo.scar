function SpawnSites()
	local site_pickup_markers = Table_Shuffle(AllMarkers_FromName("mkr_site_pickup", ""))
	local site_pickup_f_markers = Table_Shuffle(AllMarkers_FromName("mkr_site_pickup_f", ""))
	local site_t1_markers = Table_Shuffle(AllMarkers_FromName("mkr_site_t1", ""))
	local site_t2_markers = Table_Shuffle(AllMarkers_FromName("mkr_site_t2", ""))
	local site_t3_markers = Table_Shuffle(AllMarkers_FromName("mkr_site_t3", ""))
	
	local close_relics = 2
	local close_pickups = 5
	local close_markers_used = close_relics + close_pickups
	for i, marker in ipairs(site_pickup_markers) do
		if i <= close_relics then
			Site_CreateRelic(marker)
		elseif i <= close_markers_used then
			Site_CreatePickup(marker)
		end
	end
	
	local far_relics = 2
	local far_pickups = 10
	local far_markers_used = far_relics + far_pickups
	for i, marker in ipairs(site_pickup_f_markers) do
		if i <= far_relics then
			Site_CreateRelic(marker)
		elseif i <= close_markers_used then
			Site_CreatePickup(marker)
		end
	end
	
	local t1_as_pickup_count = 0
	local t1_markers_used = 5
	for i, marker in ipairs(site_t1_markers) do
		if i <= t1_as_pickup_count then
			Site_CreatePickup(marker)
		elseif i <= t1_markers_used then
			Site_CreateCampSmall(marker)
		end
	end
	
	local t2_markers_used = 5 
	for i, marker in ipairs(site_t2_markers) do
		if i <= t2_markers_used then
			Site_CreateCampSmall(marker)
		end
	end
	
	local t3_markers_as_large_camps = 4
	local t3_markers_used = 6
	for i, marker in ipairs(site_t3_markers) do
		if i <= t3_markers_as_large_camps then
			Site_CreateCampLarge(marker)
		elseif i <= t3_markers_used then
			Site_CreateCampSmall(marker)
		end
	end
	
	--for i, marker in ipairs(side_objective_markers) do --this table only contains unused objective markers
		--Site_CreateCampLarge(marker)
	--end
	
	local pickup_markers = AllMarkers_FromName("mkr_pickup", "")
	for _, marker in ipairs(pickup_markers) do
		local pickup_ebp = Table_GetRandomItem(pickup_ebps)
		CreateEntity(ROGUE_ENEMY_ALLY_PLAYER, pickup_ebp, marker, nil, DIRECTION_BACK)
	end
	
	local relic_markers = AllMarkers_FromName("mkr_relic", "")
	for _, marker in ipairs(relic_markers) do
		CreateEntity(nil, BP_GetEntityBlueprint("relic"), marker, nil, DIRECTION_BACK)
	end
	
	Sites_Debug()
end

function ValidateOnlyCavalry(wave_template)
	if wave_template.okay_vs_buildings_type_count == 0 then
		return false
	end
	for _, subwave_template in ipairs(wave_template.subwave_templates) do
		for _, unit_row in ipairs(subwave_template.unit_table) do
			local archtype = unit_types[unit_row.unit_name].archtype
			if archtype.name ~= "cavalry" and archtype.name ~= "siege" and archtype.name ~= "ram" then
				return false
			end
		end
	end
	return true
end

function ValidateOnlyMeleeInfantry(wave_template)
	if wave_template.okay_vs_buildings_type_count == 0 then
		return false
	end
	for _, subwave_template in ipairs(wave_template.subwave_templates) do
		for _, unit_row in ipairs(subwave_template.unit_table) do
			local unit_type = unit_types[unit_row.unit_name]
			local archtype = unit_type.archtype
			if not (archtype.name == "infantry" and (unit_type.wave_role == "tank" or unit_type.wave_role == "support")) and archtype.name ~= "siege" and archtype.name ~= "ram" then
				return false
			end
		end
	end
	return true
end

function ValidateOnlyRangedInfantry(wave_template)
	for _, subwave_template in ipairs(wave_template.subwave_templates) do
		for _, unit_row in ipairs(subwave_template.unit_table) do
			local unit_type = unit_types[unit_row.unit_name]
			local archtype = unit_type.archtype
			if not (archtype.name == "infantry" and (unit_type.wave_role == "dps" or unit_type.wave_role == "support")) and archtype.name ~= "siege" and archtype.name ~= "ram" then
				return false
			end
		end
	end
	return true
end

function ShinobiShrine()
	EGroup_SetInvulnerable(eg_shinbo_secrets, 0.2, -1)
	EGroup_SetTargetingType(eg_shinbo_secrets, Targeting_Manual)
	
	Rule_AddInterval(_monitorShinobiSecrets, 1)
	Rule_AddInterval(_monitorSecretShinobi, 1)
	
end

function _monitorShinobiSecrets()
	if eg_shinbo_secrets ~= nil and 
		EGroup_CountSpawned(eg_shinbo_secrets) > 0 then
		
		if EGroup_GetAvgHealth(eg_shinbo_secrets) >= 1 then
			Rule_RemoveMe()
			CreateUnits(ROGUE_HUMAN_PLAYERS[1], 
				{
					{sbp = SBP.JAPANESE.UNIT_SHINOBI_2_JPN, numSquads = 4},
					{sbp = SBP.JAPANESE_HA_SEN.UNIT_MONK_IKKO_3_JPN_HA_SEN, numSquads = 1},
				},
				mkr_shrinesecret)
			EventCues_CallToAction("$11270160", CTA_CELEBRATE, nil, nil, mkr_shrinesecret, 30, "icons/cta/illustrations/player_reinforcement_arrived")
			Sound_Play2D("sfx_ability_monk_conversion_cast") 
			--EGroup_SetPlayerOwner(eg_shinbo_secrets, ROGUE_PLAYER)
		end
	else
		Rule_RemoveMe()
	end
end

function _monitorSecretShinobi()
	if sg_shinobi_secrets ~= nil and
		SGroup_CountSpawned(sg_shinobi_secrets) > 0 then
		if Players_CanSeeSGroup(ROGUE_HUMAN_PLAYERS, sg_shinobi_secrets, ANY) and Players_SGroupIsOnScreen(ROGUE_HUMAN_PLAYERS, sg_shinobi_secrets, ANY, 0.99) then
			Rule_RemoveMe()
			LocalCommand_SquadPosAbility(ROGUE_NEUTRAL_PLAYER, sg_shinobi_secrets, Util_GetPosition(sg_shinobi_secrets), BP_GetAbilityBlueprint("shinobi_blink_jpn"), true, true)
			EGroup_SetPlayerOwner(eg_shinbo_secrets, ROGUE_ALLY_PLAYER)
			Rule_AddOneShot(_staySecret, 0.5)
		end
		
	else
		Rule_RemoveMe()
	end
end

function _staySecret()
	if sg_shinobi_secrets ~= nil and SGroup_CountSpawned(sg_shinobi_secrets) > 0 then
		SGroup_DestroyAllSquads(sg_shinobi_secrets)
	end
end

function Spawn_Shinobi()
	local shinobiMarkers = AllMarkers_FromName("mkr_shinobi_enemy", "")
	local unitTable = {sbp = SBP.JAPANESE.UNIT_SHINOBI_2_JPN, numSquads = 1}
	for i = 1, 3 do
		if #shinobiMarkers > 0 then
			local randomMarkerNumber = World_GetRand(1, #shinobiMarkers)
			local thisSpawn = shinobiMarkers[randomMarkerNumber]
			table.remove(shinobiMarkers, randomMarkerNumber)
			
			--local thisShinobiSgroup = CreateUnits(ROGUE_ENEMY_ALLY_PLAYER, unitTable, thisSpawn, "sg_wildshinobi_"..i, nil, mkr_wonder)
			
			local camp_army_params = {
				player = ROGUE_ENEMY_ALLY_PLAYER,
				spawn = thisSpawn,
				units = {sbp = SBP.JAPANESE.UNIT_SHINOBI_2_JPN, numSquads = 1},
				targetOrder = TARGET_ORDER_LINEAR,
				onDeathDissolve = true,
				combatRange = 20,
				leashRange = 50,
				targets = {
					Util_GetPosition(thisSpawn)
				},
			}
			local army = Army_Init(camp_army_params)
			LocalCommand_SquadEntityAbility(ROGUE_ENEMY_ALLY_PLAYER, army.sgroup, eg_player_wonder, BP_GetAbilityBlueprint("shinobi_spy_jpn"), true, true)
		end
	end
end

