import("MissionOMatic/MissionOMatic.scar")		-- this imports the Cardinal scripts as well
import("rogue/rogue.scar")
import("rogue/rogue_data.scar")

function Mission_PreInit()
	content_pack = CONTENT_PACK_ROGUE
	mission_name = "Daimyo Dynamics"
	print("------------------------------------------------------------------------")
	print("------------- "..mission_name.." - Initializing -------------")
	print("------------------------------------------------------------------------")
	rogue_wave_strength = 1.0
	WAVE_STAGING_DURATION = 1
end

function Mission_SetupPlayers()
	Rogue_SetupPlayers_A()
	
	Rogue_AddHumanPlayer(1, COLOR_BLUE)
	Rogue_AddEnemyWavePlayer(2,  "$11266161", COLOR_RED)   -- Sengoku Daimyo
	Rogue_AddAllyPlayer(3, 	     "$11096698", COLOR_YELLOW)-- Allies
	Rogue_AddEnemyAllyPlayer(4,  "$11266161", COLOR_RED)   -- Sengoku Daimyo
	Rogue_AddEnemyRaiderPlayer(5,"$11266161", COLOR_ORANGE)-- Sengoku Daimyo
	Rogue_AddNeutralPlayer(6,    "$11096698", COLOR_YELLOW)-- Allies
	
	Rogue_SetupPlayers_B()
end

function Mission_Preset()	
	t_resourcePickupLocations = AllMarkers_FromName("mkr_resource_pickup", "")
	Daimyo_SpawnPickups(t_resourcePickupLocations)

	Rogue_AddLane("north", false, ValidateOnlyRangedInfantry, SBP.ROGUE.UNIT_ODA_NOBUNAGA_BOSS_ROGUE)
	Rogue_AddLane("east", true, ValidateOnlyMeleeInfantry, SBP.ROGUE.UNIT_HOJO_UJINAO_BOSS_ROGUE)
	Rogue_AddLane("west", true, ValidateOnlyCavalry, SBP.ROGUE.UNIT_TAKEDA_SHINGEN_BOSS_ROGUE)
	
	--roamer_override_type = "shinobi"
	roamer_override_sbp = SBP.JAPANESE.UNIT_SHINOBI_2_JPN
	roamer_value_increment = GetIntegerInExponentialRange(15, 60)
	
	Rogue_UseDefaultSchedule(true, true, 0.8)
	Sites_Init("archer", "manatarms", "handcannon")
	SpawnSites()
	
	Rogue_SimulateEvents()
	for _, player in ipairs(ROGUE_HUMAN_PLAYERS) do
		Objective_Register(OBJ_DESTROY_BUILDINGS, player)
	end
	table.insert(chosen_objectives, OBJ_DESTROY_BUILDINGS)
	
	ResourceSpots_InitData({40,60,20,20,25,10,0})
	ResourceSpots_Init("mkr_gaia", "gaia", 10)
	
	local wolf_spawn_chance = Rogue_DifVar({0,0,10,35,50,65,80,100})
	
	if wolf_spawn_chance > 0 then
		ResourceSpots_SpawnWolves("mkr_wolf", wolf_spawn_chance, 10)
	end
	
	Spawn_Shinobi()
	
	Daimyo_InitUniquePOIs()
	
	-- Points of interest
	local t_unit_types_jpn = {
		{sbp = BP_GetSquadBlueprint("unit_militia_rogue_jpn"), value = 60, tier = 1},
		{sbp = SBP.JAPANESE_HA_SEN.UNIT_KANABO_2_JPN_HA_SEN, value = 155, tier = 1},
		{sbp = SBP.JAPANESE_HA_SEN.UNIT_ARCHER_2_JPN_HA_SEN, value = 65, tier = 1},
		{sbp = SBP.JAPANESE_HA_SEN.UNIT_SPEARMAN_2_JPN_HA_SEN, value = 80, tier = 1},
		{sbp = SBP.JAPANESE_HA_SEN.UNIT_KANABO_3_JPN_HA_SEN, value = 160, tier = 2},
		{sbp = SBP.JAPANESE_HA_SEN.UNIT_SAMURAI_3_JPN_HA_SEN, value = 120, tier = 2},
		{sbp = SBP.JAPANESE_HA_SEN.UNIT_HANDCANNON_3_JPN_HA_SEN, value = 180, tier = 2},
	}
	
	Rogue_POI_SetRadii("mkr_poi_t1")
	Rogue_POI_SetRadii("mkr_poi_t2")
	Rogue_POI_SetRadii("mkr_poi_def")
	
	Rogue_POI_Init(ROGUE_ENEMY_ALLY_PLAYER, t_unit_types_jpn, daimyoExtraPOIS)
	
	-- Defensive points of interest
	Rogue_POI_Spawn("mkr_poi_def", t_poi_types_def, 1, 2)
end

function Mission_PreStart()
	EGroup_SetInvulnerable(eg_destroy_obj_exclude, true)
	EGroup_SetTargetingType(eg_destroy_obj_exclude, Targeting_None)
	
	EGroup_SetInvulnerable(eg_dressing, true)
	EGroup_SetTargetingType(eg_dressing, Targeting_None)
		
	Game_TransitionToState("dawn", 0)
end

function Mission_Start()	-- this is triggered after the intro, just as control is passed to the player	
	Rogue_SetupPlayers_C()
	ShinobiShrine()
end

-- triggered when the player selects the first boon and gameplay actually begins
function Mission_Unpause()
	Rule_AddOneShot(_Atmo_TransitionTo, 60, {AtmoName = "day"})
	Rule_AddOneShot(_Atmo_TransitionTo, 1440, {AtmoName = "dusk"})
	Rule_AddOneShot(_Atmo_TransitionTo, 2040, {AtmoName = "night"})
	Rule_AddOneShot(_Atmo_TransitionTo, 2640, {AtmoName = "dawn"})
	
end

function Daimyo_SpawnPickups(markerTable)
	for i, marker in ipairs(markerTable) do
		local thisPickupBP = Table_GetRandomItem({
				BP_GetEntityBlueprint("resource_pickup_food_rogue"),
				BP_GetEntityBlueprint("resource_pickup_gold_rogue"),
				BP_GetEntityBlueprint("resource_pickup_stone_rogue"),
				BP_GetEntityBlueprint("resource_pickup_wood_rogue"),
			}, 1)
		CreateEntity(ROGUE_ENEMY_WAVE_PLAYER, thisPickupBP, marker, nil, World_Pos(0, 0, 1), nil, false)
	end
end

function Daimyo_InitUniquePOIs()
	
	daimyoExtraPOIS = 
	{
		{
			name = "poi_abandonedvillage",
			title = "$11270161", --Abandoned Village
			ebp = BP_GetEntityBlueprint("rogue_poi_abandoned_village_01"),
			ebp_pickup = nil,
			rand_pickups = true,
			reward_value = 600,
			tier = 1,
			is_available = true,
			force_spawn = false,
			weight = 10,
			customLiberationFunc = TrackAbandonedVillageCompletion,
			customInitFunc = InitAbandonedVillage
		},
	}

end

function InitAbandonedVillage(poi_instance)
	
		--local poi_instance = {
			--index = poi_count,
			--type_name = type_data.name,
			--is_discovered = false,
			--is_liberated = false,
			--weapon_disabled = false,
			--marker = poi_marker,
			--title = type_data.title,
			--hpid_title = nil,
			--eg_outposts = EGroup_CreateUniqueWithPrefix("eg_poi_outposts"),
			--eg_ally = EGroup_CreateUniqueWithPrefix("eg_poi_ally"),
			--sg_ally = SGroup_CreateUniqueWithPrefix("sg_poi_ally"),
			--sg_enemy = SGroup_CreateUniqueWithPrefix("sg_poi_enemy"),
		--}
	
	HintPoint_SetVisible(121, true)
	
	poi_instance.eg_houses_here = EGroup_CreateUnique("eg_houses_here")
	World_GetAllEntitiesOfType(poi_instance.eg_houses_here, "house")
	EGroup_FilterByProximity(poi_instance.eg_houses_here, poi_instance.marker, 21, FILTER_KEEP)
	
	EGroup_SetPlayerOwner(poi_instance.eg_houses_here, ROGUE_NEUTRAL_PLAYER)
	EGroup_SetTargetingType(poi_instance.eg_houses_here, Targeting_None)
	EGroup_SetAvgHealth(poi_instance.eg_houses_here, 0.30)
	EGroup_SetInvulnerable(poi_instance.eg_houses_here, true, -1)
	
	poi_instance.trapSprung = false
	
	local reward_value = poi_instance.type_data.reward_value
	local unitBudget = GetIntegerInExponentialRange((reward_value * 0.75), (reward_value * 1.5))
		
	local total_cost = 0
	local cost = Player_GetSquadBPCost(ROGUE_ENEMY_ALLY_PLAYER, SBP.JAPANESE.UNIT_SHINOBI_2_JPN)
	total_cost = cost.food + cost.wood + cost.gold + cost.stone
	poi_instance.unitAmount = math.ceil(unitBudget / total_cost)
	
	Rule_AddInterval(_trackAbandonedVillageTrap, 0.5, {poi_instance = poi_instance})
	
end

function TrackAbandonedVillageCompletion(poi_instance)
	if poi_instance.trapSprung and SGroup_CountSpawned(poi_instance.shinobiSgroup) < 1 and EGroup_CountSpawned(poi_instance.eg_pickups) < 1 then
		return true
	end
end

function _trackAbandonedVillageTrap(context, data)
	local poi_instance = data.poi_instance
	SGroup_Clear(sg_temp)
	Players_GetAllSquadsNearMarker(ROGUE_HUMAN_PLAYERS, sg_temp, Util_GetPosition(poi_instance.marker), 5)
	if SGroup_CountSpawned(sg_temp) > 0 then
		Rule_RemoveMe()
		
		poi_instance.shinobiSgroup = SGroup_CreateUnique("sg_av_shinobi")
		poi_instance.victimSgroup = SGroup_CreateUnique("sg_av_victims")
		SGroup_AddGroup(poi_instance.victimSgroup, sg_temp)
		
		for i = 1, poi_instance.unitAmount do
			local spawnHouse = EGroup_GetRandomSpawnedEntity(poi_instance.eg_houses_here)
			CreateUnits(ROGUE_ENEMY_ALLY_PLAYER, {sbp = SBP.JAPANESE.UNIT_SHINOBI_2_JPN, numSquads = 1}, Util_GetPosition(spawnHouse), poi_instance.shinobiSgroup)
		end
		LocalCommand_SquadPosAbility(ROGUE_ENEMY_ALLY_PLAYER, poi_instance.shinobiSgroup, Util_GetPosition(poi_instance.marker), BP_GetAbilityBlueprint("shinobi_blink_jpn"), true, true)
		local camp_army_params = {
			player = ROGUE_ENEMY_ALLY_PLAYER,
			spawn = poi_instance.marker,
			targetOrder = TARGET_ORDER_LINEAR,
			--onCompleteFunction = _UpdateShinobiTargets,
			onDeathDissolve = true,
			victims = poi_instance.victimSgroup,
			targets = {
				Util_GetPosition(poi_instance.victimSgroup)
			},
		}
		local army = Army_Init(camp_army_params)
		Army_AddSGroup(army, poi_instance.shinobiSgroup)
		
		Modify_UnitSpeed(poi_instance.shinobiSgroup, 2, -1, MUT_Multiplication)
		
		Modifier_RemoveAllFromEGroup(poi_instance.eg_houses_here)
		EGroup_SetPlayerOwner(poi_instance.eg_houses_here, ROGUE_ENEMY_ALLY_PLAYER)
		EGroup_SetTargetingType(poi_instance.eg_houses_here, Targeting_Automatic)
		EGroup_SetInvulnerable(poi_instance.eg_houses_here, false)
		
		poi_instance.trapSprung = true
	end
	
end

function _UpdateShinobiTargets(army)
	if SGroup_CountSpawned(army.sgroup) > 0 then
		if army.victims ~= nil and SGroup_CountSpawned(army.victims) > 0 then
			Army_SetTarget(army, Util_GetPosition(SGroup_GetSquadAt(army.victims, 1)))
		else
			Army_SetTarget(army, army.spawn)
		end
	else
		return
	end
end

