--
-- York 1069 - Strengthen
--


function Strengthen_InitObjectives()
	
	--OBJ_BuildStable = {
		--Title = "$11172046", -- Build a Stable to produce Horsemen
		--Type = ObjectiveType_Build,
		--Intel_Start = EVENTS.BuildUpForcesStart,
		--Intel_Complete = EVENTS.BuildUpForcesComplete,
		--PreStart = function()
			--Util_AutoSave()
		--end,
		--OnStart = function()
			--TrainingGoal_AddBuildWonder()
			--Rule_AddOneShot(York_StartCheckInitDaneRaid, 90)
			--Rule_AddOneShot(TrainingGoal_EnableBuildLandmark, 180)
		--end,
		--IsComplete = function()
			--return g_stableBuilt
		--end,
		--OnComplete = function()
			--York_SpawnReinforcements(player_reinforcements2, sg_norman_allies2, mkr_reinforce_spawn2, mkr_fulford_reinforce_dest, EVENTS.Fulford_Reinforcements)
		--end,
	--}
	
	OBJ_BuildSupport = {
		Title = "$11201298", -- Build up support for your army
		Type = ObjectiveType_Build,
		PreStart = function()
			Util_AutoSave()
		end,
		OnStart = function()
			Objective_Start(SOBJ_GatherResourcesForLandmark, false)
			Objective_Start(SOBJ_BuildLandmark, false)
			Objective_Start(SOBJ_BuildStable, false)
		end,
		IsComplete = function()
			if Objective_IsComplete(SOBJ_GatherResourcesForLandmark) and g_landmarkBuilt and g_stableBuilt then
				return true
			end
			return false
		end,
	}
	
	SOBJ_GatherResourcesForLandmark = {
		Title = "$11201343", -- Gather Food and Gold to construct a Landmark
		Type = ObjectiveType_Build,
		Parent = OBJ_BuildSupport,
		IsComplete = function()
			if Player_GetResource(player1, RT_Food) >= 400 and Player_GetResource(player1, RT_Gold) >= 200 then
				return true
			end
			return false
		end,
	}
	SOBJ_BuildLandmark = {
		Title = "$11201299", -- Construct a Landmark to advance to the Feudal Age
		Type = ObjectiveType_Build,
		Parent = OBJ_BuildSupport,
		IsComplete = function()
			return g_landmarkBuilt
		end,
	}
	SOBJ_BuildStable = {
		Title = "$11172046", -- Build a Stable to produce Horsemen
		Type = ObjectiveType_Build,
		Parent = OBJ_BuildSupport,
		Intel_Start = EVENTS.BuildUpForcesStart,
		--Intel_Complete = EVENTS.BuildUpForcesComplete,
		OnStart = function()
			
			if UI_IsXboxControllerUI() then
				TrainingGoal_AddBuildWonder_Xbox()
			else
				TrainingGoal_AddBuildWonder()
			end
			
			Rule_AddOneShot(York_StartCheckInitDaneRaid, 90)
			Rule_AddOneShot(TrainingGoal_EnableBuildLandmark, 180)
		end,
		IsComplete = function()
			return g_stableBuilt
		end,
		OnComplete = function()
			Util_StartIntel(EVENTS["BuildUpForcesComplete"])
			York_SpawnReinforcements(player_reinforcements2, sg_norman_allies2, mkr_reinforce_spawn2, mkr_fulford_reinforce_dest, EVENTS.Fulford_Reinforcements)
		end,
	}
	
	--Objective_Register(OBJ_BuildStable)
	Objective_Register(OBJ_BuildSupport)
	
	Objective_Register(SOBJ_GatherResourcesForLandmark)
	Objective_Register(SOBJ_BuildLandmark)
	Objective_Register(SOBJ_BuildStable)

end





