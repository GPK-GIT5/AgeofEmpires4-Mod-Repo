function TrainingGoal_EnableBuildLandmark()
	Training_EnableGoalSequenceByID(goal_sequence_build_landmark, true)
end

function TrainingGoal_EnableBuildPalisade()
	Training_EnableGoalSequenceByID(goal_sequence_build_palisade, true)
end

function TrainingGoal_DisableBuildPalisade()
	Training_EnableGoalSequenceByID(goal_sequence_build_palisade, false)
end

function TrainingGoal_EnableBuildBarracks()
	Training_EnableGoalSequenceByID(goal_sequence_build_barracks, true)
end

function TrainingGoal_DisableBuildBarracks()
	Training_EnableGoalSequenceByID(goal_sequence_build_barracks, false)
end

function UserHasOpenedTheDiplomacyMenu()
	if not _userHasOpenedDiplomacyMenu and _diplomacy ~= nil and _diplomacy.data_context ~= nil then
		_userHasOpenedDiplomacyMenu = _diplomacy.data_context.is_ui_expanded
	end	
	return _userHasOpenedDiplomacyMenu
end

function ShouldPromptUserToSendGold(goalSequence)
	if _diplomacy ~= nil and _diplomacy.data_context ~= nil then
		
		if _diplomacy.data_context.is_ui_visible then
			if not UserHasOpenedTheDiplomacyMenu() then
				
				local localPlayer = Game_GetLocalPlayer()
				if Player_GetResource(localPlayer, RT_Gold) >= 100 then
					return true
				end
			end
		end
	end
	return false
end

function TrainingGoal_AddSendGold()
	local send_gold_goal = Training_Goal("DiplomacyButton",
		{Message = UI_PickIDForInputMode(11189533, 11248588), DataTemplate="GenericTrainingDataTemplate"}, 
		UserHasOpenedTheDiplomacyMenu)
	local send_gold_sequence = Training_GoalSequence(goal_sequence_send_gold,
		1, 0, 
		ShouldPromptUserToSendGold, 
		CampaignTraining_TimeoutIgnorePredicate, 
		nil, 
		UserHasOpenedTheDiplomacyMenu, 
		true, 
		{send_gold_goal})
	Training_AddGoalSequence(send_gold_sequence)
end

function TrainingGoal_EnableSendGold()
	Training_EnableGoalSequenceByID(goal_sequence_send_gold, true)
end

function TrainingGoal_DisableSendGold()
	Training_EnableGoalSequenceByID(goal_sequence_send_gold, false)
end
