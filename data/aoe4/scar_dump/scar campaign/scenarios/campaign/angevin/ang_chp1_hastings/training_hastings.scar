local goal_sequence_leaderability = "campaign_ang_chp1_hastings_leader_ability"
local goal_sequence_leaderrevive = "campaign_ang_chp1_hastings_leader_revive"
local goal_sequence_select_all = "campaign_ang_chp1_hastings_select_all"
local goal_sequence_archers = "campaign_ang_chp1_hastings_archers"
local goal_sequence_archers_attackmove = "campaign_ang_chp1_hastings_archers_attackmove"
local goal_sequence_enemy_spearmen = "campaign_ang_chp1_hastings_enemy_spearmen"
local goal_sequence_cavalry = "campaign_ang_chp1_hastings_cavalry"


