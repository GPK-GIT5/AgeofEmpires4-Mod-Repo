import("MissionOMatic/MissionOMatic.scar")		-- this imports the Cardinal scripts as well

import("ShieldWall_Hastings.scar")
import("Training_Hastings.scar")

import("obj_InitialAttack.scar")
import("obj_Feign.scar")
import("obj_DefeatSaxons.scar")
import("obj_KillHarold.scar")


function Mission_SetupPlayers()

	--
	-- get player IDs for each player
	-- 
	
	player1 = World_GetPlayerAt(1) -- William
	player2 = World_GetPlayerAt(2) -- Harold
	player3 = World_GetPlayerAt(3) -- William (Holding player - neutral)
	player4 = World_GetPlayerAt(4) -- William (Downed state)
	
	
	-- player 1 - William
	Setup_SetPlayerName(player1, "$11181626") -- Duke William
	Player_SetCurrentAge(player1, AGE_DARK)
	Player_SetMaximumAge(player1, AGE_DARK)

	-- player 2 - Harold	
	Setup_SetPlayerName(player2, "$11181627") -- King Harold
	Player_SetCurrentAge(player2, AGE_DARK)
	Player_SetMaximumAge(player2, AGE_DARK)

	-- player 3 - Neutral (holding player for William units)
	Setup_SetPlayerName(player3, "$11181626") -- Duke William
	Player_SetCurrentAge(player3, AGE_DARK)
	Player_SetMaximumAge(player3, AGE_DARK)

	-- player 4 - William (Downed state)
	Setup_SetPlayerName(player4, "$11181626") -- Duke William
	Player_SetCurrentAge(player4, AGE_DARK)
	Player_SetMaximumAge(player4, AGE_DARK)

	
	
	
	--
	-- set player relationships	
	--
	
	Player_SetRelationship(player1, player2, R_ENEMY)	-- player 1 - William
	Player_SetRelationship(player1, player3, R_NEUTRAL)
	Player_SetRelationship(player1, player4, R_ALLY)
	
	Player_SetRelationship(player2, player1, R_ENEMY)	-- player 2 - Harold	
	Player_SetRelationship(player2, player3, R_NEUTRAL)
	Player_SetRelationship(player2, player4, R_NEUTRAL)
	
	Player_SetRelationship(player3, player1, R_NEUTRAL)	-- player 3 - Neutral (holding player for William units)
	Player_SetRelationship(player3, player2, R_NEUTRAL)
	Player_SetRelationship(player3, player4, R_NEUTRAL)
	
	Player_SetRelationship(player4, player1, R_ALLY)	-- player 4 - William (Downed state)
	Player_SetRelationship(player4, player2, R_NEUTRAL)
	Player_SetRelationship(player4, player3, R_NEUTRAL)
	
	World_EnableSharedLineOfSight(player1, player3, false)	-- may also have to configure shared line of sight
	World_EnableSharedLineOfSight(player1, player4, false)
	
	
	--
	-- set player colours
	--
	
	PlayerColour_Enable()							-- turn on custom colour configuration for this session
	
	Game_SetPlayerSlotColour(player1, 1) 			-- William	(paint scheme)						(1 = blue - colour indexes specified in AE tuning_simulation -> ui/ui_player_colours)
	Game_SetPlayerUISlotColour(player1, 1)			--			(ui colour)
	
	Game_SetPlayerSlotColour(player2, 2) 			-- Harold										(2 = red)
	Game_SetPlayerUISlotColour(player2, 2)

	Game_SetPlayerSlotColour(player3, 9) 			-- Neutral (holding player for William units)	(9 = grey)
	Game_SetPlayerUISlotColour(player3, 9)
	
	Game_SetPlayerSlotColour(player4, 9) 			-- William (Downed state)						(9 = grey)
	Game_SetPlayerUISlotColour(player4, 9)

	
	--
	-- Turn off AI for downed leader player 
	--
	
	AI_Enable(player4, false)
	
end

