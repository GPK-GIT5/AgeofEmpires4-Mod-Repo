function Mission_SetDifficulty()
		
	t_difficulty = {
		
		-- general 
		enableLimitedReinforcements = Util_DifVar({false, true, true, true}),		-- whether reinforcements are limited or not for this difficulty mode
		maximumNumberOfReinforcements = Util_DifVar({-1, 35, 20, 10}),				-- how many reinforcement waves you can get
		
		-- william attackers
		maxNumberOfWilliamAttackers = Util_DifVar({2, 2, 3, 4}),					-- how many units can target william at once (this will potentially change after he's downed)
		
	}	
	

	
end



function Mission_Preset()
	
	DefeatSaxons_InitReinforcementCounterObjective()
	
	InitialAttack_InitObjectives()
	Feign_InitObjectives()
	DefeatSaxons_InitObjectives()
	KillHarold_InitObjectives()	
	
	
	Camera_SetDefaultOrbit(180)			-- set the custom orbit for this mission
	Camera_ResetOrbit()
	
	shieldWall_unitKillCount = 0
	
	-- make neutral units non-selectable
	Player_GetAll(player3)
	Misc_SetSGroupSelectable(sg_allsquads, false)
	
	--We're not using the upgrade wrapper, but still need to apply special health bonuses
	PlayerUpgrades_ApplyHealthBonuses(player1)
	PlayerUpgrades_ApplyHealthBonuses(player3)
	
	-- modify archer ranges on both sides	
	modid_playerArcherRange = Modify_WeaponRange(sg_archers, "hardpoint_01", 0.01)						-- make player archers inert (will be changed to reach the shield wall when the attack launches)
	modid_enemyArcherRange = Modify_WeaponRange(sg_saxons_phase5_all, "hardpoint_01", 0.01)				-- make the enemy archers inert

	-- make william tougher in the inital attack	
	modid_williamReducedDamage = Modify_ReceivedDamage(sg_dukewilliam, 0.4)								-- we don't want william being downed until after the feign, ideally

	-- make the enemy units waiting to enter the battle benign (non-targetable and non-selectable)
	SGroup_SetTargetingType(sg_saxons_phase3_all, Targeting_Manual)
	SGroup_SetTargetingType(sg_saxons_phase4_all, Targeting_Manual)
	SGroup_SetTargetingType(sg_saxons_phase5_all, Targeting_Manual)
	
	Misc_SetSGroupSelectable(sg_saxons_phase3_all, false)
	Misc_SetSGroupSelectable(sg_saxons_phase4_all, false)
	Misc_SetSGroupSelectable(sg_saxons_phase5_all, false)

	-- do the same for tents on the top of the hill 
	EGroup_SetTargetingType(eg_saxonTents, Targeting_Manual)
	Misc_SetEGroupSelectable(eg_saxonTents, false)
	

	EGroup_DestroyAllEntities(eg_blockers_shieldwall_a)
	EGroup_DestroyAllEntities(eg_blockers_shieldwall_b)
	EGroup_DestroyAllEntities(eg_blockers_shieldwall_c)
	
	Rule_AddOneShot(Mission_Preset_PartB, 0.125)	
	
end
function Mission_Preset_PartB()
	
	-- no-build mission, zero out resources and turn off the popcap
	Player_SetResource(player1, RT_Food, 0)
	Player_SetResource(player1, RT_Wood, 0)
	Player_SetResource(player1, RT_Stone, 0)
	Player_SetResource(player1, RT_Gold, 0)
	UI_SetPlayerDataContext(player1, { PopulationCapOn = false })
	
	-- set up the shield walls
	wallid_a = ShieldWall_Create(mkr_shieldwall_a1, mkr_shieldwall_a2, sg_shieldwall_a, {nil, sg_shieldwall_a_spearmen}, true, "Wall A")
	wallid_b = ShieldWall_Create(mkr_shieldwall_b1, mkr_shieldwall_b2, sg_shieldwall_b, {nil, sg_shieldwall_b_spearmen}, true, "Wall B")
	wallid_c = ShieldWall_Create(mkr_shieldwall_c1, mkr_shieldwall_c2, sg_shieldwall_c, {nil, sg_shieldwall_c_spearmen}, true, "Wall C")

	wallid_a.callbacks = {onUnitKilled = InitialAttack_ShieldWallUnitKilled}
	wallid_b.callbacks = {onUnitKilled = InitialAttack_ShieldWallUnitKilled}
	wallid_c.callbacks = {onUnitKilled = InitialAttack_ShieldWallUnitKilled}

	-- post-spawn, move units into positions that form nice organized lines
	Hastings_SpreadUnitsAlongSpline(sg_william_left_firstline_a, AllMarkers_FromName("mkr_william_left_firstline_a", ""), mkr_william_circumference, sg_william_left_firstline_cavalry)
	Hastings_SpreadUnitsAlongSpline(sg_william_left_firstline_b, AllMarkers_FromName("mkr_william_left_firstline_b", ""), mkr_william_circumference)
	Hastings_SpreadUnitsAlongSpline(sg_william_left_secondline, AllMarkers_FromName("mkr_william_left_secondline", ""), mkr_william_circumference)	

	Hastings_SpreadUnitsAlongSpline(sg_william_center_firstline_a1, AllMarkers_FromName("mkr_william_center_firstline_a1", ""), mkr_william_circumference, sg_william_center_firstline_cavalry1)	
	Hastings_SpreadUnitsAlongSpline(sg_william_center_firstline_a2, AllMarkers_FromName("mkr_william_center_firstline_a2", ""), mkr_william_circumference, sg_william_center_firstline_cavalry2)	
	Hastings_SpreadUnitsAlongSpline(sg_william_center_firstline_b, AllMarkers_FromName("mkr_william_center_firstline_b", ""), mkr_william_circumference)	
	Hastings_SpreadUnitsAlongSpline(sg_william_center_secondline, AllMarkers_FromName("mkr_william_center_secondline", ""), mkr_william_circumference)	
	
	Hastings_SpreadUnitsAlongSpline(sg_william_right_firstline_a, AllMarkers_FromName("mkr_william_right_firstline_a", ""), mkr_william_circumference, sg_william_right_firstline_cavalry)
	Hastings_SpreadUnitsAlongSpline(sg_william_right_firstline_b, AllMarkers_FromName("mkr_william_right_firstline_b", ""), mkr_william_circumference)
	Hastings_SpreadUnitsAlongSpline(sg_william_right_secondline, AllMarkers_FromName("mkr_william_right_secondline", ""), mkr_william_circumference)	
	
	Hastings_SpreadUnitsAlongSpline(sg_archers_left1, AllMarkers_FromName("mkr_william_left_archers1", ""), mkr_william_circumference, nil, true)	
	Hastings_SpreadUnitsAlongSpline(sg_archers_center1, AllMarkers_FromName("mkr_william_center_archers1", ""), mkr_william_circumference, nil, true)	
	Hastings_SpreadUnitsAlongSpline(sg_archers_center2, AllMarkers_FromName("mkr_william_center_archers2", ""), mkr_william_circumference, nil, true)	
	Hastings_SpreadUnitsAlongSpline(sg_archers_right1, AllMarkers_FromName("mkr_william_right_archers1", ""), mkr_william_circumference, nil, true)	
	
	Hastings_SpreadUnitsAlongSpline(sg_cavalry_left1, AllMarkers_FromName("mkr_william_left_cavalry1", ""), mkr_william_circumference)	
	Hastings_SpreadUnitsAlongSpline(sg_cavalry_center1, AllMarkers_FromName("mkr_william_center_cavalry1", ""), mkr_william_circumference)	
	Hastings_SpreadUnitsAlongSpline(sg_cavalry_center2, AllMarkers_FromName("mkr_william_center_cavalry2", ""), mkr_william_circumference)	
	Hastings_SpreadUnitsAlongSpline(sg_cavalry_right1, AllMarkers_FromName("mkr_william_right_cavalry1", ""), mkr_william_circumference)	
	
end


function Mission_Start()
	
	-- if on Xbox restore everything except resource bar and the VPS
	Cardinal_EnablePartialXboxUI(true, {VF_XboxUIResourceCard, VF_XboxUIVillagerPriorities})

	DefendHillLeft = MissionOMatic_FindModule("DefendHillLeft")
	DefendHillCenter = MissionOMatic_FindModule("DefendHillCenter")
	DefendHillRight = MissionOMatic_FindModule("DefendHillRight")
	
	MissionTutorial_Init()	
	
	Objective_Start(OBJ_DefeatSaxons)	

	Game_TransitionToState("morning", 10)
	Rule_AddOneShot(Mission_Start_PartB, 15)

	Rule_AddInterval(Mission_CheckForFail, 1)
	
	Cmd_HoldPosition(sg_saxons_phase2_all)
	
end
function Mission_Start_PartB()

	Game_TransitionToState("daytime", 10*60)

end



function Mission_CheckForFail()
	
	if t_difficulty.enableLimitedReinforcements == false or Objective_IsComplete(OBJ_KillHarold) then 
		
		Rule_RemoveMe()
		
	else
		
		if b_playerReinforcementsStopped == true then 
			
			
			local count = 0

			Player_GetAll(player1)
			count = count + SGroup_CountSpawned(sg_allsquads)

			--Player_GetAll(player3)
			--count = count + SGroup_CountSpawned(sg_allsquads)
			
			if count == 0 then 
				
				Mission_Fail()
				
			end
			
		end		
		
	end
	
end





