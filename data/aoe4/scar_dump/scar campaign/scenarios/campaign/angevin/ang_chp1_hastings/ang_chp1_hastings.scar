function Hastings_PassControlOfUnitsToPlayer(item, options)
	
	if scartype(item) == ST_SQUAD then
		
		local sgroup = SGroup_CreateUnique("")			-- just put it in a temp sgroup and call the function again!
		SGroup_Add(sgroup, item)
		Hastings_PassControlOfUnitsToPlayer(sgroup, options)
		SGroup_Destroy(sgroup)
		
	elseif scartype(item) == ST_SGROUP then
		
		SGroup_SetPlayerOwner(item, player1)			-- pass control to the player	
		Misc_SetSGroupSelectable(item, true)			-- make the unit selectable again
		
		-- TODO: Trigger some FX?
		
		if scartype(options) == ST_TABLE then 

			if options.destination ~= nil then 
				Cmd_FormationMove(item, options.destination, nil, nil, options.facing)
			end
			
		end
		
	end 
	
end




function Mission_PrepOutro()
	
	Prefab_DoAction(MissionOMatic_FindModule("DefendHaroldLeft"), "Stop")
	Prefab_DoAction(MissionOMatic_FindModule("DefendHaroldCenter"), "Stop")
	Prefab_DoAction(MissionOMatic_FindModule("DefendHaroldRight"), "Stop")
	Prefab_DoAction(MissionOMatic_FindModule("DefendHillLeft"), "Stop")
	Prefab_DoAction(MissionOMatic_FindModule("DefendHillCenter"), "Stop")
	Prefab_DoAction(MissionOMatic_FindModule("DefendHillRight"), "Stop")
	Prefab_DoAction(MissionOMatic_FindModule("KingHaroldDefenders1"), "Stop")
	Prefab_DoAction(MissionOMatic_FindModule("KingHaroldDefenders2"), "Stop")
	Prefab_DoAction(MissionOMatic_FindModule("KingHaroldDefenders3"), "Stop")
	Prefab_DoAction(MissionOMatic_FindModule("KingHaroldDefenders4"), "Stop")
	Prefab_DoAction(MissionOMatic_FindModule("ReinforcementsHaroldLeft"), "Stop")
	Prefab_DoAction(MissionOMatic_FindModule("ReinforcementsHaroldCenter"), "Stop")
	Prefab_DoAction(MissionOMatic_FindModule("ReinforcementsHaroldRight"), "Stop")
	
	
	-- remove ALL existing units	
	for index, player in pairs(PLAYERS) do 
		Player_GetAll(player.id)
		SGroup_DestroyAllSquads(sg_allsquads)
	end	
	
	-- spawn outro units
	local units = {
		{sbp = SBP.ENGLISH.UNIT_SHIELDWALL_HASTINGS_CMP_ENG, numSquads = 4, spawn = mkr_outro_retreatspawn1, destination = mkr_harold_reinforce},
		{type = "scar_manatarms", numSquads = 3, spawn = mkr_outro_retreatspawn2, destination = mkr_harold_reinforce},
		{sbp = SBP.ENGLISH.UNIT_SHIELDWALL_HASTINGS_CMP_ENG, numSquads = 4, spawn = mkr_outro_retreatspawn3, destination = mkr_harold_reinforce_right},
		{type = "scar_spearman", numSquads = 3, spawn = mkr_outro_retreatspawn4, destination = mkr_harold_reinforce_right},
		{sbp = SBP.ENGLISH.UNIT_SHIELDWALL_HASTINGS_CMP_ENG, numSquads = 3, spawn = mkr_outro_retreatspawn5, destination = mkr_harold_reinforce},
		{sbp = SBP.ENGLISH.UNIT_SHIELDWALL_HASTINGS_CMP_ENG, numSquads = 2, spawn = mkr_outro_retreatspawn6, destination = mkr_harold_reinforce},
		{type = "scar_spearman", numSquads = 4, spawn = mkr_outro_retreatspawn7, destination = mkr_harold_reinforce_right},
		{type = "scar_manatarms", numSquads = 2, spawn = mkr_outro_retreatspawn8, destination = mkr_harold_reinforce_right},
		{sbp = SBP.ENGLISH.UNIT_SHIELDWALL_HASTINGS_CMP_ENG, numSquads = 4, spawn = mkr_outro_retreatspawn9, destination = mkr_harold_reinforce},
		{type = "scar_manatarms", numSquads = 2, spawn = mkr_outro_retreatspawn10, destination = mkr_harold_reinforce},
	}
	UnitEntry_DeploySquads(player2, sg_outro_saxons, units)
	
	--Rule_AddOneShot(Hastings_MoveHarold, 2)
	Hastings_MoveHarold()
	--Hastings_ClearGameplayCorpses()
	-- corspe field
	local fyrd  = BP_GetSquadBlueprint("unit_shieldwall_hastings_cmp_eng_infinite_corpse")
	local spear = BP_GetSquadBlueprint("unit_spearman_2_eng_infinite_corpse")

	local corpses = {
		{sbp = spear, numSquads = 10, spawn = mkr_hill_top_center, rad_max = 20, rad_min = 3},
		{sbp = fyrd , numSquads = 10, spawn = mkr_hill_top_center, rad_max = 20, rad_min = 3},
		{sbp = spear, numSquads = 10, spawn = mkr_hill_top_right, rad_max = 20, rad_min = 3},
		{sbp = fyrd , numSquads = 10, spawn = mkr_hill_top_right, rad_max = 20, rad_min = 3},
		{sbp = spear, numSquads = 10, spawn = mkr_kingharold_defend, rad_max = 20, rad_min = 3},
		{sbp = fyrd , numSquads = 10, spawn = mkr_kingharold_defend, rad_max = 20, rad_min = 3},
	}
	
	Util_CorpseField(corpses, mkr_hill_top_center, mkr_outro_kingharold)

	SGroup_Clear(sg_cheering_a)
	
	local pos = Marker_GetPosition(mkr_outro_kingharold)
	
	local outro_normans = {
		{type = "scar_manatarms", spawn = mkr_outro_normans1a, facing = pos},
		{type = "scar_manatarms", spawn = mkr_outro_normans1b, facing = pos},
		{type = "scar_manatarms", spawn = mkr_outro_normans1c, facing = pos},
		{type = "scar_archer", numSquads = 3, spawn = mkr_outro_normans2, facing = pos},
		{type = "scar_manatarms", spawn = mkr_outro_normans3a},
		{type = "scar_manatarms", spawn = mkr_outro_normans3b},
		{type = "scar_manatarms", spawn = mkr_outro_normans3c},
		{type = "scar_archer", numSquads = 3, spawn = mkr_outro_normans4, facing = pos},
		{type = "scar_manatarms", spawn = mkr_outro_normans5a},
		{type = "scar_manatarms", spawn = mkr_outro_normans5b},
		{type = "scar_manatarms", spawn = mkr_outro_normans5c},
	}
	UnitEntry_DeploySquads(player1, sg_cheering_a, outro_normans)
	SGroup_EnableCheering(sg_cheering_a, true, -1, WALLA_CAMP_CELEBRATE_MEDIUM, 10)
	
end


function Mission_OnLeaveGameMatchRequested()

	-- mission is quitting... force-stop some sfx in case they linger into the next game session 

	if b_audio_transitionWallaPlaying == true then 
		Sound_Play2D("sfx_camp_battlle_of_hastings_walla_transition_loop_stop")
		b_audio_transitionWallaPlaying = false
	end
	
end





function Hastings_MoveHarold()
	-- destroy existing corpse
	if Entity_IsValid(entityWorldID_kingHarold) then 
		local entity = Entity_FromID(entityWorldID_kingHarold)
		Entity_Destroy(entity)
	end
	
	-- spawn new harold and kill him in place
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player2, sg_temp, {sbp=SBP.ENGLISH.UNIT_KING_HAROLD_CMP_ENG, spawn = mkr_outro_kingharold})
	SGroup_Kill(sg_temp)
end

function Hastings_ClearGameplayCorpses()
	
	local clearMarkers = {
		mkr_hill_top_center,
		mkr_hill_top_left,
		mkr_hill_top_right,
		mkr_hill_upper_center,
		mkr_hill_upper_left,
		mkr_hill_upper_right,
		mkr_kingharold_defend_outer1,
		mkr_kingharold_defend_outer2,
		mkr_kingharold_defend_outer3,
	}
	
	for k,marker in pairs (clearMarkers) do
		Marker_CleanUpTheDead(ALL, marker)
	end
	
	
end

