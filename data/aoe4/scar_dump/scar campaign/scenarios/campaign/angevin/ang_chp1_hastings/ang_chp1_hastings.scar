function Hastings_SpreadUnitsAlongSpline(sgroup, markerTable, facing, sgroupSpecialUnits, staggerOddAndEven)
	
	if facing ~= nil then 
		facing = Util_GetPosition(facing)
	end
	
	local totalSplineLength = 0
	local splineSegments = {}
	
	for index = 1, (#markerTable - 1) do
		
		local segment = {
			pointA = markerTable[index],	
			pointB = markerTable[index+1],
			distance = Util_GetDistance(markerTable[index], markerTable[index+1]),
		}
		table.insert(splineSegments, segment)
		
		totalSplineLength = totalSplineLength + segment.distance 
		
	end
	
	local numRegularUnits = SGroup_CountSpawned(sgroup)
	local numSpecialUnits = 0
	if scartype(sgroupSpecialUnits) == ST_SGROUP then 
		numSpecialUnits = SGroup_CountSpawned(sgroupSpecialUnits)
	end
	
	local numUnits = numRegularUnits + numSpecialUnits
	
	local specialUnit_frequency = 9999999
	local specialUnit_nextAppearance = 9999999
	if numSpecialUnits ~= 0 then 
		specialUnit_frequency = numUnits / numSpecialUnits
		specialUnit_nextAppearance = specialUnit_frequency / 2 
	end

	
	local distanceBetweenUnits = totalSplineLength / (numUnits - 1)

	local currentSegmentIndex = 1
	local distanceAlongSegment = 0
	
	local index_regular = 1
	local index_special = 1
	
	for index = 1, numUnits do 
		
		local squad
			
		if index > specialUnit_nextAppearance then 
			squad = SGroup_GetSpawnedSquadAt(sgroupSpecialUnits, index_special)
			index_special = index_special + 1
			specialUnit_nextAppearance = specialUnit_nextAppearance + specialUnit_frequency			
		else 
			squad = SGroup_GetSpawnedSquadAt(sgroup, index_regular)	
			index_regular = index_regular + 1
		end
		
		local segment = splineSegments[currentSegmentIndex]
		
		while currentSegmentIndex < #splineSegments and distanceAlongSegment > segment.distance do 
			distanceAlongSegment = distanceAlongSegment - segment.distance
			currentSegmentIndex = currentSegmentIndex + 1
			segment = splineSegments[currentSegmentIndex]
		end
		
		local distance = distanceAlongSegment
		if distance < 1 then
			distance = distanceAlongSegment / segment.distance	-- distances of less than 1 are treated as percentages, so convert this distance to a percentage
		end
		local pos = Util_GetPositionFromAtoB(segment.pointA, segment.pointB, distance)
		
		if staggerOddAndEven == true and math.fmod(index, 2) == 1 and facing ~= nil then
			pos = Util_GetPositionFromAtoB(pos, facing, 2)
		end
		
		Squad_WarpToPos(squad, pos)
		if facing ~= nil then
			Squad_FacePosition(squad, facing)
		end
		
		distanceAlongSegment = distanceAlongSegment + distanceBetweenUnits
		
	end
	
end



function Hastings_ForceAttackWilliam()
	
	if Objective_IsComplete(OBJ_KillHarold) then 
		
		Rule_RemoveMe()
		
	elseif g_leaderWilliam.inDownedState == true then
		
		t_difficulty.maxNumberOfWilliamAttackers = Util_DifVar({1, 2, 3, 4})		-- on story mode, after william has fallen once we reduce the number of attackers to one
		
	elseif SGroup_CountSpawned(sg_dukewilliam) >= 1 then   
		
		local squad = SGroup_GetSpawnedSquadAt(sg_dukewilliam, 1)
		local pos = Squad_GetPosition(squad)
		
		local _CheckForDisengage = function(gid, idx, sid)			-- if any of the attacker squads are far from william, disengage
			if Util_GetDistanceSquared(pos, sid) > 7^2 then 
				SGroup_Single(sg_single, sid)
				Cmd_Stop(sg_single, sid)		-- stop, hope they pick up a new target by aggro
				SGroup_Remove(gid, sid)
			end	
		end
		SGroup_ForEach(sg_williamAttackers, _CheckForDisengage)
		
		if SGroup_CountSpawned(sg_williamAttackers) < t_difficulty.maxNumberOfWilliamAttackers then 
			
			Player_GetAllSquadsNearMarker(player2, sg_williamNearby, pos, 7)
			SGroup_Intersection(sg_williamNearby, sg_activeUnits_player2)		-- only consider active units (not units-in-waiting, and not harold and his entourage)
			SGroup_RemoveGroup(sg_williamNearby, sg_williamAttackers)
			
			if SGroup_CountSpawned(sg_williamNearby) >= 1 then 
				
				local randomNearby = SGroup_GetRandomSpawnedSquad(sg_williamNearby)
				SGroup_Remove(sg_williamNearby, randomNearby)
				SGroup_Add(sg_williamAttackers, randomNearby)
			
				SGroup_Single(sg_single, randomNearby)
			
				local module = AI_Module_FindAssociatedModule(randomNearby)		
				if module ~= nil then 
					Prefab_DoAction(module, "RemoveSGroup", sg_single)
				end
			
				Cmd_Attack(sg_single, sg_dukewilliam)
				
			end
				
		end
		
	end
	
end

	