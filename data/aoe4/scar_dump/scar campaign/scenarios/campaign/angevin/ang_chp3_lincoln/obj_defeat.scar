		end,
	}
	
	SOBJ_DestroyReinforcementGroup1 = {
		
		Title = "$11192296", -- Eliminate the first column
		Type = ObjectiveType_Primary,
		Intel_Complete = EVENTS.FirstColumn_Destroyed,
		Parent = OBJ_DestroyReinforcementGroups,
		PreStart = function()
