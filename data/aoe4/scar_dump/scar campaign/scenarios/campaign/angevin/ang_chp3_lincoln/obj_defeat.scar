--
-- Lincoln 1141 - Defeat
--

function Defeat_InitObjectives()
	
	OBJ_ClearCamps = {
		
		Title = "$11180377", -- Defeat the besieging forces
				Type = ObjectiveType_Primary,
		OnComplete = function()
			
			Rule_Remove(Lincoln_ReinforceAssault)
			
			if Objective_IsComplete(OBJ_DefeatStephen) then
				Lincoln_BeginEndStage()
			elseif not Objective_IsStarted(OBJ_DefeatStephen) then
				Lincoln_LaunchFinalAttack()
				--Rule_AddOneShot(Lincoln_LaunchFinalAttack, 3)
				Sound_SetMinimumMusicCombatIntensity(801, 0)
			end
		end,
	}
	
	SOBJ_ClearLeftCamp = {
		
		Title = "$11191838", -- Clear the western camp
		Type = ObjectiveType_Primary,
		Parent = OBJ_ClearCamps,
		OnStart = function()
			hpid_camp_left = Objective_AddUIElements(SOBJ_ClearLeftCamp, mkr_siege_camp_left, true, 11191848, false)
			Objective_SetProgressBar(SOBJ_ClearLeftCamp, 0)
		end,
		OnComplete = function()
			t_besiegers[1].active = false
		end,
	}
	SOBJ_ClearMiddleCamp = {
		
		Title = "$11191839", -- Clear the central camp
		Type = ObjectiveType_Primary,
		Parent = OBJ_ClearCamps,
		OnStart = function()
			hpid_camp_middle = Objective_AddUIElements(SOBJ_ClearMiddleCamp, mkr_siege_camp_middle, true, 11191849, false)
			Objective_SetProgressBar(SOBJ_ClearMiddleCamp, 0)
		end,
		OnComplete = function()
			t_besiegers[2].active = false
			t_besiegers[3].active = false
		end,
	}
	SOBJ_ClearRightCamp = {
		
		Title = "$11191840", -- Clear the eastern camp
		Type = ObjectiveType_Primary,
		Parent = OBJ_ClearCamps,
		OnStart = function()
			hpid_camp_right = Objective_AddUIElements(SOBJ_ClearRightCamp, mkr_siege_camp_right, true, 11191850, false)
			Objective_SetProgressBar(SOBJ_ClearRightCamp, 0)
		end,
		OnComplete = function()
			t_besiegers[4].active = false
			t_besiegers[5].active = false
