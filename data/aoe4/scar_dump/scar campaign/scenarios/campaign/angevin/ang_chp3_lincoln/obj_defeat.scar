			Objective_Start(SOBJ_SetStandGround, false)
			
			Rule_AddInterval(Lincoln_CheckStealthForestProx, 1)
			Rule_AddInterval(Lincoln_CheckHoldPosition, 1)
		end,
		IsComplete = function()
			if Objective_IsComplete(SOBJ_MoveAllUnits) and Objective_IsComplete(SOBJ_SetStandGround) then
				return true
			end
		end,
		OnComplete = function()
			Objective_Start(OBJ_DestroyReinforcementGroups)
