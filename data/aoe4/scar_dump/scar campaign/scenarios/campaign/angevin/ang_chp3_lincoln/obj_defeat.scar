	}
	SOBJ_MoveAllUnits = {
		
		Title = "$11195387", -- Move all units into the stealth forest
		Type = ObjectiveType_Primary,
		Parent = OBJ_SetupAmbush,
		PreStart = function()
			Objective_SetProgressBar(SOBJ_MoveAllUnits, 0)
		end,
	}
	SOBJ_SetStandGround = {
		
		Title = "$11195388", -- Set units on stand ground
		Type = ObjectiveType_Primary,
		Parent = OBJ_SetupAmbush,
		PreStart = function()
			Objective_SetProgressBar(SOBJ_SetStandGround, 0)
		end,
