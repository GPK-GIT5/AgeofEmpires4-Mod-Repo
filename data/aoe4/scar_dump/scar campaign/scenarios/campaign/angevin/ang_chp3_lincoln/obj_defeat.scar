		--	Util_StartIntel(EVENTS.Ambush_SetUp)
		end,
	}
	
	OBJ_DestroyReinforcementGroups = {
		
		Title = "$11180378", -- Eliminate enemy reinforcements
		Type = ObjectiveType_Primary,
		Intel_Start = EVENTS.Ambush_SetUp,
		Intel_Complete = EVENTS.Eliminate_Reinforcements_Complete,
		Intel_Fail = EVENTS.Eliminate_Reinforcements_Fail,
		OnStart = function()
			Objective_Start(SOBJ_DestroyReinforcementGroup1, false)
		end,
		PreComplete = function()
			Player_GetSquadsOnscreen(player1, sg_temp)
