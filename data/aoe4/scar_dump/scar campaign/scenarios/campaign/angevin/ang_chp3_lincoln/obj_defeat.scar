	}
	
	OBJ_DefeatStephen = {
		
		Title = "$11180381", -- Capture King Stephen
		Type = ObjectiveType_Primary,
		--Parent = OBJ_DefeatArmy,
		Intel_Start = EVENTS.StephenVisible,
		Intel_Complete = EVENTS.StephenCaptured,
		PreStart = function()
			
			Rule_AddGlobalEvent(DefeatStephen_OnSquadKilled, GE_SquadKilled)
			Sound_Play2D(MUS_STINGER_ALERT)
			
			EventCues_CallToAction("$11191824", CTA_ALARM, nil, nil, sg_stephen, 20)
			FOW_RevealSGroup(sg_stephen, 7, -1)
			
			Objective_AddUIElements(OBJ_DefeatStephen, sg_stephen, false, 11180370, true, 3, sg_stephen)
		end,
		OnStart = function()
			Music_UnlockIntensity()
			Music_LockIntensity (MUSIC_TENSE_COMBAT_RARE)
		end,
		PreComplete = function()
			Lincoln_FinalAttackRetreat()
		end,
		OnComplete = function()
			if Objective_IsComplete(OBJ_ClearCamps) then
				Lincoln_BeginEndStage()
			end
		end,
	}
	
	OBJ_SetupAmbush = {
		
		Title = "$11195386", -- Set up an ambush
		Type = ObjectiveType_Primary,
		Intel_Start = EVENTS.Eliminate_Reinforcements,
		PreStart = function()
			Objective_AddUIElements(OBJ_SetupAmbush, mkr_stealth_forest1, true, 11183436, false)
