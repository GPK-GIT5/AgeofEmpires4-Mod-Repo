			rg_hasSpawned1 = true
		end,
		OnStart = function()
			Objective_SetProgressBar(SOBJ_DestroyReinforcementGroup1, 0)
		end,
		OnComplete = function()
			rg_destroyed_count = rg_destroyed_count + 1
			Objective_Start(SOBJ_DestroyReinforcementGroup2)
		end,
		OnFail = function()
			Objective_Start(SOBJ_DestroyReinforcementGroup2)
		end,
	}
	SOBJ_DestroyReinforcementGroup2 = {
		
		Title = "$11192297", -- Eliminate the second column
		Type = ObjectiveType_Primary,
		Intel_Complete = EVENTS.SecondColumn_Destroyed,
		Parent = OBJ_DestroyReinforcementGroups,
		PreStart = function()
			Lincoln_SpawnEnemyReinforcements(2, false)
			rg_hasSpawned2 = true
		end,
		OnStart = function()
			AIPlayer_ResetEnemySquadsVisibility(player2, player1)
			Objective_SetProgressBar(SOBJ_DestroyReinforcementGroup2, 0)
		end,
		OnComplete = function()
			rg_destroyed_count = rg_destroyed_count + 1
			Objective_Start(SOBJ_DestroyReinforcementGroup3)
		end,
		OnFail = function()
