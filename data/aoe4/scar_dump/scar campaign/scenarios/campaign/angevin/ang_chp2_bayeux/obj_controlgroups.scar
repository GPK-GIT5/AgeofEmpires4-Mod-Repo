
function ControlGroup_InitObjectives()		-- rename this function to use your prefix for this part of the mission

	OBJ_ControlGroups = {
	
		Title = "$11201805", -- Use CTRL+0-9 to create a control group
		Type = ObjectiveType_Optional,
		--OnStart = Destroy_OnStart,
		IsComplete = ControlGroups_IsComplete,
		--OnComplete = Destroy_OnComplete,
		--IsFailed = PlayerDeath,
		--OnFail = Mission_Fail,
	}
	SOBJ_CGArchers = {
	
		Title = "$11201806", -- Group only your archers
		Type = ObjectiveType_Optional,
		StartAlongsideParent = true,
		Parent = OBJ_ControlGroups,
		--OnStart = Destroy_OnStart,
		IsComplete = CGArchers_IsComplete,
		--OnComplete = Destroy_OnComplete,
		--IsFailed = PlayerDeath,
		--OnFail = Mission_Fail,
	}
	SOBJ_CGSpears = {
	
		Title = "$11201807", -- Group only your spearmen
		Type = ObjectiveType_Optional,
		StartAlongsideParent = true,
		Parent = OBJ_ControlGroups,
		--OnStart = Destroy_OnStart,
		IsComplete = CGSpears_IsComplete,
		--OnComplete = Destroy_OnComplete,
		--IsFailed = PlayerDeath,
		--OnFail = Mission_Fail,
	}

	Objective_Register(OBJ_ControlGroups)
	Objective_Register(SOBJ_CGArchers)	
	Objective_Register(SOBJ_CGSpears)
	
	sg_controlgroups_archers = SGroup_CreateIfNotFound("sg_controlgroups_archers")
	sg_controlgroups_spears = SGroup_CreateIfNotFound("sg_controlgroups_spears")
	sg_controlgroups_any = SGroup_CreateIfNotFound("sg_controlgroups_any")
	
end

function ControlGroup_Check()
	for i = 0, 10 do
		SGroup_Clear(sg_controlgroups_any)
		Misc_GetControlGroupContents(i, sg_controlgroups_any, eg_temp) 
		if SGroup_CountSpawned(sg_controlgroups_any) < 1 then
			Objective_Start(OBJ_ControlGroups)
		end
		EGroup_Clear(eg_temp)
	end
end

function ControlGroups_IsComplete()
	return Objective_AreSubObjectivesComplete(OBJ_ControlGroups, true)
end

function CGArchers_IsComplete()
	for i = 0, 10 do
		SGroup_Clear(sg_controlgroups_archers)
		SGroup_Clear(sg_temp)
		Misc_GetControlGroupContents(i, sg_controlgroups_archers, eg_temp)
	 	SGroup_Filter(sg_controlgroups_archers, "scar_archer", FILTER_KEEP, sg_temp)
		if SGroup_CountSpawned(sg_controlgroups_archers) >= 1 and SGroup_CountSpawned(sg_temp) < 1 then
			return true
			--Objective_Complete(SOBJ_CGArchers)
		end
		EGroup_Clear(eg_temp)
	end
end

function CGSpears_IsComplete()
	for i = 0, 10 do
		SGroup_Clear(sg_controlgroups_spears)
		SGroup_Clear(sg_temp)
		Misc_GetControlGroupContents(i, sg_controlgroups_spears, eg_temp)
	 	SGroup_Filter(sg_controlgroups_spears, "scar_spearman", FILTER_KEEP, sg_temp)
		if SGroup_CountSpawned(sg_controlgroups_spears) >= 1 and SGroup_CountSpawned(sg_temp) < 1 then
			return true
			--Objective_Complete(SOBJ_CGSpears)
		end
		EGroup_Clear(eg_temp)
	end
end

