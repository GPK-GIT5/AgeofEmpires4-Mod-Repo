--
-- Bayeux - Capture Village
--

function CaptureVillage_InitObjectives()

	local location = LOCATION("WoodTown")
	
	OBJ_CaptureVillage = 
	{
		Title = "$11192728", --Capture the Wood Mill
		Type = ObjectiveType_Capture,
		--Icon = "icons/objectives/capture_objective",
		--Intel_Start = EVENTS.JohnArrives,
		PreStart = CaptureVillage_PreStart,
		OnStart = CaptureVillage_Start,
		IsComplete = CaptureVillage_IsComplete,
		PreComplete = CaptureVillage_PreComplete, 
		OnComplete = CaptureVillage_OnComplete,
		IsFailed = CaptureVillage_IsFailed,
		OnFail = CaptureVillage_OnFail,
	}
	
	    SOBJ_DefeatHamletRebels = 
	{
         
        Title = "$11192729", --"Defeat the Defenders at the Wood Mill"
        Type = ObjectiveType_Capture,
        Parent = OBJ_CaptureVillage,
        OnStart = DefeatHamletRebels_Start,
		PreStart = DefeatHamletRebels_PreStart,
    }
	
	    SOBJ_LocationHamlet = 
	{
        Title = "$11192755", --Wood Mill
        Type = ObjectiveType_Capture,
        Parent = OBJ_CaptureVillage,
    }
	
	OBJ_DebugComplete = {
		Title = LOC("Debug Complete"),
		Type = OT_Primary,
		showTitle = false,
		Cheat = function()
			EGroup_Kill(eg_outro_destroy)
			Mission_Complete()
		end,
	}
	
	Objective_Register(OBJ_CaptureVillage)
	Objective_Register(SOBJ_DefeatHamletRebels)
	Objective_Register(SOBJ_LocationHamlet)
	Objective_Register(OBJ_DebugComplete)
	
	location.objectivePrimary = OBJ_CaptureVillage
    location.objectiveSecondary = SOBJ_DefeatHamletRebels
    location.objectiveCapture = SOBJ_LocationHamlet
end

function CaptureVillage_Start()
	
end

function CaptureVillage_PreStart() --Pre-Objective Start
	Location_SetCapturable(LOCATION("WoodTown"), true)
	Objective_RemoveUIElements(OBJ_Destroy, Bayeux_Icon)	
end

function DefeatHamletRebels_PreStart()
	
	Music_LockIntensity(MUSIC_COMBAT, 30)	
end


function CaptureVillage_IsComplete() --Is the objective complete? Looping check.
	if SGroup_CountSpawned(sg_defend_wood) <= 0 then --If there are no defenders left in Hamlet
		--LOCATION("TheHamlet").data.villagerCount = 0	
		return true --Complete
	else
		return false --Keep Looping
	end
end

function CaptureVillage_PreComplete() --Before ending the objective
	Music_StopMedium()
	--AudOnScreen(player1, "WALLA_CAMP_CELEBRATE_")
	-- on console, restore the econ HUD at this point
	if  UI_IsXboxUI() then
		Game_SetVisibility (VF_XboxUIResourceCard, true)
		Game_SetVisibility (VF_XboxUIVillagerPriorities, true)
	end				
end

function CaptureVillage_OnComplete() --When the objective completes
	
	if b_debugStart == false then
		villager_RespawnLocation = villagerlife_woodtown.mkr_flee
		
		Rule_Remove(PlayerRush)
		Rule_Remove(PlayerDeath_PreTown)
		Rule_AddInterval(PlayerDeath_PostTown, 1)
		
		SGroup_Clear(sg_temp)
		UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerlife_woodtown.roaming_count},villager_RespawnLocation)
		Cmd_Move(sg_temp, villagerlife_woodtown.location_mkr)
		SGroup_Clear(sg_temp)
		UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerlife_woodtown.food_count}, villager_RespawnLocation)
		AssignVillagersToFarms(sg_temp)
		SGroup_Clear(sg_temp)
		UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerlife_woodtown.wood_count}, villager_RespawnLocation)
		AssignVillagersToWood(sg_temp)
		SGroup_Clear(sg_temp)
		UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerlife_woodtown.stone_count}, villager_RespawnLocation)
		AssignVillagersToStone(sg_temp)
		SGroup_Clear(sg_temp)
		UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerlife_woodtown.gold_count}, villager_RespawnLocation)
		AssignVillagersToGold(sg_temp)
		
		if Game_GetSPDifficulty() > GD_EASY then --Give more resources to story mode players
			Player_AddResources(player1, {gold = 500, wood = 1000, food = 500, stone = 0,})
		else
			Player_AddResources(player1, {gold = 1000, wood = 2000, food = 1000, stone = 500,})
		end
		Objective_Start(OBJ_Rams, false)
		Objective_Start(SOBJ_Blacksmith, true)
		Music_UnlockIntensity()
		--RochesterSupply_Init()
		
		Util_StartIntel(EVENTS.BatteringRams_Start_Part1)
		
		Rule_AddOneShot(MissionTutorial_Blacksmith, 30)
		
		UI_SetPlayerDataContext(player1, { PopulationCapOn = true })
		
		Util_AutoSave()
	end
	Game_TransitionToState("sunset", 300)
end

function CaptureVillage_IsFailed() --Check if objective failed
	Player_GetAll(player1)
	if SGroup_CountSpawned(sg_allsquads) <= 0 then --If the player has no units left
		return true --Fail the objective
	else
		return false --Keep checking
	end
end

function CaptureVillage_OnFail() --On Objective Fail
	Mission_Fail() --Missions fails
end