--
-- Tinchebray
--

function Defeat_InitObjectives()
	
	OBJ_DefeatArmy = {
		
		Title = "$11180782", -- Defeat Robert and his followers
		Type = ObjectiveType_Battle,
		Intel_Complete = EVENTS.Tinchebray_Outro,
	}
	
	OBJ_DestroyVillages = {
		
		Title = "$11180805", -- Destroy villages to lure out the army
		Type = ObjectiveType_Battle,
		Intel_Start = EVENTS.StartLureArmy,
		OnStart = function()
			Objective_Start(SOBJ_DestroyMartigny, false)
			Objective_Start(SOBJ_DestroyFrenes, false)
			
			Rule_AddInterval(Tinchebray_CheckVillages, 1)
		end,
	}
	
	SOBJ_DestroyMartigny = {
		
		Title = "$11181903", -- Destroy all buildings in Martigny
		Type = ObjectiveType_Battle,
		Parent = OBJ_DestroyVillages,
		OnStart = function()
			init_martigny_count = EGroup_CountSpawned(eg_martigny)
			Objective_SetCounter(SOBJ_DestroyMartigny, 0, init_martigny_count)
			hpid_martigny = Objective_AddUIElements(SOBJ_DestroyMartigny, mkr_martigny, true, 11180369, false, 7)
			
			Rule_AddInterval(Tinchebray_CheckMartignyProx, 1)
		end,
		OnComplete = function()
			Util_AutoSave()
		end,
	}
	
	SOBJ_DestroyFrenes = {
		
		Title = "$11181904", -- Destroy all buildings in Frenes
		Type = ObjectiveType_Battle,
		Parent = OBJ_DestroyVillages,
		OnStart = function()
			init_frenes_count = EGroup_CountSpawned(eg_frenes)
			Objective_SetCounter(SOBJ_DestroyFrenes, 0, init_frenes_count)
			hpid_frenes = Objective_AddUIElements(SOBJ_DestroyFrenes, mkr_frenes, true, 11180368, false, 7)
			
			Rule_AddInterval(Tinchebray_CheckFrenesProx, 1)
		end,
		OnComplete = function()
			Util_AutoSave()
		end,
	}
	
	SOBJ_EliminateReinforcements = {
		
		Title = "$11180806", -- Destroy the enemy relief army
		Type = ObjectiveType_Battle,
		Parent = OBJ_DefeatArmy,
		OnStart = function()
			hpid_reinforcements = Objective_AddUIElements(SOBJ_EliminateReinforcements, sg_enemy_relief_army, true, 11172037, false)
			Obj_SetProgressVisible(SOBJ_EliminateReinforcements.ID, true)
			Obj_SetProgress(SOBJ_EliminateReinforcements.ID, 0)
		end,
		OnComplete = function()
			Obj_SetProgressVisible(SOBJ_EliminateReinforcements.ID, false)
			Objective_RemoveUIElements(SOBJ_EliminateReinforcements, hpid_reinforcements)
			
			Util_StartIntel(EVENTS["ReliefArmy_Damaged"])
		end,
		OnFail = function()
			Util_StartIntel(EVENTS.ReliefArmy_Failed)
		end
	}
	
	SOBJ_EliminateArmy = {
		
		Title = "$11184324", -- Eliminate Robert's army
		Type = ObjectiveType_Battle,
		Parent = OBJ_DefeatArmy,
		OnStart = function()
			Objective_AddUIElements(SOBJ_EliminateArmy, sg_enemy_army_a2, true, nil, false)
			Objective_AddUIElements(SOBJ_EliminateArmy, sg_enemy_army_b2, true, nil, false)
			Objective_AddUIElements(SOBJ_EliminateArmy, sg_enemy_army_c2, true, nil, false)
			Objective_AddUIElements(SOBJ_EliminateArmy, sg_robert, true, nil, false)
			
			Obj_SetProgressVisible(SOBJ_EliminateArmy.ID, true)
			Obj_SetProgress(SOBJ_EliminateArmy.ID, 0)
			Music_LockIntensity(MUSIC_RARE, 60, MUSIC_TENSE_COMBAT_RARE)
		end,
		OnComplete = function()
			Obj_SetProgressVisible(SOBJ_EliminateArmy.ID, false)
		end,
	}
	SOBJ_CaptureRobert = {
		
		Title = "$11184325", -- Capture Robert
		Type = ObjectiveType_Battle,
		Parent = OBJ_DefeatArmy,
		OnStart = function()
			hintpoint_robert = HintPoint_Add(sg_robert, true, 11161943, 2, HPAT_Attack, "icons/objective_arrow", nil, true, nil)
		end,
	}
	
	Objective_Register(OBJ_DefeatArmy)
	Objective_Register(OBJ_DestroyVillages)
	
	Objective_Register(SOBJ_DestroyMartigny)
	Objective_Register(SOBJ_DestroyFrenes)
	
	Objective_Register(SOBJ_EliminateReinforcements)
	
	Objective_Register(SOBJ_EliminateArmy)
	Objective_Register(SOBJ_CaptureRobert)
	
end

