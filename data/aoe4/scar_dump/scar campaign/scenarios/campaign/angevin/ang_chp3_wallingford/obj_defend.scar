
function Defend_InitObjectives()		-- rename this function to use your prefix for this part of the mission
	OBJ_Defend = {
		Title = 11182631, --Survive until reinforcements arrive
		Type = OT_Primary,	
		IsFailed = Defend_IsFailed,
		OnFail = Defend_OnFail,
	}
	Objective_Register(OBJ_Defend)
end

function Defend_IsFailed()
	eg_landmarks = Player_GetEntitiesFromType(player1, "landmark")
	local r = EGroup_CountSpawned(eg_landmarks) == 0
	EGroup_Destroy(eg_landmarks)
	return r
end

function Defend_OnFail()
	Mission_Fail()
end