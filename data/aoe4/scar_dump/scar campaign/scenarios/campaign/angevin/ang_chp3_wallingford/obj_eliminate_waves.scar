
function EliminateWaves_InitObjectives()
	OBJ_EliminateWaves = {
		Title = 11184554, --Clear the fields around Wallingford
		Type = OT_Primary,
	}
	
	SOBJ_UnitsRemaining = {
		Title = 11183899, --Units remaining
		Type = OT_Secondary,
		Parent = OBJ_EliminateWaves,
		--OnStart = UnitsRemaining_OnStart,
		SetupUI = UnitsRemaining_SetupUI,
		StartAlongsideParent = true,
		IsComplete = UnitsRemaining_IsComplete,
		OnComplete = UnitsRemaining_OnComplete,
	}
	
	Objective_Register(OBJ_EliminateWaves)
	Objective_Register(SOBJ_UnitsRemaining)
end

function UnitsRemaining_SetupUI()
	UnitsRemaining_UpdateCount()
end


function UnitsRemaining_UpdateCount()
	unit_count_assault = 0
	unit_count_patrol = 0
	unit_count_defend = 0
	unit_count_reinforce = 0
	
	for i, module in ipairs(arrived_assault_modules) do
		unit_count_assault = unit_count_assault + SGroup_CountSpawned(module.sgroup)
	end
	
	for i, module in ipairs({ siege_patrol_1, siege_patrol_2, siege_patrol_3, siege_patrol_4, siege_patrol_5 }) do
		if module.status ~= ARMY_STATUS_DISSOLVED then
			unit_count_patrol = unit_count_patrol + SGroup_CountSpawned(module.sgroup)
		end
	end
	
	for i, module in ipairs({ enemy_defend_1, enemy_defend_2, enemy_defend_3, enemy_defend_4, enemy_defend_5, enemy_defend_6 }) do
		if module.status ~= ARMY_STATUS_DISSOLVED then
			unit_count_defend = unit_count_defend + SGroup_CountSpawned(module.sgroup)
		end
	end
	
	for i, module in ipairs({ reinforcements_first_1, reinforcements_first_2, reinforcements_first_3, reinforcements_first_4, reinforcements_second_1, reinforcements_second_2 }) do
		if module.status ~= ARMY_STATUS_DISSOLVED then
			unit_count_reinforce = unit_count_reinforce + SGroup_CountSpawned(module.sgroup)
		end
	end
	unit_count = unit_count_assault + unit_count_patrol + unit_count_defend + unit_count_reinforce
	print("assault:"..unit_count_assault)
	print("patrol:"..unit_count_patrol)
	print("defend:"..unit_count_defend)
	print("reinforce:"..unit_count_reinforce)
	print("total:"..unit_count)
	Objective_SetCounter(SOBJ_UnitsRemaining, unit_count)
end

function UnitsRemaining_IsComplete()
	UnitsRemaining_UpdateCount()
	return unit_count == 0
end


function UnitsRemaining_OnComplete()
	Util_StartIntel(EVENTS.ANG_ECAM1153WALLINGFORD_Outro)
end