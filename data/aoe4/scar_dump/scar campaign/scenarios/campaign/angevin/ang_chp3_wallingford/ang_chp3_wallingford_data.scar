function GetRecipe()	
	local recipe = {
		
		audioSettings = { campaignName = "ang", missionName = "rts1153wallingford" },
		enableShroud = true,
		campaign = "english",
		chapter = "chapter3",
		phase = "mission_wallingford",
		
		introNIS = EVENTS.ANG_ECAM1153WALLINGFORD_Intro,
		
		locations = {}, 
		
		modules = {
			-- NORTHEAST
			{
				type = "Defend",
