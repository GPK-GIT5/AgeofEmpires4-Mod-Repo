function Wallingford_InitData1()
	combat_started = false
	groups_reduced_to_half = 0
	camps_destroyed = 0
	startingWallDestroyed = false
	wave_unit_index = 0
	waves_prepared = 3
	
	LAUNCH_ATTACK_2 = 100
	LAUNCH_ATTACK_3 = 225
	
	LAUNCH_ATTACK_4_APPROX = 350    
	LAUNCH_ATTACK_5_APPROX = 475    
	LAUNCH_ATTACK_6_APPROX = 675 --could intercept if the player uses reinforcements immediately
	LAUNCH_ATTACK_7_APPROX = 800 --could intercept if the player hesitates
	
	PREPARE_TIME = 210
	
	ATTACK_INTERVAL = 125
	
	REINFORCEMENTS_DELAY = 600
	
	wallingford_seconds = { 0 }
	
	spawn_info = {}
	spawn_info["ne"] = { wave = "wave_ne", defeated = false }
	spawn_info["n"] = { wave = "wave_n", defeated = false }
	spawn_info["nw"] = { wave = "wave_nw", defeated = false }
	
	intro_targets = {
		{ mkr_enemy_path_ne_4, mkr_player_base },
		{ mkr_enemy_path_n_7, mkr_enemy_path_n_8, mkr_player_base },
		{ mkr_enemy_path_nw_5, mkr_enemy_path_nw_6, mkr_player_base },
	}
	wave_targets_a = {
		nw = { mkr_enemy_path_nw_1, mkr_enemy_path_nw_2, mkr_enemy_path_nw_3, mkr_enemy_path_nw_4 },
		n = { mkr_enemy_path_n_1, mkr_enemy_path_n_2, mkr_enemy_path_n_3, mkr_enemy_path_n_4, mkr_enemy_path_n_5, mkr_enemy_path_n_6 },
		ne = { mkr_enemy_path_ne_1, mkr_enemy_path_ne_2 }
	}
	wave_targets_b = {
		nw = { mkr_enemy_path_nw_5, mkr_enemy_path_nw_6, mkr_player_base },
		n = { mkr_enemy_path_n_7, mkr_enemy_path_n_8, mkr_player_base },
		ne = { mkr_enemy_path_ne_3, mkr_enemy_path_ne_4, mkr_player_base }
	}
	intro_wave_launched = { false, false, false }
	arrive_events = { nil, EVENTS.SECOND_ATTACK, EVENTS.THIRD_ATTACK }
	dead_events = { nil, EVENTS.SECOND_ATTACK_DEFEATED, EVENTS.THIRD_ATTACK_DEFEATED }
	
	
	eg_wallingford = EGroup_CreateIfNotFound("eg_wallingford")
	eg_enemy_fort_ne = EGroup_CreateIfNotFound("eg_enemy_fort_ne")
	eg_enemy_fort_n = EGroup_CreateIfNotFound("eg_enemy_fort_n")
	eg_enemy_fort_nw = EGroup_CreateIfNotFound("eg_enemy_fort_nw")
	eg_player_walls = Player_GetEntitiesFromType(player1, "wall")
	EGroup_Filter(eg_player_walls, "stone_wall_tower", FILTER_REMOVE)
		
	sg_player_reinforcements = SGroup_CreateIfNotFound("sg_player_reinforcements") 
	sg_player_villagers_food = SGroup_CreateIfNotFound("sg_player_villagers_food")
	sg_player_villagers_wood = SGroup_CreateIfNotFound("sg_player_villagers_wood")
	sg_player_villagers_gold = SGroup_CreateIfNotFound("sg_player_villagers_gold")
	sg_player_villagers_stone = SGroup_CreateIfNotFound("sg_player_villagers_stone") 
	sg_intro_assault_1 = SGroup_CreateIfNotFound("sg_intro_assault_1")
	
	Wallingford_LoadUnitTables()
end

function Wallingford_InitData2()
	intro_assault_1 = MissionOMatic_FindModule("intro_assault_1")
	intro_assault_2 = MissionOMatic_FindModule("intro_assault_2")
	intro_assault_3 = MissionOMatic_FindModule("intro_assault_3")
	intro_assault_modules = { intro_assault_1, intro_assault_2, intro_assault_3 }
	
	incoming_assault_modules = {}
	arrived_assault_modules = { intro_assault_1, intro_assault_2, intro_assault_3 }
	
	siege_patrol_1 = MissionOMatic_FindModule("siege_patrol_1")
	siege_patrol_2 = MissionOMatic_FindModule("siege_patrol_2")
	siege_patrol_3 = MissionOMatic_FindModule("siege_patrol_3")
	siege_patrol_4 = MissionOMatic_FindModule("siege_patrol_4")
	siege_patrol_5 = MissionOMatic_FindModule("siege_patrol_5")
	
	enemy_defend_1 = MissionOMatic_FindModule("enemy_defend_1")
	enemy_defend_2 = MissionOMatic_FindModule("enemy_defend_2")
	enemy_defend_3 = MissionOMatic_FindModule("enemy_defend_3")
	enemy_defend_4 = MissionOMatic_FindModule("enemy_defend_4")
	
	reinforcements_first_1 = MissionOMatic_FindModule("reinforcements_first_1")
	reinforcements_first_2 = MissionOMatic_FindModule("reinforcements_first_2")
	reinforcements_first_3 = MissionOMatic_FindModule("reinforcements_first_3")
	reinforcements_second_1 = MissionOMatic_FindModule("reinforcements_second_1")
	reinforcements_second_2 = MissionOMatic_FindModule("reinforcements_second_2")
	
	reinforcement_sources = {
		{ reinforcements_first_1, reinforcements_first_2, reinforcements_first_3 },
		{ reinforcements_second_1, reinforcements_second_2 },
	}
	reinforcement_indexes = { 0, 0 }
	
	final_wave = MissionOMatic_FindModule("final_wave")
	
	defender_info = {}
	defender_info[1] = { module = enemy_defend_1 }
	defender_info[2] = { module = enemy_defend_2 }
	defender_info[3] = { module = enemy_defend_3 }
	defender_info[4] = { module = enemy_defend_4 }
	
	for i = 1, #defender_info do
		defender_info[i].initial_count = SGroup_CountSpawned(defender_info[i].module.sgroup)
		defender_info[i].is_half = false
	end
	
	camp_data = { 
		{ egroup = camp_1 }, 
		{ egroup = camp_2 }, 
		{ egroup = camp_3 }, 
		{ egroup = camp_4 }, 
	}
	for i = #camp_data, 1, -1 do
		camp_data[i].position = EGroup_GetPosition(camp_data[i].egroup)
	end
end

