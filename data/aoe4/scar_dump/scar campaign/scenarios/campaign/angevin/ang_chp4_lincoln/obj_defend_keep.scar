--
-- Lincoln 1217 - Defend the Keep
--


function DefendKeep_InitObjectives()
	
	OBJ_DefendKeep = {
		Title = "$11180333", -- Lincoln keep must survive
		Type = ObjectiveType_Information,
		Intel_Start = EVENTS.Keep_Warning,
		OnStart = function()
			Objective_AddUIElements(OBJ_DefendKeep, mkr_keep, true, 11180385, false)
		end,
	}
	
	Objective_Register(OBJ_DefendKeep)

end



