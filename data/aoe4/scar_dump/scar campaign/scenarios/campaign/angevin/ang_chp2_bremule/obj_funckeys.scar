
function FuncKeys_InitObjectives_Xbox()		-- xbox version of this objective using the Find menu
											-- it has fewer sub-objectives because there isn't an 
											-- equivalent of F2 in the find menu

	OBJ_FuncKeys = {
		
		Title = "$11248618", -- Use the Find Menu to quickly find buildings.
		Type = ObjectiveType_Optional,
		IsComplete = FuncKeys_IsComplete,
		showTitle = false, -- we don't want to display a banner when this completes
	}
	SOBJ_F1 = {
		
		Title = "$11248619", -- Select unit production buildings
		Type = ObjectiveType_Optional,
		StartAlongsideParent = true,
		Parent = OBJ_FuncKeys,
		IsComplete = F1_IsComplete,
	}
	SOBJ_F3 = {
		
		Title = "$11248620", -- Select research buildings
		Type = ObjectiveType_Optional,
		StartAlongsideParent = true,
		Parent = OBJ_FuncKeys,
		IsComplete = F3_IsComplete,
	}
	SOBJ_F4 = {
	
		Title = "$11248690", -- Select landmarks
		Type = ObjectiveType_Optional,
		StartAlongsideParent = true,
		Parent = OBJ_FuncKeys,
		IsComplete = F4_IsComplete,
	}

	Objective_Register(OBJ_FuncKeys)
	Objective_Register(SOBJ_F1)	
	Objective_Register(SOBJ_F3)	
	Objective_Register(SOBJ_F4)
end

function FuncKeys_InitObjectives()		-- rename this function to use your prefix for this part of the mission

	OBJ_FuncKeys = {
	
		Title = "$11201808", -- Use the function keys (F1-F4) to quick select production buildings
		Type = ObjectiveType_Optional,
		IsComplete = FuncKeys_IsComplete,
	}
	SOBJ_F1 = {
	
		Title = "$11201809", -- Press F1 to select unit production buildings
		Type = ObjectiveType_Optional,
		StartAlongsideParent = true,
		Parent = OBJ_FuncKeys,
		IsComplete = F1_IsComplete,
	}
	SOBJ_F2 = {
	
		Title = "$11201810", -- Press F2 to select economy buildings
		Type = ObjectiveType_Optional,
		StartAlongsideParent = true,
		Parent = OBJ_FuncKeys,
		IsComplete = F2_IsComplete,
	}
	SOBJ_F3 = {
	
		Title = "$11201811", -- Press F3 to select technology buildings
		Type = ObjectiveType_Optional,
		StartAlongsideParent = true,
		Parent = OBJ_FuncKeys,
		IsComplete = F3_IsComplete,
	}
	SOBJ_F4 = {
	
		Title = "$11201812", -- Press F4 to select landmarks
		Type = ObjectiveType_Optional,
		StartAlongsideParent = true,
		Parent = OBJ_FuncKeys,
		IsComplete = F4_IsComplete,
	}

	Objective_Register(OBJ_FuncKeys)
	Objective_Register(SOBJ_F1)	
	Objective_Register(SOBJ_F2)
	Objective_Register(SOBJ_F3)	
	Objective_Register(SOBJ_F4)	
end

function FuncKeys_IsComplete()
	return Objective_AreSubObjectivesComplete(OBJ_FuncKeys, true)
end

function Egroup_FuncGroupSelected(buildingType)
	Misc_GetSelectedEntities(eg_temp, false)
	Player_GetAll(player1)
	EGroup_Filter(eg_allentities, buildingType, FILTER_KEEP)
	EGroup_RemoveGroup(eg_allentities, eg_burning_farmstead)
	if EGroup_Compare(eg_temp, eg_allentities) == true then
		return true
	end	
end

function F1_IsComplete()
 return Egroup_FuncGroupSelected("military_production_building")
end

function F2_IsComplete()
 return Egroup_FuncGroupSelected("economy_building")
end

function F3_IsComplete()
 return Egroup_FuncGroupSelected("research_building")
end

function F4_IsComplete()
 return Egroup_FuncGroupSelected("landmark")
end

