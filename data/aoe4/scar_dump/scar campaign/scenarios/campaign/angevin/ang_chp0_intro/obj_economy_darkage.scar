----
---- Mission 0 - Intro - Objectives for Economy Dark Age
---


function IntroEconomyDarkAge_InitObjectives()		-- rename this function to use your prefix for this part of the mission

	OBJ_DevelopEconomy = {
	
		Title = 11192629, --Build up your economy
		Type = ObjectiveType_Primary,
		
		Intel_Complete = EVENTS.DevelopEconomy_IntelComplete,
		
		PreStart = function()
			Player_GetAll(player1, sg_allsquads, eg_TC)
			EGroup_Filter(eg_TC, EBP.ENGLISH.BUILDING_TOWN_CENTER_CAPITAL_ENG, FILTER_KEEP)
			hptc = HintPoint_Add(eg_TC, true, "$11119069", 7)
		end,
		
		OnStart = function()
			Objective_Start(SOBJ_GatherFood)
		end,
		OnComplete = IntroEconomy_OnComplete,
		
		IsComplete = function()
			return Objective_AreSubObjectivesComplete (OBJ_DevelopEconomy, ALL)
		end,
		
	}
	
	SOBJ_GatherFood = {
	
		Title = Loc_FormatText("$11192630", i_desiredFoodAmount), -- Gather 200 additional food resource
		Type = ObjectiveType_Primary,
		Parent = OBJ_DevelopEconomy,
		StartAlongsideParent = false, 
		
		Intel_Start = EVENTS.GatherFood_IntelStart,
		Intel_Complete = EVENTS.GatherFoodCompleted,
		
		SetupUI = GatherFood_UI,
		
		OnStart = GatherFood_Start,
		
		PreComplete = function ()
			if Objective_IsStarted(	OBJ_Tip_GatherFood) then
				Objective_Complete(OBJ_Tip_GatherFood,false,false)
			end
		end,
		
		OnComplete = GatherFood_OnComplete,
	}
	
	SOBJ_ProduceVillagers = {
	
		Title = Loc_FormatText("$11192638",i_desired_Villagers), -- Produce %1AMOUNT% additional villagers from the Town Center.
		Type = ObjectiveType_Primary,
		Parent = OBJ_DevelopEconomy,
		StartAlongsideParent = false, 
		
		Intel_Start = EVENTS.ProduceVillagersStart,
		Intel_Complete = EVENTS.ProduceVillagers_IntelComplete,
		
		SetupUI = ProduceVillagers_UI,
		PreStart = function()
			Player_SetSquadProductionAvailability(player1, BP_GetSquadBlueprint("unit_villager_1_eng"), ITEM_DEFAULT)
		end,
		
		OnStart = ProduceVillagers_Start,
		PreComplete = function ()
			if Objective_IsStarted(	OBJ_Tip_ProduceVillagers) then
				Objective_Complete(OBJ_Tip_ProduceVillagers,false,false)
			end
		end,
		OnComplete = ProduceVillagers_OnComplete,
	}
	
	SOBJ_BuildMill = {
	
		Title = 11193025, --Build a Mill
		Type = ObjectiveType_Build,
		Parent = OBJ_DevelopEconomy,
		StartAlongsideParent = false, 
		
		Intel_Start = EVENTS.BuildMill_IntelStart,
	--	Intel_Complete = EVENTS.ProduceVillagers_IntelComplete,
		
		PreStart = function()
			Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_ECON_FOOD_CONTROL_ENG, ITEM_DEFAULT)
			Rule_AddGlobalEvent(EconDarkAge_OnConstructionComplete, GE_ConstructionComplete)
		end,
		
		SetupUI = BuildMill_UI,
		
		OnStart = BuildMill_Start,
		
		IsComplete = function()
			return (i_built_Mills >= 1)
		end,
		
		PreComplete = function ()
			if Objective_IsStarted(	OBJ_Tip_BuildMill) then
				Objective_Complete(OBJ_Tip_BuildMill,false,false)
			end
		end,

		OnComplete = BuildMill_OnComplete,
	}
	
	SOBJ_GatherWood = {
	
		Title = Loc_FormatText("$11192666", i_desiredWoodAmount), --Gather %1AMOUNT% additional wood resource.
		Type = ObjectiveType_Primary,
		Parent = OBJ_DevelopEconomy,
		StartAlongsideParent = false, 
		
		Intel_Start = EVENTS.GatherWood_IntelStart,
		Intel_Complete = EVENTS.GatherWood_IntelComplete,
		
		SetupUI = GatherWood_UI,
		
		OnStart = GatherWood_Start,

		PreComplete = function ()
			if Objective_IsStarted(	OBJ_Tip_GatherWood) then
				Objective_Complete(OBJ_Tip_GatherWood,false,false)
			end
		end,
		
		OnComplete = GatherWood_OnComplete,
	}
	
	SOBJ_BuildLumberCamp = {
		
		Title = 11193026, --Build a Lumber Camp
		Type = ObjectiveType_Primary,
		Parent = OBJ_DevelopEconomy,
		StartAlongsideParent = false, 
		
		Intel_Start = EVENTS.BuildLumberCamp_IntelStart,
		Intel_Complete = EVENTS.BuildLumberCamp_IntelComplete,
		
		SetupUI = BuildLumberCamp_UI,
		
		PreStart = function()
			Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_ECON_WOOD_CONTROL_ENG, ITEM_DEFAULT)
		end,
		
		OnStart = BuildLumberCamp_Start,
		IsComplete = function()
			return (i_built_LumberCamps >= 1)
		end,
		
		PreComplete = function()
			if Objective_IsStarted(OBJ_Tip_BuildLumberCamp) == true then
				Objective_Complete(OBJ_Tip_BuildLumberCamp,false,false)
			end
		end,
		OnComplete = BuildLumberCamp_OnComplete,
	}
	
	
	
	SOBJ_BuildFarms = {
		Title = Loc_FormatText("$11192661",i_desired_Farms), -- Build %1AMOUNT% farms.
		Type = ObjectiveType_Build,
		Parent = OBJ_DevelopEconomy,
		StartAlongsideParent = false, 
		
		Intel_Start = EVENTS.BuildFarms_IntelStart,
		
		SetupUI = BuildFarms_UI,
		
		PreStart = function()
			Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_RESOURCE_FARM_ENG, ITEM_DEFAULT)
			
		end,
		
		OnStart = BuildFarms_Start,

		IsComplete = function()
			return (i_built_Farms >= i_desired_Farms)
		end,

		PreComplete = function ()
			if Objective_IsStarted(	OBJ_Tip_BuildFarms) then
				Objective_Complete(OBJ_Tip_BuildFarms,false,false)
			end
		end,
		
		OnComplete = BuildFarms_OnComplete,
	}
	
	SOBJ_BuildHouses = {
		Title = Loc_FormatText("$11192668",i_desired_Houses), -- Build %1AMOUNT% houses.
		Type = ObjectiveType_Build,
		Parent = OBJ_DevelopEconomy,
		StartAlongsideParent = false, 
		
		Intel_Start = EVENTS.BuildHouses_IntelStart,
		Intel_Complete = EVENTS.BuildHouses_IntelComplete,
		
		SetupUI = BuildHouses_UI,
		
		PreStart = function()
			-- unlock house production
			Player_SetEntityProductionAvailability(player1, BP_GetEntityBlueprintsWithType("house"), ITEM_DEFAULT)
		end,
		
		OnStart = BuildHouses_Start,

		IsComplete = function()
			return (i_built_Houses >= i_desired_Houses)
		end,
		
		PreComplete = function ()
			if Objective_IsStarted(	OBJ_Tip_BuildHouses) then
				Objective_Complete(OBJ_Tip_BuildHouses,false,false)
			end
		end,
		
		OnComplete = BuildHouses_OnComplete,
	}


	Objective_Register(OBJ_DevelopEconomy)
	Objective_Register(SOBJ_GatherFood)
	Objective_Register(SOBJ_ProduceVillagers)
	Objective_Register(SOBJ_BuildMill)
	Objective_Register(SOBJ_GatherWood)
	Objective_Register(SOBJ_BuildLumberCamp)
	Objective_Register(SOBJ_BuildHouses)
	Objective_Register(SOBJ_BuildFarms)

end


function GatherFood_Start()
	Tutorials_MissionZero_GatherFood()
	Tutorials_MissionZero_SelectDragUnits()
	Rule_Add(GatherFood_Monitor)
	Rule_AddOneShot(StartFoodTip,3)
end

function StartFoodTip()
	Objective_Start(OBJ_Tip_GatherFood, false, false)

end

function GatherFood_Monitor()
	
	local currentFoodAmount = Player_GetResource(player1, RT_Food)
	local amountFoodGathered = currentFoodAmount - i_lastCheckedFoodAmount	
	
	if amountFoodGathered >= 1 then 
		
		Objective_IncreaseCounter(SOBJ_GatherFood, amountFoodGathered)
		
		if Objective_GetCounter(SOBJ_GatherFood) >= i_desiredFoodAmount then 
			Objective_Complete(SOBJ_GatherFood)
			Rule_RemoveMe()
		end
		
	end
	
	i_lastCheckedFoodAmount = currentFoodAmount
	
end


function GatherFood_UI()
	
	Objective_SetCounter(SOBJ_GatherFood, 0, i_desiredFoodAmount)
	hpid_GatherFood = Objective_AddUIElements(SOBJ_GatherFood, mkr_berries_obj, true,11192637, true,3) --"food"

end


function GatherFood_OnComplete()
	
	Objective_RemoveUIElements(SOBJ_GatherFood,hpid_GatherFood)
	Objective_Start(SOBJ_ProduceVillagers,true,true)

	
end



function ProduceVillagers_Start()
	Tutorials_MissionZero_HighlightVillagers()
	Tutorials_MissionZero_IdleVillagers()

	Rule_Add(ProduceVillagers_Monitor)

	Objective_Start(OBJ_Tip_ProduceVillagers, false, false)
	
end

function ProduceVillagers_UI()
	
	Objective_SetCounter(SOBJ_ProduceVillagers, 0, i_desired_Villagers)

end

function ProduceVillagers_Monitor()

	
	Player_GetAll(World_GetPlayerAt(1))
	SGroup_Filter(sg_allsquads, "scar_villager", FILTER_KEEP)
	
	currentVillagers = SGroup_CountSpawned(sg_allsquads)
	local newVillagers = currentVillagers - i_lastCheckedVillagers	

	if newVillagers >= 1 then 
		
		Objective_IncreaseCounter(SOBJ_ProduceVillagers, newVillagers)
		
		if Objective_GetCounter(SOBJ_ProduceVillagers) >= i_desired_Villagers then 
			Objective_Complete(SOBJ_ProduceVillagers)
			Rule_RemoveMe()
		end
		
	end
	
	i_lastCheckedVillagers = currentVillagers
end	

function ProduceVillagers_OnComplete()
	
	Objective_Start(SOBJ_BuildMill)
	
end

function BuildMill_UI()
	
end

function BuildMill_Start()
	Tutorials_MissionZero_HighlightMill()
	Rule_AddOneShot(StartTipMill,3)
end

function BuildMill_OnComplete()
	
	i_lastCheckedWoodAmount = i_lastCheckedWoodAmount - 50
	
	Objective_Start(SOBJ_GatherWood,true,true)
end

function BuildLumberCamp_UI()
	
end

function BuildLumberCamp_Start()
	Tutorials_MissionZero_HighlightLumberCamp()
	Rule_AddOneShot(StartTipLumberCamp,3)
end

function StartTipLumberCamp()
	if not Objective_IsComplete(SOBJ_BuildLumberCamp) then
		Objective_Start(OBJ_Tip_BuildLumberCamp, false, false)
	end
end

function BuildLumberCamp_OnComplete()
	
	Objective_Start(SOBJ_BuildHouses,true,true)
end


function BuildFarms_UI()
	Objective_SetCounter(SOBJ_BuildFarms, i_built_Farms, i_desired_Farms)
end

function BuildFarms_Start()
	Tutorials_MissionZero_HighlightFarm()
	Rule_AddOneShot(StartTip_BuildFarms,3)
	Rule_AddInterval(MonitorNumberFarms,1)
	
end

function MonitorNumberFarms()
	Player_GetAll(player1)
	EGroup_Filter(eg_allentities,EBP.ENGLISH.BUILDING_RESOURCE_FARM_ENG,FILTER_KEEP)
	EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
	
	local farmCount = EGroup_CountSpawned(eg_allentities)
	
	if farmCount > 0 then
		if hp_firstfarmbuilt == nil then
			EGroup_Clear(eg_bestFarm)
			EGroup_Add(eg_bestFarm, EGroup_GetEntityAt(eg_allentities,1))
			hp_firstfarmbuilt = HintPoint_Add(eg_bestFarm,true,11195506,5)
		end
		
		local numberFarmsUsed = 0
		for x = 1, farmCount do
			local deposit = EGroup_GetEntityAt(eg_allentities,x)
			if Entity_GetNumInteractors(deposit, "resource_worked") > 0 then
				numberFarmsUsed = numberFarmsUsed + 1
			end
		end
		if numberFarmsUsed >= 5 then
			HintPoint_Remove(hp_firstfarmbuilt)
			print("removing hint for farms")
			Rule_RemoveMe()
		end
		
		if Objective_IsStarted (SOBJ_BuildFarms) and not Objective_IsComplete (SOBJ_BuildFarms) then
			i_built_Farms = farmCount
			Objective_SetCounter(SOBJ_BuildFarms, i_built_Farms, i_desired_Farms)
		end
	else
		if hp_firstfarmbuilt ~= nil then
			HintPoint_Remove(hp_firstfarmbuilt)
			hp_firstfarmbuilt = nil
		end
	end
	
end


function StartTip_BuildFarms()
	if not Objective_IsComplete(SOBJ_BuildFarms)then
		Objective_Start(OBJ_Tip_BuildFarms, false, false)
	end
end

