		Objective_Start(OBJ_Tip_GatherWood, false, false)
	end
end

function GatherWood_Monitor()
	
	local currentWoodAmount = Player_GetResource(player1, RT_Wood)
	local amountWoodGathered = currentWoodAmount - i_lastCheckedWoodAmount	
	
	if amountWoodGathered >= 1 then 
		
		Objective_IncreaseCounter(SOBJ_GatherWood, amountWoodGathered)
		
		if Objective_GetCounter(SOBJ_GatherWood) >= i_desiredWoodAmount then 
			Objective_Complete(SOBJ_GatherWood)
			Rule_RemoveMe()
		end
		
	end
	
	i_lastCheckedWoodAmount = currentWoodAmount

end

