function CheckObjectivesInfantryObjDone_Monitor()
	if destroyedBarracksObj == true and killedSpearmanObj == true and longbowmanCliffObjCompleted == true then
		Objective_Complete(OBJ_AttackInfantryEncampment)
	end		
end

function DestroyTheInfantryEncampment_OnComplete()
	if Objective_IsComplete(SOBJ_SetupLongbowmenOnCliff) == false then
		Objective_Complete(SOBJ_SetupLongbowmenOnCliff,false,false)
	end
	destroyedBarracksObj = true
end


function AttackInfantryEncampment_OnComplete()
	Objective_Start(OBJ_ProgressCastleAge)
end


function MissionZero_ForceVillagersToFlee(targetVillagerLife)
	
	-- if all the villagers are already gone, do nothing
	if SGroup_CountSpawned(targetVillagerLife.sg_villagers) == 0 then
		return
	end
	
	Modifier_RemoveAllFromSGroup(targetVillagerLife.sg_villagers)
	
	Modify_UnitSpeed(targetVillagerLife.sg_villagers, 1.15)
	
	if targetVillagerLife.is_fleeing ~= true then
		targetVillagerLife.is_fleeing = true
	end
	
	Sound_PlayWallaFearOnSGroup(targetVillagerLife.sg_villagers)
	
	Cmd_Move(targetVillagerLife.sg_villagers, targetVillagerLife.mkr_flee)
end
