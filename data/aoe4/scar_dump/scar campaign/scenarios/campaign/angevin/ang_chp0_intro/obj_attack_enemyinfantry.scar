
---
--- Mission Zero - Infantry encampment
---
---

function IntroAttackInfantry_InitObjectives()	

	OBJ_AttackInfantryEncampment = {
		
		Title = "$11192888", -- Attack the Enemy Infantry Encampment
		Type = ObjectiveType_Battle,
		
		Intel_Start = EVENTS.AttackInfantryEncampment_IntelStart,
		Intel_Complete = EVENTS.AttackInfantryEncampment_IntelComplete,

		OnStart = function ()
			Objective_Start(SOBJ_BuildArcheryRange)
			
		end,
		
		PreComplete = function ()
			if Objective_IsStarted(	OBJ_Tip_CombatVsInfantry) then
				Objective_Complete(OBJ_Tip_CombatVsInfantry,false,false)
			end
		end,
		
		OnComplete = AttackInfantryEncampment_OnComplete,
		
		Cheat = Cheat_AttackInfantry,
		
	}
	
	SOBJ_BuildArcheryRange = {
		
		Title = Loc_FormatText("$11193295", i_amount_archeryranges), -- Build an Archery Range
		Type = ObjectiveType_Build,
		Parent = OBJ_AttackInfantryEncampment,
		StartAlongsideParent = false, 
		
		Intel_Start = EVENTS.BuildArcheryRange_IntelStart,
		
		SetupUI = SOBJ_BuildArcheryRange_UI,
		
		OnStart = SOBJ_BuildArcheryRange_Start,
		
		PreComplete = function ()
			if Objective_IsStarted(	OBJ_TipBuildArcheryRange) then
				Objective_Complete(OBJ_TipBuildArcheryRange,false,false)
			end
		end,
		
		OnComplete = SOBJ_BuildArcheryRange_OnComplete,
	}
	
	SOBJ_ProduceArchers = {
		
		Title = Loc_FormatText("$11192891",i_amount_longbowman_produce), -- Produce 20 Longbowman units
		Type = ObjectiveType_Primary,
		Parent = OBJ_AttackInfantryEncampment,
		StartAlongsideParent = false, 
		
		Intel_Start = EVENTS.ProduceArchers_IntelStart,
		
		SetupUI = ProduceArchers_UI,
		
		PreStart = function()
			Player_SetSquadProductionAvailability(player1, BP_GetSquadBlueprint("unit_archer_2_eng"), ITEM_DEFAULT)
			Tutorials_MissionZero_Highlightlongbowmen()
		end,
		
		OnStart = ProduceArchers_Start,
		
		PreComplete = function ()
			if Objective_IsStarted(	OBJ_Tip_ProduceArchers) then
				Objective_Complete(OBJ_Tip_ProduceArchers,false,false)
			end
		end,
		
		OnComplete = ProduceArchers_OnComplete,
	}
	
	
	SOBJ_SetupLongbowmenOnCliff = {
		
		Title = "$11193185", -- Setup the Longbowmen on the clifftop
		Type = ObjectiveType_Battle,
		Parent = OBJ_AttackInfantryEncampment,
		StartAlongsideParent = false, 
		
		--Intel_Start = EVENTS.MoveToCliff_IntelStart,
		
		SetupUI = SetupLongbowmenCliff_UI,
		
		PreStart = function()
			FOW_RevealMarker(mkr_horseman_clifftop,-1)
			FOW_RevealMarker(mkr_spearman_village,-1)
			SetupLongbowmenCliff_Start()
		end,
		
		--OnStart = SetupLongbowmenCliff_Start,
		
		PreComplete = function ()
			if Objective_IsStarted(	OBJ_Tip_SetupArchers) then
				Objective_Complete(OBJ_Tip_SetupArchers,false,false)
			end
		end,
		
		OnComplete = SetupLongbowmenCliff_OnComplete,
	}
	
	SOBJ_KillSpearman = {
		
		Title = "$11192892", -- Kill the spearmen in the French Encampment.
		Type = ObjectiveType_Battle,
		Parent = OBJ_AttackInfantryEncampment,
		StartAlongsideParent = false, 
		
		Intel_Start = EVENTS.KillSpearmen_IntelStart,
		Intel_Complete = EVENTS.KillSpearmen_IntelComplete,
		
		SetupUI = KillSpearman_UI,
		
		OnStart = KillSpearman_Start,
		
		OnComplete = KillSpearman_OnComplete,
	}
	
	--SOBJ_DestroyTheInfantryEncampment = {
		
		--Title = "$11192893", -- Destroy the French Infantry Encampment's buildings
		--Type = ObjectiveType_Battle,
		--Parent = OBJ_AttackInfantryEncampment,
		--StartAlongsideParent = false, 
		
	----	Intel_Complete = EVENTS.DestroyBarracks_IntelComplete,
		
		--SetupUI = DestroyTheInfantryEncampment_UI,
		
		--OnStart = DestroyTheInfantryEncampment_Start,
		
		--OnComplete = DestroyTheInfantryEncampment_OnComplete,
	--}
	
	Objective_Register(OBJ_AttackInfantryEncampment)
	Objective_Register(SOBJ_BuildArcheryRange)
	Objective_Register(SOBJ_ProduceArchers)
	Objective_Register(SOBJ_SetupLongbowmenOnCliff)
	Objective_Register(SOBJ_KillSpearman)
--	Objective_Register(SOBJ_DestroyTheInfantryEncampment)
	
	
end

function SOBJ_BuildArcheryRange_UI()
	Objective_SetCounter(SOBJ_BuildArcheryRange, 0, i_amount_archeryranges)
	Objective_AddGroundReticule(SOBJ_BuildArcheryRange, mkr_archeryrange_buildarea, Marker_GetProximityRadius(mkr_archeryrange_buildarea), BP_GetReticuleBlueprint("campaign_capturelocation_self"))
	Objective_AddUIElements(SOBJ_BuildArcheryRange, mkr_archeryrange_buildarea, true, Loc_FormatText("$11192890", i_amount_archeryranges), true)
	
	--Allow archery range to be built after the counter has been set. There was a bug where building a stable before the
	--counter was set caused a crash. Applying the stable fix to archery ranges too.
	Player_SetEntityProductionAvailability(player1, BP_GetEntityBlueprint("building_unit_ranged_control_eng"), ITEM_DEFAULT)
	Tutorials_MissionZero_HighlightArcheryRange()
end

function SOBJ_BuildArcheryRange_Start()
	
	Sound_Play2D("sfx_walla_celebrate_small_mixed_gender")
	Sound_Play2D("mus_stinger_campaign_positive")
	EventCues_CallToAction("$11193255",CTA_CELEBRATE,EVENTS.MoreVillagers, PostCTAArcheryRange, sg_eng_villagers_archeryrange,10) --"Villagers joining you
	UnitEntry_DeploySquads(player1, sg_eng_villagers_archeryrange, {{type = "scar_villager", destination = mkr_archer_village, numSquads = 3 }}, mkr_villager_joinplayer02)	
	Rule_AddOneShot(AddArcheryRangeHintObj,3)
	
end

function PostCTAArcheryRange()
	clickedCTAArcheryRange = true
	
end

function AddArcheryRangeHintObj()

	if not Objective_IsComplete(SOBJ_BuildArcheryRange) then
		Objective_Start(OBJ_TipBuildArcheryRange, false, false)
	end
end

function SOBJ_BuildArcheryRange_OnComplete()
	Objective_Start(SOBJ_ProduceArchers)
end

function ProduceArchers_UI()
	

	Objective_SetCounter(SOBJ_ProduceArchers, 0, i_amount_longbowman_produce)

end

function ProduceArchers_Start()
	
	Rule_Add(ProduceArchers_Monitor)	
	Rule_AddOneShot(ProduceArchersTip,3)

end

function ProduceArchersTip()

	if not Objective_IsComplete(SOBJ_ProduceArchers) then
		Objective_Start(OBJ_Tip_ProduceArchers, false, false)
	end
end

function ProduceArchers_Monitor()
	
	Player_GetAll(World_GetPlayerAt(1))
	SGroup_Filter(sg_allsquads, "scar_archer", FILTER_KEEP)
	
	local currentArchers = SGroup_CountSpawned(sg_allsquads)

	Objective_SetCounter(SOBJ_ProduceArchers, currentArchers, i_amount_longbowman_produce)
	
	if currentArchers >= 1 then
		b_producedArcher = true 	
	end
	
	if currentArchers >= i_amount_longbowman_produce then 
		Objective_Complete(SOBJ_ProduceArchers)
		Rule_RemoveMe()
		
	end
	
	
end

function ProduceArchers_OnComplete()
	Objective_Start(SOBJ_SetupLongbowmenOnCliff)
	
	World_SetInteractionStage(4)
end

function SetupLongbowmenCliff_UI()
	hpid_clifftop = Objective_AddUIElements(SOBJ_SetupLongbowmenOnCliff, mkr_horseman_clifftop_archersLoc, true,"$11193186", true,3) -- Clifftop
end

function SetupLongbowmenCliff_Start()
	
	Sound_Play2D("mus_stinger_campaign_alert")
	Sound_Play2D("sfx_campaign_scripted_small_group_din_engage")
	EventCues_CallToAction("$11194651" ,CTA_UNIQUE_STAKES, EVENTS.MoveToCliff_IntelStart, nil, mkr_spearman_village_lookat, 20) --"Enemy Spearmen!"
	Rule_Add(LongbowmenOnCliff_Monitor)
	Rule_Add(CheckObjectivesInfantryObjDone_Monitor)
	Rule_AddInterval(SpearmanDeadMonitor,1)
	Rule_AddInterval(BarrackDestroyedMonitor,1.5)
	
	Rule_AddOneShot(SetupArchersTip, 3)
	
end

function SetupArchersTip()

	if not Objective_IsComplete(SOBJ_SetupLongbowmenOnCliff) then
		Objective_Start(OBJ_Tip_SetupArchers, false, false)
	end
end

function SpearmanDeadMonitor()
	if SGroup_CountSpawned(sg_spearmanVillage_spearman) == 0 then 
		killedSpearmanObj = true
		Rule_RemoveMe()
		if Objective_IsComplete(SOBJ_SetupLongbowmenOnCliff) == false then 
			Objective_Complete(SOBJ_SetupLongbowmenOnCliff,false,false)
		end
	end
end

function BarrackDestroyedMonitor()
	if EGroup_CountSpawned(eg_spearman_encampment) == 0 then
		destroyedBarracksObj = true
		Rule_RemoveMe()
		if Objective_IsComplete(SOBJ_SetupLongbowmenOnCliff) == false then 
			Objective_Complete(SOBJ_SetupLongbowmenOnCliff,false,false)
		end

	end
end

function LongbowmenOnCliff_Monitor()
	
	local sg_nearclifftop = SGroup_CreateIfNotFound("sg_nearclifftop")
	SGroup_Clear(sg_nearclifftop)
	
	Player_GetAll(player1)
	SGroup_Filter(sg_allsquads,"scar_archer",FILTER_KEEP)
	
	Player_GetAllSquadsNearMarker(player1,sg_nearclifftop,mkr_horseman_clifftop,25)
	
	if Prox_AreSquadsNearMarker(sg_allsquads,mkr_horseman_clifftop,ANY,25) == true and SGroup_CountSpawned(sg_nearclifftop) >= 18 then
		Objective_Complete(SOBJ_SetupLongbowmenOnCliff)
		Rule_RemoveMe()
	end
	
end

function SetupLongbowmenCliff_OnComplete()
	
	Objective_RemoveUIElements(SOBJ_SetupLongbowmenOnCliff, hpid_clifftop)

	if SGroup_CountSpawned(sg_spearmanVillage_spearman) == 0 then 
		killedSpearmanObj = true
		-- force all the local enemy villagers to flee once the spearment are dead
		MissionZero_ForceVillagersToFlee(villagerlife_spearmantown)
		MissionZero_ForceVillagersToFlee(villagerlife_spearmantown_02)
		Objective_Complete(OBJ_AttackInfantryEncampment)
		
		--if EGroup_CountSpawned(eg_spearman_encampment) == 0 then 
			--destroyedBarracksObj = true
		--else
			--Objective_Start(SOBJ_DestroyTheInfantryEncampment)
		--end
	else
		Objective_Start(SOBJ_KillSpearman)
	end
	
	longbowmanCliffObjCompleted = true 
end


function KillSpearman_UI()
	--hpid_SpearmanTown = Objective_AddUIElements(OBJ_AttackInfantryEncampment, mkr_spearman_village, true,"$11192897", true,3) --"French Spearman encampment"

	Objective_SetProgressBar(SOBJ_KillSpearman, 0)
end

function KillSpearman_Start()
	
	i_maxInfantryKill = SGroup_CountSpawned(sg_spearmanVillage_spearman)
	
	-- put the spearmen into an sgroup that won't change.
	SGroup_AddGroup(sg_spearmanVillage_count, sg_spearmanVillage_spearman)
	
	-- add a squad killed event on that sgroup
	Rule_AddSGroupEvent(EnemyKilledSpearmanEncampment, sg_spearmanVillage_count, GE_SquadKilled)

	SendSpearmanToAttackPlayer()
	
	Rule_Remove(SpearmanDeadMonitor)
	
	Objective_Start(OBJ_Tip_CombatVsInfantry, false, false)
end


function SendSpearmanToAttackPlayer()
	
	if SGroup_CountSpawned(sg_spearmanVillage_spearman) > 0 then 
		DissolveModuleIntoModule("Enemy_spearman_guards", "Spearman_village_attack_roving")
	else
		Objective_Complete(SOBJ_KillSpearman,false,false)
		Rule_RemoveSGroupEvent(EnemyKilledSpearmanEncampment, sg_spearmanVillage_count)
	end
end

function EnemyKilledSpearmanEncampment(context)
	
	local isComplete = false	
	if Objective_IsComplete(SOBJ_KillSpearman) == true then
		Rule_RemoveMe()
	elseif SGroup_CountSpawned(sg_spearmanVillage_count) < 1 then
		isComplete = true
	else
		i_deathInfantryEncampment = i_deathInfantryEncampment + 1
		if i_deathInfantryEncampment < i_maxInfantryKill then
			Objective_SetProgressBar(SOBJ_KillSpearman, (i_deathInfantryEncampment / i_maxInfantryKill))
		else
			isComplete = true
		end
	end
	if isComplete then
		Objective_SetProgressBar(SOBJ_KillSpearman, 1)
		Objective_Complete(SOBJ_KillSpearman, false, false)
		Rule_RemoveMe()
	end
end

function KillSpearman_OnComplete()
	-- force all the local enemy villagers to flee once the spearment are dead
	MissionZero_ForceVillagersToFlee(villagerlife_spearmantown)
	MissionZero_ForceVillagersToFlee(villagerlife_spearmantown_02)
	
	
	Objective_Complete(OBJ_AttackInfantryEncampment)
	
	killedSpearmanObj = true
end

function DestroyTheInfantryEncampment_UI()

	if hpid_SpearmanTown == nil then
		hpid_SpearmanTown = Objective_AddUIElements(OBJ_AttackInfantryEncampment, mkr_spearman_village, true,"$11192897", true,3) --"French Spearman encampment"
	end
end

function DestroyTheInfantryEncampment_Start()
--	Rule_AddEGroupEvent(DestroySpearman_EntityKilled, eg_spearman_encampment, GE_EntityKilled) --Start watching what gets killed
	Rule_Add(DestroyInfantryCamp_Monitor)
	
	Rule_Remove(BarrackDestroyedMonitor)
end

function DestroyInfantryCamp_Monitor()
	
	if EGroup_CountSpawned(eg_spearman_encampment) == 0 then
		Objective_Complete(SOBJ_DestroyTheInfantryEncampment)
		Rule_RemoveMe()
	end
end

