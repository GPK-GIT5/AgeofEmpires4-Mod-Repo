
--- Mission Zero
--- objective tips for dark age section
---


function IntroTipsDarkAge_InitObjectives()
	
	OBJ_Tip_GatherFood = {

		Title = 11192633, --To gather food, select a villager and RIGHT-CLICK on a Food Resource.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipGatherFood_OnComplete,
	}	
	
	OBJ_Tip_ProduceVillagers = {
		Title = 11195212, --To produce a Villager, LEFT CLICK on the Town Center and LEFT CLICK on the Villager icon.
		Type = ObjectiveType_Tip,
		showTitle = false,
	}
	
	OBJ_Tip_BuildMill = {
		Title = 11193028, --To build a Mill, select a villager, LEFT-CLICK on the Mill icon and click on the ground close to a Food Resource.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipBuildMill_OnComplete,
		
	}
	
	OBJ_Tip_GatherWood = {
		Title = 11195213, --To gather Wood, select a Villager and RIGHT CLICK on a tree.
		Type = ObjectiveType_Tip,
		showTitle = false,
	}

	OBJ_Tip_BuildFarms = {
		Title = 11192665, --To build Farms, select a villager, LEFT-CLICK on the Farm icon and click on the ground to start building the Farm.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipBuildFarms_OnComplete,
		
	}
	
	OBJ_Tip_BuildHouses = {
		Title = 11192670, --To build Houses, select a villager, LEFT-CLICK on the House icon and click on the ground to start building it.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipBuildHouses_OnComplete,
		
	}
	
	OBJ_Tip_BuildLumberCamp = {
		Title = 11194950, --To build a Lumber Camp, select a villager, LEFT-CLICK on the Lumber Camp icon and click on the ground to start building it.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipBuildLumberCamp_OnComplete,
	}

	OBJ_Tip_ProduceScout = {
		Title = 11195214, --To produce a Scout, LEFT CLICK on the Town Center and LEFT CLICK on the Scout icon.
		Type = ObjectiveType_Tip,
		showTitle = false,
	}

	OBJ_Tip_FindGoldDeposit = {
		Title = 11195216, --To find a Gold Deposit, LEFT CLICK to select your Scout and RIGHT CLICK farther away on the map to send the Scout exploring. As they move, the Scout will reveal the hidden parts of the map.
		Type = ObjectiveType_Tip,
		showTitle = false,
	}
	
	OBJ_Tip_BuildMine = {
		Title = 11192718, --To build a Mining Camp, select a villager, LEFT-CLICK on the Mining Camp icon and click on the ground close to a Gold Deposit to start building it.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipBuildMiningCamp_OnComplete,
		
	}
	
	OBJ_Tip_GatherGold = {

		Title = 11192725, --To gather gold, select a villager and RIGHT-CLICK on a Gold Deposit.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipGatherGold_OnComplete,
	}
	
	OBJ_Tip_AgeUpFeudal = {

		Title = 11192727, --To age up to Feudal Age, select a Villager and Left-Click on the II icon.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipAgeUpFeudal_OnComplete,
	}
	
	OBJ_Tip_AgeUpFeudalMoreVillagers = {

		Title = 11192775, --To construct the Landmark faster, assign more Villagers to it.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipAgeUpFeudalMoreVillagers_OnComplete,
	}
	
	Objective_Register(OBJ_Tip_GatherFood)
	Objective_Register(OBJ_Tip_ProduceVillagers)
	Objective_Register(OBJ_Tip_BuildMill)
	Objective_Register(OBJ_Tip_GatherWood)	
	Objective_Register(OBJ_Tip_BuildHouses)
	Objective_Register(OBJ_Tip_BuildFarms)
	Objective_Register(OBJ_Tip_BuildLumberCamp)
	Objective_Register(OBJ_Tip_ProduceScout)	
	Objective_Register(OBJ_Tip_FindGoldDeposit)
	Objective_Register(OBJ_Tip_BuildMine)
	Objective_Register(OBJ_Tip_GatherGold)
	Objective_Register(OBJ_Tip_AgeUpFeudal)
	Objective_Register(OBJ_Tip_AgeUpFeudalMoreVillagers)
	
	
end




