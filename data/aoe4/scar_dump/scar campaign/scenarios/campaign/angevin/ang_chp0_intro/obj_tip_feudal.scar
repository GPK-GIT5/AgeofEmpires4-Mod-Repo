
---
--- Mission Zero - Tips for Feudal Age
---
---

function IntroTipsFeudal_InitObjectives()
	
	OBJ_Tip_NotEnoughFood = {
		
		Title = 11195536, --You need more Food. Build more Farms near your Mill and assign Villagers to harvest from them.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipNotEnoughFood_OnComplete,

	}
	
	OBJ_Tip_NotEnoughWood = {
		
		Title = 11195537, --You need more Wood. Assign Villagers to harvest from trees near a Lumber Camp.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipNotEnoughWood_OnComplete,

	}
	
	OBJ_Tip_MakeMoreVillagers = {
		
		Title = 11195512, --Produce additional Villagers at the Town Center and assign them to gather resources to ensure you always have enough.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipMakeMoreVillagers_OnComplete,

	}
	
	OBJ_Tip_doubleclickunits = {
		
		Title = 11195535, --DOUBLE LEFT CLICK on a Spearman to select all such units on screen.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipDoubleClickSelect_OnComplete,

	}
	
	OBJ_Tip_Attack = {

		Title = 11192810, --To attack the Palisade, Select your horsemen units and RIGHT-Click on the Palisade.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipAttackPalisade_OnComplete,
	}	
	
	OBJ_Tip_BuildBarracks = {

		Title = 11192767, --To build Barracks, select a Villager, LEFT-CLICK on the Barracks icon and LEFT-CLICK on the ground to start building the Barracks.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipBuildBarracks_OnComplete,
	}	
	
	OBJ_Tip_ProduceSpearmen = {
		Title = 11192768, --To produce Spearman units, Select your Barracks, Left-Click on the Spearman unit icon.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipProduceSpearmen_OnComplete,
		
	}
	
	OBJ_Tip_BuildMultipleStables = {
		Title = 11193035, -- To increase production speed of Horseman units, build multiple Stables.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipBuildMultipleStables_OnComplete,
		
	}
	
	OBJ_Tip_AttackMove = {
		Title = 11192802, --To Attack-Move, SELECT spearman units,PRESS (A) then LEFT CLICK on the ground around enemies or in the Fog of War.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = Tip_AttackMove_OnComplete,
		
	}
	
	OBJ_Tip_BuildStables = {
		
		Title = 11192877, --To build a Stables, select a Villager, LEFT-CLICK on the Stables icon and LEFT-CLICK on the ground to start building the Stables.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipBuildStables_OnComplete,

		
	}
	
	OBJ_TipBuildArcheryRange = {
		Title = 11192894, --To build an Archery range, select a Villager, LEFT-CLICK on the Archery Range icon and LEFT-CLICK on the ground to start building the Archery Range.
		Type = ObjectiveType_Tip,
		
		showTitle = false,
		
		OnComplete = TipBuildArcheryRange_OnComplete,

	}
	
	OBJ_Tip_CombatVsCavalry = {
		Title = 11195219, --To attack the enemy encampment, select your Spearmen and issue an Attack Move order near the enemy. RIGHT CLICK on a target if you want to concentrate on a single target.
		Type = ObjectiveType_Tip,
		showTitle = false,
	}
	
	OBJ_Tip_ProduceHorsemen = {
		Title = 11195221, --To produce Horsemen, DOUBLE LEFT CLICK on a Stable to select all Stables, and LEFT CLICK on the Horseman unit icon.
		Type = ObjectiveType_Tip,
		showTitle = false,
	}
	
	OBJ_Tip_CombatVsArchery = {
		Title = 11195220, --To attack the enemy encampment, select your Horsemen and issue an Attack Move order near the enemy. RIGHT CLICK on a target if you want to concentrate on a single target.
		Type = ObjectiveType_Tip,
		showTitle = false,
	}
	
	OBJ_Tip_ProduceArchers = {
		Title = 11195222, --To produce Longbowmen, DOUBLE LEFT CLICK on an Archery Range to select all Archery Ranges, and LEFT CLICK on the Longbowman unit icon.
		Type = ObjectiveType_Tip,
		showTitle = false,
	}
	
	OBJ_Tip_SetupArchers = {
		Title = 11195223, --To set up your Longbowmen, select all your Longbowmen and RIGHT CLICK on the marked clifftop.
		Type = ObjectiveType_Tip,
		showTitle = false,
	}
	
	OBJ_Tip_CombatVsInfantry = {
		Title = 11195224, --Leave your Longbowmen in place on the clifftop and let the enemy Spearmen come to you This will maximize your arrow fire.
		Type = ObjectiveType_Tip,
		showTitle = false,
	}
	
	OBJ_Tip_AgeUpCastle = {
		Title = 11195225, --To build a Landmark (and progress to the next Age), select a Villager, click on the III icon, choose your Landmark, and place it to start building.
		Type = ObjectiveType_Tip,
		showTitle = false,
	}
	
	Objective_Register(OBJ_Tip_Attack)
	Objective_Register(OBJ_Tip_BuildBarracks)
	Objective_Register(OBJ_Tip_ProduceSpearmen)
	Objective_Register(OBJ_Tip_MakeMoreVillagers)
	Objective_Register(OBJ_Tip_doubleclickunits)
	Objective_Register(OBJ_Tip_BuildMultipleStables)
	Objective_Register(OBJ_Tip_AttackMove)
	Objective_Register(OBJ_Tip_CombatVsCavalry)
	Objective_Register(OBJ_Tip_BuildStables)
	Objective_Register(OBJ_Tip_ProduceHorsemen)
	Objective_Register(OBJ_Tip_CombatVsArchery)
	Objective_Register(OBJ_TipBuildArcheryRange)
	Objective_Register(OBJ_Tip_ProduceArchers)
	Objective_Register(OBJ_Tip_SetupArchers)
	Objective_Register(OBJ_Tip_CombatVsInfantry)
	Objective_Register(OBJ_Tip_AgeUpCastle)	
	Objective_Register(OBJ_Tip_NotEnoughFood)
	Objective_Register(OBJ_Tip_NotEnoughWood)
end

