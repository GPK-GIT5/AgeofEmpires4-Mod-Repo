function Mission_SetupPlayers()
	
	--
	-- get player IDs for each player
	-- 
	
	player1 = World_GetPlayerAt(1) -- English
	player2 = World_GetPlayerAt(2) -- French
	player3 = World_GetPlayerAt(3) --allies

	
	-- player 1 - english
	Setup_SetPlayerName(player1, 11119080) --English
	Player_SetCurrentAge(player1, AGE_DARK)
	Player_SetMaximumAge(player1, AGE_DARK)
	
	-- player 2 - french
	Setup_SetPlayerName(player2, 11144801) --FRENCH
	Player_SetCurrentAge(player2, AGE_DARK)
	Player_SetMaximumAge(player2, AGE_DARK)

	Player_SetRelationship(player1, player2,R_ENEMY)
	Player_SetRelationship(player2, player1,R_ENEMY)
	--
	-- player 3 - neutral holder	
	Setup_SetPlayerName(player3, 11172025) --Neutral
	Player_SetCurrentAge(player3, AGE_DARK)
	Player_SetMaximumAge(player3, AGE_FEUDAL)
	
	-- set player relationships	
	--
	Player_SetRelationship(player1,player3,R_ALLY)
	Player_SetRelationship(player3,player1,R_ALLY)
	Player_SetRelationship(player2,player3,R_ALLY)

	
end


