function Villagers_StartingUnits()
		
	local villagers = {
	 {type = "scar_villager", numSquads = 3, spawn = mkr_player_town, destination = mkr_player_town_villagers_moveto},
	}
	
	UnitEntry_DeploySquads(player1, sg_villagers_player, villagers, mkr_player_town_villagers_moveto)
	
end

--? @shortdesc Watches for construction in dark age
function EconDarkAge_OnConstructionComplete(context)
	
	local buildingOwner = Entity_GetPlayerOwner(context.entity)
	if buildingOwner == player1 then
		
		if not Objective_IsComplete(SOBJ_BuildFarms) and Entity_IsOfType(context.entity, "farm") then
			
			i_built_Farms = i_built_Farms + 1
			
			if Objective_IsStarted(SOBJ_BuildFarms) then
				Objective_SetCounter(SOBJ_BuildFarms, i_built_Farms, i_desired_Farms)
				if i_built_Farms < i_desired_Farms then
					Music_PlayStinger("sfx_campaign_scripted_ui_objective_counter_update")
				end
			end
		elseif not Objective_IsComplete(SOBJ_BuildMill) and Entity_IsOfType(context.entity, "mill") then
			i_built_Mills = i_built_Mills + 1
		
		elseif not Objective_IsComplete(SOBJ_BuildLumberCamp) and Entity_IsOfType(context.entity, "lumber_camp") then
			i_built_LumberCamps = i_built_LumberCamps + 1	

		elseif not Objective_IsComplete(SOBJ_BuildHouses) and Entity_IsOfType(context.entity, "house") then
			i_built_Houses = i_built_Houses + 1	
			if Objective_IsStarted(SOBJ_BuildHouses) then
				Objective_SetCounter(SOBJ_BuildHouses, i_built_Houses, i_desired_Houses)
				if i_built_Houses < i_desired_Houses then
					Music_PlayStinger("sfx_campaign_scripted_ui_objective_counter_update")
				end
			end

		elseif not Objective_IsComplete(SOBJ_BuildMine) and Entity_IsOfType(context.entity, "mining_camp") then
			i_built_MiningCamps = i_built_MiningCamps + 1			
		end
		
		
	end
	
	
end


--? @shortdesc Watches for construction in feudal age
--? 
function MilitaryFeudal_OnConstructionComplete(context)
	
	local buildingOwner = Entity_GetPlayerOwner(context.entity)
	if buildingOwner == player1 then
		
		EGroup_Clear(eg_temp)
		EGroup_Add(eg_temp, context.entity)
		
		if not Objective_IsComplete(SOBJ_BuildBarrack) then
			if Entity_IsOfType(context.entity, "barracks") then
				b_barracks_built = true
				Objective_Complete(SOBJ_BuildBarrack)
				
			end
		end
		
		
		
		--if not Objective_IsComplete(SOBJ_BuildHouses) and Objective_IsCounterSet(SOBJ_BuildHouses) then
			--if Entity_IsOfType(context.entity, "house") then
				
				--Objective_IncreaseCounter(SOBJ_BuildHouses, 1)
				
				--if Obj_GetCounterCount(SOBJ_BuildHouses.ID) >= Obj_GetCounterMax(SOBJ_BuildHouses.ID) then
					
					--Objective_Complete(SOBJ_BuildHouses)
					
				--else
					--Music_PlayStinger("sfx_campaign_scripted_ui_objective_counter_update")
				--end
			--end
		--end
		
		if not Objective_IsComplete(SOBJ_BuildStables) then
			if Entity_IsOfType(context.entity, "stable") and Prox_AreEntitiesNearMarker(eg_temp, mkr_stables_buildarea, ANY, 30)then
				
				if not b_stables_built then
					b_stables_built = true			
				end
				
				Objective_IncreaseCounter(SOBJ_BuildStables, 1)
				EGroup_Add(eg_stablesForTutorial, context.entity)
				

				
				if Obj_GetCounterCount(SOBJ_BuildStables.ID) >= Obj_GetCounterMax(SOBJ_BuildStables.ID) then
					-- we add this callback here so the the egroup is full when we do
					-- if we add it earlier it gets confused when we add things to the egroup
					if not Rule_Exists(ListenForRallyPoint) then
						Rule_AddEGroupEvent(ListenForRallyPoint, eg_stablesForTutorial, GE_EntityCommandIssued)
					end
					
					Objective_Complete(SOBJ_BuildStables)
			
				else
					Music_PlayStinger("sfx_campaign_scripted_ui_objective_counter_update")
				end
				
			end
		end
		
		if not Objective_IsComplete(SOBJ_BuildArcheryRange) then
			if Entity_IsOfType(context.entity, "archery_range") and Prox_AreEntitiesNearMarker(eg_temp, mkr_archeryrange_buildarea, ANY, 30) then
				
				if not b_archeryRange_built then
					b_archeryRange_built = true			
				end
				
				Objective_IncreaseCounter(SOBJ_BuildArcheryRange, 1)
				
				if Obj_GetCounterCount(SOBJ_BuildArcheryRange.ID) >= Obj_GetCounterMax(SOBJ_BuildArcheryRange.ID) then
					
					Objective_Complete(SOBJ_BuildArcheryRange)
					Rule_RemoveMe()
				else
					Music_PlayStinger("sfx_campaign_scripted_ui_objective_counter_update")
				end
			end
		end
		
		
	end
	
end

