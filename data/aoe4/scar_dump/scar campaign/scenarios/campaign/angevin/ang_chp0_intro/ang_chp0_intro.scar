function Mission_PreStart()

	print ("Mission_PreStart -- MZ")
end

function Mission_Start()	-- this is triggered after the intro, just as control is passed to the player
	
	print ("Mission_Start -- MZ")
	

	Player_SetResource( player1, RT_Gold, i_lastCheckedGoldAmount) 
	Player_SetResource( player1, RT_Wood, i_lastCheckedWoodAmount) 
	Player_SetResource( player1, RT_Food, i_lastCheckedFoodAmount)
	
	--Action_SetResources_Do({ player = player2, resources = { food = 30000, wood = 30000, stone = 30000, gold = 30000 } })
	
	--FILTER CUSTOM CORE TUTORIALS LIST
	Disable_CoreTutorials_MinusExceptions()
	Objective_Start(OBJ_DevelopEconomy,true, true)
	
	Villagers_StartingUnits()
	Music_LockIntensity(MUSIC_EXPLORE)

	Rule_AddInterval(FindGoldDeposit_Monitor, 1)
		
end


