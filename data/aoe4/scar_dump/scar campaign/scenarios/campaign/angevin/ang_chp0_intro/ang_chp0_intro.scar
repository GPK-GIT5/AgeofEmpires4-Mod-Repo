	Modify_EntityBuildTime(player1, EBP.ENGLISH.BUILDING_ECON_MINING_CAMP_CONTROL_ENG, 0.5)
	Modify_EntityBuildTime(player1, EBP.ENGLISH.BUILDING_ECON_WOOD_CONTROL_ENG, 0.5)
	Modify_EntityBuildTime(player1, EBP.ENGLISH.BUILDING_HOUSE_CONTROL_ENG, 0.5)
	Modify_EntityBuildTime(player1, EBP.ENGLISH.BUILDING_RESOURCE_FARM_ENG, 0.5)
	Modify_EntityBuildTime(player1, EBP.ENGLISH.BUILDING_LANDMARK_AGE1_WESTMINSTER_ABBEY_ENG, 0.4)
	Modify_EntityBuildTime(player1, EBP.ENGLISH.BUILDING_LANDMARK_AGE2_WESTMINSTER_PALACE_ENG, 0.4)
	Modify_EntityBuildTime(player1, EBP.ENGLISH.BUILDING_LANDMARK_AGE2_WHITE_TOWER_ENG, 0.5)
	Modify_EntityBuildTime(player1, EBP.ENGLISH.BUILDING_UNIT_CAVALRY_CONTROL_ENG, 0.5)
	Modify_EntityBuildTime(player1, EBP.ENGLISH.BUILDING_UNIT_INFANTRY_CONTROL_ENG, 0.5)
	Modify_EntityBuildTime(player1, EBP.ENGLISH.BUILDING_UNIT_RANGED_CONTROL_ENG, 0.5)
	Modify_EntityBuildTime(player1, EBP.ENGLISH.UNIT_ARCHER_2_ENG, 0.5)
	Modify_EntityBuildTime(player1, EBP.ENGLISH.UNIT_HORSEMAN_2_ENG, 0.5)
	Modify_EntityBuildTime(player1, EBP.ENGLISH.UNIT_SCOUT_1_ENG, 0.5)
	Modify_EntityBuildTime(player1, EBP.ENGLISH.UNIT_SPEARMAN_2_ENG, 0.5)
	Modify_EntityBuildTime(player1, EBP.ENGLISH.UNIT_VILLAGER_1_ENG, 0.5)
	Modify_EntityBuildTime(player1, EBP.ENGLISH.BUILDING_TOWN_CENTER_CAPITAL_ENG, 0.1)
	
end


function FindGoldDeposit_Monitor()
	
	Player_GetAll(player1,sg_allsquads)
	
	if Prox_AreSquadsNearMarker(sg_allsquads,mkr_gold_mine_01,ANY,30) then
		b_foundGoldDeposit = true
		hintpoint_Gold = HintPoint_Add(mkr_gold_mine_01, true, "$11119542", 5)
		g_training_markers.vein = mkr_gold_mine_01
		g_training_markers.mineHint = mkr_hint_mine01
		Rule_RemoveMe()
	elseif Prox_AreSquadsNearMarker(sg_allsquads,mkr_gold_mine_02,ANY,30) then
		b_foundGoldDeposit = true
		hintpoint_Gold = HintPoint_Add(mkr_gold_mine_02, true, "$11119542", 5)
		g_training_markers.vein = mkr_gold_mine_02
		g_training_markers.mineHint = mkr_hint_mine02
		Rule_RemoveMe()
	end
end	


function ApproachingMaxPop_Monitor()
	
	local pop = Player_GetCurrentPopulation(player1, CT_Personnel)
	
	if pop >= 180 then
		Player_SetAbilityAvailability(player1, BP_GetAbilityBlueprint("core_unit_death"), ITEM_DEFAULT)
		Rule_RemoveMe()
	end
	
	
end


---------- cheat functions for starting mid mission ----



function Cheat_Explore_DarkAge ()
	
	Sound_Play2D(MIX_RETURN_TO_GAME)
	
	Util_CreateEntities(player1, eg_TC, EBP.ENGLISH.BUILDING_TOWN_CENTER_CAPITAL_ENG, mkr_player_town, 1)
	
	Player_SetSquadProductionAvailability(player1, BP_GetSquadBlueprint("unit_villager_1_eng"), ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, BP_GetEntityBlueprintsWithType("house"), ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_RESOURCE_FARM_ENG, ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_ECON_FOOD_CONTROL_ENG, ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_ECON_WOOD_CONTROL_ENG, ITEM_UNLOCKED)

	Player_SetResource( player1, RT_Food, 500) 
	Player_SetResource( player1, RT_Wood, 500) 

	Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_ECON_FOOD_CONTROL_ENG, mkr_cheat_mill, 1)	
	Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_ECON_WOOD_CONTROL_ENG, mkr_cheat_lumber, 1)	
	Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_HOUSE_CONTROL_ENG, mkr_cheat_house1, 1)
	Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_HOUSE_CONTROL_ENG, mkr_cheat_house2, 1)
	Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_HOUSE_CONTROL_ENG, mkr_cheat_house3, 1)
	Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_RESOURCE_FARM_ENG, mkr_cheat_farm1, 1)
	Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_RESOURCE_FARM_ENG, mkr_cheat_farm2, 1)
	Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_RESOURCE_FARM_ENG, mkr_cheat_farm3, 1)

	AssignVillagersToBerries(sg_villagers_player)
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player1, sg_temp, {type="scar_villager", numSquads = 3}, mkr_cheat_farm1)
	AssignVillagersToFarms(sg_temp)
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player1, sg_temp, {type="scar_villager", numSquads = 5}, mkr_cheat_lumber)
	AssignVillagersToWood(sg_temp)

	Disable_CoreTutorials_MinusExceptions()
	Tutorials_MissionZero_BuildHouseIncreasePopCap()
	
	Rule_AddInterval(FindGoldDeposit_Monitor, 1)
	Rule_AddGlobalEvent(EconDarkAge_OnConstructionComplete, GE_ConstructionComplete)

	Player_GetAll(player1, sg_allsquads, eg_TC)
	EGroup_Filter(eg_TC, EBP.ENGLISH.BUILDING_TOWN_CENTER_CAPITAL_ENG, FILTER_KEEP)
	hptc = HintPoint_Add(eg_TC, true, "$11119069", 7)
	
end

function Cheat_Progress_Feudalage()
	
	Cheat_Explore_DarkAge ()
	
	Rule_Remove(FindGoldDeposit_Monitor)
	Rule_RemoveGlobalEvent(EconDarkAge_OnConstructionComplete)
	hintpoint_Gold = HintPoint_Add(mkr_gold_mine_01, true, 11119542, 5)
	Player_SetSquadProductionAvailability(player1, BP_GetSquadBlueprint("unit_scout_1_eng"), ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_ECON_MINING_CAMP_CONTROL_ENG, ITEM_UNLOCKED)
	
	Player_SetResource( player1, RT_Gold, 500)
	Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_RESOURCE_FARM_ENG, mkr_cheat_farm4, 1)
	Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_RESOURCE_FARM_ENG, mkr_cheat_farm5, 1)
	Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_ECON_MINING_CAMP_CONTROL_ENG, mkr_cheat_mine, 1)

	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player1, sg_temp, {type="scar_villager", numSquads = 2}, mkr_cheat_farm4)
	AssignVillagersToFarms(sg_temp)
	
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player1, sg_temp, {type="scar_villager", numSquads = 5}, mkr_cheat_mine)
	AssignVillagersToGold(sg_temp)
	
	UnitEntry_DeploySquads(player1, sg_temp, {type="scar_scout", numSquads = 1}, mkr_cheat_mine)
	
	Camera_MoveTo(mkr_gold_mine_01)
end

function Cheat_FeudalMilitary ()
	
	Cheat_Progress_Feudalage()
	
	Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_HOUSE_CONTROL_ENG, mkr_cheat_house4, 1)
	
	Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_RESOURCE_FARM_ENG, mkr_cheat_farm6, 1)
	Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_RESOURCE_FARM_ENG, mkr_cheat_farm7, 1)
	Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_RESOURCE_FARM_ENG, mkr_cheat_farm8, 1)
	
	EGroup_Clear(eg_temp)
	Util_CreateEntities(player1, eg_landmarkForTutorial, EBP.ENGLISH.BUILDING_LANDMARK_AGE1_WESTMINSTER_ABBEY_ENG, mkr_cheat_landmark, 1)
	hpid_landmark = HintPoint_Add(eg_landmarkForTutorial, true, "$11197254", 3)
	
	Player_SetMaximumAge(player1, AGE_FEUDAL)

	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player1, sg_temp, {type="scar_villager", numSquads = 3}, mkr_cheat_farm6)
	AssignVillagersToFarms(sg_temp)

	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player1, sg_temp, {type="scar_villager", numSquads = 3}, mkr_cheat_lumber)
	AssignVillagersToWood(sg_temp)
	
	Camera_MoveTo(mkr_cheat_landmark)
	
end


function Cheat_AttackCavalry()
	
	Cheat_FeudalMilitary()
	
	Player_SetSquadProductionAvailability(player1, BP_GetSquadBlueprint("unit_spearman_2_eng"), ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, BP_GetEntityBlueprint("building_unit_infantry_control_eng"), ITEM_UNLOCKED)
		
	Util_CreateEntities(player1, eg_temp, EBP.ENGLISH.BUILDING_UNIT_INFANTRY_CONTROL_ENG, mkr_cheat_barracks, 1)
	
	UnitEntry_DeploySquads(player1, sg_temp, {type="scar_spearman", numSquads = 10}, mkr_cheat_spearmen)
	
	--remove pallisade	
	Player_GetAllEntitiesNearMarker(player2, eg_temp, mkr_cheat_destroy, 10)
	EGroup_DestroyAllEntities(eg_temp)
	Player_GetAllEntitiesNearMarker(player3, eg_temp, mkr_cheat_destroy, 10)
	EGroup_DestroyAllEntities(eg_temp)
	--EGroup_Kill(eg_allied_palisade)
	
	--move camera
	Camera_MoveTo(mkr_cheat_spearmen)
	
	
	-- tutorials & rules
	Rule_AddGlobalEvent(MilitaryFeudal_OnConstructionComplete, GE_ConstructionComplete)
	
	--Map and FOW
	World_SetInteractionStage(1)
	FOW_PlayerRevealArea(player1,Util_GetPosition(mkr_closeToGate), 25, -1)
end

function Cheat_AttackArchery()
	Cheat_AttackCavalry()
	World_SetInteractionStage(2)
	FOW_RevealMarker(mkr_horseman_village,-1)
	Camera_MoveTo(mkr_horseman_village_lookat)
	EGroup_DestroyAllEntities(eg_enemy_village1)
	Player_GetAllSquadsNearMarker(player2, sg_temp, mkr_horseman_village, 80)
	SGroup_Kill(sg_temp)
end

function Cheat_AttackInfantry()
	Cheat_AttackArchery()
	World_SetInteractionStage(3)
	Player_SetEntityProductionAvailability(player1, BP_GetEntityBlueprint("building_unit_cavalry_control_eng"), ITEM_DEFAULT)
	Player_SetSquadProductionAvailability(player1, BP_GetSquadBlueprint("unit_horseman_2_eng"), ITEM_DEFAULT)
	FOW_RevealMarker(mkr_archer_village,-1)
	Camera_MoveTo(mkr_archer_village_lookat)
	EGroup_DestroyAllEntities(eg_enemy_village2)
	Player_GetAllSquadsNearMarker(player2, sg_temp, mkr_archer_village, 80)
	SGroup_Kill(sg_temp)
end

function Cheat_Progress_Castleage()
	Cheat_AttackInfantry()
	Camera_MoveTo(mkr_player_town)
	World_SetInteractionStage(4)
	Rule_RemoveGlobalEvent(MilitaryFeudal_OnConstructionComplete)
	Player_GetAllSquadsNearMarker(player2, sg_temp, mkr_spearman_village, 80)
	SGroup_Kill(sg_temp)
	Player_SetEntityProductionAvailability(player1, EBP.ENGLISH.BUILDING_UNIT_RANGED_CONTROL_ENG, ITEM_DEFAULT)
	Player_SetSquadProductionAvailability(player1, SBP.ENGLISH.UNIT_ARCHER_2_ENG, ITEM_DEFAULT)
	Player_SetResource( player1, RT_Food, 3000)
	Player_SetResource( player1, RT_Wood, 3000)
	Player_SetResource( player1, RT_Gold, 3000)
end