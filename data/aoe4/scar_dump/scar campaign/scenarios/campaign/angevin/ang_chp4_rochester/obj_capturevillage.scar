function CaptureVillage_PreComplete() --Before ending the objective
	--ConvertVillagers() --Convert village to player 1 control
	Music_StopMedium() -- music stops for a bit then will restart properly
	Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_chatham_main, 50) 
	Sound_PlayWallaCelebrateOnSGroup(sg_temp)
	Rule_AddInterval(CounterMonks, 480)
	-- add a hintpoint on the TC to show town name
	chatham_Hintpoint = HintPoint_Add(eg_chatham_tc, true, "$11175641", LOCATION_LABEL_HEIGHT) --"Chatham"	
	VillageRepopulate()
	
		-- on console, restore the econ HUD at this point
	if UI_IsXboxUI() then
		Game_SetVisibility (VF_XboxUIResourceCard, true)
		Game_SetVisibility (VF_XboxUIVillagerPriorities, true)
	end				

end

function CaptureVillage_OnComplete() --When the objective completes

	Rule_AddOneShot(Rochester_Tutorials_Init, 30)
	-- No spontaneous attacks from the enemy on Story Mode
	if Game_GetSPDifficulty() >= GD_NORMAL then
		Init_AttackWaves()
		Rule_AddOneShot(SendPoke, 60*t_difficulty.pokeTimer)
	end
	RochesterSupply_Init()
	
	Util_AutoSave()
	
	if Game_GetSPDifficulty() <= GD_NORMAL then
		Objective_Start(OBJ_SiegeTut)
	end	
end

function CaptureVillage_IsFailed() --Check if objective failed
	Player_GetAll(player1)
	SGroup_Filter(sg_allsquads, "gaia", FILTER_REMOVE)
	if SGroup_CountSpawned(sg_allsquads) <= 0 then --If the player has no units left
		return true --Fail the objective
	else
		return false --Keep checking
	end
end

function CaptureVillage_OnFail() --On Objective Fail
	Mission_Fail() --Missions fails
end

function VillageRepopulate()
	villager_RespawnLocation = villagerlife_chatham.mkr_flee
	
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerlife_chatham.roaming_count-4},villager_RespawnLocation)
	Cmd_Move(sg_temp, villagerlife_chatham.location_mkr)
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerlife_chatham.food_count}, villager_RespawnLocation)
	AssignVillagersToFarms(sg_temp)
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerlife_chatham.wood_count + Util_DifVar({ 6, 4, 4, 4 })}, villager_RespawnLocation)
	AssignVillagersToWood(sg_temp)
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerlife_chatham.stone_count + Util_DifVar({ 1, 0, 0, 0 })}, villager_RespawnLocation)
	AssignVillagersToStone(sg_temp)
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_villager", numSquads = villagerlife_chatham.gold_count + Util_DifVar({ 1, 0, 0, 0 })}, villager_RespawnLocation)
	AssignVillagersToGold(sg_temp)
	
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player1, sg_temp, {type = "scar_monk", numSquads = 2}, villager_RespawnLocation)
	Cmd_Move(sg_temp, mkr_chatham_main)
	
	UI_SetPlayerDataContext(player1, { PopulationCapOn = true })
end