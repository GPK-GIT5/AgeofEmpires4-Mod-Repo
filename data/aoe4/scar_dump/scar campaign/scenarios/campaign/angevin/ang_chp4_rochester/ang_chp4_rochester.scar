function Init_EnemyTrade() 
	i_TraderNumber = i_TraderNumber or 1
	local traderUnits = {}
	
	if i_TraderNumber < 3 then
		traderUnits = 
		{
			{type = "scar_horseman", numSquads = 2*t_difficulty.defenderValue},
			{type = "supply_cart", numSquads = 1, sgroup = sg_trade_wagons},
		}
	elseif i_TraderNumber >= 3 and i_TraderNumber < 5 then
		traderUnits = 
		{
			{type = "scar_horseman", numSquads = 8*t_difficulty.defenderValue},
			--{type = "scar_knight", numSquads = 1},
			{type = "supply_cart", numSquads = 1, sgroup = sg_trade_wagons},
		}
	else
		traderUnits = 
		{
			{type = "scar_horseman", numSquads = 12*t_difficulty.defenderValue},
			{type = "scar_knight", numSquads = 2*t_difficulty.defenderValue},
			{type = "supply_cart", numSquads = 1, sgroup = sg_trade_wagons},
		}
	end
	
	local descriptor = "EnemyTrader_"..i_TraderNumber
		local moduledata = {
			type = "RovingArmy",
			descriptor = descriptor,
			player = player2,
			targetingType = ARMY_TARGETING_REVERSE,
			targets = { mkr_tradingpost, mkr_rochester_market},
			idleTimeOverride = 0,				
			spawnLocation = mkr_rochester_market,
			onDeathDissolve = true,
			units = traderUnits,
		}
	i_TraderNumber = i_TraderNumber+1
	traderRoving = RovingArmy_Init(moduledata)
end

--Initializes castle defenders
function Init_DefendRochester() 

	local moduledata = {
		type = "RovingArmy",
		descriptor = "SiegeCounter",
		player = player2,
		sgroup = sg_siege_counter,
		targetingType = ARMY_TARGETING_PROX,
		targets = {mkr_rochester_keep_defend},
		idleTimeOverride = 3,				
		spawnLocation = mkr_rochester_keep_spawn,
		withdrawThreshold = 0.1,
		fallbacks = {{marker = mkr_rochester_keep_defend,}},
		units = {
			{type = "scar_knight", numSquads = 1},
			{type = "scar_horseman", numSquads = 9*t_difficulty.defenderValue},
			{type = "scar_spearman", numSquads = 12*t_difficulty.defenderValue},
			{type = "scar_archer", numSquads = 10*t_difficulty.defenderValue},
			{type = "scar_crossbowman", numSquads = 5*t_difficulty.defenderValue},
		},

	}
	
	local counterSiegeModule = RovingArmy_Init(moduledata)

end

--MISSION ACTION FUNCTIONS--

function BesiegeRochester_EntityKilled(context) --Watch for Rochester wall death & trigger forces to pullback into Rochester and start spawning defensive waves
	if context.victim ~= nil then
		Rule_RemoveEGroupEvent(BesiegeRochester_EntityKilled, eg_rochester_walls_notowers)
		Halt_ExtraActivities()
		if b_wallIntelPlayed == false and b_innerWallIntelPlayed == false then
			b_wallIntelPlayed = true
			Sound_Play2D(MUS_STING_TRIUMPHANT)
			-- play walla on player troops near the breach point 
			-- or if none, play walla on the breach point itself
			local pos = Util_GetPosition(context.victim)
			SGroup_Clear(sg_temp)
			Player_GetAllSquadsNearMarker(player1, sg_temp, pos, 30) 
			print ("Outer wall walla with groupsize "..SGroup_CountSpawned(sg_temp))
			if SGroup_CountSpawned(sg_temp) > 0 then
				Sound_PlayWallaCelebrateOnSGroup(sg_temp)
			else
				Sound_Play3D(WALLA_CAMP_CELEBRATE_MEDIUM, context.victim)
			end
			Util_StartIntel(EVENTS.WallFall)
		end
		if b_WallsBreached == false then
			b_WallsBreached = true
			Rule_AddInterval(PushAttack, 30)
		end
		
		print(Entity_GetPosition(context.victim))
		if MissionOMatic_FindModule("WallHoleDefense") then
			RovingArmy_SetTarget(MissionOMatic_FindModule("WallHoleDefense"), Entity_GetPosition(context.victim), 50)
		end

	end
end

function InnerRochester_EntityKilled(context) --Watch for Rochester wall death & trigger forces to pullback into Rochester and start spawning defensive waves
	if context.victim ~= nil then
		Rule_RemoveEGroupEvent(InnerRochester_EntityKilled, eg_rochester_innerwalls)
		Halt_ExtraActivities()
		if b_innerWallIntelPlayed == false then
			b_innerWallIntelPlayed = true
			Sound_Play2D(MUS_STING_TRIUMPHANT)
			-- play walla on player troops near the breach point 
			-- or if none, play walla on the breach point itself
			local pos = Util_GetPosition(context.victim)
			SGroup_Clear(sg_temp)
			Player_GetAllSquadsNearMarker(player1, sg_temp, pos, 30) 
			if SGroup_CountSpawned(sg_temp) > 0 then
				Sound_PlayWallaCelebrateOnSGroup(sg_temp)
			else
				Sound_Play3D(WALLA_CAMP_CELEBRATE_MEDIUM, context.victim)
			end
			print ("Inner wall walla with groupsize "..SGroup_CountSpawned(sg_temp))
			Util_StartIntel(EVENTS.InnerWall_Fall)
		end
		if b_WallsBreached == false then
			b_WallsBreached = true
			Rule_AddInterval(PushAttack, 30)
		end
		
		print(Entity_GetPosition(context.victim))
		if MissionOMatic_FindModule("WallHoleDefense") then
			RovingArmy_SetTarget(MissionOMatic_FindModule("WallHoleDefense"), Entity_GetPosition(context.victim), 50)
		end

	end
end

function Halt_ExtraActivities()
	if Rule_Exists(DiscoverWagons) then
		Rule_Remove(DiscoverWagons)
	end
	
	if Rule_Exists(CounterMonks) then
		Rule_Remove(CounterMonks)
	end
	
	if Objective_IsStarted(SOBJ_TroubledTrade) and Objective_IsComplete(SOBJ_TroubledTrade) ~= true then
		Objective_Stop(SOBJ_TroubledTrade)
		Rule_RemoveSGroupEvent(WagonKilled_SquadKilled, sg_trade_wagons)
		MarkerPaths_ClearIcons("rochester_trade", true)
	end
end

function KeepReveal() --If player forces have entered Rochester's walls then reveal the keep
	local sg_breachingunits = SGroup_CreateIfNotFound("sg_breachingunits")
	Player_GetAllSquadsNearMarker(player1, sg_breachingunits, mkr_keepreveal_trigger)
	if SGroup_CountSpawned(sg_breachingunits) >= 1 then
		FOW_RevealMarker(mkr_keep_orbitcam, -1)
		Rule_RemoveEGroupEvent(SiegeCounter_OnDamageReceived, eg_rochester_walls)
	end
end

--On wall damage pull together a counter siege attack module
function SiegeCounter_OnDamageReceived(context)
	if context.attacker ~= nil and Entity_IsBuilding(context.attacker) == false and context.damage > 2 then
		local attackerSquad = Entity_GetSquad(context.attacker)
		if attackerSquad ~= nil then
			SGroup_Add(sg_wall_attackers, attackerSquad)
		end
	end
		
	if SGroup_CountSpawned(sg_wall_attackers) > 0 then						
		if Rule_Exists(CounterSiegeHunt) == false then
			Rule_AddInterval(CounterSiegeHunt, 1)
		end	
	end
end

--Sends the counter sieges after offending player units
function CounterSiegeHunt()
	local counterModule = MissionOMatic_FindModule("SiegeCounter")
	if counterModule.isComplete == true 
			and SGroup_CountSpawned(RovingArmy_GetSGroup(counterModule)) > 0 then
		local newTarget = RovingArmy_GetNearestSeen(counterModule, sg_wall_attackers)
		if newTarget ~= nil then
			RovingArmy_SetTarget(counterModule, Squad_GetPosition(newTarget), 30, 60)
		else
			Rule_RemoveMe()
			SGroup_Clear(sg_wall_attackers)
			RovingArmy_SetTarget(counterModule, mkr_rochester_keep_defend)
		end
	end
end

--Pull a group of defenders to the hole in the wall
function Init_FallenWallDefense()

	local moduledata = {
		type = "RovingArmy",
		descriptor = "WallHoleDefense",
		player = player2,
		targetingType = ARMY_TARGETING_DISCARD,
		targets = {mkr_rochester_wallhole_holding},
		idleTimeOverride = 3,				
		spawnLocation = mkr_rochester_wallhole_holding,
		withdrawThreshold = 0.15,
		fallbacks = {{marker = mkr_rochester_keep_defend}}, --onFallbackModule = "DefendKeep"
		units = {
			{type = "scar_manatarms", numSquads = 8*t_difficulty.defenderValue},
			{type = "scar_spearman", numSquads = 16*t_difficulty.defenderValue},
			{type = "scar_archer", numSquads = 16*t_difficulty.defenderValue},
		}
	}
	
	local WallHoleDefense = RovingArmy_Init(moduledata) 

end

function PushAttack()
	sg_pushtarget = SGroup_CreateIfNotFound("sg_pushtarget") 
	Player_GetAllSquadsNearMarker(player1, sg_pushtarget, mkr_rochester_all, 90)
	if SGroup_CountSpawned(sg_pushtarget) > 0 then
		local pushModule = nil
		if #t_allRochesterModules > 0 then
			for i = #t_allRochesterModules, 1, -1 do
				if SGroup_CountSpawned(t_allRochesterModules[i].sgroup) > 0 then
					if pushModule == nil or 
						Util_GetDistanceSquared(pushModule.sgroup, sg_pushtarget) > Util_GetDistanceSquared(t_allRochesterModules[i].sgroup, sg_pushtarget) then
						pushModule = t_allRochesterModules[i]
					end
				end
			end
		end
		
		if pushModule ~= nil and SGroup_CountSpawned(pushModule.sgroup) > 0 and SGroup_CountSpawned(sg_pushtarget) > 0 then
			RovingArmy_SetTarget(pushModule, sg_pushtarget)
		end
	end
end

------------------------------------------------
------------------ENEMY SPAWNS------------------
------------------------------------------------

function CounterMonks()
	captureCount = captureCount or 1
	eg_target_holysites = EGroup_CreateIfNotFound("eg_target_holysites")
	EGroup_Duplicate(eg_holysites, eg_target_holysites)
	
	local _GetHolyTargets = function(gid, index, eid)
		if World_OwnsEntity(eid) ~= true then
			if Entity_GetPlayerOwner(eid) == player2 then
				EGroup_Remove(gid, eid)
			end
		end
	end
	EGroup_ForEach(eg_target_holysites, _GetHolyTargets)
	
	if EGroup_CountSpawned(eg_target_holysites) > 0 then
		local modName = ("monk_army_"..captureCount)
		local moduleData = 
		{
			type = "RovingArmy",
			descriptor = modName,
			player = player2,
			targetingType = ARMY_TARGETING_DISCARD,
			targets = {
				{ position = Util_GetPosition(EGroup_GetRandomSpawnedEntity(eg_target_holysites)), combatRange = 12, leashRange = 15},
				position = Util_GetPosition(EGroup_GetRandomSpawnedEntity(eg_target_holysites)),									
			},		
			spawnLocation = mkr_rochester_keep_spawn,
			onDeathDissolve = true,
			units = 
			{
				{type = "scar_spearman", numSquads = 4},
				{type = "scar_manatarms", numSquads = 1},
				{type = "scar_monk", numSquads = 1},
			}
		}
		_G["Rochester_Monks_"..captureCount] = RovingArmy_Init(moduleData)
		captureCount = captureCount+1
	end
end

function SetUp_Fishing()
	sg_stmargot_fishing = SGroup_CreateIfNotFound("sg_stmargot_fishing")
	UnitEntry_DeploySquads(player3, sg_stmargot_fishing, {type = "scar_villager", numSquads = 3}, mkr_stmargots)
	AssignVillagersToFish(sg_stmargot_fishing)
	Rule_AddInterval(Cycle_Fish, 30)
end

function Cycle_Fish()
	
	local _RestockFish = function(gid, index, eid)
		Entity_SetRemainingResourceDepositAmount(eid, 2000)
	end
	EGroup_ForEach(eg_allShoreFishResources, _RestockFish)
	
end

------------------------------------------------
------------Surrenderees FUNCTIONS--------------
------------------------------------------------

--Select a portion of AI units and have them surrender
function SiegeEntropy()
		
	local _isAttacking = function(gid, index, sid)
		if Squad_IsAttacking(sid, 5) or Squad_IsUnderAttack(sid, 5) then
			SGroup_Remove(gid, sid)
		end
	end
	
	--Grabs the enemy troops
	Player_GetAll(player2, sg_allsquads)
	
	--Ignores trade carts, knights, and villagers
	SGroup_Filter(sg_allsquads, "supply_cart", FILTER_REMOVE)
	SGroup_Filter(sg_allsquads, "scar_knight", FILTER_REMOVE)
	SGroup_Filter(sg_allsquads, "scar_crossbowman", FILTER_REMOVE)	
	SGroup_Filter(sg_allsquads, "scar_villager", FILTER_REMOVE)
	SGroup_Filter(sg_allsquads, "scar_springald", FILTER_REMOVE)
	SGroup_Filter(sg_allsquads, SBP.GAIA.GAIA_HERDABLE_SHEEP, FILTER_REMOVE)
	SGroup_Filter(sg_allsquads, "siege", FILTER_REMOVE)
	
	
	--Ignore units currently in critical modules or currently attacking
	SGroup_RemoveGroup(sg_allsquads, sg_siege_counter)
	SGroup_RemoveGroup(sg_allsquads, sg_attack_wave)
	SGroup_RemoveGroup(sg_allsquads, MissionOMatic_FindModule("WallHoleDefense").sgroup)
	SGroup_ForEach(sg_allsquads, _isAttacking)
	
	--Gets the total number of valid enemies and selects 20% of them
	local totalEnemies = SGroup_CountSpawned(sg_allsquads)
	SGroup_FilterCount(sg_allsquads, (totalEnemies*f_entropyAmount))
		
	--Removes all surrendering troops from their active modules
	for index, module in ipairs(t_allModules) do
		Prefab_DoAction(module, "RemoveSGroup", sg_allsquads)
	end
	
	--Reveal the surrenderees, set them to walk, and order them to move off board
	
	if SGroup_CountSpawned(sg_allsquads) > 0 then
		SGroup_AddGroup(sg_entropyTroops, sg_allsquads)
		--FOW_RevealSGroup(sg_entropyTroops, 20, -1)
		Modify_UnitSpeed(sg_entropyTroops, 0.5, -1)
		SGroup_SetPlayerOwner(sg_entropyTroops, player4)
		Cmd_MoveToAndDestroy(sg_entropyTroops, mkr_enemy_retreat)
		FOW_PlayerRevealSGroup(player1, sg_entropyTroops, 5, -1)
		EntropyCTA()
		
		--Backup check to make sure they're actually moving off board
		Rule_AddInterval(SurrenderEnsure, 5)
	end
	
	i_entropyImpact = i_entropyImpact*0.8
	Util_AutoSave()
end

function RealTime_CTATargeting()
	if SGroup_CountSpawned(sg_entropyTroops) > 0 then
		local camTarget = World_GetOffsetPositionRelativeToFacingTarget(Util_GetPosition(sg_entropyTroops), Util_GetPosition(mkr_chatham_main), 20)
		Camera_MoveTo(camTarget)
	end
end

--Ensures surrendered units are leaving
function SurrenderEnsure()
	if SGroup_CountSpawned(sg_entropyTroops) > 0 and SGroup_IsMoving(sg_entropyTroops, ALL) ~= true then
		Cmd_MoveToAndDestroy(sg_entropyTroops, mkr_enemy_retreat) --MoveTo function currently broken, needs fix
	elseif SGroup_CountSpawned(sg_entropyTroops) <= 0 then
		Rule_RemoveMe()
	end
end

