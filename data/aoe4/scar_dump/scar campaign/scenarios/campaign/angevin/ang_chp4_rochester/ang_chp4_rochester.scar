function Rochester_Intro_Movement()
	
	sg_intro_archers = SGroup_CreateIfNotFound("sg_intro_archers")
	sg_intro_maa = SGroup_CreateIfNotFound("sg_intro_maa")
	sg_intro_crossbow = SGroup_CreateIfNotFound("sg_intro_crossbow")
	sg_intro_scout = SGroup_CreateIfNotFound("sg_intro_scout")
	
	local skip_units_parade = {
		{type = "scar_scout", numSquads = 1, spawn = mkr_john_army01_target, sgroup = sg_intro_scout},
		{sbp = SBP.ENGLISH.UNIT_MANATARMS_2_ENG, numSquads = 5, spawn = mkr_john_army02_target, sgroup = sg_intro_maa},
		{sbp = SBP.ENGLISH.UNIT_MANATARMS_2_ENG, numSquads = 5, spawn = mkr_john_army03_target, sgroup = sg_intro_maa},
		{sbp = SBP.ENGLISH.UNIT_MANATARMS_2_ENG, numSquads = 5, spawn = mkr_john_army04_target, sgroup = sg_intro_maa},
		{type = "scar_archer", numSquads = 5, spawn = mkr_john_army05_target, sgroup = sg_intro_archers},
		{type = "scar_archer", numSquads = 5, spawn = mkr_john_army06_target, sgroup = sg_intro_archers},
		{type = "scar_crossbowman", numSquads = 5, spawn = mkr_john_army07_target, sgroup = sg_intro_crossbow},
		{type = "scar_crossbowman", numSquads = 5, spawn = mkr_john_army08_target, sgroup = sg_intro_crossbow},
	}
	
	UnitEntry_DeploySquads(player1, sg_temp, skip_units_parade)
end


function Delay_Detection() -- Turns off targeting on the player until the player interacts with the units.
	Player_GetAll(player1)
	SGroup_SetTargetingType(sg_allsquads, Targeting_None)
	
	Player_GetAll(player2)
	SGroup_SetTargetingType(sg_allsquads, Targeting_Manual)
	
	Rule_AddInterval(Reset_Detection, 1)
	
end

function Reset_Detection()
	Misc_GetSelectedSquads(sg_temp, false)
	if SGroup_CountSpawned(sg_temp) > 0 or Objective_IsStarted(SOBJ_DefeatHamletRebels) then
		Rule_RemoveMe()
		Player_GetAll(player1)
		SGroup_SetTargetingType(sg_allsquads, Targeting_Automatic)
		Player_GetAll(player2)
		SGroup_SetTargetingType(sg_allsquads, Targeting_Automatic)
	end
end

------------------------------------------------
----------------------AUDIO---------------------
------------------------------------------------
function Misc_PlayerUnitsOnScreen(player)
	local player = player
	
	SGroup_Clear(sg_temp)
	
	local _SquadOnScreen = function(gid, index, sid)
		if Misc_IsSquadOnScreen(sid, 1.0) ~= true then
			SGroup_Remove(gid, sid)
		end
	end
	
	Player_GetAll(player, sg_temp)
	if Misc_IsSGroupOnScreen(sg_temp, 1.0, ALL) ~= true then
		SGroup_ForEach(sg_temp, _SquadOnScreen)
	end
	
	return SGroup_CountSpawned(sg_temp)
end

function WallaSize(unitCount)
	if unitCount <= 10 then
		return "SMALL"
	elseif unitCount > 10 and unitCount <= 20 then
		return "MEDIUM"
	else
		return "LARGE"
	end
		
end

function AudOnFromPoint(player, pos, audString)
	local size = ""
	
	SGroup_Clear(sg_temp)
	
	Player_GetAllSquadsNearMarker(player, sg_temp, pos, 50)
	SGroup_Filter(sg_temp, SBP.GAIA.GAIA_HERDABLE_SHEEP, FILTER_REMOVE)
	
	unitCount = SGroup_CountSpawned(sg_temp)
	
	if unitCount <= 5 then
		return
	else
		if unitCount > 5 and unitCount <= 10 then
			size = "SMALL"
		elseif unitCount > 10 and unitCount <= 20 then
			size = "MEDIUM"
		else
			size = "LARGE"
		end
		Sound_PlayOnSquad(_G[audString..size], sg_temp)
	end
end

function AudOnScreen(player, audString)
	local size = ""
	
	SGroup_Clear(sg_temp)
	
	local _SquadOnScreen = function(gid, index, sid)
		if Misc_IsSquadOnScreen(sid, 1.0) ~= true then
			SGroup_Remove(gid, sid)
		end
	end
	
	Player_GetAll(player, sg_temp)
	if Misc_IsSGroupOnScreen(sg_temp, 1.0, ALL) ~= true then
		SGroup_ForEach(sg_temp, _SquadOnScreen)
	end
	
	unitCount = SGroup_CountSpawned(sg_temp)
	
	if unitCount <= 5 then
		return
	else
		if unitCount > 5 and unitCount <= 10 then
			size = "SMALL"
		elseif unitCount > 10 and unitCount <= 20 then
			size = "MEDIUM"
		else
			size = "LARGE"
		end
		Sound_PlayOnSquad(_G[audString..size], sg_temp)
	end
end

---- EVENT FILE SUPPORT FUNCTIONS
-- This fires the proper CTA for the surrendering forces. It chooses the fleeing squad closest to
-- the Rochester Market so the player can see it easily as it moves through the town
-- Also prevents the second CTA from choosing a squad from the first surrender group that nmight still be on the map
function EntropyCTA()
	if b_supplyIntelCompleted == false then
		b_supplyIntelCompleted = true
		Sound_Play2D(MUS_STING_TRIUMPHANT)
		SGroup_Clear(sg_CTA_squad)
		SGroup_Add(sg_CTA_squad, SGroup_GetClosestSquad(sg_entropyTroops, mkr_rochester_market))
		EventCues_CallToAction(11191066,CTA_CELEBRATE,EVENTS.RetreatCTA_Initial,nil, sg_CTA_squad,20)
	elseif b_supplyFinalCompleted == false then
		b_supplyFinalCompleted = true
		Sound_Play2D(MUS_STING_TRIUMPHANT)
		SGroup_Clear(sg_CTA_squad)
		SGroup_Add(sg_CTA_squad, SGroup_GetClosestSquad(sg_entropyTroops, mkr_rochester_market))
		EventCues_CallToAction(11191066,CTA_CELEBRATE,EVENTS.RetreatCTA_Final,nil, sg_CTA_squad,20)
	end
end

function SetupOutro()
	--Rule_RemoveAll()
	
	local glows = {"tower_outpost_alert_aura_eng", "general_aura_logistics", "general_aura_archer"}
	Mission_EnableAbilities({player = player2, abilities = glows}, false)
	
	Modify_WeaponEnabled(eg_thekeep, "hardpoint_01", false)
	
	sg_outro_parade = SGroup_CreateIfNotFound("sg_outro_parade")
	
	local keepPos = EGroup_GetPosition(eg_thekeep)
	
	local outro_squads = {
		{type = "scar_manatarms", numSquads = 20, spawn = mkr_outro_cheerunits, facing = keepPos},
		{type = "scar_spearman", numSquads = 20, facing = keepPos},
	}
	
	UnitEntry_DeploySquads(player1, sg_outro_parade, outro_squads, mkr_outro_parade)
			
	SGroup_EnableCheering(sg_outro_parade, true, -1, WALLA_CAMP_CELEBRATE_LARGE, 5)

	EGroup_SetInvulnerable(eg_thekeep, false, nil)
	
end

function AttackWave_Intel()
	if Player_CanSeeSGroup(player1, sg_attack_wave, ANY) or Player_CanSeeSGroup(player1, sg_attack_poke, ANY) then
		Rule_RemoveMe()
		Util_StartIntel(EVENTS.Chatham_Raid)
	end			
end
