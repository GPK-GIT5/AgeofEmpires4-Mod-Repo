function missionstart_OnInit()
    Prefab_InitAll() -- this is the key function to fire up Prefabs for your Scenario
end

function Mission_SetupPlayers()
	player1 = World_GetPlayerAt(1) 
	player2 = World_GetPlayerAt(2) 
	player3 = World_GetPlayerAt(3)
	player4 = World_GetPlayerAt(4) 
	
	Setup_SetPlayerName(player1, "$11174915") --John's Royalists
	Player_SetCurrentAge(player1, AGE_CASTLE)
	Player_SetMaximumAge(player1, AGE_IMPERIAL)


	Setup_SetPlayerName(player2, "$11174916") --Barons' Rebels
	Player_SetCurrentAge(player2, AGE_CASTLE)
	Player_SetMaximumAge(player2, AGE_CASTLE)
	
	Setup_SetPlayerName(player3, "$11174918") --Country Folk
	Player_SetCurrentAge(player3, AGE_FEUDAL)
	Player_SetMaximumAge(player3, AGE_FEUDAL)
		
	Setup_SetPlayerName(player4, "$11174916") --Barons' Rebels
	Player_SetCurrentAge(player4, AGE_CASTLE)
	Player_SetMaximumAge(player4, AGE_CASTLE)
	
	--Enable Player Colours
	PlayerColour_Enable()
	
	Game_SetPlayerSlotColour(player1, 1)
    Game_SetPlayerUISlotColour(player1, 1)
	Game_SetPlayerSlotColour(player2, 2)
    Game_SetPlayerUISlotColour(player2, 2)
	Game_SetPlayerSlotColour(player3, 3)
    Game_SetPlayerUISlotColour(player3, 3)	
	Game_SetPlayerSlotColour(player4, 9)
    Game_SetPlayerUISlotColour(player4, 9)
		
	-- Auto Age Up
	PlayerUpgrades_Auto(player1, true)
	PlayerUpgrades_Auto(player2, true)
	Player_SetUpgradeAvailability(player2, UPG.COMMON.UPGRADE_UNIT_TOWN_CENTER_WHEELBARROW_1, ITEM_REMOVED)
	PlayerUpgrades_Auto(player3, false)
	PlayerUpgrades_Auto(player3, true)

	Player_SetRelationship(player1, player3, R_ALLY)		-- make sure you set relationships both ways
	Player_SetRelationship(player3, player1, R_ALLY)	
	
	Player_SetRelationship(player2, player3, R_NEUTRAL)		-- make sure you set relationships both ways
	Player_SetRelationship(player3, player2, R_NEUTRAL)
	
	Player_SetRelationship(player2, player1, R_ENEMY)		-- make sure you set relationships both ways
	Player_SetRelationship(player1, player2, R_ENEMY)
	
	Player_SetRelationship(player1, player4, R_ALLY)		-- make sure you set relationships both ways
	Player_SetRelationship(player4, player1, R_ALLY)	
	
	Player_SetRelationship(player4, player3, R_NEUTRAL)		-- make sure you set relationships both ways
	Player_SetRelationship(player3, player4, R_NEUTRAL)
	
	Player_SetRelationship(player2, player4, R_ALLY)		-- make sure you set relationships both ways
	Player_SetRelationship(player4, player2, R_ALLY)
		
end

