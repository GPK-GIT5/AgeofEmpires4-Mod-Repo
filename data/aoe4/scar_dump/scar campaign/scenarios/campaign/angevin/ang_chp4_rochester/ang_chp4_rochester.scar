function Mission_SetDifficulty()

	t_difficulty = {
		defenderValue = Util_DifVar({1, 1, 1.15, 1.25}),
		baseWaveValue = Util_DifVar({5, 5, 5, 10}),
		easyWaveMod = Util_DifVar({0, 0, 1, 1}),
		waveDownTimeMin = Util_DifVar({180, 120, 0, 0}), --t_difficulty.waveDownTimeMin
		waveDownTimeMax = Util_DifVar({180, 120, 60, 30}), --t_difficulty.waveDownTimeMax
		earlyPokes = Util_DifVar({2, 2, 3, 5}),
		pokeTimer = Util_DifVar({3, 3, 4, 5}), --Minutes
	}
	
	i_maxDefenderValue = t_difficulty.defenderValue --tuning value for rochester defenders 
	i_defenderValue = i_maxDefenderValue


  end

function Mission_SetRestrictions()	-- set up any restrictions (i.e. locking out units, etc) in here
	
	--Remove Gunpowder upgrades
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_SIEGE_CHEMISTRY, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_TOWER_CANNON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_KEEP_CANNON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_OUTPOST_CANNON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_SIEGE_CORNED_GUNPOWDER, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.ENGLISH.UNIT_CANNON_4_ENG, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.ENGLISH.UNIT_RIBAULDEQUIN_4_ENG, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.ENGLISH.UNIT_CULVERIN_4_ENG, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.ENGLISH.UNIT_BOMBARD_4_ENG, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.ENGLISH.UNIT_HANDCANNON_4_ENG, ITEM_REMOVED)
	
end

function Mission_Preset()	-- any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)	
	
	World_EnableSharedLineOfSight(player1, player3, false)
	World_EnableSharedLineOfSight(player3, player1, false)
	World_EnableSharedLineOfSight(player4, player1, false)
	World_EnableSharedLineOfSight(player1, player4, false)
	World_EnableSharedLineOfSight(player4, player2, false)
	World_EnableSharedLineOfSight(player2, player4, false)
		
	--Capture all of Rochester castle walls into an egroup for later
	Player_GetAll(player2)
	EGroup_Filter(eg_allentities, "wall", FILTER_REMOVE, eg_rochester_walls_notowers)
	
	Player_GetAll(player2)
	EGroup_Filter(eg_allentities, "wall", FILTER_REMOVE, eg_rochester_walls)
	Player_GetAll(player2)
	EGroup_Clear(eg_temp)
	EGroup_Filter(eg_allentities, "tower", FILTER_REMOVE, eg_temp)
	EGroup_AddEGroup(eg_rochester_walls, eg_temp)
	
	Player_GetAllEntitiesNearMarker(player2, eg_rochester_innerwalls, mkr_inner_walls)
	EGroup_Filter(eg_rochester_innerwalls, "wall", FILTER_KEEP)
	
	EGroup_RemoveGroup(eg_rochester_walls_notowers, eg_rochester_innerwalls)
	
	--Upgrade Rochester Outposts to have arrow slits
	Player_GetAll(player2)
	EGroup_Filter(eg_allentities, EBP.ENGLISH.BUILDING_DEFENSE_OUTPOST_ENG, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	
	--Upgrade Rochester towers to have Springalds
	Player_GetAll(player2)
	EGroup_Filter(eg_allentities, EBP.ENGLISH.BUILDING_DEFENSE_TOWER_ENG, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_TOWER_SPRINGALD)
	
	Wave_OverrideBuildingSpawnType("castle", { "infantry", "ranged", "cavalry", "siege", "town_center", "religious" })
	
	UI_SetModalConstructionPhaseCallback(TrainingContructionCallback) -- callback used to track construction for training hint purposes

	
	--Initialize Objectives
	DestroyRochester_InitObjectives()
	CaptureVillage_InitObjectives()
	RochesterSupply_InitObjectives()
	SiegeTut_InitObjectives()
	
	--Music Setup
	if Music_UnlockIntensity then
		Sound_SetForceMusic(false)
	else
		Sound_SetForceMusic(true)
	end
	
		-- mission specific combat intensity mapping
	Sound_ResetMusicIntensityMapping();
	Sound_AddMusicIntensityMappingPoint(60, 500)
	Sound_AddMusicIntensityMappingPoint(100, 1500)
	Sound_AddMusicIntensityMappingPoint(150, 2500) 
	Sound_AddMusicIntensityMappingPoint(200, 3500)
	Sound_AddMusicIntensityMappingPoint(300, 5500)
	Sound_AddMusicIntensityMappingPoint(450, 6500) 
	Sound_AddMusicIntensityMappingPoint(650, 9999) -- raw value max to scaled value max 
	
	Music_LockIntensity(MUSIC_COMBAT, 20, MUSIC_TENSE_RARE) -- start with Tense and Rare music 
	
	Scar_AddInit(missionstart_OnInit)
	
	EGroup_SetInvulnerable(eg_notthekeep, true, -1)
	Entity_VisHide(EGroup_GetEntityAt(eg_notthekeep, 1), true)
end

function Mission_Start()	-- this is triggered after the intro, just as control is passed to the player
	-- on console don't restore econ-related HUD elements at first
	Cardinal_EnablePartialXboxUI(true, {VF_XboxUIResourceCard, VF_XboxUIVillagerPriorities})
	
	--Start the first objective
	Objective_Start(OBJ_DestroyRochester,false)
	Objective_Start(OBJ_CaptureVillage)
	
	TrackTradeCartsForPlayers({player2})
	
	UI_SetPlayerDataContext(player1, { PopulationCapOn = false })
	
	Init_DefendRochester()
	Init_FallenWallDefense()
	
	for i, moduleName in pairs(t_allRochesterRecipeModNames) do
		local module = MissionOMatic_FindModule(moduleName)
		table.insert(t_allRochesterModules, module)
	end
	
	SetUp_Fishing()

end

--MISSION ACTION FUNCTIONS--

--Setsup Attack Wave Module
function Init_AttackWaves()
	local moduledata = 
	{
		type = "RovingArmy",
		descriptor = "AttackWave",
		player = player2,
		sgroup = sg_attack_wave,
		targetingType = ARMY_TARGETING_DISCARD,
		targets = {
			mkr_rochester_all,
			mkr_chatham_main,					
		},			
		spawnLocation = mkr_rochester_keep_spawn,
		attackMove = attackMoveStyle_attackEverything,
		fallbacks = {{ marker = mkr_rochester_all, }},
		withdrawThreshold = 0.15,
		onFailFunction = QueueAttackWaves,
		onCompleteFunction = ResetAttackWave_OnComplete,

	}	
	local attackwaveModule = RovingArmy_Init(moduledata)
	
	local waveunits = ConstructWave()
	
	local wave_data = {
		descriptor = "wave",
		player = player2,    
		use_separate_spawns = true,
		spawn = mkr_rochester_all,
		units = waveunits,
		staging_module = "DefendRochester",
		assault_module = "AttackWave",
		ignore_build_times = false,
		auto_launch = true, 
	}
	wave = Wave_New(wave_data)
	
	PrepAttackWaves()
end

function ResetAttackWave_OnComplete()
	local AttackWave = MissionOMatic_FindModule("AttackWave")
	print("Wave Reset")
	
	if AttackWave ~= nil then
		RovingArmy_Reset(AttackWave)
	end
	if Rule_Exists(PrepAttackWaves) ~= true and AttackWave.isWithdrawn == true then
		QueueAttackWaves()
	end
	
end

function ConstructWave()
	
	--Pre-existing units
	local attackWaveMod = MissionOMatic_FindModule("AttackWave") 
	local attackWavePopCount = 0
	if attackWaveMod ~= nil then
		attackWavePopCount = SGroup_Count(attackWaveMod.sgroup)
	end
	
	--Wave Init
	local gameTime = World_GetGameTime()
	gameTime = gameTime/60
	waveTest = waveTest or nil
	if waveTest ~= nil then 
		gameTime = waveTest
	end
	
	if gameTime <= 60 then
		local quarterTime = gameTime/4
		local exponentTime = (gameTime^6)/1000000000
		
		wavePower = quarterTime + exponentTime
	else
		wavePower = 66
	end
	
	local function DivMinRound(source, divide, max)
		local crunched = source/divide
		crunched = math.floor(crunched)
		crunched = math.min(crunched, max)
		return crunched
	end
	
	local waveResource = math.floor(wavePower)
	waveResource = Util_DifVar({math.min(waveResource+3, 15), math.min(waveResource+3, 15), waveResource+12, (waveResource+10)*1.50})
	waveResource = waveResource*i_entropyImpact
	waveResource = waveResource - attackWavePopCount
	waveResource = math.floor(waveResource)
	
	local waveunits = {} --Changes attack wave composition based on game time
	
	local t_possibleUnits = {"scar_archer", "scar_horseman", "scar_manatarms", "scar_crossbowman", "scar_knight", "scar_ram", "scar_mangonel"}
	t_possibleUnits = Table_Shuffle(t_possibleUnits)
	
	local tenthTime = math.floor(gameTime/10)
	local complexityOverTime = math.max(6 - tenthTime, 0)
	for index = 1, tenthTime do
		table.remove(t_possibleUnits, 1)
	end
	
	for index = 1, #t_possibleUnits do
		local cost = 1
		if t_possibleUnits[index] == "scar_mangonel" then
			cost = 4
		elseif t_possibleUnits[index] == "scar_ram" then
			cost = 3
		elseif t_possibleUnits[index] == "scar_knight" or t_possibleUnits[index] == "scar_crossbowman" then
			cost = 2
		else
			cost = 1
		end
		local maxUnits = math.floor(waveResource/cost)
		if maxUnits > 0 then
			local randUnitAmount = World_GetRand(0, maxUnits)
			table.insert(waveunits, {type = t_possibleUnits[index], numSquads = math.floor(randUnitAmount)})
			waveResource = math.floor(waveResource - (randUnitAmount*cost))
		end
	end
	
	table.insert(waveunits, {type = "scar_spearman", numSquads = math.floor(waveResource+4)})
	
	return waveunits
end

function QueueAttackWaves()
	local AttackWave = MissionOMatic_FindModule("AttackWave")
	print("Next Wave Queued")
	
	if AttackWave ~= nil then
		Rule_AddOneShot(PrepAttackWaves, World_GetRand(t_difficulty.waveDownTimeMin, t_difficulty.waveDownTimeMax))
	end
end

function PrepAttackWaves()
	local AttackWave = MissionOMatic_FindModule("AttackWave")
	print("Next Wave Started Building")
	if AttackWave ~= nil then
		RovingArmy_Reset(AttackWave)
		local waveunits = ConstructWave()
		Wave_SetUnits(wave, waveunits)
		Wave_Prepare(wave)		
	end
	
end

function SendPoke()
	if i_pokeNumber < t_difficulty.earlyPokes then
				
		local moduledata = 
		{
			type = "RovingArmy",
			descriptor = ("PokeWave_"..i_pokeNumber), --	MissionOMatic_FindModule("PokeWave_")
			player = player2,
			sgroup = sg_attack_poke,
			units = {
				{type = "scar_spearman", numSquads = 5+i_pokeNumber},
				{type = "scar_manatarms", numSquads = 5},
				{type = "scar_horseman", numSquads = 3},
			},
			targetingType = ARMY_TARGETING_DISCARD,
			targets = {
				mkr_chatham_main,					
			},			
			spawnLocation = mkr_rochester_keep_spawn,
			attackMove = attackMoveStyle_attackEverything,
			onDeathDissolve = true,
		}
		
		RovingArmy_Init(moduledata)
		i_pokeNumber = i_pokeNumber+1
		Rule_AddOneShot(SendPoke, 60*t_difficulty.pokeTimer)
	end
	
end

--Grabs a counter-offensive force against player attacks to the countryside
