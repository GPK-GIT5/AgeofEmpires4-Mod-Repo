		b_CountrysidePatroled = true
		local moduledata = {
			type = "RovingArmy",
			descriptor = "CountrysideRoving",
			player = player2,
			sgroup = sg_countryside_roving,
			targetingType = ARMY_TARGETING_CYCLE,
