function TimerORIgnore_UserCannotSeeSquadKey(goalSequence)
	if CampaignTraining_TimeoutIgnorePredicate(goalSequence) then
		return true
	else
		return UserCannotSeeSquadKey(goalSequence)
	end
end

function Tutorials_novgorod_HintHuntingBounty()
	
	local goal_hunting_bounty_rusNov = "hunting_bounty_rus"
	
	
	-- Scout Hunting Bounty
	local selectIdleVillagerHuntingNovgorod = Training_Goal(
		"Squad", 
		{
			ID= "Hunting animals provide the Rus with a bounty of Gold.  LEFT CLICK / PRESS A to select a Villager.", 
			Message=UI_PickIDForInputMode(11184922, 11248563),
			DataTemplate="LeftClickTrainingDataTemplate"
		},
		UserHasSelectedAVillagerNov		--isComplete
	)
	
	local viewHuntingAbilityNov = Training_Goal(
		"RusBountyTag", 
		{
			ID= "Each type of animal will provide a different bounty. View the bounties here.",
			Message="$11184923", 
			DataTemplate="GenericTrainingDataTemplate"
		}, 
		Predicate_UserHasViewedHuntingAbility --isComplete
	)
	
	local VillagerViewsHuntingAbilityNov = Training_GoalSequence(
		goal_hunting_bounty_rusNov, 								--id
		1,															--repeatmax 
		1, 															--remind max
		HasIdleVillagerOnScreenNov, 								--trigger
		TimerORIgnore_UserCannotSeeSquadKey, 						--ignore
		nil, 														--remind
		UserHasHunted, 												--bypass 
		true, 														--canRegress
		{selectIdleVillagerHuntingNovgorod,viewHuntingAbilityNov}
	)
	Training_AddGoalSequence(VillagerViewsHuntingAbilityNov)
	
end

function Tutorials_novgorod_HintCabin_Xbox()
	
	local goal_hunting_cabin_rus = "hunting_cabin_rus"
		
	-- Villager Hunting Cabin
	local selectIdleVillagerCabinNov = Training_Goal("Squad", 
		{ID= "Hunting Cabins can slowly generate gold. Press (A) to select a Villager.", Message="$11248564", DataTemplate="GenericTrainingDataTemplate"},
		UserHasSelectedAVillagerNov)
	
	local GoalOnOpenRadial = Training_Goal(
			"Squad",
