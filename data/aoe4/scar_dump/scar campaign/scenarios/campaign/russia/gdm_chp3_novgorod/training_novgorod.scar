function Training_InitNov()
	training_previousConstructionBlueprint = nil
	training_currentConstructionBlueprint = nil
	
	sg_currentSelectionMonk = SGroup_CreateIfNotFound("sg_currentSelectionMonk")
	sg_currentSelectionIvan = SGroup_CreateIfNotFound("sg_currentSelectionIvan")

	UI_SetModalConstructionPhaseCallback(OnConstructionPhaseChange)	
	UI_SetModalAbilityPhaseCallback(OnAbilityPhaseChange)
	UI_SetModalHoverCallback(OnHoverChange)

end

