function novgorod_OnAbilityExecutedRightTime(context)
	
	-- We want to watch this ability
	g_ivan_production = BP_GetAbilityBlueprint("leader_production_activated")
	
	if context.ability == g_ivan_production then
		
	--	Rule_RemoveGlobalEvent()
		print("ABILITY DONE ABILITY DONE")
		b_used_ivan_abilityRightTime = true 

	end
	
end

function HasIdleVillagerCabinOnScreenNov_Xbox(goalSequence)
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	
	if currentTime > __t_trainingShortInterval then	
		local localPlayer = Game_GetLocalPlayer()
		Player_GetAll(localPlayer)
		
		local squads = Player_GetSquads(localPlayer)
		local entities = Player_GetEntities(localPlayer)
		
		goalSequence.goals[1].key = nil
		goalSequence.goals[2].key = nil
		goalSequence.goals[3].key = nil
		
		
		local squad = Nov_PickConvenientVillager()
		
		if squad ~= nil then
			goalSequence.goals[1].key = squad
			goalSequence.goals[2].key = squad
			goalSequence.goals[3].key = EBP.RUS.BUILDING_HUNTING_CABIN_RUS
		end
		
		if goalSequence.goals[1].key ~= nil then
			return true
		end
	end
	
	return false
end

function HasIdleVillagerCabinOnScreenNov(goalSequence)
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	
	if currentTime > __t_trainingShortInterval then	
		local localPlayer = Game_GetLocalPlayer()
		Player_GetAll(localPlayer)
		
		local squads = Player_GetSquads(localPlayer)
		local entities = Player_GetEntities(localPlayer)
		
--		EGroup_Filter(entities, {"building_hunting_cabin_rus"}, FILTER_KEEP)
--		local huntingCabinPresent = EGroup_Count(entities) > 0
		
--		if huntingCabinPresent then
--			return false	
--		end
		
		goalSequence.goals[1].key = nil
		goalSequence.goals[2].key = nil
		
		for i = 1, SGroup_Count(squads) do
			local squad = SGroup_GetSquadAt(squads, i)
			
			if squad ~= nil and Squad_GetBlueprint(squad) == SBP.RUS.UNIT_VILLAGER_1_RUS then
				if Misc_IsSquadOnScreen(squad, 100) then
					goalSequence.goals[1].key = Squad_GetID(squad)
					goalSequence.goals[2].key = BP_GetEntityBlueprint("building_hunting_cabin_rus")
					break
				end
			end
		end
		
		if goalSequence.goals[1].key ~= nil then
			return true
		end
	end
	
	return false
end

function Nov_CabinEconRadialOpen (goal)
	return UI_GetActiveRadialMenuType() == RMT_ContextualRadialMenu and UI_GetActiveRelicRadialMenuDirection() == RMD_Left 
end

-- Also used with a goalSequence
function UserHasStartedToBuildAHuntingCabinNov(goal)
	return UserHasStartedToBuildABuilding("scar_gristmill")
end

function UserIsGoingToBuildAHuntingCabinNov(goal)
	return UserIsGoingToBuildBuildingType("scar_gristmill")
end

function UserHasRelicNov(goal)

--	print( "USER HAS RELIC - CHECK")
	if b_relic_picked == true then
--		print( "USER HAS RELIC - TRUE")
		return true
	end
--	print( "USER HAS RELIC - FALSE")
	return false
	
end


function UserHasBuiltCabinNov(goalSequence)
	
	Player_GetAll(player1)
	
	EGroup_Filter(eg_allentities, {EBP.RUS.BUILDING_HUNTING_CABIN_RUS,EBP.CAMPAIGN.BUILDING_HUNTING_CABIN_NOV}, FILTER_KEEP)
	
	huntingCabinPresent = EGroup_CountSpawned(eg_allentities) - EGroup_CountSpawned(eg_huntingcab)
--	print(huntingCabinPresent)
	
	if huntingCabinPresent > 0 then
		return true
	end
	
	return false
end

function UserHasViewedHuntingCabinNov(goal)
	if _g_tempHuntingCabinTimer == nil then
		_g_tempHuntingCabinTimer = Training_GetNewTimerID()
		Timer_Start(_g_tempHuntingCabinTimer, 3)
	else
		local currentTime = Timer_GetRemaining(_g_tempHuntingCabinTimer)
		if currentTime <= 0 then
			Timer_End(_g_tempHuntingCabinTimer)
			_g_tempHuntingCabinTimer = nil
			return true	
		end
	end
end

function UserHasViewedHuntingAbilityNov(goal)
	if _g_tempHuntingTimer == nil then
		_g_tempHuntingTimer = Training_GetNewTimerID()
		Timer_Start(_g_tempHuntingTimer, 3)
	else
		local currentTime = Timer_GetRemaining(_g_tempHuntingTimer)
		if currentTime <= 0 then
			Timer_End(_g_tempHuntingTimer)
			_g_tempHuntingTimer = nil
			return true	
		end
	end
end

function UserHasSelectedAVillagerNov(goal)
	
	local sg_currentSelection = SGroup_CreateIfNotFound("sg_currentSelection")
	local villagerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", Game_GetLocalPlayer())
	Misc_GetSelectedSquads(sg_currentSelection, false)
	for i = 1, SGroup_Count(sg_currentSelection) do
		local squad = SGroup_GetSquadAt(sg_currentSelection, i)
		if Squad_GetBlueprint(squad) == villagerBP then
			return true
		end
	end
	
	return false
end


function HasHolySiteOnScreenNov(goalSequence)
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	
	if currentTime > __t_trainingHoverInterval then	
		local localPlayer = Game_GetLocalPlayer()
		Player_GetAll(localPlayer)
	--	local squads = Player_GetSquads(localPlayer)
		
		goalSequence.goals[1].key = nil
		--goalSequence.goals[2].key = nil
		--goalSequence.goals[3].key = nil
			
		Player_GetAll(player1,sg_allsquads)
		SGroup_Filter(sg_allsquads,"scar_monk",FILTER_KEEP)		
		
		for i = 1, EGroup_Count(eg_holy_site) do
			local entity = EGroup_GetEntityAt(eg_holy_site, i)
			
			if entity ~= nil and Entity_GetBlueprint(entity) == BP_GetEntityBlueprint("holy_site") then
					if Misc_IsEntityOnScreen(entity, 100) and SGroup_CountSpawned(sg_allsquads) > 0 then 
						goalSequence.goals[1].key = Entity_GetPosition(entity)
						break
					end
				
			end
		end
		
		if goalSequence.goals[1].key ~= nil then
			return true
		end

	end
	
	return false
end

function UserHasCapturedHolySite_Nov(goal)
	
	
	--Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_
	
	for i = 1, EGroup_Count(eg_holy_site) do
		local entity = EGroup_GetEntityAt(eg_holy_site, i)
		
		--Does the player have a monk nearby?
		Player_GetAllSquadsNearMarker(player1, sg_temp, Entity_GetPosition(entity), 8)
		SGroup_Filter(sg_temp, "scar_monk", FILTER_KEEP)
		if not SGroup_IsEmpty(sg_temp) then
			return true
		end
		
		--if World_OwnsEntity(entity) == false and Entity_GetPlayerOwner(entity) == player1 then
			--return true
		--end
	end
	
	
	return false
end


