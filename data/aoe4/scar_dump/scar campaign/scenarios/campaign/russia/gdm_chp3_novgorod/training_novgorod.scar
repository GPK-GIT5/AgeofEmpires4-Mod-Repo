function UserHasSelectedAMonkNov(goal)
	
	local MonkBP = Cardinal_ConvertTypeToSquadBlueprint("scar_monk", Game_GetLocalPlayer())
--	print("Checking USER MONK")
	Misc_GetSelectedSquads(sg_currentSelectionMonk, false)
	for i = 1, SGroup_Count(sg_currentSelectionMonk) do
		local squad = SGroup_GetSquadAt(sg_currentSelectionMonk, i)
		if Squad_GetBlueprint(squad) == MonkBP then
			print("Inside user selected a Monk - true")
			return true
		end
	end
--	print("NO monk selected")
	return false
end

--Bounty Hint
function HasIdleVillagerOnScreenNov(goalSequence)
	local currentTime = Timer_GetElapsed(goalSequence.timerID)
	if currentTime > 0.5 then	
		local localPlayer = Game_GetLocalPlayer()
		Player_GetAll(localPlayer)
		local squads = Player_GetSquads(localPlayer)
		local farmBPTable = Cardinal_ConvertTypeToEntityBlueprint("farm", localPlayer,true) -- hunter_gather_rus

		goalSequence.goals[1].key = nil
		--goalSequence.goals[2].key = nil
		
		for i = 1, SGroup_Count(squads) do
			local squad = SGroup_GetSquadAt(squads, i)
			
			if squad ~= nil and Squad_IsOfType(squad, "scar_villager") then
					if Misc_IsSquadOnScreen(squad, 100) then 
						goalSequence.goals[1].key = Squad_GetID(squad)
						--goalSequence.goals[2].key = farmBPTable[1] --BP_GetAbilityBlueprint("hunter_gather_rus")
						break
					end
			end
		end
		
		if goalSequence.goals[1].key ~= nil then
			return true
		end
	end
	
	return false
end

function Predicate_UserHasViewedHuntingAbility(goal)
	if _g_tempHuntingTimer == nil then
		_g_tempHuntingTimer = Training_GetNewTimerID()
		Timer_Start(_g_tempHuntingTimer, 10)
	else
		local currentTime = Timer_GetRemaining(_g_tempHuntingTimer)
		if currentTime <= 0 then
			Timer_End(_g_tempHuntingTimer)
			_g_tempHuntingTimer = nil
			return true	
		end
	end
end

----------------------------------
-- Utility Functions
----------------------------------

function _DelayTimeElapsed(goal)
	local currentTime = Timer_GetElapsed(goal.timerID)
	
	if currentTime >= __t_trainingModerateInterval then
		return true
	end
end


----------------------------------
-- View Ivan III Leader Aura
----------------------------------

function MissionTutorial_IvanLeaderAura_XBox()
	
	local goal_sequence_leaderability = "goal_sequence_leaderability"
	
	if SGroup_CountSpawned(g_leaderKingIvan.sgroup) >= 1 and Player_OwnsSGroup(player1, g_leaderKingIvan.sgroup, ALL) then 
		
		local Goal_SelectIvan = Training_Goal(
			SGroup_GetSpawnedSquadAt(g_leaderKingIvan.sgroup, 1),
			{
				ID = "Leaders have unique abilities they can activate at any time. Press D-Pad Right to select Ivan III.",
				Message = "$11248562",
				DataTemplate = "GenericTrainingDataTemplate",
			},
			Predicate_UserHasSelectedIvan
		)
		
		local GoalOnOpenRadial = Training_Goal(
			SGroup_GetSpawnedSquadAt(g_leaderKingIvan.sgroup, 1),
			{
				ID = "Hold RT to see Ivan's abilities.",
				Message = "$11248561",
				DataTemplate = "GenericTrainingDataTemplate",
			},
			UserHasOpenedContextualRadial
		)
		
		local Goal_HoverOverAbility = Training_Goal(
			BP_GetAbilityBlueprint("leader_production_activated"),
			{
				ID = "Ivan III's ability increases the unit and upgrade production speed of all nearby buildings.",
				Message = "$11194978",
				DataTemplate = "RadialTrainingDataTemplate",
			},
			Predicate_UserHasLookedAtIvanAbility
		)
		
		local GoalSequence_LeaderAbility = Training_GoalSequence(
			goal_sequence_leaderability, 										-- id
			1, 																	-- repeatMax
			0, 																	-- remindMax
			Predicate_UserHasNotActivatedIvanLeaderAbilityRecently, 			-- trigger
			CampaignTraining_TimeoutIgnorePredicate, 							-- ignore
			nil,														 		-- remind
			Predicate_UserHasLookedAtIvanAbility, 		 						-- bypass
			true, 																-- canRegress
			{Goal_SelectIvan, GoalOnOpenRadial, Goal_HoverOverAbility}							-- goals
		)
		Training_AddGoalSequence(GoalSequence_LeaderAbility)
		
		
	end
	
end

function MissionTutorial_IvanLeaderAura()
	
	local goal_sequence_leaderability = "goal_sequence_leaderability"
	
	if SGroup_CountSpawned(g_leaderKingIvan.sgroup) >= 1 and Player_OwnsSGroup(player1, g_leaderKingIvan.sgroup, ALL) then 
		
		local Goal_SelectIvan = Training_Goal(
			SGroup_GetSpawnedSquadAt(g_leaderKingIvan.sgroup, 1),
			{
				ID = "Leaders have unique abilities they can activate at any time. Select Ivan III to see his special ability.",
				Message = "$11202589",
				DataTemplate = "LeftClickTrainingDataTemplate",
			},
			Predicate_UserHasSelectedIvan
		)
		local Goal_HoverOverAbility = Training_Goal(
			BP_GetAbilityBlueprint("leader_production_activated"),
			{
				ID = "Ivan III's ability increases the unit and upgrade production speed of all nearby buildings.",
				Message = "$11194978",
				DataTemplate = "GenericTrainingDataTemplate",
			},
			Predicate_UserHasLookedAtIvanAbility
		)
		
		local GoalSequence_LeaderAbility = Training_GoalSequence(
			goal_sequence_leaderability, 										-- id
			1, 																	-- repeatMax
			0, 																	-- remindMax
			Predicate_UserHasNotActivatedIvanLeaderAbilityRecently, 			-- trigger
			CampaignTraining_TimeoutIgnorePredicate, 							-- ignore
			nil,														 		-- remind
			Predicate_UserHasLookedAtIvanAbility, 		 						-- bypass
			true, 																-- canRegress
			{Goal_SelectIvan, Goal_HoverOverAbility}							-- goals
		)
		Training_AddGoalSequence(GoalSequence_LeaderAbility)
		
		
	end
	
end

function Predicate_UserHasSelectedIvan(goal)
	
	Misc_GetSelectedSquads(sg_temp, true)
	return SGroup_CountSpawned(g_leaderKingIvan.sgroup) >= 1 and SGroup_ContainsSGroup(sg_temp, g_leaderKingIvan.sgroup, ALL)
	
end

function Predicate_UserHasLookedAtIvanAbility(goal)
	
	local abilityBP = BP_GetAbilityBlueprint("leader_production_activated")
	return SGroup_CountSpawned(g_leaderKingIvan.sgroup) >= 1 and (PredicateHelper_HasUserHoveredOverBP(goal, abilityBP) or training_previousAbilityBlueprint == abilityBP)
	
end

function Predicate_UserHasNotActivatedIvanLeaderAbilityRecently(goalSequence)
	
	return SGroup_CountSpawned(g_leaderKingIvan.sgroup) >= 1 and Player_OwnsSGroup(player1, g_leaderKingIvan.sgroup, ALL)
	
end


-- util function to find a villager, preferring one that is idle and on screen

function Nov_PickConvenientVillager()
	
	local bestSquad = nil
	
	Player_GetAll(player1)
	SGroup_Filter (sg_allsquads, "scar_villager", FILTER_KEEP)
	
	for i = 1, SGroup_Count(sg_allsquads) do
		local squad = SGroup_GetSquadAt(sg_allsquads, i)
		local isIdle =  Squad_IsIdle(squad)
		local isOnScreen = Misc_IsSquadOnScreen(squad, 1)
		if isIdle and isOnScreen then
			return squad
		elseif isIdle then
			bestSquad = squad
		elseif isOnScreen then
			bestSquad = bestSquad or squad
		end
	end
	
	return bestSquad	
	
end
