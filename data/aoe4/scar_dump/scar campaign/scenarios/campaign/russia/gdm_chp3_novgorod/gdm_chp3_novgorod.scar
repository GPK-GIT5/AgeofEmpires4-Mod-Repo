function Novgorod_MoveStartingUnits()
	
	Rule_AddOneShot(Move_ScoutIntro,1)
	
	intro_ivan_speed = Modify_UnitSpeed(g_leaderKingIvan.sgroup, 0.5)
	Cmd_FormationMove(g_leaderKingIvan.sgroup, mkr_player_spawn_spm02_moveto )
	Cmd_FormationMove(g_leaderKingIvan.sgroup, mkr_player_spawn_king_moveto, true )

	intro_monk_speed = Modify_UnitSpeed(sg_player_monk01, 0.5)
	Cmd_FormationMove(sg_player_monk01, mkr_player_spawn_monk01b)
	Cmd_FormationMove(sg_player_monk01, mkr_player_spawn_monk01_moveto, true)
	
	intro_monk_speed02 = Modify_UnitSpeed(sg_player_monk02, 0.5)
