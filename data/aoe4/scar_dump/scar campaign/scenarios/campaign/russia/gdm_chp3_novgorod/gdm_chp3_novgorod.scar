function CheckPlayerReachedSkirino()
	Player_GetAll(player1,sg_allsquads)
	SGroup_Filter(sg_allsquads,"scar_villager",FILTER_REMOVE)
	
	if Prox_AreSquadsNearMarker(sg_allsquads,mkr_enemy_town03_threshold_02,ANY,50) or Prox_AreSquadsNearMarker(sg_allsquads,mkr_enemy_town03_threshold_01,ANY,50) then
		AttackPlayerCloseFort()
		Rule_RemoveMe()
		
	end
end

