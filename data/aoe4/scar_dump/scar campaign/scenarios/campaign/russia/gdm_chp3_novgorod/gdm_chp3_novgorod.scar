function Mission_SetRestrictions()	-- set up any restrictions (i.e. locking out units, etc) in here
	Modify_PlayerMaxPopCap(player1, -10, MUT_Addition)
end

function Mission_Preset()	-- any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)
	
	PlayerColour_Enable()
	
	PlayerUpgrades_Auto(player1)
	PlayerUpgrades_Auto(player2, false, {UPG.COMMON.UPGRADE_TECH_UNIVERSITY_MURDER_HOLES_4})
	PlayerUpgrades_Auto(player4, false, {UPG.COMMON.UPGRADE_TECH_UNIVERSITY_MURDER_HOLES_4})
	
	--player 1 restrictions and upgrades
	Player_SetEntityProductionAvailability(player1,EBP.RUS.BUILDING_ECON_MARKET_CONTROL_RUS,ITEM_REMOVED)
	Player_SetAbilityAvailability(player1, BP_GetAbilityBlueprint("monk_conversion"), ITEM_REMOVED)	
	Player_SetStateModelFloat(player1, "master_hunter_bounty_total_rus",0)
	UI_SetPlayerDataContext(player1, {PopulationCapOn = false}) --Sets the player popcap to 0. Gotta update this when the player caps the first village
	
	if Game_GetSPDifficulty() > 0 then --If Diff harder than Story, outposts get Springalds
			--player 2 upgrades
		Player_GetAll(player2,sg_allsquads,eg_allentities)
		EGroup_Filter(eg_allentities, EBP.CAMPAIGN.BUILDING_DEFENSE_WOODEN_FORT_NOV, FILTER_KEEP)
		Cmd_InstantUpgrade(eg_allentities, UPG.RUS.UPGRADE_WOODEN_CASTLE_SPRINGALD_RUS)
	end
	
	--player 4 upgrades
	Player_GetAll(player4,sg_allsquads,eg_allentities)
	EGroup_Filter(eg_allentities, EBP.CAMPAIGN.BUILDING_DEFENSE_WOODEN_FORT_NOV, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.RUS.UPGRADE_WOODEN_CASTLE_ARROWSLITS_RUS)
	
	--Give the monastery some relics
	local monasteryID02 = EGroup_GetSpawnedEntityAt(eg_monastery_novgorod, 1)
	Entity_SetStateModelFloat(monasteryID02, "relic_count", 1)
			
	--Initialize the objectives
	GetThroughNovgorodDefences_InitObjectives()
	CaptureLocations_Initkuklino()
	CaptureLocations_Initsoltsy()
	CaptureLocations_InitOptionalObjectives()
	middle_battle_InitObjectives()
	DestroyNovgorod_InitObjectives()

	AssignVillagersToFarms(sg_villagers_enemytown)
	AssignVillagersToWood(sg_villagers_enemytown_wood)
	AssignVillagersToFarms(sg_villagers_enemytown02)
	
	Mission_SpawnDeersStartArea()
	if Game_GetSPDifficulty() > GD_EASY then --Turn off waves in Story mode
		SetupAttackWaves()
	end
	
	Sound_ResetMusicIntensityMapping()
	Sound_AddMusicIntensityMappingPoint(40, 650) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(350, 4000) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(800, 9999) -- raw value max to scaled value max 
	
	--Spawning the player's units for the intro sequence
	Novgorod_SpawnStartingUnits()
end

function Mission_SetDifficulty()

	t_difficulty = {
		given_resources_gold = Util_DifVar({1000, 800, 400, 250}), 
		given_resources_wood = Util_DifVar({200, 200, 150, 100}),
		given_resources_food = Util_DifVar({200, 200, 150, 100}),
		given_resources_stone = Util_DifVar({100, 100, 70, 60}),
		
		i_request_Nov_upperThreshold = Util_DifVar({0.6, 0.7, 0.8, 0.9}),
		i_request_Nov_lowerThreshold = Util_DifVar({0.15, 0.2, 0.2, 0.1}),
		i_request_Nov_desiredStrength = Util_DifVar({0.7, 0.8, 0.9, 1.0}),
		
		i_maximumNumberOfWolves = Util_DifVar({10, 10, 8, 6}), 
		i_maximumNumberOfAnimals = Util_DifVar({30, 22, 20, 15}),
		i_maximumNumberOfAnimalsTown01 = Util_DifVar({20, 15, 12, 10}),
		
		enemy_unitBuildTime = Util_DifVar({30, 25, 10, 12}),
		enemy_eliteUnitBuildTime = Util_DifVar({40, 30, 15, 14}),
	}
	
	--Lower production times for units
	if Game_GetSPDifficulty() == GD_EXPERT then
		Wave_OverrideUnitBuildTime("scar_spearman", t_difficulty.enemy_unitBuildTime)
		Wave_OverrideUnitBuildTime("scar_manatarms", t_difficulty.enemy_eliteUnitBuildTime)
		Wave_OverrideUnitBuildTime("scar_archer", t_difficulty.enemy_unitBuildTime)
		Wave_OverrideUnitBuildTime("scar_horseman", t_difficulty.enemy_unitBuildTime)
		Wave_OverrideUnitBuildTime("scar_horsearcher", t_difficulty.enemy_eliteUnitBuildTime)
		Wave_OverrideUnitBuildTime("scar_knight", t_difficulty.enemy_eliteUnitBuildTime)
	end

  end

function Mission_Start()	-- this is triggered after the intro, just as control is passed to the player
	
	-- on console don't restore VPS at first
	Cardinal_EnablePartialXboxUI(true, {VF_XboxUIVillagerPriorities})

	Objective_Start(OBJ_ConquerNovgorod,false,false)
	Objective_Start(OBJ_SettleBase,true, true)
	
	--Rule_AddInterval(Mission_AddMoreWolvesNovgorod,30)
	--Rule_AddInterval(Mission_AddMoreAnimalsNovgorod,10)
	--Rule_AddInterval(Mission_AddMoreAnimalsNovgorodTown01,15)
	
	Player_SetResource( player1, RT_Gold, t_difficulty.given_resources_gold) --400
	Player_SetResource( player1, RT_Wood, t_difficulty.given_resources_wood) --200
	Player_SetResource( player1, RT_Food, t_difficulty.given_resources_food) --200
	Player_SetResource( player1, RT_Stone, t_difficulty.given_resources_stone) 
	
	Action_SetResources_Do({ player = player2, resources = { food = 30000, wood = 30000, stone = 30000, gold = 30000 } })
	Action_SetResources_Do({ player = player4, resources = { food = 30000, wood = 30000, stone = 30000, gold = 30000 } })

	--Rule_AddInterval(CheckPlayerReachedSkirino,2)
	Training_InitNov()
	
	Rule_AddInterval(Novgorod_ProxFunctionCall, 1, {marker = mkr_enemy_town03, range = 90, call_function = Novgorod_SkirinoVillagerLife})
	Rule_AddInterval(Novgorod_ProxFunctionCall, 1, {marker = mkr_enemy_novgorod_front, range = 90, call_function = Novgorod_NovgorodVillagerLife})
	
	UnitEntry_DeploySquads(player4, sg_militia_01, {sbp = BP_GetSquadBlueprint("unit_militia_1_rus"), numSquads = Util_DifVar({20, 20, 20, 30})}, mkr_militia_holdingspawn)

	Game_TransitionToState("tiaga_winter_sunset", 450)
end


