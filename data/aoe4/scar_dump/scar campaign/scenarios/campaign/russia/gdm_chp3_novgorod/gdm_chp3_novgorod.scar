-- Mission Title and Date (i.e. Novgorod 1478)
--
-- Campaign, mission number (i.e. Rus campaign, Mission )
--

import("MissionOMatic/MissionOMatic.scar")		-- this imports the Cardinal scripts as well

import("obj_capture_village.scar")
import("obj_middle_battle.scar")
import("obj_getthroughnovgorod.scar")
import("obj_destroy_novgorod.scar")
import("training_novgorod.scar")

function Mission_SetupPlayers()

	player1 = World_GetPlayerAt(1) -- Rus
	player2 = World_GetPlayerAt(2) -- Novgorod units
	player3 = World_GetPlayerAt(3) --king
	player4 = World_GetPlayerAt(4) --first villages
	
	-- player 1 - Rus
	Setup_SetPlayerName(player1, "$11172087") -- Ivan the Great
	Player_SetCurrentAge(player1, AGE_CASTLE)
	Player_SetMaximumAge(player1, AGE_IMPERIAL)
	
	-- player 2 - Novgorod units	
	Setup_SetPlayerName(player2, "$11172086") --Novgorod
	Player_SetCurrentAge(player2, AGE_CASTLE)
	Player_SetMaximumAge(player2, AGE_CASTLE)

	-- player 3 - neutral holder	
	Setup_SetPlayerName(player3, "$11172085") --Rus
	Player_SetCurrentAge(player3, AGE_CASTLE)
	Player_SetMaximumAge(player3, AGE_CASTLE)
	
	-- player 4 - towns
	Setup_SetPlayerName(player4, "$11172086") --Rus
	Player_SetCurrentAge(player4, AGE_FEUDAL)
	Player_SetMaximumAge(player4, AGE_FEUDAL)
		
	-- set player relationships	
	Player_SetRelationship(player1,player2,R_ENEMY)
	Player_SetRelationship(player1,player3,R_ALLY)
	Player_SetRelationship(player2,player1,R_ENEMY)
	Player_SetRelationship(player2,player3,R_ALLY)
	Player_SetRelationship(player2,player4,R_ALLY)
	Player_SetRelationship(player3,player1,R_ALLY)
	Player_SetRelationship(player4,player2,R_ALLY)
	Player_SetRelationship(player4,player3,R_ALLY)
	
	--Set player colours
	--PlayerColour_Enable()
	--Game_SetPlayerUISlotColour(player2, 2)
	--Game_SetPlayerUISlotColour(player3, 9)
	--Game_SetPlayerUISlotColour(player4, 2)
	
	--
	-- Set Player Colours
	--
	
	PlayerColour_Enable()								--Turn on custom colour configuration for this session
	
	Game_SetPlayerSlotColour(player1, 1)			--Paint Scheme
	Game_SetPlayerUISlotColour(player1, 1)		--UI Colour
	
	Game_SetPlayerSlotColour(player2, 2)			--Paint Scheme
	Game_SetPlayerUISlotColour(player2, 2)		--UI Colour
	
	Game_SetPlayerSlotColour(player3, 1)	--Paint Scheme
	Game_SetPlayerUISlotColour(player3, 1)--UI Colour
	
	Game_SetPlayerSlotColour(player4, 2)			--Paint Scheme
	Game_SetPlayerUISlotColour(player4, 2)		--UI Colour
	
end

