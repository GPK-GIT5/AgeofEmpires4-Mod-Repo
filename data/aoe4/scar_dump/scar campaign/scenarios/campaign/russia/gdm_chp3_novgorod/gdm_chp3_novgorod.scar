end

function Novgorod_AreSGroupsDestroyed(sgroup_table)
	
	for i, sgroup in ipairs(sgroup_table) do
		if not SGroup_IsEmpty(sgroup_table[i]) then
			return false
		end
	end
	
	return true
end

function Novgorod_CountSGroups(sgroup_table)
	
	local count = 0
	
	for i, sgroup in ipairs(sgroup_table) do
		local current_count = SGroup_CountSpawned(sgroup)
		count = count + current_count
	end
	
	return count
end

--Wall wallas
function Novgorod_SoltsyWallWalla(context)
	if context.victim ~= nil then
		Rule_AddOneShot(Novgorod_DelayedAudioStinger, 1, {position = Util_GetPosition(context.victim)})
		Rule_RemoveEGroupEvent(Novgorod_SoltsyWallWalla, eg_soltsywalls)
	end
end

function Novgorod_SkirinoWallWalla(context)
	if context.victim ~= nil then
		Rule_AddOneShot(Novgorod_DelayedAudioStinger, 1, {position = Util_GetPosition(context.victim)})
		Rule_RemoveEGroupEvent(Novgorod_SkirinoWallWalla, eg_skirinowalls)
		Game_TransitionToState("tiaga_winter_dusk", 300)
	end
end

function Novgorod_NovgorodOuterWallWalla(context)
	if context.victim ~= nil then
		Rule_AddOneShot(Novgorod_DelayedAudioStinger, 1, {position = Util_GetPosition(context.victim)})
		Rule_RemoveEGroupEvent(Novgorod_NovgorodOuterWallWalla, eg_novgorodouterwalls)
	end
end

function Novgorod_NovgorodInnerWallWalla(context)
	if context.victim ~= nil then
		Rule_AddOneShot(Novgorod_DelayedAudioStinger, 1, {position = Util_GetPosition(context.victim)})
		Rule_RemoveEGroupEvent(Novgorod_NovgorodInnerWallWalla, eg_novgorodinnerwalls)
	end
end

function Novgorod_DelayedAudioStinger(context, data)
	--Choir stinger
	Sound_Play2D(MUS_STING_TRIUMPHANT)
	print("Playing stinger and walla")
	--Walla celebrate from nearby units
	SGroup_Clear(sg_temp)
	Player_GetAllSquadsNearMarker(player1, sg_temp, data.position, 30) 
	Sound_PlayWallaCelebrateOnSGroup(sg_temp)
end

--------------------------------------------------------------------------------------------------------------------------------------------------
--															VILLAGER LIFE
--------------------------------------------------------------------------------------------------------------------------------------------------

function Novgorod_ProxFunctionCall(context, data)
	if Prox_ArePlayersNearMarker(player1, data.marker, ANY, data.range) then
		data.call_function()
		Rule_RemoveMe()
	end
end

function Novgorod_SkirinoVillagerLife()
	
	skirino_villagerlife_east = VillagerLife_Find("skirino_villagerlife_east")
	skirino_villagerlife_west = VillagerLife_Find("skirino_villagerlife_west")
	skirino_villagerlife_front = VillagerLife_Find("skirino_villagerlife_front")
	
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player2, sg_temp, {type = "scar_villager", numSquads = 8}, skirino_villagerlife_east.mkr_home)
	VillagerLife_AddSGroup(skirino_villagerlife_east, sg_temp)
	
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player2, sg_temp, {type = "scar_villager", numSquads = 8}, skirino_villagerlife_west.mkr_home)
	VillagerLife_AddSGroup(skirino_villagerlife_west, sg_temp)
	
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player2, sg_temp, {type = "scar_villager", numSquads = 8}, skirino_villagerlife_front.mkr_home)
	VillagerLife_AddSGroup(skirino_villagerlife_front, sg_temp)
	
end

function Novgorod_NovgorodVillagerLife()
	
	novgorod_villagerlife_front_1 = VillagerLife_Find("novgorod_villagerlife_front_1")
	novgorod_villagerlife_front_2 = VillagerLife_Find("novgorod_villagerlife_front_2")
	novgorod_villagerlife_back_1 = VillagerLife_Find("novgorod_villagerlife_back_1")
	novgorod_villagerlife_back_2 = VillagerLife_Find("novgorod_villagerlife_back_2")
	
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player2, sg_temp, {type = "scar_villager", numSquads = 14}, novgorod_villagerlife_front_1.mkr_home)
	VillagerLife_AddSGroup(novgorod_villagerlife_front_1, sg_temp)
	
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player2, sg_temp, {type = "scar_villager", numSquads = 6}, novgorod_villagerlife_front_2.mkr_home)
	VillagerLife_AddSGroup(novgorod_villagerlife_front_2, sg_temp)
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player2, sg_temp, {type = "scar_villager", numSquads = 7}, novgorod_villagerlife_front_2.mkr_home)
	VillagerLife_AddSGroup(novgorod_villagerlife_front_2, sg_temp, "food")
	
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player2, sg_temp, {type = "scar_villager", numSquads = 6}, novgorod_villagerlife_back_1.mkr_home)
	VillagerLife_AddSGroup(novgorod_villagerlife_back_1, sg_temp)
	
	SGroup_Clear(sg_temp)
	UnitEntry_DeploySquads(player2, sg_temp, {type = "scar_villager", numSquads = 6}, novgorod_villagerlife_back_2.mkr_home)
	VillagerLife_AddSGroup(novgorod_villagerlife_back_2, sg_temp)
end

