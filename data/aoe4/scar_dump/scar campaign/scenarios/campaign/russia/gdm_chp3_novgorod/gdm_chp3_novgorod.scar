function Intro_RoutVillagers()
	if not SGroup_IsEmpty(sg_enemyTown01_cabin) then
		Cmd_FormationMoveToAndDestroy(sg_enemyTown01_cabin, mkr_hunting_cabin_site_6)
	end
end

function Move_ScoutIntro()
	if b_IntroSkipped == false then 
		Cmd_FormationMove(sg_rus_enemy_scout_intro, mkr_rus_scout_intro_spawn, true)
		Cmd_FormationMove(sg_rus_enemy_scout_intro, mkr_rus_scout_intro_moveto, true )
		
		SGroup_DestroyAllSquads(sg_enemyTown01_cabin)
		
		Rule_AddOneShot(SetIntroScoutDefend,10)
	end
end

function SetIntroScoutDefend()
	if b_IntroSkipped == false then 
		Prefab_DoAction(MissionOMatic_FindModule("enemytownDefend"), 'AddSGroup', sg_rus_enemy_scout_intro)
	end
end
		
function AttackPlayerCloseFort()
	if Objective_IsStarted(OBJ_MiddleBattle) == false then
		print("Start OBJ_MiddleBattle")
		Objective_Start(OBJ_MiddleBattle, true, true)
	end		
end	
		
function Mission_AddMoreWolvesNovgorod()
	if SGroup_CountSpawned(sg_wolves) < t_difficulty.i_maximumNumberOfWolves then 

		SGroup_Clear(sg_temp)
		-- pick a hidden position
		local marker = Table_GetRandomItem(t_wolfSpawnMarkers)
		local randomPosition = Util_GetRandomPosition(marker,10)
		local randomPosition2 = Util_GetRandomPosition(marker,10)
		local randomPosition3 = Util_GetRandomPosition(marker,10)
		
		if scartype(randomPosition) == ST_SCARPOS then	
			-- spawn a wolf
			local units = {sbp = SBP.GAIA.GAIA_HUNTABLE_WOLF, numSquads = 1}
			Player_GetAll(player1,sg_allsquads)
			
			if not Player_CanSeePosition(player1,randomPosition) and not Prox_ArePlayersNearMarker(player1, marker, ANY, 40, "gaia", FILTER_REMOVE) then
				UnitEntry_DeploySquads(player1, sg_temp, units, randomPosition)
			end
			
			if not Player_CanSeePosition(player1,randomPosition2) and not Prox_ArePlayersNearMarker(player1, marker, ANY, 40, "gaia", FILTER_REMOVE) then
				UnitEntry_DeploySquads(player1, sg_temp, units, randomPosition2)
			end
			
			if not Player_CanSeePosition(player1,randomPosition3) and not Prox_ArePlayersNearMarker(player1, marker, ANY, 40, "gaia", FILTER_REMOVE) then
				UnitEntry_DeploySquads(player1, sg_temp, units, randomPosition3)
			end
			
			if SGroup_CountSpawned(sg_temp) > 0 then
				-- set it to neutral
				SGroup_SetWorldOwned(sg_temp)
				SGroup_AddGroup(sg_wolves, sg_temp)
			end
		else
			print("Warning - Could not find a position to spawn a wolf")
		end
	end
end

function Mission_SpawnDeersStartArea()
	SGroup_Clear(sg_temp)
	
	local units = {sbp = SBP.GAIA.GAIA_HUNTABLE_DEER, numSquads = 1}

	UnitEntry_DeploySquads(player1, sg_temp, units, mkr_enemy_town_villager_cabin_deer01)
	UnitEntry_DeploySquads(player1, sg_temp, units, mkr_enemy_town_villager_cabin_deer02)
	UnitEntry_DeploySquads(player1, sg_temp, units, mkr_enemy_town_villager_cabin_deer03)
	UnitEntry_DeploySquads(player1, sg_temp, units, mkr_enemy_town_villager_cabin_deer04)
	
	SGroup_SetWorldOwned(sg_temp)

	Rule_AddOneShot(ShootDeers,1)
	Rule_AddOneShot(Intro_RoutVillagers, 2)
	--Intro_RoutVillagers()
end

function ShootDeers()
	AssignVillagersToDeer(sg_enemyTown01_cabin)
end

function Mission_AddMoreAnimalsNovgorod()
	if SGroup_CountSpawned(sg_animals) < t_difficulty.i_maximumNumberOfAnimals then 

		SGroup_Clear(sg_temp)
		
		-- pick a hidden position
		local marker = Table_GetRandomItem(t_animalsSpawnMarkers)
		local randomPosition = Util_GetRandomPosition(marker,10)
		
		if scartype(randomPosition) == ST_SCARPOS then
			
			-- spawn a boar
			local units = {sbp = SBP.GAIA.GAIA_HUNTABLE_BOAR, numSquads = 1}
			Player_GetAll(player1,sg_allsquads)
			
			if not Player_CanSeePosition(player1,randomPosition) and not Prox_ArePlayersNearMarker(player1, marker, ANY, 40, "gaia", FILTER_REMOVE) then
				UnitEntry_DeploySquads(player1, sg_temp, units, randomPosition)
				
				-- set it to neutral
				SGroup_SetWorldOwned(sg_temp)
				SGroup_AddGroup(sg_animals, sg_temp)
			end
		else
			print("Warning - Could not find a position to spawn an animal")
		end
	end
end

--spawn animals next to town 01
function Mission_AddMoreAnimalsNovgorodTown01()
	if SGroup_CountSpawned(sg_animalsTown01) < t_difficulty.i_maximumNumberOfAnimalsTown01 then 

		SGroup_Clear(sg_temp)
		
		-- pick a hidden position
		local marker = Table_GetRandomItem(t_animalsSpawnMarkersTown01)
		local randomPosition = Util_GetRandomPosition(marker,10)
		
		if scartype(randomPosition) == ST_SCARPOS then
			
			-- spawn a boar
			local units = {sbp = SBP.GAIA.GAIA_HUNTABLE_DEER, numSquads = 1}
			Player_GetAll(player1,sg_allsquads)
			
			if not Player_CanSeePosition(player1,randomPosition) and not Prox_ArePlayersNearMarker(player1, marker, ANY, 40, "gaia", FILTER_REMOVE) then
				UnitEntry_DeploySquads(player1, sg_temp, units, randomPosition)
				
				-- set it to neutral
				SGroup_SetWorldOwned(sg_temp)
				SGroup_AddGroup(sg_animalsTown01, sg_temp)
			end
		else
			print("Warning - Could not find a position to spawn an animal near town01")
		end
	end
end

function SetupAttackWaves()
		
	local assault_data_1 = { -- kuklino to soltsy
		type = "RovingArmy",
		descriptor = "wave_1_assault",
		spawnLocation = mkr_enemy_town_staging,
		player = player4,
		targetingType = ARMY_TARGETING_CYCLE,
		targets = {
			mkr_enemy_town02, mkr_enemy_town,
		},
	}
	
	local assault_data_2 = { --soltsy to kuklino
		type = "RovingArmy",
		descriptor = "wave_2_assault",
		spawnLocation = mkr_enemy_town02_staging,
		player = player4,
		targetingType = ARMY_TARGETING_CYCLE,
		targets = {
			mkr_enemy_town_target_early, mkr_enemy_town_target, mkr_enemy_town02_target,
		},
	}

	local assault_data_3 = { --sorino to soltsy and kulino
		type = "RovingArmy",
		descriptor = "wave_3_assault",
		spawnLocation = mkr_enemy_town03_staging,
		player = player2,
		targetingType = ARMY_TARGETING_CYCLE,
		targets = { mkr_enemy_town02_target_east, mkr_enemy_town02_target, mkr_enemy_town_target },
	}
	
	local assault_data_4 = { --novgorod_front to sorino, soltsy and kulino
		type = "RovingArmy",
