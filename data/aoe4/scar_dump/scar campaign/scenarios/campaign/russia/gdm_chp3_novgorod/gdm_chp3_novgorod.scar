--Called from the Events script on MissionComplete
function Novgorod_OutroSequence()
    local function _Burn (gid, index, iid)
        if Entity_IsAlive(iid) then
            Entity_SetHealth(iid, (World_GetRand(1,3)/10))
            if Entity_IsBurning(iid) ~= true then
                Entity_SetOnFire(iid)
            end 
        end
    end
	
	--Music_UnlockIntensity()
	--Music_StopMedium()
    
    EGroup_ForEach(eg_outro, _Burn)	
	
	--EGroup_Filter(eg_outro, EBP.CAMPAIGN.BUILDING_LANDMARK_AGE1_NOVGOROD_KREMLIN_CONTROL_NOV, FILTER_KEEP)
	
	EGroup_SetInvulnerable(eg_outro, 0.1)
	
	IvanMovesOnTown()
end


function IvanMovesOnTown()

	Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_outro_units_march_stop, 200)
	SGroup_DestroyAllSquads(sg_temp)
	
	Player_GetAll(player2)
	SGroup_DestroyAllSquads(sg_allsquads)
	EGroup_SetPlayerOwner( eg_allentities, player1)
	
	local cheering_units = {
		{type="scar_manatarms", numSquads = 3, spawn = mkr_outro_units_1}, --facing = Marker_GetPosition(mkr_outro_units_2)},
		{type="scar_manatarms", numSquads = 3, spawn = mkr_outro_units_2}, --facing = Marker_GetPosition(mkr_outro_units_1)},
		{type="scar_spearman", numSquads = 3, spawn = mkr_outro_units_3}, --facing = Marker_GetPosition(mkr_outro_units_4)},
		{type="scar_spearman", numSquads = 3, spawn = mkr_outro_units_4}, --facing = Marker_GetPosition(mkr_outro_units_3)},
		{type="scar_crossbowman", numSquads = 3, spawn = mkr_outro_units_5}, --facing = Marker_GetPosition(mkr_outro_units_6)},
		{type="scar_crossbowman", numSquads = 3, spawn = mkr_outro_units_6}, --facing = Marker_GetPosition(mkr_outro_units_5)},
		{type="scar_archer", numSquads = 3, spawn = mkr_outro_units_7}, --facing = Marker_GetPosition(mkr_outro_units_8)},
		{type="scar_archer", numSquads = 3, spawn = mkr_outro_units_8}, --facing = Marker_GetPosition(mkr_outro_units_7)},
		{type="scar_manatarms", numSquads = 3, spawn = mkr_outro_units_9}, --facing = Marker_GetPosition(mkr_outro_units_10)},
		{type="scar_manatarms", numSquads = 3, spawn = mkr_outro_units_10}, --facing = Marker_GetPosition(mkr_outro_units_9)},
		{sbp = SBP.RUS.UNIT_MONK_3_RUS, numSquads = 2, spawn = mkr_outro_units_11}, ---facing = Marker_GetPosition(mkr_outro_ivan_stop)},
	}
	
	SGroup_Clear(sg_cheer)
	
	UnitEntry_DeploySquads (player1, sg_cheer, cheering_units)
	
	local ivan_escort = {
		{sbp = SBP.RUS.UNIT_IVAN_THE_GREAT_CMP_RUS, numSquads = 1, sgroup = sg_ivan_outro},
	}
	
	UnitEntry_DeploySquads(player1, sg_march_outro, ivan_escort, mkr_outro_ivan_spawn)
	UnitEntry_DeploySquads (player1, sg_ivan_escort, {sbp = SBP.RUS.UNIT_MONK_3_RUS, numSquads = 2, sgroup = sg_ivan_escort}, mkr_outro_ivan_escort)
	
	local outro_guards = {
		{type="scar_spearman", numSquads = 1, spawn = mkr_outro_guard01}, 
		{type="scar_spearman", numSquads = 1, spawn = mkr_outro_guard02},
	}
	
	UnitEntry_DeploySquads (player1, sg_outro_guards, outro_guards)
	
	Rule_AddOneShot(Ivan_SendOutroCav, 2.5 )

end

function Ivan_SendOutroCav(context, data)
	
	Modify_UnitSpeed(sg_ivan_outro, 0.45)
	
	Cmd_FormationMove(sg_ivan_outro, mkr_outro_ivan_stop)
	
	Modify_UnitSpeed(sg_ivan_escort, 0.3)
	
	Cmd_FormationMove(sg_ivan_escort, mkr_outro_escort_dest)

end