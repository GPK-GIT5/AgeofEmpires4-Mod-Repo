function SurrenderUI_CreateGizmo()
	
	local xaml = 
	[[<StackPanel
		xmlns = "http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		Orientation="Vertical"
		HorizontalAlignment="Center"
		VerticalAlignment="Center">
		<TextBlock Text="Smolensk is attempting to surrender"
			Margin="{wm:DIP '0,0,0,10'}"
			VerticalAlignment="Top"
			TextAlignment="Center"
			Style="{StaticResource HUDPrimaryColorLightTitleTextBlock27ptStyle}">		
		</TextBlock>
		<StackPanel Orientation="Horizontal">
			<Button 
				x:Name="AcceptSurrender"
				Margin="{wm:DIP '0,0,5,0'}"
				SnapsToDevicePixels="True"
		        Style="{DynamicResource HUDPrimaryRaisedTextButton}"
				Content="Accept Surrender" />
			<Button 
				x:Name="RefuseSurrender"
				Margin="{wm:DIP '5,0,0,0'}"
				SnapsToDevicePixels="True"
		        Style="{DynamicResource HUDPrimaryRaisedTextButton}"
				Content="Reject Surrender" />
		</StackPanel>
	</StackPanel>]]
	
	UI_AddChild("", "XamlPresenter", "SurrenderUI", { IsHitTestVisible = true, Xaml = xaml })
	UI_AddEventHandler("SurrenderUI.AcceptSurrender", "Click", "SurrenderUI_AcceptSurrender")
	UI_AddEventHandler("SurrenderUI.RefuseSurrender", "Click", "SurrenderUI_RefuseSurrender")
	
end

function SurrenderUI_AcceptSurrender()
	UI_Remove("SurrenderUI")
	Objective_Start(OBJ_EnterSmolensk)
end

function SurrenderUI_RefuseSurrender()
	UI_Remove("SurrenderUI")
	Objective_Start(OBJ_CaptureSmolensk)
end