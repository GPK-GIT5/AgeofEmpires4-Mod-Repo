end

function Ugra_SplitModule(module, moduleList)
	
	local module_inf1 = moduleList[1]
	local module_inf2 = moduleList[2]
	local module_rng =  moduleList[3]
	local module_cav =  moduleList[4]
	
	local sgroup = module.sgroup	
	SGroup_Clear(sg_inf)
	SGroup_Clear(sg_rng)
	SGroup_Clear(sg_cav)
	
	local i = 1
	local _GetSmallestModule = function(moduleList)
		local smallestModule = nil
		for i, v in ipairs(moduleList) do
			if smallestModule == nil then
				smallestModule = v
			elseif SGroup_CountSpawned(v.sgroup) < SGroup_CountSpawned(smallestModule.sgroup) then
				smallestModule = v
			end
		end
		return smallestModule
	end
			
	if SGroup_Count(sgroup) > 0 then
		for i,v in ipairs(moduleList) do
			local sgroup = Defend_GetSGroup(v)
			local target = v.target.position
			Cmd_FormationMove(sgroup, target, false, nil, Marker_GetPosition(mkr_rusfort))
		end
		
		SGroup_Filter(sgroup, { "scar_horseman", "scar_knight", "scar_horsearcher" }, FILTER_REMOVE, sg_cav)
		SGroup_Filter(sgroup, { "scar_archer", "scar_crossbowman" }, FILTER_REMOVE, sg_rng)
		SGroup_Filter(sgroup, { "scar_spearman", "scar_manatarms" }, FILTER_REMOVE, sg_inf)
		
		Defend_AddSGroup(module_cav, sg_cav)
		Defend_AddSGroup(module_rng, sg_rng)
		Defend_AddSGroup(_GetSmallestModule({ module_inf1, module_inf2 }), sg_inf)
	end	
	
end

function Ugra_PlayerHasWalls()
	
	eg_temp = Player_GetEntities(player1)
	EGroup_Filter(eg_temp, "stone_wall", FILTER_KEEP)
	return EGroup_Count(eg_temp) > 0
end

function Ugra_ProbeFord()
	local fordModuleList = {
		{ "ScoutAttack1", mkr_monford1_spawn },
		{ "ScoutAttack2", mkr_monford2_spawn }
	}
	local unitList = {
		{ -- Phase 1
			{
				{ type = "scar_horseman", 		numSquads = Util_DifVar({ 4, 4, 6, 6 }) },
				{ type = "scar_horsearcher", 	numSquads = Util_DifVar({ 2, 2, 2, 4 }) },
				{ type = "scar_knight", 		numSquads = Util_DifVar({ 0, 0, 0, 2 }) },
			},
			{
				{ type = "scar_horseman", 		numSquads = Util_DifVar({ 4, 4, 6, 6 }) },
				{ type = "scar_horsearcher", 	numSquads = Util_DifVar({ 2, 2, 2, 4 }) },
				{ type = "scar_knight", 		numSquads = Util_DifVar({ 0, 0, 0, 2 }) },
			},
		},
		{ -- Phase 2
			{
				{ type = "scar_horseman", 		numSquads = Util_DifVar({ 4, 5, 9, 9 }) },
				{ type = "scar_horsearcher", 	numSquads = Util_DifVar({ 2, 3, 3, 7 }) },
				{ type = "scar_knight", 		numSquads = Util_DifVar({ 0, 0, 0, 2 }) },
			},
			{
				{ type = "scar_spearman", 		numSquads = Util_DifVar({ 4, 5, 9, 9 }) },
				{ type = "scar_archer", 		numSquads = Util_DifVar({ 2, 3, 3, 7 }) },
				{ type = "scar_manatarms", 		numSquads = Util_DifVar({ 0, 0, 0, 2 }) },
			},
		},
		{ -- Phase 3
			{
				{ type = "scar_horseman", 		numSquads = Util_DifVar({ 4, 4, 8, 8 }) },
				{ type = "scar_horsearcher", 	numSquads = Util_DifVar({ 2, 2, 2, 6 }) },
				{ type = "scar_knight", 		numSquads = Util_DifVar({ 0, 0, 2, 4 }) },
			},
			{
				{ type = "scar_spearman", 		numSquads = Util_DifVar({ 4, 4, 8, 8 }) },
				{ type = "scar_archer", 		numSquads = Util_DifVar({ 2, 2, 2, 6 }) },
				{ type = "scar_manatarms", 		numSquads = Util_DifVar({ 0, 0, 2, 4 }) },
			},
		},
		{ -- Phase 4
			{
				{ type = "scar_horseman", 		numSquads = Util_DifVar({ 4, 4, 10, 10 }) },
				{ type = "scar_horsearcher", 	numSquads = Util_DifVar({ 2, 2, 2, 6 }) },
				{ type = "scar_knight", 		numSquads = Util_DifVar({ 0, 0, 2, 6 }) },
			},
			{
				{ type = "scar_spearman", 		numSquads = Util_DifVar({ 4, 4, 10, 10 }) },
				{ type = "scar_archer", 		numSquads = Util_DifVar({ 2, 2, 2, 6 }) },
				{ type = "scar_manatarms", 		numSquads = Util_DifVar({ 0, 0, 2, 6 }) },
			},
		}
	}
	if currentFord == nil or currentFord == 2 then
		currentFord = 1
	else
		currentFord = 2
	end
	SpawnUnitsToModule(
		unitList[ugraPhase][World_GetRand(1, 2)],
		fordModuleList[currentFord][1], 
		fordModuleList[currentFord][2])
	if Ugra_PlayerHasWalls() then
			SpawnUnitsToModule(
		{
			{ type = "scar_ram", numSquads = 1 },
		},
		fordModuleList[currentFord][1], 
		fordModuleList[currentFord][2])
	end
	Rule_AddOneShot(Ugra_MongolDrumDelay, 10)
	if firstProbe then
		firstProbe = false
		Util_StartIntel(EVENTS.Skirmish_Ford)
	end
end

function Ugra_MongolDrumDelay()
	Music_PlayStinger("mus_camp_cust_mongol_drum_short_cavalry")
end


function Ugra_ReinforcementTrain()
	
	SpawnUnitsToModule(
			{
				{ type = "scar_horseman", 		numSquads = Util_DifVar({ 6,  6,  6,  8  }) },
				{ type = "scar_horsearcher",	numSquads = Util_DifVar({ 4,  6,  8,  10 }) },
				{ type = "scar_manatarms",		numSquads = Util_DifVar({ 0,  2,  4,  4  }) },
				{ type = "scar_archer",			numSquads = Util_DifVar({ 4,  6,  8, 10 }) },
				{ type = "scar_mangonel",		numSquads = Util_DifVar({ 0,  1,  2,  2  }) },
				{ type = "scar_ram",		    numSquads = Util_DifVar({ 1,  1,  1,  2  }) },
			},
			"SouthernReinforcements", 
			mkr_reinforcementspawn_units)
	local sgroup = MissionOMatic_FindModule("SouthernReinforcements").sgroup
	
	SpawnUnitsToModule(
			{
				{ sbp = BP_GetSquadBlueprint("building_unit_cavalry_moving_mon"), numSquads = 1, },
				{ sbp = BP_GetSquadBlueprint("building_unit_ranged_moving_mon"), numSquads = 1, },
				{ sbp = BP_GetSquadBlueprint("building_unit_infantry_moving_mon"), numSquads = 1, },
			},
			"SouthernReinforcementsBuildings", 
			mkr_reinforcementspawn_buildings)
	local buildings = MissionOMatic_FindModule("SouthernReinforcementsBuildings").sgroup
	
	southernReinforcementsSpeed = Modify_UnitSpeed(sgroup, 0.5)
	southernReinforcementsBuildingsSpeed = Modify_UnitSpeed(buildings, 0.25)
	FOW_RevealSGroup(sgroup, 20, 120)
	FOW_RevealSGroup(buildings, 20, 120)
	Rule_AddGlobalEvent(Ugra_OnSquadKilled, GE_SquadKilled)

	EventCues_CallToAction(11186859, CTA_ALARM, EVENTS.ReinforcementWave, nil, Marker_GetPosition(mkr_retreat_se), 20)
	Sound_Play2D("sfx_campaign_scripted_medium_group_engage")
	Sound_Play2D("mus_stinger_campaign_alert")

	Rule_AddInterval(Ugra_SouthernReinforcementsCheck, 1)

	Objective_Start(OBJ_SouthernReinforcements)
		
end

function Ugra_SouthernReinforcementsCheck()
	local sgroup = MissionOMatic_FindModule("SouthernReinforcements").sgroup
	local buildings = MissionOMatic_FindModule("SouthernReinforcementsBuildings").sgroup
	
	if SGroup_IsEmpty(sgroup) and SGroup_IsEmpty(buildings) then
		Objective_Complete(OBJ_SouthernReinforcements)
	end
end


function Ugra_ReleaseReinforcements()
	local module = MissionOMatic_FindModule("SouthernReinforcements")
	local buildingsModule = MissionOMatic_FindModule("SouthernReinforcementsBuildings")
	
	sg_southinfantry = SGroup_CreateIfNotFound("sg_southinfantry")
	sg_southcavalry = SGroup_CreateIfNotFound("sg_southcavalry")
	sg_southranged = SGroup_CreateIfNotFound("sg_southranged")
	
	Rule_Remove(Ugra_SouthernReinforcementsCheck)
	
	if not SGroup_IsEmpty(module.sgroup) or not SGroup_IsEmpty(buildingsModule.sgroup) and Objective_IsComplete(OBJ_SouthernReinforcements) == false then
		Modifier_Remove(southernReinforcementsSpeed)
		--Modifier_Remove(southernReinforcementsBuildingsSpeed)
		SGroup_Filter(buildingsModule.sgroup, SBP.MONGOL.BUILDING_UNIT_CAVALRY_MOVING_MON, FILTER_REMOVE, sg_southcavalry)
		SGroup_Filter(buildingsModule.sgroup, SBP.MONGOL.BUILDING_UNIT_RANGED_MOVING_MON, FILTER_REMOVE, sg_southranged)
		SGroup_Filter(buildingsModule.sgroup, SBP.MONGOL.BUILDING_UNIT_INFANTRY_MOVING_MON, FILTER_REMOVE, sg_southinfantry)
		Action_DissolveModule_Do("SouthernReinforcements")
		Defend_AddSGroup(MissionOMatic_FindModule("DefendMonFord2"), module.sgroup, true)
		print("Releasing Reinforcements to Fords")
		Objective_Fail(OBJ_SouthernReinforcements)
		Rule_AddInterval(Ugra_UnpackSouthernReinforcements, 10)
	end
end

function Ugra_UnpackSouthernReinforcements()
	packedBuildingsCount = SGroup_Count(sg_southinfantry) + SGroup_Count(sg_southcavalry) + SGroup_Count(sg_southranged)
	if packedBuildingsCount ~= 0 then
		Cmd_Ability(sg_southcavalry, BP_GetAbilityBlueprint("unpack_building_unit_cavalry_mon"), Marker_GetPosition(mkr_southbuildinglocation1))
		Cmd_Ability(sg_southranged, BP_GetAbilityBlueprint("unpack_building_unit_ranged_mon"), Marker_GetPosition(mkr_southbuildinglocation2))
		Cmd_Ability(sg_southinfantry, BP_GetAbilityBlueprint("unpack_building_unit_infantry_mon"), Marker_GetPosition(mkr_southbuildinglocation3))
	else
		Rule_RemoveMe()
	end
end


function Ugra_WarnPlayerIfTheyCrossTheFords()
	
	if Objective_IsComplete(OBJ_MaintainSuperiority) then 
		Rule_RemoveMe()
	elseif Event_IsAnyRunning() == false then 
		
		if Prox_ArePlayersNearMarker(player1, mkr_ford1_farside_trigger1, ANY) or Prox_ArePlayersNearMarker(player1, mkr_ford1_farside_trigger2, ANY) or
			Prox_ArePlayersNearMarker(player1, mkr_ford2_farside_trigger1, ANY) or Prox_ArePlayersNearMarker(player1, mkr_ford2_farside_trigger2, ANY) or 
			Prox_ArePlayersNearMarker(player1, mkr_ford3_farside_trigger1, ANY) then 
			
			Util_StartIntel(EVENTS.Warning)
			Rule_RemoveMe()
			
		end
		
	end
	
end
