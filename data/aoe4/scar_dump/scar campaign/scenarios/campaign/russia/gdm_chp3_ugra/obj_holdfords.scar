function HoldFords_InitObjectives()
	
	OBJ_MaintainSuperiority = {
		
		Title = "$11183129", -- Maintain Superiority over the Fords
		Type = ObjectiveType_Information,
		
		SetupUI = function()
			--Ugra_UpdateForceCount()
			Objective_StartTimer(OBJ_MaintainSuperiority, COUNT_DOWN, holdFordTimer, 10)
		end,
		
		PreStart = function()
			if not Objective_IsComplete(OBJ_MoveUnitsToFords) then
				Objective_Complete(OBJ_MoveUnitsToFords, false)
			end
		end,
		
		OnStart = function()
			
			Rule_AddOneShot(Ugra_Phase2, monReinforcePhase2Delay)
			Rule_AddOneShot(Ugra_Phase3, monReinforcePhase3Delay)
			Rule_AddOneShot(Ugra_Phase4, monReinforcePhase4Delay)
			Rule_AddOneShot(Ugra_ReinforcementTrain, monReinforceWaveDelay)
			Rule_AddOneShot(Ugra_TimerComplete, holdFordTimer)
			Rule_AddOneShot(Ugra_ReinforceDelay, attackCooldown)
			
			evaluateFord = false
			Rule_AddOneShot(Ugra_FordStartGraceDelay, fordStartGraceDelay)
			
			Sound_SetMinimumMusicCombatIntensity(801, 0)
		end,
		OnComplete = function()
			
			Objective_Complete(SOBJ_MoveToNorthFord, false, false)
			Objective_Complete(SOBJ_MoveToSouthFord, false, false)
			
			Objective_Complete(SOBJ_NorthFordRus, false, false)
			Objective_Complete(SOBJ_SouthFordRus, false, false)
			Sound_Play2D("sfx_campaign_scripted_medium_group_celebrate")
			
			Rule_Remove(Ugra_UpdateForceCount)
			Rule_Remove(Ugra_WarnPlayerIfTheyCrossTheFords)
			Rule_Remove(Ugra_ReinforceFords)
			Rule_Remove(Ugra_ProbeFord)
			Rule_Remove(Ugra_SouthernReinforcementsCheck)
			Rule_Remove(Ugra_UnpackSouthernReinforcements)
			
			--Rule_Remove(Ugra_CheckFordsScouted)
			
			Ugra_SplitAndFallback()
			Util_StartIntel(EVENTS["AttackMongols"])
			Objective_Start(OBJ_AttackMongols)
			Game_TransitionToState("taiga_normal", 90)
		end,
	}
	
	SOBJ_NorthFordRus = {
		
		Title = 11183131, -- North Ford
		Type = ObjectiveType_TugOfWar,
		Parent = OBJ_MaintainSuperiority,
		StartAlongsideParent = true,

		SetupUI = function()
			Obj_SetProgressVisible(SOBJ_NorthFordRus.ID, true)
			--Objective_AddGroundReticule(SOBJ_NorthFordRus, mkr_rusford1, Marker_GetProximityRadius(mkr_rusford1), BP_GetReticuleBlueprint("campaign_capturelocation_self"))
			Objective_AddUIElements(SOBJ_NorthFordRus, mkr_rusford1, true, nil, false, nil, nil, nil, "icons/objectives/objective_battle")
		end,
	}
	
	SOBJ_SouthFordRus = {
		
		Title = 11183132, -- South Ford
		Type = ObjectiveType_TugOfWar,
		Parent = OBJ_MaintainSuperiority,
		StartAlongsideParent = true,
		
		SetupUI = function()
			Obj_SetProgressVisible(SOBJ_SouthFordRus.ID, true)
			--Objective_AddGroundReticule(SOBJ_SouthFordRus, mkr_rusford2, Marker_GetProximityRadius(mkr_rusford2), BP_GetReticuleBlueprint("campaign_capturelocation_self"))
			Objective_AddUIElements(SOBJ_SouthFordRus, mkr_rusford2, true, nil, false, nil, nil, nil, "icons/objectives/objective_battle")
		end,
	}
	
	OBJ_SouthernReinforcements = {
		
		Title = "$11186858", -- Optional: Intercept the southern reinforcements
		Type = ObjectiveType_Optional,
		
		targetKillCount = 0,
		currentKillCount = 0,
		
		PreStart = function()
			Util_AutoSave()
		end,
		OnStart = function()
			Sound_Play2D("mus_stinger_campaign_alert")
			print("Spawning Southern Reinforcements")
			Objective_AddUIElements(OBJ_SouthernReinforcements, sg_mon_southreinforce, true, nil, true, nil, nil, nil)
		
		end,
		
		OnComplete = function()
			Util_StartIntel(EVENTS.Reinforcements_Success)
		end,
		
		OnFail = function()
			Util_StartIntel(EVENTS.Reinforcements_Fail)
		end,
	}
	
	SOBJ_DestroyUnits = {
		
		Title = "$11202639", -- Destroy reinforcements before they reach Southern Ford
		Type = ObjectiveType_Optional,
		Parent = OBJ_SouthernReinforcements,
		StartAlongsideParent = true,
		
		targetKillCount = 0,
		currentKillCount = 0,
		
		OnStart = function()	
			local sgroup = MissionOMatic_FindModule("SouthernReinforcements").sgroup
			local buildings = MissionOMatic_FindModule("SouthernReinforcementsBuildings").sgroup
			
			SOBJ_DestroyUnits.targetKillCount = SGroup_Count(sgroup) + SGroup_Count(buildings)
			Obj_SetProgressVisible(SOBJ_DestroyUnits.ID, true)
			Obj_SetProgress(SOBJ_DestroyUnits.ID, 0)
		
		end,
	}
	
	Objective_Register(OBJ_HoldFords)
	Objective_Register(OBJ_MaintainSuperiority)
	Objective_Register(SOBJ_NorthFordRus)
	Objective_Register(SOBJ_SouthFordRus)
	Objective_Register(OBJ_SouthernReinforcements)
	Objective_Register(SOBJ_DestroyUnits)

	timeStamp_lastFordSuperiorityWarning = 0
	Rule_AddInterval(Ugra_WarnPlayerIfTheyCrossTheFords, 2.5)
	
end

function Ugra_OnSquadKilled(context)
	local victim = context.victim
	local victimPosition = Squad_GetPosition(victim)
	
	-- Supply Cart Death Logic
	if Marker_InProximity(mkr_south, victimPosition) and World_OwnsSquad(victim) == false then
		if Squad_GetPlayerOwner(victim) == player2 then
			SOBJ_DestroyUnits.currentKillCount = SOBJ_DestroyUnits.currentKillCount + 1
			Obj_SetProgress(SOBJ_DestroyUnits.ID, SOBJ_DestroyUnits.currentKillCount / SOBJ_DestroyUnits.targetKillCount)
			if SOBJ_DestroyUnits.currentKillCount == SOBJ_DestroyUnits.targetKillCount then
				Rule_RemoveMe()
			end
		end
	end
end

function Ugra_SplitAndFallback()
	
	local northModules = {
		MissionOMatic_FindModule("ScoutAttack1"),
		MissionOMatic_FindModule("AttackNorth"),
		MissionOMatic_FindModule("DefendMonFord1_1"),
		MissionOMatic_FindModule("DefendMonFord1_2"),
		MissionOMatic_FindModule("DefendMonFord1_3"),
		MissionOMatic_FindModule("DefendMonFord1_4")
	}
	local southModules = {
		MissionOMatic_FindModule("ScoutAttack2"),
		MissionOMatic_FindModule("AttackSouth"),
		MissionOMatic_FindModule("DefendMonFord2_1"),
		MissionOMatic_FindModule("DefendMonFord2_2"),
		MissionOMatic_FindModule("DefendMonFord2_3"),
		MissionOMatic_FindModule("DefendMonFord2_4")
	}
	
	sg_mon_retreatcav = SGroup_CreateIfNotFound("sg_mon_retreatcav")
	sg_mon_retreatinf = SGroup_CreateIfNotFound("sg_mon_retreatinf")
	
	local _SplitModule = function(module, north)
		if north then
			moduleCav = MissionOMatic_FindModule("DefendNorthCav")
			moduleInf = MissionOMatic_FindModule("DefendMonFortInfantryNorth")
		else
			moduleCav = MissionOMatic_FindModule("DefendSouthCav")
			moduleInf = MissionOMatic_FindModule("DefendMonFortInfantrySouth")
		end
		
		SGroup_Clear(sg_mon_retreatcav)
		SGroup_Filter(module.sgroup, "cavalry", FILTER_REMOVE, sg_mon_retreatcav)
		Defend_RemoveSGroup(module, sg_mon_retreatcav)
		Defend_AddSGroup(moduleCav, sg_mon_retreatcav)
		
		SGroup_Clear(sg_mon_retreatinf)
		SGroup_Filter(module.sgroup, "melee", FILTER_REMOVE, sg_mon_retreatinf)
		Defend_RemoveSGroup(module, sg_mon_retreatinf)
		Defend_AddSGroup(moduleInf, sg_mon_retreatinf)
		
		DissolveModuleIntoModule(module, "DefendMonFortRangedNorth")
		
	end
	
	for k,v in ipairs(northModules) do
		_SplitModule(v, true)
	end
	
	for k,v in ipairs(southModules) do
		_SplitModule(v, false)
	end 
	
	if SGroup_IsAlive(sg_mon_backup1) then
		Cmd_MoveToAndDestroy(sg_mon_backup1, mkr_retreat_nw)
	end
	
	if SGroup_IsAlive(sg_mon_backup2) then
		Cmd_MoveToAndDestroy(sg_mon_backup2, mkr_retreat_s)
	end
	
	if SGroup_IsAlive(sg_mon_monford3) then
		Cmd_MoveToAndDestroy(sg_mon_monford3, mkr_retreat_s)
	end
	
	--Modules that retreat on engage
	retreaterModuleList = {
		moduleDefendNorthCav, 
		moduleDefendSouthCav, 
		moduleDefendMonFortInfantryNorth, 
		moduleDefendMonFortInfantrySouth,
		moduleDefendMonFortRanged
	}
end

function Ugra_TimerComplete()
	Objective_Complete(OBJ_MaintainSuperiority)
	Sound_Play2D("sfx_campaign_scripted_medium_group_celebrate")
end

-- Update north and south ford unit counts 
function Ugra_UpdateForceCount()
	
	-- Send reinforcements to formations
	Ugra_SplitModule(MissionOMatic_FindModule("DefendMonFord1"), { 
			MissionOMatic_FindModule("DefendMonFord1_1"),
			MissionOMatic_FindModule("DefendMonFord1_2"),
			MissionOMatic_FindModule("DefendMonFord1_3"),
			MissionOMatic_FindModule("DefendMonFord1_4") })
	Ugra_SplitModule(MissionOMatic_FindModule("DefendMonFord2"), { 
			MissionOMatic_FindModule("DefendMonFord2_1"),
			MissionOMatic_FindModule("DefendMonFord2_2"),
			MissionOMatic_FindModule("DefendMonFord2_3"),
			MissionOMatic_FindModule("DefendMonFord2_4") })
	
	-- Count all units at fords
	Player_GetAllSquadsNearMarker(player2, sg_temp, mkr_northford)
	SGroup_AddGroup(sg_temp, sg_mon_attacknorth)
	local northFordMonValue = Ugra_EvaluateForceValue(sg_temp)
	Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_rusford1)
	local northFordRusValue = Ugra_EvaluateForceValue(sg_temp)
	Player_GetAllSquadsNearMarker(player2, sg_temp, mkr_southford)
	SGroup_AddGroup(sg_temp, sg_mon_attacksouth)
	local southFordMonValue = Ugra_EvaluateForceValue(sg_temp)
	Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_rusford2)
	local southFordRusValue = Ugra_EvaluateForceValue(sg_temp)
	
	-- Handle NaN/Inf div by zero, if no Rus army, set to zero. If no Mon army set to 1.
	if northFordRusValue <= 0 then
		forceRatioNorth = 0
	elseif northFordMonValue <= 0 then
		forceRatioNorth = 1
	else
		forceRatioNorth = northFordRusValue / (northFordMonValue + northFordRusValue)
	end	
	
	if southFordRusValue <= 0 then
		forceRatioSouth = 0
	elseif southFordMonValue <= 0 then
		forceRatioSouth = 1
	else
		forceRatioSouth = southFordRusValue / (southFordMonValue + southFordRusValue)	
	end
	
	for i,v in ipairs({ northFordRusValue, northFordMonValue, southFordRusValue, southFordMonValue }) do
		if v > bestForceValue then
			bestForceValue = v*1.1
		end
	end
	
	-- Update UI
	if Objective_IsStarted(OBJ_MaintainSuperiority) then
		
		Obj_SetProgress(SOBJ_NorthFordRus.ID, forceRatioNorth)
		Obj_SetProgress(SOBJ_SouthFordRus.ID, forceRatioSouth)
		
		if (forceRatioNorth < warningThreshold or forceRatioSouth < warningThreshold) and (World_GetGameTime() - timeStamp_lastFordSuperiorityWarning) >= 30 then 
			--Sound_Play2D("sfx_ui_ugra_ford_warning")
			timeStamp_lastFordSuperiorityWarning = World_GetGameTime()
		end
		
	else
		
		if Objective_IsStarted(OBJ_MoveUnitsToFords) then
			
			Obj_SetProgress(SOBJ_MoveToNorthFord.ID, forceRatioNorth)
			Obj_SetProgress(SOBJ_MoveToSouthFord.ID, forceRatioSouth)
			
			if not Objective_IsComplete(OBJ_MoveUnitsToFords) then
				if forceRatioNorth >= attackThreshold and forceRatioSouth >= attackThreshold then
					Objective_Complete(OBJ_MoveUnitsToFords)
				end
			end
		else
			if forceRatioNorth > 0 or forceRatioSouth > 0 then
				Objective_Start(OBJ_MoveUnitsToFords)
			end
		end
		
	end
	
	--Evaluate Force ratio vs attackThreshold
	if forceRatioNorth < attackThreshold and evaluateFord then
		Rule_AddOneShot(Ugra_NorthFordDelayedLaunch, forceGraceDelay)
	end
	
	if forceRatioSouth < attackThreshold and evaluateFord then
		Rule_AddOneShot(Ugra_SouthFordDelayedLaunch, forceGraceDelay)
	end
end

function Ugra_NorthFordDelayedLaunch()
	if forceRatioNorth < attackThreshold then
		TransferModuleIntoModule("DefendMonFord1", "AttackNorth")
		TransferModuleIntoModule("DefendMonFord1_1", "AttackNorth")
		TransferModuleIntoModule("DefendMonFord1_2", "AttackNorth")
		TransferModuleIntoModule("DefendMonFord1_3", "AttackNorth")
		TransferModuleIntoModule("DefendMonFord1_4", "AttackNorth")
		if firstNorthAttack then
			firstNorthAttack = false
			EventCues_CallToAction(11180279, CTA_ALARM, nil, nil, Marker_GetPosition(mkr_monford1), 20) -- The Mongols attack at the north ford!
			Sound_Play2D("mus_stinger_campaign_alert")
		end	
		if attackNorthCooldown then
			Rule_AddOneShot(Ugra_NorthAttackCooldown, attackCooldown)
			attackNorthCooldown = false
		end
		if not fordAttacked then
			fordAttacked = true
			Util_StartIntel(EVENTS["FordAttacks"])
		end
	end
end

function Ugra_SouthFordDelayedLaunch()
	if forceRatioSouth < attackThreshold then
		TransferModuleIntoModule("DefendMonFord2", "AttackSouth")
		TransferModuleIntoModule("DefendMonFord2_1", "AttackSouth")
		TransferModuleIntoModule("DefendMonFord2_2", "AttackSouth")
		TransferModuleIntoModule("DefendMonFord2_3", "AttackSouth")
		TransferModuleIntoModule("DefendMonFord2_4", "AttackSouth")
		if firstSouthAttack then
			firstSouthAttack = false
			EventCues_CallToAction(11180280, CTA_ALARM, nil, nil, Marker_GetPosition(mkr_monford2), 20) -- The Mongols attack at the south ford!
			Sound_Play2D("mus_stinger_campaign_alert")
			Sound_Play2D("sfx_campaign_scripted_medium_group_engage")
		end		
		if attackSouthCooldown then
			Rule_AddOneShot(Ugra_SouthAttackCooldown, attackCooldown)
			attackSouthCooldown = false
		end
		if not fordAttacked then
			fordAttacked = true
			Util_StartIntel(EVENTS["FordAttacks"])
		end
	end
end

function Ugra_EvaluateForceValue(sgroup)
	SGroup_RemoveGroup(sgroup, sg_mon_scoutwave1)
	SGroup_RemoveGroup(sgroup, sg_mon_scoutwave2)
	SGroup_RemoveGroup(sgroup, sg_mon_backup1)
	SGroup_RemoveGroup(sgroup, sg_mon_backup2)
	local forceValue = 0
	
	local sg_units = SGroup_CreateIfNotFound("sg_units")
	
	for unit, data in pairs(unitTypeList) do
		SGroup_Clear(sg_units)
		SGroup_Filter(sgroup, data.scar, FILTER_REMOVE, sg_units)
		forceValue = forceValue + SGroup_Count(sg_units)*data.value
	end
	return forceValue
end

