		mkr_mon_river2,
		mkr_mon_river3,
		mkr_mon_river4,
		mkr_mon_river4,
	}
	markerListMonMid = {  
		mkr_mon_mid1,
		mkr_mon_mid2,
		mkr_mon_mid2,
	}

	local intro_west_units = {
		{ type = "scar_spearman", numSquads = Util_DifVar({4, 6, 6, 6}) }, 
		{ type = "scar_manatarms", numSquads = 4 }, 
		{ type = "scar_archer", numSquads = Util_DifVar({8, 10, 10, 10}) }, 
		{ type = "scar_crossbowman", numSquads = Util_DifVar({2, 4, 4, 4}) }
	}
	
	UnitEntry_DeploySquads(player2, sg_mon_intro_south, {{ type = "scar_horseman", numSquads = 8 }, { type = "scar_horsearcher", numSquads = 4 }}, mkr_mon_south1 )
	UnitEntry_DeploySquads(player2, sg_mon_intro_north, { type = "scar_scout", numSquads = 2 }, mkr_mon_north1 )
	UnitEntry_DeploySquads(player2, sg_mon_intro_west, intro_west_units, mkr_mon_west1 )
	UnitEntry_DeploySquads(player2, sg_mon_intro_ford, { type = "scar_knight", numSquads = 8 }, mkr_mon_river_spawn )
	UnitEntry_DeploySquads(player2, sg_mon_intro_villagers, { type = "scar_villager", numSquads = 2 }, mkr_mon_mid1 )
	
	Ugra_SendIntroUnits(sg_mon_intro_south, 0, markerListMonSouth ) --cavalry
	Ugra_SendIntroUnits(sg_mon_intro_north, 4, markerListMonNorth ) --scouts
	Ugra_SendIntroUnits(sg_mon_intro_west, 0, markerListMonWest ) --infantry
	Ugra_SendIntroUnits(sg_mon_intro_ford, 0, markerListMonFord ) -- knights
	Ugra_SendIntroUnits(sg_mon_intro_villagers, 0, markerListMonMid ) -- villagers
	
	intro_river_pat_speed = Modify_UnitSpeed(sg_mon_intro_ford, 0.5)
	
	Rule_AddOneShot(Ugra_AssignStartingMonUnits, 20)
	
end

function Ugra_InitPlayerUnits()
	markerListIvan = {  
		mkr_rusintro_ivan_dest,
		}
	markerListNorth = {  
		mkr_rusintropath4,
		mkr_rusintropath5,
		mkr_rusintropath_north,
		}
	markerListSouth = {  
		mkr_rusintropath4,
		mkr_rusintropath5,
		mkr_rusintropath_south1,
		mkr_rusintropath_south2,
	}
	markerListScout = {  
