		--mkr_rusintro_scout2,
		mkr_rusintro_scout3,
		mkr_rusintro_scout4,
		mkr_rusintro_scout5,
	}

	-- Rus Scout	
	UnitEntry_DeploySquads(player1, sg_rus_intro_scout, { type = "scar_scout",    numSquads = 1 }, mkr_rusintro_scout1 )
	Ugra_SendIntroUnits(sg_rus_intro_scout, 16, markerListScout)

	
	--Rus Starting Units
	UnitEntry_DeploySquads(player1, sg_rus_intro1, { type = "scar_spearman",  numSquads = 6 }, mkr_rusintrospawn1 )
	UnitEntry_DeploySquads(player1, sg_rus_intro2, { type = "scar_spearman",  numSquads = 6 }, mkr_rusintrospawn2 )
	UnitEntry_DeploySquads(player1, sg_rus_intro1, { type = "scar_manatarms", numSquads = 6 }, mkr_rusintrospawn3 )
	UnitEntry_DeploySquads(player1, sg_rus_intro4, { type = "scar_manatarms", numSquads = 6 }, mkr_rusintrospawn4 )
	UnitEntry_DeploySquads(player1, sg_rus_intro1, { type = "scar_archer",    numSquads = 6 }, mkr_rusintrospawn5 )
	UnitEntry_DeploySquads(player1, sg_rus_intro6, { type = "scar_archer",    numSquads = 6 }, mkr_rusintrospawn6 )
	UnitEntry_DeploySquads(player1, sg_rus_intro1, { type = "scar_handcannon",    numSquads = 6 }, mkr_rusintrospawn7 )
	UnitEntry_DeploySquads(player1, sg_rus_intro8, { type = "scar_handcannon",    numSquads = 6 }, mkr_rusintrospawn8 )
	
	SGroup_AddGroups(sg_rus_intro_cheer, {sg_rus_intro2, sg_rus_intro4, sg_rus_intro6,sg_rus_intro8})
	
	UnitEntry_DeploySquads(player1, g_leaderIvan.sgroup, { sbp = BP_GetSquadBlueprint("unit_ivan_the_great_cmp_rus"), numSquads = 1 }, mkr_rusintro_ivan )
	
	Ugra_SendIntroUnits(g_leaderIvan.sgroup, 2,   markerListSouth, mkr_rusintro_ivan_dest, 			true)
	Ugra_SendIntroUnits(sg_rus_intro1,       2,   markerListNorth, nil, 	    					true)
	Ugra_SendIntroUnits(sg_rus_intro2,       2.5, markerListSouth, mkr_rusintropath_south_dest1,	true) 
	Ugra_SendIntroUnits(sg_rus_intro4,       2,   markerListSouth, mkr_rusintropath_south_dest2,	true)
	Ugra_SendIntroUnits(sg_rus_intro6,       2,   markerListSouth, mkr_rusintropath_south_dest3,	true)
	Ugra_SendIntroUnits(sg_rus_intro8,       1.5, markerListSouth, mkr_rusintropath_south_dest4, 	true)
	
	
	--Rus Villagers
	AssignVillagersToFarms(sg_rus_villagers1)
	AssignVillagersToWood(sg_rus_villagers2)
	AssignVillagersToGold(sg_rus_villagers3)
	AssignVillagersToStone(sg_rus_villagers4)
	
	Rule_AddOneShot(Ugra_AddVillagersToCheer, 2, {sgroup=sg_rus_villagers1})

end

function Ugra_AddVillagersToCheer(context, data)
	
	local _assignIdle = function(grp, idx, sid)
		if Squad_IsIdle(sid) then
			SGroup_Add(sg_rus_intro_cheer, sid)
		end
	end
	
	SGroup_ForEach(data.sgroup, _assignIdle)
	
end


function Ugra_SendIvanCheck()

	if Prox_AreSquadsNearMarker(sg_rus_intro_scout, mkr_rusintro_scout3, ANY) then
		Cmd_FormationMove(g_leaderIvan.sgroup, mkr_rusintro_ivan_dest1)
		Cmd_FormationMove(g_leaderIvan.sgroup, mkr_rusintro_ivan_dest2, true)
		Rule_RemoveMe()
	end
	
end


function Ugra_AssignStartingMonUnits()
	SGroup_DestroyAllSquads(sg_mon_intro_north)
	SGroup_DestroyAllSquads(sg_mon_intro_villagers)
	Defend_AddSGroup(MissionOMatic_FindModule("DefendMonFord2"), sg_mon_intro_west, true)
	--RovingArmy_AddSGroup(MissionOMatic_FindModule("MonShore"), sg_mon_intro_ford, true)
	Defend_AddSGroup(MissionOMatic_FindModule("DefendMonBackup2"), sg_mon_intro_ford, true)
	Defend_AddSGroup(MissionOMatic_FindModule("DefendMonBackup2"), sg_mon_intro_south, true)
	SpawnUnitsToModule({{ type = "scar_archer", numSquads = 8 }, { type = "scar_knight", numSquads = 28 }, { type = "scar_horsearcher", numSquads = 16 }, { type = "scar_horseman", numSquads = 8 }}, "DefendMonBackup1", mkr_monbackup1)
	SpawnUnitsToModule({{ type = "scar_archer", numSquads = 8 }, { type = "scar_knight", numSquads = 20 }, { type = "scar_horsearcher", numSquads = 12 }}, "DefendMonBackup2", mkr_monbackup2)
	SpawnUnitsToModule({{ type = "scar_archer", numSquads = 12 }, { type = "scar_manatarms", numSquads = 8 }}, "DefendMonFortRanged", mkr_monfort)
end

function Ugra_BackupFordCombat()
	Defend_AddSGroup(MissionOMatic_FindModule("DefendMonBackup"), sg_mon_intro_ford, true)
end
	
function Ugra_SendIntroUnits(sgroup, delay, markerList, finalDestination, warpToFinalPosOnSkip)

	if t_introUnitEndPositions == nil then 
		t_introUnitEndPositions = {}
	end
	
	local data = {
		sgroup = sgroup, 
		delay = delay,
		markerList = Clone(markerList),
	}
	
	if finalDestination ~= nil then
		table.insert(data.markerList, finalDestination)
	end
	
	data.ruleID = Rule_AddOneShot(Ugra_SendIntroUnits_Delayed, delay, data)
	
	if warpToFinalPosOnSkip == true then 
		table.insert(t_introUnitEndPositions, data)
	end
	
end

function Ugra_SendIntroUnits_Delayed(context, data)
	
	-- Add the others as waypoints
	for index, marker in pairs(data.markerList) do
		if scartype(marker) == ST_MARKER then
			if index <= #data.markerList then
				Cmd_FormationMove(data.sgroup, marker, true)
			end
		end
	end
	
end

function Ugra_GatherSheep()
	local _MoveSheep = function(gid, idx, sid)
		local offsetPos = PositionWithOffset(Marker_GetPosition(mkr_sheepgather), World_GetRand(0, 10), World_GetRand(0, 10))
		
		SGroup_Single(sg_single, sid)
		Cmd_Move(sg_single, offsetPos)
	end
	Player_GetAllSquadsNearMarker(player2, sg_mon_sheep, mkr_sheepgather, 40)
	SGroup_Filter(sg_mon_sheep, "gaia", FILTER_KEEP)
	
	SGroup_ForEach(sg_mon_sheep, _MoveSheep)
end

function Achievement_OnEntityKilled(context) -- Achievement function to track kills with outposts
    
    -- Number of Outpost kills required for Achievement
    local outpostKillThreshold = 50
        
    -- make sure the victim is not world owned and that it is owned by player2
    if context.victimOwner ~= nil and context.victimOwner == player2 then
        
        -- Add a check to make sure victim is not type 'gaia' or 'building'
        if not Entity_IsOfType(context.victim, "gaia") and not Entity_IsOfType(context.victim, "building") then
                        
            -- Check if the killer was an outpost
			if context.killer ~= nil then --nil check
				if Entity_IsOfType(context.killer, "outpost") then
					
					-- Increment Outpost Kill Count
					outpostKillCounter = outpostKillCounter + 1            
					
					-- If number of Outpost kills exceeds threshold required for Achievement
					if outpostKillCounter >= outpostKillThreshold then
						
						-- ACHIEVEMENT UNLOCKED - Ancient Tower Defense
						Game_SendCustomChallengeEvent(player1, CE_ACHIEVOUTPOSTKILLSUGRA, 1) 
						
						Rule_RemoveMe()	
						
					end
				end
            end
        end
    end
end


function Ugra_SkipIntro()
	
	for index, data in pairs(t_introUnitEndPositions) do 
		
		if Rule_ExistsWithID(data.ruleID) then
			Rule_RemoveWithID(data.ruleID)
		end
		
		local finalDestination = data.markerList[#data.markerList]
		SGroup_FormationWarpToMarker(data.sgroup, finalDestination, Util_GetOffsetPosition(finalDestination, OFFSET_FRONT, 10))
		
	end
	
	--Insert destroy scout here and spawn a new one at the destination marker
	sg_starting_scout = SGroup_CreateIfNotFound("sg_starting_scout")
	
	SGroup_DestroyAllSquads(sg_rus_intro_scout)
	UnitEntry_DeploySquads(player1, sg_starting_scout, {type = "scar_scout", numSquads = 1, spawn = mkr_rusintro_scout5})
	
end

function Ugra_CheckMissionEndCondition()
	if Player_GetBuildingsCountOnly(player1, { EBP.RUS.BUILDING_TOWN_CENTER_CAPITAL_RUS }) == 0 then
		Mission_Fail()
		Rule_RemoveMe()
	end
	
	if Player_GetBuildingsCountOnly(player2, { EBP.MONGOL.BUILDING_TOWN_CENTER_MON }) == 0 then
		Mission_Complete()
		Rule_RemoveMe()
	end
	
end