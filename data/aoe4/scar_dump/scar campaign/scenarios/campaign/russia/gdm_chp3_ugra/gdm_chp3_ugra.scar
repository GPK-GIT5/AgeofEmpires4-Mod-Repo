		mkr_mon_north1,
		mkr_mon_north2,
		mkr_mon_north3,
		mkr_mon_north4,
	}
	markerListMonWest = {  
		mkr_mon_west1,
		mkr_mon_west2,
		mkr_mon_west3,
		mkr_mon_west3,
	}
	markerListMonFord = {  
