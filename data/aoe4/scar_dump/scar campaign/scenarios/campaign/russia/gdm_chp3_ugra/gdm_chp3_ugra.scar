function Mission_SetupVariables()

	g_leaderIvan = Missionomatic_InitializeLeader({
		name = "$11166684", -- Ivan III
		owner = player1,
		neutralHolder = player3,
	})

	--Ivan forces
	sg_rus_army = SGroup_CreateIfNotFound("sg_rus_army")
	sg_rus_villagers1 = SGroup_CreateIfNotFound("sg_rus_villagers1")
	sg_rus_villagers2 = SGroup_CreateIfNotFound("sg_rus_villagers2")
	sg_rus_villagers3 = SGroup_CreateIfNotFound("sg_rus_villagers3")
	sg_rus_villagers4 = SGroup_CreateIfNotFound("sg_rus_villagers4")
	
	--Cinematic SGroups
	
	sg_rus_intro_scout = SGroup_CreateIfNotFound("sg_rus_intro_scout")
	sg_rus_intro1 = SGroup_CreateIfNotFound("sg_rus_intro1")
	sg_rus_intro2 = SGroup_CreateIfNotFound("sg_rus_intro2")
	sg_rus_intro3 = SGroup_CreateIfNotFound("sg_rus_intro3")
	sg_rus_intro4 = SGroup_CreateIfNotFound("sg_rus_intro4")
	sg_rus_intro5 = SGroup_CreateIfNotFound("sg_rus_intro5")
	sg_rus_intro6 = SGroup_CreateIfNotFound("sg_rus_intro6")
	sg_rus_intro7 = SGroup_CreateIfNotFound("sg_rus_intro7")
	sg_rus_intro8 = SGroup_CreateIfNotFound("sg_rus_intro8")
	sg_rus_intro_cheer = SGroup_CreateIfNotFound("sg_rus_intro_cheer")
	
	sg_mon_intro_south = SGroup_CreateIfNotFound("sg_mon_intro_south")
	sg_mon_intro_west = SGroup_CreateIfNotFound("sg_mon_intro_west")
	sg_mon_intro_north = SGroup_CreateIfNotFound("sg_mon_intro_north")
	sg_mon_intro_ford = SGroup_CreateIfNotFound("sg_mon_intro_ford")
	sg_mon_intro_villagers = SGroup_CreateIfNotFound("sg_mon_intro_villagers")
		
	sg_mon_outro_cav = SGroup_CreateIfNotFound("sg_mon_outro_cav")
	sg_rus_outro = SGroup_CreateIfNotFound("sg_rus_outro")
	sg_outro_cannon = SGroup_CreateIfNotFound("sg_outro_cannon")
	sg_mon_outro_south = SGroup_CreateIfNotFound("sg_mon_outro_south")

	--Mongol forces
	sg_mon_fort = SGroup_CreateIfNotFound("sg_mon_fort")
	sg_mon_ford1 = SGroup_CreateIfNotFound("sg_mon_ford1")
	sg_mon_ford2 = SGroup_CreateIfNotFound("sg_mon_ford2")
	sg_mon_attacknorth = SGroup_CreateIfNotFound("sg_mon_attacknorth")
	sg_mon_attacksouth = SGroup_CreateIfNotFound("sg_mon_attacksouth")
	
	sg_mon_scoutwave1 = SGroup_CreateIfNotFound("sg_mon_scoutwave1")
	sg_mon_scoutwave2 = SGroup_CreateIfNotFound("sg_mon_scoutwave2")
	
	sg_mon_southreinforce = SGroup_CreateIfNotFound("sg_mon_southreinforce")
	sg_mon_southreinforce_buildings = SGroup_CreateIfNotFound("sg_mon_southreinforce_buildings")
	
	sg_mon_scout_intro = SGroup_CreateIfNotFound("sg_mon_scout_intro")
	
	sg_mon_roaming = SGroup_CreateIfNotFound("sg_mon_roaming")
	sg_mon_backup1 = SGroup_CreateIfNotFound("sg_mon_backup1")
	sg_mon_backup2 = SGroup_CreateIfNotFound("sg_mon_backup2")
	sg_mon_monford3 = SGroup_CreateIfNotFound("sg_mon_monford3")
	
	sg_mon_sheep = SGroup_CreateIfNotFound("sg_mon_sheep")
	
	-- Mongol ford sorting temp sgroups
	sg_inf = SGroup_CreateIfNotFound("sg_inf")
	sg_rng = SGroup_CreateIfNotFound("sg_rng")
	sg_cav = SGroup_CreateIfNotFound("sg_cav")
	
	--EGroups
	eg_mon_towncenter = EGroup_CreateIfNotFound("eg_mon_towncenter")
	eg_mon_outro = EGroup_CreateIfNotFound("eg_mon_outro")
	
	eg_rus_towncenter = EGroup_CreateIfNotFound("eg_rus_towncenter")
	
	--ints
	ugraPhase = 1
	
	--timers
	prepareTimer = Util_DifVar({520, 520, 400, 280})
	holdFordTimer = 900
	fordStartGraceDelay = 60
	forceGraceDelay = 8
	monReinforcePeriod = Util_DifVar({85, 54, 48, 42})
	monReinforcePhase2Delay = Util_DifVar({ holdFordTimer*0.5,	holdFordTimer*0.5,  holdFordTimer*0.33, holdFordTimer*0.25 })
	monReinforcePhase3Delay = Util_DifVar({ 9999, 				9999,				holdFordTimer*0.66, holdFordTimer*0.50 })
	monReinforcePhase4Delay = Util_DifVar({ 9999, 				9999,				9999, 				holdFordTimer*0.75 })
	monReinforceWaveDelay = 530
	updateLoopPeriod = 1
	attackCooldown = 60	
	monWaveTimer = Util_DifVar({60, 60, 60, 60})
	
	--bools
	prepareTimerComplete = false
	attackNorthCooldown = true
	attackSouthCooldown = true
	firstProbe = true
	firstNorthAttack = true
	firstSouthAttack = true
	fordAttacked = false
	evaluateFord = false
	
	--Ford Comparison
	warningThreshold = 0.50
	attackThreshold = 0.40
	bestForceValue = 0
	UI_SetPlayerDataContext(player1, { tug_of_war_threshold = attackThreshold, tug_of_war_warning_threshold = warningThreshold })
	
	MongolWaves_InitObjectives()
	HoldFords_InitObjectives()
	AttackMongols_InitObjectives()

end

function Mission_SetupPlayers()
	
	player1 = World_GetPlayerAt(1)
	player2 = World_GetPlayerAt(2)
	player3 = World_GetPlayerAt(3)
	
	
	--player 1 - Ivan
	Setup_SetPlayerName(player1, Loc_GetString(11180253)) -- Ivan III
	Player_SetCurrentAge(player1, AGE_CASTLE)
	Player_SetMaximumAge(player1, AGE_IMPERIAL)
	
	--player 2 - Mongol
	Setup_SetPlayerName(player2, Loc_GetString(11180254)) -- Akmet Khan
	Player_SetCurrentAge(player2, AGE_CASTLE)
	Player_SetMaximumAge(player2, AGE_CASTLE)
	Player_SetPopCapOverride(player2, 1000) -- extra popcap room for rams
	
	AI_Enable(player3, false)
	
	-- Player relationships	
	Player_SetRelationship(player1, player2, R_ENEMY)
	Player_SetRelationship(player2, player1, R_ENEMY)
	Player_SetRelationship(player1, player3, R_ALLY)
	Player_SetRelationship(player3, player1, R_ALLY)
	Player_SetRelationship(player2, player3, R_ALLY)
	Player_SetRelationship(player3, player2, R_ALLY)
	
	PlayerUpgrades_Auto(player1)
	PlayerUpgrades_Auto(player2)
	PlayerUpgrades_Auto(player3)
	
	--Tower Upgrades
	EGroup_CompleteUpgrade(eg_mon_fordtowers, UPG.MONGOL.UPGRADE_OUTPOST_ARROWSLITS_MON)
	EGroup_CompleteUpgrade(eg_rus_fordtowers, UPG.RUS.UPGRADE_WOODEN_CASTLE_WATCH_RUS)
	
end

function Mission_Preset()
	
	-- Set Player Colours
	PlayerColour_Enable()
	
	Game_SetPlayerSlotColour(player1, 1)
	Game_SetPlayerUISlotColour(player1, 1)
	Game_SetPlayerSlotColour(player2, 2)
	Game_SetPlayerUISlotColour(player2, 2)
	Game_SetPlayerSlotColour(player3, 1)
	Game_SetPlayerUISlotColour(player3, 1)
	
	-- AI cached paths
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(player2, mkr_ford1_attack2, Util_GetPosition(mkr_ford1_attack1), 5.0)
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(player2, mkr_ford2_attack2, Util_GetPosition(mkr_ford2_attack1), 5.0)
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(player2, mkr_ford3_attack2, Util_GetPosition(mkr_ford3_attack1), 5.0)
	
	--Intro action
	Ugra_InitPlayerUnits()
	Ugra_InitEnemyUnits()
	Ugra_InitializeUnitValues()
	
	-- Audio considerations
    if Music_UnlockIntensity then
        Sound_SetForceMusic(false)
    else
        Sound_SetForceMusic(true)
    end
	
	--DEBUG: Auto Test--
	AutoTest_OnInit()
	
end

function Mission_Start()	
	-- Sets initial player resources
	Player_SetResource(player1, RT_Food, 800)
	Player_SetResource(player1, RT_Wood, 1000)
	Player_SetResource(player1, RT_Stone, 300)
	Player_SetResource(player1, RT_Gold, 600)
	
	Objective_Start(OBJ_FindMongols)
	Rule_AddInterval(Ugra_CheckMissionEndCondition, 5)
	Rule_AddInterval(Ugra_GatherSheep, 20)
	
	local wave_data_ford1 = {
		descriptor = "wave_ford1",
		player = player2,	
		use_separate_spawns = true,
		spawn = mkr_monfort,
		units = {
			{ type = "scar_spearman", numSquads = 1 },
			{ type = "scar_archer", numSquads = 1 },
		},
		staging_module = "DefendMonFortRanged",
		assault_module = "DefendMonFord1",
		ignore_build_times = false,
		auto_launch = true,
	}
	
	local wave_data_ford2 = {
		descriptor = "wave_ford2",
		player = player2,	
		use_separate_spawns = true,
		spawn = mkr_monfort,
		units = {
			{ type = "scar_spearman", numSquads = 1 },
			{ type = "scar_archer", numSquads = 1 },
		},
		staging_module = "DefendMonFortRanged",
		assault_module = "DefendMonFord2",
		ignore_build_times = false,
		auto_launch = true,
	}
	
	wave_ford1 =  Wave_New(wave_data_ford1)
	wave_ford2 =  Wave_New(wave_data_ford2)
	
	-- ACHIEVEMENT SETUP - Counter for tracking kills by outposts
    outpostKillCounter = 0

    -- ACHIEVEMENT TRACKING - Rule to track death of units by Towers
    Rule_AddGlobalEvent(Achievement_OnEntityKilled, GE_EntityKilled)
	
	Game_TransitionToState("taiga_morning_fog", 90)
	
end

