--
-- Moscow 1238 - Mongol Attacks objective
--




function MongolCountdown_InitObjectives()

	OBJ_MongolCountdown = {
		
		Title = "$11201354", -- Mongol attack incoming
		Type = ObjectiveType_Information,
		
		Intel_Start = EVENTS.MongolAttacks_PreAnnounce,
		
		SetupUI = MongolCountdown_SetupUI,
		OnStart = MongolCountdown_Start,
		
		IsComplete = function()
			return Objective_GetTimerSeconds(OBJ_MongolCountdown) <= 0
		end,
		OnComplete = function()
			Objective_Start(OBJ_MongolAttacks)
		end,
		
		showTitle = false,
		
	}	
	
	Objective_Register(OBJ_MongolCountdown)	
	
end

function MongolAttacks_InitObjectives()

	OBJ_MongolAttacks = {
		
		Title = "$11180194", -- Defend against Mongol attacks
		Type = ObjectiveType_Battle,
		
		Intel_Start = EVENTS.MongolAttacks_ObjectiveStart,
		SetupUI = MongolAttacks_SetupUI,
		
		OnStart = MongolAttacks_Start,
	
		
		PreComplete = MongolAttacks_PreComplete,
		OnComplete = MongolAttacks_Complete,
		
		OnFail = MongolAttacks_Fail,
		
		Cheat = function()
			SGroup_DestroyAllSquads(sg_start_mongols)
			SGroup_DestroyAllSquads(sg_start_mongols_khan)
		end,
		
	}	

	Objective_Register(OBJ_MongolAttacks)
	
end




--
-- Note: The probing attacks are triggered after the Landmark is built
--

function MongolCountdown_TriggerObjective()

	Objective_Start(OBJ_MongolCountdown)
	
end

function MongolCountdown_SetupUI()
	
	local timeInSeconds = t_difficulty.mongolAttackDelay * 60
	Objective_StartTimer(OBJ_MongolCountdown, COUNT_DOWN, timeInSeconds)
	Game_TransitionToState("taiga_winter_sunset", timeInSeconds)	
	
end

function MongolCountdown_Start()
	
	MongolCountdown_StartProbingAttacks()
	

	
end



function MongolCountdown_StartProbingAttacks()
	
	if Game_GetSPDifficulty() ~= GD_EASY then 		-- no probing attacks in story mode
		
		i_numProbingAttacks = 0
		threatID_probingAttacks = ThreatArrow_CreateGroup("threat_group", sg_probing_mongol_attacks_threatgroup)
		
		-- create an attack now, and schedule future attacks
		MongolCountdown_CreateProbingAttack()
		Rule_AddInterval(MongolCountdown_CreateProbingAttack, t_difficulty.probingAttackFrequency * 60)	
		
		-- add the rule to monitor these attacks	
		Rule_AddInterval(MongolCountdown_MonitorProbingAttacks, 1)
		
	end
		
end

function MongolCountdown_CreateProbingAttack()
	
	if Objective_IsComplete(OBJ_MongolCountdown) or (Objective_IsTimerSet(OBJ_MongolCountdown) and Objective_GetTimerSeconds(OBJ_MongolCountdown) < 60) then 
		Rule_RemoveMe()
	else
		Rule_AddOneShot(MongolCountdown_CreateProbingAttack_Delayed, World_GetRand(0, 10))	-- add a rule to do the actual creation somewhere in the next few seconds (so it's isn't rigidly on the same schedule)
	end
	
end


function MongolCountdown_CreateProbingAttack_Delayed()
	
	i_numProbingAttacks = i_numProbingAttacks + 1
	
	local units
	local potentialSpawnLocations
	local targets
	local level = i_numProbingAttacks + t_difficulty.probingAttackLevelAdjustment
	
	if level <= 2 then 
		
		units = {
			{type = "scar_scout", numSquads = 1},
		}
		potentialSpawnLocations = {
			mkr_mongol_spawn1,							-- use the two potential spawn locations on the east edge of the map
			mkr_mongol_spawn2,
		}
		targets = {"OuterCity", "InnerCity"}
		
	elseif level <= 4 then
		
		units = {
			{type = "scar_scout", numSquads = 1},
			{type = "scar_spearman", numSquads = 2},
		}
		potentialSpawnLocations = {
			mkr_mongol_spawn1,			
			mkr_mongol_spawn2,
			mkr_mongol_spawn4,							-- add in the spawn location at the north edge of the map
		}
		targets = {"OuterCity", "InnerCity"}
		
	elseif level <= 5 then
		
		units = {
			{type = "scar_horseman", numSquads = 2},
			{type = "scar_spearman", numSquads = 2},
		}
		potentialSpawnLocations = {
			mkr_mongol_spawn1,
			mkr_mongol_spawn2,
			mkr_mongol_spawn4,
		}
		targets = {"InnerCity"} 
		
	elseif level <= 6 then
		
		units = {
			{type = "scar_horsearcher", numSquads = 3},
		}
		potentialSpawnLocations = {
			mkr_mongol_spawn1,
			mkr_mongol_spawn2,
			mkr_mongol_spawn4,
		}
		targets = {"InnerCity"} 
		
	else
		
		units = {
			{type = "scar_horsearcher", numSquads = 4},
		}
		potentialSpawnLocations = {
			mkr_mongol_spawn1,
			mkr_mongol_spawn2,
			mkr_mongol_spawn4,
		}
		targets = {"InnerCity"} 
		
	end
	
	-- create new probing attack
	local newModule = {
		type = "RovingArmy",
		descriptor = "ProbingMongolAttacks",
		player = player2,
		spawnLocation = Table_GetRandomItem(potentialSpawnLocations),
		units = units,
		sgroup = sg_probing_mongol_attacks,
		attackMove = attackMoveStyle_normal,
		targets = targets, 
	}
	RovingArmy_Init(newModule)
	
	
	
end

function MongolCountdown_MonitorProbingAttacks()
	
	local module = MissionOMatic_FindModule("ProbingMongolAttacks")
	
	if Objective_IsStarted(OBJ_MongolAttacks) == true then
		
		Rule_RemoveMe()
		
	else
		
		SGroup_Duplicate(module.sgroup, sg_temp)
		SGroup_RemoveGroup(sg_temp, sg_probing_mongol_attacks_threatgroup)
		
		local _CheckSquad = function(gid, idx, sid)
			if Player_CanSeeSquad(player1, sid, ANY) then 
				SGroup_Add(sg_probing_mongol_attacks_threatgroup, sid)
			end
		end
		SGroup_ForEach(sg_temp, _CheckSquad)		
		
	end
	
end 



-- 
-- The Final Big Mongol Attack
--

function MongolAttacks_SetupUI()
	
		-- hide any lingering objectives, because this is the end phase of the mission
	
		Objective_Show(OBJ_FindVillagers, false, false)
		OBJ_FindVillagers.showTitle = false
		OBJ_FindVillagers.playIntel = false
		
		Objective_Show(OBJ_BuildDefences, false, false)
		OBJ_BuildDefences.showTitle = false
		OBJ_BuildDefences.playIntel = false
		
		Objective_Show(SOBJ_BuildDefensiveStructures, false, false)
		SOBJ_BuildDefensiveStructures.showTitle = false
		SOBJ_BuildDefensiveStructures.playIntel = false

		Objective_Show(SOBJ_BuildMilitaryUnits, false, false)
		SOBJ_BuildMilitaryUnits.showTitle = false
		SOBJ_BuildMilitaryUnits.playIntel = false
	
	
end




function MongolAttacks_Start()

	module_mongolAttackers1a = MissionOMatic_FindModule("MongolAttackers1a")
	module_mongolAttackers1b = MissionOMatic_FindModule("MongolAttackers1b")
	module_mongolAttackers1c = MissionOMatic_FindModule("MongolAttackers1c")
	module_mongolAttackers2a = MissionOMatic_FindModule("MongolAttackers2a")
	module_mongolAttackers2b = MissionOMatic_FindModule("MongolAttackers2b")
	module_mongolAttackers2c = MissionOMatic_FindModule("MongolAttackers2c")
	module_mongolAttackers2d = MissionOMatic_FindModule("MongolAttackers2d")
	module_mongolAttackers2e = MissionOMatic_FindModule("MongolAttackers2e")
	module_mongolAttackers3a = MissionOMatic_FindModule("MongolAttackers3a")
	module_mongolAttackers3b = MissionOMatic_FindModule("MongolAttackers3b")
	module_mongolAttackers3c = MissionOMatic_FindModule("MongolAttackers3c")
	module_mongolAttackers3d = MissionOMatic_FindModule("MongolAttackers3d")
	module_mongolAttackers3e = MissionOMatic_FindModule("MongolAttackers3e")
	module_mongolAttackers4a = MissionOMatic_FindModule("MongolAttackers4a")
	module_mongolAttackers4b = MissionOMatic_FindModule("MongolAttackers4b")
	module_mongolAttackers4c = MissionOMatic_FindModule("MongolAttackers4c")
	module_mongolAttackers4d = MissionOMatic_FindModule("MongolAttackers4d")
	module_mongolAttackers4e = MissionOMatic_FindModule("MongolAttackers4e")
	
	-- upgrade some of the Mongol units to Age II variants
	Player_CompleteUpgrade(player2, UPG.MONGOL.UPGRADE_UNIT_HORSEMAN_2_MON)
	Player_CompleteUpgrade(player2, UPG.MONGOL.UPGRADE_UNIT_SPEARMAN_2_MON)

	Rule_AddOneShot(MongolAttacks_StartAttacks_PartB, 5)
	
end

