function MongolAttacks_AttackSpotted() 
	
	SGroup_Clear(sg_temp)
	
	SGroup_AddGroup(sg_temp, Prefab_DoAction(module_mongolAttackers1a, "GetSGroup"))
	SGroup_AddGroup(sg_temp, Prefab_DoAction(module_mongolAttackers1b, "GetSGroup"))
	SGroup_AddGroup(sg_temp, Prefab_DoAction(module_mongolAttackers1c, "GetSGroup"))

	
	if Player_CanSeeSGroup(player1, sg_temp, ANY) then
		
		Music_PlayStinger("mus_camp_cust_mongol_drum_short_cavalry")	

		--Music_LockIntensity(MUSIC_COMBAT, 30)
		EventCues_CallToAction("$11180195", CTA_ALARM, nil, nil, sg_end_mongols, 8) -- The Mongols are attacking
		Sound_Play2D("sfx_campaign_scripted_large_group_engage")
		Sound_Play2D("mus_stinger_campaign_warning")
		
		time_lastMongolAttackWave = World_GetGameTime()
		Rule_AddInterval(MongolAttacks_Monitor, 0.5)
		
		Rule_RemoveMe()
		
	end
	
end




function MongolAttacks_Monitor()
	
	local mongolCount = SGroup_CountSpawned(sg_end_mongols)
	
	if mongolCount == 0 and #t_mongolAttackWaves == 0 then 

		Rule_RemoveMe()
		Objective_Complete(OBJ_MongolAttacks)
		
	else
		
		local timeSinceLastWave = World_GetGameTime() - time_lastMongolAttackWave
		
		if timeSinceLastWave >= 10 and #t_mongolAttackWaves >= 1 then 
			
			local wave = t_mongolAttackWaves[1]
			
			if (scartype(wave.difficulty) == ST_NUMBER and wave.difficulty ~= Game_GetSPDifficulty()) 
			   or (scartype(wave.difficulty) == ST_TABLE and Table_Contains(wave.difficulty, Game_GetSPDifficulty()) == false) then		
				
				table.remove(t_mongolAttackWaves, 1)		-- this wave is NOT for this difficulty mode, so just remove it and try the next wave next time
				
			elseif (wave.timeThreshold ~= nil and timeSinceLastWave >= wave.timeThreshold)
			   or (wave.unitCountThreshold ~= nil and mongolCount <= wave.unitCountThreshold) then  
				
				local delay = 4
				
				for index, spawn in ipairs(wave.spawns) do 
					
					Rule_AddOneShot(MongolAttacks_SpawnUnits, delay, {units = spawn.units, module = spawn.module, spawnGroup = spawn.spawnGroup, useHiddenPos = true})
					delay = delay + 2
					
				end
				
				time_lastMongolAttackWave = World_GetGameTime()				
				
				table.remove(t_mongolAttackWaves, 1)
				
			end
			
		end
		
	 	-- check for mission fail
		Player_GetAll(player1)
		EGroup_Filter(eg_allentities, {EBP.RUS.BUILDING_TOWN_CENTER_CAPITAL_RUS, EBP.RUS.BUILDING_LANDMARK_AGE1_NOVGOROD_KREMLIN_CONTROL_RUS}, FILTER_KEEP)
		EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
		
		if EGroup_Count(eg_allentities) == 0 then 
			Rule_RemoveMe()
			Objective_Fail(OBJ_MongolAttacks)
		end
		
	end
		
end


function MongolAttacks_SpawnUnits(context, data)
	
	SGroup_Clear(sg_temp)
	
	if data.useHiddenPos == true then 
		local hiddenPos = World_GetHiddenPositionOnPath(player1, data.spawnGroup.marker, mkr_location_moscow, CHECK_IN_FOW)
		if hiddenPos ~= nil then 
			data.spawnLocation = hiddenPos
		end
	end
	
	UnitEntry_DeploySquads(player2, {sg_temp, sg_end_mongols}, data.units, data.spawnGroup.marker, nil, nil, {facing = Util_GetPosition(mkr_location_moscow)})

	-- add units to module
	Prefab_DoAction(data.module, "AddSGroup", sg_temp)	

	-- add to threat arrow group
	ThreatArrow_Add(data.spawnGroup.threatGroup, sg_temp)

	-- if this is the first spawn at this location, add a minimap blip
	if data.spawnGroup.previouslyUsed ~= true then 
		UI_CreateMinimapBlip(data.spawnGroup.marker, 10, "threat_group")
		data.spawnGroup.previouslyUsed = true
	end	
	
end


function MongolAttacks_PreComplete()
	
	Music_LockIntensity(MUSIC_COMBAT_RARE)
	
end

function MongolAttacks_Complete()
	
	for index, location in pairs(t_endMongolSpawnLocations) do 
		ThreatArrow_DestroyGroup(location.threatGroup)
	end
	
	Mission_Complete()
	
end

function MongolAttacks_Fail()
	
	Mission_Fail()
	
end
