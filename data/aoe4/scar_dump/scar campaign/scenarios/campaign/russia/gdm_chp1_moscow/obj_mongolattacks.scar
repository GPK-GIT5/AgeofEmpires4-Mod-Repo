						{type = "scar_spearman", numSquads = 2, difficulty = {GD_HARD, GD_EXPERT}},
						{type = "scar_spearman", numSquads = 2, difficulty = {GD_EXPERT}},
					},
					module = module_mongolAttackers2a,
					spawnGroup = t_endMongolSpawnLocations[1],
				},
				{
					units = {
						{type = "scar_spearman", numSquads = Util_DifVar({4, 5, 5, 5})},
						{type = "scar_spearman", numSquads = 1, difficulty = {GD_HARD, GD_EXPERT}},
						{type = "scar_spearman", numSquads = 3, difficulty = GD_EXPERT},
					},
					module = module_mongolAttackers2b,
					spawnGroup = t_endMongolSpawnLocations[2],
				},
				{
					units = {
						{type = "scar_spearman", numSquads = Util_DifVar({3, 4, 4, 4})},
						{type = "scar_spearman", numSquads = 2, difficulty = {GD_HARD, GD_EXPERT}},
						{type = "scar_spearman", numSquads = 2, difficulty = {GD_EXPERT}},
					},
					module = module_mongolAttackers2c,
