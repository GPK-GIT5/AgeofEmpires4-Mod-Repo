				{type = "scar_horsearcher", numSquads = 3, difficulty = {GD_HARD, GD_EXPERT}},
				{type = "scar_horsearcher", numSquads = 1, difficulty = {GD_EXPERT}},
				{type = "scar_khan", numSquads = 1},
			},
			module = module_mongolAttackers1b,
