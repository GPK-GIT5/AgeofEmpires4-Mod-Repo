			Prefab_DoAction(MissionOMatic_FindModule("MongolCenterArmy"), "UpdateTargetLocation", mkr_final_mainarmy_center, attackMoveStyle_normal)
			Prefab_DoAction(MissionOMatic_FindModule("MongolRightArmy"), "UpdateTargetLocation", mkr_final_mainarmy_right, attackMoveStyle_normal)
			
			DefenseLines_ReplenishModule(ally_left, sg_ally_left, mkr_ally_left_spawn)
			DefenseLines_ReplenishModule(ally_center, sg_ally_center, mkr_ally_center_spawn)
			DefenseLines_ReplenishModule(ally_right, sg_ally_right, mkr_ally_right_spawn)
			
			RovingArmy_SetTarget(ally_left, mkr_last_stand_left)
			RovingArmy_SetTarget(ally_center, mkr_last_stand_center)
			RovingArmy_SetTarget(ally_right, mkr_last_stand_right)
			
