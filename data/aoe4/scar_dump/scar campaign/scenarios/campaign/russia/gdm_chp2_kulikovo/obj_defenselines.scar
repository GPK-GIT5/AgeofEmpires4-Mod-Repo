import("gdm_chp2_kulikovo.scar")

------------------------------------------------------------------------------------------------------------------------------------------
--														OBJECTIVE INITIALIZATION
------------------------------------------------------------------------------------------------------------------------------------------

function DefenseLines_InitObjectives()
	
	--
	-- Repel the Mongol attackers
	--
	OBJ_RepelMongols = {
		Title = "$11176411", -- Repel the Mongol Horde
		Type = ObjectiveType_Battle,
		
		PreStart = function()
			Objective_Start(SOBJ_HoldFords, true)
		end,
		
		PreComplete = function()
			--Music_LockIntensity(MUSIC_TENSE_RARE)
		end,
		
		OnComplete = function()
			Music_StopMedium()
			Mission_Complete()
		end,
	}
	
	--Smolka river ford defense line
	SOBJ_HoldFords = {
		Title = "$11176412", -- Support your allies at the Smolka River fords
		Type = ObjectiveType_Battle,
		--StartAlongsideParent = true,
		Parent = OBJ_RepelMongols,
		showTitle = true,
		
		OnStart = function()
			--Reveal the fords for the Mongol player so they stop ignoring the player
			FOW_PlayerRevealArea(player2, Marker_GetPosition(mkr_ford_left), Marker_GetProximityRadiusOrDefault(mkr_ford_left, 0), -1)
			FOW_PlayerRevealArea(player2, Marker_GetPosition(mkr_ford_center), Marker_GetProximityRadiusOrDefault(mkr_ford_center, 0), -1)
			FOW_PlayerRevealArea(player2, Marker_GetPosition(mkr_ford_right), Marker_GetProximityRadiusOrDefault(mkr_ford_right, 0), -1)
			
			Objective_Start(SOBJ_Wave1)
		end,
		
		PreComplete = function()
			holdStatus[LOCATION_FORDS] = false
			holdStatus[LOCATION_MAINLINE] = false
			holdStatus[LOCATION_LASTLINE] = false
		end,
		
		OnComplete = function()
			Util_StartIntel(EVENTS.Wave3_Good)
			Objective_Start(SOBJ_HoldMainline)
		end,
		
		IsFailed = function()
			local left_count = Kulikovo_CountMarker(player1, mkr_ford_left) + Kulikovo_CountMarker(player3, mkr_ford_left)
			local center_count = Kulikovo_CountMarker(player1, mkr_ford_center) + Kulikovo_CountMarker(player3, mkr_ford_center)
			local right_count = Kulikovo_CountMarker(player1, mkr_ford_right) + Kulikovo_CountMarker(player3, mkr_ford_right)
			local minimum = math.min(left_count, center_count, right_count)
			Obj_SetProgress(SOBJ_HoldFords.ID, minimum / 30)
			return Objective_IsFailed(OBJ_FordStrength_L) or Objective_IsFailed(OBJ_FordStrength_C) or Objective_IsFailed(OBJ_FordStrength_R)
		end,
		
		PreFail = function()
			holdStatus[LOCATION_FORDS] = false
			holdStatus[LOCATION_MAINLINE] = false
			holdStatus[LOCATION_LASTLINE] = false
			
			Prefab_DoAction(MissionOMatic_FindModule("MongolLeftArmy"), "UpdateTargetLocation", mkr_mainline_mainarmy_left, attackMoveStyle_normal)
			Prefab_DoAction(MissionOMatic_FindModule("MongolCenterArmy"), "UpdateTargetLocation", mkr_mainline_mainarmy_center, attackMoveStyle_normal)
			Prefab_DoAction(MissionOMatic_FindModule("MongolRightArmy"), "UpdateTargetLocation", mkr_mainline_mainarmy_right, attackMoveStyle_normal)
			
			DefenseLines_ReplenishModule(ally_left, sg_ally_left, mkr_ally_left_spawn)
			DefenseLines_ReplenishModule(ally_center, sg_ally_center, mkr_ally_center_spawn)
			DefenseLines_ReplenishModule(ally_right, sg_ally_right, mkr_ally_right_spawn)
			
			RovingArmy_SetTarget(ally_left, mkr_mainline_left)
			RovingArmy_SetTarget(ally_center, mkr_mainline_center)
			RovingArmy_SetTarget(ally_right, mkr_mainline_right)
			
			Objective_Fail(OBJ_FordStrength_L, false, false)
			Objective_Fail(OBJ_FordStrength_C, false, false)
			Objective_Fail(OBJ_FordStrength_R, false, false)
		end,
		
		OnFail = function()
			Util_StartIntel(EVENTS.Wave3_Bad)
			Objective_Start(SOBJ_HoldMainline)
		end,
	}
	
	-- Main line of defense
	SOBJ_HoldMainline = {
		Title = "$11176773", -- Support your allies holding the central hill
		Type = ObjectiveType_Battle,
		Parent = OBJ_RepelMongols,
		showTitle = true,
		
		
		SetupUI = function()
			Objective_Show(SOBJ_HoldFords, false)
			Objective_AddUIElements(SOBJ_HoldMainline, Marker_GetPosition(mkr_mainline_area), true, "$11180218") -- Hill
			--Obj_SetProgressVisible(SOBJ_HoldMainline.ID, true)
		end,
		
		PreStart = function()
		end,
		
		OnStart = function()
		--Moved the below to here from the PreComplete of HoldFords in order for elements to appear in the correct way
			Support_SpawnMainlineReinforcements()
			
			Prefab_DoAction(MissionOMatic_FindModule("MongolLeftArmy"), "UpdateTargetLocation", mkr_mainline_mainarmy_left, attackMoveStyle_normal)
			Prefab_DoAction(MissionOMatic_FindModule("MongolCenterArmy"), "UpdateTargetLocation", mkr_mainline_mainarmy_center, attackMoveStyle_normal)
			Prefab_DoAction(MissionOMatic_FindModule("MongolRightArmy"), "UpdateTargetLocation", mkr_mainline_mainarmy_right, attackMoveStyle_normal)
			
			DefenseLines_ReplenishModule(ally_left, sg_ally_left, mkr_ally_left_spawn)
			DefenseLines_ReplenishModule(ally_center, sg_ally_center, mkr_ally_center_spawn)
			DefenseLines_ReplenishModule(ally_right, sg_ally_right, mkr_ally_right_spawn)
			
			RovingArmy_SetTarget(ally_left, mkr_mainline_left)
			RovingArmy_SetTarget(ally_center, mkr_mainline_center)
			RovingArmy_SetTarget(ally_right, mkr_mainline_right)
			
			Objective_Complete(OBJ_FordStrength_L, false, false)
			Objective_Complete(OBJ_FordStrength_C, false, false)
			Objective_Complete(OBJ_FordStrength_R, false, false)
			
			EventCues_CallToAction("$11193040", CTA_CELEBRATE, EVENTS.Reinforcements_Hill, nil, sg_mainline_reinforcements, 20) -- "Reinforcements have arrived!"
			Sound_Play2D("sfx_campaign_scripted_medium_group_celebrate")
			Sound_Play2D("mus_stinger_campaign_triumph_short")
			
			--Reveal the hill to the enemy so the AI actually attacks
			FOW_PlayerRevealArea(player2, Marker_GetPosition(mkr_mainline_left), Marker_GetProximityRadiusOrDefault(mkr_mainline_left, 0), -1)
			FOW_PlayerRevealArea(player2, Marker_GetPosition(mkr_mainline_center), Marker_GetProximityRadiusOrDefault(mkr_mainline_center, 0), -1)
			FOW_PlayerRevealArea(player2, Marker_GetPosition(mkr_mainline_right), Marker_GetProximityRadiusOrDefault(mkr_mainline_right, 0), -1)
			
			fallbackTimeouts[LOCATION_MAINLINE] = false
			Rule_AddOneShot(DefenseLines_ReinforceTimedBypass, 64, {status = LOCATION_MAINLINE})
			Rule_AddInterval(DefenseLines_UpdateHoldStatus, 1, {status = LOCATION_MAINLINE, objective = SOBJ_HoldMainline}) --Update holdStatus when the progress bar has completely filled
		end,
		
		PreComplete = function()
			holdStatus[LOCATION_FORDS] = false
			holdStatus[LOCATION_MAINLINE] = false
			holdStatus[LOCATION_LASTLINE] = false
		end,
		
		OnComplete = function()
			Util_StartIntel(EVENTS.Wave7_Good)
			Objective_Start(SOBJ_HoldLast)
		end,
		
		IsFailed = function()
			return DefenseLines_IsMarkerLost(SOBJ_HoldMainline, mkr_mainline_area, 150) --Updates the progress bar and fails if abandoned sector is occupied
		end,
		
		PreFail = function()
			holdStatus[LOCATION_FORDS] = false
			holdStatus[LOCATION_MAINLINE] = false
			holdStatus[LOCATION_LASTLINE] = false
			
			Prefab_DoAction(MissionOMatic_FindModule("MongolLeftArmy"), "UpdateTargetLocation", mkr_final_mainarmy_left, attackMoveStyle_normal)
			Prefab_DoAction(MissionOMatic_FindModule("MongolCenterArmy"), "UpdateTargetLocation", mkr_final_mainarmy_center, attackMoveStyle_normal)
			Prefab_DoAction(MissionOMatic_FindModule("MongolRightArmy"), "UpdateTargetLocation", mkr_final_mainarmy_right, attackMoveStyle_normal)
			
			DefenseLines_ReplenishModule(ally_left, sg_ally_left, mkr_ally_left_spawn)
			DefenseLines_ReplenishModule(ally_center, sg_ally_center, mkr_ally_center_spawn)
			DefenseLines_ReplenishModule(ally_right, sg_ally_right, mkr_ally_right_spawn)
			
			RovingArmy_SetTarget(ally_left, mkr_last_stand_left)
			RovingArmy_SetTarget(ally_center, mkr_last_stand_center)
			RovingArmy_SetTarget(ally_right, mkr_last_stand_right)
		end,
		
		OnFail = function()
			Util_StartIntel(EVENTS.Wave7_Bad)
			Objective_Start(SOBJ_HoldLast)
		end,
	}
	
	-- Last line of defense
	SOBJ_HoldLast = {
		Title = "$11176776", --Hold the Don river crossing with your allies
		Type = ObjectiveType_Battle,
		Parent = OBJ_RepelMongols,
		showTitle = true,
		
		SetupUI = function()
			Objective_Show(SOBJ_HoldMainline, false)
			Objective_AddUIElements(SOBJ_HoldLast, Marker_GetPosition(mkr_last_stand_center), true, "$11180220") -- Don river
			--Obj_SetProgressVisible(SOBJ_HoldLast.ID, true)
		end,
		
		PreStart = function()
			holdStatus[LOCATION_FORDS] = false
			holdStatus[LOCATION_MAINLINE] = false
			holdStatus[LOCATION_LASTLINE] = false
			
			Player_GetAll(player1)
			locationThresholds.lastline = (SGroup_CountSpawned(sg_allsquads) / 2)
		end,
		
		OnStart = function()
			FOW_PlayerRevealArea(player2, Marker_GetPosition(mkr_last_stand_left), Marker_GetProximityRadiusOrDefault(mkr_last_stand_left, 0), -1)
			FOW_PlayerRevealArea(player2, Marker_GetPosition(mkr_last_stand_center), Marker_GetProximityRadiusOrDefault(mkr_last_stand_center, 0), -1)
			FOW_PlayerRevealArea(player2, Marker_GetPosition(mkr_last_stand_right), Marker_GetProximityRadiusOrDefault(mkr_last_stand_right, 0), -1)
			
			fallbackTimeouts[LOCATION_LASTLINE] = false
			Rule_AddOneShot(DefenseLines_ReinforceTimedBypass, 45, {status = LOCATION_LASTLINE})
			Rule_AddInterval(DefenseLines_UpdateHoldStatus, 1, {status = LOCATION_LASTLINE, objective = SOBJ_HoldLast}) --Update holdStatus when the progress bar has completely filled
			
