function debugprint(print_string)
	if debug then print(print_string) end
end
function CollectMeat_Kulikovo()
	if SGroup_CountSpawned(sg_gaia_kulikovo) > 0 then
		SGroup_Duplicate(sg_gaia_kulikovo, sg_temp)
		SGroup_Filter(sg_temp, SBP.GAIA.GAIA_HUNTABLE_DEER_CORPSE, FILTER_KEEP)
		if SGroup_CountSpawned(sg_temp) > 0 then
			local _AssignToAbandonedMeat = function(gid, index, sid)
				SGroup_Clear(sg_single)
				deerCorpse_TempSGroup = SGroup_CreateUnique("sg_deercorpse")
				SGroup_Add(deerCorpse_TempSGroup, sid)
				UnitEntry_DeploySquads(player4, {sg_single, sg_meatcollection}, {type = "scar_villager", numSquads = 1}, mkr_village_04)
				LocalCommand_SquadSquad(player4, sg_single, SCMD_Gather, deerCorpse_TempSGroup, false)
				SGroup_RemoveGroup(sg_gaia_kulikovo, deerCorpse_TempSGroup)
				SGroup_Destroy(deerCorpse_TempSGroup)
			end
			SGroup_ForEach(sg_temp, _AssignToAbandonedMeat)
		end
	else
		Rule_RemoveMe()
	end
end

function Cleanup_MeatCollectors()
	if SGroup_CountSpawned(sg_meatcollection) > 0 then
		local _IfIdleCleanup = function(gid, index, sid)
			if Squad_IsIdle(sid) then
				SGroup_Clear(sg_single)
				SGroup_Single(sg_single, sid)
				Cmd_MoveToAndDestroy(sg_single, mkr_village_04)
			end
		end
		SGroup_ForEach(sg_meatcollection, _IfIdleCleanup)
	end
end