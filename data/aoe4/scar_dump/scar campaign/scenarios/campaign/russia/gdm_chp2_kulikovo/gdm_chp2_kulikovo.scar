function Mission_SetRestrictions()
	
	--Disable the player's popcap since they can't build their own units for use
	UI_SetPlayerDataContext(player1, {PopulationCapOn = false})
	
	PlayerUpgrades_Auto(player1)
	PlayerUpgrades_Auto(player2)
	PlayerUpgrades_Auto(player3)
	PlayerUpgrades_Auto(player4, nil, {UPG.COMMON.UPGRADE_UNIT_ARCHER_3, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_3})
	PlayerUpgrades_Auto(player5)
	
	PlayerUpgrades_LearnAllUnits(player1, AGE_CASTLE, {}, Player_GetRaceName(player1))
	
end -- Mission_SetRestrictions()

function Mission_Preset()
	
	PlayerColour_Enable()
	
	--Rus Player
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_2)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_SCOUT_FORESTER)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_UNIT_RELIGIOUS_HERBAL_MEDICINE_4)
	
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_UNIT_RELIGIOUS_PIETY_4, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_UNIT_RELIGIOUS_TITHE_BARN_4, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_MANATARMS_ELITE_ARMY_TACTICS, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_SPEARMAN_ELITE_SPEAR_TACTICS, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_SIEGE_ENGINEERS, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_TECH_MILITARY_ACADEMY, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_CAVALRY_GRAPERED_LANCE, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_CAVALRY_BARDING, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.RUS.UPGRADE_CAVALRY_HP_RUS, ITEM_REMOVED)
	
	--Mongol Enemy
	Player_CompleteUpgrade(player2, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_2)
	
	--Rus Ally
	Player_CompleteUpgrade(player3, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_2)
	Action_AddResources_Do({player = player3, resources = {food = 0, wood = 3000, gold = 0, stone = 0}})
	Player_SetStateModelBool(player3, "player_can_construct_structures", true)
	
	--Music related
	--Force Music play non-stop when music intensity is locked, allow music to play with silence system when music intensity is unlocked. 
	if Music_UnlockIntensity then
		Sound_SetForceMusic(false)
	else
		Sound_SetForceMusic(true)
	end

	Sound_SetMinimumMusicCombatIntensity(801, 0)
	
	--Intro Function Initialization
	Kulikovo_SpawnStartingUnits()
	--Kulikovo_SpawnVillagers()
	
end -- Mission_Preset()

function Mission_Start() -- This is triggered after the intro, just as control is passed to the player

	-- on console don't restore VPS as we have no villagers
	Cardinal_EnablePartialXboxUI(true, {VF_XboxUIVillagerPriorities})

	-- Setup references to useful modules
	--Ally modules
	ally_left = MissionOMatic_FindModule("ally_left")
	ally_center = MissionOMatic_FindModule("ally_center")
	ally_right = MissionOMatic_FindModule("ally_right")
	
	--Enemy modules
	
	--Village stuff
	--AssignVillagersToStone(sg_villagers_stone)
	
	-- Start the first objective
	Objective_Start(OBJ_PrepareArmy)
	Action_SetResources_Do({player = player1, resources = {food = 100, wood = 0, gold = 0, stone = 0}})
	
	Rule_AddInterval(Kulikovo_CheckPlayerArmyDead, 1)
	
	--Add hint points for map landmarks
	HintPoint_Add(mkr_don_river, true, "$11180220", 4, nil, nil, nil, true)
	HintPoint_Add(mkr_don_river_2, true, "$11189869", 4, nil, nil, nil, true)
	HintPoint_Add(mkr_don_river_3, true, "$11189869", 4, nil, nil, nil, true)
	HintPoint_Add(mkr_don_river_4, true, "$11189869", 4, nil, nil, nil, true)
	HintPoint_Add(mkr_don_river_5, true, "$11189869", 4, nil, nil, nil, true)
	HintPoint_Add(mkr_smolka_river, true, "$11189870", 4, nil, nil, nil, true)
	HintPoint_Add(mkr_smolka_river_2, true, "$11189870", 4, nil, nil, nil, true)
	HintPoint_Add(mkr_smolka_river_3, true, "$11189870", 4, nil, nil, nil, true)
	HintPoint_Add(mkr_smolka_river_4, true, "$11189870", 4, nil, nil, nil, true)
	HintPoint_Add(mkr_smolka_river_5, true, "$11189870", 4, nil, nil, nil, true)
	
	--Minor Hunting Polish
	Rule_AddInterval(CollectMeat_Kulikovo, 3)
	Rule_AddInterval(Cleanup_MeatCollectors, 5)
	
	MissionTutorial_AddHintToHuntingBounties()
	
end -- Mission_Start()

