	--SGroup_Kill(sg_village_04_army)
	--SGroup_Kill(sg_village_05_army)
	--SGroup_Kill(sg_village_06_army)
end --Kulikovo_DebugKillAllVillagers()

function Kulikovo_CheckPlayerArmyDead()
	Player_GetAll(player1)
	if SGroup_IsEmpty(sg_allsquads) then Mission_Fail() end
end

function Kulikovo_CheckPlayerIsWithinPopCap()
	Player_GetAll(player1, sg_player_units)
	assert(SGroup_CountSpawned(sg_player_units) <= 200, "The player has gone above population cap!")
end

------------------------------------------------------------------------------------------------------------------------------------------
--													STARTING VILLAGE MONGOL SPAWNING
------------------------------------------------------------------------------------------------------------------------------------------

function Mongol_OnStart()
	
	Rule_AddInterval(Mongol_SpawnVillageRaid, 0.5, {marker = mkr_village_02, radiusOffset = -5, spawn = mkr_mongol_raid_1})
	Rule_AddInterval(Mongol_SpawnVillageRaid, 0.5, {marker = mkr_village_03, radiusOffset = 20, spawn = mkr_mongol_raid_2})
	--Rule_AddInterval(Mongol_SpawnVillageRaid, 0.5, {marker = mkr_village_05, radiusOffset = 20, spawn = mkr_mongol_raid_2})
	
end --Mongol_OnStart()

function Mongol_SpawnVillageRaid(context, data)
	
	Player_GetAllSquadsNearMarker(player1, sg_temp, Util_GetPosition(data.marker), Marker_GetProximityRadiusOrDefault(data.marker, 0) + data.radiusOffset)
	if SGroup_CountSpawned(sg_temp) >= 1 then
		-- Spawn dem bad boys here
		local _units = {
			{sbp = SBP.MONGOL.UNIT_HORSEMAN_1_MON, numSquads = 8, spawn = data.spawn, difficulty = {GD_EASY, GD_NORMAL}},
			{sbp = SBP.MONGOL.UNIT_HORSEMAN_2_MON, numSquads = 8, spawn = data.spawn, difficulty = GD_HARD},
			{sbp = SBP.MONGOL.UNIT_HORSEARCHER_2_MON, numSquads = 6, spawn = data.spawn, difficulty = GD_HARD},
			{sbp = SBP.MONGOL.UNIT_KNIGHT_2_MON, numSquads = 6, spawn = data.spawn, difficulty = GD_EXPERT},
			{sbp = SBP.MONGOL.UNIT_HORSEARCHER_2_MON, numSquads = 9, spawn = data.spawn, difficulty = GD_EXPERT},
			
		}
		
		local attackModule = {
			type = "RovingArmy",
			descriptor = "RovingArmy_"..Marker_GetName(data.marker),
			player = player2,
			targets = { data.marker },
			targetingType = ARMY_TARGETING_DISCARD,
			units = _units,
			spawnLocation = data.spawn,
			onDeathDissolve = true,
		}
		
		RovingArmy_Init(attackModule)
		
		Rule_RemoveMe()
	end
	
end --Mongol_SpawnVillageRaid()

------------------------------------------------------------------------------------------------------------------------------------------
--														ALLY ROVING ARMY FUNCTIONS
------------------------------------------------------------------------------------------------------------------------------------------

function Kulikovo_MoveAll(marker_name)
	RovingArmy_SetTarget(ally_left, Marker_FromName(marker_name.."_left", ""))
	RovingArmy_SetTarget(ally_center, Marker_FromName(marker_name.."_center", ""))
	RovingArmy_SetTarget(ally_right, Marker_FromName(marker_name.."_right", ""))
end

function Kulikovo_SetQueuedMove(lane_name)
	RovingArmy_SetTargets(ally_left, {mkr_last_stand_left, mkr_mainline_left, mkr_ford_left})
end

