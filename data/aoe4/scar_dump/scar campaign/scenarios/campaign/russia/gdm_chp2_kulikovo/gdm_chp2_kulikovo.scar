--													      MISSION SETUP
------------------------------------------------------------------------------------------------------------------------------------------

function Mission_SetupPlayers()
	
	--
	-- get player IDs for each player
	-- 
	
	player1 = World_GetPlayerAt(1) -- Player
	player2 = World_GetPlayerAt(2) -- Mongols
	player3 = World_GetPlayerAt(3) -- Rus Principalities
	player4 = World_GetPlayerAt(4) -- Rus Villages
	player5 = World_GetPlayerAt(5) -- Neutral
	
	-- player 1 - Player
	Setup_SetPlayerName(player1, "$11176403") -- Moscow
	Player_SetCurrentAge(player1, AGE_CASTLE)
	Player_SetMaximumAge(player1, AGE_CASTLE)
	
	-- player 2 - Mongols
	Setup_SetPlayerName(player2, "$11176404") -- Golden Horde
	Player_SetCurrentAge(player2, AGE_FEUDAL)
	Player_SetMaximumAge(player2, AGE_FEUDAL)
	
	-- player 3 - Ally
	Setup_SetPlayerName(player3, "$11176405") -- Rus Allies
	Player_SetCurrentAge(player3, AGE_FEUDAL)
	Player_SetMaximumAge(player3, AGE_FEUDAL)
	
	-- player 4 - Cavalry
	Setup_SetPlayerName(player4, "$11176406") -- Rus Villages
	Player_SetCurrentAge(player4, AGE_CASTLE)
	Player_SetMaximumAge(player4, AGE_CASTLE)
	
	-- player 5 - Neutral
	Setup_SetPlayerName(player5, "$11176403") -- Neutral
	Player_SetCurrentAge(player5, AGE_FEUDAL)
	Player_SetMaximumAge(player5, AGE_FEUDAL)
	
	--
	-- set player relationships
	--
	
	Player_SetRelationship(player1, player3, R_ALLY) --RUS COALITION
	Player_SetRelationship(player1, player4, R_ALLY) --RUS COALITION
	Player_SetRelationship(player1, player5, R_ALLY) --RUS COALITION
	
	Player_SetRelationship(player2, player5, R_NEUTRAL) --NEUTRAL
	
	Player_SetRelationship(player3, player1, R_ALLY) --RUS COALITION
	Player_SetRelationship(player3, player4, R_ALLY)
	Player_SetRelationship(player3, player5, R_NEUTRAL)
	
	Player_SetRelationship(player4, player1, R_ALLY) --RUS COALITION
	Player_SetRelationship(player4, player3, R_ALLY)
	Player_SetRelationship(player4, player5, R_NEUTRAL)
	
	
	Player_SetRelationship(player5, player1, R_ALLY) --RUS COALITION
	Player_SetRelationship(player5, player2, R_NEUTRAL) --NEUTRAL
	Player_SetRelationship(player5, player3, R_NEUTRAL)
	Player_SetRelationship(player5, player4, R_NEUTRAL)
	
	
	World_EnableSharedLineOfSight(player1, player3, true)
	World_EnableSharedLineOfSight(player3, player1, true)
	
	World_EnableSharedLineOfSight(player1, player4, false)
	World_EnableSharedLineOfSight(player3, player4, false)
	World_EnableSharedLineOfSight(player4, player1, false)
	World_EnableSharedLineOfSight(player4, player3, false)
	
	World_EnableSharedLineOfSight(player1, player5, false)
	World_EnableSharedLineOfSight(player5, player1, false)
	
	--
	-- Set Player Colours
	--
	
	PlayerColour_Enable()								--Turn on custom colour configuration for this session
	
	Game_SetPlayerSlotColour(player1, 1)			--Paint Scheme
	Game_SetPlayerUISlotColour(player1, 1)		--UI Colour
	
	Game_SetPlayerSlotColour(player2, 2)			--Paint Scheme
	Game_SetPlayerUISlotColour(player2, 2)		--UI Colour
	
	Game_SetPlayerSlotColour(player3, 3)			--Paint Scheme
	Game_SetPlayerUISlotColour(player3, 3)		--UI Colour
	
	Game_SetPlayerSlotColour(player4, 3)			--Paint Scheme
	Game_SetPlayerUISlotColour(player4, 3)		--UI Colour
	
	Game_SetPlayerSlotColour(player5, 1)	--Paint Scheme
	Game_SetPlayerUISlotColour(player5, 1)--UI Colour
	
end -- Mission_SetupPlayers()

