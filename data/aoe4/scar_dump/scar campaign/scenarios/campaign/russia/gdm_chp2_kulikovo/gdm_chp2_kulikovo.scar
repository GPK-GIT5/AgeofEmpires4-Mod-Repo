--														INTRO / OUTRO SEQUENCES
------------------------------------------------------------------------------------------------------------------------------------------

function Kulikovo_SpawnStartingUnits()
	
	--Spawning and moving left group of Knights
	UnitEntry_DeploySquads(player1, sg_player_knights_1, { sbp = SBP.RUS.UNIT_KNIGHT_2_RUS, numSquads = 7}, mkr_intro_start_1)
	Cmd_FormationMove(sg_player_knights_1, mkr_intro_cav_1, false, false, Util_GetFacingFromDirection(Marker_GetPosition(mkr_intro_cav_1), Marker_GetDirection(mkr_intro_cav_1)))
	
	--Spawning and moving right group of Knights
	UnitEntry_DeploySquads(player1, sg_player_knights_2, { sbp = SBP.RUS.UNIT_KNIGHT_2_RUS, numSquads = 7}, mkr_intro_start_3)
	Cmd_FormationMove(sg_player_knights_2, mkr_intro_cav_2, false, false, Util_GetFacingFromDirection(Marker_GetPosition(mkr_intro_cav_2), Marker_GetDirection(mkr_intro_cav_2)))
	
	--Spawning infantry
	local infantry = {
		{type = "scar_manatarms", numSquads = 24, spawn = mkr_player_crossbows, destination = mkr_player_manatarms, sgroup = sg_player_menatarms},
		{type = "scar_crossbowman", numSquads = 24, spawn = mkr_intro_start_2, destination = mkr_player_crossbows, sgroup = sg_player_crossbowmen},
	}
	UnitEntry_DeploySquads(player1, sg_player_infantry, infantry)
	
	--Spawning scouts
	UnitEntry_DeploySquads(player1, sg_player_scout_1, { type = "scar_scout", numSquads = 1}, mkr_intro_scout_1)
	UnitEntry_DeploySquads(player1, sg_player_scout_2, { type = "scar_scout", numSquads = 1}, mkr_intro_scout_2)
	UnitEntry_DeploySquads(player1, sg_player_scout_3, { type = "scar_scout", numSquads = 1}, mkr_intro_scout_3)
	
	-- Spawn escort
	UnitEntry_DeploySquads(player1, sg_player_escort, { type = "scar_monk", numSquads = 2}, mkr_intro_escort_start)
	
	local function __MoveToStart (sgroup, destination)
		Cmd_FormationMove(sgroup, mkr_intro_start_4a, true)
		Cmd_FormationMove(sgroup, mkr_intro_start_4b, true)
		Cmd_FormationMove(sgroup, mkr_intro_start_4c, true)
		Cmd_FormationMove(sgroup, mkr_intro_start_4d, true)
		Cmd_FormationMove(sgroup, mkr_intro_start_4e, true)
		Cmd_FormationMove(sgroup, destination, true, false, Util_GetFacingFromDirection(Marker_GetPosition(destination), Marker_GetDirection(destination)))
	end
	
	__MoveToStart (sg_leaderDmitry.sgroup, mkr_player_prince_1)
	__MoveToStart (sg_player_escort, mkr_player_escort)
	
	intro_MonkSpeed_Mod = Modify_UnitSpeed(sg_player_escort, 1)
	
	sg_scout_left = SGroup_CreateIfNotFound("sg_scout_left")
	sg_scout_center = SGroup_CreateIfNotFound("sg_scout_center")
	sg_scout_right = SGroup_CreateIfNotFound("sg_scout_right")
	
	UnitEntry_DeploySquads(player4, sg_scout_left, laning_starting_group, mkr_ally_left_idle)
	UnitEntry_DeploySquads(player4, sg_scout_center, laning_starting_group, mkr_ally_center_idle)
	UnitEntry_DeploySquads(player4, sg_scout_right, laning_starting_group, mkr_ally_right_idle)
	
end --Kulikovo_SpawnStartingUnits()

function Kulikovo_SpawnVillagers()
	UnitEntry_DeploySquads(player4, sg_villagers_food, {type = "scar_villager", numSquads = 8, spawn = mkr_townlife_1})
	UnitEntry_DeploySquads(player4, sg_villagers_wood, {type = "scar_villager", numSquads = 6, spawn = mkr_townlife_2})
	UnitEntry_DeploySquads(player4, sg_villagers_stone, {type = "scar_villager", numSquads = 4, spawn = mkr_townlife_3})
	AssignVillagersToFarms(sg_villagers_food)
	AssignVillagersToWood(sg_villagers_wood)
	AssignVillagersToStone(sg_villagers_stone)
end

function Kulikovo_SkippedIntro()
	
	SGroup_FormationWarpToMarker(sg_player_knights_1, mkr_intro_cav_1)
	SGroup_FormationWarpToMarker(sg_player_knights_2, mkr_intro_cav_2)
	
	SGroup_FormationWarpToMarker(sg_player_menatarms, mkr_player_manatarms)
	SGroup_FormationWarpToMarker(sg_player_crossbowmen, mkr_player_crossbows)
	
	SGroup_FormationWarpToMarker(sg_leaderDmitry.sgroup, mkr_player_prince_1)
	SGroup_FormationWarpToMarker(sg_player_escort, mkr_player_escort)
	
	SGroup_FormationWarpToMarker(sg_player_scout_1, mkr_intro_scout_1)
	SGroup_FormationWarpToMarker(sg_player_scout_2, mkr_intro_scout_2)
	SGroup_FormationWarpToMarker(sg_player_scout_3, mkr_intro_scout_3)
	
end

