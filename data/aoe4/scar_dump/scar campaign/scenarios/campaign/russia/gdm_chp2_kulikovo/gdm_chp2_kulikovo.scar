------------------------------------------------------------------------------------------------------------------------------------------
--														 SUPPORT FUNCTIONS
------------------------------------------------------------------------------------------------------------------------------------------

function Kulikovo_TransitionToEvening()
	Game_TransitionToState("night", 120)
end --Kulikovo_TransitionToEvening()

function Kulikovo_IncrementWave() 
	--Updates completed wave, which ties into how much a player is rewarded if they hold for a reasonable amount of time
	current_wave = current_wave + 1
end --Kulikovo_IncrementWave()

function Kulikovo_CountMarker(player, marker)
	Player_GetAllSquadsNearMarker(player, sg_temp, marker)
	return SGroup_CountSpawned(sg_temp)
end

--Cheating functions to skip ahead

function Skip()
	sg_dmitry = SGroup_CreateIfNotFound("sg_dmitry")
	Player_GetAll(player1)
	SGroup_Filter(sg_allsquads, SBP.RUS.UNIT_PRINCE_DMITRI_CMP_RUS, FILTER_REMOVE, sg_dmitry)
	
	Rule_AddOneShot(_SkipWarp, 1, {marker = mkr_ally_left_idle})
	Rule_AddOneShot(_SkipWarp, 2, {marker = mkr_ally_center_idle})
	Rule_AddOneShot(_SkipWarp, 3, {marker = mkr_ally_right_idle})
	
	Objective_Complete(SOBJ_VisitVillages)
end

function _SkipWarp(context, data)
	if data.marker ~= nil then
		SGroup_WarpToMarker(sg_dmitry, data.marker)
	else
		assert(data.marker, "Marker is nil")
	end
end

function Warp_Fords()
	Player_GetAll(player1)
	SGroup_WarpToMarker(sg_allsquads, mkr_ford_center)
	SGroup_WarpToMarker(sg_ally_left, mkr_ford_left)
	SGroup_WarpToMarker(sg_ally_center, mkr_ford_center)
	SGroup_WarpToMarker(sg_ally_right, mkr_ford_right)
end

function Warp_Hill()
	Player_GetAll(player1)
	SGroup_WarpToMarker(sg_allsquads, mkr_mainline_center)
	SGroup_WarpToMarker(sg_ally_left, mkr_mainline_left)
	SGroup_WarpToMarker(sg_ally_center, mkr_mainline_center)
	SGroup_WarpToMarker(sg_ally_right, mkr_mainline_right)
end

function Warp_Don()
	Player_GetAll(player1)
	SGroup_WarpToMarker(sg_allsquads, mkr_last_stand_center)
	SGroup_WarpToMarker(sg_ally_left, mkr_last_stand_left)
	SGroup_WarpToMarker(sg_ally_center, mkr_last_stand_center)
	SGroup_WarpToMarker(sg_ally_right, mkr_last_stand_right)
end

-- Spawning reinforcements for players
function Support_SpawnMainlineReinforcements()
	
	unspawned_mainline_count = 0
	mainline_reinforcement_units = {}
	Kulikovo_AddToSpawnTable({type = "scar_spearman", numSquads = 8, spawn = mkr_village_03, destination = mkr_mainline_reinforcement}, mainline_reinforcement_units, true)
	Kulikovo_AddToSpawnTable({type = "scar_manatarms", numSquads = 8, spawn = mkr_village_03, destination = mkr_mainline_reinforcement}, mainline_reinforcement_units, true)
	Kulikovo_AddToSpawnTable({type = "scar_manatarms", numSquads = 8, spawn = mkr_village_03, destination = mkr_mainline_reinforcement}, mainline_reinforcement_units, true)
	Kulikovo_AddToSpawnTable({type = "scar_crossbowman", numSquads = 8, spawn = mkr_village_03, destination = mkr_mainline_reinforcement}, mainline_reinforcement_units, true)
	Kulikovo_AddToSpawnTable({type = "scar_knight", numSquads = 4, spawn = mkr_village_03, destination = mkr_mainline_reinforcement}, mainline_reinforcement_units, true)
	Kulikovo_AddToSpawnTable({type = "scar_monk", numSquads = 4, spawn = mkr_village_03, destination = mkr_mainline_reinforcement}, mainline_reinforcement_units, true)
	
	sg_mainline_reinforcements = SGroup_CreateIfNotFound("sg_mainline_reinforcements")
	UnitEntry_DeploySquads(player1, sg_mainline_reinforcements, mainline_reinforcement_units)

end
function Support_SpawnLastlineReinforcements()

	unspawned_lastline_count = 0
	lastline_reinforcement_units = {}
	Kulikovo_AddToSpawnTable({type = "scar_spearman", numSquads = 8, spawn = mkr_village_03, destination = mkr_last_stand_reinforcement}, lastline_reinforcement_units, false)
	Kulikovo_AddToSpawnTable({type = "scar_manatarms", numSquads = 8, spawn = mkr_village_03, destination = mkr_last_stand_reinforcement}, lastline_reinforcement_units, false)
	Kulikovo_AddToSpawnTable({type = "scar_manatarms", numSquads = 8, spawn = mkr_village_03, destination = mkr_last_stand_reinforcement}, lastline_reinforcement_units, false)
	Kulikovo_AddToSpawnTable({type = "scar_crossbowman", numSquads = 8, spawn = mkr_village_03, destination = mkr_last_stand_reinforcement}, lastline_reinforcement_units, false)
	Kulikovo_AddToSpawnTable({type = "scar_knight", numSquads = 8, spawn = mkr_village_03, destination = mkr_last_stand_reinforcement}, lastline_reinforcement_units, false)
	Kulikovo_AddToSpawnTable({type = "scar_monk", numSquads = 8, spawn = mkr_village_03, destination = mkr_last_stand_reinforcement}, lastline_reinforcement_units, false)
	
	sg_lastline_reinforcements = SGroup_CreateIfNotFound("sg_lastline_reinforcements")
	UnitEntry_DeploySquads(player1, sg_lastline_reinforcements, lastline_reinforcement_units)
	
end
function Kulikovo_SpawnWithinPopcap(scarType, _numSquads, _destination)
	if SGroup_CountSpawned(sg_player_units) <= (200 - _numSquads) then 
		UnitEntry_DeploySquads(player1, sg_player_units, {type = scarType, numSquads = _numSquads, destination = _destination}, mkr_village_03) 
	else print("Can't spawn "..scarType.." to reinforce "..Marker_GetName(_destination).." as the player would exceed pop cap") end
end

function Kulikovo_AddToSpawnTable(units, destinationUnitTable, isMainline) -- Checks if there's room to add these units to the table
	
	--Get the previously unspawned amount of units
	local unspawned_count = 0
	if isMainline then
		unspawned_count = unspawned_mainline_count
	else
		unspawned_count = unspawned_lastline_count
	end
	
	--Check if there's room for this iteration of units
	Player_GetAll(player1, sg_player_units)
	if (SGroup_CountSpawned(sg_player_units) + unspawned_count) <= (200 - units.numSquads) then
		table.insert(destinationUnitTable, units)
		unspawned_count = unspawned_count + units.numSquads
	end
	
	--Update the new unspawned amount of units
	if isMainline then
		unspawned_mainline_count = unspawned_count
	else
		unspawned_lastline_count = unspawned_count
	end
	
end

function Kulikovo_RefillAmount()
	Player_GetAll(player1)
		SGroup_Filter(sg_allsquads, SBP.RUS.UNIT_MONK_3_RUS, FILTER_KEEP)
		return playerMaxUnits.monk - SGroup_CountSpawned(sg_allsquads)
end

function Kulikovo_DebugKillAllVillagers()
	SGroup_Kill(sg_village_01_army)
	SGroup_Kill(sg_village_02_army)
