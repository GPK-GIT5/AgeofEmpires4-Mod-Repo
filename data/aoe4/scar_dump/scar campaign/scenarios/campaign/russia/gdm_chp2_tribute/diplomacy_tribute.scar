							<!--  "Tax (%1TAX_PERCENT:.0%%%): %2TAX_AMOUNT%"  -->
							<MultiBinding Converter="{StaticResource LocalizedStringMultiConverter}" ConverterParameter="$11164617">
								<Binding Path="[tax_rate]" />
								<Binding Path="[total_taxes][amount]" />
							</MultiBinding>
						</TextBlock.Text>
					</TextBlock>
					<TextBlock Grid.Column="1"
							   HorizontalAlignment="Left" VerticalAlignment="Center"
							   Style="{StaticResource HUDWhiteBodyTextBlock18ptStyle}"
							   Text="{Binding [total_cost][amount], Converter={StaticResource LocalizedStringConverter}, ConverterParameter=$11164618}"
							   TextAlignment="Left" />
				</Grid>
				<!--  Buttons  -->
				<StackPanel Grid.Row="4" Grid.Column="2"
							Margin="0,6,16,8" HorizontalAlignment="Right"
							Orientation="Horizontal"
							Visibility="{Binding [is_tribute_enabled], Converter={StaticResource BoolToVis}}">
					<!--  Send button  -->
					<Button Height="28"
							MinWidth="95"
							utility:AudioAttachedProperty.PreviewMouseLeftButtonUpSound="sfx_ui_hud_inGame_tribute_send_play"
							Command="{Binding [command][send_tribute]}"
							Content="{Binding [text][send_button]}"
							Style="{StaticResource HUDPrimaryRaisedTextButton}" />
					<!--  Clear button  -->
					<Button Height="28"
							MinWidth="95"
							Margin="8,0,0,0"
							utility:AudioAttachedProperty.PreviewMouseLeftButtonUpSound="sfx_ui_hud_inGame_tribute_clear_play"
							Command="{Binding [command][clear_tribute]}"
							Content="{Binding [text][clear_button]}"
							Style="{StaticResource HUDPrimaryRaisedTextButton}" />
				</StackPanel>
				<!--  Header  -->
				<ContentControl Grid.Row="5" Grid.Column="0"
								Grid.ColumnSpan="2"
								Visibility="{Binding [buySettlements][Visible], Converter={StaticResource BoolToVis}}">
					<StackPanel>
						<Separator Grid.Row="1"
								   HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
								   Style="{StaticResource PrimarySeperatorStyle}" />
						<TextBlock Margin="0,6" HorizontalAlignment="Center"
								   Style="{StaticResource HUDPrimaryColorGradientVerticalSubtitleTextBlock14ptNoShadowStyle}"
								   Text="{utility:LocString $11180283}" />
					</StackPanel>
				</ContentControl>
				<!--  Settlements list  -->
				<ItemsControl Grid.Row="6" Grid.Column="0"
							  Grid.ColumnSpan="2"
							  Margin="8,0"
							  ItemsSource="{Binding [buySettlements][Settlements]}"
							  Visibility="{Binding [buySettlements][Visible], Converter={StaticResource BoolToVis}}">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Grid Margin="0,0,0,2">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>
								<!--  Settlement  -->
								<StackPanel Grid.Column="0"
											Margin="0,0,4,0" HorizontalAlignment="Left"
											Orientation="Horizontal">
									<!--  Camera Look button  -->
									<Button Width="28" Height="28"
											Margin="4,0,0,0" HorizontalContentAlignment="Center"
											Command="{Binding [ViewButtonCommand]}"
											CommandParameter="{Binding [SettlementID]}"
											Style="{StaticResource ResourceButtonStyle}"
											ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="86400000"
											ToolTipService.ShowOnDisabled="True">
										<Image Source="pack://application:,,,/WPFGUI;component/icons/cinematic_mode.png" />
										<Button.ToolTip>
											<ToolTip Content="{Binding}"
													 DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
													 Placement="Left"
													 Style="{StaticResource TributeToolTipStyle}">
												<ToolTip.ContentTemplate>
													<DataTemplate>
														<ContentControl Width="{StaticResource HUDTooltipMaxWidthSmall}" Style="{StaticResource HUDTooltipBorderStyle}">
															<Grid>
																<Grid.ColumnDefinitions>
																	<ColumnDefinition Width="{StaticResource HUDTooltipGutterWidthGridLength}" />
																	<ColumnDefinition Width="*" />
																</Grid.ColumnDefinitions>
																<StackPanel Grid.Column="1" Orientation="Vertical">
																	<TextBlock Style="{StaticResource HUDPrimaryColorLightTitleTextBlock18ptStyle}" Text="{Binding [Name], Converter={StaticResource LocalizedStringConverter}, ConverterParameter=$11183276}" />
																	<Grid HorizontalAlignment="Left">
																		<Border Background="{StaticResource ButtonBackgroundBrush}" Opacity="0.5" />
																		<TextBlock Margin="6,2,7,2"
																				   Style="{StaticResource HUDWhiteBaseTextBlock14ptStyle}"
																				   Text="{utility:LocString $11164338}"
																				   TextWrapping="Wrap" />
																	</Grid>
																	<TextBlock Margin="{StaticResource SmallMarginTop}"
																			   Style="{StaticResource HUDGray80ParagraphTextBlock14ptStyle}"
																			   Text="{utility:LocString $11183277}" />
																</StackPanel>
															</Grid>
														</ContentControl>
													</DataTemplate>
												</ToolTip.ContentTemplate>
											</ToolTip>
										</Button.ToolTip>
									</Button>
									<!--  Name  -->
									<TextBlock Width="250"
											   Margin="8,0,0,0" HorizontalAlignment="Left"
											   VerticalAlignment="Center"
											   Foreground="{Binding [PlayerColour]}"
											   Style="{StaticResource HUDParentBaseTextBlock18ptStyle}"
											   Text="{Binding [Name]}" />
								</StackPanel>
								<!--  Trade Progress  -->
								<StackPanel Grid.Column="1"
											Margin="0,0,4,0" HorizontalAlignment="Right"
											Orientation="Horizontal"
											Visibility="{Binding [BuyButtonVisible], Converter={StaticResource BoolToVis}}">
									<Grid Width="125"
										  Margin="0,0,8,0" VerticalAlignment="Center">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="Auto" />
											<ColumnDefinition Width="*" />
										</Grid.ColumnDefinitions>
										<Grid.RowDefinitions>
											<RowDefinition Height="Auto" />
											<RowDefinition Height="Auto" />
										</Grid.RowDefinitions>
										<StackPanel Grid.Row="0" Grid.Column="0"
													HorizontalAlignment="Left" VerticalAlignment="Bottom"
													Orientation="Horizontal">
											<TextBlock VerticalAlignment="Bottom"
													   Style="{StaticResource HUDGray80BodyTextBlock14ptStyle}"
													   Text="{Binding [TradeAmount], Converter={StaticResource LocalizedStringConverter}, ConverterParameter=$11183982}" />
											<Image Height="18" Source="pack://application:,,,/WPFGUI;component/icons/resources/resource_gold_icon.png" />
											<TextBlock VerticalAlignment="Bottom"
													   Style="{StaticResource HUDGray80BodyTextBlock14ptStyle}"
													   Text="{Binding [TradeGoal]}" />
										</StackPanel>
										<StackPanel Grid.Row="0" Grid.Column="1"
													HorizontalAlignment="Right" VerticalAlignment="Bottom"
													Orientation="Horizontal">
											<Image Height="18" Source="pack://application:,,,/WPFGUI;component/icons/races/common/units/trade_cart.png" />
											<TextBlock VerticalAlignment="Bottom"
													   Style="{StaticResource HUDGray80BodyTextBlock14ptStyle}"
													   Text="{Binding [TradersAssigned]}" />
											<StackPanel.Style>
												<Style TargetType="StackPanel">
													<Setter Property="Opacity" Value="1" />
													<Style.Triggers>
														<DataTrigger Binding="{Binding [TradersAssigned]}" Value="0">
															<Setter Property="Opacity" Value="0.3" />
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</StackPanel.Style>
										</StackPanel>
										<ProgressBar Grid.Row="2" Grid.Column="0"
													 Grid.ColumnSpan="2"
													 Height="4"
													 VerticalAlignment="Top"
													 Maximum="{Binding [TradeGoal]}"
													 Minimum="0"
													 Style="{StaticResource VictoryConditionProgressbarStyle}"
													 Value="{Binding [TradeAmount]}" />
									</Grid>
									<!--  Buy Button  -->
									<Button Width="76"
											Height="28"
											HorizontalContentAlignment="Center"
											Command="{Binding [BuyButtonCommand]}"
											CommandParameter="{Binding [SettlementID]}"
											Content="{utility:LocString $11183278}"
											IsEnabled="{Binding [BuyButtonEnabled]}"
											Style="{StaticResource HUDPrimaryRaisedTextButton}"
											ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="86400000"
											ToolTipService.ShowOnDisabled="True">
										<Button.ToolTip>
											<ToolTip Content="{Binding}"
													 DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
													 Placement="Left"
													 Style="{StaticResource TributeToolTipStyle}">
												<ToolTip.ContentTemplate>
													<DataTemplate>
														<ContentControl Width="{StaticResource HUDTooltipMaxWidthSmall}" Style="{StaticResource HUDTooltipBorderStyle}">
															<Grid>
																<Grid.ColumnDefinitions>
																	<ColumnDefinition Width="{StaticResource HUDTooltipGutterWidthGridLength}" />
																	<ColumnDefinition Width="*" />
																</Grid.ColumnDefinitions>
																<StackPanel Grid.Column="1" Orientation="Vertical">
																	<TextBlock Style="{StaticResource HUDPrimaryColorLightTitleTextBlock18ptStyle}" Text="{Binding [Name], Converter={StaticResource LocalizedStringConverter}, ConverterParameter=$11180288}" />
																	<Grid HorizontalAlignment="Left">
																		<Border Background="{StaticResource ButtonBackgroundBrush}" Opacity="0.5" />
																		<TextBlock Margin="6,2,7,2"
																				   Style="{StaticResource HUDWhiteBaseTextBlock14ptStyle}"
																				   Text="{utility:LocString $11164338}"
																				   TextWrapping="Wrap" />
																	</Grid>
																	<TextBlock Margin="{StaticResource SmallMarginTop}"
																			   VerticalAlignment="Center"
																			   Style="{StaticResource HUDGray80ParagraphTextBlock14ptStyle}"
																			   Text="{Binding [IncomeAmount], Converter={StaticResource LocalizedStringConverter}, ConverterParameter=$11180286}"
																			   TextWrapping="Wrap" />
																	<StackPanel Margin="0,10,0,0" VerticalAlignment="Center"
																				Orientation="Horizontal">
																		<Image Height="20">
																			<Image.Style>
																				<Style TargetType="Image">
																					<Setter Property="Source" Value="pack://application:,,,/WPFGUI;component/icons/resources/resource_gold_icon.png" />
																					<Style.Triggers>
																						<DataTrigger Binding="{Binding [BuyButtonPlayerHasEnoughGold]}" Value="false">
																							<Setter Property="Source" Value="pack://application:,,,/WPFGUI;component/icons/resources/resource_gold_icon_insufficient.png" />
																						</DataTrigger>
																					</Style.Triggers>
																				</Style>
																			</Image.Style>
																		</Image>
																		<TextBlock Margin="4,0,0,0" Text="{Binding [BuyButtonPrice]}">
																			<TextBlock.Style>
																				<Style BasedOn="{StaticResource HUDParentParagraphTextBlock14ptStyle}" TargetType="TextBlock">
																					<Setter Property="Foreground" Value="White" />
																					<Style.Triggers>
																						<DataTrigger Binding="{Binding [BuyButtonPlayerHasEnoughGold]}" Value="false">
																							<Setter Property="Foreground" Value="{StaticResource ErrorColorLightBrush}" />
																						</DataTrigger>
																					</Style.Triggers>
																				</Style>
																			</TextBlock.Style>
																		</TextBlock>
																	</StackPanel>
																	<TextBlock Margin="{StaticResource SmallMarginTop}"
																			   Style="{StaticResource HUDErrorColorLightParagraphTextBlock14ptStyle}"
																			   Text="{Binding [BuyButtonDisabledReason]}" />
																</StackPanel>
															</Grid>
														</ContentControl>
													</DataTemplate>
												</ToolTip.ContentTemplate>
											</ToolTip>
										</Button.ToolTip>
									</Button>
								</StackPanel>
								<!--  Bought Settlements Income Amount  -->
								<StackPanel Grid.Column="1"
											Margin="0,0,4,0" HorizontalAlignment="Right"
											Orientation="Horizontal"
											Visibility="{Binding [IncomeVisible], Converter={StaticResource BoolToVis}}">
									<TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
											   Style="{StaticResource HUDGray80BodyTextBlock18ptStyle}"
											   Text="{Binding [IncomeAmount], Converter={StaticResource LocalizedStringConverter}, ConverterParameter=$11183419}" />
									<Image Height="20" Source="pack://application:,,,/WPFGUI;component/icons/resources/resource_gold_icon.png" />
									<TextBlock Margin="0,0,8,0" HorizontalAlignment="Left"
											   VerticalAlignment="Center"
											   Style="{StaticResource HUDGray80BodyTextBlock18ptStyle}"
											   Text="{utility:LocString $11183420}" />
									<Image Height="28"
										   HorizontalAlignment="Center"
										   Source="pack://application:,,,/WPFGUI;component/icons/objectives/objective_complete.png" />
								</StackPanel>
								<!--  Destroyed Settlement  -->
								<StackPanel Grid.Column="1"
											Margin="0,0,4,0" HorizontalAlignment="Right"
											Orientation="Horizontal"
											Visibility="{Binding [DestroyedSettlementVisible], Converter={StaticResource BoolToVis}}">
									<TextBlock Margin="0,0,8,0" HorizontalAlignment="Right"
											   VerticalAlignment="Center"
											   Style="{StaticResource HUDGray80BodyTextBlock18ptStyle}"
											   Text="{utility:LocString $11192362}" />
									<Image Height="28"
										   HorizontalAlignment="Center"
										   Source="pack://application:,,,/WPFGUI;component/icons/objectives/objective_complete.png" />
								</StackPanel>
							</Grid>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
				<!--  Total income  -->
				<ContentControl Grid.Row="7" Grid.Column="0"
								Grid.ColumnSpan="2">
					<StackPanel Margin="10,6,16,4" HorizontalAlignment="Left"
								Orientation="Horizontal"
								Visibility="{Binding [buySettlements][TotalIncomeVisible], Converter={StaticResource BoolToVis}}">
						<TextBlock Margin="0,0,8,0" HorizontalAlignment="Left"
								   VerticalAlignment="Center"
								   Style="{StaticResource HUDWhiteBaseTextBlock18ptStyle}"
								   Text="{utility:LocString $11180306}" />
						<TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
								   Style="{StaticResource HUDWhiteBaseTextBlock18ptStyle}"
								   Text="{Binding [buySettlements][TotalIncomeAmount], Converter={StaticResource LocalizedStringConverter}, ConverterParameter=$11183419}" />
						<Image Height="20" Source="pack://application:,,,/WPFGUI;component/icons/resources/resource_gold_icon.png" />
						<TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
								   Style="{StaticResource HUDWhiteBaseTextBlock18ptStyle}"
								   Text="{utility:LocString $11183420}" />
					</StackPanel>
				</ContentControl>
				<!--  Blurb  -->
				<ContentControl Grid.Row="8" Grid.Column="0"
								Grid.ColumnSpan="2">
					<TextBlock Margin="10,6"
							   Style="{StaticResource HUDGray80BodyTextBlock18ptStyle}"
							   Text="{Binding [buySettlements][TradeGoal], Converter={StaticResource LocalizedStringConverter}, ConverterParameter=$11180282}"
							   TextWrapping="Wrap"
							   Visibility="{Binding [buySettlements][Visible], Converter={StaticResource BoolToVis}}" />
				</ContentControl>
			</Grid>
		</ContentControl>
	</ContentControl>
</Grid>]]
		
		UI_AddChild("", "XamlPresenter", "DiplomacyUI", { IsHitTestVisible = true, Xaml = Xaml, DataContext = UI_CreateDataContext(_diplomacy.data_context) })		
		UI_AddCommandBinding("hud_game", "toggle_diplomacy_panel", "Diplomacy_ToggleDiplomacyUI")
		_diplomacy.is_ui_created = true
	end
end

function Diplomacy_RemoveUI()
	if _diplomacy ~= nil then
		UI_RemoveCommandBinding("hud_game", "toggle_diplomacy_panel")
		UI_Remove("DiplomacyUI")
		_diplomacy.is_ui_created = false
	end
end

function Diplomacy_UpdateUI()
	-- UI_SetDataContext() is expensive so only call it once per frame (e.g. score changes when >1 squads die in a frame)
	if not Rule_Exists(Rule_Diplomacy_UpdateUI) then
		Rule_AddOneShot(Rule_Diplomacy_UpdateUI, 0.125)
	end
end

function Rule_Diplomacy_UpdateUI()		 			
	if _diplomacy ~= nil and _diplomacy.is_ui_created then 
		UI_SetDataContext("DiplomacyUI", _diplomacy.data_context)
	end
end

-- TEMP: For UI testing 
function Diplomacy_Restart()
	Diplomacy_RemoveUI()
	Diplomacy_CreateUI()
	Diplomacy_UpdateDataContext()
end


function Diplomacy_ShowEventCue(tribute)
	
	local cue = _diplomacy.cue
	
	if tribute.food > 0 then 
		local text = Loc_FormatText(11161258, tribute.food, Player_GetDisplayName(tribute.sender.id))		-- "%1AMOUNT% food received from %2PLAYER_NAME%"
		UI_CreateEventCueClickable(-1, cue.lifetime, 0, cue.repeatTime, text, cue.desc, cue.template, cue.icon, cue.sfx, cue.color.r, cue.color.g, cue.color.b, cue.color.a, cue.style, nothing)
	end
	if tribute.wood > 0 then 
		local text = Loc_FormatText(11161259, tribute.wood, Player_GetDisplayName(tribute.sender.id))		-- "%1AMOUNT% wood received from %2PLAYER_NAME%"
		UI_CreateEventCueClickable(-1, cue.lifetime, 0, cue.repeatTime, text, cue.desc, cue.template, cue.icon, cue.sfx, cue.color.r, cue.color.g, cue.color.b, cue.color.a, cue.style, nothing)
	end
	if tribute.stone > 0 then 
		local text = Loc_FormatText(11161260, tribute.stone, Player_GetDisplayName(tribute.sender.id))	-- "%1AMOUNT% stone received from %2PLAYER_NAME%"
		UI_CreateEventCueClickable(-1, cue.lifetime, 0, cue.repeatTime, text, cue.desc, cue.template, cue.icon, cue.sfx, cue.color.r, cue.color.g, cue.color.b, cue.color.a, cue.style, nothing)
	end
	if tribute.gold > 0 then 
		local text = Loc_FormatText(11161261, tribute.gold, Player_GetDisplayName(tribute.sender.id))		-- "%1AMOUNT% gold received from %2PLAYER_NAME%"
		UI_CreateEventCueClickable(-1, cue.lifetime, 0, cue.repeatTime, text, cue.desc, cue.template, cue.icon, cue.sfx, cue.color.r, cue.color.g, cue.color.b, cue.color.a, cue.style, nothing)
	end	
end


-----------------------------------------------------------------------
-- Network functions
-----------------------------------------------------------------------

--[[
function Diplomacy_ChangeRelationNtw(playerID, data)  

	-- Expected format of data parameter is: observerPlayerID,targetPlayerID,relationAsAnInt
	local parts = string.split(data)
	local observerPlayer = Core_GetPlayersTableEntry(playerID)
 	local targetPlayer = Core_GetPlayersTableEntryFromIndex(tonumber(parts[1]))
	local relation = Diplomacy_RelationConverter(tonumber(parts[2]))
	
	if Player_ObserveRelationship(playerID, targetPlayer.id) ~= relation then 
		Player_SetRelationship(playerID, targetPlayer.id, relation)								
		Core_CallDelegateFunctions("OnRelationshipChanged", playerID, targetPlayer.id)		-- HACK: Player_SetRelationship() needs to trigger a global event (GE_RelationChanged)
	end
end
]]

function Diplomacy_SendTributeNtw(playerID, data)
	
	local sender = Core_GetPlayersTableEntry(playerID)
	local tax_rate = Diplomacy_GetTaxRate(playerID)	
	local tribute_data = {}
	local chunks = string.split(data ,"|")	
	
	-- Returns tribute amount after withholding tax has been applied.
	local EffectiveTribute = function(amount)
		return  math.floor(amount * (1.0 + tax_rate))
	end
	
	for i = 1, #chunks do 
		local parts = string.split(chunks[i])
		if #parts == 5 then 
			local receiver = Core_GetPlayersTableEntryFromIndex(tonumber(parts[5]))
			local tribute = {
				food = tonumber(parts[1]),
				wood = tonumber(parts[2]),
				gold = tonumber(parts[3]),
				stone = tonumber(parts[4]),				
				sender = sender,		
				receiver = receiver,
				tax_rate = tax_rate,
			}		
			table.insert(tribute_data, tribute)
						
			if tribute.food > 0 then 
				Player_AddResource(receiver.id, RT_Food, tribute.food)
				Player_AddResource(sender.id, RT_Food, -EffectiveTribute(tribute.food))
			end
			if tribute.wood > 0 then 
				Player_AddResource(receiver.id, RT_Wood, tribute.wood)
				Player_AddResource(sender.id, RT_Wood, -EffectiveTribute(tribute.wood))
			end
			if tribute.gold > 0 then 
				Player_AddResource(receiver.id, RT_Gold, tribute.gold)
				Player_AddResource(sender.id, RT_Gold, -EffectiveTribute(tribute.gold))
			end
			if tribute.stone > 0 then 
				Player_AddResource(receiver.id, RT_Stone, tribute.stone)
				Player_AddResource(sender.id, RT_Stone, -EffectiveTribute(tribute.stone))
			end
		
			if tribute.receiver.isLocal and not tribute.receiver.isEliminated then
				Diplomacy_ShowEventCue(tribute)
			elseif sender.isLocal and (tribute.food > 0 or tribute.wood > 0 or tribute.gold > 0 or tribute.stone > 0) then
				local cue = _diplomacy.cue
				local text = Loc_FormatText(11164677, Player_GetDisplayName(tribute.receiver.id))		-- "Tribute sent to %1PLAYER_NAME%"
				UI_CreateEventCueClickable(-1, cue.lifetime, 0, cue.repeatTime, text, cue.desc, cue.template, cue.icon, cue.sfx, cue.color.r, cue.color.g, cue.color.b, cue.color.a, cue.style, nothing)
			end
		end
	end	
	
	Core_CallDelegateFunctions("OnTributeSent", tribute_data)   
end