				</Setter>
				<Setter Property="utility:AudioAttachedProperty.PreviewMouseLeftButtonUpSound" Value="sfx_ui_hud_inGame_button_play" />
			</Style>
		</ResourceDictionary>
	</Grid.Resources>
	<Grid.RowDefinitions>
		<RowDefinition Height="Auto" />
		<RowDefinition Height="*" />
	</Grid.RowDefinitions>
	<!--  Diplomacy button  -->
	<Button Grid.Row="0"
			Margin="0,0,0,2" HorizontalAlignment="Right"
			VerticalAlignment="Top" Panel.ZIndex="2"
			esControls:TagAdorner.AlignmentMode="Relative"
