function Mission_VillagerSetup()
	local villagers = {
			{type = "scar_villager", numSquads = Util_DifVar({9, 8, 8, 8})},
		}
	local guards = {
			{type = "scar_spearman", numSquads = 2},
			{type = "scar_archer", numSquads = 1},
		}
	
	sg_villagers_farms = SGroup_CreateIfNotFound("sg_villagers_farms")
	sg_villagers_stone = SGroup_CreateIfNotFound("sg_villagers_stone")
	sg_villagers_wood1 = SGroup_CreateIfNotFound("sg_villagers_wood1")
	sg_villagers_wood2 = SGroup_CreateIfNotFound("sg_villagers_wood2")
	
	UnitEntry_DeploySquads(player1, sg_villagers_farms, villagers, mkr_villager_farms)
	AssignVillagersToFarms(sg_villagers_farms)
	
	UnitEntry_DeploySquads(player1, sg_villagers_stone, villagers, mkr_villager_stone)
	AssignVillagersToStone(sg_villagers_stone)
	--UnitEntry_DeploySquads(player1, sg_temp, guards, mkr_villager_stone)
	
	UnitEntry_DeploySquads(player1, sg_villagers_wood1, villagers, mkr_villager_wood1)
	AssignVillagersToWood(sg_villagers_wood1)
	--UnitEntry_DeploySquads(player1, sg_temp, guards, mkr_villager_wood1)
	
	UnitEntry_DeploySquads(player1, sg_villagers_wood2, villagers, mkr_villager_wood2)
	AssignVillagersToWood(sg_villagers_wood2)
	--UnitEntry_DeploySquads(player1, sg_temp, guards, mkr_villager_wood2)
	
end


function Mission_TrickleResources()
		
	if GOLD_TRICKLE_AMOUNT > 0 then
		local goldPerTick = GOLD_TRICKLE_AMOUNT/(60/GOLD_TRICKLE_FREQUENCY)
		Player_AddResource(player1, RT_Gold, goldPerTick, RES_Resourcing)
		Rule_AddOneShot(Mission_TrickleResources, GOLD_TRICKLE_FREQUENCY)
	end
	
end

function Init_MongolInvasion()
	
	--Music_PlayStinger("mus_camp_cust_mongol_drum_cavalry")	
	
	MongolArmy_1 = { 				--First attack wave army
				type = "RovingArmy",
				descriptor = "MongolAttackRoute1",
				player = player2,
				sgroup = sg_mongols1,
				spawnLocation = mkr_enemyspawn1,
				fallbacks = {{marker = mkr_enemyspawn1,}},
				
				targetingType = ARMY_TARGETING_DISCARD,
				onDeathFunction = NewMongolArmy,
				onDeathDissolve = true,
				
				targets = {
					mkr_outercity_target,
					mkr_innercity_target,
				},
				
				units = {
					{sbp = SBP.MONGOL.UNIT_HORSEARCHER_2_MON, numSquads = 12 },
					{sbp = SBP.MONGOL.UNIT_KNIGHT_2_MON, numSquads = 7 },
					{sbp = SBP.MONGOL.UNIT_KHAN_2_MON, numSquads = 1 },
				},
			}
	
	t_difficulty.totalMongols = t_difficulty.totalMongols - 20
	MissionOMatic_InitializeModule(MongolArmy_1)
			
	MongolArmy_Wood = { 				--Targets wood
		type = "RovingArmy",
		descriptor = "MongolAttack_Resource1",
		player = player2,
		--sgroup = sg_mongols1,
		spawnLocation = mkr_enemyspawn1,
		fallbacks = {{marker = mkr_enemyspawn1,}},
	
		attackMoveEnRoute = attackMoveStyle_ignoreEverything,
		attackMoveAtTarget = attackMoveStyle_attackEverything,
		onlyAtTargetForFinal = true,
		scanRangeEnRoute = 30, 
		
		targetingType = ARMY_TARGETING_DISCARD,
		
		targets = {
			mkr_villager_wood1, 
			mkr_villager_wood2, 
		},
		onCompleteFunction = UpdateWoodArmy,
		onDeathFunction = OnWoodArmyDeath,
		
		units = {
			{sbp = SBP.MONGOL.UNIT_HORSEARCHER_2_MON, numSquads = 6 },
			{sbp = SBP.MONGOL.UNIT_KNIGHT_2_MON, numSquads = 4 },
		},
	}
	
	MongolArmy_Stone = {  				--Targets stone
		type = "RovingArmy",
		descriptor = "MongolAttack_Resource2",
		player = player2,
		--sgroup = sg_mongols1,
		spawnLocation = mkr_enemyspawn1,
		fallbacks = {{marker = mkr_enemyspawn1,}},
		
		attackMoveEnRoute = attackMoveStyle_ignoreEverything,
		attackMoveAtTarget = attackMoveStyle_attackEverything,
		onlyAtTargetForFinal = true,
		scanRangeEnRoute = 30, 
		
		targetingType = ARMY_TARGETING_DISCARD,
		
		targets = {
			mkr_villager_stone,
		},
		onCompleteFunction = UpdateStoneArmy,		
		
		units = {
			{sbp = SBP.MONGOL.UNIT_HORSEARCHER_2_MON, numSquads = 6 },
			{sbp = SBP.MONGOL.UNIT_KNIGHT_2_MON, numSquads = 4 },
		},
	}
	if Game_GetSPDifficulty() > GD_EASY then --Turn off these waves in story mode
		t_difficulty.totalMongols = t_difficulty.totalMongols - 20
		MissionOMatic_InitializeModule(MongolArmy_Wood)
		MissionOMatic_InitializeModule(MongolArmy_Stone)
	end
end

function NewMongolWave() --Generate a new ID for the next mongol wave
	g_mongolWaveIndex = g_mongolWaveIndex or 1
	local myreturnstring = "Mongol_Army_"..g_mongolWaveIndex
	g_mongolWaveIndex = g_mongolWaveIndex+1
	
	return myreturnstring
end

function NewMongolArmy() --Spin up a new mongol attack wave
	local mongolCount = Player_GetSquadCount(player2)
	if mongolCount < t_difficulty.maxMongols and t_difficulty.totalMongols > 0 then
	
		--Vars--
		local MongolTargets = {
			Table_GetRandomItem({mkr_inner_northeast_gate, mkr_inner_northwest_gate, mkr_inner_southeast_gate, mkr_inner_southwest_gate}),
			mkr_innercity_target,
		}
		local wave_SpawnLocation = mkr_enemyspawn1
		local randSpawn = {mkr_enemyspawn1, mkr_enemyspawn2, mkr_enemyspawn3, mkr_enemyspawn4, mkr_enemyspawn5, mkr_enemyspawn6}
		
		--Check if default spawn area is clear of player interferance
		Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_enemyspawn1, 70)
		Player_GetAllEntitiesNearMarker(player1, eg_temp, mkr_enemyspawn1, 70)
				
		if b_outerCityBreached == false and 
			SGroup_CountSpawned(sg_temp) < 5 and 
				EGroup_CountSpawned(eg_temp) < 1 then	
			wave_SpawnLocation = mkr_enemyspawn1
		else
			wave_SpawnLocation = Table_GetRandomItem(randSpawn)
		end	
						
		--If city hasn't been breached, target gates.
		if b_outerCity_Destroyed == false then
			
			--If outer city still stands, include it as the primary target
			table.insert(MongolTargets, 1, mkr_outercity_target)

			--Var with default
			local randGate = {mkr_outer_north_gate, mkr_outer_northeast_gate, mkr_outer_south_gate, mkr_outer_southeast_gate}
			
			--If North Spawn:
			if wave_SpawnLocation == mkr_enemyspawn2 then
				--Only target north gates
				randGate = {mkr_outer_north_gate, mkr_outer_northeast_gate}
			
				--NorthEast Spawn
			elseif wave_SpawnLocation == mkr_enemyspawn3 then
				--North & East Gates
				randGate = {mkr_outer_north_gate, mkr_outer_northeast_gate, mkr_outer_southeast_gate}
			
			--South/SouthEast Spawns (South only access to the city)
			elseif wave_SpawnLocation == mkr_enemyspawn4 or wave_SpawnLocation == mkr_enemyspawn5 then
				--South Gates
				randGate = {mkr_outer_south_gate}
			
			--East Spawns (Access to East gates)
			else
				--East Gates
				randGate ={mkr_outer_northeast_gate, mkr_outer_southeast_gate}
			end
				
			table.insert(MongolTargets, 1, Table_GetRandomItem(randGate))
		end
		
		--Build the Mongol Unit comp based on mission progress and context
		local t_MongolUnitComp = {}
		if Game_GetSPDifficulty() > GD_EASY then
			t_MongolUnitComp = Get_MongolUnits(mongolCount)
		else
			t_MongolUnitComp = Get_MongolUnitsStory(mongolCount)
		end
		
		local copyTargetTable = Table_Copy(MongolTargets)
				
		--Make the new army module
		local moduleData = {
			descriptor = NewMongolWave(), 				
			type = "RovingArmy",
			player = player2,
			
			attackMove = attackMoveStyle_attackEverything,
			scanRangeEnRoute = 30, 
			targetingType = ARMY_TARGETING_DISCARD,
			targets = copyTargetTable,
			spawnLocation = wave_SpawnLocation,
			
			onDeathFunction = NewMongolArmy,
			onDeathDissolve = true,
		}
		
		local myNewModule = RovingArmy_Init(moduleData)
		
		--DEBUG--
		if myNewModule.targets == {} or #myNewModule.targets <= 1 then
				print(myNewModule.descriptor.." is in Error, improper target list.")
		end
		
		--Spawn Wave
		SpawnUnitsToModule(t_MongolUnitComp, myNewModule, wave_SpawnLocation)
				
		--Audio drum stinger
		if b_CanPlayDrums == true then
			Music_PlayStinger("mus_camp_cust_mongol_drum_cavalry")
			b_CanPlayDrums = false
			Rule_AddOneShot(ResetDrums, drumTimer)
		end
		
		--Catalogue the module
		allmongolWaves = allmongolWaves or {}
		table.insert(allmongolWaves, myNewModule)
	end
end

function ResetDrums()
	b_CanPlayDrums = true
end

function Get_MongolUnits(mongolCount) --Generates the composition of the incoming attack waves based on mission progress criteria
		local remainingMongols = t_difficulty.totalMongols+mongolCount --siegeWaveCount
		local units = {}
	
	if mongolCount < t_difficulty.maxMongols and t_difficulty.totalMongols >= 11 then
		if t_difficulty.totalMongols > t_difficulty.siegeWaves then 
			Player_GetAll(player2)
			SGroup_Filter(sg_allsquads, "scar_ram", FILTER_KEEP)
			if b_outerCityBreached == true and SGroup_CountSpawned(sg_allsquads) < 1 then
				units = {
					{type = "scar_spearman", numSquads = 8},
					{type = "scar_ram", numSquads = 2},}
				t_difficulty.totalMongols = t_difficulty.totalMongols - 10
			elseif b_outerCityBreached == true and SGroup_CountSpawned(sg_allsquads) < t_difficulty.mongolMaxRams then
				local randUnitTable = {
					{{type = "scar_horsearcher", numSquads = 6},
					{type = "scar_knight", numSquads = 4},},
					
					{{type = "scar_spearman", numSquads = 8},
					{type = "scar_ram", numSquads = 2},},
					
					{{type = "scar_manatarms", numSquads = 4},
					{type = "scar_archer", numSquads = 5},
					{type = "scar_ram", numSquads = 1},}
				}
				units = Table_GetRandomItem(randUnitTable, 1)
				t_difficulty.totalMongols = t_difficulty.totalMongols - 10
			else
				units = {
					{type = "scar_horsearcher", numSquads = 6},
					{type = "scar_knight", numSquads = 4},}
				t_difficulty.totalMongols = t_difficulty.totalMongols - 10
			end
		elseif t_difficulty.totalMongols <= t_difficulty.siegeWaves and t_difficulty.totalMongols > (t_difficulty.siegeWaves/2)  then
			Trebuchet_Intel()
			units =  {
				{type = "scar_horsearcher", numSquads = 6 },
				{type = "scar_knight", numSquads = 3 },
				{type = "scar_mangonel", numSquads = 1 },}
			t_difficulty.totalMongols = t_difficulty.totalMongols - 10
		elseif t_difficulty.totalMongols <= (t_difficulty.siegeWaves/2) then
			units =  {
				{type = "scar_archer", numSquads = 6 },
				{type = "scar_manatarms", numSquads = 3 },
				{type = "scar_trebuchet_traction", numSquads = 1 },}
			t_difficulty.totalMongols = t_difficulty.totalMongols - 10
		end
	else
		units =  {
			{type = "scar_horsearcher", numSquads = t_difficulty.totalMongols},}
		t_difficulty.totalMongols = t_difficulty.totalMongols - t_difficulty.totalMongols
		i_timeSinceFinalMongols = i_timeSinceFinalMongols or World_GetGameTime()
		Rule_AddInterval(Emergency_Cleanup, 2)
	end
	
	return units
end

function Get_MongolUnitsStory(mongolCount) --Story mode unit comps
		local remainingMongols = t_difficulty.totalMongols+mongolCount --siegeWaveCount
		local units = {}
	
	if mongolCount < t_difficulty.maxMongols and t_difficulty.totalMongols >= 11 then
		if t_difficulty.totalMongols > t_difficulty.siegeWaves then 
			if b_outerCityBreached == true then
				local randUnitTable = {
						{{type = "scar_horsearcher", numSquads = 10}},
						{{type = "scar_horseman", numSquads = 10}},
				}
				units = Table_GetRandomItem(randUnitTable, 1)
				t_difficulty.totalMongols = t_difficulty.totalMongols - 10
			else
				units = {
					{type = "scar_horsearcher", numSquads = 6},
					{type = "scar_horseman", numSquads = 4},}
				t_difficulty.totalMongols = t_difficulty.totalMongols - 10
			end
		elseif t_difficulty.totalMongols <= t_difficulty.siegeWaves and t_difficulty.totalMongols > (t_difficulty.siegeWaves/2)  then
			Trebuchet_Intel()
			units =  {
				{type = "scar_horsearcher", numSquads = 6 },
				{type = "scar_horseman", numSquads = 3 },
				{type = "scar_ram", numSquads = 1 },}
			t_difficulty.totalMongols = t_difficulty.totalMongols - 10
		elseif t_difficulty.totalMongols <= (t_difficulty.siegeWaves/2) then
			units =  {
				{type = "scar_archer", numSquads = 6 },
				{type = "scar_spearman", numSquads = 3 },
				{type = "scar_mangonel", numSquads = 1 },}
			t_difficulty.totalMongols = t_difficulty.totalMongols - 10
		end
	else
		units =  {
			{type = "scar_horsearcher", numSquads = t_difficulty.totalMongols},}
		t_difficulty.totalMongols = t_difficulty.totalMongols - t_difficulty.totalMongols
		i_timeSinceFinalMongols = i_timeSinceFinalMongols or World_GetGameTime()
		Rule_AddInterval(Emergency_Cleanup, 2)
	end
	
	return units
end

function Emergency_Cleanup()
	if Objective_IsComplete(OBJ_HoldAgainstTheHorde) then 
		Rule_RemoveMe()
	else
		Player_GetAll(player2)
		if Player_CanSeeSGroup(player1, sg_allsquads, ANY) then
			i_timeSinceFinalMongols = World_GetGameTime()
			else
			if World_GetGameTime() - i_timeSinceFinalMongols > 30 then 
				if SGroup_CountSpawned(sg_allsquads) < 10 then
					Rule_RemoveMe()
					SGroup_DestroyAllSquads(sg_allsquads)
				else
					i_timeSinceFinalMongols = World_GetGameTime()
				end
			end
		end
	end
end

function GetOutsideTarget(rovingArmy) --Targets player units/buildings outside the city area
	
	local closestDist = -1
	local closestTarget = nil
	local thisDist = 0
	local hunterPos = SGroup_GetPosition(rovingArmy.sgroup)
	
	Player_GetAllEntitiesNearMarker(player1, eg_temp, mkr_inside_moscow)
	Player_GetAll(player1)
	
	EGroup_RemoveGroup(eg_allentities, eg_temp)
	EGroup_Filter(eg_allentities, "wall", FILTER_REMOVE)
	EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
	
	for index = EGroup_CountSpawned(eg_allentities), 1, -1 do
		local thisEntity = EGroup_GetEntityAt(eg_allentities, index)
		local thisEntityPos = Entity_GetPosition(thisEntity)
		thisDist = Util_GetDistanceSquared(thisEntityPos, hunterPos)
		
		if closestDist < 0 or thisDist < closestDist then
			closestDist = thisDist
			closestTarget = thisEntity
		end
	end

	Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_inside_moscow)
	Player_GetAll(player1)
	
	SGroup_RemoveGroup(sg_allsquads, sg_temp)

	for index = SGroup_CountSpawned(sg_allsquads), 1, -1 do
		local thisSquad = SGroup_GetSquadAt(sg_allsquads, index)
		local thisSquadPos = Squad_GetPosition(thisSquad)
		thisDist = Util_GetDistanceSquared(thisSquadPos, hunterPos)
		
		if closestDist < 0 or thisDist < closestDist then
			closestDist = thisDist
			closestTarget = thisSquad
		end
	end
	

	
	return closestTarget
	
end

function UpdateWoodArmy()
	local WoodArmy = MissionOMatic_FindModule("MongolAttack_Resource1")
	local closestTargetPos = nil
	local nextTarget = GetOutsideTarget(WoodArmy)
	
	if nextTarget ~= nil then
		closestTargetPos = Util_GetPosition(nextTarget)
		RovingArmy_SetTarget(WoodArmy, closestTargetPos)
	else
		RovingArmy_SetTarget(WoodArmy, mkr_innercity_target)
	end
end

function UpdateStoneArmy()
	local StoneArmy = MissionOMatic_FindModule("MongolAttack_Resource2")
	local closestTargetPos = nil
	local nextTarget = GetOutsideTarget(StoneArmy)
	
	if nextTarget ~= nil then
		closestTargetPos = Util_GetPosition(nextTarget)
		RovingArmy_SetTarget(StoneArmy, closestTargetPos)
	else
		RovingArmy_SetTarget(StoneArmy, mkr_innercity_target)
	end
end

function OnWoodArmyDeath() --If the Mongols attacking the exterior areas die make new ones. Turned off on Story mode
	Rule_AddOneShot(NewWoodArmy, 60)
end

function NewWoodArmy()
	
	Player_GetAll(player2)
	local mongolCount = SGroup_CountSpawned(sg_allsquads)
	
	if t_difficulty.totalMongols+mongolCount >= 20 then
		local units = {
			{type = "scar_horsearcher", numSquads = 6},
			{type = "scar_horseman", numSquads = 4},
		}
		woodArmy = MissionOMatic_FindModule("MongolAttack_Resource1")
		SpawnUnitsToModule(units, woodArmy,mkr_enemyspawn1)
	end
end

function PositionArchers()
	Player_GetAll(player1)
	SGroup_Filter(sg_allsquads, "scar_archer", FILTER_KEEP)
	SGroup_Duplicate(sg_allsquads, sg_archer_cinecommand)
	
	local splitCount = SGroup_CountSpawned(sg_allsquads)/#t_archer_start
	
	if splitCount > 0 then
		for index, marker in pairs(t_archer_start) do
			SGroup_Clear(sg_temp)
			SGroup_FilterCount(sg_allsquads, splitCount, sg_temp)
			Cmd_FormationMove(sg_allsquads, marker)
			SGroup_Duplicate(sg_temp, sg_allsquads)			
		end
		if SGroup_CountSpawned(sg_allsquads) > 0 then
			Cmd_FormationMove(sg_allsquads, t_archer_start[1])
		end
	end
end

function Trebuchet_Intel()
	if b_trebIntelPlayed == false then
		b_trebIntelPlayed = true
		Util_StartIntel(EVENTS.LastFiveWaves)
	end
end

function Tribute_Intel()
	if b_tributeIntelPlayed == false then
		b_tributeIntelPlayed = true
		Util_StartIntel(EVENTS.TributeMenu)
	end
end

function Reinforcement_Intel()
	if b_reinforceIntelPlayed == false then
		b_reinforceIntelPlayed = true
		Util_StartIntel(EVENTS.VassalSupport)
		Rule_AddOneShot(Reinforcement_Intel_Cooldown, 300)
	end
end

function Reinforcement_Intel_Cooldown()
	b_reinforceIntelPlayed = false
end

