function Mission_SetupPlayers()
	
	--
	-- get player IDs for each player
	-- 
	
	player1 = World_GetPlayerAt(1) -- Muscovites
	player2 = World_GetPlayerAt(2) -- Mongols
	player3 = World_GetPlayerAt(3) -- Refugees
	player4 = World_GetPlayerAt(4) -- Downed Prince
	
	Setup_SetPlayerName(player1, Loc_GetString(11176388)) --Muscovites
	Setup_SetPlayerName(player2, Loc_GetString(11176389)) --Mongol Horde
	Setup_SetPlayerName(player3, Loc_GetString(11176390)) --Refugees
	Setup_SetPlayerName(player4, Loc_GetString(11176388)) --Muscovites
		
	-- player 1 - Muscovites
	Player_SetCurrentAge(player1, AGE_FEUDAL)
	Player_SetMaximumAge(player1, AGE_CASTLE)

	-- player 2 - Mongols	
	Player_SetCurrentAge(player2, AGE_FEUDAL)
	Player_SetMaximumAge(player2, AGE_CASTLE)
	
		-- player 3 - Refugees
	Player_SetCurrentAge(player3, AGE_FEUDAL)
	Player_SetMaximumAge(player3, AGE_FEUDAL)

	-- player 4 - Dmitry (downed state)
	Player_SetCurrentAge(player4, AGE_FEUDAL)
	Player_SetMaximumAge(player4, AGE_CASTLE)
	
	AI_Enable(player4, false)
	
		--Perform Upgrades
	PlayerUpgrades_Auto(player1, true)
	PlayerUpgrades_Auto(player2, true)
	PlayerUpgrades_Auto(player3, false)
	PlayerUpgrades_Auto(player3, true)

	--
	-- set player relationships	
	--
		
	Player_SetRelationship(player1, player3, R_ALLY)		-- Refugees are your friends 
	Player_SetRelationship(player3, player1, R_ALLY)	

	Player_SetRelationship(player1, player4, R_ALLY)	 	-- player 4 is for Dmitry's downed state
	Player_SetRelationship(player2, player4, R_ALLY)
	Player_SetRelationship(player3, player4, R_ALLY)
	Player_SetRelationship(player4, player1, R_ALLY)	
	Player_SetRelationship(player4, player2, R_ALLY)	
	Player_SetRelationship(player4, player3, R_ALLY)	
	
		--Enable Player Colours
	PlayerColour_Enable()
	
	Game_SetPlayerSlotColour(player1, 1)
    Game_SetPlayerUISlotColour(player1, 1)
	
	Game_SetPlayerSlotColour(player2, 2)
    Game_SetPlayerUISlotColour(player2, 2)
	
	Game_SetPlayerSlotColour(player3, 9)
    Game_SetPlayerUISlotColour(player3, 9)	
	
	Game_SetPlayerSlotColour(player4, 1)
    Game_SetPlayerUISlotColour(player4, 1)
	
end


