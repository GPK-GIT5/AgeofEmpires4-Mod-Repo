	Objective_Start(OBJ_Prepare)
	
	Rule_AddOneShot(Mission_TrickleResources, GOLD_TRICKLE_FREQUENCY)
	
	Mission_VillagerSetup()
	
	Moscow3_Tutorials_Init()
	
	Rule_AddInterval(Wispness, 4)
	
end

