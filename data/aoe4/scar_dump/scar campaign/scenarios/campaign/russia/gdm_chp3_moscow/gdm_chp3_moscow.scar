function Wispness()
	EGroup_WarpToPos(eg_wisp, Util_GetRandomPosition(mkr_wisp))
	local boolHideWisp = true
	if World_GetRand(0,10) >= 9 then 
		boolHideWisp = false
	end
	Entity_VisHide(EGroup_GetEntityAt(eg_wisp, 1), boolHideWisp)
end



