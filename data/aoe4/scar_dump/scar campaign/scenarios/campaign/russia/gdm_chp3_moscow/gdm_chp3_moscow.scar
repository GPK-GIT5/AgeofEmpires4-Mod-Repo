	sg_mongols1 = SGroup_CreateIfNotFound("sg_mongols1")
	sg_mongols2 = SGroup_CreateIfNotFound("sg_mongols2")
	sg_mongols3 = SGroup_CreateIfNotFound("sg_mongols3")
	sg_mongols4 = SGroup_CreateIfNotFound("sg_mongols4")
