	sg_dmitri_start = SGroup_CreateIfNotFound("sg_dmitri_start")
	sg_monk_start = SGroup_CreateIfNotFound("sg_monk_start")
	sg_infantry1_start = SGroup_CreateIfNotFound("sg_infantry1_start")
	sg_infantry2_start = SGroup_CreateIfNotFound("sg_infantry2_start")
	sg_refugees = SGroup_CreateIfNotFound("sg_refugees")
	sg_reinforcment_cavalry = SGroup_CreateIfNotFound("sg_reinforcment_cavalry")
	sg_reinforcment_archers = SGroup_CreateIfNotFound("sg_reinforcment_archers")
	sg_reinforcment_infantry = SGroup_CreateIfNotFound("sg_reinforcment_infantry")
	
	sg_archer_cinecommand = SGroup_CreateIfNotFound("sg_archer_cinecommand")
	
	g_leaderDmitry = Missionomatic_InitializeLeader({
		name = 11159688, -- Prince Dmitry
		owner = player1,
		neutralHolder = player4,
	})
	
	b_outerCityBreached = false
	b_outerCity_Destroyed = false
	b_innerwallBreached = false
	b_reinforceCooldown = false
	b_trebIntelPlayed = false
	b_tributeIntelPlayed = false
	b_reinforceIntelPlayed = false
	b_pathIsClear = false
	b_CanPlayDrums = true
	drumTimer = 30 --Changes how often the mongol drums are allowed to play
	b_EndingComplete = false
	b_endofMission = false
	
	t_archer_start = AllMarkers_FromName("mkr_archer_start", "")
	
	t_villagerDestroy = AllMarkers_FromName("mkr_villager_destroy", "")
	
	GOLD_TRICKLE_AMOUNT = 300			-- how much gold we give to the player (per minute)
	GOLD_TRICKLE_FREQUENCY = 5			-- how often this trickle is applied to the player's resource amount (scaled so as to remain in line with the per-minute amount above)
		
	--Reinforcement amounts in the Request Aid Menu
	aid_Horseman = 20
	aid_Archers = 30
	aid_Menatarms = 10
	aid_Spearman_1 = 30
	aid_Spearman_2 = 30
	aid_Monks = 10
	aid_Knights = 15
	aid_Streltsy = 15
	
end

function Mission_SetDifficulty()

	t_difficulty = {
		totalMongols = Util_DifVar({300, 300, 400, 500}),
		maxMongols = Util_DifVar({60, 80, 120, 200}), --Should to be a multiple of 20
		mongolFrequency = Util_DifVar({120, 120, 120, 90}),
		mongolMaxRams = Util_DifVar({0, 3, 5, 8}), --No Forced Ram waves
		timeTillFailure = Util_DifVar({120, 60, 30, 30}),
		totalMongolWaves = nil,
		siegeWaves = Util_DifVar({120, 120, 200, 240}),
		preperationTime = Util_DifVar({420, 420, 300, 300}),
		escapingVillagers = Util_DifVar({100, 100, 200, 300}), --t_difficulty.escapingVillagers
	}
	
	t_difficulty.totalMongolWaves = t_difficulty.totalMongols/10
	
	--How many resources the player starts with
	local player_StartingResource = Util_DifVar(
		{
			{gold = 1500, wood = 5000, food = 3000, stone = 1000,},
			{gold = 1000, wood = 3000, food = 2400, stone = 600,},
			{gold = 500, wood = 2000, food = 1200, stone = 300,},
			{gold = 0, wood = 1000, food = 600, stone = 100,},
		})
	Player_AddResources(player1, player_StartingResource)
	
	maxTotalMongols = t_difficulty.totalMongols

  end

