	sg_mongolsblockade_2 = SGroup_CreateIfNotFound("sg_mongolsblockade_2")
	sg_mongolsblockade_3 = SGroup_CreateIfNotFound("sg_mongolsblockade_3")
	
	sg_refugeestemp = SGroup_CreateIfNotFound("sg_refugeestemp")
