end

function Mission_SetupPlayers()
	
	player1 = World_GetPlayerAt(1)
	player2 = World_GetPlayerAt(2)
	player3 = World_GetPlayerAt(3)
	player4 = World_GetPlayerAt(4)
	player5 = World_GetPlayerAt(5)
	
	
	--player 1 - Ivan
	Setup_SetPlayerName(player1, Loc_GetString("$11180265")) -- Ivan IV
	Player_SetCurrentAge(player1, AGE_IMPERIAL)
	Player_SetMaximumAge(player1, AGE_IMPERIAL)
	
	--player 2 - Kazan
	Setup_SetPlayerName(player2, Loc_GetString("$11180266")) -- Khanate of Kazan
	Player_SetCurrentAge(player2, AGE_IMPERIAL)
	Player_SetMaximumAge(player2, AGE_IMPERIAL)
	Player_SetPopCapOverride(player2, 1000) -- extra popcap room for rams
	
	--player 1 - Ivan
	Setup_SetPlayerName(player3, Loc_GetString("$11180265")) -- Ivan IV
	Player_SetCurrentAge(player3, AGE_IMPERIAL)
	Player_SetMaximumAge(player3, AGE_IMPERIAL)
	Game_SetPlayerSlotColour(player3, 1)
    Game_SetPlayerUISlotColour(player3, 1)
	AI_Enable(player3, false)

	--player 4 - Khan's Guard
	Setup_SetPlayerName(player4, Loc_GetString("$11197731")) -- Khanate of Kazan
	Player_SetCurrentAge(player4, AGE_IMPERIAL)
	Player_SetMaximumAge(player4, AGE_IMPERIAL)
	Game_SetPlayerUISlotColour(player4, 7)
	
	--player 5 - Ivan's Navy
	Setup_SetPlayerName(player5, Loc_GetString("$11180265")) -- Ivan IV
	
		-- Player relationships	
	Player_SetRelationship(player1, player2, R_ENEMY)
	Player_SetRelationship(player2, player1, R_ENEMY)
	Player_SetRelationship(player1, player3, R_ALLY)
	Player_SetRelationship(player3, player1, R_ALLY)
	Player_SetRelationship(player2, player3, R_ALLY)
	Player_SetRelationship(player3, player2, R_ALLY)
	Player_SetRelationship(player2, player4, R_ALLY)
	Player_SetRelationship(player4, player2, R_ALLY)
	Player_SetRelationship(player1, player5, R_ALLY)
	Player_SetRelationship(player5, player1, R_ALLY)
	
	PlayerUpgrades_Auto(player1)
	PlayerUpgrades_Auto(player2, nil, {UPG.COMMON.UPGRADE_TECH_UNIVERSITY_MURDER_HOLES_4})
	PlayerUpgrades_Auto(player3)
	PlayerUpgrades_Auto(player4)
end

function Mission_SetRestrictions()
	
	Modify_EntityBuildTime(player1, BP_GetEntityBlueprint("building_defense_palisade_rus"), 0.05)
	Modify_EntityBuildTime(player1, BP_GetEntityBlueprint("building_town_center_rus"), 0.05)
	
	--Remove TC Lock
	Player_SetEntityProductionAvailability(player1, EBP.RUS.BUILDING_UNIT_INFANTRY_CONTROL_RUS, ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.RUS.BUILDING_HOUSE_CONTROL_RUS, ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.RUS.BUILDING_DEFENSE_WOODEN_FORT_RUS, ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.RUS.BUILDING_DEFENSE_PALISADE_GATE_RUS, ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.RUS.BUILDING_DEFENSE_PALISADE_RUS, ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.RUS.BUILDING_ECON_FOOD_CONTROL_RUS, ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.RUS.BUILDING_ECON_MINING_CAMP_CONTROL_RUS, ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.RUS.BUILDING_ECON_WOOD_CONTROL_RUS, ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.RUS.BUILDING_RESOURCE_FARM_CONTROL_RUS, ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(player1, EBP.RUS.BUILDING_HUNTING_CABIN_RUS, ITEM_UNLOCKED)

end

function Mission_Preset()	
	
	-- Set Player Colours
	PlayerColour_Enable()
	
	Game_SetPlayerSlotColour(player1, 1)
	Game_SetPlayerUISlotColour(player1, 1)
	Game_SetPlayerSlotColour(player2, 2)
	Game_SetPlayerUISlotColour(player2, 2)
	Game_SetPlayerSlotColour(player3, 1)
	Game_SetPlayerUISlotColour(player3, 1)
	Game_SetPlayerSlotColour(player4, 7)
	Game_SetPlayerUISlotColour(player4, 7)
	Game_SetPlayerSlotColour(player5, 3)
	Game_SetPlayerUISlotColour(player5, 3)
	
	-- Outpost Upgrades
	Player_GetAll(player2)
	EGroup_Filter(eg_allentities, EBP.MONGOL.BUILDING_DEFENSE_OUTPOST_MON, FILTER_KEEP)
	if Game_GetSPDifficulty() == GD_EXPERT then
		Cmd_InstantUpgrade(eg_allentities, UPG.MONGOL.UPGRADE_OUTPOST_CANNON_MON)		-- Hard mode
	else
		Cmd_InstantUpgrade(eg_allentities, UPG.MONGOL.UPGRADE_OUTPOST_SPRINGALD_MON)	-- Story, Easy and Intermediate modes
	end
	
	-- Tower Upgrades
	Player_GetAll(player2)
	EGroup_Filter(eg_allentities, EBP.RUS.BUILDING_DEFENSE_TOWER_RUS, FILTER_KEEP)
	if Game_GetSPDifficulty() >= GD_HARD then
		Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_TOWER_CANNON)			-- Intermediate and Hard modes
	else
		Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_TOWER_SPRINGALD)		-- Story and Easy modes
	end
	
	--AI Cached Paths
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(player2, mkr_ford1_attack2, Util_GetPosition(mkr_ford1_attack1), 5.0)
	AIPlayer_SetMarkerToUpdateCachedPathToPosition(player2, mkr_ford2_attack2, Util_GetPosition(mkr_ford2_attack1), 5.0)
	
	-- Intro action
	Kazan_InitStartingUnits()
	
end

function Mission_Start()
	-- on console don't restore econ-related HUD elements at first
	Cardinal_EnablePartialXboxUI(true, {VF_XboxUIVillagerPriorities})

	Objective_Start(OBJ_SecureFort)
	UI_SetPlayerDataContext(player1, { PopulationCapOn = false })
	Player_SetPopCapOverride(player2, 500)
	Player_SetResource(player2, RT_Food, 10000)
	Player_SetResource(player2, RT_Wood, 10000)
	Player_SetResource(player2, RT_Gold, 10000)
	Player_SetResource(player2, RT_Stone, 10000)
	
	Kazan_WeakenTatarSettlement()
end

