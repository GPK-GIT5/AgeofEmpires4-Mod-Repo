function Kazan_InitStartingUnits()
	
	local action_rus = {
		{type = "scar_archer", numSquads = 12, spawn = mkr_playerstartarcher, sgroup = sg_rus_archerstart},
		{sbp = SBP.RUS.UNIT_IVAN_THE_TERRIBLE_CMP_RUS, sgroup = {sg_rus_cavalrystart, g_leaderIvan.sgroup}},
		{type = "scar_horseman", numSquads = 6, sgroup = sg_rus_cavalrystart},
		{type = "scar_knight", numSquads = 4, difficulty = {GD_EASY, GD_NORMAL}, sgroup = sg_rus_cavalrystart},
	}
	
	UnitEntry_DeploySquads(player1, sg_temp, action_rus, mkr_playerstartcavalry)
	
	--Action_SpawnUnits_Do({ player = player1, spawnLocation = mkr_playerstartarcher, sgroup = sg_rus_archerstart, units = {{ type = "scar_archer", numSquads = 12 }}, })
	--Action_SpawnUnits_Do({ player = player1, spawnLocation = mkr_playerstartinfantry, sgroup = g_leaderIvan.sgroup, units = {{ sbp = BP_GetSquadBlueprint("unit_ivan_the_terrible_cmp_rus"), numSquads = 1 }}})
	--Action_SpawnUnits_Do({ player = player1, spawnLocation = mkr_playerstartcavalry, sgroup = sg_rus_cavalrystart, units = {{ type = "scar_horseman", numSquads = 6 },{ type = "scar_knight", numSquads = 4, difficulty = {GD_EASY, GD_NORMAL} }}})
	--Action_SpawnUnits_Do({ player = player1, spawnLocation = mkr_playerstartinfantry, sgroup = sg_rus_infantrystart, units = {{ type = "scar_manatarms", numSquads = 8 }, { type = "scar_spearman", numSquads = 8 }, { type = "scar_scout", numSquads = 1 }, { type = "scar_handcannon", numSquads = 10 }}, })
		
	UnitEntry_DeploySquads( player2, sg_mon_start1, {{ type = "scar_archer", numSquads = 6, facing = Marker_GetPosition(mkr_playerstartcavalry) }},	mkr_enemystart1 )
	UnitEntry_DeploySquads( player2, sg_mon_start2, {{ type = "scar_scout", numSquads = 2 }},	mkr_enemystart2 )
	
	Cmd_FormationMove(sg_mon_start2, mkr_enemywaypoint1, true)
	Cmd_FormationMove(sg_mon_start2, mkr_enemywaypoint2, true)
	Cmd_FormationMove(sg_mon_start2, mkr_enemydest3, true)
	
	SGroup_SetInvulnerable(sg_rus_archerstart, true)

	Rule_AddOneShot(Kazan_MoveStartingUnits_Archers, 1)
	
	--Start evaluating mission failure now that we have units
	Rule_AddOneShot(Kazan_AddMissionFailureCheckLoop, 20)
end

function Kazan_WeakenTatarSettlement()
	Modify_EntityMaxHealth(eg_mon_woodcutters, 0.5, MUT_Multiplication)
	Modify_OnFireThreshold(eg_mon_woodcutters, MUT_Multiplication, 0.1)
	Modify_OnFireDamagePerTick(eg_mon_woodcutters, MUT_Multiplication, 5)
	Modify_EntityMaxHealth(eg_woodcuttertents, 0.5, MUT_Multiplication)
	Modify_OnFireDamagePerTick(eg_woodcuttertents, MUT_Multiplication, 5)
	
end

function Kazan_MoveStartingUnits_Archers()
	Cmd_Attack(sg_rus_archerstart, sg_mon_start1)
	Rule_AddOneShot(Kazan_MoveStartingUnits_Cavalry, 6)
	
end
	
function Kazan_MoveStartingUnits_Cavalry()
	Cmd_Attack(sg_mon_start1, sg_rus_archerstart)
	Cmd_Attack(sg_rus_cavalrystart, sg_mon_start1)
	Rule_AddOneShot(Kazan_MoveStartingUnits_Infantry, 6)
	
	Rule_AddInterval(Kazan_PositionArchersAndCav, 0.5)
	
	Rule_AddOneShot(Kazan_RetreatScouts, 3)
	
end

function Kazan_RetreatScouts()
	
	Cmd_FormationMove(sg_mon_start2, mkr_woodcutters)
	SGroup_AddGroup(sg_mon_defend_woodcutters, sg_mon_start2)
	
	
end

function Kazan_MoveStartingUnits_Infantry()
	Cmd_Attack(sg_rus_cavalrystart, sg_mon_start1)
	--Cmd_FormationMove(sg_rus_infantrystart, mkr_playerstartinfantry_target)
	
	local parade ={
		mkr_infantry_parade_0,
		mkr_infantry_parade_1,
		mkr_infantry_parade_2,
		mkr_infantry_parade_3,
		mkr_infantry_parade_4,
	}
		-- sgroup = sg_rus_infantrystart, units = {{  }, {  }, { type = "scar_scout", numSquads = 1 }, {  }}, })

	local units = {
		{type = "scar_scout",   numSquads = 1, spawn = mkr_infantry_parade_0},
		{type = "scar_spearman",   numSquads = 8, spawn = mkr_playerstartinfantry_4},
		{type = "scar_manatarms",  numSquads = 8, spawn = mkr_playerstartinfantry_3},
		{type = "scar_handcannon", numSquads = 5, spawn = mkr_playerstartinfantry_2},
		{type = "scar_handcannon", numSquads = 5, spawn = mkr_playerstartinfantry_1},
	}
	
	Util_UnitParade(parade, units, sg_rus_infantrystart)
	
end

function Kazan_PositionArchersAndCav()
	
	if SGroup_CountSpawned(sg_mon_start1) < 1 then
		
		SGroup_SetInvulnerable(sg_rus_archerstart, false)
		
		Cmd_FormationMove(sg_rus_cavalrystart, mkr_playerstartcavalry_target, false, nil, mkr_enemystart1)
		Cmd_FormationMove(sg_rus_archerstart, mkr_playerstartarchers_target, false, nil, mkr_enemystart1)
		--Cmd_FormationMove(g_leaderIvan.sgroup, mkr_playerstartivan_target)
		Rule_RemoveMe()
		
		--Cmd_FormationMove(sg_rus_archerstart, mkr_enemystart1, false, nil, mkr_enemydest3)
		
	end
	
end

function Kazan_GroupWallsForObjectives()
	
	Player_GetAllEntitiesNearMarker(player2, eg_mon_outerwalls, mkr_kazancity, 250)
	EGroup_Filter(eg_mon_outerwalls, { "stone_wall", "stone_gate" }, FILTER_KEEP)
	
	Player_GetAllEntitiesNearMarker(player2, eg_mon_innerwalls, mkr_innerkazan2, 55)
	Player_GetAllEntitiesNearMarker(player2, eg_temp, mkr_innerkazan3, 55)
	EGroup_AddEGroup(eg_mon_innerwalls, eg_temp)
	EGroup_Filter(eg_mon_innerwalls, { "stone_wall", "stone_gate" }, FILTER_KEEP)
	
	EGroup_RemoveGroup(eg_mon_outerwalls, eg_mon_innerwalls)
	
	startingcount_outerWall = EGroup_Count(eg_mon_outerwalls)
	startingcount_innerWall = EGroup_Count(eg_mon_innerwalls)
	
end

