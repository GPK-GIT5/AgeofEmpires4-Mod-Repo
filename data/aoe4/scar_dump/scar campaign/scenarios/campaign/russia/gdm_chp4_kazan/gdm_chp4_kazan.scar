function Kazan_SetIntensity(newIntensity, context)
	print("Current kazan_intensity: " .. tostring(kazan_intensity))
	print("Set kazan_intensity: " .. tostring(newIntensity))
	if newIntensity > kazan_intensity then
		kazan_intensity = newIntensity
	end
	print("New kazan_intensity: " .. tostring(kazan_intensity))
end

function Kazan_SkipIntro()
	
	SGroup_DestroyAllSquads(sg_rus_archerstart)
	SGroup_DestroyAllSquads(sg_rus_infantrystart)
	SGroup_DestroyAllSquads(sg_mon_start1)
	SGroup_DestroyAllSquads(sg_mon_start2)
	
	local rules = {
		Kazan_MoveStartingUnits_Cavalry,
		Kazan_MoveStartingUnits_Infantry,
		Kazan_PositionArchersAndCav,
		Kazan_RetreatScouts,
	}
	
	for k, rule in pairs (rules) do
		if Rule_Exists(rule) then
			Rule_Remove(rule)
		end
	end
	
	
	local action_rus = {
		{type = "scar_archer", numSquads = 12, spawn = mkr_playerstartarchers_target, sgroup = sg_rus_archerstart},
	}
	

	local infantry = {
		{type = "scar_spearman",   numSquads = 8, spawn = mkr_infantry_parade_4},
		{type = "scar_manatarms",  numSquads = 8, spawn = mkr_infantry_parade_3},
		{type = "scar_handcannon", numSquads = 5, spawn = mkr_infantry_parade_2},
		{type = "scar_handcannon", numSquads = 5, spawn = mkr_infantry_parade_1},
	}

	UnitEntry_DeploySquads(player1, sg_temp, action_rus, mkr_playerstartcavalry_target)
	UnitEntry_DeploySquads(player1, sg_rus_infantrystart, infantry, mkr_infantry_parade_4)
	
	SGroup_FormationWarpToMarker(sg_rus_cavalrystart, mkr_playerstartcavalry_target)
	
end

function Kazan_CheckFailure()
	--If player doesn't currently have a capital town center
	if Player_HasBuilding(player1, {EBP.RUS.BUILDING_TOWN_CENTER_CAPITAL_RUS}) == false then
		--and they're on the objective after building one, it must have been destroyed, mission fail.
		if Objective_IsStarted(OBJ_SiegeKazan) then
			Rule_RemoveMe()
			Mission_Fail()
		--or if they're still on the objective to build a TC,
		elseif Objective_IsStarted(SOBJ_BuildFort) then
			SGroup_Clear(sg_temp)
			SGroup_Duplicate(sg_rus_villagers, sg_temp)
			SGroup_Filter(sg_temp, "scar_villager", FILTER_KEEP)
			--but they have no villagers, progress blocked, mission fail.
			if SGroup_CountSpawned(sg_temp) <= 0 then
				Rule_RemoveMe()
				Mission_Fail()
			end
		--or if they've got no units and haven't gotten villagers yet, progress blocked, mission fail.
		elseif Player_GetSquadCount(player1) == 0 then
			Rule_RemoveMe()
			Mission_Fail()
		end
	end
end

-- ACHIEVEMENT - check to see if all enemy units and unit producing buildings are destroyed
function Achievement_CheckAnnihilation()
	
	-- Get all Mongol units
	local sg_enemyUnitsAlive = Player_GetSquads(player2)
	-- Remove Sheep and Sheep Carcasses from SGroup
	SGroup_Filter(sg_enemyUnitsAlive, "gaia", FILTER_REMOVE)
	-- Count number of Mongol units
	local enemyUnitCount = SGroup_Count(sg_enemyUnitsAlive)
	
	-- Get all Mongol buildings that can produce units
	local eg_enemyProductionBuildings = Player_GetEntitiesFromType(player2, "production_building")
	
	-- Count number of Mongol production buildings
	local enemyProductionCount = EGroup_Count(eg_enemyProductionBuildings)

	-- If Mongol player has no units or production buildings remaining
	if enemyUnitCount <= 1 and enemyProductionCount == 0 then
		
		Game_SendCustomChallengeEvent(player1, CE_ACHIEVDESTROYALLSIEGEOFKAZAN, 1)	
		
		Rule_RemoveMe()
		
	end
end
function TriggerContextObjective()
	if b_attackWaveContextTriggered == false then
		i_timesDefeated = i_timesDefeated or 0
		i_timesDefeated = i_timesDefeated + 1
		if i_timesDefeated >= 2 then
			b_attackWaveContextTriggered = true
			Objective_Start(OBJ_ClearWestFord, true)
		end
	end
end