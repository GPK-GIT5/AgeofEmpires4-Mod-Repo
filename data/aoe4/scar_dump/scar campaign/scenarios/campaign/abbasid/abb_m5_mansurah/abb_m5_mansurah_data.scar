		{ type = "scar_archer",    	 						numSquads = Util_DifVar({ 5, 6, 9, 12 }), 	pool = pool_tents },
		{ type = "scar_crossbowman", 						numSquads = Util_DifVar({ 5, 6, 9, 12 }),   pool = pool_tents },
		{ type = "scar_manatarms", 	 						numSquads = Util_DifVar({ 5, 6, 9, 12 }), 	pool = pool_home },
		{ type = "scar_crossbowman", 						numSquads = Util_DifVar({ 5, 6, 9, 12 }),   pool = pool_home },
