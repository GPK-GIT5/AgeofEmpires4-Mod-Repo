end

function GetRecipe()
	return {
		introNIS = EVENTS.Intro,
		outroNIS = EVENTS.Victory,
		audioSettings = {
			campaignName = "abb",
			missionName = "rts1350mansurah",
		},
		onStart = {
			titleCard = {
				icon = "icons/campaign/campaign_slaves_to_sultans",
				title = "$11253225", -- Nile Delta
				date =  "$11253224", -- 1250
			},
		},
	}
end

