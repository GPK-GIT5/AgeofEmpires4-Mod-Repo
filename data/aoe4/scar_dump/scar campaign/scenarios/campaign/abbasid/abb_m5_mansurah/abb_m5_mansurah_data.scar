		--------------------------------------------------------------------------------------------------------------
	--------------------------------------------- CAMP UNITS -----------------------------------------------------
	--------------------------------------------------------------------------------------------------------------
	camp_follower_units = {
		{ type = "scar_militia",   	 						numSquads = Util_DifVar({ 5, 6, 9, 12 }), 	pool = pool_tents },
		{ type = "scar_spearman",  	 						numSquads = Util_DifVar({ 5, 6, 9, 12 }),   pool = pool_tents },
