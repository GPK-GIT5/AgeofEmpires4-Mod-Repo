		Player_SetUpgradeAvailability(player, UPG.COMMON.UPGRADE_NAVAL_EXPLOSIVES, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.COMMON.UPGRADE_NAVAL_EXTRA_HAMMOCKS, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.COMMON.UPGRADE_NAVAL_FORECASTLE, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.COMMON.UPGRADE_NAVAL_GALLEY_CANNON, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.COMMON.UPGRADE_NAVAL_HEATED_SHOT, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.COMMON.UPGRADE_NAVAL_INCENDIARIES, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.COMMON.UPGRADE_NAVAL_MOUNTED_GUNS, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.COMMON.UPGRADE_NAVAL_NAVIGATOR, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.COMMON.UPGRADE_NAVAL_ROLE_CHAINSHOT, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.COMMON.UPGRADE_NAVAL_ROLE_FIREARROWS, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.COMMON.UPGRADE_NAVAL_ROLE_FIRESTATION, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.COMMON.UPGRADE_NAVAL_SHIPWRIGHTS, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.COMMON.UPGRADE_NAVAL_SPRINGALD_SHIP_UPGRADE_1, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.COMMON.UPGRADE_NAVAL_SWIVEL_CANNON, ITEM_REMOVED)
		
		
		Player_SetUpgradeAvailability(player, UPG.AYYUBID_CMP.UPGRADE_ADD_TRADE_WING_AYY, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.AYYUBID_CMP.UPGRADE_ADD_TRADE_WING_FEUDAL_AYY, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.AYYUBID_CMP.UPGRADE_ADD_TRADE_WING_CASTLE_AYY, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.AYYUBID_CMP.UPGRADE_ADD_TRADE_WING_IMPERIAL_AYY, ITEM_REMOVED)
		
		Player_SetUpgradeAvailability(player, UPG.ABBASID.UPGRADE_TRADE_GOLD_INCOME_ABB, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.ABBASID.UPGRADE_TRADE_COMMODITY_TRADE_ABB, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.ABBASID.UPGRADE_TRADE_TRADER_ARMOR_ABB, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.ABBASID.UPGRADE_NAVAL_TEAK_MASTS_ABB, ITEM_REMOVED)
		Player_SetUpgradeAvailability(player, UPG.AYYUBID_CMP.UPGRADE_NAVAL_ALLIED_DOCK_HEAL_AYY, ITEM_REMOVED)

		Player_CompleteUpgrade(player, UPG.COMMON.UPGRADE_UNIT_TOWN_CENTER_WHEELBARROW_1)
		Player_CompleteUpgrade(player, UPG.COMMON.UPGRADE_SCOUT_FORESTER)
		Player_CompleteUpgrade(player, UPG.AYYUBID_CMP.UPGRADE_MIL_PARTHIAN_TACTICS_AYY)
		
		Player_ModifyAyyubidMilitaryBuildTimes(player, Util_DifVar({ 0.5, 0.75, 1, 1 }))
		PlayerUpgrades_ApplyHealthBonuses(player)
	end
	
	
	--House of Wisdom Prebuild Econ Wing--
	EGroup_CompleteUpgrade(eg_player_how, UPG.ABBASID.UPGRADE_ADD_MILITARY_WING)
	Player_SetStateModelBool(player1, "military_wing_built_abb", true)
	EGroup_SetAnimatorVariable(eg_player_how, "military_wing_build_progress_abb", 1)
	Modify_EntityMaxHealth(eg_player_how, 5000, MUT_Addition)
	
	Player_SetResource(player2, RT_Wood, 100000000)
	Player_CompleteUpgrade(player2, UPG.COMMON.UPGRADE_SIEGE_ENGINEERS)
	Player_SetPopCapOverride(player2, 3000)

	TechTree_GiveUnitUpgrades(player2, 3, TT_INCLUDE_TIERED)
	TechTree_GiveMilitaryUpgrades(player2, Util_DifVar({ 0, 0, 1, 2 }), TT_INCLUDE_TIERED)
	
	UI_SetPlayerDataContext(player1, { PopulationCapOn = false })
	
	if Game_GetSPDifficulty() >= GD_EXPERT then
		Player_CompleteUpgrade(player2, UPG.CRUSADER_CMP.UPGRADE_ARMOR_CLAD_CRU)
		Cmd_InstantUpgrade(eg_outposts, UPG.COMMON.UPGRADE_OUTPOST_SPRINGALD)
	end
	if Game_GetSPDifficulty() >= GD_HARD then
		Player_CompleteUpgrade(player2, UPG.COMMON.UPGRADE_RAM_SCALING)
		Player_CompleteUpgrade(player2, UPG.COMMON.UPGRADE_SIEGE_ADJUSTABLE_CROSSBAR)
		Cmd_InstantUpgrade(eg_outposts, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	end
	if Game_GetSPDifficulty() >= GD_NORMAL then
		Player_CompleteUpgrade(player2, UPG.COMMON.UPGRADE_SIEGE_WEAPON_SPEED)
		Player_CompleteUpgrade(player2, UPG.COMMON.UPGRADE_SIEGE_MATHEMATICS)
	end
	
	FoodReserves_Init()

	local num_spies = SGroup_CountSpawned(sg_spies)
	Player_SetStateModelFloat(player1, "shajar_num_spies_ayy", num_spies)
	Player_SetStateModelFloat(player3, "shajar_num_spies_ayy", num_spies)
	SGroup_RemoveAbility(sg_spies, BP_GetAbilityBlueprint("core_unit_death"))
	
	Rule_AddGlobalEvent(OnSquadKilled, GE_SquadKilled)
	Rule_AddGlobalEvent(OnEntityKilled, GE_EntityKilled)
	Rule_AddGlobalEvent(OnAbilityExecuted, GE_AbilityExecuted)
	
	sg_villagers_berries = CreateUnits(player3, {{ type = "scar_villager", numSquads = VILLAGER_COUNT_BERRIES }}, mkr_villagers_berries, "sg_villagers_berries")
	sg_villagers_gold =    CreateUnits(player3, {{ type = "scar_villager", numSquads = VILLAGER_COUNT_GOLD }},    mkr_villagers_gold,    "sg_villagers_gold")
	sg_villagers_wood =    CreateUnits(player3, {{ type = "scar_villager", numSquads = VILLAGER_COUNT_WOOD }},    mkr_villagers_wood,    "sg_villagers_wood")
	sg_fishing_boats =    CreateUnits(player3, {{ type = "scar_fishing_ship", numSquads = 2 }},    				  mkr_fishing_boats,     "sg_fishing_boats")
	gather_speed_modification_berries = Modify_FoodGatherRate(sg_villagers_berries, 0.2)
	gather_speed_modification_gold = Modify_GoldGatherRate(sg_villagers_gold, 0.02)
	gather_speed_modification_wood = Modify_WoodGatherRate(sg_villagers_wood, 0.2)
	gather_speed_modification_fish = Modify_FoodGatherRate(sg_fishing_boats, 0.2)
	gather_speed_modifications = { gather_speed_modification_berries, gather_speed_modification_gold, gather_speed_modification_wood, gather_speed_modification_fish }
	AssignVillagersToBerries(sg_villagers_berries, false, true)
	AssignVillagersToGold(sg_villagers_gold, false, false)
	AssignVillagersToWood(sg_villagers_wood, true, true)
	AssignFishingBoatsToDeepFish(sg_fishing_boats, true, false)
	SGroup_AddGroup(sg_mansurah, sg_villagers_berries)
	SGroup_AddGroup(sg_mansurah, sg_villagers_gold)
	SGroup_AddGroup(sg_mansurah, sg_villagers_wood)
	SGroup_SetTargetingType(sg_cavalry_all, Targeting_None)
	SGroup_SetTargetingType(sg_signal_messanger, Targeting_None)
	Cmd_HoldPosition(sg_cavalry_all)
	
	local range_modifier = Modifier_Create(MAT_WeaponType, "range_weapon_modifier", MUT_Multiplication, false, 10/16, BP_GetWeaponBlueprint("weapon_trebuchet_4_counterweight"))
	Modifier_ApplyToPlayer(range_modifier, player2, 0)
	
	local unit_types = {
		EBP.CRUSADER_CMP.UNIT_TREBUCHET_CRU,
		EBP.CRUSADER_CMP.UNIT_MANGONEL_CRU,
		EBP.CRUSADER_CMP.UNIT_SPRINGALD_CRU,
	}
	for i, ebp in ipairs(unit_types) do
		local modifier = Modifier_Create(MAT_EntityType, "speed_maximum_modifier", MUT_Set, true, 4.5, ebp)	
		Modifier_ApplyToPlayer(modifier, player2, 0)
	end
	Entity_SetStateModelFloat(EGroup_GetEntityAt(eg_monastery, 1), "relic_count", Util_DifVar({ 3, 2, 1, 1 }))

	SpawnSingles()
	SpawnHolyOrders()
	SpawnDefendingArmies()
	Ambush_Spawn()
	
	StartMonitoringResources()
	
	AutoTest_OnInit()
end

function Mission_PreStart()
	print("PreStart")
	Man_RegisterObjectives()
	HintPoint_Add(eg_town_center, true, "$11257250", 0) -- Mansurah
	Player_SetResource(player1, RT_Wood, Util_DifVar({ 350, 300, 250, 200 }))
	Player_SetResource(player1, RT_Food, Util_DifVar({ 350, 300, 250, 200 }))
	Player_SetResource(player1, RT_Gold, Util_DifVar({ 250, 200, 150, 100 }))
	Player_SetResource(player1, RT_Stone, Util_DifVar({ 150, 100, 50, 0 }))
	
	-- Audio
	Sound_ResetMusicIntensityMapping();
	Sound_AddMusicIntensityMappingPoint(50, 200) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(100, 1250) -- point 1 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(150, 2500) -- point 1 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(200, 4000) -- point 1 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(300, 5500) -- point 1 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(400, 7250) -- point 1 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(550, 9999) -- raw value max to scaled value max 
end
function Mission_Start()	-- this is triggered after the intro, just as control is passed to the player
	Util_StartIntel(EVENTS.Start)
	StartInitialObjectives()

	if Misc_IsCommandLineOptionSet("skipBaybarsTimer") then
		skipBaybarsTimer()
	end
	
	Tutorials_Init()
	
	Rule_AddOneShot(SpyTutorial_Enable, 5)
	StealthStrikeTutorial_Enable()
	PickupTutorial_Enable()
end

--------------------------------------------------
------------------- RunTime ---------------------
--------------------------------------------------

function RemoveGatherSpeedModifications()
	for _, mod in ipairs(gather_speed_modifications) do
		Modifier_Remove(mod)
	end
	for _, sgroup in ipairs({ sg_villagers_berries, sg_villagers_gold, sg_villagers_wood, sg_fishing_boats }) do
		SGroup_SetResource(sgroup, RT_Wood, 0)
		SGroup_SetResource(sgroup, RT_Gold, 0)
		SGroup_SetResource(sgroup, RT_Food, 0)
	end
end

function StartMonitoringResources()
	EGroup_AddEGroup(eg_trees, eg_allWoodResources)
	EGroup_FilterByProximity(eg_trees, mkr_villagers_wood, 30, FILTER_KEEP)
	Rule_AddInterval(MonitorResources, 1)
end

function MonitorResources(context, data)
	if stop_reinforcing_resources == true then
		Rule_RemoveMe()
	else
		EGroup_SetRemainingResourceDepositAmount(eg_trees, 150)
		EGroup_SetRemainingResourceDepositAmount(eg_gold, 8000)
		EGroup_SetRemainingResourceDepositAmount(eg_gold_small, 4000)
		EGroup_SetRemainingResourceDepositAmount(eg_stone, 2400)
		EGroup_SetRemainingResourceDepositAmount(eg_berries, 350)
		EGroup_SetRemainingResourceDepositAmount(eg_shore_fish, 500)
		EGroup_SetRemainingResourceDepositAmount(eg_deep_fish, 1000)
	end
end

function Ambush_Spawn()
	local params_left = {
		player = player2,
		spawn = mkr_ambush_left_spawn,
		units = {
			{ sbp = SBP.CRUSADER_CMP.UNIT_SCOUT_MANSURAH_CRU, numSquads = 1 },
			{ sbp = SBP.CRUSADER_CMP.UNIT_KNIGHT_3_MANSURAH_CRU, numSquads = 2 },
		}
	}
	local params_right = {
		player = player2,
		spawn = mkr_ambush_right_spawn,
		units = {
			{ sbp = SBP.CRUSADER_CMP.UNIT_SCOUT_MANSURAH_CRU, numSquads = 1 },
			{ sbp = SBP.CRUSADER_CMP.UNIT_KNIGHT_3_MANSURAH_CRU, numSquads = 2 },
		}
	}
	ambush_left = Army_Init(params_left)
	ambush_right = Army_Init(params_right)
	Modify_UnitSpeedWhenNotInCombat(ambush_left.sgroup, 4.0, MUT_Set)
	Modify_UnitSpeedWhenNotInCombat(ambush_right.sgroup, WALK_SPEED, MUT_Set)
	
	Rule_Add(Ambush_Monitor)
	
	Player_GetAllSquadsNearMarker(player2, sg_ambush_bait, mkr_ambush_bait)
	ambush_bait_spawned = SGroup_CountSpawned(sg_ambush_bait) > 0
end

function Ambush_Monitor(context, data)
	local triggered_by_prox = SGroup_CountSpawned(sg_spies) > 0 and Prox_AreSquadsNearMarker(sg_spies, mkr_ambush_trigger, ANY)
	local triggered_by_kills = ambush_bait_spawned and SGroup_CountSpawned(sg_ambush_bait) == 0
	if triggered_by_prox or triggered_by_kills then
		Rule_RemoveMe()
		Ambush_Trigger()
	end
end

function Ambush_Trigger()
	local targets_left = { 
		{ marker = mkr_ambush_left_target_1, combatRange = 20, leashRange = 25 }, 
		{ marker = mkr_ambush_left_target_2, combatRange = 20, leashRange = 25 }, 
		{ marker = mkr_ambush_left_target_3, combatRange = 20, leashRange = 25 },
		{ marker = mkr_ambush_left_target_4, combatRange = 20, leashRange = 25 },
		{ marker = mkr_ambush_left_target_5, useCustomDirection = true },
	}
	local targets_right = {
		{ marker = mkr_ambush_right_target_1, combatRange = 20, leashRange = 25 }, 
		{ marker = mkr_ambush_right_target_2, combatRange = 20, leashRange = 25 }, 
		{ marker = mkr_ambush_right_target_3, useCustomDirection = true },
	}
	Army_AddTargets(ambush_left, targets_left)
	Army_AddTargets(ambush_right, targets_right)
	Rule_AddOneShot(Ambush_Reveal, 1)
	Multiple_Change()
	
end

function Ambush_Reveal(context, data)
	UI_CreateEventCue("$11256231", Loc_Empty(), "high_priority", "icons/event_queue_high_priority_large", "sfx_ui_event_queue_high_priority_play", ECV_Title|ECV_Queue, 12)
	FOW_RevealSGroup(ambush_left.sgroup, 15, 15)
	FOW_RevealSGroup(ambush_right.sgroup, 15, 15)
	Rule_AddOneShot(Ambush_ShowHint, 3.5)
end

function Ambush_ShowHint(context, data)
	FarmhouseTutorial_Enable()
end

function SpawnCampFollowers()
	Camp_SpawnUnitsIntoPools(0, camp_follower_units)
end

function SpawnHolyOrders()
	holy_orders_spawned = true
	for _, holy_order in ipairs(holy_orders) do
		local params = {
			player = player2,
			units = {{ sbp = holy_order.member_sbp, numSquads = holy_order.member_count }},
			TARGET_ORDER = TARGET_ORDER_PATROL,
			spawn = holy_order.member_spawn,
			combatRange = COMBAT_RANGE_LARGE,
			leashRange = LEASH_RANGE_LARGE,
			useCustomDirection = true,
		}
		holy_order.army = Army_Init(params)
	end
end

function HolyOrder_Flee(holy_order)
	print("REPORT - "..holy_order.name.." Grand Master killed")
	holy_order.sgroup = SGroup_CreateUniqueWithPrefix("sg_holy_order")
	holy_order.sg_remaining = SGroup_CreateUniqueWithPrefix("sg_holy_order_remaining")
	Army_Dissolve(holy_order.army, holy_order.sgroup)
	SGroup_AddGroup(holy_order.sg_remaining, holy_order.sgroup)
	if SGroup_CountSpawned(holy_order.sgroup) > 0 then
		FOW_PlayerRevealSGroup(player1, holy_order.sgroup, 10, -1)
		Sound_Play2D("sfx_campaign_small_large_fear")
		UI_CreateMinimapBlip(SGroup_GetAvgPosition(holy_order.sgroup), 10, "general")
		last_holy_order_cta_at = last_holy_order_cta_at or 0
		if World_GetGameTime() >= last_holy_order_cta_at + 30 then
			last_holy_order_cta_at = World_GetGameTime()
			--Objective_AddUIElements(OBJ_DummyPrimary, holy_order.sgroup, true, "test", false)
			
			-- Determine which CTA to play in the events file
			VOCue_HolyOrderLeaving(holy_order)
			Sound_Play2D("mus_stinger_campaign_triumph_short")
		end
		Cmd_Stop(holy_order.sgroup)
		Rule_AddInterval(HolyOrder_SingleMemberFlees, 0.375, { holy_order = holy_order })
	end
end

function HolyOrder_SingleMemberFlees(context, data)
	local holy_order = data.holy_order
	if SGroup_CountSpawned(holy_order.sg_remaining) == 0 then
		Rule_RemoveMe()
		return
	end
	SGroup_Clear(sg_temp)
	local squad = SGroup_GetSquadAt(holy_order.sg_remaining, 1)
	SGroup_Add(sg_temp, squad)
	SGroup_Remove(holy_order.sg_remaining, squad)
	local queued = false
	if holy_order.member_waypoint then
		SGroup_Move(sg_temp, holy_order.member_waypoint, queued)
		queued = true
	end
	Cmd_MoveToAndDestroy(sg_temp, mkr_enemy_flee, queued)
end

function SpawnDefendingArmies()
	for _, army in ipairs(defending_armies) do
		Army_Init(army)
	end
end

function BaybarsArrives()
	Sound_Play2D("sfx_campaign_scripted_large_group_celebrate")
	Sound_Play2D("mus_stinger_campaign_positive")
	local units = {{ sbp = SBP.AYYUBID_CMP.UNIT_LEADER_BAIBARS_AYY }}
	SGroup_Clear(sg_temp)
	CreateUnits(player1, units, mkr_baybars_spawn, sg_temp)
	SGroup_AttackMove(sg_temp, mkr_baybars_dest)
	SGroup_Filter(sg_temp, SBP.AYYUBID_CMP.UNIT_LEADER_BAIBARS_AYY, FILTER_KEEP)
	LeaderTent_RegisterLeader(SGroup_GetSquadAt(sg_temp, 1))
	sg_baybars = SGroup_CreateUniqueWithPrefix("sg_baybars")
	SGroup_AddGroup(sg_baybars, sg_temp)
	local event = EVENTS.BaybarsArrives_CTA
	local func = EVENTS.BaybarsArrives_CTA_OnClick
	EventCues_CallToAction("$11256711", CTA_CELEBRATE, event, func, sg_baybars, 35, "icons/cta/illustrations/player_leader_has_arrived")
	Sound_Play2D("mus_stinger_campaign_triumph_short")
	baybars_offset = 0
	baybars_rows_spawned = 0

	local population = Player_GetTotalPopulation(player1)
	reinforcement_files = 5 -- 50 total
	if population > 170 then
		reinforcement_files = 4 -- 40 total
	elseif population > 190 then
		reinforcement_files = 3 -- 30 total
	end
	Rule_AddInterval(BaybarsArrives_B, 0.75)
	Rule_AddInterval(VOCue_BaybarsSelected, 1)
end

function BaybarsArrives_B(context, data)
	baybars_offset = baybars_offset + 3.5
	baybars_rows_spawned = baybars_rows_spawned + 1
	if baybars_rows_spawned > 10 then
		Rule_RemoveMe()
		return
	end
	local units
	if baybars_rows_spawned <= 5 then
		units = {{ sbp = SBP.AYYUBID_CMP.UNIT_KNIGHT_3_AYY, numSquads = reinforcement_files }}
	else
		units = {{ sbp = SBP.AYYUBID_CMP.UNIT_TURKIC_HORSEARCHER_2_AYY, numSquads = reinforcement_files }}
	end
	
	local pos = World_GetOffsetPositionRelativeToFacingTarget(Marker_GetPosition(mkr_baybars_dest), Marker_GetPosition(mkr_baybars_spawn), baybars_offset)
	SGroup_Clear(sg_temp)
	CreateUnits(player1, units, mkr_baybars_spawn, sg_temp)
	SGroup_AttackMove(sg_temp, pos)
end

function VOCue_BaybarsSelected()
	if VOFlag_AllowSelectBaybarsVO == true then
		if Misc_IsSGroupSelected(sg_baybars, ALL) == true then
			VOFlag_AllowSelectBaybarsVO = false
			Rule_RemoveMe()
			Util_StartIntel(EVENTS.History_Baybars)
		end
	end
end

function OnAbilityExecuted(context, data)
	if context.ability == BP_GetAbilityBlueprint("farmhouse_ungarrison_dummy_ayy") then
		local player = Entity_GetPlayerOwner(context.executer)
		EGroup_Clear(eg_temp)
		EGroup_Add(eg_temp, context.executer)
		LocalCommand_Entity(player, eg_temp, CMD_UnloadSquads)
	end
end

--------------------------------------------------
--------------------- MISC -----------------------
--------------------------------------------------

function PrintReport()
	local siege_duration  = World_GetGameTime() - siege_started_at
	local s = Util_ConvertIntegerSecondsToStringTime(math.floor(siege_duration))
	
	--
	Player_GetAll(player1, sg_allsquads)
	local sg_villagers = SGroup_CreateUnique("")
	SGroup_Filter(sg_allsquads, "scar_villager", FILTER_REMOVE, sg_villagers)
	local villagerCount = SGroup_CountSpawned(sg_villagers)
	local militaryCount = SGroup_CountSpawned(sg_allsquads)
	local militaryCost = SGroup_GetResourceCost(sg_allsquads)
	SGroup_Destroy(sg_villagers)
	--print("PLAYER  -  Villagers:"..villagerCount.."  MilitaryCost:"..militaryCost)
	s = s.."   PlayerVillagers: "..villagerCount.."   PlayerMilitaryCost: "..militaryCost.."   "
	
	local loitering_count = 0
	local mustered_count = 0
	local pending_count = 0
	for _, invasion in ipairs(pending_invasions) do
		pending_count = pending_count + SGroup_CountSpawned(invasion.sgroup)
		if invasion.is_mustered then
			mustered_count = mustered_count + SGroup_CountSpawned(invasion.sgroup)
		else
			loitering_count = loitering_count + SGroup_CountSpawned(invasion.sgroup)
		end
	end
	
	local fighting_count = 0
	local blocked_count = 0
	local active_count = 0
	for i = #active_invasions, 1, -1 do
		local invasion = active_invasions[i]
		if SGroup_CountSpawned(invasion.sgroup) == 0 then
			table.remove(active_invasions, i)
		else
			active_count = active_count + SGroup_CountSpawned(invasion.sgroup)
			if invasion.is_blocked then
				blocked_count = blocked_count + SGroup_CountSpawned(invasion.sgroup)
			else
				fighting_count = fighting_count + SGroup_CountSpawned(invasion.sgroup)
			end
		end
	end
	local staged_count = SGroup_CountSpawned(army_blocked.sgroup)
	active_count = active_count + SGroup_CountSpawned(army_blocked.sgroup)
	s = s.."EnemiesPending: "..pending_count.."   EnemiesActive: "..active_count
	print(s)
	--print("ENEMY_REPORT  -  Loitering:"..loitering_count.."  Mustered:"..mustered_count.."  Fighting:"..fighting_count.."  Blocked:"..blocked_count.."  Staged:"..staged_count)
end


function tag()
	local squad = SGroup_GetSpawnedSquadAt(sg_shajar, 1)
	local data = {
		ID = "Shajar al-Durr has a new ability",
		Message = "$11257153", -- Select Shajar al-Durr
		DataTemplate = "LeftClickTrainingDataTemplate",
	}
	UI_CreateTagForSquad(squad, data)
end

function untag()
	local squad = SGroup_GetSpawnedSquadAt(sg_shajar, 1)
	UI_DestroyTagForSquad(squad)
end

function skipBaybarsTimer()
	skip_activated = true
	BAIBARS_DELAY = 20
	Player_GetAllSquadsNearMarker(player2, sg_temp, mkr_skip_kill)
	SGroup_Kill(sg_temp)
end