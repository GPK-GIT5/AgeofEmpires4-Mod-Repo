function Mission_SetupPlayers()
	content_pack = CONTENT_PACK_ABBASID_CAMPAIGN
	
	player1 = World_GetPlayerAt(1)
	player2 = World_GetPlayerAt(2)	
	player3 = World_GetPlayerAt(3)	

	Setup_SetPlayerName(player1, "$11253227")
	Setup_SetPlayerName(player2, "$11250539") --Franks
	Setup_SetPlayerName(player3, "$11253227")
	
	Player_SetMaximumAge(player1, AGE_CASTLE)
	Player_SetMaximumAge(player2, AGE_CASTLE)
	Player_SetMaximumAge(player3, AGE_CASTLE)
	
	PlayerColour_Enable()
	Game_SetPlayerSlotColour(player1, COLOR_BLUE)
    Game_SetPlayerSlotColour(player2, COLOR_RED)
	Game_SetPlayerSlotColour(player3, COLOR_YELLOW)
	
	Game_SetPlayerUISlotColour(player1, COLOR_BLUE)
    Game_SetPlayerUISlotColour(player2, COLOR_RED)
	Game_SetPlayerUISlotColour(player3, COLOR_YELLOW)
	
	Player_SetRelationship(player1, player3, R_ALLY)
	Player_SetRelationship(player3, player1, R_ALLY)
	World_EnableSharedLineOfSight(player1, player3, true)
end

function Mission_SetupVariables()	-- create any extra sgroups, egroups, and mission variables in here
	print("SetupVariables")
	InitData1()
end

function Mission_Preset()	-- any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)	
	print("Preset")
	InitData2()

	for _, player in ipairs({ player1, player3 }) do
		TechTree_GiveUnitUpgrades(player, 2, TT_INCLUDE_TIERED)
		TechTree_GiveEconUpgrades(player, 2, TT_INCLUDE_TIERED)
		TechTree_GiveEconUpgrades(player, 1, TT_INCLUDE_NON_TIERED)
		TechTree_GiveMilitaryUpgrades(player, 1, TT_INCLUDE_TIERED)
		TechTree_HideProductionByAge_UsingTypes(player, 3)
		
		Player_SetSquadProductionAvailability(player, SBP.AYYUBID_CMP.UNIT_NAVAL_XEBEC_AYY, ITEM_REMOVED)
		Player_SetSquadProductionAvailability(player, SBP.AYYUBID_CMP.UNIT_NAVAL_EXPLOSIVE_DHOW_AYY, ITEM_REMOVED)
		Player_SetSquadProductionAvailability(player, SBP.AYYUBID_CMP.UNIT_NAVAL_DHOW_AYY, ITEM_REMOVED)
		Player_SetSquadProductionAvailability(player, SBP.AYYUBID_CMP.UNIT_NAVAL_BAGHLAH_AYY, ITEM_REMOVED)
		Player_SetSquadProductionAvailability(player, SBP.AYYUBID_CMP.UNIT_NAVAL_TRADE_SHIP_AYY, ITEM_REMOVED)
		Player_SetSquadProductionAvailability(player, SBP.AYYUBID_CMP.UNIT_NAVAL_TRANSPORT_AYY, ITEM_REMOVED)
		Player_SetSquadProductionAvailability(player, SBP.AYYUBID_CMP.UNIT_TRADE_CART_AYY, ITEM_REMOVED)
		Player_SetSquadProductionAvailability(player, SBP.AYYUBID_CMP.UNIT_TREBUCHET_AYY, ITEM_REMOVED)
		
		Player_SetUpgradeAvailability(player, UPG.COMMON.UPGRADE_NAVAL_ADDSAILS, ITEM_REMOVED)
