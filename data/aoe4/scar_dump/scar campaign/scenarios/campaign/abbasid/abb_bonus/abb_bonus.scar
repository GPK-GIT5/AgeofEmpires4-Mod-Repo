function Mission_SetupPlayers()
	content_pack = CONTENT_PACK_ABBASID_CAMPAIGN
	
	t_difficulty = {
		researchLevel = Util_DifVar({ 1, 2, 3, 4 }),
		researchInterval = Util_DifVar({ 420, 360, 300, 240 }),
		econMod = Util_DifVar({ 0.55, 0.70, 0.85, 1.0 }),
		unitCount_low = Util_DifVar({ 2, 3, 4, 5 }),
		unitCount_med = Util_DifVar({ 4, 6, 8, 10 }),
		unitCount_high = Util_DifVar({ 6, 9, 12, 15 }),
		raidSpawnMod = Util_DifVar({ 1.6, 1.4, 1.2, 1.0 })
	}
	
	player1 = World_GetPlayerAt(1)
	player2 = World_GetPlayerAt(2)
	player3 = World_GetPlayerAt(3)
	player4 = World_GetPlayerAt(4)
	player5 = World_GetPlayerAt(5)
	
	Setup_SetPlayerName(player1, LOC("Crusaders"))
	Player_SetCurrentAge(player1, AGE_DARK)
	Player_SetMaximumAge(player1, AGE_IMPERIAL)
	
	Setup_SetPlayerName(player2, LOC("Rival Crusaders")) 
	Player_SetCurrentAge(player2, AGE_CASTLE)
	Player_SetMaximumAge(player2, AGE_CASTLE)
	
	Setup_SetPlayerName(player3, LOC("The Holy Orders")) 
	Player_SetCurrentAge(player3, AGE_CASTLE)
	Player_SetMaximumAge(player3, AGE_CASTLE)
	
	Setup_SetPlayerName(player4, LOC("Ayyubid Allies"))
	Player_SetCurrentAge(player4, AGE_FEUDAL)
	Player_SetMaximumAge(player4, AGE_FEUDAL)
	
	Setup_SetPlayerName(player5, LOC("Byzantine Empire")) 
	Player_SetCurrentAge(player5, AGE_CASTLE)
	Player_SetMaximumAge(player5, AGE_CASTLE)
	
	Player_AddResource(player2, RT_Wood, 20000)
	Player_AddResource(player2, RT_Stone, 5000)
	Player_AddResource(player2, RT_Gold, 2000)
	
	Player_SetPopCapOverride(player2, 300)
	Player_SetPopCapOverride(player3, 300)
	Player_SetPopCapOverride(player5, 300)
	
	PlayerColour_Enable()
	
	player2_data = {
		player = player2,
		econMod = 0.8 * t_difficulty.econMod,
		econStrength = 0,
		econStrengthMin = 500 * t_difficulty.econMod,
		econStrengthMax = 1400 * t_difficulty.econMod,
		resourcePool = 0,
		initVillagerCount = 42,
		isActive = true
	}
	
	Player_CompleteUpgrade(player4, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_2)
	
	Player_CompleteUpgrade(player2, UPG.COMMON.UPGRADE_SIEGE_ENGINEERS)
	
	--Player_SetEntityProductionAvailability(player1, EBP.CRUSADER_CMP.BUILDING_LANDMARK_RED_PALACE_CRU, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.CRUSADER_CMP.BUILDING_LANDMARK_COLLEGE_OF_ARTILLERY_CRU, ITEM_REMOVED)
	
	Player_SetSquadProductionAvailability(player1, SBP.CRUSADER_CMP.UNIT_CANNON_ROYAL_CRU, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.CRUSADER_CMP.UNIT_CANNON_CRU, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.CRUSADER_CMP.UNIT_CULVERIN_CRU, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.CRUSADER_CMP.UNIT_CULVERIN_ROYAL_CRU, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.CRUSADER_CMP.UNIT_HANDCANNON_CRU, ITEM_REMOVED)
	
	Player_SetSquadProductionAvailability(player1, SBP.CRUSADER_CMP.UNIT_NAVAL_CARRACK_CRU, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.CRUSADER_CMP.UNIT_RIBAULDEQUIN_CRU, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.CRUSADER_CMP.UNIT_RIBAULDEQUIN_ROYAL_CRU, ITEM_REMOVED)
	
	Player_SetSquadProductionAvailability(player1, SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEMPLAR_CRU, ITEM_LOCKED)
	Player_SetSquadProductionAvailability(player1, SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEUTON_CRU, ITEM_LOCKED)
	Player_SetSquadProductionAvailability(player1, SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_HOSPITALLER_CRU, ITEM_LOCKED)
	
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_NAVAL_GALLEY_CANNON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_NAVAL_MOUNTED_GUNS, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_NAVAL_SWIVEL_CANNON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_OUTPOST_CANNON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_TOWER_CANNON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_KEEP_CANNON, ITEM_REMOVED)
	
	Player_SetSquadProductionAvailability(player1, SBP.CRUSADER_CMP.UNIT_RAM_TOWER_CRU, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player2, SBP.CRUSADER_CMP.UNIT_RAM_TOWER_CRU, ITEM_REMOVED)
	
	
	Player_SetRelationship(player1, player4, R_ALLY)
	Player_SetRelationship(player4, player1, R_ALLY)
	World_EnableSharedLineOfSight(player1, player4, true)

	Player_SetRelationship(player2, player4, R_ENEMY)
	Player_SetRelationship(player4, player2, R_ENEMY)
	
	Player_SetRelationship(player2, player3, R_ALLY)
	Player_SetRelationship(player3, player2, R_ALLY)
	
	Player_SetRelationship(player2, player5, R_ENEMY)
	Player_SetRelationship(player5, player2, R_ENEMY)
	
	Player_SetRelationship(player3, player5, R_ENEMY)
	Player_SetRelationship(player5, player3, R_ENEMY)

end

function Mission_SetupVariables()
	
	AbbBonus_InitData()
	AbbBonus_SetupAttackersData()
	
	AbbBonus_SetUnitTables()
	AbbBonus_SpawnInitUnits()
	
	AbbBonus_SetupPatrols()
	AbbBonus_SetupRaiders()
	
	AbbBonus_SetupUnitTables()
	AbbBonus_SetupTechData()
	
	AbbBonus_SetupAttackersP2()
end


function Mission_Preset()
	
	landmarks_built = 0
	
	Player_SetResource(player1, RT_Food, P1_FOOD)
	Player_SetResource(player1, RT_Wood, P1_WOOD)
	Player_SetResource(player1, RT_Gold, P1_GOLD)
	Player_SetResource(player1, RT_Stone, P1_STONE)
	
	AssignVillagersToWood(sg_p1_villagers_wood)
	AssignVillagersToGold(sg_p1_villagers_gold)
	AssignVillagersToFarms(sg_p1_villagers_farm)
	AssignVillagersToFish(sg_p1_villagers_fish)
	
	
	Cmd_InstantUpgrade(eg_p4_outposts, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	Cmd_InstantUpgrade(eg_p2_outposts_final, UPG.COMMON.UPGRADE_OUTPOST_STONE)
	
	if t_difficulty.researchLevel == 2 then
		Cmd_InstantUpgrade(eg_p2_outposts_final, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	end
	
	if t_difficulty.researchLevel >= 2 then
		--normal, hard, expert
		Cmd_InstantUpgrade(eg_p2_outposts, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
		Cmd_InstantUpgrade(eg_p2_st_outposts, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	end
	
	if t_difficulty.researchLevel >= 3 then
		--hard, expert
		Cmd_InstantUpgrade(eg_p2_outposts, UPG.COMMON.UPGRADE_OUTPOST_STONE)
		Cmd_InstantUpgrade(eg_p5_outposts, UPG.COMMON.UPGRADE_OUTPOST_SPRINGALD)
		Cmd_InstantUpgrade(eg_p2_outposts_final, UPG.COMMON.UPGRADE_OUTPOST_SPRINGALD)
	end
	
	if t_difficulty.researchLevel >= 4 then
		--expert
		Cmd_InstantUpgrade(eg_p2_st_outposts, UPG.COMMON.UPGRADE_OUTPOST_STONE)
		Cmd_InstantUpgrade(eg_p5_outposts, UPG.COMMON.UPGRADE_OUTPOST_STONE)
		Cmd_InstantUpgrade(eg_p5_keep, UPG.COMMON.UPGRADE_KEEP_SPRINGALD)
	end
	
	Game_SetPlayerSlotColour(player1, COLOR_BLUE)
	Game_SetPlayerUISlotColour(player1, COLOR_BLUE)
	
	Game_SetPlayerSlotColour(player2, COLOR_RED)
	Game_SetPlayerUISlotColour(player2, COLOR_RED)
	
	Game_SetPlayerSlotColour(player3, COLOR_ORANGE)
	Game_SetPlayerUISlotColour(player3, COLOR_ORANGE)
	
	Game_SetPlayerSlotColour(player4, COLOR_YELLOW)
	Game_SetPlayerUISlotColour(player4, COLOR_YELLOW)
	
	Game_SetPlayerSlotColour(player5, COLOR_PURPLE)
	Game_SetPlayerUISlotColour(player5, COLOR_PURPLE)
	
	Rule_Add(MonitorLandmarks)
	
	Rule_AddInterval(UpdateTech, t_difficulty.researchInterval)
	Rule_AddGlobalEvent(AbbBonus_OnConstructionComplete, GE_ConstructionComplete)
end

function AbbBonus_OnConstructionComplete(context)
	
	if Entity_IsOfType(context.entity, "landmark") then
		
		if landmarks_built == 0 then
			landmarks_built = 1
			if Objective_IsStarted(OBJ_EstablishTrade) == false then
				
				Objective_Start(OBJ_EstablishTrade, true, true)
				Rule_RemoveMe()
			end
		end
	end
end


function Mission_PreStart()
	AbbBonus_SetObjectiveConstants()
	AbbBonus_RegisterObjectives()
	AbbBonus_Capture_Init()
end

function Mission_Start()
	
	AbbBonus_InitVillagerCountP2()
	
	--LocalCommand_SquadEntity(player1, sg_p1_ship_trade, SCMD_Trade, eg_p4_dock, false)	
	LocalCommand_SquadEntity(player1, sg_p1_ship_fish, SCMD_Gather, eg_p1_fish, false)
	
	LocalCommand_SquadEntity(player2, sg_p2_ship_fish1, SCMD_Gather, eg_p2_fish1, false)
	LocalCommand_SquadEntity(player2, sg_p2_ship_fish2, SCMD_Gather, eg_p2_fish2, false)
	LocalCommand_SquadEntity(player2, sg_p2_ship_fish3, SCMD_Gather, eg_p2_fish3, false)
	LocalCommand_SquadEntity(player2, sg_p2_ship_fish4, SCMD_Gather, eg_p2_fish4, false)
	LocalCommand_SquadEntity(player2, sg_p2_ship_fish5, SCMD_Gather, eg_p2_fish5, false)
	
	--Objective_Start(OBJ_CaptureControlPoints, true, true)
	Objective_Start(OBJ_DestroyLandmarks, true, true)
	
	AbbBonus_SetupHolyOrders()
	
	AbbBonus_CreatePatrol(player2, units_p2_cav_patrol1, "sg_p2_cav_patrol1", "mkr_p2_patrol1_", 8)
	AbbBonus_CreatePatrol(player2, units_p2_cav_patrol2, "sg_p2_cav_patrol2", "mkr_p2_patrol3_", 4)
	AbbBonus_CreatePatrol(player2, units_p2_inf_patrol1, "sg_p2_inf_patrol1", "mkr_p2_patrol2_", 5)
	
	AbbBonus_CreatePatrol(player2, units_p2_spears_low, "sg_p2_spear_patrol1", "mkr_p2_patrol4_", 2)
	AbbBonus_CreatePatrol(player2, units_p2_spears_low, "sg_p2_spear_patrol2", "mkr_p2_patrol5_", 2)
	AbbBonus_CreatePatrol(player2, units_p2_spears_low, "sg_p2_spear_patrol3", "mkr_p2_patrol6_", 2)
	AbbBonus_CreatePatrol(player2, units_p2_spears_low, "sg_p2_spear_patrol4", "mkr_p2_patrol7_", 3)
	
	Rule_AddOneShot(AbbBonus_StartRaidersP2, 180)
	
	Rule_AddOneShot(AbbBonus_StartDocksObjective, 600) --to do: this should also start on approach
	Rule_AddOneShot(AbbBonus_StartNavalRaiders, 600)
	
	Rule_AddOneShot(AbbBonus_StartAttackersP2, 60)
	
	AbbBonus_Reinforce_Init()
end

function MonitorLandmarks(context, data)
	
	local eg_landmarks = Player_GetAllEntitiesFromType(player1, "landmark")
	local landmarks_remaining = 0
	
	local _Check = function(gid, idx, eid)
		
		if Entity_GetStateModelBool(eid, "landmark_active") then
			landmarks_remaining = landmarks_remaining + 1
		end
	end
	EGroup_ForEach(eg_landmarks, _Check)
	
	if landmarks_remaining == 0 then
		Mission_Fail()
	end

end

function UpdateTech(context, data)
	
	if p2_tech_index <= #p2_techData then
		Player_CompleteUpgrade(player2, p2_techData[p2_tech_index])
		p2_tech_index = p2_tech_index + 1
	end
end


