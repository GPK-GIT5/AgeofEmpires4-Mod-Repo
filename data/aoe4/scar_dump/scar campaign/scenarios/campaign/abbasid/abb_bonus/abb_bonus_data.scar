function AbbBonus_SetupAttackersP2()
	
	p2_unitMix = {
		{"spearman", "archer", "spearman", "archer", "spearman", "crossbowman", "spearman", "spearman", "ram"},
		{"spearman", "crossbowman", "spearman", "manatarms", "archer", "ram"},
		{"manatarms", "spearman", "manatarms", "crossbowman", "manatarms", "crossbowman", "ram"},
		{"manatarms", "crossbowman", "manatarms", "spearman", "manatarms", "horseman", "mangonel", "ram"},
		{"manatarms", "crossbowman", "knight", "manatarms", "crossbowman", "mangonel", "ram"},
		{"manatarms", "knight", "horseman", "manatarms", "crossbowman", "mangonel", "ram", "trebuchet"},
		{"manatarms", "crossbowman", "manatarms", "crossbowman", "knight", "mangonel", "trebuchet"},
	}
	
	local p2_army_params = {
		player = player2,
		name = "p2_attack_army",
		targets = { mkr_p2_attack_rally },
		targetOrder = TARGET_ORDER_LINEAR,
		ramsBuiltWhenBlocked = 1,
		units = {
			{type = "scar_manatarms", numSquads = 3},
			{type = "scar_ram", numSquads = 1},
		},
		sgroup = SGroup_CreateIfNotFound("sg_p2_attack_army")
	}
	
	p2_attack_army = Army_Init(p2_army_params)
	
	p2_attackers1 = {
		player = player2,
		sgroup = SGroup_CreateIfNotFound("sg_p2_attackers1"),
		army = p2_attack_army,
		attack_targets = { 
			mkr_p2_attack_path1,
			mkr_p2_attack_path2, 
			mkr_p2_attack_path3, 
			mkr_p2_attack_path4, 
			mkr_p2_attack_path5, 
			mkr_p2_attack_path6, 
			mkr_p1_base, 
		},
		end_target = mkr_p1_base,
		capture_target = nil,
		currentCount = 0,
		targetCount = 15,
		targetCountMin = 15,
		targetCountMax = 50,
		attacksPlayerBase = true,
		currentState = "reinforce",
		unitMix = p2_unitMix,
		unitTable = p2_unitTable,
		unitMixIndex = 1,
		rallyMarker = mkr_p2_attack_rally,
	}

end

