	P1_WOOD = 200
	P1_GOLD = 150
	P1_STONE = 100
	
	--P1 init unit counts
	P1_VILLAGERS_WOOD = 2
	P1_VILLAGERS_GOLD = 2
	P1_VILLAGERS_FARM = 5
	P1_VILLAGERS_FISH = 1
	
	ARMY_INACTIVE_RANGE = 30
	ARMY_WAIT_NONE = 0
	ARMY_WAIT_SHORT = 2
	ARMY_WAIT_LONG = 5
	
	SIEGE_LIMIT = 3
	
	currentUnitIndex = 1 --used for attacks
end


function GetRecipe()
	local recipe = {		
		introNIS = EVENTS.Intro,
		outroNIS = EVENTS.Victory,
		
		-- Locations
		locations = {
			{ 
				descriptor = "Templar Keep",
				marker = mkr_p3_templars,
				marker_spawn = mkr_p3_templar_final_spawn,
				player = player3,
				egroup = eg_p3_templars,
				sgroup_defenders = {sg_templars},
				extraVillagerCount = Util_DifVar({0, 0, 0, 0}),
			},
			{ 
				descriptor = "Teutonic Keep",
				marker = mkr_p3_teutons,
				marker_spawn = mkr_p3_teuton_final_spawn,
				player = player3,
				egroup = eg_p3_teutons,
				sgroup_defenders = {sg_teutons},
				extraVillagerCount = Util_DifVar({0, 0, 0, 0}),
			},
			{ 
				descriptor = "Hospitaller Keep",
				marker = mkr_p3_hospitallers,
				marker_spawn = mkr_p3_hospitaller_final_spawn,
				player = player3,
				egroup = eg_p3_hospitallers,
				sgroup_defenders = {sg_hospitallers},
				extraVillagerCount = Util_DifVar({0, 0, 0, 0}),
			}
		},
		
		-- Modules
		modules = {
			
			--P2 MODULES
			{
				type = "Army",
				name = "army_p2_defend1",
				player = player2,
				targetOrder = TARGET_ORDER_PATROL,
				targets = { mkr_p2_defend1 },
				units = { 
					{type = "scar_manatarms", numSquads = t_difficulty.unitCount_low},
					{type = "scar_crossbowman", numSquads = t_difficulty.unitCount_low}
				},
				combatRange = 50
			},
			{
				type = "Army",
				name = "army_p2_defend2",
				player = player2,
				targetOrder = TARGET_ORDER_PATROL,
				targets = { mkr_p2_defend2 },
				units = { 
					{type = "scar_spearman", numSquads = t_difficulty.unitCount_med},
					{type = "scar_crossbowman", numSquads = t_difficulty.unitCount_low}
				},
				combatRange = 50
			},
			{
				type = "Army",
				name = "army_p2_defend3",
				player = player2,
				targetOrder = TARGET_ORDER_PATROL,
				targets = { mkr_p2_defend3 },
				units = { 
					{type = "scar_manatarms", numSquads = t_difficulty.unitCount_low},
					{type = "scar_crossbowman", numSquads = t_difficulty.unitCount_med}
				},
				combatRange = 50
			},
			{
				type = "Army",
				name = "army_p2_defend4",
				player = player2,
				targetOrder = TARGET_ORDER_PATROL,
				targets = { mkr_p2_defend4 },
				units = { 
					{type = "scar_manatarms", numSquads = t_difficulty.unitCount_low},
					{type = "scar_crossbowman", numSquads = t_difficulty.unitCount_low}
				},
				combatRange = 50
			},
			{
				type = "Army",
				name = "army_p2_defend5",
				player = player2,
				targetOrder = TARGET_ORDER_PATROL,
				targets = { mkr_p2_defend5 },
				units = { 
					{type = "scar_manatarms", numSquads = t_difficulty.unitCount_med},
					{type = "scar_crossbowman", numSquads = t_difficulty.unitCount_med},
					{type = "scar_mangonel", numSquads = 1},
				},
				combatRange = 50
			},
			{
				type = "Army",
				name = "army_p2_st1_defend",
				player = player2,
				targetOrder = TARGET_ORDER_PATROL,
				targets = { mkr_p2_st1_defend },
				units = { 
					{type = "scar_spearman", numSquads = t_difficulty.unitCount_low},
					{type = "scar_manatarms", numSquads = t_difficulty.unitCount_low},
					{type = "scar_crossbowman", numSquads = t_difficulty.unitCount_med}
				},
				combatRange = 50
			},
			
			--P3 MODULES
			{
				type = "Army",
				name = "army_p3_templars",
				player = player3,
				targetOrder = TARGET_ORDER_PATROL,
				targets = { mkr_p3_templar_army },
				units = { 
					{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEMPLAR_MASTER_CRU, numSquads = 1},
					{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEMPLAR_CRU, numSquads = t_difficulty.unitCount_low},
					{type = "scar_crossbowman", numSquads = t_difficulty.unitCount_low}
				},
				combatRange = 30
			},
			{
				type = "Army",
				name = "army_p3_teutons",
				player = player3,
				targetOrder = TARGET_ORDER_PATROL,
				targets = { mkr_p3_teuton_army },
				units = { 
					{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEUTON_MASTER_CRU, numSquads = 1},
					{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEUTON_CRU, numSquads = t_difficulty.unitCount_med},
				},
				combatRange = 30
			},
			{
				type = "Army",
				name = "army_p3_hospitallers",
				player = player3,
				targetOrder = TARGET_ORDER_PATROL,
				targets = { mkr_p3_hospitaller_army },
				units = { 
					{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_HOSPITALLER_MASTER_CRU, numSquads = 1},
					{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_HOSPITALLER_CRU, numSquads = t_difficulty.unitCount_high},
				},
				combatRange = 30
			},
			
			
			
			--P5 MODULES
			{
				type = "Army",
				name = "army_p5_naval_defend1",
				player = player5,
				targetOrder = TARGET_ORDER_PATROL,
				targets = { mkr_p5_ship1 },
				units = {{sbp = SBP.BYZANTINE.UNIT_NAVAL_COMBAT_SHIP_2_BYZ, numSquads = 1}},
				combatRange = 50
			},
			{
				type = "Army",
				name = "army_p5_naval_defend2",
				player = player5,
				targetOrder = TARGET_ORDER_PATROL,
				targets = { mkr_p5_ship2 },
				units = {{sbp = SBP.BYZANTINE.UNIT_NAVAL_COMBAT_WARSHIP_4_BYZ, numSquads = 1}},
				combatRange = 50
			},
			
		}
	}
	
	for i, army in ipairs(recipe.modules) do
		if #army.targets == 1 then
			
			army.activeRange = Marker_GetProximityRadiusOrDefault(army.targets[1], 45)
			army.targets[1] = {
				position = Marker_GetPosition(army.targets[1]),
				combatRange = ARMY_INACTIVE_RANGE,
			}
			army.useCustomDirection = true
		end
	end
	
	return recipe
end


