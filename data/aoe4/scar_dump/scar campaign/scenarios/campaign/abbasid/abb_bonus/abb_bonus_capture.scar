function AbbBonus_Capture_MergeTemplars()
	local army = Army_FindFromName("army_p3_templars")
	Army_AddSGroup(army, sg_templars)
end

function AbbBonus_Capture_MergeTeutons()
	local army = Army_FindFromName("army_p3_teutons")
	Army_AddSGroup(army, sg_teutons)
end

function AbbBonus_Capture_MergeHospitallers()
	local army = Army_FindFromName("army_p3_hospitallers")
	Army_AddSGroup(army, sg_hospitallers)
end
