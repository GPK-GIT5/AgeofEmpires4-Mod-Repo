import("cardinal.scar")
import("MissionOMatic/MissionOMatic.scar")

function AbbBonus_Capture_Init()
	
	OBJ_SubdueHolyOrders = {
		Title = "Subdue the Holy Orders",
		Type = ObjectiveType_Capture,
		IsComplete = function()
			return Objective_AreSubObjectivesComplete(OBJ_SubdueHolyOrders, ALL)
		end,
		OnComplete = function()
			if Objective_IsComplete(OBJ_DestroyLandmarks) then
				Mission_Complete()
			end
		end,
	}
	
	Objective_Register(OBJ_SubdueHolyOrders)
	
	AbbBonus_Capture_InitTemplars()
	AbbBonus_Capture_InitTeutons()
	AbbBonus_Capture_InitHospitallers()
end


function AbbBonus_Capture_InitTemplars()

	local location = LOCATION("Templar Keep")
	
	SOBJ_CaptureTemplarKeep = {
		Title = "Capture Templar Keep", -- Capture Templar Keep
		Type = ObjectiveType_Capture,
		Parent = OBJ_SubdueHolyOrders,
		StartAlongsideParent = true,
		
		SetupUI = function()
			Location_SetCapturable(LOCATION("Templar Keep"), true)
		end,
		
		PreComplete = function()
			Sound_Play2D("sfx_campaign_scripted_medium_group_celebrate")
		end,
		OnComplete = function()
			
			local units_templars = {
				{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEMPLAR_MASTER_CRU, numSquads = 1},
				{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEMPLAR_CRU, numSquads = 3},
			}
			
			CreateUnits(player1, units_templars, mkr_p3_templar_final_spawn, "sg_p1_templars")
			Player_SetSquadProductionAvailability(player1, SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEMPLAR_CRU, ITEM_DEFAULT)
		end,
	}
	
	SOBJ_DefeatTemplarResistance = {
		Title = "Defeat Templar Resistance", -- Defeat Templar Resistance
		Type = ObjectiveType_Battle,
		Parent = OBJ_SubdueHolyOrders,
		OnStart = function()
			Rule_AddOneShot(AbbBonus_Capture_MergeTemplars, 10)
		end,
	}
	
	SOBJ_LocationTemplarKeep = {
		Title = LOC("Templar Keep"), -- Templar Keep
		Type = ObjectiveType_Capture,
		Parent = OBJ_SubdueHolyOrders,
	}
	
	Objective_Register(SOBJ_CaptureTemplarKeep)
	Objective_Register(SOBJ_DefeatTemplarResistance)
	Objective_Register(SOBJ_LocationTemplarKeep)
	
	location.objectiveMaster = OBJ_SubdueHolyOrders
	location.objectivePrimary = SOBJ_CaptureTemplarKeep
	location.objectiveSecondary = SOBJ_DefeatTemplarResistance
	location.objectiveCapture = SOBJ_LocationTemplarKeep
	
end

