function Hattin_SpawnBarricadeAllies()
	allied_infantry_common_markers = AllMarkers_FromName("mkr_ally_spears", "")
	allied_archer_common_markers = AllMarkers_FromName("mkr_ally_archers", "")
	
	--Spawn Common Infantry Allied Armies
	for i, marker in pairs(allied_infantry_common_markers) do
		local params = {
			player = player4,
			name = "barricade_spears_"..i,
			spawn = marker,
			target = marker,
			useCustomDirection = true,
			direction = Marker_GetDirection(marker),
			units = {
				{type="scar_spearman", numSquads = 2},
			},
		}
		local thisArmy = Army_Init(params)
		Cmd_Ability(thisArmy.sgroup, BP_GetAbilityBlueprint("core_formation_line"))
	end
		
	--Spawn Archer Allied Armies
	for i, marker in pairs(allied_archer_common_markers) do
		local params = {
			player = player4,
			name = "barricade_archer_"..i,
			spawn = marker,
			target = marker,
			useCustomDirection = true,
			direction = Marker_GetDirection(marker),
			units = {
				{type="scar_archer", numSquads = 2},
			},
		}
		local thisArmy = Army_Init(params)
		Cmd_Ability(thisArmy.sgroup, BP_GetAbilityBlueprint("core_formation_line"))
		Cmd_Ability(thisArmy.sgroup, BP_GetAbilityBlueprint("combat_unit_hold_position"), nil, nil, nil, true)
	end
end

function EGroup_CountEntitiesNearMarker(egroup, pos, range)

	if range == nil then 
		if scartype(pos) == ST_MARKER then 
			range = Marker_GetProximityRadiusOrDefault(pos, -1)
			if range == -1 then 
				fatal("EGroup_CountEntitiesNearMarker: Marker has no range, and no override was provided")
			end				
		else
			fatal("EGroup_CountEntitiesNearMarker: No range value provided, and pos wasn't a marker to use its range as default")
		end
	end
	
	range = range * range 		-- we're going to use Util_GetDistanceSquared to avoid an unnecessary square root calculation, so square the range first
	local count = 0
	
	local _CheckEntity = function(gid, idx, eid)
		if Util_GetDistanceSquared(eid, pos) <= range then 
			count = count + 1
		end
	end

	EGroup_ForEach(egroup, _CheckEntity)

	return count	
	
end

function SGroup_CountSquadsNearMarker(sgroup, pos, range)

	if range == nil then 
		if scartype(pos) == ST_MARKER then 
			range = Marker_GetProximityRadiusOrDefault(pos, -1)
			if range == -1 then 
				fatal("SGroup_CountSquadsNearMarker: Marker has no range, and no override was provided")
			end				
		else
			fatal("SGroup_CountSquadsNearMarker: No range value provided, and pos wasn't a marker to use its range as default")
		end
	end
	
	range = range * range 		-- we're going to use Util_GetDistanceSquared to avoid an unnecessary square root calculation, so square the range first
	local count = 0	
	
	local _CheckSquad = function(gid, idx, sid)
		if Util_GetDistanceSquared(sid, pos) <= range then 
			count = count + 1
		end
	end
	SGroup_ForEach(sgroup, _CheckSquad)
	
	return count 
	
end

function Hattin_ReinforceAsNeeded(context, data)
	-- How many military units?
	Player_GetAll(player1)
	SGroup_Filter(sg_allsquads, "military", FILTER_KEEP)
	local troopTotal = SGroup_CountSpawned(sg_allsquads)
	if troopTotal >= 40 then
		return
	end
		
	local roomToSpare = Player_GetCurrentPopulationCap(player1, CT_Personnel) - Player_GetCurrentPopulation(player1, CT_Personnel)
	if roomToSpare < 4 then
		return
	end
	
	-- Cavalry are all 1 pop each so this is fine
	local factor = math.min(roomToSpare, 40) / 8.0
	local reinforcementUnits = {
		{ type = "scar_camel_rider", numSquads = math.max(1, 3.0 * factor)},
		{ type = "scar_knight", numSquads = math.max(1, 3.0 * factor)},
		{ type = "scar_horsearcher", numSquads = math.max(1, 2.0 * factor)},
	}
	
	sg_player_reinforcements = SGroup_CreateIfNotFound("sg_player_reinforcements")
	SGroup_Clear(sg_player_reinforcements)
	CreateUnits(player1,reinforcementUnits, mkr_reinforcement_spawn, sg_player_reinforcements, Marker_GetDirection(mkr_reinforcement_spawn))
	MissionOMatic_SGroupCommandDelayed(sg_player_reinforcements, mkr_reinforcement_rally, true, 1)
	EventCues_CallToAction("$11256540", CTA_CELEBRATE, nil, nil, sg_player_reinforcements, 10, "icons/cta/illustrations/player_reinforcement_arrived")
	--UI_CreateMinimapBlip(mkr_reinforcement_spawn, 6, "general")
	-- Since we've "produced" new units, reset that timer
	g_lastGoodProductionTime = World_GetGameTime()
end