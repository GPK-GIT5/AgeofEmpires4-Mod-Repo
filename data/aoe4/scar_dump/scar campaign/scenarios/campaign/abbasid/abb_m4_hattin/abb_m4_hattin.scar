function Mission_SetDifficulty()

end

function Mission_SetRestrictions()	-- set up any restrictions (i.e. locking out units, etc) in here
	
	TechTree_GiveAllUpgrades_ByAge(player1, 2, TT_INCLUDE_BOTH)
	
end

function Mission_Preset()	-- any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)	

	print("Playing Mission_Preset!")
	BurnTutorial_InitObjectives()
	Crusaders_InitObjectives()
	
	BurnableFields_Init()

	-- set the entire map to explored
	Mission_ExploreMap()		-- some shenanigans needed to make sure the buildings of Tiberias are visible, so call out to a script to do the reveal/unreveal magic
	
	-- register the leader
	if SGroup_CountSpawned(sg_saladin) >= 1 then 
		local squad = SGroup_GetSpawnedSquadAt(sg_saladin, 1)
		LeaderTent_RegisterLeader(squad)
	end
	
	-- Nil all starting resources for the tutorial
	Player_SetResource(player1, RT_Food, 0)
	Player_SetResource(player1, RT_Wood, 0)
	Player_SetResource(player1, RT_Gold, 0)
	Player_SetResource(player1, RT_Stone, 0)
	
	-- Increased health based on difficulty/console status
	PlayerUpgrades_ApplyHealthBonuses(player1)
	Player_ModifyAyyubidMilitaryBuildTimes(player1, Util_DifVar({ 0.5, 0.75, 1, 1 }))
	
	-- Place the allies in nice lines
	-- Blocking the road to Tiberias
	Cmd_Ability(sg_allies_roadblock, BP_GetAbilityBlueprint("core_formation_line"))
	Cmd_FormationMove(sg_allies_roadblock, mkr_ally_roadblock, false, false, mkr_ally_roadblock_b_facing)
	
	-- Temporarily make sure players can't control most units
	Player_GetAll(player1)
	SGroup_RemoveGroup(sg_allsquads, sg_tutorial_infantry)
	
	-- Spawn extra spearmen for the tutorial
	CreateUnitsInsideEGroup(player8, {{type = "scar_spearman", numSquads = 4}}, eg_tutorial_outpost, sg_extra_spearmen)
	
	SGroup_AddGroup(sg_playerUnitsDisabled, sg_allsquads)
	EGroup_AddEGroup(eg_playerBuildingsDisabled, eg_allentities)
	
	SGroup_SetPlayerOwner(sg_playerUnitsDisabled, player4)
	EGroup_SetPlayerOwner(eg_playerBuildingsDisabled, player4)
	print("Player units not selectable (except Tutorial units)")
	
	-- tell the villagers to go resource gathering
	AssignVillagersToFarms(sg_villagers_farms)
	AssignVillagersToBerries(sg_villagers_berries)
	AssignVillagersToWood(sg_villagers_wood)
	AssignVillagersToStone(sg_villagers_stone)
	AssignVillagersToGold(sg_villagers_gold)
	
	Modify_SightRadius(eg_spotters, 2)
	
	EGroup_SetInvulnerable(eg_tiberias_walls, true)
	EGroup_SetSelectable(eg_tiberias_walls, false)
	
	-- Turn of neutral minimap clutter
	Player_GetAll(player7)
	EGroup_EnableMinimapIndicator(eg_allentities, false)
	SGroup_EnableMinimapIndicator(sg_allsquads, false)
	Player_GetAll(player8)
	EGroup_EnableMinimapIndicator(eg_allentities, false)
	SGroup_EnableMinimapIndicator(sg_allsquads, false)
	
	-- DEBUG: Autotest
	AutoTest_OnInit()
	
	FoodReserves_Init()
end

function Mission_PreStart()
	print("Playing Mission_PreStart!")
	
	SGroup_RemoveAbility(sg_tutorial_infantry, BP_GetAbilityBlueprint("core_unit_death"))
	SGroup_AddGroup(sg_scuttle_removed, sg_tutorial_infantry)
end

function Mission_Start()	-- this is triggered after the intro, just as control is passed to the player
	
	print("Playing Mission_Start!")
	BurnTutorial_Start()
	
	Rule_AddInterval(Mission_CheckEndConditions, 1)
	
end

function Mission_ExploreMap()		-- simply using FOW_ExploreAll left enemy buildings invisible, so this reveal/unreveal trick works better
	FOW_RevealAll()
	Rule_AddOneShot(Mission_ExploreMap_PartB, 0.25)
end
function Mission_ExploreMap_PartB()
	FOW_UnRevealAll()
end

function Mission_CheckEndConditions()
	-- wait for the crusaders to actually be spawned first!
	if b_allCrusadersSpawned == true then
		local THRESHOLD = 15 
		if SGroup_CountSpawned(sg_crusaders) + SGroup_CountSpawned(sg_crusaders_fled) < THRESHOLD then
			Objective_Complete(SOBJ_DefeatReynald)		
			Rule_RemoveMe()
		else
			if SGroup_CountSquadsNearMarker(sg_crusaders, mkr_tiberias) >= THRESHOLD then 
				-- they rescued tiberias 
				Objective_Fail(OBJ_Crusaders)
				Rule_RemoveMe()	
			end
		end
	end
end

