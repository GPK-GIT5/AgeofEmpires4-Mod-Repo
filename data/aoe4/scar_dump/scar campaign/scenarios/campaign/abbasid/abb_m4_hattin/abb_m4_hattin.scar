--
-- Hattin 1187
--
-- Abbasid campaign, mission 4
--

import("MissionOMatic/MissionOMatic.scar")		-- this imports the Cardinal scripts as well
import("abb_m4_hattin_automated.scar")
import("abb_m4_hattin_data.scar")
import("obj_crusaders.scar")
import("obj_burningfields.scar")
import("obj_tutorial.scar")

MissionOMatic_UpdateHolyOrderFlags()

function Mission_SetupPlayers()
	content_pack = CONTENT_PACK_ABBASID_CAMPAIGN
	--
	-- get player IDs for each player
	-- 
	
	player1 = World_GetPlayerAt(1) -- Saladin
	player2 = World_GetPlayerAt(2) -- Crusaders
	player3 = World_GetPlayerAt(3) -- Tiberias defenders
	player4 = World_GetPlayerAt(4) -- Jamal ad-Din Hajji				(Allied units)
	player5 = World_GetPlayerAt(5) -- G�kb�ri							(DEPRECATED)
	player6 = World_GetPlayerAt(6) -- Ally 3 							(allies permanently siegeing Tiberias)
	player7 = World_GetPlayerAt(7) -- Burnable fields					(needs to be a player so I can make them targetable)
	player8 = World_GetPlayerAt(8) -- Neutral Houses and Towers 		(needs to be a player so I can share LOS with them)
	
	-- player 1 - Saladin
	Setup_SetPlayerName(player1, "$11253243")
	for _, player in ipairs({ player1, player4 }) do
		Player_CompleteUpgrade(player, UPG.AYYUBID_CMP.UPGRADE_MIL_PARTHIAN_TACTICS_AYY)
		Player_CompleteUpgrade(player, UPG.COMMON.UPGRADE_RANGED_INCENDIARY)
	end
	-- This also ages them up, so no need to do that manually or in the Player settings
	EGroup_CompleteUpgrade(eg_houseofwisdom, UPG.ABBASID.UPGRADE_ADD_MILITARY_WING)
	EGroup_CompleteUpgrade(eg_houseofwisdom, UPG.ABBASID.UPGRADE_ADD_CULTURE_WING_FEUDAL)
	Player_SetUpgradeAvailability(player1, UPG.AYYUBID_CMP.UPGRADE_ADD_TRADE_WING_AYY, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.AYYUBID_CMP.UPGRADE_ADD_TRADE_WING_FEUDAL_AYY, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.AYYUBID_CMP.UPGRADE_ADD_TRADE_WING_CASTLE_AYY, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.AYYUBID_CMP.UPGRADE_ADD_TRADE_WING_IMPERIAL_AYY, ITEM_REMOVED)
	Player_SetStateModelBool(player1, "military_wing_built_abb", true)
	Player_SetStateModelBool(player1, "culture_wing_built_abb", true)
	EGroup_SetAnimatorVariable(eg_houseofwisdom, "military_wing_build_progress_abb", 1)
	EGroup_SetAnimatorVariable(eg_houseofwisdom, "culture_wing_build_progress_abb", 1)
	Modify_EntityMaxHealth(eg_houseofwisdom, 10000, MUT_Addition)
	Player_SetCurrentAge(player1, AGE_CASTLE)
	Player_SetMaximumAge(player1, AGE_CASTLE)
	TechTree_HideProductionByAge_UsingTypes(player1, AGE_CASTLE)
	
	-- No anti-wall siege units allowed (we'll allow artillery since it's functional against units)
	Player_SetSquadProductionAvailability(player1, SBP.AYYUBID_CMP.UNIT_RAM_AYY, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.AYYUBID_CMP.UNIT_SIEGE_TOWER_AYY, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.AYYUBID_CMP.UNIT_RAM_AYY, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.AYYUBID_CMP.UNIT_SIEGE_TOWER_AYY, ITEM_REMOVED)
	-- No wall construction allowed!
	Player_SetEntityProductionAvailability(player1, EBP.AYYUBID_CMP.BUILDING_DEFENSE_PALISADE_AYY, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.AYYUBID_CMP.BUILDING_DEFENSE_PALISADE_BASTION_AYY, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.AYYUBID_CMP.BUILDING_DEFENSE_PALISADE_GATE_AYY, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.AYYUBID_CMP.BUILDING_DEFENSE_WALL_AYY, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.AYYUBID_CMP.BUILDING_DEFENSE_WALL_BASTION_AYY, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.AYYUBID_CMP.BUILDING_DEFENSE_WALL_GATE_AYY, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.AYYUBID_CMP.BUILDING_DEFENSE_TOWER_AYY, ITEM_REMOVED)

	-- player 2 - Crusaders	
	Setup_SetPlayerName(player2, "$11250539") --Franks
	Player_SetCurrentAge(player2, AGE_CASTLE)
	Player_SetMaximumAge(player2, AGE_CASTLE)
	Player_CompleteUpgrade(player2, UPG.COMMON.UPGRADE_SIEGE_WEAPON_SPEED)

	-- player 3 - Tiberias defenders
	Setup_SetPlayerName(player3, "$11253244")
	Player_SetCurrentAge(player3, AGE_CASTLE)
	Player_SetMaximumAge(player3, AGE_CASTLE)

	-- player 4 - Jamal ad-Din Hajji
	Setup_SetPlayerName(player4, "$11253245")
	Player_SetCurrentAge(player4, AGE_CASTLE)
	Player_SetMaximumAge(player4, AGE_CASTLE)
	Cmd_InstantUpgrade(eg_outposts_hattin_allies, UPG.COMMON.UPGRADE_OUTPOST_STONE)
	Cmd_InstantUpgrade(eg_outposts_hattin_allies, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	
	-- player 5 - G�kb�ri
	Setup_SetPlayerName(player5, "$11250716")
	Player_SetCurrentAge(player5, AGE_CASTLE)
	Player_SetMaximumAge(player5, AGE_CASTLE)

	-- player 6 - Ally 3
	Setup_SetPlayerName(player6, "$11253247")
	
	-- player 7 - Burnable fields (shows up the same as player 8 - Neutral - but is actually an enemy so you can attack the fields and set them alight)
	Setup_SetPlayerName(player7, "$11253248")
	
	-- player 8 - Neutral houses and towers
	Setup_SetPlayerName(player8, "$11253249")
	
	--
	-- set player relationships	
	--
	
	Player_SetRelationship(player1, player2, R_ENEMY)	-- player 1 - Saladin
	Player_SetRelationship(player1, player3, R_ENEMY)
	Player_SetRelationship(player1, player4, R_ALLY)
	Player_SetRelationship(player1, player5, R_ALLY)
	Player_SetRelationship(player1, player6, R_ALLY)
	Player_SetRelationship(player1, player7, R_ENEMY)
	Player_SetRelationship(player1, player8, R_ALLY)	
	
	Player_SetRelationship(player2, player1, R_ENEMY)	-- player 2 - Crusaders	
	Player_SetRelationship(player2, player3, R_ALLY)
	Player_SetRelationship(player2, player4, R_ENEMY)
	Player_SetRelationship(player2, player5, R_ALLY)
	Player_SetRelationship(player2, player6, R_ENEMY)
	Player_SetRelationship(player2, player7, R_ALLY)
	Player_SetRelationship(player2, player8, R_NEUTRAL)
	
	Player_SetRelationship(player3, player1, R_ENEMY)	-- player 3 - Frankish Tiberias defenders
	Player_SetRelationship(player3, player2, R_ALLY)
	Player_SetRelationship(player3, player4, R_ENEMY)
	Player_SetRelationship(player3, player5, R_ENEMY)
	Player_SetRelationship(player3, player6, R_ENEMY)
	Player_SetRelationship(player3, player7, R_ALLY)
	Player_SetRelationship(player3, player8, R_NEUTRAL)
	
	Player_SetRelationship(player4, player1, R_ALLY)	-- player 4 - Jamal ad-Din Hajji
	Player_SetRelationship(player4, player2, R_ENEMY)
	Player_SetRelationship(player4, player3, R_ENEMY)
	Player_SetRelationship(player4, player5, R_ALLY)
	Player_SetRelationship(player4, player6, R_ALLY)
	Player_SetRelationship(player4, player7, R_NEUTRAL)
	Player_SetRelationship(player4, player8, R_ALLY)	
	
	Player_SetRelationship(player5, player1, R_ALLY)	-- player 5 - G�kb�ri (holds Tiberias)
	Player_SetRelationship(player5, player2, R_ALLY)
	Player_SetRelationship(player5, player3, R_ENEMY)
	Player_SetRelationship(player5, player4, R_ALLY)
	Player_SetRelationship(player5, player6, R_ALLY)
	Player_SetRelationship(player5, player7, R_NEUTRAL)
	Player_SetRelationship(player5, player8, R_ALLY)	
	
	Player_SetRelationship(player6, player1, R_ALLY)	-- player 6 - Ally 3
	Player_SetRelationship(player6, player2, R_ENEMY)
	Player_SetRelationship(player6, player3, R_ENEMY)
	Player_SetRelationship(player6, player4, R_ALLY)
	Player_SetRelationship(player6, player5, R_ALLY)
	Player_SetRelationship(player6, player7, R_NEUTRAL)
	Player_SetRelationship(player6, player8, R_ALLY)	
	
	Player_SetRelationship(player7, player1, R_ALLY)	-- player 7 - Burnable fields
	Player_SetRelationship(player7, player2, R_NEUTRAL)
	Player_SetRelationship(player7, player3, R_NEUTRAL)
	Player_SetRelationship(player7, player4, R_NEUTRAL)
	Player_SetRelationship(player7, player5, R_NEUTRAL)
	Player_SetRelationship(player7, player6, R_NEUTRAL)
	Player_SetRelationship(player7, player8, R_NEUTRAL)	

	Player_SetRelationship(player8, player1, R_NEUTRAL)	-- player 8 - Neutral houses and towers
	Player_SetRelationship(player8, player2, R_NEUTRAL)
	Player_SetRelationship(player8, player3, R_NEUTRAL)
	Player_SetRelationship(player8, player4, R_NEUTRAL)
	Player_SetRelationship(player8, player5, R_NEUTRAL)
	Player_SetRelationship(player8, player6, R_NEUTRAL)
	Player_SetRelationship(player8, player7, R_NEUTRAL)	
	
	World_EnableSharedLineOfSight(player1, player4, true)	-- may also have to configure shared line of sight
	World_EnableSharedLineOfSight(player1, player5, true)
	World_EnableSharedLineOfSight(player1, player6, true)
	World_EnableSharedLineOfSight(player1, player8, true)
	World_EnableSharedLineOfSight(player4, player1, true)
	World_EnableSharedLineOfSight(player4, player5, true)
	World_EnableSharedLineOfSight(player4, player6, true)
	World_EnableSharedLineOfSight(player4, player8, true)
	World_EnableSharedLineOfSight(player5, player1, true)
	World_EnableSharedLineOfSight(player5, player4, true)
	World_EnableSharedLineOfSight(player5, player5, true)
	World_EnableSharedLineOfSight(player5, player8, true)
	World_EnableSharedLineOfSight(player6, player1, true)
	World_EnableSharedLineOfSight(player6, player4, true)
	World_EnableSharedLineOfSight(player4, player5, true)
	World_EnableSharedLineOfSight(player4, player8, true)
	World_EnableSharedLineOfSight(player8, player1, true)
	World_EnableSharedLineOfSight(player8, player4, true)
	World_EnableSharedLineOfSight(player8, player5, true)
	World_EnableSharedLineOfSight(player8, player6, true)
	
	-- Make sure the Crusaders don't share LOS with the outposts or with Tiberias
	World_EnableSharedLineOfSight(player2, player5, false)
	World_EnableSharedLineOfSight(player2, player8, false)
	World_EnableSharedLineOfSight(player3, player8, false)
	World_EnableSharedLineOfSight(player5, player2, false)
	
	--
	-- set player colours
	--
	
	PlayerColour_Enable()							-- turn on custom colour configuration for this session
	
	Game_SetPlayerSlotColour(player1, 1) 			-- Saladin	(paint scheme)						(1 = blue - colour indexes specified in AE tuning_simulation -> ui/ui_player_colours)
	Game_SetPlayerUISlotColour(player1, 1)			--			(ui colour)
	
	Game_SetPlayerSlotColour(player2, 2) 			-- Crusaders									(2 = red)
	Game_SetPlayerUISlotColour(player2, 2)

	Game_SetPlayerSlotColour(player3, 7) 			-- Tiberias defenders							(7 = orange)
	Game_SetPlayerUISlotColour(player3, 7)
	
	Game_SetPlayerSlotColour(player4, 3) 			-- Jamal ad-Din Hajji							(3 = yellow)
	Game_SetPlayerUISlotColour(player4, 3)
	
	Game_SetPlayerSlotColour(player5, 4) 			-- G�kb�ri										(4 = green)
	Game_SetPlayerUISlotColour(player5, 4)
	
	Game_SetPlayerSlotColour(player6, 9) 			-- Ally 3										(5 = cyan)
	Game_SetPlayerUISlotColour(player6, 9)

	Game_SetPlayerSlotColour(player7, 9) 			-- Burnable fields								(9 = grey)
	Game_SetPlayerUISlotColour(player7, 9)
	
	Game_SetPlayerSlotColour(player8, 9) 			-- Neutral houses and towers					(9 = grey)
	Game_SetPlayerUISlotColour(player8, 9)

	
	--
	-- set player upgrades
	--
	
	TechTree_GiveEconUpgrades(player1, 3, TT_INCLUDE_BOTH)
	TechTree_GiveMilitaryUpgrades(player1, 3, TT_INCLUDE_BOTH)
	TechTree_GiveUnitUpgrades(player1, 2, TT_INCLUDE_BOTH)
	Player_CompleteUpgrade(player1, UPG.AYYUBID_CMP.UPGRADE_CUL_MEDICAL_CENTERS_AYY)
	Player_CompleteUpgrade(player1, UPG.ABBASID.UPGRADE_MIL_CAMEL_ARCHERS_IMPROVED_WEAPON_ABB)
	Player_CompleteUpgrade(player1, UPG.ABBASID.UPGRADE_ECON_IMPROVED_CARRY_CAPACITY_ABB)
	Player_CompleteUpgrade(player1, UPG.ABBASID.UPGRADE_CUL_CHEAPER_RESEARCH_ABB)
	
	Player_SetUpgradeAvailability(player1, UPG.ABBASID.UPGRADE_TRADE_COMMODITY_TRADE_ABB, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.ABBASID.UPGRADE_TRADE_TRADER_ARMOR_ABB, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.AYYUBID_CMP.UPGRADE_FOOD_RESERVES_AYY, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.AYYUBID_CMP.UPGRADE_ECON_AGRICULTURE_AYY, ITEM_REMOVED)
	
	--
	-- disable AI for stub players
	--
	
	AI_Enable(player7, false)						-- Burnable fields	
	AI_Enable(player8, false)						-- Neutral houses and towers
	
	
end

