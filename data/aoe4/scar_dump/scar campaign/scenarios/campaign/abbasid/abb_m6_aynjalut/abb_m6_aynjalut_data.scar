function CreateLane(lane_name, min, max)
	min = min or 1
	max = max or 9999
	local index = min
	local path = {}
	while index <= max do
		local index_string = tostring(index)
		if index < 10 then
			index_string = "0"..index_string
		end
		local marker_name = "mkr_"..lane_name.."_"..index_string
		if Marker_Exists(marker_name, "") == false then
			break
		end
		local marker = Marker_FromName(marker_name, "")
		table.insert(path, marker)
		index = index + 1
	end
	return path
end

function CreateSlots(area_name)
	local slots = {}
	
	for _, letter in ipairs(slot_letters) do
		for _, number in ipairs(slot_numbers) do
			local marker_name = "mkr_"..area_name.."_"..letter..tostring(number)
			if Marker_Exists(marker_name, "") then
				local marker = Marker_FromName(marker_name, "")
				local key = letter..tostring(number)
				slots[key] = marker
			end
		end
	end
	return slots
end

