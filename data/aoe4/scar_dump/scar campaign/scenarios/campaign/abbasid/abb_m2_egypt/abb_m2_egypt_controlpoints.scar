--Control Point Data Managment--

--? @shortdesc Compiles the Control Point location data for all the control points in the mission.
--? @extdesc Evaluates eg_villagecenters to find all the control points in the mission. 
--  Then saves a table containing the location, owner, layout (nearby entities owned by the player owner), 
--  spins up garrison armies for both the player and the enemy, and finally a villager life module.
function Egypt_InitControlPointSystem()
	
	controlPoints = {}	
	for i = 1, EGroup_CountSpawned(eg_villagecenters) do
		local entity = EGroup_GetSpawnedEntityAt(eg_villagecenters, i)
		ControlPoint_Init(entity)
	end
end

function ControlPoint_GetID()
	controlPoint_index = controlPoint_index or 0
	controlPoint_index = controlPoint_index + 1
	return controlPoint_index
end

function ControlPoint_Init(eid)
	
	local index = ControlPoint_GetID()
	
	local controlPoint = {
		id = index,
		entityID = eid,
		currentowner = player5,
		previousowner = player5,
		deferedowner = player5,
		villageLayout = {},
		alliedGarrisonArmy = {},
		enemyGarrisonArmy = {},
		villageGarrisionType = "scar_militia",
		villageGarrisionSpawn = Util_GetPosition(eid),
		villageGarrisionSpawnRule = nil,
		--villLifeModule = {},
		villLifeMarker = {},
	}
	
	if World_OwnsEntity(eid) then
		controlPoint.currentowner = player5
		controlPoint.previousowner = player5
	else
		controlPoint.currentowner = Entity_GetPlayerOwner(eid)
		controlPoint.previousowner = controlPoint.currentowner 
	end
	
	local defered_owner = player5
	if controlPoint.currentowner == player1 then
		defered_owner = player3
	elseif controlPoint.currentowner == player2 then
		defered_owner = player4
	else
		defered_owner = player5
	end
	controlPoint.defered_owner = defered_owner
	
	SaveVillageLayout(controlPoint, defered_owner)
	
	SGroup_MakeOrClear("sg_temp_vlife_roam")
	SGroup_MakeOrClear("sg_temp_vlife_farm")
	
	local pos = Util_GetPosition(controlPoint.entityID)
	controlPoint.villLifeMarker = Marker_Create("mkr_villhome_"..index, "Prefab", pos, pos, 40)
	--controlPoint.villLifeModule = New_VillLife(controlPoint, defered_owner)
	
	--Save player allied garrison
	Init_Garrison(controlPoint, player3)
	--Save enemy allied garrison
	Init_Garrison(controlPoint, player4)
		
	table.insert(controlPoints, controlPoint)
	return controlPoint
	
end

--? @shortdesc Monitoring function for Control Point owner changes.
--? On change set new owner in the controlPoints table, rebuild structures, and convert/restart villager life.
function _Egypt_ControlPoint_Monitor()
	
	if controlPoints ~= nil then
		
		local _ControlPoint_StatusUpdate = function(gid, index, eid)
			local controlPoint = controlPoints[index]
			if World_OwnsEntity(controlPoint.entityID) == false then
				
				controlPoint.currentowner = Entity_GetPlayerOwner(controlPoint.entityID)
				if controlPoint.currentowner ~= controlPoint.previousowner and controlPoint.currentowner ~= player5 then
					
					-- DILLON: Look into why currentowner and previousowner are both being passed as player
					VOCue_ControlPointTaken_MultiUse(controlPoint.currentowner, controlPoint.previousowner)
					
					controlPoint.previousowner = controlPoint.currentowner
					Rebuild_Location(controlPoint)
					Convert_Location_VillLife(controlPoint)
				end
			end
		end
		EGroup_ForEach(eg_villagecenters, _ControlPoint_StatusUpdate)
	end
	
end

--? @shortdesc Init function for Control Point status at mission start.
function Egypt_ControlPoint_MissionStart()
		
	if controlPoints ~= nil then
		
		local _ControlPoint_StatusUpdate = function(gid, index, eid)
			local controlPoint = controlPoints[index]
			if World_OwnsEntity(controlPoint.entityID) == false then
								
				controlPoint.currentowner = Entity_GetPlayerOwner(controlPoint.entityID)
				if controlPoint.currentowner ~= player5 then
					
					controlPoint.previousowner = controlPoint.currentowner
					SaveVillageLayout(controlPoint, player5) 
					Rebuild_Location(controlPoint)
					Convert_Location_VillLife(controlPoint)
				end
			end
		end
		EGroup_ForEach(eg_villagecenters, _ControlPoint_StatusUpdate)
	end
end

