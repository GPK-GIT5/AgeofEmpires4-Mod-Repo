--? @shortdesc Given a string name it will create a new sgroup if one of that name does not exist, if it does it clears it of squads.
--? @args string name
function SGroup_MakeOrClear(name)
	if SGroup_Exists(name) then
		SGroup_Clear(SGroup_FromName(name))
	else
		_G[name] = SGroup_CreateIfNotFound(name)
	end
end
