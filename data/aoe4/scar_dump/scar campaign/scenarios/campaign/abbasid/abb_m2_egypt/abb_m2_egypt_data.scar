--Difficulty--
function Init_Egypt_Difficulty()
	
	-- Add Horsemen numbers to globals so they can be used to determine the parade size in the intro cam.
	-- (The Util_DifVar table is resolved to a single value when the mission loads.)
	
	g_horsemen_easy = 10
	g_horsemen_normal = 10 
	g_horsemen_hard = 5
	g_horsemen_expert = 5
	
	t_difficulty = 
	{
		difficultyLevel = Game_GetSPDifficulty(),
		
		playerMods = { --t_difficulty.playerMods
			STARTING_SPEARMEN = Util_DifVar({10, 10, 5, 5}), --t_difficulty.playerMods.STARTING_SPEARMEN
			STARTING_ARCHERS = Util_DifVar({10, 10, 5, 5}), --t_difficulty.playerMods.STARTING_ARCHERS
			STARTING_HORSEMEN = Util_DifVar({g_horsemen_easy, g_horsemen_normal, g_horsemen_hard, g_horsemen_expert}), --t_difficulty.playerMods.STARTING_HORSEMEN
		},
	
		
		enemyMods = { --t_difficulty.enemyMods
			--starting 180/200/210/260
			STARTING_SPEARMEN = Util_DifVar({40, 40, 50, 80}), --t_difficulty.enemyMods.STARTING_SPEARMEN
			STARTING_ARCHERS = Util_DifVar({100, 100, 100, 80}), --t_difficulty.enemyMods.STARTING_ARCHERS
			STARTING_MANATARMS = Util_DifVar({20, 30, 40, 50}), --t_difficulty.enemyMods.STARTING_MANATARMS
			STARTING_HORSEMEN = Util_DifVar({20, 50, 40, 50}), --t_difficulty.enemyMods.STARTING_HORSEMEN
			
			STARTING_ARMYBUDGET = Util_DifVar({20, 30, 50, 75}), --t_difficulty.enemyMods.STARTING_ARMYBUDGET
		
			attack_group_size = Util_DifVar({10, 10, 10, 15}), --t_difficulty.enemyMods.attack_group_size
			ATTACK_GROUP_SIZE_ACCELERATION = Util_DifVar({0, 5, 5, 10}), --t_difficulty.enemyMods.ATTACK_GROUP_SIZE_ACCELERATION
			ATTACK_GROUP_SIZE_CEILING = Util_DifVar({10, 20, 40, 50}), --t_difficulty.enemyMods.ATTACK_GROUP_SIZE_CEILING
			ATTACK_INTERVAL = Util_DifVar({20, 20, 20, 15}), --t_difficulty.enemyMods.ATTACK_INTERVAL
			ATTACK_ACCELERATION = Util_DifVar({5, 5, 10, 5}), --t_difficulty.enemyMods.ATTACK_ACCELERATION
			ATTACK_INTERVAL_FLOOR = Util_DifVar({15, 10, 5, 5}), --t_difficulty.enemyMods.ATTACK_INTERVAL_FLOOR
		
			QUADRANT_COOLDOWN = Util_DifVar({90, 90, 30, 10}), --t_difficulty.enemyMods.QUADRANT_COOLDOWN
			
			HOSTILECHECK_RADIUS = Util_DifVar({100, 100, 100, 100}), --t_difficulty.enemyMods.HOSTILECHECK_RADIUS
			AVOID_HOSTILE_COUNT_MULITPLIER = Util_DifVar({0, 1, 1.5, 2}), --t_difficulty.enemyMods.AVOID_HOSTILE_COUNT_MULITPLIER
			RANGE_PRIORITY_MULTIPLIER = Util_DifVar({1.5, 1, 0.5, 0}), --t_difficulty.enemyMods.RANGE_PRIORITY_MULTIPLIER
			
			AI_AGGRESSION_EMPTYLOCATION = Util_DifVar({200, 1200, 2000, 10}), --t_difficulty.enemyMods.AI_AGGRESSION_EMPTYLOCATION
			AI_AGGRESSION_WEAKLOCATION = Util_DifVar({200, 400, 800, 1200}),--t_difficulty.enemyMods.AI_AGGRESSION_WEAKLOCATION
			AI_AGGRESSION_FORTIFIEDLOCATION = Util_DifVar({200, 400, 400, 800}), --t_difficulty.enemyMods.AI_AGGRESSION_FORTIFIEDLOCATION
			AI_AGGRESSION_LOSINGMULTIPLIER = Util_DifVar({1, 1.2, 2, 3}), --t_difficulty.enemyMods.AI_AGGRESSION_LOSINGMULTIPLIER
						
		},
	}
end

function Init_Egypt_Data()
	
	OFFSETS_ALL = {OFFSET_FRONT, OFFSET_BACK, OFFSET_LEFT, OFFSET_RIGHT, OFFSET_BACK_LEFT, OFFSET_FRONT_RIGHT, OFFSET_BACK_RIGHT, OFFSET_FRONT_LEFT}	
	LAYER_SIZES = 15
	
	Quadrants_Init()
	
	--Enemy Army Variables
	t_enemy_armies = {}
	t_enemy_armies_atCamp = {}
	egypt_crusader_army_ID = egypt_crusader_army_ID or 0
	
	--Tuning Values
	CONTROLPOINT_WAVEVALUE = 5
	UNNOCUPIED_HEATBUFFER = 2000
	
	ENEMY_SQUAD_TYPES = {typeList = {"scar_archer", "scar_spearman", "scar_horseman", "scar_militia"}, currentInt = 1}
end

