	if Game_GetSPDifficulty() <= GD_NORMAL then
		local berry_vills = { {type="scar_villager", numSquads = t_difficulty.playerMods.BERRY_VILLAGERS}, }
		sg_berryvills = CreateUnits(player1, berry_vills, mkr_player_vills_wood, "sg_berryvills")
		AssignVillagersToBerries(sg_berryvills)
	else
		EGroup_DestroyAllEntities(eg_player_mill)
	end
	
