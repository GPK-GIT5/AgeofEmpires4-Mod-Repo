			ACRE_ARCHER_SIZE = Util_DifVar({4, 5, 6, 8}), --t_difficulty.enemyMods.ACRE_ARCHER_SIZE 
	
			ACRE_ANTISIEGE_ENGINE_SIZE = Util_DifVar({0, 1, 1, 2}), --t_difficulty.enemyMods.ACRE_ANTISIEGE_ENGINE_SIZE 
			ACRE_ANTISIEGE_GUARD_SIZE = Util_DifVar({0, 2, 4, 8}), --t_difficulty.enemyMods.ACRE_ANTISIEGE_GUARD_SIZE 
	
			ACRE_CAVALRY_PATROL_SIZE = Util_DifVar({4, 4, 4, 6}), --t_difficulty.enemyMods.ACRE_CAVALRY_PATROL_SIZE
			ACRE_CAVALRY_PATROL_SGT = Util_DifVar({0, 1, 2, 3}), --t_difficulty.enemyMods.ACRE_CAVALRY_PATROL_SGT 
			
			ACRE_SHIP_SIZE = Util_DifVar({3, 2, 3, 4}), --t_difficulty.enemyMods.ACRE_SHIP_SIZE 
