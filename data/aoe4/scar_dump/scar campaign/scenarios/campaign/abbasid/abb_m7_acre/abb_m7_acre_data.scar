	}   
	
	UnitEntry_DeploySquads(player1, {sg_playerunits, sg_playerunits_forward}, forward_units, mkr_siege_camp_units)
	
	--local home_units = {
		--{type="scar_spearman", numSquads = t_difficulty.playerMods.STARTING_SPEARMEN/2},
		--{type="scar_archer", numSquads = t_difficulty.playerMods.STARTING_ARCHERS/2},
		--{type="scar_manatarms", numSquads = t_difficulty.playerMods.STARTING_MANATARMS*0.25},
	--}
	
	--UnitEntry_DeploySquads(player1, {sg_playerunits, sg_playerunits_rear}, home_units, mkr_home_camp)
	
	local gold_vills = { {type="scar_villager", numSquads = 3}, }
