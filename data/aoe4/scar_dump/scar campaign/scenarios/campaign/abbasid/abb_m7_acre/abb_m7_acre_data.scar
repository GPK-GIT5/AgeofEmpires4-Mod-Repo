	--local stone_vills = { {type="scar_villager", numSquads = 2}, }
	--sg_stonevills = CreateUnits(player1, stone_vills, mkr_player_vills_stone, "sg_stonevills")
	--AssignVillagersToStone(sg_stonevills)
	
	local wood_vills = { {type="scar_villager", numSquads = t_difficulty.playerMods.STARTING_VILLAGERS}, }
	sg_woodvills = CreateUnits(player1, wood_vills, mkr_player_vills_wood, "sg_woodvills")
