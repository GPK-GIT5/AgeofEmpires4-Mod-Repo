	sg_playerunits_forward = SGroup_CreateIfNotFound("sg_playerunits_forward")
	sg_playerunits_rear = SGroup_CreateIfNotFound("sg_playerunits_rear")
	
	local forward_units = {
		{type="scar_scout", numSquads = 2},
		{type="scar_spearman", numSquads = t_difficulty.playerMods.STARTING_SPEARMEN},
		{type="scar_archer", numSquads = t_difficulty.playerMods.STARTING_ARCHERS},
		{type="scar_manatarms", numSquads = t_difficulty.playerMods.STARTING_MANATARMS},
		{type="scar_horseman", numSquads = t_difficulty.playerMods.STARTING_HORSEMEN},
