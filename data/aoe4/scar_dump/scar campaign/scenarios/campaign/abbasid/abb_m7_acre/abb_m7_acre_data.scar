function Acre_InitAlliedUnits()
	
	Allied_Defense_Armies = {}
		
	--Spawn Common Infantry Allied Armies
	for i, marker in pairs(allied_infantry_common_markers) do
		local params = {
			player = player3,
			name = "allied_spears_"..i,
			spawn = marker,
			target = marker,
			useCustomDirection = true,
			direction = Util_GetDirectionFromAtoB(marker, mkr_crusader_spawning),
			units = {
				{type="scar_spearman", numSquads = t_difficulty.enemyMods.ACRE_COMMON_INFANTRY_SIZE},
			},
		}
		local thisArmy = Army_Init(params)
		table.insert(Allied_Defense_Armies, thisArmy)
		Cmd_Ability(thisArmy.sgroup, BP_GetAbilityBlueprint("core_formation_line"))
	end
		
	--Spawn Archer Allied Armies
	for i, marker in pairs(allied_archer_common_markers) do
		local params = {
			player = player3,
			name = "allied_archer_"..i,
			spawn = marker,
			target = marker,
			useCustomDirection = true,
			direction = Util_GetDirectionFromAtoB(marker, mkr_crusader_spawning),
			units = {
				{type="scar_archer", numSquads = t_difficulty.enemyMods.ACRE_ARCHER_SIZE},
			},
		}
		local thisArmy = Army_Init(params)
		table.insert(Allied_Defense_Armies, thisArmy)
		Cmd_Ability(thisArmy.sgroup, BP_GetAbilityBlueprint("core_formation_line"))
	end
	
	Rule_AddOneShot(Replace_Allied_Units, t_difficulty.playerMods.ALLY_RESPAWN_DELAY)
		
end

function Replace_Allied_Units()
	local allyRespawnDelay = t_difficulty.playerMods.ALLY_RESPAWN_DELAY
	local bulk_allyRespawnDelay = allyRespawnDelay+10
	local nextRun = allyRespawnDelay
	for i, army in ipairs(Allied_Defense_Armies) do
		if army.idealUnits ~= nil then
			local idealCount = UnitTable_CountUnits(army.idealUnits)
			if SGroup_IsEmpty(army.sgroup) == true then
				SGroup_Clear(sg_temp)
				CreateUnits(player3, army.idealUnits, mkr_ally_spawn, sg_temp)
				Cmd_Ability(sg_temp, BP_GetAbilityBlueprint("core_formation_line"))
				Army_AddSGroup(army, sg_temp)
				Cmd_FormationAttackMove(sg_temp, army.spawn.marker)
				nextRun = allyRespawnDelay+(idealCount*bulk_allyRespawnDelay)
				break
			elseif SGroup_CountSpawned(army.sgroup) < idealCount then
				local missingUnits = idealCount - SGroup_CountSpawned(army.sgroup)
				local units = {type=army.idealUnits[1].type, numSquads = missingUnits}			
				SGroup_Clear(sg_temp)
				CreateUnits(player3, units, mkr_ally_spawn, sg_temp)
				Cmd_Ability(sg_temp, BP_GetAbilityBlueprint("core_formation_line"))
				Army_AddSGroup(army, sg_temp)
				Cmd_FormationAttackMove(sg_temp, army.spawn.marker)
				nextRun = allyRespawnDelay+(missingUnits*bulk_allyRespawnDelay)
				break
			end
		end	
	end
	
	Rule_AddOneShot(Replace_Allied_Units, nextRun)
	
end

function Init_StoryModeItems()
	eg_tutorial_relic = EGroup_CreateIfNotFound("eg_tutorial_relic")
	sg_tutorial_monk = SGroup_CreateIfNotFound("sg_tutorial_monk")
	CreateEntity(player1, BP_GetEntityBlueprint("relic"), mkr_story_relic, eg_tutorial_relic) 
	CreateUnits(player1, {type = "scar_monk", numSquads = 1}, mkr_story_imam, sg_tutorial_monk)
end

function _Monitor_WaterRuins()
	sg_playersquads_at_ruins = SGroup_CreateIfNotFound("sg_playersquads_at_ruins")
	
	if Game_GetSPDifficulty() >= GD_EXPERT then
		_Monitor_NavyTransports()
	else	
		Player_GetAllSquadsNearMarker(player1, sg_playersquads_at_ruins, mkr_naval_landing)
		SGroup_Filter(sg_playersquads_at_ruins, "scar_villager", FILTER_KEEP)
		if SGroup_IsAlive(sg_playersquads_at_ruins) then
			_Monitor_NavyTransports()
		end
	end
	
end

function _Monitor_NavyTransports()
	if EGroup_CountSpawned(eg_enemy_docks) > 0 then
		sg_navytransports = SGroup_CreateIfNotFound("sg_navytransports")
		local MAX_TRANSPORTS = t_difficulty.enemyMods.NAVAL_MAX_TRANSPORTS 
		
		local livingTransportsCount = SGroup_CountSpawned(sg_navytransports)
		
		if livingTransportsCount < MAX_TRANSPORTS then
			local spawn = Get_ValidEnemySpawn_Naval()
			local units = {type="scar_transport_ship", numSquads = 1}
			CreateUnits(player2, units, Util_GetPosition(spawn), sg_navytransports)	
			SGroup_AddGroup(sg_all_enemy_ships, sg_navytransports)
		end
	else
		Rule_RemoveMe()
	end
end

function SpawnEnemy_FrankishMarines()
	sg_navytransports = SGroup_CreateIfNotFound("sg_navytransports")
	sg_navyinfantry = SGroup_CreateIfNotFound("sg_navyinfantry")
	SGroup_Clear(sg_navyinfantry)
	
	navyLandingID = navyLandingID or 1
	if SGroup_CountSpawned(sg_navytransports) > 0 then
		local sg_validtransports = SGroup_Duplicate(sg_navytransports, sg_temp)
		SGroup_FilterByProximity(sg_temp, mkr_naval_spawn, FILTER_KEEP, 60)
		
		local units = {
			{type="scar_archer", numSquads = t_difficulty.enemyMods.ACRE_ARCHER_SIZE},
			{type="scar_manatarms", numSquads = t_difficulty.enemyMods.ACRE_ELITE_INFANTRY_SGT},
		}
		
		local _SpawnUnitsInEachShip = function(gid, index, sid)
			if Squad_CanHold(sid) and Squad_GetHoldSlotsAvailable(sid) > 12 then
				CreateUnitsInsideSquad(player2, units, sid, sg_navyinfantry)
			end
		end
		
		SGroup_ForEach(sg_temp, _SpawnUnitsInEachShip)
		
		if SGroup_CountSpawned(sg_navyinfantry) > 0 then
			local params = {
				player = player2,
				name = "enemy_navy_transports_"..navyLandingID,
				spawn = mkr_naval_spawn,
				targets = {mkr_naval_landing}, 
				transport_ships = sg_temp,
				sgroup = sg_navyinfantry, 
				onCompleteFunction = _RuinsAttack_TransitionToLand,
				ARMYID = navyLandingID,
			}
			local thisArmy = Army_Init(params)
			navyLandingID = navyLandingID+1
		end
	end
end

function _RuinsAttack_TransitionToLand(army)
	local params = {
		player = player2,
		name = "ruins_naval_attack_"..army.ARMYID,
		spawn = mkr_naval_landing,
		targets = {mkr_naval_landing, mkr_player_vills_gold, mkr_player_vills_wood, mkr_siege_camp}, 
		sgroup = army.sgroup, 
		onDeathDissolve = true,
	}
	local thisArmy = Army_Init(params)

	Army_Dissolve(army)
	Cmd_AttackMove(army.transport_ships, mkr_naval_spawn)
end

function Flank_Warning()
	sg_navytransports = SGroup_CreateIfNotFound("sg_navytransports")
	if SGroup_CountSpawned(sg_navytransports) > 0 then
		if Util_GetDistanceSquared(sg_navytransports, mkr_naval_landing) <= 125^2 then
			if Player_CanSeeSGroup(player1, sg_navytransports, ANY) then
				if bFirstFlank == true then
					EventCues_CallToAction("$11255648", CTA_ALARM, nil, EVENTS.FlankingAttack, sg_navytransports, 20, "icons/cta/illustrations/announce_incoming_attack_naval") --Enemy transport on our flank!
					UI_CreateMinimapBlip(sg_navytransports, 5, "threat_group")
					bFirstFlank = false
				else
					UI_CreateEventCue("$11255648", Loc_Empty(), "high_priority_negative", "icons/event_queue_high_priority_large", "sfx_ui_event_queue_high_priority_play", ECV_Title|ECV_Queue, 12) --Enemy transport on our flank!
					UI_CreateMinimapBlip(sg_navytransports, 5, "threat_group")
				end
				Rule_RemoveMe()
				if EGroup_CountSpawned(eg_enemy_docks) > 0 then
					Rule_AddOneShot(Flank_Warning_Cooldown, 45)
				end
			end
		end
	end
end

function Flank_Warning_Cooldown()
	Rule_AddInterval(Flank_Warning, 1)
end

--Returns 1 of 2 results depending on a difficulty split at GD_EASY, GD_NORMAL, GD_HARD, or GD_EXPERT
function Difficulty_Split(lowerDiff, lower, higher)
	if Game_GetSPDifficulty() <= lowerDiff then
		return lower
	else
		return higher
	end
end
