function Acre_InitTuningValues()
	Acre_EnemyArmies = {
		INFANTRY = {}, --Acre_EnemyArmies.INFANTRY
		ELITE_INFANTRY = {}, --Acre_EnemyArmies.ELITE_INFANTRY
		ARCHERS = {}, --Acre_EnemyArmies.ARCHERS
		ANTISIEGE = {}, --Acre_EnemyArmies.ANTISIEGE
		TEMPLAR = {}, --Acre_EnemyArmies.TEMPLAR
		HOSPITALIER = {}, --Acre_EnemyArmies.HOSPITALIER
		TEUTON = {}, --Acre_EnemyArmies.TEUTON
		CAVALRY = {}, --Acre_EnemyArmies.CAVALRY
		SHIPS = {}, --Acre_EnemyArmies.SHIPS
		ELITE_SHIPS = {}, --Acre_EnemyArmies.ELITE_SHIPS
	}
	All_Army_Distance_Sorted = {}
	ReverseDist_ArmySorted = {}
	
	All_Navy_Distance_Sorted = {}
	ReverseDist_NavySorted = {}
	
	counterAttackAmount = t_difficulty.enemyMods.COUNTER_ATTACK_INITIAL_AMOUNT
	lastCounterAttackTime = -1000
end

function Acre_MarkerData()
	enemy_infantry_common_markers = AllMarkers_FromName("mkr_infantrydefenders_common", "")
	enemy_infantry_elite_markers = AllMarkers_FromName("mkr_infantrydefenders_elite", "")
	enemy_archer_markers = AllMarkers_FromName("mkr_wallarchers", "")
	enemy_antisiege_markers = AllMarkers_FromName("mkr_antisiege", "")
	enemy_templars_markers = AllMarkers_FromName("mkr_templars", "")
	enemy_hospitalier_markers = AllMarkers_FromName("mkr_hospitalier", "")
	enemy_teutons_markers = AllMarkers_FromName("mkr_teutons", "")
	enemy_ship_idle_markers = AllMarkers_FromName("mkr_ships_idle", "")

	enemy_cavalry_patrol_markers = {
		enemy_cavalry_patrol_markers_1 = AllMarkers_FromName("mkr_cavalry_patrol_1", ""),
		enemy_cavalry_patrol_markers_2 = AllMarkers_FromName("mkr_cavalry_patrol_2", ""),
		enemy_cavalry_patrol_markers_3 = AllMarkers_FromName("mkr_cavalry_patrol_3", "")
	}
	
	enemy_ship_patrol_markers = {
		enemy_ship_patrol_markers_1 = AllMarkers_FromName("mkr_ship_patrol_1", ""),
		enemy_ship_patrol_markers_2 = AllMarkers_FromName("mkr_ship_patrol_2", ""),
	}	
	
	allied_infantry_common_markers = AllMarkers_FromName("mkr_ally_spears", "")
	allied_archer_common_markers = AllMarkers_FromName("mkr_ally_archers", "")
	
	geneose_fleets = AllMarkers_FromName("mkr_geneose_spawn", "")
	geneose_landings = AllMarkers_FromName("mkr_genoese_landing", "")
	
	WARPATH_ALLIED_LEFT = {mkr_siege_camp_units, mkr_frontgate_left, mkr_frontgate_main, mkr_bridge_left, mkr_enemy_base_main}
	WARPATH_ALLIED_RIGHT = {mkr_siege_camp_allies_front, mkr_frontgate_right, mkr_frontgate_main, mkr_bridge_right, mkr_enemy_base_main}
	
	WARPATH_ENEMY_LEFT = {mkr_frontgate_main, mkr_frontgate_left, mkr_siege_camp}
	WARPATH_ENEMY_RIGHT = {mkr_frontgate_main, mkr_frontgate_right, mkr_siege_camp}
	
end

function Acre_InitMarkerArmies()
	acre_spawn_delay = acre_global_spawn_delay or 0
	local spawnTimer = 0.005 --0.125
	Acre_InitTuningValues()
	Init_Acre_Difficulty()
	Acre_MarkerData()
	
		-- Queue Spawn Ship Armies
	for i, marker in pairs(enemy_ship_idle_markers) do
		local params = {
			player = player2,
			name = "ship_defender_"..i,
			spawn = marker,
			units = {
				{sbp = SBP.CRUSADER_CMP.UNIT_NAVAL_GALLEY_CRU, numSquads = t_difficulty.enemyMods.ACRE_SHIP_SIZE},
				{sbp = SBP.CRUSADER_CMP.UNIT_NAVAL_HULK_CRU, numSquads = t_difficulty.enemyMods.ACRE_ELITE_SHIP_SIZE},
			},
		}
		Rule_AddOneShot(_Amoritize_EnemySpawns, acre_spawn_delay*spawnTimer, {params = params, parent_table = Acre_EnemyArmies.SHIPS, index = i, location = params.spawn, bWaterUnit = true})
		acre_spawn_delay = acre_spawn_delay+1
	end
	
	-- Queue Spawn Ship Patrols	
	for i, marker_table in pairs(enemy_ship_patrol_markers) do
		local params = {
			player = player2,
			name = "ship_patrol_"..i,
			spawn = marker_table[1],
			units = {
				{sbp = SBP.CRUSADER_CMP.UNIT_NAVAL_HULK_CRU, numSquads = t_difficulty.enemyMods.ACRE_SHIP_SIZE},
			},
			targets = marker_table,
    		targetOrder = TARGET_ORDER_PATROL,
		}
		Rule_AddOneShot(_Amoritize_EnemySpawns, acre_spawn_delay*spawnTimer, {params = params, parent_table = Acre_EnemyArmies.ELITE_SHIPS, index = i, location = params.spawn, bWaterUnit = true})
		acre_spawn_delay = acre_spawn_delay+1
	end
	
	-- Queue Spawn Common Infantry Armies
	for i, marker in pairs(enemy_infantry_common_markers) do
		local params = {
			player = player2,
			name = "common_infantry_defender_"..i,
			spawn = marker,
			units = {
				{type="scar_spearman", numSquads = t_difficulty.enemyMods.ACRE_COMMON_INFANTRY_SIZE},
				{type="scar_manatarms", numSquads = t_difficulty.enemyMods.ACRE_COMMON_INFANTRY_SGT},
			},
		}
		Rule_AddOneShot(_Amoritize_EnemySpawns, acre_spawn_delay*spawnTimer, {params = params, parent_table = Acre_EnemyArmies.INFANTRY, index = i, location = params.spawn})
		acre_spawn_delay = acre_spawn_delay+1
		
	end
	
	-- Queue Spawn Elite Infantry Armies
	for i, marker in pairs(enemy_infantry_elite_markers) do
		local params = {
			player = player2,
			name = "elite_infantry_defender_"..i,
			spawn = marker,
			units = {
				{type="scar_manatarms", numSquads = t_difficulty.enemyMods.ACRE_ELITE_INFANTRY_SIZE},
				{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEUTON_CRU, numSquads = t_difficulty.enemyMods.ACRE_ELITE_INFANTRY_SGT},
			},
		}
		Rule_AddOneShot(_Amoritize_EnemySpawns, acre_spawn_delay*spawnTimer, {params = params, parent_table = Acre_EnemyArmies.ELITE_INFANTRY, index = i, location = params.spawn})
		acre_spawn_delay = acre_spawn_delay+1
	end
	
	-- Queue Spawn Archer Armies
	for i, marker in pairs(enemy_archer_markers) do
		local params = {
			player = player2,
			name = "archer_defender_"..i,
			spawn = marker,
			units = {
				{type="scar_archer", numSquads = t_difficulty.enemyMods.ACRE_ARCHER_SIZE },
			},
		}
		Rule_AddOneShot(_Amoritize_EnemySpawns, acre_spawn_delay*spawnTimer, {params = params, parent_table = Acre_EnemyArmies.ARCHERS, index = i, location = params.spawn})
		acre_spawn_delay = acre_spawn_delay+1
	end
	
	-- Queue Spawn AntiSiege Armies
	for i, marker in pairs(enemy_antisiege_markers) do
		local lowerDiffUnits= {
			{type="scar_militia", numSquads = t_difficulty.enemyMods.ACRE_COMMON_INFANTRY_SIZE*2},
		}
		local higherDiffUnits = {
			{type="scar_springald", numSquads = t_difficulty.enemyMods.ACRE_ANTISIEGE_ENGINE_SIZE},
			{type="scar_manatarms", numSquads = t_difficulty.enemyMods.ACRE_ANTISIEGE_GUARD_SIZE},
		}
		local params = {
			player = player2,
			name = "antisiege_defender_"..i,
			spawn = marker,
			units = Difficulty_Split(GD_NORMAL, lowerDiffUnits, higherDiffUnits),
		}
		Rule_AddOneShot(_Amoritize_EnemySpawns, acre_spawn_delay*spawnTimer, {params = params, parent_table = Acre_EnemyArmies.ANTISIEGE, index = i, location = params.spawn})
		acre_spawn_delay = acre_spawn_delay+1
	end
	
	-- Queue Templar Armies
	for i, marker in pairs(enemy_templars_markers) do
		local params = {
			player = player2,
			name = "templar_defender_"..i,
			spawn = marker,
			units = {
				{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEMPLAR_CRU, numSquads = t_difficulty.enemyMods.ACRE_ELITE_INFANTRY_SIZE},
				{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEMPLAR_MASTER_CRU, numSquads = 1},
			},
		}
		Rule_AddOneShot(_Amoritize_EnemySpawns, acre_spawn_delay*spawnTimer, {params = params, parent_table = Acre_EnemyArmies.TEMPLAR, index = i, location = params.spawn})
		acre_spawn_delay = acre_spawn_delay+1
	end
	
	-- Queue Hospitalier Armies
	for i, marker in pairs(enemy_hospitalier_markers) do
		local params = {
			player = player2,
			name = "hospitalier_defender_"..i,
			spawn = marker,
			units = {
				{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_HOSPITALLER_CRU, numSquads = t_difficulty.enemyMods.ACRE_ELITE_INFANTRY_SIZE},
				{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_HOSPITALLER_MASTER_CRU, numSquads = 1},
			},
		}
		Rule_AddOneShot(_Amoritize_EnemySpawns, acre_spawn_delay*spawnTimer, {params = params, parent_table = Acre_EnemyArmies.HOSPITALIER, index = i, location = params.spawn})
		acre_spawn_delay = acre_spawn_delay+1
	end
	
	-- Queue Hospitalier Armies
	for i, marker in pairs(enemy_teutons_markers) do
		local params = {
			player = player2,
			name = "teuton_defender_"..i,
			spawn = marker,
			units = {
				{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEUTON_CRU, numSquads = t_difficulty.enemyMods.ACRE_ELITE_INFANTRY_SIZE},
				{sbp = SBP.CRUSADER_CMP.UNIT_HOLY_ORDER_TEUTON_MASTER_CRU, numSquads = 1},
			},
		}
		Rule_AddOneShot(_Amoritize_EnemySpawns, acre_spawn_delay*spawnTimer, {params = params, parent_table = Acre_EnemyArmies.TEUTON, index = i, location = params.spawn})
		acre_spawn_delay = acre_spawn_delay+1
	end
	
	-- Queue Spawn Cavalry Patrols	
	for i, marker_table in pairs(enemy_cavalry_patrol_markers) do
		local params = {
			player = player2,
			name = "cavalry_patrol_"..i,
			spawn = marker_table[1],
			units = {
				{type="scar_horseman", numSquads = t_difficulty.enemyMods.ACRE_CAVALRY_PATROL_SIZE},
				{type="scar_knight", numSquads = t_difficulty.enemyMods.ACRE_CAVALRY_PATROL_SGT},
			},
			targets = marker_table,
    		targetOrder = TARGET_ORDER_PATROL,
		}
		Rule_AddOneShot(_Amoritize_EnemySpawns, acre_spawn_delay*spawnTimer, {params = params, parent_table = Acre_EnemyArmies.CAVALRY, index = i, location = params.spawn})
		acre_spawn_delay = acre_spawn_delay+1
	end
			
	Rule_AddOneShot(Sort_Enemy_Tables_Distances, acre_spawn_delay*0.125)
end

function Compare_Army_Distance(armyA, armyB)
	return armyA.SIEGERANGE < armyB.SIEGERANGE
end

function Compare_Navy_Distance(navyA, navyB)
	return navyA.DOCKRANGE < navyB.DOCKRANGE
end

function Sort_Enemy_Tables_Distances()
	table.sort(All_Army_Distance_Sorted, Compare_Army_Distance)
	
	ReverseDist_ArmySorted = Clone(All_Army_Distance_Sorted, false)
	ReverseDist_ArmySorted = Table_Reverse(ReverseDist_ArmySorted)	
	
	table.sort(All_Navy_Distance_Sorted, Compare_Navy_Distance)
	
	ReverseDist_NavySorted = Clone(All_Navy_Distance_Sorted, false)
	ReverseDist_NavySorted = Table_Reverse(ReverseDist_NavySorted)	
	
	--Rule_AddEGroupEvent(_Monitor_Barrage_Used, eg_siegecamp, GE_AbilityExecuted)
	Rule_AddInterval(COUNTER_ATTACK, t_difficulty.enemyMods.COUNTER_ATTACK_TIMER)
end

function _Amoritize_EnemySpawns(context, data)
	local params = data.params
	local originalUnits = params.units
	local parent_table = data.parent_table
	local index = data.index
	local location = data.location
	local bWaterUnit = data.bWaterUnit
	local this = {}	
	
	if bWaterUnit == nil or bWaterUnit == false then
		this = Army_Init(params)
		this.SIEGERANGE = Util_GetDistanceSquared(mkr_siege_camp, location)
		this.ORIGINAL_UNITS = originalUnits
		table.insert(All_Army_Distance_Sorted, this)
		SGroup_EnableLeaderCrown(this.sgroup, false)
	else
		this = NavalArmy_Init(params)
		this.DOCKRANGE = Util_GetDistanceSquared(mkr_naval_spawn, location)
		this.ORIGINAL_UNITS = originalUnits
		table.insert(All_Navy_Distance_Sorted, this)
		SGroup_AddGroup(sg_all_enemy_ships, this.sgroup)
	end
	
	table.insert(parent_table, this)
end

function Acre_LaunchAttack()
		
		--Melee
		local MELEE = 
		{
			spawn = mkr_melee_spawn, 
			targets = {mkr_siege_camp},
			units = {
				{type="scar_spearman", numSquads=t_difficulty.enemyMods.ACRE_COMMON_INFANTRY_SIZE*4},
				{type="scar_manatarms", numSquads=t_difficulty.enemyMods.ACRE_COMMON_INFANTRY_SGT},
			},
		}
	
		--Militia
		local MILITIA = 
		{
			spawn = mkr_melee_spawn, 
			targets = {mkr_siege_camp},
			units = {
				{type="scar_militia", numSquads=t_difficulty.enemyMods.ACRE_COMMON_INFANTRY_SIZE*4},
			},
		}
		
		--Ranged
		local RANGED = 
		{
			spawn = mkr_ranged_spawn, 
			targets = {mkr_siege_camp},
			units = {
				{type="scar_archer", numSquads=t_difficulty.enemyMods.ACRE_ARCHER_SIZE*4},
				{type="scar_manatarms", numSquads=t_difficulty.enemyMods.ACRE_COMMON_INFANTRY_SGT},
			},
		}
		
		--Siege
		local SIEGE = 
		{
			spawn = mkr_siege_spawn, 
			targets = {mkr_siege_camp},
			units = {
				{type="scar_mangonel", numSquads= t_difficulty.enemyMods.ACRE_ANTISIEGE_ENGINE_SIZE},
				{type="scar_manatarms", numSquads= t_difficulty.enemyMods.ACRE_ANTISIEGE_GUARD_SIZE},
			},
		}
		
		--Cavalry
		local CAVALRY = 
		{			
			spawn = mkr_cavalry_spawn, 
			targets = {mkr_siege_camp},
			units = {
				{type="scar_horseman", numSquads=t_difficulty.enemyMods.ACRE_CAVALRY_PATROL_SIZE*4},
				{type="scar_knight", numSquads=t_difficulty.enemyMods.ACRE_CAVALRY_PATROL_SGT},
			},
		}
		
		local enemy_Targets = WARPATH_ENEMY_RIGHT
		local ally_Targets = WARPATH_ALLIED_RIGHT

		SGroup_Clear(sg_temp)
		Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_siege_camp_units)
		
		if SGroup_CountSpawned(sg_temp) <= 10 then
			enemy_Targets = WARPATH_ENEMY_LEFT
			ally_Targets = WARPATH_ALLIED_LEFT
		end
		
		local ENEMY_ATTACK_SEQUENCE = {}
		local ALLY_ATTACK_SEQUENCE = {}
		if Game_GetSPDifficulty() == GD_EASY then
			ENEMY_ATTACK_SEQUENCE = {CAVALRY, MELEE, RANGED, MELEE, MILITIA, MELEE, CAVALRY, RANGED, MILITIA, MELEE, CAVALRY, MILITIA, RANGED, MELEE}
			ALLY_ATTACK_SEQUENCE = {MELEE, RANGED, CAVALRY, SIEGE, CAVALRY, RANGED, MELEE, SIEGE, CAVALRY, RANGED, MELEE, CAVALRY, SIEGE, RANGED}
		else
			ENEMY_ATTACK_SEQUENCE =  {MELEE, RANGED, CAVALRY, SIEGE, CAVALRY, RANGED, MELEE, SIEGE, CAVALRY, RANGED, MELEE, CAVALRY, SIEGE, RANGED}
			ALLY_ATTACK_SEQUENCE =  {CAVALRY, MELEE, RANGED, MELEE, SIEGE, MELEE, CAVALRY, RANGED, SIEGE, MELEE, CAVALRY, SIEGE, RANGED, MELEE}
		end
		waveAttackNumber = waveAttackNumber or 1
		sequenceNumber = sequenceNumber or 1
		
		if sequenceNumber > #ENEMY_ATTACK_SEQUENCE then
			sequenceNumber = 1 
		end
		
		local enemy_WaveData = ENEMY_ATTACK_SEQUENCE[sequenceNumber]
		
		local enemy_params = {
			player = player2,
			name = "enemy_attack_wave_"..waveAttackNumber,
			spawn = Util_GetPosition(Get_ValidEnemySpawn()),
			units = enemy_WaveData.units,
			targets = enemy_Targets,
			targetOrder = TARGET_ORDER_LINEAR,
			onDeathDissolve = true,
		}
		
		Army_Init(enemy_params)
		
		local ally_WaveData = ALLY_ATTACK_SEQUENCE[sequenceNumber]
		sg_allied_wave_pop_count = SGroup_CreateIfNotFound("sg_allied_wave_pop_count")
	
		local ally_params = {
			player = player3,
			name = "allied_attack_wave_"..waveAttackNumber,
			spawn = mkr_ally_spawn,
			units = ally_WaveData.units,
			targets = ally_Targets,
			targetOrder = TARGET_ORDER_LINEAR,
			onDeathDissolve = true,
			onCompleteFunction = AllyTargetClosestKeep,
		}
		if SGroup_CountSpawned(sg_allied_wave_pop_count) < 50 then
			local thisAlliedArmy = Army_Init(ally_params)
			SGroup_AddGroup(sg_allied_wave_pop_count, thisAlliedArmy.sgroup)
			Modify_UnitSpeedWhenNotInCombat(thisAlliedArmy.sgroup, 0.9)
		end
		
		waveAttackNumber = waveAttackNumber+1
		sequenceNumber = sequenceNumber+1
		
end

function AllyTargetClosestKeep(army)
	if EGroup_CountSpawned(eg_crusaderkeeps) > 0 then
		Army_SetTarget(army, Util_GetPosition(Get_ValidEnemySpawn()))
	end
end

function Init_GenoeseAttack()
	
	sg_genoese = SGroup_CreateIfNotFound("sg_genoese")
	sg_genoese_ships = SGroup_CreateIfNotFound("sg_genoese_ships")
	
	--TRANSPORT_REQ = t_difficulty.enemyMods.ACRE_ARCHER_SIZE*6
	--TRANSPORT_REQ = TRANSPORT_REQ + t_difficulty.enemyMods.ACRE_ELITE_INFANTRY_SGT
	--TRANSPORT_REQ = math.ceil(TRANSPORT_REQ/16)
	
	local ACRE_GENOESE_CROSSBOWS_PERBOAT = t_difficulty.enemyMods.ACRE_GENOESE_CROSSBOWS_PERBOAT 
	local ACRE_GENOESE_SGT_PERBOAT = t_difficulty.enemyMods.ACRE_GENOESE_SGT_PERBOAT
	local ACRE_GENOESE_TRANSPORTS_PERSPAWN = t_difficulty.enemyMods.ACRE_GENOESE_TRANSPORTS_PERSPAWN
	
	
	for i, marker in pairs(geneose_fleets) do
		
		if Game_GetSPDifficulty() > GD_EASY or i % 2 == 1 then
			
			local units_ships = {
				{type="scar_transport_ship", numSquads = ACRE_GENOESE_TRANSPORTS_PERSPAWN, sgroup = sg_genoese_ships},	
			}
			
			local unit_ship_guards = {
				{sbp = SBP.CRUSADER_CMP.UNIT_NAVAL_HULK_CRU, numSquads = 1, sgroup = sg_genoese_ships}
			}
			
			local units_marines = {
				{type="scar_manatarms", numSquads = ACRE_GENOESE_SGT_PERBOAT, sgroup = sg_genoese},
				{sbp=SBP.CRUSADER_CMP.UNIT_GENOESE_CROSSBOWMAN_CRU, numSquads = ACRE_GENOESE_CROSSBOWS_PERBOAT, sgroup = sg_genoese},
			}
			
			local sg_transport = CreateUnits(player2, units_ships, marker, "sg_transport_")	
			local sg_ship_guards = CreateUnits(player2, unit_ship_guards, marker, "sg_ship_guards_")	
			
			local sg_marines = SGroup_CreateUnique()
			
			local _SpawnUnitsInEachShip = function(gid, index, sid)
				local thisTransport = SGroup_Single(sg_temp, sid)
				local thisGroup = CreateUnitsInsideSGroup(player2, units_marines, thisTransport, "sg_marines_")
				SGroup_AddGroup(sg_marines, thisGroup)
			end
			
			SGroup_ForEach(sg_transport, _SpawnUnitsInEachShip)

			SGroup_AddGroup(sg_genoese, sg_marines)
			
			local closest_landing_marker = World_GetClosest(marker, geneose_landings)
			
			local params = {
				player = player2,
				name = "geneose_transport_"..i,
				spawn = marker,
				targets = {closest_landing_marker}, 
				attackBuildings = BUILDINGS_IMPORTANT,
				attackMove = false,
				holdPositionWhileWaiting = true,
				transport_ships = sg_transport,
				sgroup = sg_marines, 
				onCompleteFunction = _GenoeseAttack_TransitionToLand,
				ARMYNUMBER = i,
			}
			
			local thisArmy = Army_Init(params)
			--Army_AddSGroup(thisArmy, sg_marines)
			
			local guard_params = {
				player = player2,
				name = "geneose_guards_"..i,
				spawn = marker,
				targets = {marker, closest_landing_marker},
				targetOrder = TARGET_ORDER_PATROL,
				sgroup = sg_ship_guards, 
			}
			local thisGuardArmy = Army_Init(guard_params)
		end	
	end
	
end

function _GenoeseAttack_TransitionToLand(army)
	local params = {
		player = player2,
		name = "geneose_attack_"..army.ARMYNUMBER,
		spawn = mkr_genoese_landing,
		targets = {mkr_siege_camp}, 
		attackBuildings = BUILDINGS_IMPORTANT,
		attackMove = false,
		holdPositionWhileWaiting = true,
		sgroup = army.sgroup, 
		onDeathDissolve = true,
	}
	local thisArmy = Army_Init(params)
	
	Cmd_AttackMove(army.transport_ships, mkr_geneose_despawn, false, nil, false, true)
	Cmd_Ability(thisArmy.sgroup, BP_GetAbilityBlueprint("core_formation_spread"))
end

