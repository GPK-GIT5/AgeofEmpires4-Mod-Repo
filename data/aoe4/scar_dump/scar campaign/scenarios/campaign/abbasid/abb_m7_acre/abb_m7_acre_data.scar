			RES_TRICKLE_AMOUNT = Util_DifVar({800, 500, 500, 300}), --t_difficulty.playerMods.RES_TRICKLE_AMOUNT
			ALLY_RESPAWN_DELAY = Util_DifVar({2, 5, 6, 10}), --t_difficulty.playerMods.ALLY_RESPAWN_DELAY
			RES_PICKUP_SPAWN_CHANCE_NAVAL = Util_DifVar({1, 1, 2, 4}), --t_difficulty.playerMods.RES_PICKUP_SPAWN_CHANCE_NAVAL
