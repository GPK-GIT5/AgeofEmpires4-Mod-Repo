		{type = "scar_villager", numSquads = 3, spawn = mkr_outro_crowd16},
		{type = "scar_villager", numSquads = 3, spawn = mkr_outro_crowd17},
		{type = "scar_villager", numSquads = 3, spawn = mkr_outro_crowd18},
		{type = "scar_villager", numSquads = 3, spawn = mkr_outro_crowd19},
		{type = "scar_villager", numSquads = 3, spawn = mkr_outro_crowd20},
