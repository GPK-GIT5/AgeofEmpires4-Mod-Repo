function SpawnOutroRiders()
	local numKnightsPerRow = 1
	local parade_markers = {
		mkr_outro_dest1,
		mkr_outro_dest2,
		mkr_outro_dest3,
	}
	local parade_units = {
		{type = "scar_knight", numSquads = numKnightsPerRow, spawn = mkr_outro_spawn1},
		{type = "scar_knight", numSquads = numKnightsPerRow, spawn = mkr_outro_spawn2},
		{type = "scar_knight", numSquads = numKnightsPerRow, spawn = mkr_outro_spawn3},
		{type = "scar_knight", numSquads = numKnightsPerRow, spawn = mkr_outro_spawn4},
		{type = "scar_knight", numSquads = numKnightsPerRow, spawn = mkr_outro_spawn5},
	}
	Util_UnitParade(parade_markers, parade_units)	
end
