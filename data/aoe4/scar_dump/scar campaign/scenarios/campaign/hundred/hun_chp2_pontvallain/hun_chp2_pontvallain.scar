		{type = "scar_villager", numSquads = 3, spawn = mkr_outro_crowd11},
		{type = "scar_villager", numSquads = 3, spawn = mkr_outro_crowd12},
		{type = "scar_villager", numSquads = 3, spawn = mkr_outro_crowd13},
		{type = "scar_villager", numSquads = 3, spawn = mkr_outro_crowd14},
