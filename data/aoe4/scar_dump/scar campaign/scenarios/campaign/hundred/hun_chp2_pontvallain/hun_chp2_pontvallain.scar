function Mission_SetupPlayers()
	print("Mission_SetupPlayers")
	player1 = World_GetPlayerAt(1)
	player2 = World_GetPlayerAt(2)
	player3 = World_GetPlayerAt(3)
	player4 = World_GetPlayerAt(4)
	
	-- player 1 - French
	Setup_SetPlayerName(player1, Loc_GetString(11180084)) -- ("Bertrand du Guesclin")
	Player_SetCurrentAge(player1, AGE_FEUDAL)
	Player_SetMaximumAge(player1, AGE_CASTLE)

	-- player 2 - English	
	Setup_SetPlayerName(player2, "$11180085") -- (Alan Buxhull")))
	Player_SetCurrentAge(player2, AGE_FEUDAL)
	Player_SetMaximumAge(player2, AGE_FEUDAL)

	-- player 3 - Pontvallain Allies
	Setup_SetPlayerName(player3, "$11156658") -- ("Pontvallain")))
	Player_SetCurrentAge(player3, AGE_FEUDAL)
	Player_SetMaximumAge(player3, AGE_FEUDAL)
	
	-- player 4 - Bandits
	Setup_SetPlayerName(player4, "$11180223") -- ("Bandits")))
	Player_SetCurrentAge(player4, AGE_FEUDAL)
	Player_SetMaximumAge(player4, AGE_FEUDAL)
	
	PlayerColour_Enable()
	Game_SetPlayerUISlotColour(player1, 1)
	Game_SetPlayerUISlotColour(player2, 2) --english
	Game_SetPlayerUISlotColour(player3, 3) --ally
	Game_SetPlayerUISlotColour(player4, 7) --bandits
end

function Mission_SetupVariables()	-- create any extra sgroups, egroups, and mission variables in here		
	print("Mission_SetupVariables")
	Pontvallain_InitData1()
end

function Mission_SetRestrictions()
	print("Mission_SetRestrictions")
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_DEFENSE_WALL_FRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_DEFENSE_WALL_GATE_FRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_DEFENSE_TOWER_FRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_DEFENSE_OUTPOST_FRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_DEFENSE_PALISADE_FRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_DEFENSE_PALISADE_GATE_FRE, ITEM_REMOVED)
end
--Modules loaded after SetRestrictions and before Preset
function Mission_Preset()
	print("Mission_Preset")
	
	Pontvallain_InitData2()
	
	-- Player starting units
	UnitEntry_DeploySquads(player1, sg_player_army, player_units, mkr_player_garrison)
	UnitEntry_DeploySquads(player1, sg_player_farmers, {{type = "scar_villager", numSquads = 8 }}, mkr_player_farmers)
	UnitEntry_DeploySquads(player1, sg_player_woodcutters, {{type = "scar_villager", numSquads = Util_DifVar({ 8, 4, 4, 4 }) }}, mkr_player_woodcutters)
	UnitEntry_DeploySquads(player1, sg_temp, {{type = "scar_villager", numSquads = 2 }}, mkr_player_idle)
	UnitEntry_DeploySquads(player1, sg_player_trader, {{type = "scar_trade_cart", numSquads = 1, creator = eg_player_market }}, mkr_player_trader)
	UnitEntry_DeploySquads(player1, sg_player_trader2, {{type = "scar_trade_cart", numSquads = 1, creator = eg_player_market }}, mkr_player_trader2)
	
	-- Allied villagers
	UnitEntry_DeploySquads(player3, sg_ally_farmers1, {{type = "scar_villager", numSquads = 8 }}, mkr_ally_farmers1)
	UnitEntry_DeploySquads(player3, sg_ally_farmers2, {{type = "scar_villager", numSquads = 2 }}, mkr_ally_farmers2)
	UnitEntry_DeploySquads(player3, sg_ally_farmers3, {{type = "scar_villager", numSquads = 2 }}, mkr_ally_farmers3)
	UnitEntry_DeploySquads(player3, sg_ally_farmers4, {{type = "scar_villager", numSquads = 2 }}, mkr_ally_farmers4)
	UnitEntry_DeploySquads(player3, sg_ally_farmers5, {{type = "scar_villager", numSquads = 2 }}, mkr_ally_farmers5)
	UnitEntry_DeploySquads(player3, sg_ally_farmers6, {{type = "scar_villager", numSquads = 2 }}, mkr_ally_farmers6)
	UnitEntry_DeploySquads(player3, sg_ally_farmers7, {{type = "scar_villager", numSquads = 2 }}, mkr_ally_farmers7)
	UnitEntry_DeploySquads(player3, sg_ally_woodcutters1, {{type = "scar_villager", numSquads = 3 }}, mkr_ally_woodcutters1)
	UnitEntry_DeploySquads(player3, sg_ally_woodcutters2, {{type = "scar_villager", numSquads = 5 }}, mkr_ally_woodcutters2)
	UnitEntry_DeploySquads(player3, sg_ally_woodcutters3, {{type = "scar_villager", numSquads = 5 }}, mkr_ally_woodcutters3)
	UnitEntry_DeploySquads(player3, sg_ally_woodcutters4, {{type = "scar_villager", numSquads = 5 }}, mkr_ally_woodcutters4)
	
	
	-- Player scout, moving from Pontvallain to start area
	
	--local route = { mkr_intro_path1, mkr_intro_path2, mkr_intro_path3, mkr_intro_path4, mkr_intro_path5, mkr_intro_path6, mkr_intro_path7, mkr_intro_path8, mkr_intro_path9, mkr_intro_path10, mkr_intro_path11 }
	--local units = {{type= "scar_scout", numSquads = 1, spawn = mkr_player_scout}}
	--Util_UnitParade(route, units, sg_player_scout)
	
	UnitEntry_DeploySquads(player1, sg_player_scout, {{type = "scar_scout", numSquads = 1}}, mkr_intro_path1)
	Pontvallain_IntroMoveScout()
	--Rule_AddOneShot(Pontvallain_IntroMoveScout, 3)
	
	PlayerUpgrades_Auto(player1, false)
	PlayerUpgrades_Auto(player2, false)
	
	Player_GetAll(player3)
	EGroup_Filter(eg_allentities, EBP.FRENCH.BUILDING_DEFENSE_OUTPOST_FRE, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	
	AssignVillagersToFarms(sg_player_farmers)
	AssignVillagersToWood(sg_player_woodcutters)
	
	AssignVillagersToFarms(sg_ally_farmers1)
	AssignVillagersToFarms(sg_ally_farmers2)
	AssignVillagersToFarms(sg_ally_farmers3)
	AssignVillagersToFarms(sg_ally_farmers4)
	AssignVillagersToFarms(sg_ally_farmers5)
	AssignVillagersToFarms(sg_ally_farmers6)
	AssignVillagersToFarms(sg_ally_farmers7)
	
	AssignVillagersToWood(sg_ally_woodcutters1)
	AssignVillagersToWood(sg_ally_woodcutters2)
	AssignVillagersToWood(sg_ally_woodcutters3)
	AssignVillagersToWood(sg_ally_woodcutters4)

	Sound_ResetMusicIntensityMapping();
	Sound_AddMusicIntensityMappingPoint(65, 800) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(375, 4000) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(800, 9999) -- raw value max to scaled value max
	
	Pontvallain_InitObjectives()
end

function Pontvallain_IntroMoveScout()
	Rule_AddOneShot(Pontvallain_IntroMoveScout_2, 4)
	
	Cmd_FormationMove(sg_player_scout, mkr_intro_path2, false)
	Cmd_FormationMove(sg_player_scout, mkr_intro_path3, true)
	Cmd_FormationMove(sg_player_scout, mkr_intro_path4, true)
	Cmd_FormationMove(sg_player_scout, mkr_intro_path5, true)
	Cmd_FormationMove(sg_player_scout, mkr_intro_path6, true)
	Cmd_FormationMove(sg_player_scout, mkr_intro_path7, true)
	Cmd_FormationMove(sg_player_scout, mkr_intro_path8, true)
	Cmd_FormationMove(sg_player_scout, mkr_intro_path9, true)
	Cmd_FormationMove(sg_player_scout, mkr_intro_path10, true)
	Cmd_FormationMove(sg_player_scout, mkr_intro_path11, true)	
end
function Pontvallain_IntroMoveScout_2()
	-- Speed up scout in middle of path to arrive at correct time
	modid_IntroScoutSpeedModifier = Modify_UnitSpeed(sg_player_scout, 3)
end

function Mission_Start()
	print("Mission_Start")
	Music_UnlockIntensity()
	Sound_SetMinimumMusicCombatIntensity(801, 0)
	
	--AssignTradecartsToTrade(sg_player_trader, eg_ally_market)
	Pontvallain_SetupWaves()
	
	Objective_Start(OBJ_Protect, true, true)
	
	if Game_GetSPDifficulty() <= GD_NORMAL then
		Rule_AddOneShot(Pontvallain_ShowBuildObjective, SHOW_BUILD_OBJECTIVE_TIME)
		Rule_AddGlobalEvent(Pontvallain_OnConstructionComplete, GE_ConstructionComplete)
	end

	Rule_AddInterval(FindBandits, 2)
	Rule_AddOneShot(Pontvallain_EnemyArrives, GRACE_PERIOD)
	
	if Game_GetSPDifficulty() == GD_EASY then
		Player_SetResource(player1, RT_Food, 400)
		Player_SetResource(player1, RT_Wood, 400)
		Player_SetResource(player1, RT_Stone,400)
		Player_SetResource(player1, RT_Gold, 400)
	elseif Game_GetSPDifficulty() == GD_NORMAL then
		Player_SetResource(player1, RT_Food, 300)
		Player_SetResource(player1, RT_Wood, 300)
		Player_SetResource(player1, RT_Stone,300)
		Player_SetResource(player1, RT_Gold, 300)
	elseif Game_GetSPDifficulty() == GD_HARD then
		Player_SetResource(player1, RT_Food, 200)
		Player_SetResource(player1, RT_Wood, 200)
		Player_SetResource(player1, RT_Stone,200)
		Player_SetResource(player1, RT_Gold, 200)
	else
		Player_SetResource(player1, RT_Food, 100)
		Player_SetResource(player1, RT_Wood, 100)
		Player_SetResource(player1, RT_Stone,100)
		Player_SetResource(player1, RT_Gold, 100)	
	end
	
	if UI_IsXboxControllerUI() == false then
		Pontvallain_AddHintTrade()
	end
end

function Pontvallain_EnemyArrives(context, data)
	print("Pontvallain_EnemyArrives")
	for i = 1, 3, 1 do
		Pontvallain_MoveEnglish(i)
	end
	Rule_AddOneShot(Pontvallain_StartObjective, 5)
end

function Pontvallain_MoveEnglish(i)
	local raid = EnglishRaids[i]
	local army = EnglishArmies[i]
	RovingArmy_SetTarget(raid, raid_intro_targets[i])
	RovingArmy_SetTarget(army, army_intro_targets[i])
	raid_positions[i] = RovingArmy_GetTarget(raid).position
	army_positions[i] = RovingArmy_GetTarget(army).position
end

function Pontvallain_StartObjective()
	Objective_Start(OBJ_DefeatEnglish)
end

function Pontvallain_StartRaid(context, data)
	local i = data.i
	print("Pontvallain_StartRaid "..i)
	Wave_Prepare(ally_waves[i])
	if raid_is_dead[i] == false and raid_is_started[i] == false then
		local module = EnglishRaids[i]
		local targets = raid_targets[i]
		raid_is_started[i] = true
		module.useCustomDirection = false
		RovingArmy_SetTargets(module, targets)
		Music_LockIntensity(MUSIC_TENSE_RARE, 10)
		raid_icons[i] = Objective_AddUIElements(SOBJ_DefeatRaids, module.sgroup, true, 11182314, false)
		ThreatArrow_CreateGroup("Raiders", module.sgroup)
		MarkerPaths_GenerateIcons(paths[i].name, AllMarkers_FromName(paths[i].markerName, ""), "military_route_enemy")
		Rule_AddOneShot(Pontvallain_RemovePath, 30, { i = i })
		Rule_Add(Pontvallain_MonitorRaid, { i = i })
		if i == 1 then
			Objective_Start(SOBJ_DefeatRaids)	
		else
			Util_StartIntel(EVENTS.More_English)
		end
	end
end

function Pontvallain_MonitorRaid(context, data)
	local i = data.i
	local module = EnglishRaids[i]
	local sgroup = module.sgroup
	if SGroup_CountSpawned(sgroup) > 0 then
		raid_positions[i] = SGroup_GetAvgPosition(sgroup)
	else
		Rule_RemoveMe()
	end
end

function Pontvallain_RaidDead(module)
	local i = module.raid_number
	print("Pontvallain_RaidDead "..i)
	raid_is_dead[i] = true
	dead_raid_count = dead_raid_count + 1
	
	Player_GetAllSquadsNearMarker(player1, sg_temp, raid_positions[i], 40)
	Sound_PlayWallaCelebrateOnSGroup(sg_temp)
	Sound_Play2D("sfx_campaign_scripted_ui_objective_counter_update")
	Objective_SetCounter(SOBJ_DefeatRaids, dead_raid_count, 3)
	
	if raid_is_started[i] then
		Objective_RemoveUIElements(SOBJ_DefeatRaids, raid_icons[i])
	end
	
	if dead_raid_count == 3 then
		if Objective_IsComplete(SOBJ_DefeatArmies) == true then
			Objective_Complete(SOBJ_DefeatRaids, false, false)
			Objective_Complete(OBJ_DefeatEnglish, true, true)
		else
			Objective_Complete(SOBJ_DefeatRaids, true, true)
		end
	end
end

function Pontvallain_StartArmies()
	armies_are_started = true
	Pontvallain_StartArmy(nil, { i = 1 })
	Pontvallain_StartArmy(nil, { i = 2 })
	Pontvallain_StartArmy(nil, { i = 3 })
	
end

function Pontvallain_StartArmy(context, data)
	local i = data.i
	
	if army_is_dead[i] == false and army_is_started[i] == false then
		local module = EnglishArmies[i]
		local targets = army_targets[i]
		army_is_started[i] = true
		module.useCustomDirection = false
		RovingArmy_SetTargets(module, targets)
		
		army_icons[i] = Objective_AddUIElements(SOBJ_DefeatArmies, module.sgroup, true, "$11182343", false)
		ThreatArrow_CreateGroup("Final Attack", module.sgroup)
		MarkerPaths_GenerateIcons(paths[i].name, AllMarkers_FromName(paths[i].markerName, ""), "military_route_enemy")
		Rule_AddOneShot(Pontvallain_RemovePath, 30, { i = i })
		Rule_Add(Pontvallain_MonitorArmy, { i = i })
	end
end

function Pontvallain_MonitorArmy(context, data)
	local i = data.i
	local module = EnglishArmies[i]
	local sgroup = module.sgroup
	if SGroup_CountSpawned(sgroup) > 0 then
		army_positions[i] = SGroup_GetAvgPosition(sgroup)
	else
		Rule_RemoveMe()
	end
end

function Pontvallain_ArmyDead(module)
	local i = module.army_number
	print("Pontvallain_ArmyDead "..i)
	
	army_is_dead[i] = true
	dead_army_count = dead_army_count + 1
	
	Player_GetAllSquadsNearMarker(player1, sg_temp, army_positions[i], 40)
	Sound_PlayWallaCelebrateOnSGroup(sg_temp)
	Sound_Play2D("sfx_campaign_scripted_ui_objective_counter_update")
	
	if army_is_started[i] == true then
		Objective_RemoveUIElements(SOBJ_DefeatArmies, army_icons[i])
		Objective_SetCounter(SOBJ_DefeatArmies, dead_army_count, 3)
	end
	
	if dead_army_count == 3 then
		if Objective_IsComplete(OBJ_Wait) == false then
			Objective_Complete(OBJ_Wait, false, false)
		end
		if Objective_IsStarted(SOBJ_DefeatArmies) == false then
			print("SOBJ_DefeatArmies started prematurely because armies are dead")
			Objective_Start(SOBJ_DefeatArmies, false, false)
		end
		if Objective_IsComplete(SOBJ_DefeatRaids) == true then
			Objective_Complete(SOBJ_DefeatArmies, false, false)
			Objective_Complete(OBJ_DefeatEnglish, true, true)
		else
			
			Objective_Complete(SOBJ_DefeatArmies, true, true)
		end
	end
end

----------------
--- Utility ----
----------------

function Pontvallain_SetMusicTense()
	Music_UnlockIntensity()
	Sound_SetMinimumMusicCombatIntensity(801, 0)
end

function FindBandits()
	if Player_CanSeeSGroup(player1, sg_bandits, ANY) then
		Util_StartIntel(EVENTS.Discover_Bandits)
		Rule_RemoveMe()
	end	
end

function Pontvallain_RemovePath(context, data)
	local i = data.i
	MarkerPaths_ClearIcons(paths[i].name)
end

function Pontvallain_OnConstructionComplete(context)
	local entity = context.entity
	if Entity_GetPlayerOwner(entity) == player1 then
		if Entity_IsOfType(entity, "barracks") or Entity_IsOfType(entity, "stable")  or Entity_IsOfType(entity, "archery_range") or Entity_IsOfType(entity, "siege_workshop") then
			production_buildings_constructed = production_buildings_constructed + 1
			if production_buildings_constructed > production_buildings_required then
				production_buildings_constructed = production_buildings_required
			end
			Sound_Play2D("sfx_campaign_scripted_ui_objective_counter_update")
			if production_buildings_constructed >= production_buildings_required then
				Rule_RemoveMe()
			end
		end
	end
end

function Pontvallain_ShowBuildObjective(context)
	if production_buildings_constructed < production_buildings_required then
		Objective_Start(OBJ_Build, true, true)
	else
		Objective_Start(OBJ_Build, false, false)
	end
end

