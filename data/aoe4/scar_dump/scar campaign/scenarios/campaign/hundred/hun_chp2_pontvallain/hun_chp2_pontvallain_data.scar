--called from MissionPreset, after modules are initialized
function Pontvallain_InitData2()
	EnglishRaid1 = MissionOMatic_FindModule("EnglishRaid1")
	EnglishRaid2 = MissionOMatic_FindModule("EnglishRaid2")
	EnglishRaid3 = MissionOMatic_FindModule("EnglishRaid3")
	EnglishArmy1 = MissionOMatic_FindModule("EnglishArmy1")
	EnglishArmy2 = MissionOMatic_FindModule("EnglishArmy2")
	EnglishArmy3 = MissionOMatic_FindModule("EnglishArmy3")
	EnglishRaids = { EnglishRaid1, EnglishRaid2, EnglishRaid3 }
	EnglishArmies = { EnglishArmy1, EnglishArmy2, EnglishArmy3 }
	EnglishModules = { EnglishRaid1, EnglishRaid2, EnglishRaid3, EnglishArmy1, EnglishArmy2, EnglishArmy3 }
	
	BanditDefenders = MissionOMatic_FindModule("BanditDefenders")
	BanditPatrol = MissionOMatic_FindModule("BanditPatrol")
	SGroup_AddGroup(sg_bandits, BanditDefenders.sgroup)
	SGroup_AddGroup(sg_bandits, BanditPatrol.sgroup)
	
	for i = 1, 3, 1 do
		SGroup_AddGroup(sg_english_all, EnglishRaids[i].sgroup)
		SGroup_AddGroup(sg_english_all, EnglishArmies[i].sgroup)	
		SGroup_AddGroup(sg_english_army, EnglishArmies[i].sgroup)
		EnglishRaids[i].raid_number = i
		EnglishArmies[i].army_number = i
	end	
end


