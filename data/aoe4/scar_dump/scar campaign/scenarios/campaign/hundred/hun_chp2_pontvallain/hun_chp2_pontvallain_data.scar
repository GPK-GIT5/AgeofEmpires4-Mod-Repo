function Pontvallain_SetupWaves()
	--wave_data
	local ally_wave_data_1 = {
		descriptor = "ally_wave_1",
		player = player3,	
		use_separate_spawns = true,
		spawn = mkr_pontvallain_buildings,
		units = {
			{ type = "scar_archer", numSquads = 5 },
			{ type = "scar_spearman", numSquads = 5 },
		},
		assault_module = "PontvallainDefend1",
		ignore_build_times = false,
	}
	local ally_wave_data_2 = {
		descriptor = "ally_wave_2",
		player = player3,	
		use_separate_spawns = true,
		spawn = mkr_pontvallain_buildings,
		units = {
			{ type = "scar_archer", numSquads = 5 },
			{ type = "scar_spearman", numSquads = 5 },
		},
		assault_module = "PontvallainDefend2",
		ignore_build_times = false,
	}
	local ally_wave_data_3 = {
		descriptor = "ally_wave_3",
		player = player3,	
		use_separate_spawns = true,
		spawn = mkr_pontvallain_buildings,
		units = {
			{ type = "scar_archer", numSquads = 5 },
			{ type = "scar_spearman", numSquads = 5 },
		},
		assault_module = "PontvallainDefend3",
		ignore_build_times = false,
	}
	ally_wave_1 = Wave_New(ally_wave_data_1)
	ally_wave_2 = Wave_New(ally_wave_data_2)
	ally_wave_3 = Wave_New(ally_wave_data_3)
	ally_waves = { ally_wave_1, ally_wave_2, ally_wave_3 }
	Wave_OverrideUnitBuildTime("scar_spearman", 20)
	Wave_OverrideUnitBuildTime("scar_archer", 20)
end