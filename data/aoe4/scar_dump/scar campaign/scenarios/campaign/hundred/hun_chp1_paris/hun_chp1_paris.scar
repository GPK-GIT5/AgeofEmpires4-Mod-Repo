function Paris_AddWaveUI(context, data)
	if SGroup_CountSpawned(data.sgroup) > 0 then
		ThreatArrow_CreateGroup("attack wave", data.sgroup)
		Sound_PlayWallaChargeOnSGroup(data.sgroup)
	end
end

function WallsBreached(context)
	if wallsBreachedStingerHasPlayer ~= true then
		wallsBreachedStingerHasPlayer = true
		Util_StartIntel(EVENTS.WallsBreached)
		Rule_RemoveEGroupEvent(WallsBreached, eg_paris_walls)
	end
end

function LandmarkUnderAttack(context)
	Util_StartIntel(EVENTS.LandmarkAttack)
	Rule_RemoveEGroupEvent(LandmarkUnderAttack, eg_landmarks)
end
