		Cmd_FormationMove(sg_intro_archer_3, mkr_french_wall_3, false, false, Util_GetFacingFromDirection(Marker_GetPosition(mkr_french_wall_3), Marker_GetDirection(mkr_french_wall_3)))
		Cmd_FormationMove(sg_intro_archer_4, mkr_french_wall_4, false, false, Util_GetFacingFromDirection(Marker_GetPosition(mkr_french_wall_4), Marker_GetDirection(mkr_french_wall_4)))
		Rule_RemoveMe()
	end
end

function Paris_InitOutro()
	sg_outro_units1 = SGroup_CreateIfNotFound("sg_outro_units1")
	sg_outro_units2 = SGroup_CreateIfNotFound("sg_outro_units2")
	sg_outro_units3 = SGroup_CreateIfNotFound("sg_outro_units3")
	sg_outro_units3a = SGroup_CreateIfNotFound("sg_outro_units3a")

	sg_outro_frenchunits3 = SGroup_CreateIfNotFound("sg_outro_frenchunits3")
	sg_outro_frenchunits4 = SGroup_CreateIfNotFound("sg_outro_frenchunits4")	
	
	sg_outro_wallunits01 = SGroup_CreateIfNotFound("sg_outro_wallunits01")
	sg_outro_wallunits02 = SGroup_CreateIfNotFound("sg_outro_wallunits02")
	sg_outro_wallunits03 = SGroup_CreateIfNotFound("sg_outro_wallunits03")
	sg_outro_wallunits04 = SGroup_CreateIfNotFound("sg_outro_wallunits04")
	sg_outro_wallunits05 = SGroup_CreateIfNotFound("sg_outro_wallunits05")
	sg_outro_wallunits06 = SGroup_CreateIfNotFound("sg_outro_wallunits06")
	sg_outro_wallunits07 = SGroup_CreateIfNotFound("sg_outro_wallunits07")
	
	sg_outro_lancer01 = SGroup_CreateIfNotFound("sg_outro_lancer01")
	sg_outro_lancer02 = SGroup_CreateIfNotFound("sg_outro_lancer02")
	sg_outro_lancer03 = SGroup_CreateIfNotFound("sg_outro_lancer03")
	sg_outro_lancer04 = SGroup_CreateIfNotFound("sg_outro_lancer04")
	
	sg_outro_cheer01 = SGroup_CreateIfNotFound("sg_outro_cheer01")
	
	UnitEntry_DeploySquads(player2, sg_outro_units1, {{ type = "scar_spearman", numSquads = 5 }, { type = "scar_archer", numSquads = 5 }, { type = "scar_knight", numSquads = 5 }}, mkr_english_outro1 )
	UnitEntry_DeploySquads(player2, sg_outro_units2, {{ type = "scar_archer", numSquads = 5 }, { type = "scar_knight", numSquads = 5 }, { type = "scar_spearman", numSquads = 5 }}, mkr_english_outro2 )
	UnitEntry_DeploySquads(player2, sg_outro_units3, {{ type = "scar_knight", numSquads = 5 }, { type = "scar_spearman", numSquads = 5 }, { type = "scar_archer", numSquads = 5 }}, mkr_english_outro3 )
	
	UnitEntry_DeploySquads(player2, sg_outro_units3a, {{ type = "scar_knight", numSquads = 8 }, { type = "scar_archer", numSquads = 7 }}, mkr_english_outro3a )
	
	UnitEntry_DeploySquads(player1, sg_outro_frenchunits3, { type = "scar_archer", numSquads = 10 }, mkr_french_outro3 )
	UnitEntry_DeploySquads(player1, sg_outro_frenchunits4, { type = "scar_spearman", numSquads = 10 }, mkr_french_outro4 )
	UnitEntry_DeploySquads(player1, sg_outro_cheer01, { type = "scar_manatarms", numSquads = 10 }, mkr_french_cheer01 )
	
	--Outro Wall units
	UnitEntry_DeploySquads(player1, sg_outro_wallunits01, { type = "scar_crossbowman", numSquads = 2 }, mkr_outro_wallunits01 )
	UnitEntry_DeploySquads(player1, sg_outro_wallunits02, { type = "scar_spearman", numSquads = 2 }, mkr_outro_wallunits02 )
	UnitEntry_DeploySquads(player1, sg_outro_wallunits03, { type = "scar_crossbowman", numSquads = 2 }, mkr_outro_wallunits03 )
	UnitEntry_DeploySquads(player1, sg_outro_wallunits04, { type = "scar_archer", numSquads = 2 }, mkr_outro_wallunits04 )
	UnitEntry_DeploySquads(player1, sg_outro_wallunits05, { type = "scar_crossbowman", numSquads = 3 }, mkr_outro_wallunits05 )
	UnitEntry_DeploySquads(player1, sg_outro_wallunits06, { type = "scar_archer", numSquads = 3 }, mkr_outro_wallunits06 )
	UnitEntry_DeploySquads(player1, sg_outro_wallunits07, { type = "scar_spearman", numSquads = 1 }, mkr_outro_wallunits07 )
	
	--Outro Lancer units
	UnitEntry_DeploySquads(player1, sg_outro_lancer01, { type = "scar_knight", numSquads = 2 }, mkr_outro_lancer01 )
	UnitEntry_DeploySquads(player1, sg_outro_lancer02, { type = "scar_knight", numSquads = 2 }, mkr_outro_lancer02 )
	UnitEntry_DeploySquads(player1, sg_outro_lancer03, { type = "scar_knight", numSquads = 2 }, mkr_outro_lancer03 )
	UnitEntry_DeploySquads(player1, sg_outro_lancer04, { type = "scar_knight", numSquads = 2 }, mkr_outro_lancer04 )
	
	Cmd_HoldPosition(sg_outro_wallunits01)
	Cmd_HoldPosition(sg_outro_wallunits02)
	Cmd_HoldPosition(sg_outro_wallunits03)
	Cmd_HoldPosition(sg_outro_wallunits04)
	Cmd_HoldPosition(sg_outro_wallunits05)
	Cmd_HoldPosition(sg_outro_wallunits06)
	
