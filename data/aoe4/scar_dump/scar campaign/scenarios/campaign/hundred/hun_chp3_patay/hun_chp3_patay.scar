function Patay_WakeRegiment1()
	Rule_AddInterval(Patay_CheckAllyFlee, 3)
	Patay_ActivateRegiment(t_regiments[1])
	Patay_MergeRegiment(t_regiments[1])
end

function Patay_WakeRegiment2()
	Patay_ActivateRegiment(t_regiments[2])
	Patay_MergeRegiment(t_regiments[2])
end

function Patay_WakeRegiment3()
	Patay_ActivateRegiment(t_regiments[3])
	Patay_MergeRegiment(t_regiments[3])
end

function Patay_ActivateRegiment(data)
	
	if data.isActive == false then
		data.isActive = true
		local module = MissionOMatic_FindModule(data.name)
		RovingArmy_SetTargets(module, data.final_targets)
	end
end

function Patay_MergeRegiment(data)
	
	if data.hasFullyMerged == false then
		
		data.hasFullyMerged = true
		
		for i = 1, #t_scatter_groups do
			
			local scatter_group = t_scatter_groups[i]
			
			if scatter_group.hasMerged == false and scatter_group.isAlive == true then
				if scatter_group.merge_target == data.name then
					scatter_group.hasMerged = true
					Prefab_DoAction(MissionOMatic_FindModule(scatter_group.merge_target), "AddSGroup", scatter_group.sgroup)
				end
			end
		end
	end
end

