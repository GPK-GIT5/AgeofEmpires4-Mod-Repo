function Patay_JoanCav_Cheer()
	
	SGroup_PlaySpeech(g_leaderJoan.sgroup,"Campaign_Speech/leaders/hun/jeanne/french_jeannedarc_hun_chp3_orleans_iHigh_cMed_07")
	
	SGroup_Clear(sg_temp)
	SGroup_AddGroups(sg_temp, {sg_joan_cav1, sg_joan_cav2})
	Sound_PlayWallaChargeOnSGroup(sg_temp)	
end

function Patay_CheckDepartTrigger()
	
	Player_GetAll(player1)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_depart_trigger, ANY, 30)  then
		Patay_BeginChasePhase()
		Rule_RemoveMe()
	end
end

function Patay_CheckPatayDefendTrigger()
	
	Player_GetAll(playerEnglish)
	
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_patay_trigger, ANY, 50) then
		
		Player_GetAllSquadsNearMarker(playerEnglish, sg_temp, mkr_patay_trigger, 50)
		if SGroup_CountSpawned(sg_temp) >= 2 then
			
			Objective_Start(OBJ_DefendPatay)
			Rule_RemoveMe()
		end
	end
end

function Patay_CheckSigmundRetreatTrigger()
	
	if SGroup_CountSpawned(sg_sigmund_main) > 0 then
		if Prox_AreSquadsNearMarker(sg_sigmund_main, mkr_main_battle_rear_trigger, ANY, 30) then
			if SGroup_CountSpawned(sg_battle_group2) > 0 then
				Prefab_DoAction(MissionOMatic_FindModule("BattleGroup2"), "AddSGroup", sg_sigmund_main)
			end
			Rule_RemoveMe()
		end
	else
		Rule_RemoveMe()
	end
end

function Patay_MergeRetreatIntoRegiment1()
	
	local data = t_regiments[1]
	
	if SGroup_CountSpawned(data.sgroup) > 0 and SGroup_CountSpawned(sg_main_retreat) > 0 then
		
		Prefab_DoAction(MissionOMatic_FindModule("Regiment1"), "AddSGroup", sg_main_retreat)
		SGroup_AddGroup(data.sgroup_master, sg_main_retreat)
		data.initCount = SGroup_CountSpawned(data.sgroup_master)
	end
	
end

function Patay_SetGoldValue()
	
	local _SetGold = function(gid, idx, eid)
		Entity_SetStateModelFloat(eid, "resource_pickup_amount_gold", 400)
	end
	EGroup_ForEach(eg_gold, _SetGold)
end

function Patay_InitStartingUnits()

	SpawnUnitGroups(player1, "sg_starting", t_player_starting_units, "mkr_player_army", false)
	SpawnUnitGroups(playerEnglish, "sg_intro_archers", t_intro_archer_units, "mkr_intro_archer", false)
	
	Player_GetAll(player1)
	SGroup_AddGroup(sg_startingUnitsFrench, sg_allsquads)

end

function Patay_SpawnTestArcher()
	
	sg_test_archer = SGroup_CreateIfNotFound("sg_test_archer")
	UnitEntry_DeploySquads(playerEnglish, sg_test_archer, {type = "scar_archer", numSquads = 1}, Misc_GetMouseOnTerrain())
	Cmd_Ability(sg_test_archer, BP_GetAbilityBlueprint("deploy_palings"))
end

function Patay_SpawnJoanCav()
	
	joan_has_spawned = true
	
	local units = {
		{type = "scar_scout", numSquads = 1},
		{type = "scar_horseman", numSquads = 5}
	}
	
	UnitEntry_DeploySquads(player1, sg_joan_cav1, units, mkr_joan_cav1)
	UnitEntry_DeploySquads(player1, sg_joan_cav2, units, mkr_joan_cav2)
	UnitEntry_DeploySquads(player1, sg_joan_cav3, units, mkr_joan_cav3)
	UnitEntry_DeploySquads(player1, sg_joan_cav4, units, mkr_joan_cav4)
	
	UnitEntry_DeploySquads(player1, g_leaderJoan.sgroup, {{sbp = BP_GetSquadBlueprint("unit_joan_of_arc_cmp_fre"), numSquads = 1, tag = "General" }}, mkr_joan)
	Cmd_Move(MissionOMatic_GetSGroupForTaggedUnit("General"), mkr_joan_dest)
	
	Cmd_FormationAttackMove(sg_joan_cav1, mkr_joan_cav_dest1)
	Cmd_FormationAttackMove(sg_joan_cav2, mkr_joan_cav_dest2)
	Cmd_FormationAttackMove(sg_joan_cav3, mkr_joan_cav_dest3)
	Cmd_FormationAttackMove(sg_joan_cav4, mkr_joan_cav_dest4)
	
	mkr_reinforce_main = mkr_reinforce3
	mkr_reinforce_main_dest = mkr_reinforce_dest3
	
end

function Patay_SpawnSigmundReserve()
	
	Patay_SpawnUnitCluster("mkr_sigmund1", 3, "scar_archer", sg_sigmund_reserve)
	Patay_SpawnUnitCluster("mkr_sigmund2", 2, "scar_spearman", sg_sigmund_reserve)
	Patay_SpawnUnitCluster("mkr_sigmund3", 2, "scar_archer", sg_sigmund_reserve)
	Patay_SpawnUnitCluster("mkr_sigmund4", 3, "scar_spearman", sg_sigmund_reserve)
	Patay_SpawnUnitCluster("mkr_sigmund5", 3, "scar_archer", sg_sigmund_reserve)
	Patay_SpawnUnitCluster("mkr_sigmund6", 2, "scar_spearman", sg_sigmund_reserve)
	Patay_SpawnUnitCluster("mkr_sigmund7", 2, "scar_archer", sg_sigmund_reserve)
	Patay_SpawnUnitCluster("mkr_sigmund8", 3, "scar_spearman", sg_sigmund_reserve)
	
	SGroup_AddGroup(sg_sigmund_main, sg_sigmund_reserve)
	
	sigmund_init_count = SGroup_CountSpawned(sg_sigmund_main)
	
end

function Patay_SpawnAmbush()
	
	SpawnUnitsToModule({{type = "scar_archer", numSquads = 4}, {type = "scar_scout", numSquads = 1}}, "Rearguard1")
	SpawnUnitsToModule({{type = "scar_archer", numSquads = 4}}, "Rearguard2")
	SpawnUnitsToModule({{type = "scar_archer", numSquads = 4}, {type = "scar_scout", numSquads = 1}}, "Rearguard3")
	SpawnUnitsToModule({{type = "scar_archer", numSquads = 4}}, "Rearguard4")
	
	SGroup_AddGroup(sg_rearguard, sg_rearguard1)
	SGroup_AddGroup(sg_rearguard, sg_rearguard2)
	SGroup_AddGroup(sg_rearguard, sg_rearguard3)
	SGroup_AddGroup(sg_rearguard, sg_rearguard4)
	
end

function Patay_SpawnUnitCluster(markerName, numPerMarker, unitType, masterSgroup)
	
	local sgroup = SGroup_CreateUnique("")
	local marker = Marker_FromName(markerName, "")
	UnitEntry_DeploySquads(playerEnglish, sgroup, {{type = unitType, numSquads = numPerMarker }}, marker)
	SGroup_AddGroup(masterSgroup, sgroup)
end

function Patay_StartDefeatArmy()
	if not Objective_IsStarted(OBJ_DefeatArmy) then
		Objective_Start(OBJ_DefeatArmy)
	end
end

function Patay_SetRegimentUnitData()
	
	t_regiments[1].units = {
		{type = "scar_archer", numSquads = 3 * t_difficulty.regimentBaseCount},
		{type = "scar_horseman", numSquads = t_difficulty.regimentBaseCount}
	}
	
	t_regiments[2].units = {
		{type = "scar_archer", numSquads = 2 * t_difficulty.regimentBaseCount},
		{type = "scar_spearman", numSquads = 4 * t_difficulty.regimentBaseCount},
		{type = "scar_springald", numSquads = t_difficulty.regimentSiegeCount}
	}
	
	t_regiments[3].units = {
		{type = "scar_archer", numSquads = 3 * t_difficulty.regimentBaseCount},
		{type = "scar_manatarms", numSquads = 4 * t_difficulty.regimentBaseCount},
		{type = "scar_mangonel", numSquads = t_difficulty.regimentSiegeCount}
	}
	
end

function Patay_BeginMainBattle()
	
	main_battle_started = true
	
	Patay_SetRegimentUnitData()
	
	Patay_AddArmyTarget("BattleGroup1", sg_battle_group1, mkr_battle_group_attack1)
	Patay_AddArmyTarget("BattleGroup2", sg_battle_group2, mkr_battle_group_attack2)
	Patay_AddArmyTarget("BattleGroup3", sg_battle_group3, mkr_battle_group_attack3)
	
	Sound_PlayOnSquad(WALLA_CAMP_CHARGE_MEDIUM, sg_main_line)
	Rule_AddInterval(Patay_ProcessMainBattle, 1)
	
	Rule_AddInterval(Patay_CheckDepartTrigger, 1)
	
	RovingArmy_SetTarget(MissionOMatic_FindModule("LureArchers"), mkr_lure_archer_dest)
	
	Rule_AddOneShot(Patay_SpawnRegiment, 2, {index = 1})
	Rule_AddOneShot(Patay_SpawnRegiment, 3, {index = 2})
	Rule_AddOneShot(Patay_SpawnRegiment, 4, {index = 3})
	
end

function Patay_SpawnRegiment(context, data)
	
	local i = data.index
	local regiment = t_regiments[i]
	SpawnUnitsToModule(regiment.units, regiment.name, regiment.marker)
	SGroup_AddGroup(regiment.sgroup_master, regiment.sgroup)
	
	
	if i <= #t_scatter_groups then
		
		local scatter_group = t_scatter_groups[i]
		
		local marker_main = Marker_FromName("scatter"..tostring(i).."_main", "")
		local marker1 = Marker_FromName("scatter"..tostring(i).."_1", "")
		local marker2 = Marker_FromName("scatter"..tostring(i).."_2", "")
		
		UnitEntry_DeploySquads(playerEnglish, scatter_group.sgroup, scatter_group.units[1], marker_main)
		UnitEntry_DeploySquads(playerEnglish, scatter_group.sgroup, scatter_group.units[2], marker1)
		UnitEntry_DeploySquads(playerEnglish, scatter_group.sgroup, scatter_group.units[3], marker2)
		
		SGroup_AddGroup(scatter_group.sgroup_master, scatter_group.sgroup)
	end
	
	-- init counts
	local regiment = t_regiments[i]
	regiment.initCount = SGroup_CountSpawned(regiment.sgroup_master)
	
end


function Patay_SetBattleProgress(initCount, currentCount, threshold)
	
	local remaining = currentCount - threshold
	
	if remaining <= 0 then
		main_battle_progress = main_battle_progress + (1/4)
	else
		local allowed_losses = initCount - threshold
		local progress = (allowed_losses - remaining) / allowed_losses
		main_battle_progress = main_battle_progress + (progress * (1/4))
	end
	
end

function Patay_ProcessMainBattle()
	
	local player_count = Player_GetTotalPopulation(player1)
	
	if main_line_broken == false then
		
		local main_line_count = SGroup_CountSpawned(sg_main_line)
		
		main_battle_progress = 0
		Patay_SetBattleProgress(24, main_line_count, main_line_threshold)
		
		if main_line_count <= main_line_threshold then
			
			main_line_broken = true
			Cmd_FormationMove(sg_main_line, mkr_reg1_main)
		end
	
	else
		main_battle_progress = (1/4)
		
		Player_GetAllSquadsNearMarker(playerEnglish, sg_temp, mkr_main_battle_center, 40)
		
		if battle_groups_broken >= 3 or SGroup_CountSpawned(sg_temp) == 0 then
			
			SGroup_AddGroup(sg_main_retreat, sg_main_line)
			SGroup_AddGroup(sg_main_retreat, sg_battle_retreat1)
			SGroup_AddGroup(sg_main_retreat, sg_battle_retreat2)
			SGroup_AddGroup(sg_main_retreat, sg_battle_retreat3)
			--SGroup_AddGroup(sg_main_retreat, sg_battle_retreat4)
			
			Rule_AddOneShot(Patay_MergeRetreatIntoRegiment1, 35)
			
			Objective_Complete(OBJ_DefeatArmy)
			--Rule_AddInterval(Patay_CheckMainRetreatTrigger, 1)
			Rule_RemoveMe()
		end
	end
	
	for i = 1, 3 do Patay_CheckBattleGroup(i) end
	Obj_SetProgress(OBJ_DefeatArmy.ID, main_battle_progress)
end

function Patay_CheckBattleGroup(num)
	
	local sgroup = SGroup_FromName("sg_battle_group"..tostring(num))
	local unit_count = SGroup_CountSpawned(sgroup)
	
	Patay_SetBattleProgress(14, unit_count, battle_group_threshold)
	
	if unit_count > 0 and unit_count <= battle_group_threshold then
		
		local module = MissionOMatic_FindModule("BattleGroup"..tostring(num))
		local sgroup_retreat = SGroup_FromName("sg_battle_retreat"..tostring(num))
		
		local _Assign = function(gid, idx, sid)
			if Squad_IsAlive(sid) then
				SGroup_Add(sgroup_retreat, sid)
			end
		end
		
		SGroup_ForEach(sgroup, _Assign)
		RovingArmy_Disband(module)
		Cmd_FormationMove(sgroup_retreat, mkr_reg1_main)
		
		battle_groups_broken = battle_groups_broken + 1
	end
end

function Patay_StartClearRegiments()
	Objective_Start(OBJ_ClearRegiments)
end

function Patay_InitPatay()
	
	UnitEntry_DeploySquads(playerAllies, sg_player_farmers, {{type = "scar_villager", numSquads = 8 }}, mkr_patay1)
	UnitEntry_DeploySquads(playerAllies, sg_player_woodcutters, {{type = "scar_villager", numSquads = 6 }}, mkr_patay2)
	UnitEntry_DeploySquads(playerAllies, sg_player_gold_miners, {{type = "scar_villager", numSquads = 3 }}, mkr_patay3)
	UnitEntry_DeploySquads(playerAllies, sg_player_stone_miners, {{type = "scar_villager", numSquads = 1 }}, mkr_patay4)
	UnitEntry_DeploySquads(playerAllies, sg_player_shepherds, {{type = "scar_villager", numSquads = 2 }}, mkr_patay5)
	
	AssignVillagersToFarms(sg_player_farmers)
	AssignVillagersToGold(sg_player_gold_miners)
	AssignVillagersToStone(sg_player_stone_miners)
	AssignVillagersToWood(sg_player_woodcutters)
	
	Modify_WoodGatherRate(sg_player_woodcutters, 0.1)
	Modify_GoldGatherRate(sg_player_gold_miners, 0.1)
	Modify_StoneGatherRate(sg_player_stone_miners, 0.1)
	
end

function Patay_CheckAllyFlee()
	
	if farmers_fled == false then
		if Player_CanSeeSGroup(playerEnglish, sg_player_farmers, ANY) then
			farmers_fled = true
			Cmd_AttackMove(sg_player_farmers, mkr_ally_flee)
		end
	end
	
	if woodcutters_fled == false then
		if Player_CanSeeSGroup(playerEnglish, sg_player_woodcutters, ANY) then
			woodcutters_fled = true
			Cmd_AttackMove(sg_player_woodcutters, mkr_ally_flee)
		end
	end
	
	if gold_miners_fled == false then
		if Player_CanSeeSGroup(playerEnglish, sg_player_gold_miners, ANY) then
			gold_miners_fled = true
			Cmd_AttackMove(sg_player_gold_miners, mkr_ally_flee)
		end
	end
	
	if stone_miners_fled == false then
		if Player_CanSeeSGroup(playerEnglish, sg_player_stone_miners, ANY) then
			stone_miners_fled = true
			Cmd_AttackMove(sg_player_stone_miners, mkr_ally_flee)
		end
	end
	
	if shepherds_fled == false then
		if Player_CanSeeSGroup(playerEnglish, sg_player_shepherds, ANY) then
			shepherds_fled = true
			Cmd_AttackMove(sg_player_shepherds, mkr_ally_flee)
		end
	end
end

function Patay_TakeControlOfPatay()
	-- if on console, restore the VPS at this point
	if UI_IsXboxControllerUI() then
		Game_SetVisibility(VF_XboxUIVillagerPriorities, true)
	end
	
	Rule_Remove(Patay_CheckAllyFlee)
	Rule_Remove(Patay_CheckDiplomacyReminder)
	
	Player_SetMaxPopulation(player1, CT_Personnel, 0)	
	Patay_SetPopulationCapVisibility(true)
	
	EGroup_SetPlayerOwner(eg_patay, player1)
	EGroup_SetPlayerOwner(eg_patay_tc, player1)
	
	Defend_Disband(MissionOMatic_FindModule("PatayDefenders1"))
	Defend_Disband(MissionOMatic_FindModule("PatayDefenders2"))
	
	Player_GetAll(playerAllies)
	SGroup_SetPlayerOwner(sg_allsquads, player1)
	
	--give the player some resources based on time
	local minutes_elapsed = math.ceil((World_GetGameTime() - patay_start_time) * 0.01667)
	
	local resources = {
		gold = 100 * minutes_elapsed, 
		wood = 100 * minutes_elapsed, 
		food = 200 * minutes_elapsed, 
		stone = 50 * minutes_elapsed,
	}
	
	Player_AddResources(player1, resources)
	
	AssignVillagersToSheep(sg_player_shepherds)
	
	Modify_WoodGatherRate(sg_player_woodcutters, 10)
	Modify_GoldGatherRate(sg_player_gold_miners, 10)
	Modify_StoneGatherRate(sg_player_stone_miners, 10)
	
	mkr_reinforce_main = mkr_reinforce4
	mkr_reinforce_main_dest = mkr_reinforce_dest4
	
	Util_AutoSave()
	
end


function Patay_BeginChasePhase()
	
	Objective_Start(OBJ_ClearRegiments)
	Rule_AddInterval(Patay_CheckPatayDefendTrigger, 1)
	Rule_AddInterval(Patay_CheckRegiments, 1)
	Rule_AddSGroupEvent(Patay_CheerRegiment1, sg_regiment1, GE_SquadKilled)
	Rule_AddSGroupEvent(Patay_CheerRegiment2, sg_regiment2, GE_SquadKilled)
	Rule_AddSGroupEvent(Patay_CheerRegiment3, sg_regiment3, GE_SquadKilled)
	Rule_AddInterval(Patay_CheckScatterGroups, 3)
	
	-- slow down regiments
	Modify_UnitSpeed(sg_regiment_main1, 0.5)
	Modify_UnitSpeed(sg_regiment_main2, 0.5)
	Modify_UnitSpeed(sg_regiment_main3, 0.5)
	
	-- timed activation of regiments
	Rule_AddOneShot(Patay_WakeRegiment1, t_difficulty.regimentWakeTimer)
	Rule_AddOneShot(Patay_WakeRegiment2, t_difficulty.regimentWakeTimer * 3)
	Rule_AddOneShot(Patay_WakeRegiment3, t_difficulty.regimentWakeTimer * 5)
	
	if SGroup_CountSpawned(sg_sigmund_attack) > 0 then
		RovingArmy_SetTarget(MissionOMatic_FindModule("SigmundAttackers"), mkr_patay_center)
	end
	
	if not Objective_IsComplete(OBJ_DefeatArmy) then
		
		local targets = {mkr_eastroad1, mkr_eastroad2, mkr_eastroad3, mkr_eastroad4, mkr_eastroad5, mkr_eastroad6, mkr_patay_center}
		
		-- relief army heads to patay
		if SGroup_CountSpawned(sg_main_line) > 0 then
			Prefab_DoAction(MissionOMatic_FindModule("BattleGroup1"), "AddSGroup", sg_main_line)
		end
		
		Patay_AddArmyTargets("BattleGroup1", sg_battle_group1, targets)
		Patay_AddArmyTargets("BattleGroup2", sg_battle_group2, targets)
		Patay_AddArmyTargets("BattleGroup3", sg_battle_group3, targets)
		--Patay_AddArmyTargets("BattleGroup4", sg_battle_group4, targets)
		
		Objective_RemoveUIElements(OBJ_DefeatArmy, hpid_army)
		Objective_AddUIElements(OBJ_DefeatArmy, sg_battle_group1, true, 11180181, false)
	end
	
end

function Patay_CheckScatterGroups()
	
	for i = 1, #t_scatter_groups do
		
		local scatter_group = t_scatter_groups[i]
		
		if scatter_group.isAlive == true then
		
			if SGroup_CountSpawned(scatter_group.sgroup) == 0 then
				scatter_group.isAlive = false
			elseif scatter_group.hasMerged == true then
				-- is there anything further to do here?
			elseif scatter_group.isFleeing == true then
				-- am i close enough to the main regiment to merge in?
				
				if SGroup_CountSpawned(scatter_group.sgroup_target) > 0 then
					if Prox_AreSquadsNearMarker(scatter_group.sgroup, Util_GetPosition(scatter_group.sgroup_target), ANY, 20) then
						scatter_group.hasMerged = true
						Prefab_DoAction(MissionOMatic_FindModule(scatter_group.merge_target), "AddSGroup", scatter_group.sgroup)
					end
				end
			else
				-- does the player locally outnumber me?
				Player_GetAllSquadsNearMarker(player1, sg_temp, scatter_group.marker, 15)
				if SGroup_CountSpawned(sg_temp) > SGroup_CountSpawned(scatter_group.sgroup) then
					scatter_group.isFleeing = true
					Cmd_FormationMove(scatter_group.sgroup, mkr_patay_center)
				end
			end
		end
	end
end

function Patay_CheckRegiments()
	
	Patay_CheckRegiment(SOBJ_ClearRegiment1, t_regiments[1])
	Patay_CheckRegiment(SOBJ_ClearRegiment2, t_regiments[2])
	Patay_CheckRegiment(SOBJ_ClearRegiment3, t_regiments[3])
	
end

function Patay_CheckRegiment(objective, data)
	
	if not Objective_IsComplete(objective) then
		
		local count = SGroup_CountSpawned(data.sgroup_master)
		
		if count == 0 then
			regiments_cleared = regiments_cleared + 1
			
			if regiments_cleared < regiments_total then
				Objective_Complete(objective)
			else
				Objective_Complete(objective, false)
				Objective_Complete(OBJ_ClearRegiments)
			end
		else
			local progress = (data.initCount - count) / data.initCount
			Objective_SetProgressBar(objective, progress)
			
			--Obj_SetProgress(objective.ID, progress)
		end
		
		
		if data.isActive == false then
			
			Player_GetAll(player1)
			if Prox_AreSquadsNearMarker(sg_allsquads, data.marker, ANY, 60) then
				Patay_ActivateRegiment(data)
			end
			
		elseif data.hasSpeededUp == false then
			
			Player_GetAll(player1)
			if Prox_AreSquadsNearMarker(sg_allsquads, Util_GetPosition(data.sgroup), ANY, 35) then
				data.hasSpeededUp = true
				Modify_UnitSpeed(data.sgroup, 2)
			end
			
		elseif data.hasFullyMerged == false then
			
			if count < (data.initCount * 0.5) then
				Patay_MergeRegiment(data)
			end
		end

	end
	
end

function Patay_CheerRegiment1(context,data)
	
	if SGroup_CountSpawned(sg_regiment1) < 1 then
		local pos = Squad_GetPosition(context.victim)
		Player_GetAllSquadsNearMarker(player1, sg_temp, pos, 35)
		Sound_PlayWallaCelebrateOnSGroup(sg_temp)
		Music_PlayStinger(MUS_STING_TRIUMPHANT)
		Rule_RemoveMe()
	end
	
