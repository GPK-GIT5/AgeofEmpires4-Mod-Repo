function Patay_MergeReserveIntoSigmund()
	
	if SGroup_CountSpawned(sg_sigmund_reserve) > 0 then
		Prefab_DoAction(MissionOMatic_FindModule("SigmundDefenders"), "AddSGroup", sg_sigmund_reserve)
	end
end

function Patay_MergeIntoSigmund()
	
	if SGroup_CountSpawned(sg_road_blockers) > 0 then
		sigmund_init_count = sigmund_init_count + SGroup_CountSpawned(sg_road_blockers)
		Prefab_DoAction(MissionOMatic_FindModule("SigmundDefenders"), "AddSGroup", sg_road_blockers)
	end
end


function Patay_OnSquadKilled(context)
	
	local victim = context.victim
	
	if not World_OwnsSquad(victim) then
		
		if Squad_GetPlayerOwner(victim) == playerEnglish then
			
			if SGroup_ContainsSquad(sg_road_blockers, victim.SquadID, true) then
				
				if not Objective_IsComplete(OBJ_ClearRoad) then
					
					--if rear_guard_disbanded == false then
						--rear_guard_disbanded = true
						--Patay_DisbandRearguard()
					--end
					
					if SGroup_CountSpawned(sg_road_blockers) <= road_blocker_threshold then
						
						Objective_Complete(OBJ_ClearRoad)
						
						Cmd_FormationMove(sg_road_blockers, mkr_sigmund_trigger_center)
						Rule_AddOneShot(Patay_MergeIntoSigmund, 15)
						--Prefab_DoAction(MissionOMatic_FindModule("SigmundDefenders"), "AddSGroup", sg_road_blockers)
						
						Patay_CheckReinforcePanel()
						
					else
						
						local kill_count_goal = road_blocker_init_count - road_blocker_threshold
						local kill_count = road_blocker_init_count - SGroup_CountSpawned(sg_road_blockers)
						local progress = kill_count / kill_count_goal
						Objective_SetProgressBar(OBJ_ClearRoad, progress)
						
					end
				end
				
			elseif SGroup_ContainsSquad(sg_sigmund_main, victim.SquadID, true) then
				
				if not Objective_IsComplete(OBJ_ClearStSigmund) then
					
					if SGroup_CountSpawned(sg_sigmund_main) <= sigmund_threshold then
						
						Objective_SetProgressBar(OBJ_ClearStSigmund, 1)
						Objective_Complete(OBJ_ClearStSigmund)
						
						Defend_Disband(MissionOMatic_FindModule("SigmundDefenders"))
						
						Cmd_FormationMove(sg_sigmund_main, mkr_main_battle_rear_trigger)
						Rule_AddInterval(Patay_CheckSigmundRetreatTrigger, 1)
						
						mkr_reinforce_main = mkr_reinforce2
						mkr_reinforce_main_dest = mkr_reinforce_dest2
						
						Patay_CheckReinforcePanel()
						
					else
						
						local kill_count_goal = sigmund_init_count - sigmund_threshold
						local kill_count = sigmund_init_count - SGroup_CountSpawned(sg_sigmund_main)
						local progress = kill_count / kill_count_goal
						Objective_SetProgressBar(OBJ_ClearStSigmund, progress)
						
					end
				end
				
			end
				
		end
		
	end
	
end

