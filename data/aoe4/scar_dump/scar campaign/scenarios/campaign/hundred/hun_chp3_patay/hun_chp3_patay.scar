--
-- Patay 1429
--
-- Hundred campaign, mission 6
--

import("MissionOMatic/MissionOMatic.scar")		-- this imports the Cardinal scripts as well
import("hun_chp3_patay_data.scar")
import("diplomacy_chp3_patay.scar")
import("obj_defeat_english.scar")
import("obj_reinforcements.scar")

-- Training
import("hun_chp3_patay_training.scar")


function Mission_SetupPlayers()

	player1 = World_GetPlayerAt(1)
	player2 = World_GetPlayerAt(2)
	player3 = World_GetPlayerAt(3)
	player4 = World_GetPlayerAt(4)
	
	playerFrench = player1
	playerEnglish = player2
	playerAllies = player3
	playerNeutrals = player4 -- placeholder for leader
	
	Setup_SetPlayerName(player1, Loc_GetString("$11180115")) -- ("Jeanne d'Arc")))
	Player_SetCurrentAge(player1, AGE_CASTLE)
	Player_SetMaximumAge(player1, AGE_CASTLE)
	
	Setup_SetPlayerName(playerEnglish, Loc_GetString("$11180116")) -- ("John Talbot")))
	Player_SetCurrentAge(playerEnglish, AGE_CASTLE)
	Player_SetMaximumAge(playerEnglish, AGE_CASTLE)
	
	Setup_SetPlayerName(playerAllies, Loc_GetString("$11156660")) -- ("Patay")))
	Player_SetCurrentAge(playerAllies, AGE_CASTLE)
	Player_SetMaximumAge(playerAllies, AGE_CASTLE)
	
	Setup_SetPlayerName(playerNeutrals, Loc_GetString("$11180115")) -- ("Jeanne d'Arc")))
	Player_SetCurrentAge(playerNeutrals, AGE_CASTLE)
	Player_SetMaximumAge(playerNeutrals, AGE_CASTLE)
	AI_Enable(playerNeutrals,false)
	
	Player_SetRelationship(player1, playerNeutrals, R_ALLY)
	Player_SetRelationship(playerNeutrals, player1, R_ALLY)
	
	Player_SetRelationship(player1, playerAllies, R_ALLY)
	Player_SetRelationship(playerAllies, player1, R_ALLY)
	
	Player_SetRelationship(playerEnglish, playerAllies, R_NEUTRAL)
	Player_SetRelationship(playerAllies, playerEnglish, R_NEUTRAL)
	
	Player_SetRelationship(playerEnglish, playerNeutrals, R_NEUTRAL)
	Player_SetRelationship(playerNeutrals, playerEnglish, R_NEUTRAL)
	
	Player_SetMaxPopulation(player1, CT_Personnel, 200)	
	Patay_SetPopulationCapVisibility(false)
	
	PlayerColour_Enable()
	
    Game_SetPlayerSlotColour(player1, 1)
	Game_SetPlayerUISlotColour(player1, 1)
	
    Game_SetPlayerSlotColour(playerEnglish, 2)
	Game_SetPlayerUISlotColour(playerEnglish, 2)
	
    Game_SetPlayerSlotColour(playerAllies, 3)
	Game_SetPlayerUISlotColour(playerAllies, 3)
	
    Game_SetPlayerSlotColour(playerNeutrals, 1)
	Game_SetPlayerUISlotColour(playerNeutrals, 1)
	
end


function Mission_SetupVariables()
	
	Patay_Data_Init()
	Patay_InitStartingUnits()
	Patay_InitDebug ()
end

function Mission_SetRestrictions()
	
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_DEFENSE_TOWER_FRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_DEFENSE_WALL_FRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_DEFENSE_WALL_GATE_FRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_TOWN_CENTER_CAPITAL_FRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_TOWN_CENTER_FRE, ITEM_REMOVED)
	
end

function Mission_SetDifficulty()
	
	t_difficulty = {
		--upgradeLevel = Util_DifVar({0, 1, 2, 3}),
		regimentWakeTimer = Util_DifVar({60, 40, 30, 30}),
		regimentBaseCount = Util_DifVar({9, 10, 10, 10}),
		regimentSiegeCount = Util_DifVar({1, 2, 2, 2}),
	}
	
 end

function Mission_PreInit()
	Patay_HideTributeMenu()
end

function Patay_ShowTributeMenu()
	Diplomacy_ShowUI(true)
end

function Patay_SetPopulationCapVisibility(visibility)
	
	for index, player in pairs(PLAYERS) do
		if player.isLocal == true then
			player.scarModel.PopulationCapOn  = visibility
			UI_SetPlayerDataContext(player1, player.scarModel)
		end
    end
end

function Patay_HideTributeMenu()

	Core_CallDelegateFunctions("DiplomacyEnabled", false)
	Diplomacy_ShowUI(false)
end

function Patay_CheckReinforcePanel()
	
	if  reinforce_panel_enabled == false then
		
		reinforce_panel_enabled = true
		Patay_ShowTributeMenu()
		UI_ReinforcePanel_UpdateData()
		Rule_AddInterval(UI_ReinforcePanel_UpdateData, 1)
		
		if UI_IsXboxUI() == false then
			Diplomacy_ShowDiplomacyUI(true)
		end
		
		Rule_AddInterval(Patay_CheckDiplomacyReminder, 1)
		Rule_AddOneShot(Patay_EnableSendGoldHint, 20)
		
	end
end

function Patay_CheckDiplomacyReminder()
	
	current_gold_total = Player_GetResource(player1, RT_Gold)
	
	if current_gold_total >= 1000 then
		if current_gold_total > prev_gold_total and Diplomacy_IsExpanded() == false and UI_IsXboxUI() == false then
			Diplomacy_ShowDiplomacyUI(true)
		end
	end
	
	prev_gold_total = current_gold_total
end

function Patay_EnableSendGoldHint()
	TrainingGoal_AddSendGold()
	TrainingGoal_EnableSendGold()
end



function Mission_Preset()
	
	PlayerUpgrades_Auto(player1, false)
	PlayerUpgrades_Auto(playerEnglish, false, { 
		UPG.COMMON.UPGRADE_RANGED_ARCHER_SILKSTRING,
		UPG.FRENCH.UPGRADE_RANGED_INCENDIARY_FRE,
		UPG.COMMON.UPGRADE_RANGED_DAMAGE_II
	})
	
	PlayerUpgrades_LearnAllResearch(playerAllies, AGE_FEUDAL, {}, Player_GetRaceName(playerAllies))
	PlayerUpgrades_LearnAllUnits(playerAllies, AGE_FEUDAL, {}, Player_GetRaceName(playerAllies))
	
	Player_CompleteUpgrade(player1, UPG.FRENCH.UPGRADE_UNIT_KNIGHT_3_FRE)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_UNIT_HORSEMAN_3)
	
	DefeatEnglish_InitObjectives()
	
	Rule_AddGlobalEvent(Patay_OnSquadKilled, GE_SquadKilled)
	
	-- Audio considerations
	if Music_UnlockIntensity then
		Sound_SetForceMusic(false)
	else
		Sound_SetForceMusic(true)
	end
	
	AudioTrigger_InitAreaTrigger({
		marker = mkr_patay_trigger,
		audioCue = MUSIC_COMBAT_RARE,
		triggeringPlayer = playerEnglish,
		startAboveUnitCount = 10,
		duration = 40,
	})	
	
	Patay_MoveStartingUnits1()
	Patay_MoveStartingUnits2()
	Rule_AddOneShot(Patay_ReverseSpeedMod, 7)
	
	Patay_SetGoldValue()
	Patay_InitPatay()
	
end

function Mission_Start()
	-- on console don't restore VPS at first (as we have no villagers until we reach Patay)
	Cardinal_EnablePartialXboxUI(true, {VF_XboxUIVillagerPriorities})

	Objective_Start(OBJ_DefeatEnglish)
	Rule_AddInterval(Patay_CheckAmbushTrigger, 1)
	Rule_AddInterval(Patay_CheckMissionFail, 1)
	Rule_AddInterval(Patay_CheckGoldPickupsLooted, 1)
	
	road_blocker_init_count = SGroup_CountSpawned(sg_road_blockers)
	
	Cmd_Ability(sg_road_blockers, BP_GetAbilityBlueprint("deploy_palings"))
	Cmd_Ability(sg_main_line, BP_GetAbilityBlueprint("deploy_palings"))
	
	-- Reset resources
	Player_SetResource(player1, RT_Wood, 0)
	Player_SetResource(player1, RT_Gold, 3000)
	Player_SetResource(player1, RT_Food, 0)
	
	FOW_PlayerRevealArea(player1, Util_GetPosition(mkr_patay_trigger), 50, -1)
	hint_patay = HintPoint_Add(mkr_patay_trigger, true, "$11156660", LOCATION_LABEL_HEIGHT, nil, nil, nil, true, nil)
	
	Patay_SpawnSigmundReserve()
	
end

function Patay_CheckMissionFail()
	
	Player_GetAll(player1)
	SGroup_Filter(sg_allsquads, "scar_villager", FILTER_REMOVE)
	SGroup_Filter(sg_allsquads, "gaia", FILTER_REMOVE)
	EGroup_Filter(eg_allentities, "town_center", FILTER_KEEP)
	
	if SGroup_CountSpawned(sg_allsquads) <= 0 and EGroup_CountSpawned(eg_allentities) <= 0 then
		Mission_Fail()
	end
	
	if Objective_IsStarted(OBJ_DefendPatay) then
		if EGroup_CountSpawned(eg_patay_tc) == 0 then
			Mission_Fail()
		end
	end
	
end

function Patay_CombatIntensityIntro()
	Sound_SetMinimumMusicCombatIntensity(801,0)
end

function Patay_StartRearguardPursuit()
	
	if rearguard_pursuit_started == false then
		rearguard_pursuit_started = true
		RovingArmy_SetTargets(MissionOMatic_FindModule("Rearguard1"), rearguard_pursuit_targets)
		RovingArmy_SetTargets(MissionOMatic_FindModule("Rearguard2"), rearguard_pursuit_targets)
		RovingArmy_SetTargets(MissionOMatic_FindModule("Rearguard3"), rearguard_pursuit_targets)
		RovingArmy_SetTargets(MissionOMatic_FindModule("Rearguard4"), rearguard_pursuit_targets)
	end

end

function Patay_DisbandRearguard()
	
	RovingArmy_Disband(MissionOMatic_FindModule("Rearguard1"))
	RovingArmy_Disband(MissionOMatic_FindModule("Rearguard2"))
	RovingArmy_Disband(MissionOMatic_FindModule("Rearguard3"))
	RovingArmy_Disband(MissionOMatic_FindModule("Rearguard4"))
	
	Cmd_AttackMove(sg_rearguard, mkr_rearguard_flee)
	Rule_AddInterval(Patay_CheckRearguardDespawn, 3)

end

--mkr_ford_trigger

function Patay_CheckHasLeftAmbushArea()
	
	if Prox_AreSquadsNearMarker(sg_startingUnitsFrench, mkr_ford_trigger, ANY, 15) or Prox_AreSquadsNearMarker(sg_startingUnitsFrench, mkr_barricade1, ANY, 15) then
		
		if SGroup_CountSpawned(sg_rearguard) > 0 then
			Patay_StartRearguardPursuit()
		end
		Rule_RemoveMe()
	end
	
end

function Patay_CheckRearguardDespawn()
	
	if SGroup_CountSpawned(sg_rearguard) == 0 then
		Rule_RemoveMe()
	end
	
	if Prox_AreSquadsNearMarker(sg_rearguard, mkr_rearguard_flee, ANY, 10) then
		if not Player_CanSeeSGroup(player1, sg_rearguard, ANY) then
			SGroup_DestroyAllSquads(sg_rearguard)
			Rule_RemoveMe()
		end
	end
end

function Patay_CheckSigmundTrigger()

	Player_GetAll(player1)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_sigmund_trigger_center, ANY, 40) then
		Rule_AddOneShot(Patay_MergeReserveIntoSigmund, 3)
		Rule_RemoveMe()
	end
end

function Patay_CheckPatayTrigger()
	
	Player_GetAll(player1)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_patay_trigger, ANY, 50) then
		Objective_Complete(OBJ_TakePatay)
		Patay_TakeControlOfPatay()
		Music_PlayStinger(MUS_STING_POSITIVE)
		Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_patay_trigger, Marker_GetProximityRadius(mkr_patay_trigger))
		Sound_PlayWallaCelebrateOnSGroup(sg_temp)
		Rule_RemoveMe()
	end
end

function Patay_CheckClearRoadTrigger()
	
	Player_GetAll(player1)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_clear_road_trigger, ANY) then
		Objective_Start(OBJ_ClearRoad)
		Rule_RemoveMe()
	end
end

function Patay_CheckAmbushTrigger()

	Player_GetAll(player1)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_ambush_trigger, ANY, 15) then
		
		if not intro_skipped then
			SGroup_DestroyAllSquads(sg_intro_archers1)
			SGroup_DestroyAllSquads(sg_intro_archers2)
			SGroup_DestroyAllSquads(sg_intro_archers3)
			SGroup_DestroyAllSquads(sg_intro_archers4)
			SGroup_DestroyAllSquads(sg_intro_archers5)
		end
		
		Patay_SpawnAmbush()
		
		FOW_PlayerRevealArea(player1, Util_GetPosition(mkr_rearguard_attack1), 10, 12)
		FOW_PlayerRevealArea(player1, Util_GetPosition(mkr_rearguard_attack2), 10, 12)
		FOW_PlayerRevealArea(player1, Util_GetPosition(mkr_rearguard_attack3), 10, 12)
		
		Rule_AddInterval(Patay_CheckClearRoadTrigger, 1)
		Rule_AddInterval(Patay_CheckStSigmundTrigger, 1)
		Rule_AddInterval(Patay_CheckHasLeftAmbushArea, 1)
		
		Util_StartIntel(EVENTS["Ambush"])
		
		Rule_RemoveMe()
	end
end

function Patay_CheckStSigmundTrigger()
	
	Player_GetAll(player1)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_sigmund_trigger_start, ANY) then
		Objective_Start(OBJ_ClearStSigmund)
		Rule_AddInterval(Patay_CheckMainBattleTrigger, 1)
		Rule_RemoveMe()
	end
end

function Patay_CheckMainBattleTrigger()
	
	Player_GetAll(player1)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_main_battle_trigger, ANY, 25)  then
		
		Patay_StartDefeatArmy()
		Patay_StartRoadPatrol()
		Rule_AddInterval(Patay_CheckMainBattleStartTrigger, 1)
		Rule_RemoveMe()
	end
end

function Patay_CheckMainBattleStartTrigger()
	
	Player_GetAll(player1)
	if Prox_AreSquadsNearMarker(sg_allsquads, mkr_main_battle_start_trigger, ANY, 30)  then
		Patay_BeginMainBattle()
		--Rule_AddInterval(Patay_CheckMainRearTrigger, 2)
		
		if not Objective_IsComplete(OBJ_ClearStSigmund) then
			Rule_AddInterval(Patay_CheckSigmundFail, 2)
		end
		
		Rule_RemoveMe()
	end
end

function Patay_CheckSigmundFail()
	
	Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_main_battle_start_trigger, 35)
	if SGroup_CountSpawned(sg_temp) > 5 then
		--the player has run past st.sigmund without completing it
		Objective_Fail(OBJ_ClearStSigmund)
		DissolveModuleIntoModule("SigmundDefenders", "SigmundAttackers")
		
		--the blockade army is harder to break, now that it knows help is coming
		battle_group_threshold = 1
		main_line_threshold = 3
		
		Rule_RemoveMe()
	end
	
	if Objective_IsComplete(OBJ_ClearStSigmund) then
		Rule_RemoveMe()
	end
end

function Patay_StartRoadPatrol()
	
	UnitEntry_DeploySquads(playerEnglish, sg_road_patrol, {{type = "scar_archer", numSquads = 5}}, mkr_road_patrol)
	Cmd_AttackMove(sg_road_patrol, mkr_road_patrol_dest)
	Rule_AddInterval(Patay_CheckRoadPatrol, 1)
end

function Patay_CheckRoadPatrol()
	if Player_CanSeeSGroup(player1, sg_road_patrol, ANY) then
		Rule_AddOneShot(Patay_MergeRoadPatrol, 2)
		Rule_RemoveMe()
	end
end

function Patay_MergeRoadPatrol()
	Cmd_FormationMove(sg_road_patrol, mkr_main_battle_center)
	Prefab_DoAction(MissionOMatic_FindModule("BattleGroup2"), "AddSGroup", sg_road_patrol)
end

function Patay_AddArmyTarget(moduleName, sgroup, target)
	if SGroup_CountSpawned(sgroup) > 0 then
		RovingArmy_AddTarget(MissionOMatic_FindModule(moduleName), target)
	end
end

function Patay_AddArmyTargets(moduleName, sgroup, targets)
	if SGroup_CountSpawned(sgroup) > 0 then
		RovingArmy_AddTargets(MissionOMatic_FindModule(moduleName), targets)
	end
end

