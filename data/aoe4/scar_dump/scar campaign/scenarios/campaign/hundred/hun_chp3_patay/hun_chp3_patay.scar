		--Util_StartIntel(EVENTS[reserve.intel_event])
	--end
--end

function Patay_InitDebug ()
	OBJ_DebugComplete = {
        Title = LOC("Debug Complete"),
        Type = OT_Primary,
        showTitle = false,
        Cheat = function()
			Rule_RemoveAll()
			Player_GetAll(playerEnglish)
			SGroup_DestroyAllSquads(sg_allsquads)
			
			Music_StopMedium()
			--Music_Stop()
			Patay_TriggerOutro()
			
	       end,
	    }

    Objective_Register(OBJ_DebugComplete)	
end

-- Achievement tracking for Achievement #14 - Fill The Coffers - Collect every Gold chest in the Battle of Patay
function Patay_CheckGoldPickupsLooted()
	
	if EGroup_Count(eg_gold) == 0 then
		
		-- Unlock Achievement
		Game_SendCustomChallengeEvent(player1, CE_ACHIEVALLGOLDCHESTSPATAY, 1)
		Rule_RemoveMe()
	end
end