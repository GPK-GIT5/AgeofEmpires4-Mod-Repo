--
-- Patay 1429 - Tutorial elements
--

import("training/campaigntraininggoals.scar")
--import("training/coretraininggoals.scar")

local goal_sequence_send_gold = "send_gold"

function UserHasOpenedTheDiplomacyMenu()
	if not _userHasOpenedDiplomacyMenu and _diplomacy ~= nil and _diplomacy.data_context ~= nil then
		_userHasOpenedDiplomacyMenu = _diplomacy.data_context.is_ui_expanded
	end	
	return _userHasOpenedDiplomacyMenu
end

function UserHasZeroGold()
	if Player_GetResource(player1, RT_Gold) == 0 then
		return true
	end	
	return false
end

function ShouldRemindToSendGold(goalSequence)
	if Player_GetResource(player1, RT_Gold) >= 800 and _diplomacy.data_context.is_ui_expanded == false then
		if Timer_GetElapsed(goalSequence.timerID) > 45 then
			return true
		end
	end	
	return false
end

function ShouldPromptUserToSendGold(goalSequence)
	if _diplomacy ~= nil and _diplomacy.data_context ~= nil then
		
		-- has at least 400 gold, button is visible, ui is not expanded, x time has passed since last opening
		if _diplomacy.data_context.is_ui_visible == true and _diplomacy.data_context.is_ui_expanded == false then
			if Player_GetResource(player1, RT_Gold) >= 400 then
				return true
			end
		end
	end
	return false
end

function TrainingGoal_AddSendGold()
	local send_gold_goal = Training_Goal("DiplomacyButton",
		{Message = "$11191744", DataTemplate="GenericTrainingDataTemplate"}, 
		UserHasOpenedTheDiplomacyMenu)
	local send_gold_sequence = Training_GoalSequence(goal_sequence_send_gold,
		1, 1, 
		ShouldPromptUserToSendGold, 
		CampaignTraining_TimeoutIgnorePredicate,
		ShouldRemindToSendGold, 
		UserHasZeroGold, 
		true, 
		{send_gold_goal})
	Training_AddGoalSequence(send_gold_sequence)
end

function TrainingGoal_EnableSendGold()
	Training_EnableGoalSequenceByID(goal_sequence_send_gold, true)
end

function TrainingGoal_DisableSendGold()
	Training_EnableGoalSequenceByID(goal_sequence_send_gold, false)
end

