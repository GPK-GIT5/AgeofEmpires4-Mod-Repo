		end,
		OnFail = function()
			Recruit2_OnFail(SOBJ_Recruit2, OBJ_RecruitChampions, false)
		end
	}
	SOBJ_Recruit3 = {
		Title = "$11197189", -- Win a Duel,
		Type = ObjectiveType_Battle,
		Parent = OBJ_RecruitChampions,
		PreStart = function()
			Recruit3_PreStart(SOBJ_Recruit3, OBJ_RecruitChampions, false)
