--
-- Combat of the Thirty - Approach
--

function MoveToAndRespectFacing(sgroup, marker, queued)
	Cmd_FormationMove(sgroup, marker, queued, false, Util_GetFacingFromDirection(Marker_GetPosition(marker), Marker_GetDirection(marker)))
end

function Approach_InitObjectives()
	
	OBJ_RecruitChampions = {
		Title = "$11197131", -- "Recruit Champions to Combat the English",
		Type = ObjectiveType_Primary,
		PreStart = function()
			print("OBJ_RecruitChampions PreStart")
			Combat30_VillagersToWork()
		end,
		OnStart = function()
			print("OBJ_RecruitChampions OnStart")
			Util_StartIntel(EVENTS.RecruitChampions_Start)
			
			hintpoint_recruit1 = Objective_AddUIElements(OBJ_RecruitChampions, mkr_recruit1, true, "$11197133", false, 5 ) --French Champion
			Objective_SetCounter(OBJ_RecruitChampions, 0, 2)
			
			Rule_AddInterval(Recruit1_Trigger, 1)
			Rule_AddInterval(Recruit2_Trigger, 1)
			Rule_AddInterval(Recruit3_Trigger, 1)
			Rule_AddInterval(Recruit4_Trigger, 1)
			
			Rule_AddInterval(Combat30_BeaumanoirLowHealth, 1)
			Rule_AddInterval(Combat30_FailCheck, 1)
		end,
		IsFailed = function()
			return recruitFailedCount > 2
		end,
		OnFail = function()
			print("OBJ_RecruitChampions OnFail")
			Mission_Fail()
		end,
		PreComplete = function()
			print("OBJ_RecruitChampions PreComplete")
		end,
		OnComplete = function()
			print("OBJ_RecruitChampions OnComplete")
			if recruitedChampions == 2 then
				Combat30_LastChampionVO()
			end
			Objective_Start(OBJ_Arrive, false)
			if recruitFailedCount < 2 then
				Objective_Start(OBJ_RecruitChampions_Optional, false, false)
			end
		end,
	}
	SOBJ_Recruit1 = {
		Title = "$11197134", --Kill wolves attacking villagers
		Type = ObjectiveType_Battle,
		Parent = OBJ_RecruitChampions,
		PreStart = function()
			Recruit1_PreStart(SOBJ_Recruit1, OBJ_RecruitChampions, false)
		end,
		OnStart = function()
			Recruit1_OnStart(SOBJ_Recruit1, OBJ_RecruitChampions, false)
		end,
		PreComplete = function()
			Recruit1_PreComplete(SOBJ_Recruit1, OBJ_RecruitChampions, false)
		end,
		OnComplete = function()
			Recruit1_OnComplete(SOBJ_Recruit1, OBJ_RecruitChampions, false)
		end,
		PreFail = function()
			Recruit1_PreFail(SOBJ_Recruit1, OBJ_RecruitChampions, false)
		end,
		OnFail = function()
			Recruit1_OnFail(SOBJ_Recruit1, OBJ_RecruitChampions, false)
		end
	}
	SOBJ_Recruit2 = {
		Title = "$11197135", --"Defeat the English raiders"
		Type = ObjectiveType_Battle,
		Parent = OBJ_RecruitChampions,
		PreStart = function()
			Recruit2_PreStart(SOBJ_Recruit2, OBJ_RecruitChampions, false)
		end,
		OnStart = function()
			Recruit2_OnStart(SOBJ_Recruit2, OBJ_RecruitChampions, false)
		end,
		PreComplete = function()
