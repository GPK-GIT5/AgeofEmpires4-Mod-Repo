--
-- Recurit 3 - Recruit Yves Charruel (win a duel)
--
function Recruit3_SpawnDuel()
	print("Spawn Duel")
	sg_recruit3_villagers = SGroup_CreateIfNotFound("sg_recruit3_villagers")
	sg_recruit3 = SGroup_CreateIfNotFound("sg_recruit3")
	for k,v in pairs(mkr_duelvillager_group) do
		UnitEntry_DeploySquads(player3, sg_recruit3_villagers, { type = "scar_villager" }, v)
	end
	UnitEntry_DeploySquads(player3, sg_recruit3, { sbp = SBP.FRENCH.UNIT_YVES_CHARRUEL_CMP_FRE }, mkr_duelistspawn)
	MoveToAndRespectFacing(sg_recruit3, mkr_start_enemy)
end

function Recruit3_CheckDuelComplete()
	if Objective_IsFailed(SOBJ_Recruit3) or Objective_IsFailed(SOBJ_Recruit3_Optional) then
		Rule_RemoveMe()
	elseif Objective_IsComplete(OBJ_RecruitChampions_Optional) then 
		Rule_RemoveMe()
	else
		if SGroup_GetAvgHealth(sg_recruit3) < 0.5 then
			if not Objective_IsComplete(OBJ_RecruitChampions) then
				local play_banner = (recruitedChampions ~= 1)
				Objective_UpdateText(SOBJ_Recruit3, 11197138, nil, false) --"Recruit Yves Charruel"
				Objective_Complete(SOBJ_Recruit3, play_banner)
			else
				Objective_UpdateText(SOBJ_Recruit3_Optional, 11197138, nil, false) --"Recruit Yves Charruel"
				Objective_Complete(SOBJ_Recruit3_Optional)
			end
			Rule_RemoveMe()
		end
	end
end

function Recruit3_CatchTravellers()
	if Objective_IsComplete(SOBJ_Recruit3) or Objective_IsComplete(SOBJ_Recruit3_Optional) or Objective_IsFailed(SOBJ_Recruit3) or Objective_IsFailed(SOBJ_Recruit3_Optional) then
		Rule_AddInterval(Recruit3_ResumeTravellers, 3)
		Rule_RemoveMe()
	else
		Player_GetAllSquadsNearMarker(player7, sg_temp, mkr_mainpath13, 15)
		Cmd_FormationMove(sg_temp, mkr_dueltravellers)
		SGroup_AddGroup(sg_travellers_hold, sg_temp)
	end
end

function Recruit3_ResumeTravellers() -- Send collected travellers onward in groups now that the bridge duel is over
	if SGroup_Count(sg_travellers_hold) == 0 then
		Rule_RemoveMe()
	else
		local markerList = { mkr_mainpath14, mkr_mainpath15, mkr_mainpath16, mkr_mainpath17, mkr_mainpath18, mkr_mainpath19, mkr_mainpath20 }
		local sgroup = SGroup_CreateUnique("sg_traveller_")
		local groupSize = World_GetRand(1, 4)
		
		if SGroup_Count(sg_travellers_hold) < groupSize then
			groupSize = SGroup_Count(sg_travellers_hold)
		end
		
		for i=1, groupSize, 1 do
			SGroup_Add(sgroup, SGroup_GetSquadAt(sg_travellers_hold, i))
		end
		SGroup_RemoveGroup(sg_travellers_hold, sgroup)
		
		for index, marker in pairs(markerList) do
			if scartype(marker) == ST_MARKER then
				if index < #markerList then
					Cmd_FormationMove(sgroup, marker, true)
				elseif index == #markerList then
					Cmd_FormationMoveToAndDestroy(sgroup, marker, true)
				end
			end
		end
	end
end

function Recruit3_PostDuelRelationships()
	Player_SetRelationship(player1, player5, R_ALLY)
	Player_SetRelationship(player3, player5, R_ALLY)
	Player_SetRelationship(player5, player1, R_ALLY)
	Player_SetRelationship(player3, player3, R_ALLY)
	World_EnableSharedLineOfSight(player1, player5, false)
end

--
-- Recurit 4 - Recruit Geoffroy du Bois (defeat the longbowmen, then defend the outpost)
--
function Recruit4_SpawnEnglishArchers()
	local module = recruit_module_groups[4][1]
	SpawnUnitsToModule({ type = "scar_archer", numSquads = Util_DifVar({9, 10, 11, 12}) }, module, mkr_englisharchers)
	SGroup_AddGroup(sg_recruit4_enemies, module.sgroup)
	Rule_AddInterval(Recruit4_CheckEnglishDead, 1)	
end

function Recruit4_CheckEnglishDead()
	if Objective_IsComplete(OBJ_RecruitChampions_Optional) then
		Rule_RemoveMe()
	elseif SGroup_IsEmpty(sg_recruit4_enemies) then
		Recruit4_SpawnEnglishWaves()
		Rule_RemoveMe()
	end
end

function Recruit4_SpawnEnglishWaves()
	Util_StartIntel(EVENTS.Recruit4_Step1)
	towerDefended = false 
	if not Objective_IsComplete(OBJ_RecruitChampions) then
		Objective_UpdateText(SOBJ_Recruit4, "$11197959")
		Objective_StartTimer(SOBJ_Recruit4, COUNT_DOWN, defendTimer, 10)
	else
		Objective_UpdateText(SOBJ_Recruit4_Optional, "$11197959")
		Objective_StartTimer(SOBJ_Recruit4_Optional, COUNT_DOWN, defendTimer, 10)
	end
	Rule_AddOneShot(Recruit4_TowerDefended, defendTimer)
	Rule_AddInterval(Recruit4_CheckTowerAlive, 1)
	recruit4_wave_index = 0
	Rule_AddOneShot(Recruit4_SpawnRandomWave, 0)
	Rule_AddOneShot(Recruit4_SpawnRandomWave, 18)
	Rule_AddOneShot(Recruit4_SpawnRandomWave, 34)
	Rule_AddOneShot(Recruit4_SpawnRandomWave, 48)
	Rule_AddOneShot(Recruit4_SpawnRandomWave, 60)
	Rule_AddOneShot(Recruit4_SpawnRandomWave, 70)
end
	
function Recruit4_TowerDefended()
	if not Objective_IsFailed(SOBJ_Recruit4) and not Objective_IsFailed(SOBJ_Recruit4_Optional) then
		towerDefended = true
	end
end

function Recruit4_SpawnRandomWave()
	recruit4_wave_index = recruit4_wave_index + 1
	local module = recruit_module_groups[4][recruit4_wave_index]
	local unitOptions = {
		{
			{ type = "scar_horseman", numSquads = Util_DifVar({4, 4, 5, 5}) },
		},
		{
			{ type = "scar_spearman", numSquads = Util_DifVar({3, 4, 5, 6}) },
		},
		{
			{ type = "scar_manatarms", numSquads = Util_DifVar({3, 4, 4, 5}) },
		},
		{
			{ type = "scar_spearman", numSquads = Util_DifVar({3, 4, 5, 6}) },
		},
		{
			{ type = "scar_manatarms", numSquads = Util_DifVar({3, 4, 5, 6}) },
		},
		{
			{ type = "scar_horseman", numSquads = Util_DifVar({2, 3, 4, 3}) },
			{ type = "scar_knight", numSquads = Util_DifVar({1, 1, 1, 2}) },
		},
	}
	local units = unitOptions[recruit4_wave_index]
	towerWaveCount = towerWaveCount 
	local randomSpawn = Table_GetRandomItem({ mkr_englishtower_west, mkr_englishtower_east, mkr_englishtower_south })
	
	if not Objective_IsFailed(SOBJ_Recruit4) and not Objective_IsFailed(SOBJ_Recruit4_Optional) and not Objective_IsComplete(OBJ_RecruitChampions_Optional) then
		local options = { dynamicSpawnType = DST_CLOSEST_HIDDEN }
		SGroup_Clear(sg_temp)
		UnitEntry_DeploySquads(player2, sg_temp, units, randomSpawn, nil, nil, options)
		RovingArmy_AddSGroup(module, sg_temp)
		SGroup_AddGroup(sg_recruit4_enemies, module.sgroup)	
	end
end

function Recruit4_CheckTowerAlive()
	if Objective_IsComplete(OBJ_RecruitChampions_Optional) then
		Rule_RemoveMe()
	elseif EGroup_IsEmpty(eg_towerdefend) or SGroup_IsEmpty(sg_recruit4) then
		HintPoint_Remove(hintname_outpost)
		if not Objective_IsComplete(OBJ_RecruitChampions) then
			Objective_Fail(SOBJ_Recruit4)
		else
			Objective_Fail(SOBJ_Recruit4_Optional)
		end
		Rule_RemoveMe()
	elseif towerDefended and SGroup_CountSpawned(sg_recruit4_enemies) == 0 then
		HintPoint_Remove(hintname_outpost)
		if not Objective_IsComplete(OBJ_RecruitChampions) then
			local play_banner = (recruitedChampions ~= 1)
			Objective_UpdateText(SOBJ_Recruit4, "$11197950", nil, false) --"Recruit Geoffroy du Bois"
			Objective_Complete(SOBJ_Recruit4, play_banner)
		else
			Objective_UpdateText(SOBJ_Recruit4_Optional, "$11197950", nil, false)
			Objective_Complete(SOBJ_Recruit4_Optional, true)
		end
		Rule_RemoveMe()
	end
end



function Combat30_RecruitSGroup(sgroup)
	if not SGroup_IsEmpty(sgroup) then
		Util_SetPlayerOwner(sgroup, player1)
	end
	
	-- Call tutorials for Recruit 2 or 4 on first recruit. Recruit 1 and 3 are handled elsewhere because their flow is different
	if sgroup == sg_recruit2 and not rochefortTutorialTriggered then
		
		if UI_IsXboxControllerUI() then
			MissionTutorial_RochefortAura_Xbox()
		else
			MissionTutorial_RochefortAura()
		end
		
		rochefortTutorialTriggered = true
	elseif sgroup == sg_recruit4 and not boisTutorialTriggered then
		
		if UI_IsXboxControllerUI() then
			MissionTutorial_BloisAura_Xbox()
		else
			MissionTutorial_BloisAura()
		end
		
		boisTutorialTriggered = true
	end
end

function Combat30_UnrecruitSGroup(sgroup)
	if not SGroup_IsEmpty(sgroup) then
		Util_SetPlayerOwner(sgroup, player3)
	end
end

function Combat30_RetreatSGroup(sgroup)
	if not SGroup_IsEmpty(sgroup) then
		Util_SetPlayerOwner(sgroup, player3)
		Cmd_MoveToAndDestroy(sgroup, mkr_josselin)
	end
end

function Combat30_Recruit_BoundaryCheck(context, options)
	
	local boundary_marker = options.marker
	local sg_recruit_hero = options.sgroups[1]
	local objective = options.objective
	
	local function LeaderHasFled()
		return Util_GetDistance(SGroup_GetPosition(g_leaderBeaumanoir.sgroup), Marker_GetPosition(boundary_marker)) > Marker_GetProximityRadius(boundary_marker)
	end
	
	local function CheckSquad(group, index, squad)
		if Squad_GetPlayerOwner(squad) == player1 then
			if Marker_InProximity(boundary_marker, Squad_GetPosition(squad)) == false then
				Squad_SetPlayerOwner(squad, player3)
				SGroup_Clear(sg_temp)
				SGroup_Add(group, squad)
				Cmd_FormationAttackMove(group, boundary_marker)
			end
		elseif Squad_GetPlayerOwner(squad) == player3 then
			if Marker_InProximity(boundary_marker, Squad_GetPosition(squad)) == true then
				Squad_SetPlayerOwner(squad, player1)
				SGroup_Clear(sg_temp)
				SGroup_Add(group, squad)
				Cmd_FormationAttackMove(group, boundary_marker)
			end
		end
	end
	
	if Objective_IsComplete(objective) or Objective_IsFailed(objective) or Objective_IsComplete(OBJ_RecruitChampions_Optional) then
		Rule_RemoveMe()
	else
		if SGroup_IsEmpty(sg_recruit_hero) then 
		Objective_Fail(objective)
	else
			if SGroup_CountSpawned(g_leaderBeaumanoir.sgroup) > 0 and LeaderHasFled() == true then
				Objective_Fail(objective)
			else
				for i, sgroup in ipairs(options.sgroups) do
					SGroup_ForEach(sgroup, CheckSquad)
			end
		end
	end
end
end

function Combat30_Recruit3_BoundaryCheck()
	local marker = mkr_recruit3_retreat
	
	local function _IsChampionNearMarker(marker)
		return Util_GetDistance(SGroup_GetPosition(g_leaderBeaumanoir.sgroup), Marker_GetPosition(marker)) < Marker_GetProximityRadius(marker)
	end
	
	if Objective_IsComplete(SOBJ_Recruit3) or Objective_IsComplete(SOBJ_Recruit3_Optional) or Objective_IsComplete(OBJ_RecruitChampions_Optional) then
		Rule_RemoveMe()
	else
		if not SGroup_IsEmpty(g_leaderBeaumanoir.sgroup) then
			if not _IsChampionNearMarker(marker) then
				if not Objective_IsComplete(OBJ_RecruitChampions) then
					Objective_UpdateText(SOBJ_Recruit3, "$11197138", nil, false) --"Recruit Yves Charruel"
					Objective_Fail(SOBJ_Recruit3)
				else
					Objective_UpdateText(SOBJ_Recruit3_Optional, "$11197138", nil, false) --"Recruit Yves Charruel"
					Objective_Fail(SOBJ_Recruit3_Optional)
				end
				Rule_RemoveMe()
			end
		end 
	end
end

function Combat30_AddOptionToRecruitPanel(recruitNumber)
	table.insert(t_availableRecruitData, t_recruitData[recruitNumber])
	Combat30_ShowTributeMenu()
	
	--On Xbox, don't force open the diplomacy UI
	if UI_IsXboxUI() == false then
		Diplomacy_ShowDiplomacyUI(true)
	end
end

function Combat30_SpawnChampionsAtBase()
	
	local sgroupData = {
		{ sgroup = sg_recruit1,			marker = mkr_frespawn1, 		objective1 = SOBJ_Recruit1, objective2 = SOBJ_Recruit1_Optional, hintstring = 11195760 },
		{ sgroup = sg_recruit2,			marker = mkr_frespawn2, 		objective1 = SOBJ_Recruit2, objective2 = SOBJ_Recruit2_Optional, hintstring = 11195764 },
		{ sgroup = sg_recruit3,			marker = mkr_frespawn3, 		objective1 = SOBJ_Recruit3, objective2 = SOBJ_Recruit3_Optional, hintstring = 11195763 },
		{ sgroup = sg_recruit4,			marker = mkr_frespawn4, 		objective1 = SOBJ_Recruit4, objective2 = SOBJ_Recruit4_Optional, hintstring = 11195762 },
		{ sgroup = sg_recruit1_escort,	marker = mkr_frespawn1_escort, 	objective1 = SOBJ_Recruit1, objective2 = SOBJ_Recruit1_Optional, hintstring = nil },
		{ sgroup = sg_recruit2_escort,	marker = mkr_frespawn2_escort, 	objective1 = SOBJ_Recruit2, objective2 = SOBJ_Recruit2_Optional, hintstring = nil },
		{ sgroup = sg_recruit3_escort,	marker = mkr_frespawn3_escort, 	objective1 = SOBJ_Recruit3, objective2 = SOBJ_Recruit3_Optional, hintstring = nil },
		{ sgroup = sg_recruit4_escort,	marker = mkr_frespawn4_escort, 	objective1 = SOBJ_Recruit4, objective2 = SOBJ_Recruit4_Optional, hintstring = nil },
	}
	
	for k,v in pairs(sgroupData) do
		local sgroup = v.sgroup
		local marker = v.marker
		local objective1 = v.objective1
		local objective2 = v.objective2
		local hintstring = v.hintstring
		
		if not Objective_IsComplete(objective1) and not Objective_IsComplete(objective2) then
			Combat30_RetreatSGroup(sgroup)
		else
			Combat30_UnrecruitSGroup(sgroup)
			Modify_UnitSpeed(sgroup, 1.5)
			MoveToAndRespectFacing(sgroup, marker)
			--if hintstring ~= nil then
				--HintPoint_Add(sgroup, true, hintstring)
			--end
		end
	end
end

function Combat30_SpawnCrowd()
	villagercount = 8
	
	UnitEntry_DeploySquads(player5, sg_eng_crowd, { type = "scar_villager", numSquads = villagercount, holdPosition = true }, mkr_engcrowd1)
	UnitEntry_DeploySquads(player5, sg_eng_crowd, { type = "scar_villager", numSquads = villagercount, holdPosition = true }, mkr_engcrowd2)
	UnitEntry_DeploySquads(player3, sg_fre_crowd, { type = "scar_villager", numSquads = villagercount, holdPosition = true }, mkr_frecrowd1)
	UnitEntry_DeploySquads(player3, sg_fre_crowd, { type = "scar_villager", numSquads = villagercount, holdPosition = true }, mkr_frecrowd2)
	Modify_WeaponRange(sg_eng_crowd, "hardpoint_01", 0.01)
	Modify_WeaponRange(sg_fre_crowd, "hardpoint_01", 0.01)
	
	SGroup_SetTargetingType(sg_eng_crowd, Targeting_None)
	SGroup_SetTargetingType(sg_fre_crowd, Targeting_None)
	
end

function Combat30_CheerFrench()
	SGroup_EnableCheering(sg_fre_crowd, true, 5)
end

function Combat30_CheerEnglish()
	SGroup_EnableCheering(sg_eng_crowd, true, 5)
end

function Combat30_CheerBoth()
	SGroup_EnableCheering(sg_fre_crowd, true, 10)
	SGroup_EnableCheering(sg_eng_crowd, true, 10)
end
	
function Combat30_StartTravellers()
	Combat30_SendTraveller()
	Rule_AddInterval(Combat30_SendTraveller, 25)
end
	
function Combat30_SendTraveller()
	local markerList = {
		mkr_mainpath1, mkr_mainpath2, mkr_mainpath3, mkr_mainpath4, mkr_mainpath5, mkr_mainpath6, mkr_mainpath7,
		mkr_mainpath8, mkr_mainpath9, mkr_mainpath11, mkr_mainpath12, mkr_mainpath13, mkr_mainpath14, mkr_mainpath15,
		mkr_mainpath16, mkr_mainpath17, mkr_mainpath18, mkr_mainpath19, mkr_mainpath20,	
	}
	local travellerUnits = {
		{ type = "scar_villager", numSquads = 3 },
		{ type = "scar_villager", numSquads = 2 },
		{ type = "scar_villager", numSquads = 1 },
		{ type = "scar_spearman", numSquads = 2 },
		{ type = "scar_trade_cart", numSquads = 1 },
	}
	
	if Objective_IsStarted(OBJ_BuildForce) then
		Rule_RemoveMe()
	else
		local sgroup = SGroup_CreateUnique("sg_traveller_")
		
		UnitEntry_DeploySquads(player7, sgroup, travellerUnits[World_GetRand(1, #travellerUnits)], mkr_mainpath1)
		Modify_UnitSpeed(sgroup, 0.6)
		
		for index, marker in pairs(markerList) do
			
			if scartype(marker) == ST_MARKER then
				if index < #markerList then
					Cmd_FormationMove(sgroup, marker, true)
				elseif index == #markerList then
					Cmd_FormationMoveToAndDestroy(sgroup, marker, true)
				end
			end
		end
	end
end

function Combat30_RetreatRecruitSGroup(sgroup)
	if SGroup_Count(sgroup) > 0 then
		Cmd_MoveToAndDestroy(sgroup, mkr_fredespawn)
	end
end

function Combat30_FailCheck()	
	if fail_check_paused ~= true then
	Player_GetAll(player1, sg_fre_army)
		SGroup_RemoveGroup(sg_fre_army, sg_recruit1)
		SGroup_RemoveGroup(sg_fre_army, sg_recruit2)
		SGroup_RemoveGroup(sg_fre_army, sg_recruit3)
		SGroup_RemoveGroup(sg_fre_army, sg_recruit4)
	if SGroup_Count(sg_fre_army) <= 0 then
		Mission_Fail()
	end
end
end

function Combat30_ToggleBeaumanoirSlow(slow)
	if slow and not beaumanoir_isslow then
		modifier_beaumanoir_slow = Modify_UnitSpeed(g_leaderBeaumanoir.sgroup, 0.615)
		beaumanoir_isslow = true
	elseif not slow and beaumanoir_isslow then
		Modifier_Remove(modifier_beaumanoir_slow)
		beaumanoir_isslow = false
	end
end

function Combat30_LastChampionVO()
	local VOList = {
		EVENTS.Recruit1_Complete,
		EVENTS.Recruit2_Complete,
		EVENTS.Recruit3_Complete,
		EVENTS.Recruit4_Complete,
	}
	
	Util_StartIntel(VOList[last_champion_collected])
	Util_StartIntel(EVENTS.Complete_Recruit)
end

function Combat30_BeaumanoirLowHealth()
	local injuredLines = {
		"Campaign_Speech/leaders/hun/fre_manatarms/french_manatarms_hun_chp1_combat30_iHigh_cLow_05",
		"Campaign_Speech/leaders/hun/fre_manatarms/french_manatarms_hun_chp1_combat30_iHigh_cLow_06",
		"Campaign_Speech/leaders/hun/fre_manatarms/french_manatarms_hun_chp1_combat30_iHigh_cLow_07",
	}
	local gameTime = World_GetGameTime()
		
	if g_leaderBeaumanoir.inDownedState and (gameTime - beaumanoirLastDownedVO > 45)then
		SGroup_PlaySpeech(g_leaderBeaumanoir.sgroup, injuredLines[World_GetRand(1,3)])
		beaumanoirLastDownedVO = World_GetGameTime()
	end
	
end
function Refresh_Crowns()
	Player_GetAll(player1)
	SGroup_Filter(sg_allsquads, "leader", FILTER_KEEP)
	local crownTable = {}
	
	local _EachLeader = function(gid, index, sid)
		local sg_singlecrown = SGroup_CreateUnique()
		SGroup_Single(sg_singlecrown, sid)
		SGroup_EnableLeaderCrown(sg_singlecrown, false)
		SGroup_EnableLeaderCrown(sg_singlecrown, true)
		table.insert(crownTable, sg_singlecrown)
	end
	SGroup_ForEach(sg_allsquads, _EachLeader)
	Rule_AddOneShot(Cleanup_CrownGroups, 1, {crowncleanTable = crownTable})
end

function Cleanup_CrownGroups(context, data)
	local crowncleanTable = data.crowncleanTable
	for i = 1, #crowncleanTable do
		SGroup_Destroy(crowncleanTable[i])
	end
end