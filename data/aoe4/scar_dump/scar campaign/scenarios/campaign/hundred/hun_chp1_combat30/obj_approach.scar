		end
	}
	SOBJ_Recruit4 = {
		Title = "$11197906", --"Defeat the English longbowmen"
		Type = ObjectiveType_Battle,
		Parent = OBJ_RecruitChampions,
		Intel_Start = EVENTS.Recruit4_OnStart,
		PreStart = function()
			Recruit4_PreStart(SOBJ_Recruit4, OBJ_RecruitChampions, false)
		end,
		OnStart = function()
