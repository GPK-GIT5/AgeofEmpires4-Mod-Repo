end


function Recruit1_Trigger()
	if Player_AreSquadsNearMarker(player1, mkr_recruit1_trigger) then
		Rule_RemoveMe()
		print("NearRecruit1")
		if not Objective_IsComplete(OBJ_RecruitChampions) then
			Objective_Start(SOBJ_Recruit1, true)
		elseif not Objective_IsComplete(OBJ_RecruitChampions_Optional) then
			Objective_Start(SOBJ_Recruit1_Optional, true)
		end
	end
end

function Recruit1_PreStart(objective, parent_objective, is_optional)
	print("Recruit1_PreStart  optional:"..tostring(is_optional))
	Music_PlayStinger("sfx_campaign_scripted_small_group_fear")
	hintname_recruit1 = HintPoint_Add(sg_recruit1, true, 11195760, 1) -- Sir Olivier Arrel
	Objective_RemoveUIElements(parent_objective, hintpoint_recruit1)
	Combat30_ToggleBeaumanoirSlow(false)
	
	if UI_IsXboxControllerUI() then
		MissionTutorial_BeaumanoirAura_Xbox()
	else
		MissionTutorial_BeaumanoirAura()
	end
	
	Combat30_RecruitSGroup(sg_recruit1)
	Combat30_RecruitSGroup(sg_recruit1_escort)
	FOW_PlayerRevealSGroup(player1, sg_recruit1, REVEAL_RADIUS, -1)
	FOW_PlayerRevealSGroup(player1, sg_recruit1_escort, REVEAL_RADIUS, -1)
	--Rule_AddOneShot(Recruit1_MidBanner, 1.5)
	Recruit1_SpawnWolves()
end

function Recruit1_MidBanner()
	Recruit1_SpawnWolves()
end

function Recruit1_OnStart(objective, parent_objective, is_optional)
	print("Recruit1_OnStart  optional:"..tostring(is_optional))
	Music_PlayStinger("sfx_campaign_scripted_small_group_fear")
	Music_UnlockIntensity()
	Music_LockIntensity(MUSIC_TENSE_RARE)
	Rule_AddInterval(Combat30_Recruit_BoundaryCheck, 1, { 
		objective = objective, 
		marker = mkr_recruit1_boundary, 
		sgroups = { sg_recruit1, sg_recruit1_escort },
	})
end

function Recruit1_PreComplete(objective, parent_objective, is_optional)
	print("Recruit1_PreComplete  optional:"..tostring(is_optional))
	Combat30_ToggleBeaumanoirSlow(true)
	
	if UI_IsXboxControllerUI() then
		MissionTutorial_ArrelAura_Xbox()
	else
		MissionTutorial_ArrelAura()
	end
	
	Music_UnlockIntensity()
	Sound_SetMinimumMusicCombatIntensity(801, 0)
	last_champion_collected = 1
	Combat30_IncrementChampionCounter()
	hintpoint_recruit2 = Objective_AddUIElements(parent_objective, mkr_recruit2, true, 11197133, false, 5 ) --French Champion
	hintpoint_recruit3 = Objective_AddUIElements(parent_objective, mkr_recruit3, true, 11197133, false, 5 ) --French Champion
	hintpoint_recruit4 = Objective_AddUIElements(parent_objective, mkr_recruit4, true, 11197133, false, 5 ) --French Champion
	HintPoint_Remove(hintname_recruit1)
	Combat30_RecruitSGroup(sg_recruit1)
	Combat30_RecruitSGroup(sg_recruit1_escort)
	FOW_PlayerUnRevealSGroup(player1, sg_recruit1)
	FOW_PlayerUnRevealSGroup(player1, sg_recruit1_escort)
	
	Combat30_AddOptionToRecruitPanel(1)
	-- On Xbox, indicate the location of the champions panel
	if UI_IsXboxUI() then
		CampaignTraining_AddDiplomacyPanelHint("$11250021", "see_champions_sequence")
	end
	
	Combat30_StartTravellers()
	recruit1_vo_handled_by_parent = false
	if recruitedChampions == 2 then
		recruit1_vo_handled_by_parent = true
		Objective_Complete(parent_objective, true, false)
	end	
end

function Recruit1_OnComplete(objective, parent_objective, is_optional)
	print("Recruit1_OnComplete  optional:"..tostring(is_optional))
	
	if recruit1_vo_handled_by_parent == false then
		Util_StartIntel(EVENTS.Recruit1_Complete)
	end
end

function Recruit1_PreFail(objective, parent_objective, is_optional)
	print("Recruit1_PreFail  optional:"..tostring(is_optional))
	Mission_Fail()
	Music_UnlockIntensity()
end

function Recruit1_OnFail(objective, parent_objective, is_optional)
	print("Recruit1_OnFail  optional:"..tostring(is_optional))
end



function Recruit2_Trigger()
	if Player_AreSquadsNearMarker(player1, mkr_recruit2_trigger) then
		Rule_RemoveMe()
		print("NearRecruit2")
		if not Objective_IsComplete(OBJ_RecruitChampions) then
			Objective_Start(SOBJ_Recruit2, true)
		elseif not Objective_IsComplete(OBJ_RecruitChampions_Optional) then
			Objective_Start(SOBJ_Recruit2_Optional, true)
		end
	end
end

function Recruit2_PreStart(objective, parent_objective, is_optional)
	print("Recruit2_PreStart  optional:"..tostring(is_optional))
	Util_StartIntel(EVENTS.Recruit2_Start)
	Objective_RemoveUIElements(parent_objective, hintpoint_recruit2)
	hintname_recruit2 = HintPoint_Add(sg_recruit2, true, "$11195764", 1) --Sir Guy de Rochefort
	FOW_PlayerRevealSGroup(player1, sg_recruit2, REVEAL_RADIUS, -1)
	FOW_PlayerRevealSGroup(player1, sg_recruit2_escort, REVEAL_RADIUS, -1)
	Rule_AddOneShot(Recruit2_MidBanner1, 3) 
	Rule_AddOneShot(Recruit2_MidBanner2, 5) --6 was too late
end

function Recruit2_MidBanner1()
	print("Recruit2_MidBanner1")
	Recruit2_SpawnEnglishRaid1()
end

function Recruit2_MidBanner2()
	print("Recruit2_MidBanner2")
	FOW_PlayerUnRevealSGroup(player1, sg_recruit2)
	FOW_PlayerUnRevealSGroup(player1, sg_recruit2_escort)
	Combat30_RecruitSGroup(sg_recruit2)
	Combat30_RecruitSGroup(sg_recruit2_escort)
	Combat30_ToggleBeaumanoirSlow(false)
end

function Recruit2_OnStart(objective, parent_objective, is_optional)
	print("Recruit2_OnStart  optional:"..tostring(is_optional))
	Music_LockIntensity(MUSIC_TENSE_RARE, 20)
	Rule_AddInterval(Combat30_Recruit_BoundaryCheck, 1, { 
		objective = objective, 
		marker = mkr_recruit2_boundary,
		sgroups = { sg_recruit2, sg_recruit2_escort },
	})
end

function Recruit2_PreComplete(objective, parent_objective, is_optional)
	print("Recruit2_PreComplete  optional:"..tostring(is_optional))
	Combat30_ToggleBeaumanoirSlow(true)
	last_champion_collected = 2
	Combat30_IncrementChampionCounter()
	HintPoint_Remove(hintname_recruit2)
	Combat30_AddOptionToRecruitPanel(2)
	recruit2_vo_handled_by_parent = false
	if recruitedChampions == 2 then
		recruit2_vo_handled_by_parent = true
		Objective_Complete(OBJ_RecruitChampions, true, false)
	end		
end

function Recruit2_OnComplete(objective, parent_objective, is_optional)	
	print("Recruit2_OnComplete  optional:"..tostring(is_optional))
	if recruit2_vo_handled_by_parent == false then
		Util_StartIntel(EVENTS.Recruit2_Complete)
	end
end

function Recruit2_PreFail(objective, parent_objective, is_optional)
	print("Recruit2_PreFail  optional:"..tostring(is_optional))
	recruitFailedCount = recruitFailedCount + 1
	Combat30_ToggleBeaumanoirSlow(true)
	Objective_UpdateText(objective, "$11197136", nil, false) --"Recruit Guy de Rochfort"
	Combat30_RetreatSGroup(sg_recruit2)
	Combat30_RetreatSGroup(sg_recruit2_escort)
	HintPoint_Remove(hintname_recruit2)
end

function Recruit2_OnFail(objective, parent_objective, is_optional)	
	print("Recruit2_OnFail  optional:"..tostring(is_optional))
end



function Recruit3_Trigger()
	if Player_AreSquadsNearMarker(player1, mkr_recruit3) then
		Rule_RemoveMe()
		Rule_AddInterval(Recruit3_Trigger_Inner, 1)
		print("NearRecruit3")
		Recruit3_SpawnDuel()
		Music_LockIntensity(MUSIC_TENSE_RARE, 20)
		Rule_AddInterval(Recruit3_CatchTravellers, 1)	
		Rule_Remove(Combat30_SendTraveller)
	end
end

function Recruit3_Trigger_Inner()
	if Util_GetDistance(SGroup_GetPosition(g_leaderBeaumanoir.sgroup), Marker_GetPosition(mkr_recruit3_duelstart)) < Marker_GetProximityRadius(mkr_recruit3_duelstart) then
		Rule_RemoveMe()
		print("NearRecruit3_Inner")
		if not Objective_IsComplete(OBJ_RecruitChampions) then
			Objective_Start(SOBJ_Recruit3, true)
		elseif not Objective_IsComplete(OBJ_RecruitChampions_Optional) then
			Objective_Start(SOBJ_Recruit3_Optional, true)
		end
	end
end

function Recruit3_PreStart(objective, parent_objective, is_optional)
	print("Recruit3_PreStart  optional:"..tostring(is_optional))
	--Take positions
	Util_StartIntel(EVENTS.Recruit3_Start)
	Objective_RemoveUIElements(parent_objective, hintpoint_recruit3)
	hint_Recruit3 = HintPoint_Add(sg_recruit3, true, "$11195763", 1)
	Player_GetAll(player1, sg_fre_hold)
	SGroup_Filter(sg_fre_hold, SBP.FRENCH.UNIT_JEAN_DE_BEAUMANOIR_CMP_FRE, FILTER_REMOVE)
	Combat30_UnrecruitSGroup(sg_fre_hold)
	MoveToAndRespectFacing(sg_fre_hold, mkr_duelarmy)
	Combat30_UnrecruitSGroup(g_leaderBeaumanoir.sgroup)
	MoveToAndRespectFacing(g_leaderBeaumanoir.sgroup, mkr_start_player)
	MoveToAndRespectFacing(sg_recruit3, mkr_start_enemy)
	fail_check_paused = true
	SGroup_SetAvgHealth(g_leaderBeaumanoir.sgroup, 1)
	FOW_PlayerRevealSGroup(player1, g_leaderBeaumanoir.sgroup, 20, -1)
end

function Recruit3_OnStart(objective, parent_objective, is_optional)
	print("Recruit3_OnStart  optional:"..tostring(is_optional))
	
	--StartDuel
	Music_LockIntensity(MUSIC_TENSE_RARE, 20)
	SGroup_SetPlayerOwner(sg_recruit3, player4)
	Combat30_RecruitSGroup(g_leaderBeaumanoir.sgroup)
	fail_check_paused = false
	FOW_PlayerUnRevealSGroup(player1, g_leaderBeaumanoir.sgroup)
	
	print("Start Duel")
	Cmd_Attack(sg_recruit3, g_leaderBeaumanoir.sgroup)
	Cmd_Attack(g_leaderBeaumanoir.sgroup, sg_recruit3)
	Modify_ReceivedDamage(sg_recruit3, damageScale)
	
	Rule_AddInterval(Recruit3_CheckDuelComplete, 1)
	Rule_AddInterval(Combat30_Recruit3_BoundaryCheck, 1)
end

function Recruit3_PreComplete(objective, parent_objective, is_optional)
	print("Recruit3_PreComplete  optional:"..tostring(is_optional))
	
	last_champion_collected = 3
	Combat30_IncrementChampionCounter()
	Combat30_RecruitSGroup(sg_recruit3)
	Combat30_RecruitSGroup(sg_fre_hold)
	Combat30_AddOptionToRecruitPanel(3)
	HintPoint_Remove(hint_Recruit3)
	
	if UI_IsXboxControllerUI() then
		MissionTutorial_CharruelAura_Xbox()
	else
		MissionTutorial_CharruelAura()
	end
	
	if is_optional == true then
		Rule_AddOneShot(Refresh_Crowns, 1)
	end
	recruit3_vo_handled_by_parent = false
	if recruitedChampions == 2 then
		recruit3_vo_handled_by_parent = true
		Objective_Complete(OBJ_RecruitChampions, true, false)
	end
end

function Recruit3_OnComplete(objective, parent_objective, is_optional)
	print("Recruit3_OnComplete  optional:"..tostring(is_optional))
	if recruit3_vo_handled_by_parent == false then
		Util_StartIntel(EVENTS.Recruit3_Complete)
	end
end

function Recruit3_PreFail(objective, parent_objective, is_optional)
	print("Recruit3_PreFail  optional:"..tostring(is_optional))
	Combat30_RecruitSGroup(sg_fre_hold)
	recruitFailedCount = recruitFailedCount + 1
	Combat30_RetreatSGroup(sg_recruit3)
	HintPoint_Remove(hint_Recruit3)
	Objective_UpdateText(objective, "$11197138", nil, false) --"Recruit Yves Charruel"
	if is_optional == true then
		Rule_AddOneShot(Refresh_Crowns, 1)
	end
end

function Recruit3_OnFail(objective, parent_objective, is_optional)
	print("Recruit3_OnFail  optional:"..tostring(is_optional))
end


function Recruit4_Trigger()
	if Player_AreSquadsNearMarker(player1, mkr_recruit4_trigger) then
		Rule_RemoveMe()
		print("NearRecruit4")
		if not champion_4_completing then
			if not Objective_IsComplete(OBJ_RecruitChampions) then
				Objective_Start(SOBJ_Recruit4, true)
			elseif not Objective_IsComplete(OBJ_RecruitChampions_Optional) then
				Objective_Start(SOBJ_Recruit4_Optional, true)
			end
		end
	end
end

function Recruit4_PreStart(objective, parent_objective, is_optional)
	print("Recruit4_PreStart  optional:"..tostring(is_optional))
	Recruit4_SpawnEnglishArchers()
	Util_StartIntel(EVENTS.Recruit4_Start)
	Objective_RemoveUIElements(parent_objective, hintpoint_recruit4)
	hintname_recruit4 = HintPoint_Add(sg_recruit4, true, "$11195762", 1) --Geoffroy de Blois
	Cmd_Attack(sg_recruit4_spearmen, mkr_englisharchers)
	FOW_PlayerRevealSGroup(player1, sg_recruit4, REVEAL_RADIUS, -1)
	FOW_PlayerRevealSGroup(player1, sg_recruit4_escort, REVEAL_RADIUS, -1)
	FOW_PlayerRevealArea(player1, Marker_GetPosition(mkr_recruit4_reveal), Marker_GetProximityRadius(mkr_recruit4_reveal), -1)
	Rule_AddOneShot(Recruit4_MidBanner, 8)
	Cmd_HoldPosition(sg_recruit4)
	Cmd_HoldPosition(sg_recruit4_escort)
	hintname_outpost = HintPoint_Add(eg_towerdefend, true, "$11199264", 5)
end

function Recruit4_MidBanner()
	print("Recruit4_MidBanner")
	FOW_PlayerUnRevealSGroup(player1, sg_recruit4)
	FOW_PlayerUnRevealSGroup(player1, sg_recruit4_escort)
	Combat30_RecruitSGroup(sg_recruit4)
	Combat30_RecruitSGroup(sg_recruit4_escort)
