		end,
		OnFail = function()
			Recruit4_OnFail(SOBJ_Recruit4, OBJ_RecruitChampions, false)
		end
	}
	OBJ_Arrive = {
		Title = "$11197139", --"Arrive at the Halfway Oak"
		Type = ObjectiveType_Primary,
		OnStart = function()
			Music_LockIntensity(MUSIC_EXPLORE, 10)
			Music_UnlockIntensity()
			Sound_SetMinimumMusicCombatIntensity(0, 0)
			hintpoint_arrive = Objective_AddUIElements(OBJ_RecruitChampions, mkr_frebase, true, "$11197140") --Halfway Oak
			PreRound_SpawnEnglish()
			Combat30_SpawnCrowd()
		end,
		IsComplete = function()
			return Util_GetDistance(SGroup_GetPosition(g_leaderBeaumanoir.sgroup), Marker_GetPosition(mkr_frebase)) < Marker_GetProximityRadius(mkr_frebase)
		end,
		OnComplete = function()
			Player_GetAll(player2)
			SGroup_DestroyAllSquads(sg_allsquads)
			
			Sound_Play2D("sfx_campaign_scripted_small_group_celebrate")
			Music_UnlockIntensity()
			Sound_SetMinimumMusicCombatIntensity(0, 0)
			Objective_RemoveUIElements(OBJ_RecruitChampions, hintpoint_arrive)
			Combat30_ToggleBeaumanoirSlow(false)
			
			Player_CompleteUpgrade(player2, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_3)
			Player_CompleteUpgrade(player2, UPG.HRE.UPGRADE_UNIT_MANATARMS_3_HRE)
			Player_CompleteUpgrade(player2, UPG.COMMON.UPGRADE_UNIT_HORSEMAN_3)
			
			Objective_Complete(OBJ_RecruitChampions_Optional, false, false)
			Combat30_SpawnChampionsAtBase()
			FOW_PlayerRevealArea(player1, Util_GetPosition(mkr_inbase), 60, 99999)
			FOW_PlayerRevealArea(player1, Util_GetPosition(mkr_combatring), 60, 99999)
			Objective_Complete(OBJ_RecruitChampions, false)
			
			Util_StartIntel(EVENTS.Enter_StagingArea)
			Objective_Start(OBJ_BuildForce)
		end,
	}
	OBJ_RecruitChampions_Optional = {
		
		Title = "$11198270", -- "Optional: Recruit additional champions to Combat the English",
		Type = ObjectiveType_Optional,
		OnStart = function()
			print("OBJ_RecruitChampions_Optional PreStart")
			Objective_RemoveUIElements(OBJ_RecruitChampions, hintpoint_recruit1)
			Objective_RemoveUIElements(OBJ_RecruitChampions, hintpoint_recruit2)
			Objective_RemoveUIElements(OBJ_RecruitChampions, hintpoint_recruit3)
			Objective_RemoveUIElements(OBJ_RecruitChampions, hintpoint_recruit4)
			
			if not Objective_IsComplete(SOBJ_Recruit1) then
				hintpoint_recruit1 = Objective_AddUIElements(OBJ_RecruitChampions_Optional, mkr_recruit1, true, "$11197133", false, 5 ) --French Champion
			end
			if not Objective_IsComplete(SOBJ_Recruit2) then
				hintpoint_recruit2 = Objective_AddUIElements(OBJ_RecruitChampions_Optional, mkr_recruit2, true, "$11197133", false, 5 ) --French Champion
			end				
			if not Objective_IsComplete(SOBJ_Recruit3) then
				hintpoint_recruit3 = Objective_AddUIElements(OBJ_RecruitChampions_Optional, mkr_recruit3, true, "$11197133", false, 5 ) --French Champion
			end					
			if not Objective_IsComplete(SOBJ_Recruit4) then
				hintpoint_recruit4 = Objective_AddUIElements(OBJ_RecruitChampions_Optional, mkr_recruit4, true, "$11197133", false, 5 ) --French Champion
			end
		end,
		IsComplete = function()
			return (recruitedChampions + recruitFailedCount) == 4
		end,
	}
	SOBJ_Recruit1_Optional = {
		Title = "$11197134", --Kill wolves attacking villagers
		Type = ObjectiveType_Battle,
		Parent = OBJ_RecruitChampions_Optional,
		PreStart = function()
			Recruit1_PreStart(SOBJ_Recruit1_Optional, OBJ_RecruitChampions_Optional, true)
		end,
		OnStart = function()
			Recruit1_OnStart(SOBJ_Recruit1_Optional, OBJ_RecruitChampions_Optional, true)
		end,
		PreComplete = function()
			Recruit1_PreComplete(SOBJ_Recruit1_Optional, OBJ_RecruitChampions_Optional, true)
		end,
		OnComplete = function()
			Recruit1_OnComplete(SOBJ_Recruit1_Optional, OBJ_RecruitChampions_Optional, true)
		end,
		PreFail = function()
			Recruit1_PreFail(SOBJ_Recruit1_Optional, OBJ_RecruitChampions_Optional, true)
		end,
		OnFail = function()
			Recruit1_OnFail(SOBJ_Recruit1_Optional, OBJ_RecruitChampions_Optional, true)
		end
	}
	SOBJ_Recruit2_Optional = {
		Title = "$11197135", --"Defeat the English raiders"
		Type = ObjectiveType_Battle,
		Parent = OBJ_RecruitChampions_Optional,
		PreStart = function()
			Recruit2_PreStart(SOBJ_Recruit2_Optional, OBJ_RecruitChampions_Optional, true)
		end,
		OnStart = function()
			Recruit2_OnStart(SOBJ_Recruit2_Optional, OBJ_RecruitChampions_Optional, true)
		end,
		PreComplete = function()
			Recruit2_PreComplete(SOBJ_Recruit2_Optional, OBJ_RecruitChampions_Optional, true)
		end,
		OnComplete = function()
			Recruit2_OnComplete(SOBJ_Recruit2_Optional, OBJ_RecruitChampions_Optional, true)
		end,
		PreFail = function()
			Recruit2_PreFail(SOBJ_Recruit2_Optional, OBJ_RecruitChampions_Optional, true)
		end,
		OnFail = function()
			Recruit2_OnFail(SOBJ_Recruit2_Optional, OBJ_RecruitChampions_Optional, true)
		end
	}
	SOBJ_Recruit3_Optional = {
		Title = "$11197189", -- Win a duel,
		Type = ObjectiveType_Battle,
		Parent = OBJ_RecruitChampions_Optional,
		PreStart = function()
			Recruit3_PreStart(SOBJ_Recruit3_Optional, OBJ_RecruitChampions_Optional, true)
		end,
		OnStart = function()
			Recruit3_OnStart(SOBJ_Recruit3_Optional, OBJ_RecruitChampions_Optional, true)
		end,
		PreComplete = function()
			Recruit3_PreComplete(SOBJ_Recruit3_Optional, OBJ_RecruitChampions_Optional, true)
		end,
		OnComplete = function()
			Recruit3_OnComplete(SOBJ_Recruit3_Optional, OBJ_RecruitChampions_Optional, true)
		end,
		PreFail = function()
			Recruit3_PreFail(SOBJ_Recruit3_Optional, OBJ_RecruitChampions_Optional, true)
		end,
		OnFail = function()
			Recruit3_OnFail(SOBJ_Recruit3_Optional, OBJ_RecruitChampions_Optional, true)
		end
	}
		SOBJ_Recruit4_Optional = {
		Title = "$11197906", --"Defeat the English longbowmen"
		Type = ObjectiveType_Battle,
		Parent = OBJ_RecruitChampions_Optional,
		Intel_Start = EVENTS.Recruit4_OnStart,
		Intel_Complete = EVENTS.Recruit4_OnComplete,
		PreStart = function()
			Recruit4_PreStart(SOBJ_Recruit4_Optional, OBJ_RecruitChampions_Optional, true)
		end,
		OnStart = function()
			Recruit4_OnStart(SOBJ_Recruit4_Optional, OBJ_RecruitChampions_Optional, true)
		end,
		PreComplete = function()
			Recruit4_PreComplete(SOBJ_Recruit4_Optional, OBJ_RecruitChampions_Optional, true)
