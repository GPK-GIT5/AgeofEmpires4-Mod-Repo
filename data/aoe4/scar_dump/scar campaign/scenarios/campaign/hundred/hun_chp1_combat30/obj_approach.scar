function Combat30_IncrementChampionCounter()
	recruitedChampions = recruitedChampions + 1
	if Objective_IsComplete(OBJ_RecruitChampions) == false then
	Objective_SetCounter(OBJ_RecruitChampions, recruitedChampions, 2)
end
end

function Combat30_SpawnChampions()
	UnitEntry_DeploySquads(player3, sg_recruit1, { sbp = SBP.FRENCH.UNIT_OLIVIER_ARREL_CMP_FRE, numSquads = 1},			mkr_recruit1)
	UnitEntry_DeploySquads(player3, sg_recruit1_escort, { type = "scar_spearman", numSquads = 2 }, 						mkr_recruit1_escort1)
	UnitEntry_DeploySquads(player3, sg_recruit1_escort, { type = "scar_spearman", numSquads = 2 }, 						mkr_recruit1_escort2)
	
	UnitEntry_DeploySquads(player3, sg_recruit2, { sbp = SBP.FRENCH.UNIT_GUY_DE_ROCHEFORT_CMP_FRE, numSquads = 1 }, 	mkr_recruit2)
	UnitEntry_DeploySquads(player3, sg_recruit2_escort, { type = "scar_spearman", numSquads = 3 }, 						mkr_recruit2_escort1)
	UnitEntry_DeploySquads(player3, sg_recruit2_escort, {{ type = "scar_manatarms", numSquads = 2 },{ type = "scar_spearman", numSquads = 1 }}, mkr_recruit2_escort2)
		
	UnitEntry_DeploySquads(player3, sg_recruit4, { sbp = SBP.FRENCH.UNIT_GEOFFROY_DU_BLOIS_CMP_FRE, numSquads = 1}, 	mkr_recruit4)
	UnitEntry_DeploySquads(player3, sg_recruit4_escort, { type = "scar_knight", numSquads = 2}, 						mkr_recruit4_escort1)
	UnitEntry_DeploySquads(player3, sg_recruit4_escort, { type = "scar_horseman", numSquads = 3}, 						mkr_recruit4_escort2)
	UnitEntry_DeploySquads(player3, sg_recruit4_spearmen, { type = "scar_spearman", numSquads = 1}, 					mkr_recruit4_spearman1)
	UnitEntry_DeploySquads(player3, sg_recruit4_spearmen, { type = "scar_spearman", numSquads = 1}, 					mkr_recruit4_spearman2)
	UnitEntry_DeploySquads(player3, sg_recruit4_spearmen, { type = "scar_spearman", numSquads = 1}, 					mkr_recruit4_spearman3)
end


--
-- Recurit 1 - Recruit Olivier Arrel (kill the wolves)
--
function Recruit1_SpawnWolves()
	sg_wolves = SGroup_CreateIfNotFound("sg_wolves")
	sg_fleeingvillager = SGroup_CreateIfNotFound("sg_fleeingvillager")
	
	local markerList = { mkr_wolf1, mkr_wolf2, mkr_wolf3, mkr_wolf4, mkr_wolf5 }
	local units = {sbp = SBP.GAIA.GAIA_HUNTABLE_WOLF}
		
	for k,v in pairs(markerList) do
		UnitEntry_DeploySquads(player1, sg_wolves, units, v)
	end
		
	-- set it to neutral
	Modify_ReceivedDamage(sg_wolves, 0.66)
	SGroup_SetWorldOwned(sg_wolves)
	
	-- Spawn Villager to lure wolves
	UnitEntry_DeploySquads(player3, sg_fleeingvillager, { type = "scar_villager", numSquads = 2 }, mkr_fleeingvillagers)
	Cmd_FormationMove(sg_fleeingvillager, mkr_recruit1, true)
	Cmd_FormationMove(sg_fleeingvillager, mkr_recruit1_despawn, true, true)
	
	Rule_AddInterval(Recruit1_CheckWolvesDead, 1)
end

function Recruit1_CheckWolvesDead()
	if Objective_IsComplete(OBJ_RecruitChampions_Optional) then 
		Rule_RemoveMe()
	elseif SGroup_IsEmpty(sg_wolves) and not Objective_IsFailed(SOBJ_Recruit1) and not Objective_IsFailed(SOBJ_Recruit1_Optional) then
		Objective_UpdateText(SOBJ_Recruit1, 11197132, nil, false) -- "Recruit Olivier Arrel"
		local play_banner = (recruitedChampions ~= 1)
		if not Objective_IsComplete(OBJ_RecruitChampions) then
			Objective_Complete(SOBJ_Recruit1, play_banner)
		else
			Objective_Complete(SOBJ_Recruit1_Optional, true)
		end
		Rule_RemoveMe()
	end
end

--
-- Recurit 2 - Recruit Guy de Rochfort (defeat english raiders)
--
