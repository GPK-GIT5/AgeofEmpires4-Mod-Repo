function Mission_SetupPlayers()
	
	player1 = World_GetPlayerAt(1)
	player2 = World_GetPlayerAt(2)
	player3 = World_GetPlayerAt(3)
	player4 = World_GetPlayerAt(4)
	player5 = World_GetPlayerAt(5)
	player6 = World_GetPlayerAt(6)
	player7 = World_GetPlayerAt(7)
	player8 = World_GetPlayerAt(8)
	
		
	--player 1 - French
	Setup_SetPlayerName(player1, Loc_GetString("$11180019"))
	Player_SetCurrentAge(player1, AGE_CASTLE)
	Player_SetMaximumAge(player1, AGE_CASTLE)
	
	--player 2 - English
	Setup_SetPlayerName(player2, Loc_GetString("$11180020"))
	Player_SetCurrentAge(player2, AGE_CASTLE)
	Player_SetMaximumAge(player2, AGE_CASTLE)
	
	--player 3 - Local French
	Setup_SetPlayerName(player3, Loc_GetString("$11201649"))
	Player_SetCurrentAge(player3, AGE_CASTLE)
	Player_SetMaximumAge(player3, AGE_CASTLE)
	
	--player 4 - Aggressive Local (Yves)
	Setup_SetPlayerName(player4, Loc_GetString("$11201649"))
	Player_SetCurrentAge(player4, AGE_CASTLE)
	Player_SetMaximumAge(player4, AGE_CASTLE)
	
	--player 5 - Passive English
	Setup_SetPlayerName(player5, Loc_GetString("$11180020"))
	Player_SetCurrentAge(player5, AGE_CASTLE)
	Player_SetMaximumAge(player5, AGE_CASTLE)
	
	--player 7 - Local French
	Setup_SetPlayerName(player7, Loc_GetString("$11201649"))
	Player_SetCurrentAge(player7, AGE_CASTLE)
	Player_SetMaximumAge(player7, AGE_CASTLE)
	World_EnableSharedLineOfSight(player7, player1, false)

	
	
	
	--player relationships
	Player_SetRelationship(player1, player3, R_ALLY)
	Player_SetRelationship(player3, player1, R_ALLY)
	Player_SetRelationship(player3, player5, R_ALLY)
	Player_SetRelationship(player5, player3, R_ALLY)
	Player_SetRelationship(player1, player5, R_ALLY)
	Player_SetRelationship(player5, player1, R_ALLY)
	Player_SetRelationship(player7, player1, R_ALLY)
	Player_SetRelationship(player1, player7, R_ALLY)
	Player_SetRelationship(player2, player5, R_ALLY)
	Player_SetRelationship(player5, player2, R_ALLY)
	
	Player_SetRelationship(player3, player7, R_ALLY)
	Player_SetRelationship(player7, player3, R_ALLY)
	Player_SetRelationship(player2, player7, R_ALLY)
	Player_SetRelationship(player7, player2, R_ALLY)
	Player_SetRelationship(player4, player7, R_ALLY)
	Player_SetRelationship(player7, player4, R_ALLY)
	
	
	Player_SetRelationship(player1, player4, R_ENEMY)
	Player_SetRelationship(player4, player1, R_ENEMY)
	Player_SetRelationship(player3, player4, R_ALLY)
	Player_SetRelationship(player4, player3, R_ALLY)
	
	Player_SetRelationship(player6, player2, R_ALLY)
	Player_SetRelationship(player2, player6, R_ALLY)
	Player_SetRelationship(player6, player3, R_ALLY)
	Player_SetRelationship(player3, player6, R_ALLY)
	Player_SetRelationship(player6, player1, R_ALLY)
	Player_SetRelationship(player1, player6, R_ALLY)
	
	-- ui / paint scheme colours
	Game_SetPlayerSlotColour(player1, 1)			-- player 1 - French (blue index 1)
	Game_SetPlayerUISlotColour(player1, 1)
	Game_SetPlayerSlotColour(player2, 2)			-- player 2 - English (red index 2)
	Game_SetPlayerUISlotColour(player2, 2)
	Game_SetPlayerSlotColour(player3, 3)			-- player 3 - Local French (yellow index 3)
	Game_SetPlayerUISlotColour(player3, 3)
	Game_SetPlayerSlotColour(player4, 2)			-- player 4 - Aggressive French / Yves (red index 2)
	Game_SetPlayerUISlotColour(player4, 2)
	Game_SetPlayerSlotColour(player5, 7)			-- player 5 - Passive English (orange index 7, yellow index 3)
	Game_SetPlayerUISlotColour(player5, 3)
	Game_SetPlayerSlotColour(player6, 1)			-- player 6 - Downed Leader holder (blue index 1)
	Game_SetPlayerUISlotColour(player6, 1)
	Game_SetPlayerSlotColour(player7, 3)			-- player 7 - Local french (yellow index 3)
	Game_SetPlayerUISlotColour(player7, 3)
	Game_SetPlayerSlotColour(player8, 1)			-- player 8 - French Supporters (blue index 1)
	Game_SetPlayerUISlotColour(player8, 1)
	
	
	AI_Enable(player6, false)
	
	World_EnableSharedLineOfSight(player1, player5, false)	
	World_EnableSharedLineOfSight(player1, player3, false)
		
	PlayerUpgrades_Auto(player1)
	PlayerUpgrades_Auto(player2)
	PlayerUpgrades_Auto(player4)
	PlayerUpgrades_Auto(player5)
end

function Mission_SetRestrictions()
	
	Player_SetPopCapOverride(player1, 30)
	Player_SetPopCapOverride(player2, 30)
	Modify_PlayerProductionRate(player2, 1.5)
	Action_SetResources_Do({player = player1, resources = {food = 1000, wood = 0, gold = Util_DifVar({750, 750, 450, 150}), stone = 0}})
	
	Wave_OverrideUnitBuildTime("scar_spearman", 1)
	Wave_OverrideUnitBuildTime("scar_manatarms", 1)
	Wave_OverrideUnitBuildTime("scar_archer", 1)
	Wave_OverrideUnitBuildTime("scar_crossbowman", 1)
	Wave_OverrideUnitBuildTime("scar_horseman", 1)
	Wave_OverrideUnitBuildTime("scar_knight", 1)
	
	
	Player_GetAll(player1)
	EGroup_AddEGroup(eg_fre_invulnerable_buildings, eg_allentities)
	EGroup_Filter(eg_fre_invulnerable_buildings, {"wall", "gate"}, FILTER_KEEP)
	Misc_SetEGroupSelectable(eg_fre_invulnerable_buildings, false)
	EGroup_SetInvulnerable(eg_fre_invulnerable_buildings, true)
	Misc_SetEGroupSelectable(eg_fre_tents, false)
	EGroup_SetInvulnerable(eg_fre_tents, true)
	EGroup_SetTargetingType(eg_fre_tents, Targeting_None)
	
	Player_GetAll(player2)
	EGroup_AddEGroup(eg_eng_invulnerable_buildings, eg_allentities)
	EGroup_Filter(eg_eng_invulnerable_buildings, {"wall", "gate"}, FILTER_KEEP)
	Misc_SetEGroupSelectable(eg_eng_invulnerable_buildings, false)
	Misc_SetEGroupSelectable(eg_eng_tents, false)
	EGroup_SetInvulnerable(eg_eng_invulnerable_buildings, true)
	EGroup_SetInvulnerable(eg_eng_tents, true)
	EGroup_SetTargetingType(eg_eng_tents, Targeting_None)
end


function Mission_PreInit()
	Combat30_HideTributeMenu()
end

function Mission_Preset()
	
	-- Enable player colours
	PlayerColour_Enable()
	
	--Player Upgrades
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_3)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_UNIT_ARCHER_3)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_UNIT_HORSEMAN_3)
	Player_CompleteUpgrade(player1, UPG.FRENCH.UPGRADE_UNIT_KNIGHT_3_FRE)
	Player_RemoveUpgrade(player1, UPG.COMMON.UPGRADE_MELEE_DAMAGE_I)
	Player_RemoveUpgrade(player1, UPG.COMMON.UPGRADE_MELEE_ARMOR_I)
	Player_RemoveUpgrade(player1, UPG.COMMON.UPGRADE_MELEE_DAMAGE_II)
	Player_RemoveUpgrade(player1, UPG.COMMON.UPGRADE_MELEE_ARMOR_II)
	Player_RemoveUpgrade(player1, UPG.COMMON.UPGRADE_MELEE_DAMAGE_III)
	Player_RemoveUpgrade(player1, UPG.COMMON.UPGRADE_MELEE_ARMOR_III)
	Player_SetUpgradeAvailability(player1, UPG.FRENCH.UPGRADE_CAVALRY_GRAPERED_LANCE_FRE, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_TECH_MILITARY_ACADEMY, ITEM_REMOVED)
	
	Cmd_FormationMove(sg_eng_army, mkr_engbase)
	
	--EnemyUpgrades
	Player_CompleteUpgrade(player2, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_3)
	Player_CompleteUpgrade(player2, UPG.COMMON.UPGRADE_UNIT_ARCHER_3)
	Player_CompleteUpgrade(player2, UPG.COMMON.UPGRADE_UNIT_HORSEMAN_3)
	Player_CompleteUpgrade(player2, UPG.ENGLISH.UPGRADE_UNIT_MANATARMS_3_ENG)
	Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_3)
	Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_ARCHER_3)
	Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_HORSEMAN_3)
	Player_CompleteUpgrade(player5, UPG.ENGLISH.UPGRADE_UNIT_MANATARMS_3_ENG)
	
	if Game_GetSPDifficulty() == GD_EXPERT then
		Player_CompleteUpgrade(player2, UPG.COMMON.UPGRADE_MELEE_ARMOR_III)
		Player_CompleteUpgrade(player2, UPG.COMMON.UPGRADE_MELEE_DAMAGE_III)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_MELEE_ARMOR_III)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_MELEE_DAMAGE_III)
	end
	
	--Intro Action
	Combat30_SpawnChampions()
	Combat30_InitIntroUnits_Proto()
end

function Mission_Start()
	-- on console don't restore VPS as we have no villagers
	Cardinal_EnablePartialXboxUI(true, {VF_XboxUIVillagerPriorities})

	recruit_module_groups[4] = { MissionOMatic_FindModule("EnglishArchers1"), 
		MissionOMatic_FindModule("EnglishArchers2"), MissionOMatic_FindModule("EnglishArchers3"), 
		MissionOMatic_FindModule("EnglishArchers4"), MissionOMatic_FindModule("EnglishArchers5"), 
		MissionOMatic_FindModule("EnglishArchers6"), MissionOMatic_FindModule("EnglishArchers7") 
	}
	Objective_Start(OBJ_RecruitChampions)
end
		
