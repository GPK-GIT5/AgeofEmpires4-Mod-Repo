function Combat30_SendIntroUnits(context, data)
	
	-- Add the others as waypoints
	for index, marker in pairs(data.markerList) do
		
		if scartype(marker) == ST_MARKER then
			if index <= #data.markerList then
				Cmd_FormationMove(data.sgroup, marker, true)
			end
		end
	end
	Cmd_HoldPosition(data.sgroup,SGroup_GetPosition(data.sgroup),true)
	
	if data.destination ~= nil then
		Cmd_FormationMove(data.sgroup, data.destination, true)
	end
end

function Combat30_CleanUpIntro()
	SGroup_DestroyAllSquads(sg_fre_intro)
	SGroup_DestroyAllSquads(sg_eng_intro)
	SGroup_DestroyAllSquads(sg_fre_intro_attache)
	SGroup_DestroyAllSquads(sg_eng_intro_attache)
	SGroup_DestroyAllSquads(sg_fre_intro_villager_cheer)
	SGroup_DestroyAllSquads(sg_eng_intro_villager_cheer)
end

