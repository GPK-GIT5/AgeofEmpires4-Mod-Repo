function Combat30_SkipIntro()
	Rule_Remove(Intro_Cheer01)
	
	SGroup_FormationWarpToMarker(g_leaderBeaumanoir.sgroup, mkr_josselin)
	SGroup_FormationWarpToMarker(sg_intro_horsemen, mkr_intro_horsemen_dest)
	SGroup_FormationWarpToMarker(sg_intro_escort, mkr_josselin_escort)
	
	SGroup_FormationWarpToMarker(sg_intro_cheer_02a, mkr_intro_cheer02a)
	SGroup_FormationWarpToMarker(sg_intro_cheer_03a, mkr_intro_cheer03a)
	SGroup_FormationWarpToMarker(sg_intro_cheer05, mkr_intro_cheer05)
	SGroup_FormationWarpToMarker(sg_intro_cheer_01a, mkr_intro_cheer01a)
	SGroup_FormationWarpToMarker(sg_intro_cheer01, mkr_intro_cheer01)
	SGroup_FormationWarpToMarker(sg_intro_cheer02, mkr_intro_cheer02)
	
	Modifier_Remove(intro_hero_speed)
	Modifier_Remove(intro_escort_speed)
	Modifier_Remove(intro_horsemen_speed)
	
end

function Combat30_VillagersToWork()
	
	SGroup_AddGroups(sg_intro_background, {sg_intro_cheer_02a, sg_intro_cheer_01a, sg_intro_cheer_03a, sg_intro_cheer01, sg_intro_cheer05, sg_intro_cheer02, sg_intro_cheer03})
	
	Modify_GoldGatherRate(sg_intro_background, 0.1)
	Modify_GoldCarryCapacity(sg_intro_background, 0.1)
	Modify_WoodGatherRate(sg_intro_background, 0.1)
	Modify_WoodCarryCapacity(sg_intro_background, 0.1)
	Modify_StoneGatherRate(sg_intro_background, 0.1)
	Modify_StoneCarryCapacity(sg_intro_background, 0.1)
	
	Rule_AddInterval(Combat30_AssignSomeVillagers, 0.1)
end

function Combat30_AssignSomeVillagers()
	
	if SGroup_Count(sg_intro_background) == 0 then
		Rule_RemoveMe()
	else		
		local sgroup = SGroup_CreateUnique("sg_villager_")
		local groupSize = World_GetRand(0, 3)
		
		if SGroup_Count(sg_intro_background) < groupSize then
			groupSize = SGroup_Count(sg_intro_background)
		end
		
		if groupSize > 0 then -- For a more scattered pacing, there's a chance of not sending any villagers on a beat
			
			for i=1, groupSize, 1 do
				SGroup_Add(sgroup, SGroup_GetSquadAt(sg_intro_background, i))
			end
			SGroup_RemoveGroup(sg_intro_background, sgroup)
			
			local job = World_GetRand(1, 7)
			
			if job == 1 or job == 2 then
				AssignVillagersToWood(sgroup)
			elseif job == 3 then
				AssignVillagersToGold(sgroup)
			elseif job == 4 then
				AssignVillagersToStone(sgroup)
			elseif job == 5 or job == 6  or job == 7 then
				Cmd_MoveToAndDestroy(sgroup, mkr_despawn)
			end		
		end
	end
end

function Combat30_UpdateFollowerTargets()
	for k, v in ipairs(followerArray) do
		
		local championSGroup = v[1]
		local championPosition = SGroup_GetPosition(v[1])
		local followerSGroup = v[2]
		if not SGroup_IsEmpty(championSGroup) and not SGroup_IsEmpty(followerSGroup) then 
			if Util_GetDistance(championSGroup, followerSGroup) > 5 then
				Cmd_FormationMove(followerSGroup, championSGroup, true)
			end
		end
	end
end

function Combat30_SpawnFollowers(sgroup, num, scar_type, marker)
	-- Get the champion and spawn followers of the correct type
	local sourceSGroup = sgroup
	followerGroupCount = followerGroupCount + 1
	
	local units = {
		{ type = scar_type, numSquads = num },
	}
	
	newSGroup = SGroup_CreateUniqueWithPrefix("Follower_")
	UnitEntry_DeploySquads(player3, newSGroup, units[1], marker)
	table.insert(followerArray, { sourceSGroup, newSGroup } )
end

-- Achievement tracking for Achievement #13 - Du Bois Are Back In Town - Win in the arena without losing more than 10 units during the Combat of the Thirty
function Combat30_AchievementTracker(context)
	
	if Squad_IsValid(Squad_GetID(context.victim)) then
		
		if not World_OwnsSquad(context.victim) then
			
			local owner = Squad_GetPlayerOwner(context.victim)
			
			-- Verify that victim belongs to player
			if owner == player1 then
				
				arenaUnitLost = arenaUnitLost + 1
				
				-- Stop achievement tracking if achievement task has failed
				if arenaUnitLost > 10 then
					Rule_RemoveMe()
				end		
			end
		end
	end
end

-- Achievement tracking for Achievement #13 - Du Bois Are Back In Town - Win in the arena without losing more than 10 units during the Combat of the Thirty
function Combat30_GrantAchievement()
	
	-- If player has not lost any units during arena rounds
	if arenaUnitLost <= 10 then
		
		-- Grant achievement completion
		Game_SendCustomChallengeEvent(player1, CE_ACHIEVNODEATHSINCOMBAT30ARENA, 1)
		
	end
end