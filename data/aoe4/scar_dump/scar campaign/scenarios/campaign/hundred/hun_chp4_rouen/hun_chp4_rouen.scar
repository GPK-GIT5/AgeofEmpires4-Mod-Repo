function Anti_Ram()
	
	Player_GetAll(player1)
	SGroup_Filter(sg_allsquads, "scar_ram", FILTER_KEEP)
	local ramCount = SGroup_CountSpawned(sg_allsquads)
	
	if ramCount >= 4 then
		
		local springCounter = math.floor(ramCount/2)
		
		local units = {{type = "scar_springald", numSquads = springCounter}, {type = "scar_spearman", numSquads = 5},}
		
		Wave_SetUnits(southWave_base, units)
		southWave_base.auto_launch = 120
		Wave_Prepare(southWave_base)
		
		Wave_SetUnits(centerWave_base, units)
		centerWave_base.auto_launch = 120
		Wave_Prepare(centerWave_base)
		
		Wave_SetUnits(northWave_base, units)
		northWave_base.auto_launch = 120
		Wave_Prepare(northWave_base)
		
	end
	
end

function CelebrateOnPosition(pos, range)
	Player_GetAllSquadsNearMarker(player1, sg_temp, Util_GetPosition(pos), range)
	if SGroup_CountSpawned(sg_temp) > 0 then
		Sound_PlayWallaCelebrateOnSGroup(sg_temp)
	end
end



function DestroyFieldWall_EntityKill(context) --Checks to see if any field walls were killed for SFX
	if context.victim ~= nil then
		local victimBP = Entity_GetBlueprint(context.victim)
		
		if victimBP == EBP.ENGLISH.BUILDING_DEFENSE_WALL_ENG or victimBP == EBP.ENGLISH.BUILDING_DEFENSE_WALL_GATE_ENG then			
			CelebrateOnPosition(context.victim, 60)
			Sound_Play2D(MUS_STING_POSITIVE)
			Rule_RemoveEGroupEvent(DestroyFieldWall_EntityKill, eg_fieldwalls)	
		end
	end
end -- 

function Achievement_ProduceUpgradedCannon(context) -- Achievement tracking for Achievement #15 - Battle Royal - Produce a Royal siege unit with all Bureau Brothers' Workshop special benefits
	
	if AssistBrothers_IsComplete() then
		
		local itemOwner = Squad_GetPlayerOwner(context.spawnedSquad)
		if itemOwner == player1 and Squad_IsOfType(context.spawnedSquad, "siege") == true then
	
			Game_SendCustomChallengeEvent(player1, CE_ACHIEVUPGRADECANNONSNORMANDY, 1)
			Rule_RemoveMe()
		end	
	end
end