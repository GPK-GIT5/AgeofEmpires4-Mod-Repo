	for i, marker in pairs(t_archeryDefenders) do
		local modName = ("defend_archer_"..i)
		local moduleData = 
		{			
			type = "RovingArmy",
			descriptor = modName,
			player = player2,
			targetingType = ARMY_TARGETING_DISCARD,
			targets = {marker},		
			spawnLocation = marker,
			onDeathDissolve = true,
			units = 
			{
				{type = "scar_archer", numSquads = 6*t_difficulty.defenderValue},
			},
		} 
		table.insert(recipe.modules, moduleData)
		table.insert(t_allRouenRecipeModNames, modName)
	end
	
	t_infatryDefenders = AllMarkers_FromName("mkr_infantry_defender", "")
	for i, marker in pairs(t_infatryDefenders) do
		local modName = ("infantry_defender_"..i)
		local moduleData = 
		{			
			type = "RovingArmy",
			descriptor = modName,
			player = player2,
			targetingType = ARMY_TARGETING_DISCARD,
			spawnLocation = marker,
			targets = {marker},
			onDeathDissolve = true,
			units = 
			{
				{type = "scar_spearman", numSquads = 10*t_difficulty.defenderValue},
				{type = "scar_manatarms", numSquads = 1},
			},
		} 
		table.insert(recipe.modules, moduleData)
		table.insert(t_allRouenRecipeModNames, modName)
	end
	
	t_eliteDefenders = AllMarkers_FromName("mkr_elite_defender", "")
	for i, marker in pairs(t_eliteDefenders) do
		local modName = ("elite_defender_"..i)
		local moduleData = 
		{			
			type = "RovingArmy",
			descriptor = modName,
			player = player2,
			targetingType = ARMY_TARGETING_DISCARD,
			spawnLocation = marker,
			targets = {marker},
			onDeathDissolve = true,
			units = 
			{
				{type = "scar_manatarms", numSquads = 10*t_difficulty.defenderValue},
				{type = "scar_crossbowman", numSquads = 12*t_difficulty.defenderValue},
			},
		} 
		table.insert(recipe.modules, moduleData)
		table.insert(t_allRouenRecipeModNames, modName)
	end
	
	t_cavalryDefenders = AllMarkers_FromName("mkr_cavalry_defender", "")
	for i, marker in pairs(t_cavalryDefenders) do
		local modName = ("cavalry_defender_"..i)
		local moduleData = 
		{			
			type = "RovingArmy",
			descriptor = modName,
			player = player2,
			targetingType = ARMY_TARGETING_DISCARD,
			spawnLocation = marker,
			targets = {marker},
			onDeathDissolve = true,
			units = 
			{
				{type = "scar_horseman", numSquads = 8*t_difficulty.defenderValue},
				{type = "scar_knight", numSquads = 1},
			},
		} 
		table.insert(recipe.modules, moduleData)
		table.insert(t_allRouenRecipeModNames, modName)
	end
	
	t_siegeDefenders = AllMarkers_FromName("mkr_siege_defender", "")
	for i, marker in pairs(t_siegeDefenders) do
		local modName = ("siege_defender_"..i)
		local moduleData = 
		{			
			type = "RovingArmy",
			descriptor = modName,
			player = player2,
			targetingType = ARMY_TARGETING_DISCARD,
			spawnLocation = marker,
			targets = {marker},
			onDeathDissolve = true,
			units = 
			{
				{type = "scar_manatarms", numSquads = 4*t_difficulty.defenderValue},
				{type = "scar_springald", numSquads = 2},
				{type = "scar_mangonel", numSquads = 1},
			},
		} 
		table.insert(recipe.modules, moduleData)
		table.insert(t_allRouenRecipeModNames, modName)
	end
	
	if Game_GetSPDifficulty() >= GD_HARD then
		t_siegeDefenders = AllMarkers_FromName("mkr_siege_defender_medium", "")
		for i, marker in pairs(t_siegeDefenders) do
			local modName = ("siege_defender_"..i)
			local moduleData = 
			{			
				type = "RovingArmy",
				descriptor = modName,
				player = player2,
				targetingType = ARMY_TARGETING_DISCARD,
				spawnLocation = marker,
				targets = {marker},
				onDeathDissolve = true,
				units = 
				{
					{type = "scar_manatarms", numSquads = 4*t_difficulty.defenderValue},
					{type = "scar_springald", numSquads = 2},
				},
			} 
			table.insert(recipe.modules, moduleData)
			table.insert(t_allRouenRecipeModNames, modName)
		end
	end
	
	if Game_GetSPDifficulty() >= GD_EXPERT then
		t_siegeDefenders = AllMarkers_FromName("mkr_siege_defender_hard", "")
		for i, marker in pairs(t_siegeDefenders) do
			local modName = ("siege_defender_"..i)
			local moduleData = 
			{			
				type = "RovingArmy",
				descriptor = modName,
				player = player2,
				targetingType = ARMY_TARGETING_DISCARD,
				spawnLocation = marker,
				targets = {marker},
				onDeathDissolve = true,
				units = 
				{
					{type = "scar_manatarms", numSquads = 4*t_difficulty.defenderValue},
					{type = "scar_springald", numSquads = 2},
				},
			} 
			table.insert(recipe.modules, moduleData)
			table.insert(t_allRouenRecipeModNames, modName)
		end
	end
	
	return recipe
end

