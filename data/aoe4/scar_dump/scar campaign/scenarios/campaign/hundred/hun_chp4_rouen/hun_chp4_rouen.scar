function Mission_SetupPlayers()
	
	player1 = World_GetPlayerAt(1) 
	player2 = World_GetPlayerAt(2)
	player3 = World_GetPlayerAt(3)
	player4 = World_GetPlayerAt(4)

	Setup_SetPlayerName(player1, Loc_GetString(11172305) )--(("France")))
	Player_SetCurrentAge(player1, AGE_CASTLE)
	Player_SetMaximumAge(player1, AGE_IMPERIAL)

	Setup_SetPlayerName(player2, Loc_GetString(11172306) )-- ("England")))
	Player_SetCurrentAge(player2, AGE_CASTLE)
	Player_SetMaximumAge(player2, AGE_CASTLE)
	
	Setup_SetPlayerName(player3, Loc_GetString(11196580) )--(("University")))
	Player_SetCurrentAge(player3, AGE_IMPERIAL)
	Player_SetMaximumAge(player3, AGE_IMPERIAL)
	
	Setup_SetPlayerName(player4, Loc_GetString(11161095) )--(("The Bureau Brothers")))
	Player_SetCurrentAge(player4, AGE_IMPERIAL)
	Player_SetMaximumAge(player4, AGE_IMPERIAL)
	
	Player_SetRelationship(player1, player2, R_ENEMY)
	Player_SetRelationship(player1, player3, R_NEUTRAL)
	Player_SetRelationship(player1, player4, R_ALLY)
	
	Player_SetRelationship(player2, player1, R_ENEMY)
	Player_SetRelationship(player2, player3, R_NEUTRAL)
	Player_SetRelationship(player2, player4, R_ENEMY)
	
	Player_SetRelationship(player3, player1, R_NEUTRAL)
	Player_SetRelationship(player3, player2, R_NEUTRAL)
	Player_SetRelationship(player2, player4, R_NEUTRAL)
	
	Player_SetRelationship(player4, player1, R_ALLY)
	Player_SetRelationship(player4, player2, R_ENEMY)
	Player_SetRelationship(player2, player3, R_NEUTRAL)
	
	--
    -- set player colours
    --
   
    PlayerColour_Enable()                                    -- turn on custom colour configuration for this session
   
    Game_SetPlayerSlotColour(player1, 1)              -- France    (paint scheme)
    Game_SetPlayerUISlotColour(player1, 1)            --            (ui colour)
   
    Game_SetPlayerSlotColour(player2, 2)              -- England
    Game_SetPlayerUISlotColour(player2, 2)
	
    Game_SetPlayerSlotColour(player3, 9)            -- University
    Game_SetPlayerUISlotColour(player3, 9)
	
    Game_SetPlayerSlotColour(player4, 3)            -- The Bureau Brothers
    Game_SetPlayerUISlotColour(player4, 3)

end

