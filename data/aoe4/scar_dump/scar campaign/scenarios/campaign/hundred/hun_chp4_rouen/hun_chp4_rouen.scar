function ConstructWave(waveType, powerMod, siegeOn)
	
	if waveType == nil then waveType = "Mixed" end
	if powerMod == nil then powerMod = 0 end
	if siegeOn == nil then siegeOn = false end
	
	local gameTime = World_GetGameTime()
	gameTime = gameTime/60
	
	--DEBUG--
	waveTest = waveTest or nil
	if waveTest ~= nil then 
		gameTime = waveTest
	end
	---------
	
	if gameTime <= 60 then
		local quarterTime = gameTime/4
		local exponentTime = (gameTime^6)/1000000000
		
		wavePower = quarterTime + exponentTime
	else
		wavePower = 66
	end

	
	local function DivMinRound(source, divide, max)
		local crunched = source/divide
		crunched = math.floor(crunched)
		crunched = math.min(crunched, max)
		return crunched
	end
	
	local waveResource = math.floor(wavePower)
	waveResource = Util_DifVar({math.min(waveResource+3, 20), math.min(waveResource+3, 20), waveResource+8, (waveResource+10)*1.25})
	waveResource = math.floor(waveResource * powerMod)
	
	local waveunits = {} --Changes attack wave composition based on game time
	
	local t_possibleUnits = {"scar_archer", "scar_horseman", "scar_manatarms", "scar_crossbowman", "scar_knight",}
	local fillUnit = "scar_spearman"
	if waveType == "Infantry" then
		t_possibleUnits = {"scar_archer", "scar_manatarms", "scar_crossbowman",}
		fillUnit = "scar_spearman"
	elseif waveType == "Cavalry" then
		t_possibleUnits = {"scar_horseman", "scar_knight",}
		fillUnit = "scar_horseman"
	elseif waveType == "Melee" then
		t_possibleUnits = {"scar_horseman", "scar_manatarms", "scar_knight",}
		fillUnit = "scar_spearman"
	elseif waveType == "Ranged" then
		t_possibleUnits = {"scar_archer", "scar_crossbowman",}
		fillUnit = "scar_archer"
	end
	
	if siegeOn == true then
		table.insert(t_possibleUnits, "scar_ram")
		table.insert(t_possibleUnits, "scar_springald")
		table.insert(t_possibleUnits, "scar_mangonel")		
	end
		
	t_possibleUnits = Table_Shuffle(t_possibleUnits)
	
	--local tenthTime = math.floor(gameTime/10)
	--local complexityOverTime = math.max(6 - tenthTime, 0)
	--for index = 1, tenthTime do
		--table.remove(t_possibleUnits, 1)
	--end
	
	for index = 1, #t_possibleUnits do
		local cost = 1
		if t_possibleUnits[index] == "scar_mangonel" or t_possibleUnits[index] == "scar_springald" then
			cost = 4
		elseif t_possibleUnits[index] == "scar_ram" then
			cost = 3
		elseif t_possibleUnits[index] == "scar_knight" or t_possibleUnits[index] == "scar_crossbowman" then
			cost = 2
		else
			cost = 1
		end
		local maxUnits = math.floor(waveResource/cost)
		if maxUnits > 0 then
			local randUnitAmount = World_GetRand(0, maxUnits)
			if randUnitAmount > 0 then 
				table.insert(waveunits, {type = t_possibleUnits[index], numSquads = randUnitAmount})
				waveResource = waveResource - (randUnitAmount*cost)
			end
		end
	end
	
	table.insert(waveunits, {type = fillUnit, numSquads = waveResource+1})
	
	return waveunits
end

function Send_NorthWave(randTime)
	EGroup_Clear(eg_temp)
	Player_GetAllEntitiesNearMarker(player2, eg_temp, mkr_enemy_attack_northlane_3, 60)
	EGroup_Filter(eg_temp, "stable", FILTER_KEEP)
	
	SGroup_Clear(sg_temp)
	Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_enemy_attack_northlane_3, 80)
	
	if EGroup_CountSpawned(eg_temp) > 0 and SGroup_CountSpawned(sg_temp) <= 0 then 
		Wave_SetUnits(northWave_forward, ConstructWave("Cavalry", 1, false))
		Wave_Prepare(northWave_forward)
	else
		Wave_SetUnits(northWave_base, ConstructWave("Cavalry", 1, false))
		northWave_base.auto_launch = randTime
		Wave_Prepare(northWave_base)
	end
end

function Send_CentralWave(randTime)
	EGroup_Clear(eg_temp)
	Player_GetAllEntitiesNearMarker(player2, eg_temp, mkr_enemy_attack_centerlane_1, 60)
	EGroup_Filter(eg_temp, {"castle", "archery_range", "barracks"}, FILTER_KEEP)
	
	SGroup_Clear(sg_temp)
	Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_enemy_attack_centerlane_1, 80)
	
	if EGroup_CountSpawned(eg_temp) > 0 and SGroup_CountSpawned(sg_temp) <= 0 then 
		Wave_SetUnits(centerWave_forward, ConstructWave("Infantry", 1, false))
		Wave_Prepare(centerWave_forward)
	else
		Wave_SetUnits(centerWave_base, ConstructWave("Mixed", 0.85, true))
		centerWave_base.auto_launch = randTime
		Wave_Prepare(centerWave_base)
	end
	
end

function Send_SouthWave(randTime)
	EGroup_Clear(eg_temp)
	Player_GetAllEntitiesNearMarker(player2, eg_temp, mkr_enemy_attack_southlane_3, 60)
	EGroup_Filter(eg_temp, "barracks", FILTER_KEEP)
	
	SGroup_Clear(sg_temp)
	Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_enemy_attack_southlane_3, 80)
	
	if EGroup_CountSpawned(eg_temp) > 0 and SGroup_CountSpawned(sg_temp) <= 0 then 
		Wave_SetUnits(southWave_forward, ConstructWave("Infantry", 1, false))
		Wave_Prepare(southWave_forward)
	else
		
		EGroup_Clear(eg_temp)
		Player_GetAllEntitiesNearMarker(player2, eg_temp, mkr_enemy_attack_southlane_1, 60)
		EGroup_Filter(eg_temp, {"barracks", "stable"}, FILTER_KEEP)
		
		SGroup_Clear(sg_temp)
		Player_GetAllSquadsNearMarker(player1, sg_temp, mkr_enemy_attack_southlane_1, 80)
		
		if EGroup_CountSpawned(eg_temp) > 0 and SGroup_CountSpawned(sg_temp) <= 0 then
			Wave_SetUnits(southWave_fallback, ConstructWave("Melee", 1, false))
			Wave_Prepare(southWave_fallback)
		else
			Wave_SetUnits(southWave_base, ConstructWave("Mixed", 0.85, true))
			southWave_base.auto_launch = randTime
			Wave_Prepare(southWave_base)
		end
	end
	
end

function Manage_AttackWaves()
	if b_attackWavesOn == true then
		sg_rouen_threatcount = SGroup_CreateIfNotFound("sg_rouen_threatcount")
		sg_rouen_defendercount = SGroup_CreateIfNotFound("sg_rouen_defendercount")
		Player_GetAllSquadsNearMarker(player1, sg_rouen_threatcount, mkr_enemy_base_approach)
		if SGroup_CountSpawned(sg_rouen_threatcount) > 12 then
			Player_GetAllSquadsNearMarker(player2, sg_rouen_defendercount, mkr_enemy_base)
			if SGroup_CountSpawned(sg_rouen_defendercount) < 150*t_difficulty.defenderValue then
				Wave_Prepare(wave_defend_rouen)
			end
			Rule_AddOneShot(Manage_AttackWaves, 450-t_difficulty.timerMod)
			SGroup_Clear(sg_rouen_threatcount)
		else
			local randTime = World_GetRand(120-t_difficulty.timerMod, 360-t_difficulty.timerMod)
			local randLane = World_GetRand(1,100)
			if randLane <= 35 then
				Send_NorthWave(randTime)
			elseif randLane >= 66 then
				Send_SouthWave(randTime)
			else
				Send_CentralWave(randTime)	
			end
			Rule_AddOneShot(Manage_AttackWaves, randTime)
		end
	end
end

function GetMissionFail()
	
	Mission_Fail()
end

function RetakeNormandy_MoveStartingUnits()
	
	local units = {
		{type = "scar_spearman", numSquads = 15},
		{type = "scar_manatarms", numSquads = 30},
		{type = "scar_crossbowman", numSquads = 20},
		}	
	UnitEntry_DeploySquads(player1, sg_player_startingunits_01, units, mkr_player_start_spawn_middle)
	Cmd_FormationMove(sg_player_startingunits_01, mkr_player_start_dest, false, false, Marker_GetPosition(mkr_player_start_facing))
	
	
	-- slowing units down a bit to fill length of intro camera
	modid_intro_unit_speed = Modify_UnitSpeed(sg_player_startingunits_01, 0.9)

end

function PlayerSkippedIntro_PlaceUnits()
	-- reset intro units speed
	Modifier_Remove(modid_intro_unit_speed)
end

function Monitor_TC()
	
	if EGroup_IsUnderAttackByPlayer(eg_player_towncenter, player2, 1) == true or EGroup_IsUnderAttackByPlayer(eg_bbworkshop, player2, 1) == true then
		Rule_RemoveMe()
		Util_StartIntel(EVENTS.TC_Attack)
	end
end

function CounterMonks()
	captureCount = captureCount or 1
	eg_target_holysites = EGroup_CreateIfNotFound("eg_target_holysites")
	EGroup_Duplicate(eg_holysites, eg_target_holysites)
	
	local _GetHolyTargets = function(gid, index, eid)
		if World_OwnsEntity(eid) ~= true then
			if Entity_GetPlayerOwner(eid) == player2 then
				EGroup_Remove(gid, eid)
			end
		end
	end
	EGroup_ForEach(eg_target_holysites, _GetHolyTargets)
	
	if EGroup_CountSpawned(eg_target_holysites) > 0 then
		local modName = ("monk_army_"..captureCount)
		local moduleData = 
		{
			type = "RovingArmy",
			descriptor = modName,
			player = player2,
			targetingType = ARMY_TARGETING_DISCARD,
			targets = {
				{ position = Util_GetPosition(EGroup_GetRandomSpawnedEntity(eg_target_holysites)), combatRange = 12, leashRange = 15},
				position = Util_GetPosition(EGroup_GetRandomSpawnedEntity(eg_target_holysites)),					
			},		
			spawnLocation = mkr_enemy_base_garrison,
			onDeathDissolve = true,
			units = 
			{
				{type = "scar_spearman", numSquads = 10},
				{type = "scar_manatarms", numSquads = 3},
				{type = "scar_monk", numSquads = 1},
			}
		}
		_G["Rouen_Monks_"..captureCount] = RovingArmy_Init(moduleData)
		captureCount = captureCount+1
	end
end

function GameOver_EarlyDeath()
	Player_GetAll(player1)
	if SGroup_CountSpawned(sg_allsquads) <= 0 then
		Mission_Fail()
	end
end

function ApplyPressure_Wave1()
	local pressureModule = MissionOMatic_FindModule("PressureWave1")
	if pressureModule ~= nil and SGroup_CountSpawned(pressureModule.sgroup) then
		RovingArmy_SetTarget(pressureModule, mkr_player_base)
	end
end

function ApplyPressure_Wave2()
	local pressureModule = MissionOMatic_FindModule("PressureWave2")
	if pressureModule ~= nil and SGroup_CountSpawned(pressureModule.sgroup) then
		RovingArmy_SetTarget(pressureModule, mkr_player_base)
	end
end

function ApplyPressure_Wave3()
	local pressureModule = MissionOMatic_FindModule("PressureWave3")
	if pressureModule ~= nil and SGroup_CountSpawned(pressureModule.sgroup) then
		RovingArmy_SetTarget(pressureModule, mkr_player_base)
	end
