function Mission_SetRestrictions()	-- set up any restrictions (i.e. locking out units, etc) in here
	
	PlayerUpgrades_Auto(player1, true)
	PlayerUpgrades_Auto(player2,false,{UPG.COMMON.UPGRADE_TECH_UNIVERSITY_MURDER_HOLES_4})
	PlayerUpgrades_Auto(player3, true)
	PlayerUpgrades_Auto(player4, true)

	Player_GetAll(player2)
	EGroup_Filter(eg_allentities, EBP.ENGLISH.BUILDING_DEFENSE_KEEP_ENG, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_KEEP_SPRINGALD)
	
	Player_GetAll(player2)
    EGroup_Filter(eg_allentities, EBP.ENGLISH.BUILDING_DEFENSE_OUTPOST_ENG, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_OUTPOST_STONE)
	
	Player_GetAll(player2)
    EGroup_Filter(eg_allentities, EBP.FRENCH.BUILDING_DEFENSE_OUTPOST_FRE, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)

	Player_GetAll(player2)
    EGroup_Filter(eg_allentities, EBP.ENGLISH.BUILDING_DEFENSE_TOWER_ENG, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_OUTPOST_SPRINGALD)
	
	Player_SetStateModelBool(player1, "disable_landmark_rebuild",true)
	Player_SetStateModelBool(player2, "disable_landmark_rebuild",true)
	
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_SIEGE_ENGINEERS, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_SIEGE_ADJUSTABLE_CROSSBAR, ITEM_REMOVED)
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_SIEGE_ROLLER_TRIGGER, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.FRENCH.UNIT_RAM_3_FRE, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.FRENCH.UNIT_SIEGE_TOWER_3_FRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_UNIT_SIEGE_CONTROL_FRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_LANDMARK_AGE3_ECOLE_DE_POUDRE_A_CANON_FRE, ITEM_REMOVED)
	--Conversion is verboten
	Player_SetAbilityAvailability(player1, BP_GetAbilityBlueprint("monk_conversion"), ITEM_REMOVED)
end

function Mission_PreInit()
	-- prep the tribute menu for this mission (will be enabled later on)
	Core_CallDelegateFunctions("DiplomacyEnabled", true)
	Diplomacy_ShowUI(false)
		
end

function Mission_Preset()
	
	BBSurvive_InitObjectives()
	RetakeNormandy_InitObjectives()	
	RetakeNormandy_Init_ResearchObjectives()
	CaptureLocations_InitUniTown()
	ConditionalInit_OptionalObjectives()

	Villagers05BuildingNow = false
	
	defend3VillageDestroyed = false
	defend2VillageDestroyed = false
	defend4VillageDestroyed = false
	defend5VillageDestroyed = false
	defend6VillageDestroyed = false
	LaneTimerTop = t_difficulty.initial_lane_timer_top
	LaneTimerMiddle = t_difficulty.initial_lane_timer_middle
	LaneTimerBelow = t_difficulty.initial_lane_timer_below
	
	choiceAttack = 5
	
	i_rouen_phase = {}
	i_rouen_phase[1] = 1
	i_rouen_phase[2] = 1
	i_rouen_phase[3] = 1
	
	i_numberWallPieces = 0
	i_numberWallPiecesToDestroy = 1
	i_maxNumberLandmarks = 3
	
	firstAttackDone = false
	firstAttackersArrived = false
	numberOfCannonsObj = 4
	b_IntelStartOnFirstCannon = false
	b_CannonDestroyedWall = false
	b_TCUnderAttack = false
	
	AssignVillagersToFarms(sg_player_farmers_1 )
	AssignVillagersToFarms(sg_player_farmers_2)
	AssignVillagersToGold(sg_player_gold_miners)
	AssignVillagersToStone(sg_player_stone_miners)
	AssignVillagersToWood(sg_player_wood_cutters)
	
	Init_AttackWaves()
	
	--DEBUG: TEMP TILL TENTS ARE SORTED--
	Modify_PlayerPopCap(player1, 140, MUT_Addition)
	Modify_PlayerPopCap(player1, 140, MUT_Addition)
	Player_SetPopCapOverride(player2, 2000)
	
	EGroup_Filter(eg_rouenwalls, EBP.ENGLISH.BUILDING_DEFENSE_TOWER_ENG, FILTER_REMOVE)
	
	UI_SetPlayerDataContext(player1, { PopulationCapOn = false })
	
	Entity_SetRemainingResourceDepositAmount(EGroup_GetEntityAt(eg_playergold, 1), 7000)
	
	Player_SetResource( player1, RT_Gold, 0) 
	Player_SetResource( player1, RT_Wood, 0) 
	Player_SetResource( player1, RT_Food, 0) 
	Player_SetResource( player1, RT_Stone, 0) 
	
	EGroup_SetInvulnerable(eg_bbworkshop, 0.2)
			
end
	
function Mission_SetDifficulty()

	t_difficulty = {
		given_resources_gold = Util_DifVar({3000,2500,2200,2000}),
		given_resources_wood = Util_DifVar({2400,1200,700,500}),
		given_resources_food = Util_DifVar({3000,2500,2000,1200}),
		given_resources_stone = Util_DifVar({1000,1000,500,0}),
		
		initial_lane_timer_top = Util_DifVar({150,150,120,110}),
		initial_lane_timer_middle = Util_DifVar({150,150,120,110}),
		initial_lane_timer_below = Util_DifVar({150,150,120,110}),
		
		i_request_upperThreshold = Util_DifVar({0.6,0.6,0.7,0.75}),
		i_request_lowerThreshold = Util_DifVar({0.2,0.2,0.2,0.1}),
		i_request_desiredStrength = Util_DifVar({0.7,0.7,0.8,1}),
		
		defenderValue = Util_DifVar({0.66, 0.75, 1, 1.20}), --t_difficulty.defenderValue
		
		timerMod = Util_DifVar({0, 0, 45, 90}), --t_difficulty.timerMod

	}

  end

function Mission_Start()
	
	Player_SetResource( player1, RT_Gold, 0) 
	Player_SetResource( player1, RT_Wood, 0) 
	Player_SetResource( player1, RT_Food, 0) 
	Player_SetResource( player1, RT_Stone, 0)
	
	Action_SetResources_Do({ player = player2, resources = { food = 30000, wood = 30000, stone = 30000, gold = 30000 } })
	
	Objective_Start(OBJ_RetakeNormandy, false, true)
	Objective_Start(OBJ_CaptureUniTown, true)
	
	Rule_AddInterval(TradeRoute_Step1_PlayerProximity_Optional, 1)
	Rule_AddInterval(RiverPort_Step1_PlayerProximity_Optional, 1)
	Rule_AddInterval(MineCapture_PlayerProx, 1)
	
	Rule_AddInterval(GameOver_EarlyDeath, 1)
	
	for i, moduleName in pairs(t_allRouenRecipeModNames) do
		local module = MissionOMatic_FindModule(moduleName)
		table.insert(t_allRouenModules, module)
	end
	
	if Game_GetSPDifficulty() > GD_NORMAL then
		Rule_AddInterval(Anti_Ram, 360)
	end
	
	Rule_AddEGroupEvent(DestroyFieldWall_EntityKill, eg_fieldwalls ,GE_EntityKilled)
	
	Rule_AddGlobalEvent(Achievement_ProduceUpgradedCannon, GE_BuildItemComplete)
	
	Game_TransitionToState("day", 300)
	
end

function Monitor_landmarks()
	
	Player_GetAll(player1)
	EGroup_Filter(eg_allentities, "landmark", FILTER_KEEP)
	
	if EGroup_CountSpawned(eg_allentities) == 0 then -- Removed "SGroup_CountSpawned(sg_allsquads) == 0 and"
		Mission_Fail()
	end
	
end

function Monitor_BBWorkshop()
	
	if EGroup_CountSpawned(eg_bbworkshop) <= 0 then 
		Mission_Fail()
	end
end

