function UI_ReinforcePanel_UpdateData()
	
	uiData_ReinforcePanel = {
		Visible = true,
		Settlements = {},
		SumIncome = 0,
	}
	
	for index, settlement in pairs(t_reinforcementData) do
		if settlement.purchased ~= true then
			local uiData = {
				
				Name = Loc_GetString(settlement.displayName),
				
				TradeCountVisible = false,				
				
				BuyButtonVisible = false,
				BuyButtonEnabled = false,
				BuyButtonOpacity = 0.44,
				BuyButtonCommand = UI_CreateCommand("UI_CameraSnap_ButtonCallback"),
				BuyButtonParameter = settlement.id,
				AidButtonTitle = Loc_GetString(settlement.buttontext),
				--AidButtonTooltip = settlement.tooltip,
				AidIncome = settlement.income,
				ToolTip_CompletionText = Loc_GetString(11196695),
				--BuyButtonTooltip = "",
				PopWarning = true,
				ProgressValue_Visible = _diplomacy.data_context.is_progress_visible,
				CostColour = "#FFBFBFBF",
				
				
				--Order = settlement.foundOrder,
				--utility:LocString $11196695 --Complete this location
			}			
			
			uiData.TradeCountVisible = false
			uiData.BuyButtonVisible = true
			
			--if Player has pop cap available
			local totalAidAmount = (settlement.aidAmount_2 or 0) + settlement.aidAmount
			if (Player_GetCurrentPopulation(player1, CT_Personnel) + totalAidAmount) <= 200 then --Player_GetCurrentPopulationCap(player1, CT_Personnel) then
				uiData.BuyButtonEnabled = true 
				uiData.BuyButtonOpacity = 1.0
				uiData.PopWarning = false
			end
			--end
			
			if settlement.activated == true then
				uiData.CostColour = "#FFFFDB88"
				uiData.ToolTip_CompletionText = Loc_GetString(11202094)
				uiData_ReinforcePanel.SumIncome = uiData_ReinforcePanel.SumIncome + settlement.income
			end
			
			--uiData.BuyButtonTooltip = Loc_GetString(Loc_FormatText(11180286, uiData.AidIncome))
			uiData.IncomeAmount = Loc_GetString(Loc_FormatText(11196585, uiData.AidIncome)) -- Progress Rate Bonus: %1AMOUNT%
			--Loc_GetString(Loc_FormatText(11180286, 69))
			if settlement.aidAmount_2 ~= nil then
				uiData.AidButtonTooltip = Loc_GetString(settlement.tooltip) --Loc_GetString(Loc_FormatText(settlement.tooltip, settlement.aidAmount, settlement.aidAmount_2)) -- %1AMMOUNT% Reinforcement type 1 and %2AMMOUNT% Reinforcement type 2
			else
				uiData.AidButtonTooltip = Loc_GetString(settlement.tooltip) --Loc_GetString(Loc_FormatText(settlement.tooltip, settlement.aidAmount)) -- %1AMMOUNT% Reinforcement type
			end
			
			table.insert(uiData_ReinforcePanel.Settlements, uiData)
		end
	end
	
	--if #uiData_ReinforcePanel.Settlements == 0 then 
		uiData_ReinforcePanel.Visible = true
	--end
	uiData_ReinforcePanel.SumIncome = tostring(uiData_ReinforcePanel.SumIncome) --LOC(uiData_ReinforcePanel.SumIncome) --Loc_GetString(Loc_FormatText(11180287, uiData_ReinforcePanel.SumIncome))
	
	--table.sort(uiData_ReinforcePanel.Settlements, function(a, b) return a.Order < b.Order end)		-- this sorts the settlements into the order they were found
	
	_diplomacy.data_context.buySettlements = uiData_ReinforcePanel
	Diplomacy_UpdateUI()
	
end

function UI_CameraSnap_ButtonCallback(parameter)
		
	for index, settlement in pairs(t_reinforcementData) do 
	
		if settlement.id == parameter then
			Camera_FocusOnPosition(Util_GetPosition(settlement.marker))
		end
	end
end