--
-- Mission Retake Normandy and 1448 - Objective Research Cannons
--

import("sobj_capture_mine.scar")
import("training/campaigntraininggoals.scar")

function RetakeNormandy_Init_ResearchObjectives()		-- rename this function to use your prefix for this part of the mission

	OBJ_ResearchCannons = {
	
		Title = "$11197656", --("Research Chemistry"),
		Type = ObjectiveType_Primary,
		
		Intel_Start = EVENTS.NewObj_ResearchChemistry,
				 
		SetupUI = CannonResearch_SetupUI, 
		OnStart = CannonResearch_Start,
		IsComplete = CannonResearch_IsComplete,
		OnComplete = CannonResearch_OnComplete,

	}
	
	SOBJ_EstablishTradeRoute = {
	
		Title = "$11196661", --("Capture the local trade route"),
		Type = ObjectiveType_Primary,
		Parent = OBJ_ResearchCannons,
		StartAlongsideParent = false,
		OnStart = CaptureTradeRoute_Start,
	}
	
	SOBJ_RaidTheRiverPort = {
	
		Title = "$11196662", --("Raze the River Port"),
		Type = ObjectiveType_Battle,
		Parent = OBJ_ResearchCannons,
		StartAlongsideParent = false, 
		OnStart = CaptureTheRiverPort_Start,
	}
	
	SOBJ_HoldTheUniversity = {
	
		Title = "$11196663", --("Hold the University"),
		Type = ObjectiveType_Primary,
		Parent = OBJ_ResearchCannons,
		StartAlongsideParent = false,
		OnStart = CaptureTheUniversity_Start,
	}
	
	SOBJ_BuildLandmark = {
	
		Title = "$11183683", --("Advance to the Imperial Age"),
		Type = ObjectiveType_Primary,
		Parent = OBJ_ResearchCannons,
		StartAlongsideParent = false,
		IsComplete = BuildLandmark_IsComplete,
		OnComplete = WrapUp_ResearchObj,
	}
		
	
	Objective_Register(OBJ_ResearchCannons)
	
	OptionalObjective_Data = 
	{
		traderoute = {isCompleted = false, step = 1},
		riverport = {isCompleted = false, step = 1},
		minecapture = {isCompleted = false, step = 1},
	}
	
	--
	-- any other variable initialization can go in here
	--	
end

function CannonResearch_SetupUI()
	Player_GetAll(player1)
	EGroup_Filter(eg_allentities, "university", FILTER_KEEP)
	if EGroup_CountSpawned(eg_allentities) > 0 then
		chemistryUI = Objective_AddUIElements(OBJ_ResearchCannons, EGroup_GetEntityAt(eg_allentities, 1), true, "$11197656", true, 6) --("Research Chemistry"),
	end
end

