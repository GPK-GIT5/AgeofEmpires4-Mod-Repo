function CannonResearch_IsComplete()
	if Player_HasUpgrade(player1, UPG.COMMON.UPGRADE_SIEGE_CHEMISTRY) then
		return true
	end
end

function CannonResearch_OnComplete()
	
	Util_AutoSave(true, true)
	
	Util_StartIntel(EVENTS.CannonProdAvailable)

	EventCues_CallToAction("$11196713", CTA_CELEBRATE, nil, nil, eg_bbworkshop, 8) -- Cannon production available at Bureau Brothers' Workshop!
	Sound_Play2D("mus_stinger_campaign_triumph_short")
	Sound_Play2D("sfx_campaign_scripted_small_group_celebrate")
		
	StartOptionals_IfNotStarted()
	Objective_Start(SOBJ_GetCannons, true)
	
	Objective_RemoveUIElements(OBJ_ResearchCannons, chemistryUI)
	
end

function DelayDiplomacyPanel()
	--LW delay the appearance of the diplomacy panel until after the CTA has gone away so that they don't overlap.
	Diplomacy_ShowUI(true)
	
	if UI_IsXboxUI() then
		CampaignTraining_AddDiplomacyPanelHint("$11250125", "workshop_sequence")
	else
		Diplomacy_ShowDiplomacyUI(true)
	end
end

function BuildLandmark_IsComplete()
	if Player_GetCurrentAge(player1) == Player_GetMaximumAge(player1) then
		Rule_RemoveMe()
		Util_StartIntel(EVENTS.AgeUp_ChemistryAvailable)
	end
end
