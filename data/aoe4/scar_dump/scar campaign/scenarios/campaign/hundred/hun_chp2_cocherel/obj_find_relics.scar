--
-- France in Chaos 1364 
-- Find the relics
-- optional
--

function FindRelics_InitObjectives()		-- rename this function to use your prefix for this part of the mission

	OBJ_increase_gold_income = {
	
		Title = 11172156, --LOC("Optional: Increase your gold income."),
		Type = OT_Primary,
		Icon = "icons\\races\\common\\victory_conditions\\victory_condition_religious",
		IsComplete = function()
			return Objective_AreSubObjectivesComplete(OBJ_increase_gold_income,ALL)
		end,
		
	}
	
	SOBJ_Findrelics = {
	
		Title = 11172157, --LOC("Place relics in Holy Sites"),
		Type = OT_Secondary,
		Parent = OBJ_increase_gold_income,
		StartAlongsideParent = true,
		Icon = "icons\\races\\common\\abilities\\pick_up_relic",

		SetupUI = Findrelics_SetUI,
		
		OnStart = Findrelics_Start,
		
		OnComplete = Findrelics_OnComplete,
		
	}
		
	
	Objective_Register(OBJ_increase_gold_income)
	Objective_Register(SOBJ_Findrelics)

	--
	-- any other variable initialization can go in here
	--
	monasteryID = nil
end

function Findrelics_SetUI()
	
	Objective_SetCounter(SOBJ_Findrelics, 0, i_numberRelics)
	
end

function Findrelics_Start()
	
	Rule_Add(Findrelics_Monitor)
	
	Rule_AddGlobalEvent(FindRelics_OnAbilityExecuted, GE_AbilityExecuted)
	
end




function FindRelics_OnAbilityExecuted(context)
	
	g_relicDeposited = BP_GetAbilityBlueprint("monk_statetree_deposit_relic")
	monkRemoveRelic = BP_GetAbilityBlueprint("monk_remove_relic")
	monasteryRemovesRelic = BP_GetAbilityBlueprint("monastery_relic_remove")

	if context.ability == g_relicDeposited or context.ability == monkRemoveRelic or context.ability == monasteryRemovesRelic then
		
		if context.ability == g_relicDeposited then
			if  Entity_GetPlayerOwner( context.executer  ) == player1 then
				if Objective_IsComplete(SOBJ_Findrelics) == false then
					
					if Entity_GetBlueprint(context.target) == BP_GetEntityBlueprint("holy_site") then
						
						Objective_IncreaseCounter(SOBJ_Findrelics,1)
						Music_PlayStinger("mus_stinger_event_declare_world_religion_player")
						
					end
				end
			end
		end	
	end
	
end

function Findrelics_Monitor()
	
	if Objective_IsComplete(SOBJ_Findrelics) == true then
		Rule_RemoveMe()
	else
		local numberCounted = Objective_GetCounter(SOBJ_Findrelics)
		
		if numberCounted >= i_numberRelics then 
			Objective_Complete(SOBJ_Findrelics)
			Rule_RemoveMe()
		end
	end
end

function Findrelics_OnComplete()
	Rule_RemoveGlobalEvent(FindRelics_OnAbilityExecuted)
end


