function Mission_SetRestrictions()	-- set up any restrictions (i.e. locking out units, etc) in here
	
	Modify_PlayerMaxPopCap(player1, -15, MUT_Addition)
end

function Mission_Preset()	-- any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)	

	--PlayerUpgrades_Auto(player1)
	--We're not using the upgrade wrapper, but still need to apply special health bonuses
	PlayerUpgrades_ApplyHealthBonuses(player1)
	
	PlayerUpgrades_HideAgeUpAbilities(player1, Player_GetMaximumAge(player1))  
	PlayerUpgrades_HideAllUpgrades(player1, Player_GetMaximumAge(player1), "french")
	PlayerUpgrades_Auto(player2)
	PlayerUpgrades_Auto(player3, nil, {UPG.COMMON.UPGRADE_RANGED_ARMOR_I, UPG.COMMON.UPGRADE_RANGED_ARMOR_II, UPG.COMMON.UPGRADE_MELEE_ARMOR_I, UPG.COMMON.UPGRADE_MELEE_ARMOR_II})
	PlayerUpgrades_Auto(player4, nil, {UPG.COMMON.UPGRADE_RANGED_ARMOR_I, UPG.COMMON.UPGRADE_RANGED_ARMOR_II, UPG.COMMON.UPGRADE_MELEE_ARMOR_I, UPG.COMMON.UPGRADE_MELEE_ARMOR_II})
	
	Player_SetMaximumAge(player1, AGE_FEUDAL)  

	-- set player start resources (set again after the NIS, but this avoids the worst of the popping)
	Player_SetResource( player1, RT_Gold, t_difficulty.given_resources_gold) 
	Player_SetResource( player1, RT_Wood, t_difficulty.given_resources_wood) 
	Player_SetResource( player1, RT_Food, t_difficulty.given_resources_food) 
	Player_SetResource( player1, RT_Stone, t_difficulty.given_resources_stone) 

	--player 1 removing specific things
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_TOWN_CENTER_CAPITAL_FRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_TOWN_CENTER_FRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_ECON_MARKET_CONTROL_FRE,ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_UNIT_RELIGIOUS_CONTROL_FRE, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_LANDMARK_AGE2_LA_CHATEAU_ROUGE_FRE,ITEM_REMOVED) 
	Player_SetEntityProductionAvailability(player1, EBP.FRENCH.BUILDING_LANDMARK_AGE2_GUILD_HALL_FRE,ITEM_REMOVED)  
	
	--player 2
	Player_GetAll(player2)
	EGroup_Filter(eg_allentities, EBP.FRENCH.BUILDING_DEFENSE_OUTPOST_FRE, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)

	Player_SetEntityProductionAvailability(player2,EBP.FRENCH.BUILDING_ECON_MARKET_CONTROL_FRE,ITEM_REMOVED)
		
	Player_GetAll(player2)  
	EGroup_Filter(eg_allentities, "monastery", FILTER_KEEP)
	local monasteryID = EGroup_GetSpawnedEntityAt(eg_allentities, 1)
	Entity_SetStateModelFloat(monasteryID, "relic_count", 1)
	
	--player 3
	Player_GetAll(player3)
	EGroup_Filter(eg_allentities, EBP.ENGLISH.BUILDING_DEFENSE_OUTPOST_ENG, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	
	local militia_speed_buff = Modifier_Create(MAT_EntityType, "speed_maximum_modifier", MUT_Multiplication, false, 1.33, "unit_shield_villager_cmp_fre")
	Modifier_ApplyToPlayer(militia_speed_buff , player2, 0)

	--objectives
	ProtectMonastery_InitObjectives()	
	CaptureFrenchVillages_InitStemRebel()
	CaptureFrenchVillages_InitJouy()
	CaptureFrenchVillages_InitCroisy()
	CaptureFrenchVillages_InitCocherel()
	DefeatCharlesBadArmy_InitObjectives()
	DefeatRoutiers_InitObjectives()
	
	Player_SetStateModelBool(player2, "can_capture_override", true)

	
	--RebuildTC_Villagers()
	Rule_AddOneShot(RebuildTC_Villagers, 0.125)
	SetupAttackWaves()
	
end

function Mission_SetDifficulty()

	t_difficulty = {
		given_resources_gold = Util_DifVar({500, 400, 300, 200}),
		given_resources_wood = Util_DifVar({1000, 800, 600, 400}),
		given_resources_food = Util_DifVar({1000, 800, 600, 400}), 
		given_resources_stone = Util_DifVar({250, 200, 150, 100}), 
		i_numberUnitsToKillCharles = Util_DifVar({83, 97, 124, 159}),
		
		-- how close you need to be to a settlement to get a hint as to it's location
		findHolySite_NearbyDistance = Util_DifVar({140, 110, 80, 50}),
		
		routiers_goldDemanded = Util_DifVar({800, 800, 1000, 1400}),
		
		routiers_firstAttackDelay = Util_DifVar({90, 90, 60, 30}),
		routiers_attackFrequency = Util_DifVar({180, 180, 150, 120}),
		
		cocherel_firstAttackDelay = Util_DifVar({50, 50, 30, 10}),
		cocherel_attackFrequency = Util_DifVar({180, 180, 150, 120}),
		
		routier_attackCocherelDelay = Util_DifVar({120, 120, 100, 80}),
		routier_attackCocherelInterval = Util_DifVar({180, 180, 150, 120}),
		
		charles_firstAttackDelay = Util_DifVar({70, 70, 50, 30}),
		charles_attackInterval = Util_DifVar({180, 180, 150, 120}),
	}

end


function Mission_PreInit()
	-- prep the tribute menu for this mission (will be enabled later on)
	Core_CallDelegateFunctions("DiplomacyEnabled", false)
	Diplomacy_ShowUI(false)
end


function Mission_Start()	-- this is triggered after the intro, just as control is passed to the player
	
	Player_SetResource( player1, RT_Gold, t_difficulty.given_resources_gold) 
	Player_SetResource( player1, RT_Wood, t_difficulty.given_resources_wood) 
	Player_SetResource( player1, RT_Food, t_difficulty.given_resources_food) 
	Player_SetResource( player1, RT_Stone, t_difficulty.given_resources_stone) 

	Action_SetResources_Do({ player = player2, resources = { food = 30000, wood = 30000, stone = 30000, gold = 30000 } })
	Action_SetResources_Do({ player = player3, resources = { food = 30000, wood = 30000, stone = 30000, gold = 30000 } })
	Action_SetResources_Do({ player = player4, resources = { food = 30000, wood = 30000, stone = 30000, gold = 30000 } })

	
	Objective_Start(OBJ_StemRebel,true, true)
	
	HintPoint_Add(mkr_player_rebuildTC,true,"$11195396", LOCATION_LABEL_HEIGHT)
	
	Rule_AddInterval(Mission_CheckTC,10)
	--Config_holy_sites()
	EGroup_SetInvulnerable(eg_monastery,0.3)
	
	if difficulty <= GD_NORMAL then
		t_RoutiersAttackTest = Clone(t_RoutiersAttackEasy,false)
	elseif difficulty == GD_HARD then
		t_RoutiersAttackTest = Clone(t_RoutiersAttackMed,false)
	else
		t_RoutiersAttackTest = Clone(t_RoutiersAttackHard,false)
	end

	local gold = Util_DifVar({1000,800,600,400})
	
	local _SetGold = function(gid, idx, eid)
		Entity_SetStateModelFloat(eid, "resource_pickup_amount_gold", gold)
	end
	EGroup_ForEach(eg_gold_Routiers, _SetGold)
	
	Rule_AddInterval(MoveRoutiersKnights,15)
	Rule_AddInterval(MoveJouyUnit01, 15)
	Rule_AddInterval(MoveJouyUnit02,12)
	Rule_AddInterval(MoveCroisyUnit02,13)
	Rule_AddInterval(MoveCroisyUnit01,16)
	Rule_AddInterval(MoveCocherelUnits01,8)
	
	Rule_AddInterval(CheckRoutierslooted,3)
	
	Rule_AddInterval(CounterMonks,340)
	
	if difficulty ~= GD_EXPERT then 
		Rule_AddInterval(Monitor_PlayerFoundSecret,1)
	end
	
	Rule_AddInterval(Cocherel_Mainloop, 1)
	
	EGroup_DestroyAllEntities(eg_relic_remove)
end

function Cocherel_Mainloop()
	cocherel_seconds = cocherel_seconds + 1
end

