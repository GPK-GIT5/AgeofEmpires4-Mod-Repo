function Mission_CheckTC()

	Player_GetAll(player1,eg_allentities)
	EGroup_Filter(eg_allentities, "town_center", FILTER_KEEP)

	if EGroup_CountSpawned(eg_allentities) <= 0 then
		Mission_Fail()
	end
	
end

function Routiers_ShowTributeMenu()

	-- Configure diplomacy UI to only show the Routiers	
	Diplomacy_OverrideSettings(true, true, false, false)
	Diplomacy_OverridePlayerSettings(player1, false)
	Diplomacy_OverridePlayerSettings(player2, false)
	Diplomacy_OverridePlayerSettings(player4, false)
	Diplomacy_OverridePlayerSettings(player3, true, true, false, false, true, false)
	Diplomacy_SetTaxRate(Game_GetLocalPlayer(), 0.0)
	Diplomacy_UpdateNameColours()
	Diplomacy_ShowUI(true)
end

function Routiers_HideTributeMenu()
	print("Hiding menu Tribute")
	Core_CallDelegateFunctions("DiplomacyEnabled", false)
	Diplomacy_ShowUI(false)
end

function RebuildTC_Villagers()
	print("This script is attempting to set everything on fire.")
	
	EGroup_Kill(eg_buildingDestroyed_player1)
	
	Player_GetAllEntitiesNearMarker(player1, eg_allentities,mkr_destroy_wall_02)
	EGroup_Kill(eg_allentities)
	
	Modify_OnFireHealthPercentage(eg_player_burning, MUT_Addition, 0.5)
	
	local _SetOnFire = function(gid, idx, eid)
		Entity_SetHealth(eid, 40 / 100)		-- randomize the health so things don't all burn down in sync
		print("Attempting t set "..BP_GetName(Entity_GetBlueprint(eid)).." on fire.")
	end
	
	EGroup_ForEach(eg_player_burning, _SetOnFire)
	
	mod_id_onfire = Modify_OnFireDamagePerTick(eg_player_burning,MUT_Multiplication,0)
	Rule_AddOneShot(Rebuildvillage,5)
	
	UnitEntry_DeploySquads(player3, sg_routiers_introVillage, {{ type = "scar_horseman", numSquads = 4 }}, mkr_routier_intro_village_spawn, nil, nil, {})
	
	Cmd_Attack(sg_routiers_introVillage,eg_TC_town01)
	Rule_AddOneShot(MoveRoutiersIntroOut, 8)
	Rule_Add(MonitorRoutiersIntro)
end

function MoveRoutiersIntroOut()
	Sound_PlayOnSquad(WALLA_CAMP_FEAR_MEDIUM, sg_routiers_introVillage)
	Rule_AddOneShot(MoveRoutiersIntroOut_PartB, 3)	
end

function MoveRoutiersIntroOut_PartB()
	-- If the marker is moved further into FOW, this could be changed to deleteOnArrival and the Prox_AreSquadsNearMarker check below could be removed
	-- This would save performance but looks worse if the unit is not shrouded by FOW
	Cmd_FormationMove(sg_routiers_introVillage,mkr_routier_intro_village_dest)
end

function MonitorRoutiersIntro()
	
	if Prox_AreSquadsNearMarker(sg_routiers_introVillage,mkr_routier_intro_village_dest,ALL,20) == true then
		SGroup_DestroyAllSquads(sg_routiers_introVillage)
		Rule_RemoveMe()
	end
end

function Rebuildvillage()
	
	if EGroup_CountSpawned(eg_TC_town01) >= 1 then 

		Cmd_Ability(sg_player_villagers03, BP_GetAbilityBlueprint("villager_repair"), eg_TC_town01)
	end
	
	if EGroup_CountSpawned(eg_house_town01_burning) >= 1 then 
		Cmd_Ability(sg_player_villagers02, BP_GetAbilityBlueprint("villager_repair"), eg_house_town01_burning)
	end
	
	if EGroup_CountSpawned(	eg_house_town02_burning) >= 1 then 
		Cmd_Ability(sg_player_villagers, BP_GetAbilityBlueprint("villager_repair"), eg_house_town02_burning)
	end

	
	Rule_AddInterval(CheckRepairStatusTC,10)
	Rule_AddInterval(CheckRepairStatusHouse,12)

end

function CleanIntroSkipped()
	
	SGroup_DestroyAllSquads(sg_routiers_introVillage)
	SGroup_DestroyAllSquads(sg_player_army_sco)
	SGroup_DestroyAllSquads(sg_player_army_kni)
	SGroup_DestroyAllSquads(sg_player_army_maa)
	SGroup_DestroyAllSquads(sg_player_army_maa02)
	SGroup_DestroyAllSquads(sg_player_army_maa03)
	SGroup_DestroyAllSquads(sg_player_army_maa04)
	SGroup_DestroyAllSquads(sg_player_army_cbm)
	SGroup_DestroyAllSquads(sg_player_army_cbm02)
	SGroup_DestroyAllSquads(sg_player_army_cbm03)
	
	UnitEntry_DeploySquads(player1, sg_player_army_sco, {type = "scar_scout", numSquads = 2, tag = "player_army"}, mkr_player_army_scout_moveto )
	
	UnitEntry_DeploySquads(player1, sg_player_army_kni, {type = "scar_knight", numSquads = 2, tag = "player_army"}, mkr_player_army_knight_moveto )
	
	UnitEntry_DeploySquads(player1, sg_player_army_maa, {type = "scar_spearman", numSquads = 2, tag = "player_army"}, mkr_player_army_maa_moveto )
	
	UnitEntry_DeploySquads(player1, sg_player_army_maa02, {type = "scar_spearman", numSquads = 2, tag = "player_army"}, mkr_player_army_maa02_moveto )
	
	UnitEntry_DeploySquads(player1, sg_player_army_maa03, {type = "scar_spearman", numSquads = 2, tag = "player_army"}, mkr_player_army_maa03_moveto )
	
	UnitEntry_DeploySquads(player1, sg_player_army_maa04, {type = "scar_spearman", numSquads = 2, tag = "player_army"}, mkr_player_army_maa04_moveto )
	
	UnitEntry_DeploySquads(player1, sg_player_army_cbm, {type = "scar_archer", numSquads = 3, tag = "player_army"}, mkr_player_army_cbm_moveto )

	UnitEntry_DeploySquads(player1, sg_player_army_cbm02, {type = "scar_archer", numSquads = 3, tag = "player_army"}, mkr_player_army_cbm02_moveto )

	UnitEntry_DeploySquads(player1, sg_player_army_cbm03, {type = "scar_archer", numSquads = 3, tag = "player_army"}, mkr_player_army_cbm03_moveto )
	
end

function CheckRepairStatusTC()
	
	if EGroup_CountSpawned(eg_TC_town01) >= 1 then 
		if Entity_IsUnderRepair( EGroup_GetEntityAt( eg_TC_town01, 1 ) ) == false then
			if SGroup_IsIdle( sg_player_villagers03, ALL ) then
				Cmd_Move(sg_player_villagers03,mkr_routier_intro_village_spawn)
			--	AssignVillagersToWood(sg_player_villagers03)
			end
			Rule_RemoveMe()
		end
	end
end
	
function CheckRepairStatusHouse()
	
	local _SetOnRepair = function(gid,idx,eid)
		if Entity_IsUnderRepair( eid ) == false then
			EGroup_Remove( eg_house_town01_burning, eid)
		end
	end
	EGroup_ForEach(eg_house_town01_burning, _SetOnRepair)
	
	if EGroup_CountSpawned(eg_house_town01_burning) == 0 then 
		if SGroup_IsIdle( sg_player_villagers02, ALL ) then

		--	AssignVillagersToFarms(sg_player_villagers02)
			Cmd_Move(sg_player_villagers02,mkr_routier_intro_village_spawn)
		end
		Rule_RemoveMe()
	end
end


function CounterMonks()
	if Objective_IsComplete(SOBJ_CaptureCocherel) == false then 
		captureCount = captureCount or 1
		eg_target_holysites = EGroup_CreateIfNotFound("eg_target_holysites")
		EGroup_Duplicate(eg_holy_sites, eg_target_holysites)
		
		local _GetHolyTargets = function(gid, index, eid)
			if World_OwnsEntity(eid) ~= true then
				if Entity_GetPlayerOwner(eid) == player2 then
					EGroup_Remove(gid, eid)
				end
			end
		end
		EGroup_ForEach(eg_target_holysites, _GetHolyTargets)
		
		if EGroup_CountSpawned(eg_target_holysites) > 0 then
			local modName = ("monk_army_"..captureCount)
			local moduleData = 
			{
				type = "RovingArmy",
				descriptor = modName,
				player = player2,
				targetingType = ARMY_TARGETING_DISCARD,
				targets = {
					{ position = Util_GetPosition(EGroup_GetRandomSpawnedEntity(eg_target_holysites)), combatRange = 12, leashRange = 15},
					position = Util_GetPosition(EGroup_GetRandomSpawnedEntity(eg_target_holysites)),								
				},		
				spawnLocation = mkr_peasant_villagers_monastery_spawn,
				onDeathDissolve = true,
				units = 
				{
					{type = "scar_spearman", numSquads = 4},
					{type = "scar_manatarms", numSquads = 1},
					{type = "scar_monk", numSquads = 1},
				}
			}
			_G["Cocherel_Monks_"..captureCount] = RovingArmy_Init(moduleData)
			captureCount = captureCount+1
		end
	else
		Rule_RemoveMe()
	end
end

