function Monitor_PlayerFoundSecret()
	
	if Prox_ArePlayersNearMarker(player1, mkr_holysite_jouy, ANY, t_difficulty.findHolySite_NearbyDistance) and bliped_holysite_nearjouy == nil then 	
		bliped_holysite_nearjouy = UI_CreateMinimapBlip(mkr_holysite_jouy,12, "general")
	end
	
	if Prox_ArePlayersNearMarker(player1, mkr_holysite_mountain, ANY, t_difficulty.findHolySite_NearbyDistance) and bliped_holysite_mountain == nil then 	
		bliped_holysite_mountain = UI_CreateMinimapBlip(mkr_holysite_mountain,12, "general")
	end
	
	if Prox_ArePlayersNearMarker(player1, mkr_holysite_routier, ANY, t_difficulty.findHolySite_NearbyDistance) and bliped_holysite_nearroutiers == nil then 	
		bliped_holysite_nearroutiers = UI_CreateMinimapBlip(mkr_holysite_routier,12, "general")
	end
	
	if Prox_ArePlayersNearMarker(player1, mkr_relic_road, ANY, t_difficulty.findHolySite_NearbyDistance) and bliped_relic_road == nil then 	
		bliped_relic_road = UI_CreateMinimapBlip(mkr_relic_road,12, "general")
	end
	
	if bliped_holysite_nearjouy ~= nil and bliped_holysite_mountain ~= nil and bliped_holysite_nearroutiers ~= nil and bliped_relic_road == nil then
		Rule_RemoveMe()
	end
	
end

function CheckRoutierslooted()
	
	
	if EGroup_Count(eg_gold_Routiers) == 0 then
	
		-- Unlock Achievement
		Game_SendCustomChallengeEvent(player1, CE_ROUTIERSLOOTED, 1)
	
		Rule_RemoveMe()
	end
end
