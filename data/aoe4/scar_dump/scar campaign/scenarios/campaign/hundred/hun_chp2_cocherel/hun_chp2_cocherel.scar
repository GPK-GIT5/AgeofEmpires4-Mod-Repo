function FoundCocherelCamp()
	
		
	if Objective_IsStarted(SOBJ_CaptureCocherel) == false then
		Objective_Start(SOBJ_CaptureCocherel)
	end

end

function FoundRoutiersCamp()
	
	if Objective_IsStarted(OBJ_DefeatRoutiers) == false then
		Objective_Start(OBJ_DefeatRoutiers,true,true)
	
	end
	
	Util_StartIntel(EVENTS.DiscoverRoutierCamp)
	camp_routiers = HintPoint_Add(mkr_routier_village, true, "$11195395", LOCATION_LABEL_HEIGHT) --"Routiers' camp"

end


function FoundCroisyCamp()
	
	b_FoundCroisy = true
	Util_StartIntel(EVENTS.Croisy_GoldHint)

end


