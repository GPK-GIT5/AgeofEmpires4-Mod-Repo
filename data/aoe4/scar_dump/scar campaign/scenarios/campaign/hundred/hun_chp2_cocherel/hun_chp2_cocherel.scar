-- France in Chaos 1364
--
-- Hundred Years War - Mission 2
--


import("MissionOMatic/MissionOMatic.scar")	-- this imports the Cardinal scripts as well

import("obj_capture_frenchtowns.scar")
import("obj_kill_charlesarmy.scar")
import("obj_optional_killroutiers.scar")
import("obj_protect_monastery.scar")

import("diplomacy_chp2_cocherel.scar")


function Mission_OnGameSetup()

	player1 = World_GetPlayerAt(1) 
	player2 = World_GetPlayerAt(2) 
	player3 = World_GetPlayerAt(3)
	player4 = World_GetPlayerAt(4) 
	
	Setup_SetPlayerName(player1, "$11172129") -- Bertrand du Guesclin
	Setup_SetPlayerName(player2, "$11172130") -- Peasant Rebels
	Setup_SetPlayerName(player3, "$11172131") -- Routiers
	Setup_SetPlayerName(player4, "$11172132") -- Charles of Navarre
	
end

function Mission_SetupPlayers()
	

	Player_SetCurrentAge(player1, AGE_FEUDAL)
	Player_SetMaximumAge(player1, AGE_CASTLE)

	Player_SetCurrentAge(player2, AGE_FEUDAL)
	Player_SetMaximumAge(player2, AGE_CASTLE)
	
	Player_SetCurrentAge(player3, AGE_CASTLE)
	Player_SetMaximumAge(player3, AGE_CASTLE)
	
	Player_SetCurrentAge(player4, AGE_CASTLE)
	Player_SetMaximumAge(player4, AGE_CASTLE)

	-- set player relationships	
	Player_SetRelationship(player3, player4, R_ALLY)		-- make sure you set relationships both ways
	Player_SetRelationship(player4, player3, R_ALLY)

	-- set player colours 
	PlayerColour_Enable()
	
	Game_SetPlayerSlotColour(player1, 1) 		-- Player (1 = blue)
	Game_SetPlayerUISlotColour(player1, 1) 

	Game_SetPlayerSlotColour(player2, 2) 		-- Enemy french villagers (2 = red)    
	Game_SetPlayerUISlotColour(player2, 2) 
	
	Game_SetPlayerSlotColour(player3, 6)		-- Routiers (6 = purple)
	Game_SetPlayerUISlotColour(player3, 6)

	Game_SetPlayerSlotColour(player4, 8) 		-- Charles (8 = pink)
	Game_SetPlayerUISlotColour(player4, 8)
	
end



function Mission_PreInit()
	
end

