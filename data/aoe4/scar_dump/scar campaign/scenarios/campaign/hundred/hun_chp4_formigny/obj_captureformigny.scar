
function InitObjectives_CaptureFormigny()
	SOBJ_CaptureFormigny = {
		Title = "$11172296", --Capture Formigny 
		Type = ObjectiveType_Capture,
		Parent = OBJ_ClearNormandy,
		SetupUI = function()
			--hpid_captureFormigny = Objective_AddUIElements(SOBJ_CaptureFormigny, mkr_formigny_hintpoint, true,"$11172298", true, nil, nil, nil) --"Formigny"
		end,
		Intel_Start = EVENTS.FORMIGNY_CAPTURE,
		OnStart = function()
			print("SOBJ_CaptureFormigny STARTED - master")
			Location_SetCapturable(LocationFormigny, true)
			HintPoint_Remove(village_formigny)
			Music_UnlockIntensity()
			Music_LockIntensity(MUSIC_RARE, 30)
			Sound_SetMinimumMusicCombatIntensity(801, 0)
		end,
		OnComplete = function()
			print("SOBJ_CaptureFormigny COMPLETED - master")
			Objective_Complete(OBJ_ClearNormandy, false, false)
		end,
    }
	SOBJ_DefeatFormignyUnits = {
        Title = "$11172297", --Defeat the English occupiers
        Type = ObjectiveType_Capture,
        Parent = OBJ_ClearNormandy,
		OnStart = function()
			print("SOBJ_DefeatFormignyUnits STARTED - secondary")
		end,
		onComplete = function()
			print("SOBJ_DefeatFormignyUnits COMPLETED - secondary")
		end,
    }
    SOBJ_LocationFormigny = {
        Title = "$11172298", --Formigny
        Type = ObjectiveType_Capture,
        Parent = OBJ_ClearNormandy,
		onStart = function()
			print("SOBJ_LocationFormigny STARTED - capture")
		end,
		onComplete = function()
			print("SOBJ_LocationFormigny COMPLETED - capture")
		end,
    }
	
	OBJ_DebugComplete = {
        Title = LOC("Debug Complete"),
        Type = OT_Primary,
        showTitle = false,
        Cheat = function()
			Mission_Complete()
		end,
	}
    
    Objective_Register(SOBJ_CaptureFormigny)
    Objective_Register(SOBJ_DefeatFormignyUnits)
    Objective_Register(SOBJ_LocationFormigny)
	Objective_Register(OBJ_DebugComplete)	
    
	
	LocationFormigny.objectiveMaster = OBJ_ClearNormandy
    LocationFormigny.objectivePrimary = SOBJ_CaptureFormigny
    LocationFormigny.objectiveSecondary = SOBJ_DefeatFormignyUnits
    LocationFormigny.objectiveCapture = SOBJ_LocationFormigny
end

function CheckForFinalFight()
	if Prox_ArePlayersNearMarker(player1, mkr_formigny_defend_1, ANY) then
		Rule_RemoveMe()
		Defend_UpdateRange(formigny_defend_1, 200, 200)
	end
end
