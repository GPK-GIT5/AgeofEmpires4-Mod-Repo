function Xiangyang1273_WatchForBarbicanBypass(context, data)
	
	SGroup_Clear(sg_temp)
	Player_GetAllSquadsNearMarker(g_playerMongol, sg_temp, mkr_city_inclusion_2, Marker_GetProximityRadiusOrDefault(mkr_city_inclusion_2, 90))
	-- If the keep is still up and the player doesn't have units in the city, don't bother forcing the objective to complete yet
	if EGroup_Count(eg_xiangyang_keep) > 0 and SGroup_CountSpawned(sg_temp) <= 0 then
		return
	end
	
	-- If the player is doing those things, force that objective to end, to prevent soft-lock
	if Objective_IsComplete(SOBJ_RazeLandmark) == false then
		Objective_Complete(SOBJ_RazeLandmark, false, false)
		Rule_RemoveMe()
	end
	
	if Objective_IsComplete(SOBJ_DefeatGarrison) == false then
		Objective_Complete(SOBJ_DefeatGarrison, false, false)
		Rule_RemoveMe()
	end
	
end