--? @shortdesc Sets up the bridge to be destroyed before the player can cross it
function Xiangyang1273_BurnCentralBridge()
	if g_bridgeBurnt ~= true then
		EGroup_SetAvgHealth(eg_twin_city_bridge, 0.3)
		EGroup_SetOnFire(eg_twin_city_bridge)
		g_bridgeBurnt = true
		print("FALL OF XIANGYANG: Destroying Central Bridge")
		-- Start a function to handle the case where the player starts rebuilding the bridge before finishing the objective they're supposed to
		g_bridgeBurnTime = World_GetGameTime()
		Rule_AddInterval(Xiangyang1273_HandlePrematureBridgeConstruction, {delay = 20, interval = 0.5})
	end
end

function Xiangyang1273_BridgeReminder()
	if not Objective_IsComplete(SOBJ_CrossMoat) then
		if Obj_GetProgress(SOBJ_CrossMoat.ID) < 0.33 then
			
			if g_wallDestructionStung ~= true then
				-- if we haven't yet busted the Fancheng wall, we just show the bridge objective banner
				Objective_Show(SOBJ_CrossMoat, true, true)
				Sound_Play2D("sfx_ui_event_queue_campaign_objective_start")
			else
				-- if we have busted the wall, we play VO (event also plays the banner)
				Util_StartIntel(EVENTS.BridgeContext)
			end
		end
	end
end

