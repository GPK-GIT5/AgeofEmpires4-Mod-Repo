function Kiev_SpawnIntroUnits(spawn_at_destination)
	if b_hasSpawnedIntroUnits ~= true then
		local units = {}
		if spawn_at_destination == true then
			print("Spawning at destination")
			units = {
				{	type = "scar_scout", 		numSquads = 1, 	spawn = mkr_player_scout_1 },
				{	type = "scar_scout", 		numSquads = 1, 	spawn = mkr_player_scout_2 },
				{	type = "scar_ram",			numSquads = 1,	spawn = mkr_ram_destination },
				{	type = "scar_knight",		numSquads = 6,	spawn = mkr_player_start },
				{	type = "scar_horsearcher",	numSquads = 12,	spawn = mkr_player_start },
				{	type = "scar_spearman",		numSquads = 30,	spawn = mkr_player_start_2, sgroup = sg_intro_infantry },
				{	type = "scar_archer",		numSquads = 18,	spawn = mkr_player_start_2, sgroup = sg_intro_infantry },
				{	sbp = SBP.MONGOL.UNIT_MONGKE_KHAN_CMP_MON,	numSquads = 1,	spawn = mkr_khan_destination, sgroup = sg_leaderMongke.sgroup	},
				{	type = "scar_trebuchet_traction", 	numSquads = 1, 	spawn = mkr_player_arty_1, destination = mkr_player_arty_1 },
				{	type = "scar_trebuchet_traction", 	numSquads = 1, 	spawn = mkr_player_arty_2, destination = mkr_player_arty_2 },
			}
		else
			print("Spawning normally")
			units = {
				{	type = "scar_scout", 		numSquads = 1, 	spawn = mkr_intro_spawn_2,	destination = mkr_player_scout_1 },
				{	type = "scar_scout", 		numSquads = 1, 	spawn = mkr_intro_spawn_3,	destination = mkr_player_scout_2 },
				{	type = "scar_ram",			numSquads = 1,	spawn = mkr_player_villager_destination, destination = mkr_ram_destination },
				{	type = "scar_knight",		numSquads = 6,	spawn = mkr_intro_spawn_1,	destination = mkr_player_start },
				{	type = "scar_horsearcher",	numSquads = 12,	spawn = mkr_intro_spawn_1,	destination = mkr_player_start },
				{	type = "scar_spearman",		numSquads = 30,	spawn = mkr_intro_spawn_6,	destination = mkr_player_start_2, sgroup = sg_intro_infantry },
				{	type = "scar_archer",		numSquads = 18,	spawn = mkr_intro_spawn_6,	destination = mkr_player_start_2, sgroup = sg_intro_infantry },
				{	sbp = SBP.MONGOL.UNIT_MONGKE_KHAN_CMP_MON,	numSquads = 1,	spawn = mkr_khan_start,	destination = mkr_khan_destination, sgroup = sg_leaderMongke.sgroup	},
				{	type = "scar_trebuchet_traction", 	numSquads = 1, 	spawn = mkr_intro_spawn_4,	destination = mkr_player_arty_1	},
				{	type = "scar_trebuchet_traction", 	numSquads = 1, 	spawn = mkr_intro_spawn_5,	destination = mkr_player_arty_2	},
			}
		end
		
		SGroup_Clear(sg_temp)
		UnitEntry_DeploySquads(player1, sg_temp, units)		
		SGroup_EnableLeaderCrown(sg_leaderMongke.sgroup, false) --Disable the leader crown since we don't want to see it in the intro
		b_hasSpawnedIntroUnits = true
	end
end --Kiev_SpawnIntroUnits()
