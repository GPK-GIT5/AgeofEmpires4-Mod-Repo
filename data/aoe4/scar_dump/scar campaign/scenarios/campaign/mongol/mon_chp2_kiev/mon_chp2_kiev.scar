	--Rule_AddInterval(Kiev_ProximitySpawnVillagerLife, 1, {villageModule = "villagerlife_sprawl_1_attack", 	range = 60, villagers = {roaming = 8, wood = 3}})
	--Rule_AddInterval(Kiev_ProximitySpawnVillagerLife, 1, {villageModule = "villagerlife_sprawl_2_attack", 	range = 60, villagers = {roaming = 8, wood = 3}})
	--Rule_AddInterval(Kiev_ProximitySpawnVillagerLife, 1, {villageModule = "villagerlife_out_1_flee", 		range = 60, villagers = {roaming = 8}})
