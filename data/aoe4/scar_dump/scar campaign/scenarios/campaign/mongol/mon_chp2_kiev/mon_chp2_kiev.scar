--
--
-- Siege of Kiev 1240
--
-- The Mongol Horde, Mission 4
--

import("MissionOMatic/MissionOMatic.scar") -- this imports the Cardinal scripts as well
import("obj_destroygate.scar")
import("obj_forwardbase.scar")
import("obj_destroykiev.scar")

--Training
import("training_kiev.scar")

function Mission_SetupPlayers()
	
	-- Get player IDs for each player
	player1 = World_GetPlayerAt(1)
	player2 = World_GetPlayerAt(2)
	player3 = World_GetPlayerAt(3)
	player4 = World_GetPlayerAt(4)
	
	-- player 1 - Player (Mongols)
	Setup_SetPlayerName(player1, "$11176020") -- Mongke Khan
	Player_SetCurrentAge(player1, AGE_FEUDAL)
	Player_SetMaximumAge(player1, AGE_CASTLE)
	
	-- player 2 - Kiev (Rus)
	Setup_SetPlayerName(player2, "$11176021") -- Kiev
	Player_SetCurrentAge(player2, AGE_CASTLE)
	Player_SetMaximumAge(player2, AGE_CASTLE)
	
	-- player 3 - Neutral Hero Holder
	Setup_SetPlayerName(player3, "$11176020") -- Mongke Khan
	Player_SetCurrentAge(player3, AGE_FEUDAL)
	Player_SetMaximumAge(player3, AGE_CASTLE)
	
	--player 4 - Kiev Trading Partner (Rus)
	Setup_SetPlayerName(player4, "$11176021") -- Kiev
	Player_SetCurrentAge(player4, AGE_CASTLE)
	Player_SetMaximumAge(player4, AGE_CASTLE)
	
	--Mongol Team
	Player_SetRelationship(player1, player3, R_ALLY)
	Player_SetRelationship(player3, player1, R_ALLY)
	
	--Rus Team
	Player_SetRelationship(player2, player4, R_ALLY)
	Player_SetRelationship(player4, player2, R_ALLY)
	
	Player_SetRelationship(player2, player3, R_NEUTRAL)
	Player_SetRelationship(player4, player3, R_NEUTRAL)
	Player_SetRelationship(player3, player2, R_NEUTRAL)
	Player_SetRelationship(player3, player4, R_NEUTRAL)
	
	--
	-- Set Player Colours
	--
	
	PlayerColour_Enable()								--Turn on custom colour configuration for this session
	
	Game_SetPlayerSlotColour(player1, 1)			--Paint Scheme
	Game_SetPlayerUISlotColour(player1, 1)		--UI Colour
	
	Game_SetPlayerSlotColour(player2, 2)			--Paint Scheme
	Game_SetPlayerUISlotColour(player2, 2)		--UI Colour
	
	Game_SetPlayerSlotColour(player3, 1)	--Paint Scheme
	Game_SetPlayerUISlotColour(player3, 1)--UI Colour
	
	Game_SetPlayerSlotColour(player4, 2)			--Paint Scheme
	Game_SetPlayerUISlotColour(player4, 2)		--UI Colour
	
end -- Mission_SetupPlayers()

function Mission_SetupVariables()
	
	--OBJECTIVES
	DestroyGate_InitObjectives()
	ForwardBase_InitObjectives()
	DestroyKiev_InitObjectives()
	
	-- EGROUPS
	eg_playerBuildings = EGroup_CreateIfNotFound("eg_playerBuildings")
	eg_main_gate = EGroup_CreateIfNotFound("eg_main_gate")
	eg_industrial_gate = EGroup_CreateIfNotFound("eg_industrial_gate")
	eg_outer_gate = EGroup_CreateIfNotFound("eg_outer_gate")
	eg_inner_gate = EGroup_CreateIfNotFound("eg_inner_gate")
	
	eg_inner_walls = EGroup_CreateIfNotFound("eg_inner_walls")
	eg_outer_walls = EGroup_CreateIfNotFound("eg_outer_walls")
	
	-- SGROUPS
	
	sg_intro_infantry = SGroup_CreateIfNotFound("sg_intro_infantry")
	
	sg_player_scout_1 = SGroup_CreateIfNotFound("sg_player_scout_1")
	sg_player_scout_2 = SGroup_CreateIfNotFound("sg_player_scout_2")
	sg_player_cav = SGroup_CreateIfNotFound("sg_player_cav")
	sg_player_inf = SGroup_CreateIfNotFound("sg_player_inf")
	sg_playerBuildings = SGroup_CreateIfNotFound("sg_playerBuildings")
	
	sg_kiev_inner_defend = SGroup_CreateIfNotFound("sg_kiev_inner_defend")
	sg_main_gate_defenders = SGroup_CreateIfNotFound("sg_main_gate_defenders")
	sg_industrial_gate_defenders = SGroup_CreateIfNotFound("sg_industrial_gate_defenders")
	sg_outer_gate_defenders = SGroup_CreateIfNotFound("sg_outer_gate_defenders")
	sg_inner_gate_defenders = SGroup_CreateIfNotFound("sg_inner_gate_defenders")
	
	sg_villagers_01 = SGroup_CreateIfNotFound("sg_villagers_01")
	sg_villagers_02 = SGroup_CreateIfNotFound("sg_villagers_02")
	sg_villagers_03 = SGroup_CreateIfNotFound("sg_villagers_03")
	sg_villagers_04 = SGroup_CreateIfNotFound("sg_villagers_04")
	sg_villagers_05 = SGroup_CreateIfNotFound("sg_villagers_05")
	
	sg_market_traders_1 = SGroup_CreateIfNotFound("sg_market_traders_1")
	sg_market_traders_2 = SGroup_CreateIfNotFound("sg_market_traders_2")
	
	sg_patrol_units_count = SGroup_CreateIfNotFound("sg_patrol_units_count")
	
	-- VARIABLES
	GATE_MAIN = 1
	GATE_INDUSTRIAL = 2
	GATE_OUTER = 3
	GATE_INNER = 4
	
	attack_wave = 1
	
	remainingSpawns = {}
	
	remainingSpawns[GATE_MAIN] = 3
	remainingSpawns[GATE_INDUSTRIAL] = 3
	remainingSpawns[GATE_OUTER] = 3
	remainingSpawns[GATE_INNER] = 3
	
	destroyedGate = {}
	
	destroyedGate[GATE_MAIN] = false
	destroyedGate[GATE_INDUSTRIAL] = false
	destroyedGate[GATE_OUTER] = false
	destroyedGate[GATE_INNER] = false
	
	-- LEADERS
	sg_leaderMongke = Missionomatic_InitializeLeader({
		name = 11165064, -- Mongke Khan
		owner = player1,
		neutralHolder = player3,
	})
	
	
end -- Mission_SetupVariables()

function Mission_SetDifficulty()
	
	t_difficulty = {
		forts_have_springalds = Util_DifVar({false, false, true, true}),
		forts_have_garrisons = Util_DifVar({false, true, true, true}),
		spawn_attack_waves = Util_DifVar({false, true, true, true}),
		defender_count_high = Util_DifVar({6, 8, 12, 16}),
		defender_count_med = Util_DifVar({3, 4, 6, 8}),
		defender_count_low = Util_DifVar({2, 2, 3, 5}),
		defender_count_very_low = Util_DifVar({1, 1, 2, 3}),
		main_attack_interval = Util_DifVar({360, 360, 300, 180}),
	}
	
	-- UNIT TEMPLATES
	sprawl_defenders = {
		{ type = "scar_spearman", numSquads = t_difficulty.defender_count_med },
		{ type = "scar_archer", numSquads = t_difficulty.defender_count_low },
	}
	
 end

function Mission_SetRestrictions()

	----Player 1
	Player_SetSquadProductionAvailability(player1, SBP.MONGOL.UNIT_TREBUCHET_4_CW_MON, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.MONGOL.UNIT_TREBUCHET_4_CW_DOUBLE_MON, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.MONGOL.UNIT_TREBUCHET_4_CW_FIELD_CONSTRUCT_MON, ITEM_REMOVED)
	
	Player_SetSquadProductionAvailability(player1, SBP.MONGOL.UNIT_TREBUCHET_4_TR_MON, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.MONGOL.UNIT_TREBUCHET_4_TR_DOUBLE_MON, ITEM_REMOVED)
	Player_SetSquadProductionAvailability(player1, SBP.MONGOL.UNIT_TREBUCHET_4_TR_FIELD_CONSTRUCT_MON, ITEM_REMOVED)
	
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_TECH_UNIVERSITY_MURDER_HOLES_4, ITEM_REMOVED)
	
	----Player 2
	Player_SetEntityProductionAvailability(player2, EBP.RUS.BUILDING_LANDMARK_AGE1_GOLDEN_GATE_VLADIMIR_CONTROL_RUS, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player2, EBP.RUS.BUILDING_LANDMARK_AGE1_NOVGOROD_KREMLIN_CONTROL_RUS, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player2, EBP.RUS.BUILDING_LANDMARK_AGE2_MUSCOVY_TRADE_COMPANY_CONTROL_RUS, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player2, EBP.RUS.BUILDING_LANDMARK_AGE2_TRINITY_LAVRA_CONTROL_RUS, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player2, EBP.RUS.BUILDING_LANDMARK_AGE3_KREMLIN_ARMOURY_RUS, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player2, EBP.RUS.BUILDING_LANDMARK_AGE3_SPASSAKAYA_TOWER_CONTROL_RUS, ITEM_REMOVED)
	
	PlayerUpgrades_Auto(player1, true)
	PlayerUpgrades_Auto(player2)

	if t_difficulty.forts_have_springalds then
		Cmd_Upgrade(eg_gate_forts, UPG.RUS.UPGRADE_WOODEN_CASTLE_SPRINGALD_RUS, 1, true)
	end

	UI_SetPlayerDataContext(player1, {PopulationCapOn = false})
	
end




function Mission_Preset()
	
	--Set up references to each gate
	Player_GetAllEntitiesNearMarker(player2, eg_main_gate, mkr_main_gate)
	EGroup_Filter(eg_main_gate, EBP.RUS.BUILDING_DEFENSE_WALL_GATE_RUS, FILTER_KEEP)
	Player_GetAllEntitiesNearMarker(player2, eg_industrial_gate, mkr_industrial_gate)
	EGroup_Filter(eg_industrial_gate, EBP.RUS.BUILDING_DEFENSE_WALL_GATE_RUS, FILTER_KEEP)
	Player_GetAllEntitiesNearMarker(player2, eg_outer_gate, mkr_outer_gate)
	EGroup_Filter(eg_outer_gate, EBP.RUS.BUILDING_DEFENSE_WALL_GATE_RUS, FILTER_KEEP)
	Player_GetAllEntitiesNearMarker(player2, eg_inner_gate, mkr_inner_gate)
	EGroup_Filter(eg_inner_gate, EBP.RUS.BUILDING_DEFENSE_WALL_GATE_RUS, FILTER_KEEP)
	
	Player_GetAllEntitiesNearMarker(player2, eg_inner_walls, mkr_inner_walls)
	EGroup_Filter(eg_inner_walls, "wall", FILTER_KEEP)
	Player_GetAllEntitiesNearMarker(player2, eg_outer_walls, mkr_outer_walls)
	EGroup_Filter(eg_outer_walls, "wall", FILTER_KEEP)
	
	--Wall Group
	wall_count_main = EGroup_CountSpawned(eg_main_gate_wall)
	wall_count_industrial = EGroup_CountSpawned(eg_industrial_wall)
	wall_count_shared_walls = EGroup_CountSpawned(eg_city_walls)
	wall_count_outer_walls = EGroup_CountSpawned(eg_outer_walls)
	wall_count_inner_walls = EGroup_CountSpawned(eg_inner_walls)
	
	--Weakening enemy buildings because winter cold and there are a lot of buildings to destroy in this mission
	Kiev_WeakenStructures()
	
	--Global Events
	--Rule_AddGlobalEvent(DestroyGate_EntityKilled, GE_EntityKilled) --Disabled for conversion into count checker instead
	--Rule_AddGlobalEvent(Kiev_StructureFireSpread, GE_EntityKilled) --Disabled fire spreading as burning is getting simplified later on
	Rule_AddInterval(Kiev_GateTracking, 0.5, {
			egroup = eg_industrial_wall, 
			compared_amount = wall_count_industrial,
			walla_marker = mkr_industrial_gate,
			function_callback = Kiev_SpawnIndustrialDistrictUnits,
			gate = GATE_INDUSTRIAL})
	Rule_AddInterval(Kiev_GateTracking, 0.5, {
			egroup = eg_outer_walls, 
			compared_amount = wall_count_outer_walls,
			walla_marker = mkr_outer_gate,
			function_callback = Kiev_SpawnOuterDistrictUnits,
			gate = GATE_OUTER})
	Rule_AddInterval(Kiev_GateTracking, 0.5, {
			egroup = eg_inner_walls, 
			compared_amount = wall_count_inner_walls,
			walla_marker = mkr_inner_gate,
			function_callback = Kiev_SpawnInnerDistrictUnits,
			gate = GATE_INNER})
	
	Player_SetStateModelBool(Game_GetLocalPlayer(), "khan_spawning_disabled", true)
	Action_SetResources_Do({player = player1, resources = {food = 0, wood = 0, gold = 0, stone = 0}})
	Action_SetResources_Do({player = player2, resources = {food = 10000, wood = 10000, gold = 10000, stone = 10000}})
	
	--Intro Spawning
	Rule_AddOneShot(Kiev_SpawnIntroUnits, 10)
	TrackTradeCartsForPlayers({player2, player4})
	Kiev_SpawnTraders(2, 16)
	Rule_AddGlobalEvent(Kiev_CheckTraderKilled, GE_SquadKilled)
	
	-- Audio considerations
	if Music_UnlockIntensity then
		Sound_SetForceMusic(false)
	else
		Sound_SetForceMusic(true)
	end
	
	--Set up building tracking for atmosphere adjustments to make things SMOKEY
	Player_GetAll(player2)
	enemy_initial_building_amount = EGroup_CountSpawned(eg_allentities)
	Rule_AddInterval(Kiev_UpdateBurningAtmospherics, 5)
	
end -- Mission_Preset()

function Mission_Start()
	
	Objective_Start(OBJ_DestroyGate)
	
	--Filter out any entities that may have been inadvertantly added to the egroup
	local entity_list = { 
		EBP.RUS.BUILDING_DEFENSE_WALL_RUS, 
		EBP.RUS.BUILDING_DEFENSE_WALL_BASTION_RUS, 
		EBP.RUS.BUILDING_RESOURCE_FARM_CONTROL_RUS }
	EGroup_Filter(eg_kiev_industrial, entity_list, FILTER_REMOVE)
	EGroup_Filter(eg_kiev_outer, entity_list, FILTER_REMOVE)
	EGroup_Filter(eg_kiev_inner, entity_list, FILTER_REMOVE)
	
	if t_difficulty.forts_have_garrisons then
		SpawnGarrisonsIntoEGroup(eg_gate_forts, player2)
	end
	
	--Rule_AddInterval(Kiev_ProximitySpawnVillagerLife, 1, {villageModule = "villagerlife_industry_1_flee", 	range = 60, villagers = {roaming = 12}})
