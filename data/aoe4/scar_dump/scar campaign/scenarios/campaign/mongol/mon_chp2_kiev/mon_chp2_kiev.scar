------------------------------------------------------------------------------------------------------------------------------
--													GATE DEFENDER SPAWNING CODE
------------------------------------------------------------------------------------------------------------------------------


--Checks if any structures within the gate marker has taken damage and activates resistance if there is any
function Kiev_CheckGateDamage(context, data)
	Player_GetAllEntitiesNearMarker(player2, eg_temp, data.marker)
	
	if EGroup_IsUnderAttack(eg_temp, ANY, 2) then
		--Prefab_DoAction(MissionOMatic_FindModule(data.module), "UpdateRange", 80, 100)
		--FOW_PlayerRevealArea(player2, Marker_GetPosition(data.marker), 80, -1)
		--FOW_PlayerRevealArea(player1, Marker_GetPosition(data.marker), 80, -1)
		
		--Set a new target for the module
		local module = MissionOMatic_FindModule(data.module)
		RovingArmy_SetTargets(module, data.targets)
		Rule_AddInterval(Kiev_CheckDefenderStatus, 1, data)
		
		Rule_RemoveMe()
	end
end

--Checks to see if the defenders are below the required reinforcement threshold
function Kiev_CheckDefenderStatus(context, data)
	
	--Duplicate the sgroup so we can do some filters and checks on it
	SGroup_Duplicate(Prefab_DoAction(MissionOMatic_FindModule(data.module), "GetSGroup"), sg_temp)
	SGroup_Filter(sg_temp, {"scar_spearman", "scar_manatarms"}, FILTER_KEEP)
	
	--Checking if there are less than 3 melee units and we can spawn more
	if SGroup_CountSpawned(sg_temp) <= 3 and remainingSpawns[data.gate] > 0 then
		
		--If the gate is not destroyed, spawn the new set of defenders 15 seconds from now, else don't spawn and stop checking
		if not destroyedGate[data.gate] then
			Rule_AddOneShot(Kiev_SpawnResistance, data.delay, data) --Spawn new wave after small delay
		end
		
		Rule_RemoveMe()
	end
	
end

--Spawns reinforcements to the defend module if there are reinforcements remaining
function Kiev_SpawnResistance(context, data)
	
	--Now that this is starting to run 15 seconds later, check to make sure the gate hasn't been destroyed during that period
	if not destroyedGate[data.gate] then
		local units = {
			{type = "scar_spearman", numSquads = t_difficulty.defender_count_high},
			{type = "scar_archer", numSquads = t_difficulty.defender_count_med}}
		
		SpawnUnitsToModule(units, data.module, data.spawn)
		remainingSpawns[data.gate] = remainingSpawns[data.gate] - 1
		
		--Reset the resistance loop back to checking the defenders status, as long as there are remaining spawns
		if remainingSpawns[data.gate] > 0 then
			Rule_AddInterval(Kiev_CheckDefenderStatus, 1, data) --Return to checking defender's status
		end
		
	end
	
end

function Kiev_SpawnTraders(trader_amount, spawn_delay)
	-- For traders starting in the Outer City
	local _unit_outer = {{type = "scar_trade_cart", numSquads = trader_amount, creator = eg_outer_market}}
	local outer_options = {
		onSpawnCallback = Kiev_StartTrading,
		target_market = eg_trade_market,
	}
	UnitEntry_DeploySquads(player2, sg_market_traders_1, _unit_outer, mkr_trade_1, nil, (spawn_delay + 4), outer_options)
	
	-- For traders starting in the Industrial District
	local _unit_market = {{type = "scar_trade_cart", numSquads = trader_amount, creator = eg_trade_market}}
	local market_options = {
		onSpawnCallback = Kiev_StartTrading,
		target_market = eg_outer_market,
	}
	UnitEntry_DeploySquads(player4, sg_market_traders_2, _unit_market, mkr_trade_2, nil, spawn_delay, market_options)
end

function Kiev_StartTrading(unit, deployment)
	SGroup_Single(sg_single, unit.squadID)
	LocalCommand_SquadEntity(deployment.player, sg_single, SCMD_Trade, deployment.options.target_market, false)
end

--Gate / Wall breach tracking for unit spawning and other variables
--data.egroup, data.compared_amount, data.walla_marker, data.function_callback
function Kiev_GateTracking(context, data)
	
	if EGroup_CountSpawned(data.egroup) < data.compared_amount then
		
		--Play Walla on units near the gate
		Music_PlayStinger(MUS_STING_TRIUMPHANT)
		
		Player_GetAllSquadsNearMarker(player1, sg_temp, data.walla_marker, 80)
		Sound_PlayWallaChargeOnSGroup(sg_temp)
		
		if SGroup_ContainsSGroup(sg_temp, sg_leaderMongke.sgroup, ANY) then
			Rule_AddOneShot(MongkeCall, 1, {marker = data.walla_marker})
			print ("KIEV - MongkeCall triggered")
		end
		SGroup_Clear(sg_temp)
		--Spawn defenders inside of the module that the wall was protecting
		data.function_callback()
		
		--Set the variable for the gate, which is tracked in the defender spawning script as to whether to keep spawning units
		destroyedGate[data.gate] = true
		
		Rule_RemoveMe()
	end
	
end

function MongkeCall(context, data)
	
	local calls = {
		{
			marker = mkr_industrial_gate,
			call = "Campaign_Speech/leaders/mon/mongke/mongol_mongke_mon_chp2_kiev_iHigh_cMed_04",
		},
		{
			marker = mkr_outer_gate,
			call = "Campaign_Speech/leaders/mon/mongke/mongol_mongke_mon_chp2_kiev_iHigh_cMed_03_ALT01",
		},
		{
			marker = mkr_inner_gate,
			call = "Campaign_Speech/leaders/mon/mongke/mongol_mongke_mon_chp2_kiev_iHigh_cMed_05",
		},
	}
	
	for k,v in pairs (calls) do
		if v.marker == data.marker then
			SGroup_PlaySpeech(sg_leaderMongke.sgroup, v.call)
			print ("KIEV - MongkeCall played ".. v.call)
			break
		end
	end
end

