--Gate Defenders
function Kiev_SpawnFirstGateDefenders()
	
	--Spawns the defenders for the gate defend modules first accessed within the city
	local industrialGateUnits = {
		{type = "scar_spearman", numSquads = t_difficulty.defender_count_high},
		{type = "scar_archer", numSquads = t_difficulty.defender_count_med},
		{type = "scar_springald", numSquads = t_difficulty.defender_count_very_low}
	}
	
	local outerGateUnits = {
		{type = "scar_spearman", numSquads = t_difficulty.defender_count_high},
		{type = "scar_archer", numSquads = t_difficulty.defender_count_med}
	}
	
	SpawnUnitsToModule(industrialGateUnits, "industrial_gate_defend", mkr_industrial_gate_spawn)
	SpawnUnitsToModule(outerGateUnits, "outer_gate_defend", mkr_outer_gate_spawn)
	
end

--Sprawl Defenders
function Kiev_SetupSprawlProxChecking()
	Rule_AddInterval(Kiev_SprawlProxCheck, 1, {marker = mkr_sprawl_prox_1, starting_amount = 1, ending_amount = 2})
	Rule_AddInterval(Kiev_SprawlProxCheck, 1, {marker = mkr_sprawl_prox_2, starting_amount = 3, ending_amount = 5})
	Rule_AddInterval(Kiev_SprawlProxCheck, 1, {marker = mkr_sprawl_prox_3, starting_amount = 6, ending_amount = 7})
	Rule_AddInterval(Kiev_SprawlProxCheck, 1, {marker = mkr_sprawl_prox_4, starting_amount = 8, ending_amount = 9})
	Rule_AddInterval(Kiev_SprawlProxCheck, 1, {marker = mkr_sprawl_prox_5, starting_amount = 10, ending_amount = 11})
	Rule_AddInterval(Kiev_SprawlProxCheck, 1, {marker = mkr_sprawl_prox_6, starting_amount = 12, ending_amount = 13})
	Rule_AddInterval(Kiev_SprawlProxCheck, 1, {marker = mkr_sprawl_prox_7, starting_amount = 14, ending_amount = 16})
	
	Kiev_SpawnOuterDistrictWallDefenders()
end

function Kiev_SprawlProxCheck(context, data)
	Player_GetAllSquadsNearMarker(player1, sg_temp, data.marker)
	if SGroup_CountSpawned(sg_temp) > 0 then
		
		for i = data.starting_amount, data.ending_amount, 1 do
			local _marker = Marker_FromName("mkr_sprawl_defend_"..tostring(i), "")
			local moduleData = {
				type = "RovingArmy",
				descriptor = "sprawl_def_"..tostring(i),
				player = player2,
				targets = { _marker },
				spawnLocation = _marker,
				units = sprawl_defenders,
				onDeathDissolve = true,
			}
			
			RovingArmy_Init(moduleData)
		end
		
		Rule_RemoveMe()
	end
	
	SGroup_Clear(sg_temp)
end

--Market District
function Kiev_SpawnIndustrialDistrictUnits()
	
	SpawnUnitsToModule({
			{type = "scar_spearman", numSquads = t_difficulty.defender_count_med},
			{type = "scar_archer", numSquads = t_difficulty.defender_count_low},
			{type = "scar_springald", numSquads = t_difficulty.defender_count_very_low}}, "defend_ind_01", mkr_defend_ind_01)
	
	SpawnUnitsToModule({
			{type = "scar_manatarms", numSquads = t_difficulty.defender_count_med},
			{type = "scar_archer", numSquads = t_difficulty.defender_count_low},
			{type = "scar_springald", numSquads = t_difficulty.defender_count_very_low}}, "defend_ind_02", mkr_defend_ind_02)
		
	Util_AutoSave()
end

--Outer City
function Kiev_SpawnOuterDistrictUnits()

	if Player_CanSeePosition(player1, Marker_GetPosition(mkr_defend_out_01)) == false then
		SpawnUnitsToModule({
			{type = "scar_horseman", numSquads = 6},
			{type = "scar_horsearcher", numSquads = 4}}, "defend_out_01", mkr_defend_out_01)
	end
	
	if Player_CanSeePosition(player1, Marker_GetPosition(mkr_defend_out_02)) == false then
		SpawnUnitsToModule({
			{type = "scar_spearman", numSquads = 6},
			{type = "scar_horsearcher", numSquads = 4},
			{type = "scar_horseman", numSquads = t_difficulty.defender_count_high}}, "defend_out_02", mkr_defend_out_02)
	end
	
	if Player_CanSeePosition(player1, Marker_GetPosition(mkr_defend_out_03)) == false then
		SpawnUnitsToModule({
			{type = "scar_horseman", numSquads = 6},
			{type = "scar_horsearcher", numSquads = 8},
			{type = "scar_crossbowman", numSquads = t_difficulty.defender_count_med}}, "defend_out_03", mkr_defend_out_03)
	end
	
	if Player_CanSeePosition(player1, Marker_GetPosition(mkr_defend_out_04)) == false then
		SpawnUnitsToModule({
			{type = "scar_horseman", numSquads = 6},
			{type = "scar_horsearcher", numSquads = 4}}, "defend_out_04", mkr_defend_out_04)
	end
	
	if Player_CanSeePosition(player1, Marker_GetPosition(mkr_defend_out_05)) == false then
		SpawnUnitsToModule({
			{type = "scar_horseman", numSquads = 12},
			{type = "scar_manatarms", numSquads = 6},
			{type = "scar_archer", numSquads = t_difficulty.defender_count_low}}, "defend_out_05", mkr_defend_out_05)
	end
	
	if Player_CanSeePosition(player1, Marker_GetPosition(mkr_inner_gate_spawn)) == false then
		SpawnUnitsToModule({
			{type = "scar_manatarms", numSquads = 12},
			{type = "scar_crossbowman", numSquads = 6}}, "inner_gate_defend", mkr_inner_gate_spawn)
	end
	--Also set the minimum music level to tense now that the outer district is breached
	Sound_SetMinimumMusicCombatIntensity(801, 0)
	
	-- Spawn the wall defenders for the inner district here, since the player will be fighting them around this time anyways
	Kiev_SpawnInnerDistrictWallDefenders() 

	Util_AutoSave()
end

function Kiev_SpawnOuterDistrictWallDefenders()
	for i = 1, 2, 1 do
		local _marker = Marker_FromName("mkr_outer_wall_defend_"..tostring(i), "")
		if Player_CanSeePosition(player1, Marker_GetPosition(_marker)) == false then
			local moduleData = {
				type = "RovingArmy",
				descriptor = "outer_wall_def_"..tostring(i),
				player = player2,
				targets = { _marker },
				spawnLocation = _marker,
				units = {{type = "scar_archer", numSquads = 5}},
			onDeathDissolve = true}
			RovingArmy_Init(moduleData)
		end
	end
end

--Inner City
function Kiev_SpawnInnerDistrictUnits()

	local units_type1 = {
		{type = "scar_manatarms", numSquads = Util_DifVar({5, 6, 6, 6})},
		{type = "scar_crossbowman", numSquads = Util_DifVar({2, 4, 4, 4})},
		{type = "scar_monk", numSquads = t_difficulty.defender_count_very_low}
	}
	
	local units_type2 = {
		{type = "scar_manatarms", numSquads = Util_DifVar({5, 6, 6, 6})},
		{type = "scar_crossbowman", numSquads = Util_DifVar({2, 4, 4, 4})},
		{type = "scar_knight", numSquads = t_difficulty.defender_count_med},
		{type = "scar_monk", numSquads = t_difficulty.defender_count_very_low}
	}
	
	local units_type3 = {
		{type = "scar_manatarms", numSquads = Util_DifVar({4, 5, 5, 5})},
		{type = "scar_crossbowman", numSquads = Util_DifVar({4, 5, 5, 5})}
	}
	
	local spawn_iterator = function(min, max, _units)
		for i = min, max, 1 do
			local _marker = Marker_FromName("mkr_defend_in_"..tostring(i), "")
			if Player_CanSeePosition(player1, Marker_GetPosition(_marker)) == false then
				local moduleData = {
					type = "RovingArmy",
					descriptor = "defend_in_"..tostring(i),
					player = player2,
					targets = { _marker },
					spawnLocation = _marker,
					units = _units,
				onDeathDissolve = true}
				
				RovingArmy_Init(moduleData)
			end
		end
	end
	
	spawn_iterator(1, 2, units_type1)
	spawn_iterator(3, 3, units_type2)
	spawn_iterator(4, 5, units_type1)
	spawn_iterator(6, 7, units_type3)
	
	Util_AutoSave()
end

function Kiev_SpawnInnerDistrictWallDefenders()
	for i = 1, 4, 1 do
		local _marker = Marker_FromName("mkr_inner_wall_defend_"..tostring(i), "")
		if Player_CanSeePosition(player1, Marker_GetPosition(_marker)) == false then
			local moduleData = {
				type = "RovingArmy",
				descriptor = "inner_wall_def_"..tostring(i),
				player = player2,
				targets = { _marker },
				spawnLocation = _marker,
				units = { 
					{type = "scar_crossbowman", numSquads = Util_DifVar({4, 5, 5, 5})} 
				},
			onDeathDissolve = true}
			
			RovingArmy_Init(moduleData)
		end
	end
end

