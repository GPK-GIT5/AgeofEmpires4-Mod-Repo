function Kiev_WaitForLeaderHint()
	if Objective_IsComplete(OBJ_ForwardBase) then
		
		if UI_IsXboxControllerUI() then
			Kiev_InitializeLeaderTrainingHints_Xbox()
		else
			Kiev_InitializeLeaderTrainingHints()
		end
		
		Rule_RemoveMe()
	end
end

------------------------------------------------------------------------------------------------------------------------------
--												FIRE PROPAGATION & ATMOSPHERICS
------------------------------------------------------------------------------------------------------------------------------


--Called via Rule_AddInterval(), checks to see if a building is on fire, and spreads it to every member of the group
function Kiev_CheckGroupsForFire(context, data)
	
	local _setFire = function(gid, idx, eid)
		Entity_SetOnFire(eid)
	end
	
	if data.egroup ~= nil then
		if EGroup_IsBurning(data.egroup, ANY) then
			EGroup_ForEach(data.egroup, _setFire)
			Rule_RemoveMe()
		end
	else
		print("One of the groups we are checking for fire spreading is now nil")
		Rule_RemoveMe()
	end
	
end

--Occurs on an GE_EntityDestroyed event. Checks the area around the destroyed structure for viable structures to ignite
function Kiev_StructureFireSpread(context, data)
	
	if context.victim ~= nil then

		if Entity_IsBurning(context.victim) then
			Player_GetAllEntitiesNearMarker(player2, eg_temp, Entity_GetPosition(context.victim), 16)
			EGroup_ForEach(eg_temp, Kiev_IgniteEGroup)
		end
	end
	
end

function Kiev_IgniteEGroup(gid, idx, eid)

	if not Entity_IsBurning(eid) then -- Is the entity not burning?
		if not Entity_IsOfType(eid, "defensive_structure") then -- Is the entity not a defensive structure? (Outpost)

			--Set the entity on fire
			--Entity_DoBurnDamage(eid, 10, true)
			Entity_SetOnFire(eid)
			
			--Do some slight damage to each structure to make the collapse a bit more randomized
			local entHP = Entity_GetHealthPercentage(eid)
			entHP = entHP - (World_GetRand(1, 10) / 100)
			if entHP < 0 then entHP = 0 end
			Entity_SetHealth(eid, entHP)
			
			--Award the player with raiding resources if they have Deer Stones active -- BUG: CURRENTLY ALWAYS GIVES 100.0!
			Player_AddResources(player1, {
					food = Player_GetStateModelFloat(player1, "raid_bounty_food_mon"),
					wood = Player_GetStateModelFloat(player1, "raid_bounty_wood_mon"),
					gold = Player_GetStateModelFloat(player1, "raid_bounty_gold_mon")
				}) 
			
			--Add an upgrade to the structure so the player can't receive a raiding bonus a second time
			Entity_CompleteUpgrade(eid, UPG.MONGOL.UPGRADE_BURN_BUILDING_BONUS_COOLDOWN_MON)
			
		end
	else
		--Entity is already burning, so let's do a bit of chain-reaction damage to it
		local entity_hp = Entity_GetHealthPercentage(eid)
		local explosion_damage = World_GetRand(15, 35) / 100
		if entity_hp - explosion_damage > 0 then
			Entity_SetHealth(eid, entity_hp - explosion_damage)
		else
			Entity_Kill(eid)
		end
	end

	Modifier_ApplyToEntity()
end

--Weakens enemy non-military structures so they are easier to kill
function Kiev_WeakenStructures()
	local modHealth = Modifier_Create(MAT_Entity, "health_maximum_modifier", MUT_Multiplication, false, 0.5, "")
	local _modifyHealthValues = function(gid, idx, eid)
		Modifier_ApplyToEntity(modHealth, eid, 0)
	end
	
	Player_GetAll(player2)
	EGroup_Filter(eg_allentities, {"building"}, FILTER_KEEP)
	EGroup_Filter(eg_allentities, {"wall", "defensive_structure"}, FILTER_REMOVE)
	EGroup_ForEach(eg_allentities, _modifyHealthValues)
end

function Kiev_UpdateBurningAtmospherics()
	Player_GetAll(player2)
	if EGroup_CountSpawned(eg_allentities) <= enemy_initial_building_amount - 20 then
		Game_TransitionToState("winter_afternoon_haze", 15)
		Rule_RemoveMe()
	end
end

------------------------------------------------------------------------------------------------------------------------------
--												ATTACK WAVE / MODULE SPAWNS
------------------------------------------------------------------------------------------------------------------------------

function Kiev_SpawnAttackWave2()
	--if not destroyedGate[GATE_INDUSTRIAL] or not destroyedGate[GATE_OUTER] or not destroyedGate[GATE_INNER] then
	if not EGroup_IsEmpty(eg_industry_production) or not EGroup_IsEmpty(eg_outer_production) or not EGroup_IsEmpty(eg_inner_production) then
		
		if SGroup_CountSpawned(sg_patrol_units_count) < Util_DifVar({50, 60, 80, 120}) then
			
			--Generate a list of the secure places that we can spawn an attack from
			local spawn_options = {}
			if not EGroup_IsEmpty(eg_industry_production) then
				table.insert(spawn_options, 1, mkr_industrial_gate_spawn) 
			end
			if not EGroup_IsEmpty(eg_outer_production) then
				table.insert(spawn_options, 1, mkr_outer_gate_spawn)
			end
			if not EGroup_IsEmpty(eg_inner_production) then
				table.insert(spawn_options, 1, mkr_inner_gate_spawn)
			end
			
			--Generate the wave data according to the selected district
			local random_source = Table_GetRandomItem(spawn_options, 1)
			
			if random_source == mkr_industrial_gate_spawn then
				print("Wave coming from industrial gate")
				Wave_Prepare(industrial_attack, sg_patrol_units_count)
				
			elseif random_source == mkr_outer_gate_spawn then
				print("Wave coming from outer gate")
				Wave_Prepare(outer_attack, sg_patrol_units_count)
			else
				print("Wave coming from inner gate")
				Wave_Prepare(inner_attack, sg_patrol_units_count)
			end
		end
	else
		print("All viable sources for spawning from districts are destroyed. Stopping attacks.")
		Rule_RemoveMe()
	end
end

function Kiev_SpawnSprawlAttackWave(context, data)
	
	if EGroup_CountSpawned(data.egroup) > 0 then -- Are the spawning structures still alive?
		if SGroup_CountSpawned(sg_patrol_units_count) < Util_DifVar({50, 60, 80, 120}) then
			Wave_Prepare(data.wave_module, sg_patrol_units_count)
		end
	else 
		Rule_RemoveMe()
	end
	
end

function Kiev_CheckTraderKilled(context, data)
	if context.victim ~= nil then
		if Squad_GetBlueprint(context.victim) == SBP.RUS.UNIT_TRADE_CART_RUS then
			print("Trader was killed. Play the VO.")
			Util_StartIntel(EVENTS.Trader_Killed)
			Rule_RemoveMe()
		end
	end
end

