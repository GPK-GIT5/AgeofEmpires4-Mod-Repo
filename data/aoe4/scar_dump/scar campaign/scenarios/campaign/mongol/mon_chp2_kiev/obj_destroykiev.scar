	Rule_AddInterval(Kiev_SpawnSprawlAttackWave, {delay = 180, interval = Util_DifVar({60, 60, 60, 40})}, {egroup = eg_sprawl_building_1, wave_module = sprawl_attack_1})
	Rule_AddInterval(Kiev_SpawnSprawlAttackWave, {delay = 200, interval = Util_DifVar({80, 80, 80, 60})}, {egroup = eg_sprawl_building_2, wave_module = sprawl_attack_2})
	Rule_AddInterval(Kiev_SpawnSprawlAttackWave, {delay = 220, interval = Util_DifVar({100, 100, 100, 80})}, {egroup = eg_sprawl_building_3, wave_module = sprawl_attack_3})
	Rule_AddInterval(Kiev_SpawnSprawlAttackWave, {delay = 240, interval = Util_DifVar({120, 120, 120, 100})}, {egroup = eg_sprawl_building_4, wave_module = sprawl_attack_4})
end

function DestroyKiev_SurvivorCallout(context, data)
	--This function checks a district and adds hint markers to all of the remaining required structures
	local _MakeHintpoint = function(gid, idx, eid)
		local blipid = Objective_AddUIElements(data.objective, eid, true)	-- Destroy buildings
		Rule_AddInterval(DestroyKiev_CheckEntityMarker, 1, {objective = data.objective, blipid = blipid, egroup = data.egroup, entity = eid, hintpoint_trigger = data.remain_trigger/2})
	end
	
	if EGroup_CountSpawned(data.egroup) <= data.remain_trigger then
		Objective_RemoveUIElements(data.objective, data.old_hpid)
		EGroup_ForEach(data.egroup, _MakeHintpoint)
		Rule_RemoveMe()
	end
end

function DestroyKiev_CheckEntityMarker(context, data)
	--This function is called by SurvivorCallout to track each entity that is marked with a hintpoint
	if not EGroup_ContainsEntity(data.egroup, data.entity) then
		
		if data.blipid ~= nil then 
			Objective_RemoveUIElements(data.objective, data.blipid)
		end
		if data.hpid ~= nil then 
			Objective_RemoveUIElements(OBJ_DestroyKiev, data.hpid)
		end
		
		Rule_RemoveMe()
		
	elseif data.hpid == nil and EGroup_CountSpawned(data.egroup) <= data.hintpoint_trigger then 
		
		data.hpid = Objective_AddUIElements(OBJ_DestroyKiev, data.entity, false, "$11191883", true)	-- Destroy buildings		
		
	end		
end

function DestroyKiev_PlayDestructionWalla(marker_location)
	Player_GetAllSquadsNearMarker(player1, sg_temp, marker_location, 60)
	
	if SGroup_CountSpawned(sg_temp) <= 30 then
		Sound_PlayOnSquad(WALLA_CAMP_CELEBRATE_SMALL, sg_temp)
	elseif SGroup_CountSpawned(sg_temp) <= 60 then
		Sound_PlayOnSquad(WALLA_CAMP_CELEBRATE_MEDIUM, sg_temp)
	else
		Sound_PlayOnSquad(WALLA_CAMP_CELEBRATE_LARGE, sg_temp)
	end
end