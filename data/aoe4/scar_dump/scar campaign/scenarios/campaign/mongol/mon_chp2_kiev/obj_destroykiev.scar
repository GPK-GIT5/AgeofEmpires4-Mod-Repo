		spawn = mkr_sprawl_spawn_3,
		units = {
			{type = "scar_archer", numSquads = t_difficulty.defender_count_med}
		},
		staging_module = "sprawl_staging_3",
		assault_module_data = moduleData,
		auto_launch = true,
	}
	sprawl_attack_3 = Wave_New(sprawl_data_3)
	
	local sprawl_data_4 = {
		descriptor = "sprawl_wave_4",
		player = player2,
		use_separate_spawns = true,
		spawn = mkr_sprawl_spawn_4,
		units = {
			{type = "scar_spearman", numSquads = t_difficulty.defender_count_med}
		},
		staging_module = "sprawl_staging_4",
		assault_module_data = moduleData,
		auto_launch = true,
	}
