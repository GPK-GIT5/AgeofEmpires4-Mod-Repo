--
-- Zhongdu 1215
--
-- Mongol Chapter 1
--

-- We need to import this for anything to work
import("MissionOMatic/MissionOMatic.scar")
-- We need to import custom objective files
import("obj_zhongdu_secondary.scar")
import("obj_zhongdu_phase1.scar")
import("training_zhongdu.scar")

--? @shortdesc Is the FIRST function called during setup
function Mission_SetupPlayers()

	-- Get IDs for all players
	g_playerMongol = World_GetPlayerAt(1)
	g_playerJin = World_GetPlayerAt(2)
	g_playerNeutral = World_GetPlayerAt(3)
	
	-- The human player
	Setup_SetPlayerName(g_playerMongol, Loc_GetString(11178718)) -- Genghis Khan
	Player_SetCurrentAge(g_playerMongol, AGE_DARK)
	Player_SetMaximumAge(g_playerMongol, AGE_FEUDAL)
	--
	-- The main enemy AI player
	--
	Setup_SetPlayerName(g_playerJin, Loc_GetString(11178715)) -- Jin Dynasty
	Player_SetCurrentAge(g_playerJin, AGE_FEUDAL)
	Player_SetMaximumAge(g_playerJin, AGE_FEUDAL)
	-- Player relationship
	Player_SetRelationship(g_playerMongol, g_playerJin, R_ENEMY)
	Player_SetRelationship(g_playerJin, g_playerMongol, R_ENEMY)
	--
	-- The AI neutral holder player
	--
	Setup_SetPlayerName(g_playerNeutral, Loc_GetString(11178716))
	Player_SetCurrentAge(g_playerNeutral, AGE_DARK)
	Player_SetMaximumAge(g_playerNeutral, AGE_FEUDAL)
	-- Relationship to player
	Player_SetRelationship(g_playerMongol, g_playerNeutral, R_ALLY)
	Player_SetRelationship(g_playerNeutral, g_playerMongol, R_ALLY)
	-- Enemy also needs to consider this player an ally, so they don't attack neutral units
	Player_SetRelationship(g_playerJin, g_playerNeutral, R_ALLY)
	
	AI_Enable(g_playerNeutral, false)
	
	-- Player/Leader LoS
	World_EnableSharedLineOfSight(g_playerMongol, g_playerNeutral, true)
	World_EnableSharedLineOfSight(g_playerNeutral, g_playerMongol, true)
	
end

--? @shortdesc Is the SECOND function called during setup
function Mission_SetupVariables()

	-- Generic SGroups
	sg_player = SGroup_CreateIfNotFound("sg_player")
	sg_enemy = SGroup_CreateIfNotFound("sg_enemy")
	
	-- Special SGroups for this scenario
	sg_intro_troops = SGroup_CreateIfNotFound("sg_intro_troops")
	sg_intro_riders = SGroup_CreateIfNotFound("sg_intro_riders")
	sg_intro_caravan = SGroup_CreateIfNotFound("sg_intro_caravan")
	sg_intro_sheep = SGroup_CreateIfNotFound("sg_intro_sheep")
	sg_outro_troops = SGroup_CreateIfNotFound("sg_outro_troops")
	sg_outro_troops2 = SGroup_CreateIfNotFound("sg_outro_troops2")
	sg_outro_genghis = SGroup_CreateIfNotFound("sg_outro_genghis")
	sg_outro_troops3 = SGroup_CreateIfNotFound("sg_outro_troops3")
	sg_outro_troops4 = SGroup_CreateIfNotFound("sg_outro_troops4")
	sg_outro_troops5 = SGroup_CreateIfNotFound("sg_outro_troops5")
	sg_outro_villagers = SGroup_CreateIfNotFound("sg_outro_villagers")
	
	sg_scouts_waiting = SGroup_CreateIfNotFound("sg_scouts_waiting")

	sg_first_enemies = SGroup_CreateIfNotFound("sg_first_enemies")

	eg_zhongdu = EGroup_CreateIfNotFound("eg_zhongdu")
	eg_shunyi = EGroup_CreateIfNotFound("eg_shunyi")
	eg_tongzhou = EGroup_CreateIfNotFound("eg_tongzhou")
	eg_daxing = EGroup_CreateIfNotFound("eg_daxing")
	eg_fangshan = EGroup_CreateIfNotFound("eg_fangshan")
	eg_zhongdu_landmarks = EGroup_CreateIfNotFound("eg_zhongdu_landmarks")
	eg_raid_targets = EGroup_CreateIfNotFound("eg_raid_targets")
	eg_bridge_riverbend = EGroup_CreateIfNotFound("eg_bridge_riverbend")
	
	eg_market_shunyi = EGroup_CreateIfNotFound("eg_market_shunyi")
	eg_market_tongzhou = EGroup_CreateIfNotFound("eg_market_tongzhou")
	eg_market_daxing = EGroup_CreateIfNotFound("eg_market_daxing")
	eg_market_fangshan = EGroup_CreateIfNotFound("eg_market_fangshan")
	
	-- Basic variables
	g_numOutroCarts = 8
	g_zhongduModifierList = {}
	g_villagesDestroyed = 0
	g_followerSystem = {
		usesCavalry = 0,
		usesInfantry = 0,
		usesFood = 0,
		usesResources = 0,
		drumTimer = 0,
	}
	g_supplyCartFrequency = 120
	g_supplyCartSpacing = g_supplyCartFrequency / 4
	g_supplyCartStrength = 6
	g_raidGrowthIncrements = 8
	g_baseHuntingTimer = 30
	
	g_debugRaidClocker = 0
	
	-- Numbers for the guards within Zhongdu
	g_guardsPrimary = Util_DifVar({8, 9, 18, 27})
	g_guardsLandmarks = Util_DifVar({5, 6, 12, 18})
	g_guardsSkirmish = Util_DifVar({2, 3, 6, 9})
	g_guardsWalls = Util_DifVar({6, 8, 12, 16})
	g_guardsTowns = Util_DifVar({4, 6, 12, 18})
	
	g_pos_market_shunyi = Util_GetPosition(eg_market_shunyi)
	g_pos_market_tongzhou = Util_GetPosition(eg_market_tongzhou)
	g_pos_market_daxing = Util_GetPosition(eg_market_daxing)
	g_pos_market_fangshan = Util_GetPosition(eg_market_fangshan)
	
	g_supplyIntelLowPlayed = false
	g_supplyIntelNonePlayed = false
	g_intelFirstTraderPlayed = false
	g_intelFirstMarketPlayed = false
	g_intelFirstCounterattackPlayed = false
	
	-- Do this after specifying cart count
	for cart = 1, g_numOutroCarts, 1 do
		SGroup_CreateIfNotFound("sg_outro_cart_"..tostring(cart))
	end
	
	-- Get a table of these positions
	eg_world_resources = EGroup_CreateIfNotFound("eg_world_resources")
	local resourcePositions = {}
	local _GetEntityPos = function(gid, idx, eid)
		table.insert(resourcePositions, Util_GetPosition(eid))
	end
	EGroup_ForEach(eg_world_resources, _GetEntityPos)
	
	-- Also make a group just for stone
	eg_world_stone = EGroup_CreateIfNotFound("eg_world_stone")
	EGroup_AddEGroup(eg_world_stone, eg_world_resources)
	EGroup_Filter(eg_world_stone, BP_GetEntityBlueprint("resource_stone_deposit"), FILTER_KEEP)
	
	eg_settlement_1 = EGroup_CreateIfNotFound("eg_settlement_1")
	HintPoint_Add(eg_settlement_1, true, "$11178717", LOCATION_LABEL_HEIGHT)
	
	-- Compile the tower EGroup
	Player_GetAll(g_playerJin)
	EGroup_Filter(eg_allentities, EBP.CHINESE.BUILDING_DEFENSE_TOWER_CHI, FILTER_KEEP)
	eg_zhongdu_towers = EGroup_CreateIfNotFound("eg_zhongdu_towers")
	EGroup_AddEGroup(eg_zhongdu_towers, eg_allentities)
	Cmd_InstantUpgrade(eg_allentities, UPG.CHINESE.UPGRADE_TOWER_HANDCANNONSLITS_CHI)
	
	-- Set up the leader as a global variable
	g_leaderGenghisKhan = Missionomatic_InitializeLeader({
		name = 11162478, -- Genghis Khan
		owner = g_playerMongol,
		neutralHolder = g_playerNeutral,
		respawns = { mkr_leader_respawn },
	})
	
	-- Setup the raiding system
	Raiding_Init({
		player = g_playerJin,
		spawnLocation = mkr_zhongdu_raid_spawn,
		despawnLocation = mkr_scout_despawn,
		scoutTargets = resourcePositions,
		raiderComposition = {
			{ type = "scar_spearman", ratio = 0.4, },
			{ type = "scar_archer", ratio = 0.6, },
		},
		sendProbes = true,
		activeScouting = false,
		scoutTiming = Util_DifVar({330, 300, 270, 210}),
		partyLimit = 1,
		partySize = Util_DifVar({4, 4, 6, 9}),
		raidTiming = Util_DifVar({480, 360, 240, 120}),
		onIdle = Zhongdu_OnIdleRaiders,
	})
	
	-- Objectives
	Zhongdu_InitObjectives_Phase1()
	Zhongdu_InitObjectives_Phase2()
	ZhongduRaid_InitObjectives()
	
	--Set Invulnerable Buildings
	EGroup_SetInvulnerable(eg_zhongdu_landmark_3, 0.05)
	EGroup_SetInvulnerable(eg_zhongdu_landmark_2, 0.05)
	EGroup_SetInvulnerable(eg_zhongdu_landmark_1, 0.05)
	
end

