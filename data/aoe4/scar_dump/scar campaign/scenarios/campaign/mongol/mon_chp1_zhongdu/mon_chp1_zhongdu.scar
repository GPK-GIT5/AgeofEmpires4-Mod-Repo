--? @shortdesc Marks the arrival of a caravan in Zhongdu by removing the caravan and spawning soldiers to the Jin
function Zhongdu_OnAbilityExecuted(context)
	
	-- We want to watch this ability
	g_relicDeposited = BP_GetAbilityBlueprint("monk_statetree_deposit_relic")
	if context.ability == g_relicDeposited then
		
		-- If the Target is owned by a player (this is done here instead of where context.executer is found because context.target is a position instead of an entity for Monk Dropped Relic, which gets weird)
		if not World_OwnsEntity(context.target) then
			-- Grab ID of target
			targetPlayerID = Entity_GetPlayerOwner(context.target)		
		end
		
		-- Ping minimap at Monk's pickup location
		Religious_PingMinimap(context.target)
		-- This is the monk itself: context.executer
		
	end
	
end

--? @shortdesc Watches for the killing of Jin units
function Zhongdu_OnSquadKilled(context, data)
	
	local victim = context.victim
	if World_OwnsSquad(victim) == false and Squad_GetPlayerOwner(victim) == g_playerJin then
		
		-- Killing a scout should trigger the start of the sallies, but after that should do nothing
		if Game_GetSPDifficulty() >= GD_NORMAL and (g_raidSystem.partyLimit > 0 or Squad_IsOfType(victim, "scar_scout") == true) and MissionOMatic_SquadHasTag(victim, "probe") == false then
			local deathPos = Util_GetPosition(context.victim)
			-- Issue a raid against anything near the point of death
			local unitRevengeTarget = SGroup_CreateUnique("sally_target")
			Player_GetAllSquadsNearMarker(g_playerMongol, unitRevengeTarget, deathPos, 30)
			if SGroup_Count(unitRevengeTarget) > 0 then
				local raidRevengeSquad = Raiding_TriggerRaid(unitRevengeTarget)
				if raidRevengeSquad ~= nil then
					g_baseHuntingTimer = g_baseHuntingTimer + Util_DifVar({4, 4, 2, 1})
					Zhongdu_DebugRaidTiming("squad revenge")
				end
			end
			
			-- Killing a trader should increment the progress on that objective
			
		end
		
		-- Also handle trader destruction as a 
		if Squad_IsOfType(victim, "scar_trade_cart") == true and Objective_IsComplete(SOBJ_StopTraders) == false then
			SOBJ_StopTraders.progressCurrent = SOBJ_StopTraders.progressCurrent + 5
			print("SOBJ_StopTraders: progress at "..tostring(SOBJ_StopTraders.progressCurrent))
			
			-- Also, the first time, play intel
			if g_intelFirstTraderPlayed == false then
				Util_StartIntel(EVENTS.Eliminate_Trader)
				g_intelFirstTraderPlayed = true
			end
		end
		
	end
	
end

--? @shortdesc For debugging raid timing
function Zhongdu_DebugRaidTiming(causeString)
	
	local thisTime = World_GetGameTime()
	print(string.format("REQUESTING RAID (%s) at %s seconds, %s seconds since last time", causeString, thisTime, thisTime - g_debugRaidClocker))
	g_debugRaidClocker = thisTime
	
end

--? @shortdesc Checks for entity destruction
function Zhongdu_OnEntityKilled(context, data)

	local killer = context.killer
	local victim = context.victim
	local victimOwner = context.victimOwner
	
	-- We don't need to know who the killer is. It's actually easier to debug if we don't care
	if scartype(victimOwner) == ST_PLAYER and victimOwner == g_playerJin then

		if Game_GetSPDifficulty() >= GD_NORMAL and g_raidSystem.partyLimit > 0 then
			-- Where was the entity killed?
			local deathPos = Util_GetPosition(victim)
			-- Issue a raid against anything near the point of death
			local buildingRevengeTarget = SGroup_CreateUnique("sally_target")
			Player_GetAllSquadsNearMarker(g_playerMongol, buildingRevengeTarget, deathPos, 30)
			if SGroup_Count(buildingRevengeTarget) > 0 then
				local raidRevengeBurn = Raiding_TriggerRaid(buildingRevengeTarget)
				if raidRevengeBurn ~= nil then
					g_baseHuntingTimer = g_baseHuntingTimer + 20
					Zhongdu_DebugRaidTiming("burn revenge")
				end
			end
		end
			
		-- If one of the landmarks is getting destroyed, debug it
		if Entity_IsOfType(victim, "landmark") == true then
			print("ALERT: Landmark destroyed?! Victim:")
			Util_PrintTable(victim)
			print(string.format("Was invulnerable? %s", Entity_IsInvulnerable(victim)))
			print(string.format("Was on fire? %s", Entity_IsBurning(victim)))
			
			if killer == nil then
				print("ALERT: Landmark destroyed?! Nil killer table!")
			else
				print("ALERT: Landmark destroyed?! Killer:")
				Util_PrintTable(killer)
			end
		end
		
	-- If player buildings are getting destroyed, boost the timer between now and the next attack on their base
	elseif scartype(victimOwner) == ST_PLAYER and victimOwner == g_playerMongol and Entity_IsOfType(victim, "building") then
		g_baseHuntingTimer = g_baseHuntingTimer + Util_DifVar({120, 120, 60, 30})
		
	end
end

--? @shortdesc Creates a Mongol parade for the outro cinematic
function Zhongdu_OutroParade()
	
	-- Delete any leftover units
	Player_GetAll(g_playerMongol)
	SGroup_DestroyAllSquads(sg_allsquads)
	
	Player_GetAll(g_playerJin)
	SGroup_DestroyAllSquads(sg_allsquads)
	EGroup_SetPlayerOwner(eg_allentities, g_playerMongol)
	
	UnitEntry_DeploySquads(g_playerMongol,
		sg_outro_troops,
		{
			{ sbp = BP_GetSquadBlueprint("unit_genghis_khan_cmp_mon"), numSquads = 1, spawn = mkr_outro_genghis, sgroup = sg_outro_genghis},
			{ type = "scar_knight", numSquads = 1, spawn = mkr_outro_troops },
			{ type = "scar_knight", numSquads = 1, spawn = mkr_outro_troops5 },
		},
		mkr_outro_troops)
	
	--UnitEntry_DeploySquads(g_playerMongol,
		--sg_outro_troops5,
		--{
			--{ type = "scar_spearman", numSquads = 6 },
			--{ type = "scar_manatarms", numSquads = 12 },
		--},
		--mkr_outro_troops5)
	
	UnitEntry_DeploySquads(g_playerMongol,
		sg_outro_villagers,
		{
			{ type = "scar_villager", numSquads = 4 },
			--{ type = "scar_archer", numSquads = 4 },
			--{ type = "scar_manatarms", numSquads = 8 },
		},
		mkr_outro_troops2)
	
	UnitEntry_DeploySquads(g_playerMongol,
		sg_outro_troops3,
		{
			--{ type = "scar_spearman", numSquads = 8 },
			{ type = "scar_manatarms", numSquads = 6 },
		},
		mkr_outro_troops3)
	
	UnitEntry_DeploySquads(g_playerMongol,
		sg_outro_villagers,
		{
			{ type = "scar_villager", numSquads = 3 },
			--{ type = "scar_archer", numSquads = 3 },
		--	{ type = "scar_crossbowman", numSquads = 8 },
		},
		mkr_outro_troops4)
	
		UnitEntry_DeploySquads(g_playerMongol,
		sg_gate_guard01,
		{
			{ type = "scar_spearman", numSquads = 1 },
		},
		mkr_outro_gateguard_01)
	
		UnitEntry_DeploySquads(g_playerMongol,
		sg_gate_guard02,
		{
			{ type = "scar_spearman", numSquads = 1 },
		},
		mkr_outro_gateguard_02)
	
	Cmd_Stop(sg_outro_troops)
	Cmd_HoldPosition(sg_outro_troops)
	
	Cmd_Stop(sg_outro_troops2)
	Cmd_HoldPosition(sg_outro_troops2)
	
	local markerList = { 
		mkr_outro_carts_middle,
		mkr_outro_carts_exit_4,
		mkr_outro_carts_exit_3,
		mkr_outro_carts_exit_2,
		mkr_outro_carts_exit_1,
	}
	
	local function __AddGold(gid, index, sid)
		local entity = Squad_GetFirstEntity(sid)
		Entity_SetAnimatorState(entity, "trade_cart_carry_resource", "gold")
	end
	
	for cart = 1, g_numOutroCarts, 1 do
		local cartSGroup = SGroup_FromName("sg_outro_cart_"..tostring(cart))
		local cartMarker = Marker_FromName("mkr_outro_carts_"..tostring(cart), "")
		if cartSGroup ~= nil and cartSGroup ~= nil then
			UnitEntry_DeploySquads(g_playerMongol, cartSGroup, { type = "scar_trade_cart", numSquads = 1 }, cartMarker)
			MissionOMatic_SGroupCommandDelayed(cartSGroup, markerList, false, 0.5)
			SGroup_ForEach(cartSGroup, __AddGold)
		else
			fatal("Not enough markers or trade carts for outro cart #"..tostring(cart))
		end
	end
	
end

function Zhongdu_GrowRaidSize(context, data)
	
	-- Boost the raid party size by a small amount
	g_raidSystem.partySize = g_raidSystem.partySize + 1
	
	-- Make sure we don't do this too many times
	g_raidGrowthIncrements = g_raidGrowthIncrements - 1
	if g_raidGrowthIncrements <= 0 then
		Rule_RemoveMe()
	end
	
end

--? @shortdesc Triggers the speech content related to entering Zhongdu
function Zhongdu_OnPlayerBreach()
	
	World_GetSquadsNearMarker(g_playerMongol, sg_temp, mkr_jin_zhongdu, OT_Player)
	if SGroup_Count(sg_temp) > 3 then
		
		-- Once the player is inside the city, stop all raiding!
		Raiding_Dectivate()
		
		-- If the primary objective wasn't completed, complete it so we can get on with the mission
		if Objective_IsComplete(OBJ_StarveCity) == false then
			Objective_Complete(OBJ_StarveCity)	
		end
		
		-- Get those units and send them back to Zhongdu
		local allRaiders = Raiding_ExtractAllSquads()
		if scartype(allRaiders) == ST_SGROUP and SGroup_Count(allRaiders) > 0 then
			Cmd_AttackMove(allRaiders, Marker_GetPosition(mkr_jin_zhongdu), false)
		end
		
		-- Trigger a stinger
		Sound_Play2D(MUS_STING_TRIUMPHANT)
		-- And a walla
		Sound_PlayWallaEngageOnSGroup(sg_temp)
		-- And VO!
		Util_StartIntel(EVENTS.BREAKZHONGDU)
		
		Rule_RemoveMe()
	end
	
end

--? @shortdesc Occasionally launches an attack on the player's base
function Zhongdu_AttackPlayerBase(context, data)

	g_baseHuntingTimer = g_baseHuntingTimer - 1
	-- If we've hit that time, attack the player's economy where it hurts - villagers!
	if g_baseHuntingTimer <= 0 then
		Player_GetAll(g_playerMongol)
		SGroup_Filter(sg_allsquads, { SBP.MONGOL.UNIT_VILLAGER_1_MON, SBP.MONGOL.UNIT_TRADE_CART_MON }, FILTER_KEEP)
		if SGroup_Count(sg_allsquads) > 0 then
			local econTarget = SGroup_CreateUnique("target_econ")
			SGroup_Add(econTarget, SGroup_GetRandomSpawnedSquad(sg_allsquads))
			-- Trigger a raid, or at least try to (may not work out if there's nobody available and we can't make a new raid party)
			local baseRaiders = Raiding_TriggerRaid(econTarget)
			-- If we did assign the target, we'll have gotten something back, so we can reset the timer
			if baseRaiders ~= nil then
				Zhongdu_DebugRaidTiming("base raid")
				g_baseHuntingTimer = Util_DifVar({360, 360, 300, 210}) + World_GetRand(0, 60)
				print(string.format("ZHONGDU: Base raid timer reset to %s seconds", g_baseHuntingTimer))
			end
		end
	end
	
end

--? @shortdesc What to do if an idle raid party was found?
function Zhongdu_OnIdleRaiders()
	
	Player_GetAll(g_playerMongol)
	SGroup_Filter(sg_allsquads, { SBP.MONGOL.UNIT_VILLAGER_1_MON, SBP.MONGOL.UNIT_TRADE_CART_MON, SBP.MONGOL.HERDABLE_SHEEP_MON }, FILTER_REMOVE)
	if SGroup_Count(sg_allsquads) > 0 then
		local militaryTarget = SGroup_CreateUnique("target_military")
		SGroup_Add(militaryTarget, SGroup_GetRandomSpawnedSquad(sg_allsquads))
		-- Trigger a raid, or at least try to (may not work out if there's nobody available and we can't make a new raid party)
		local idleRaiders = Raiding_TriggerRaid(militaryTarget)
		-- If we did assign the target, we'll have gotten something back, so we can reset the timer
		if idleRaiders == nil then
			print(string.format("ZHONGDU: Idle raiders detected, but failed to launch an attack!"))
		else
			Zhongdu_DebugRaidTiming("idle raiders")
		end
	end
	
end

--? @shortdesc Starts raid system scouting after a delay
function Zhongdu_DelayScouting(context, data)
	
	print("ZHONGDU: Enabling raid scouting!")
	Raiding_SetScouting(true)
	
end

--? @shortdesc Warns the player if they get too close too early
function Zhongdu_WarnAgainstCity(context, data)
	
	Player_GetAllSquadsNearMarker(g_playerMongol, sg_temp, mkr_jin_zhongdu_perimeter, Marker_GetProximityRadiusOrDefault(mkr_jin_zhongdu_perimeter, 95))
	if SGroup_Count(sg_temp) > 2 then
		Util_StartIntel(EVENTS.High_Strength_Attack)
		Rule_RemoveMe()
	end
	
end

--? @shortdesc Watch for aging up to notify player of fancy new stuff
function Zhongdu_WatchForAgeUp_Xbox(context, data)
	
	if Player_GetCurrentAge(g_playerMongol) == Player_GetMaximumAge(g_playerMongol) then
		Rule_RemoveMe()
		MissionOMatic_HintOnHover_Xbox(
			Zhongdu_TriggerGenghisHint_Xbox,
			"Genghis Khan's arrows can grant nearby units Incendiary Arrows for destroying buildings",
			"$11199781",
			"campaign_mon_chp1_zhongdu_incendiaries")
	end
	
end

