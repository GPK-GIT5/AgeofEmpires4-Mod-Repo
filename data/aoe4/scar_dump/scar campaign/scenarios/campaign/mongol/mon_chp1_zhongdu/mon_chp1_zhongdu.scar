--? @shortdesc Is the THIRD function called during setup
function Mission_SetRestrictions()	-- set up any restrictions (i.e. locking out units, etc) in here

	-- Set tech based on difficulty and age
	PlayerUpgrades_Auto(g_playerMongol, true)
	PlayerUpgrades_Auto(g_playerJin, false)
	PlayerUpgrades_Auto(g_playerNeutral, true)

	-- Give players incendiary arrows. Ranged units are utterly infuriating to play with without them.
	Player_CompleteUpgrade(g_playerMongol, UPG.MONGOL.UPGRADE_RANGED_INCENDIARY_MON)
	
	--Player does not reach an age to make use of improved siege options
	Player_SetUpgradeAvailability(g_playerMongol, UPG.MONGOL.UPGRADE_IMPROVED_SIEGE_ENGINEERS_MON, ITEM_REMOVED)
	
	-- If we're on easy, remove all outposts from villages. They are perceptually intimidating and cause approach anxiety.
	if Game_GetSPDifficulty() <= GD_NORMAL then
		Player_GetAllEntitiesNearMarker(g_playerJin, eg_temp, mkr_jin_shunyi, 100)
		EGroup_Filter(eg_temp, EBP.CHINESE.BUILDING_DEFENSE_OUTPOST_CHI, FILTER_KEEP)
		EGroup_DestroyAllEntities(eg_temp)
		
		Player_GetAllEntitiesNearMarker(g_playerJin, eg_temp, mkr_jin_tongzhou, 100)
		EGroup_Filter(eg_temp, EBP.CHINESE.BUILDING_DEFENSE_OUTPOST_CHI, FILTER_KEEP)
		EGroup_DestroyAllEntities(eg_temp)
		
		Player_GetAllEntitiesNearMarker(g_playerJin, eg_temp, mkr_jin_daxing, 100)
		EGroup_Filter(eg_temp, EBP.CHINESE.BUILDING_DEFENSE_OUTPOST_CHI, FILTER_KEEP)
		EGroup_DestroyAllEntities(eg_temp)
		
		Player_GetAllEntitiesNearMarker(g_playerJin, eg_temp, mkr_jin_fangshan, 100)
		EGroup_Filter(eg_temp, EBP.CHINESE.BUILDING_DEFENSE_OUTPOST_CHI, FILTER_KEEP)
		EGroup_DestroyAllEntities(eg_temp)
		
		-- Also remove this bridge, which allows the enemy to attack from angles that are hard for low-difficulty players to understand
		EGroup_SetAvgHealth(eg_bridge_riverbend, 0.0)
		
	end
	
	
	
	-- Make sure Jin fortifications actually shoot
	Player_GetAll(g_playerJin)
	EGroup_Filter(eg_allentities, EBP.CHINESE.BUILDING_DEFENSE_OUTPOST_CHI, FILTER_KEEP)
	-- On the hardest difficulty, make them Stone outposts to really mess with players
	if Game_GetSPDifficulty() == GD_EXPERT then 
		Cmd_InstantUpgrade(eg_allentities, UPG.COMMON.UPGRADE_OUTPOST_STONE)
	end
	-- But don't add cannons to that first one, ever
	EGroup_RemoveGroup(eg_allentities, eg_do_not_upgrade)
	Cmd_InstantUpgrade(eg_allentities, UPG.CHINESE.UPGRADE_OUTPOST_HANDCANNONSLITS_CHI)
	
	-- Make sure Jin landmarks actually burn
	Modify_OnFireHealthPercentage(eg_zhongdu_landmark_1, MUT_Addition, 0.25)
	Modify_OnFireHealthPercentage(eg_zhongdu_landmark_2, MUT_Addition, 0.25)
	Modify_OnFireHealthPercentage(eg_zhongdu_landmark_3, MUT_Addition, 0.25)
	
	-- Also make the markets burn faster to reward hit-and-runs
	Modify_OnFireHealthPercentage(eg_market_shunyi, MUT_Addition, 0.35)
	Modify_OnFireHealthPercentage(eg_market_tongzhou, MUT_Addition, 0.35)
	Modify_OnFireHealthPercentage(eg_market_daxing, MUT_Addition, 0.35)
	Modify_OnFireHealthPercentage(eg_market_fangshan, MUT_Addition, 0.35)
	
	-- We could do this, but it breaks a pattern:
	-- UI_SetPlayerDataContext(g_playerMongol, { PopulationCapOn = false })
	-- Instead, we want to do this, for safety:
	for index, player in pairs(PLAYERS) do
		if player.isLocal == true then
			player.scarModel.PopulationCapOn  = false
			UI_SetPlayerDataContext(g_playerMongol, player.scarModel)
		end
    end
	
end

--? @shortdesc Is the FIFTH function called during setup
function Mission_Preset()	-- any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)

	-- Enable player colours
	PlayerColour_Enable()
   
    Game_SetPlayerSlotColour(g_playerMongol, 1)
    Game_SetPlayerUISlotColour(g_playerMongol, 1)
	
    Game_SetPlayerSlotColour(g_playerJin, 2)
    Game_SetPlayerUISlotColour(g_playerJin, 2)
	
    Game_SetPlayerSlotColour(g_playerNeutral, 1)
    Game_SetPlayerUISlotColour(g_playerNeutral, 1)
	
	-- Set up rules
	Rule_AddGlobalEvent(Zhongdu_OnAbilityExecuted, GE_AbilityExecuted)
	Rule_AddGlobalEvent(Zhongdu_OnSquadKilled, GE_SquadKilled)
	Rule_AddGlobalEvent(Zhongdu_OnEntityKilled, GE_EntityKilled)
	Rule_AddInterval(Zhongdu_OnPlayerBreach, 1)
	Rule_AddInterval(Zhongdu_MonitorSkirmishers, 1)
	
	if UI_IsXboxControllerUI() then
		Rule_AddInterval(Zhongdu_WatchForAgeUp_Xbox, 1)
		Rule_AddInterval(Zhongdu_WatchForBlacksmith_Xbox, 1)
	else
		Rule_AddInterval(Zhongdu_WatchForAgeUp, 1)
		Rule_AddInterval(Zhongdu_WatchForBlacksmith, 1)
	end
	
	
	
	-- Configure the rules
	Rule_AddInterval(Zhongdu_GrowRaidSize, 180)
	Rule_AddOneShot(Zhongdu_DelayScouting, 90)
	Rule_AddInterval(Zhongdu_WarnAgainstCity, 1)
	
	-- Audio considerations
	if Music_UnlockIntensity then
		Sound_SetForceMusic(false)
	else
		Sound_SetForceMusic(true)
	end
	-- We'll start off with Chinese music, and transition to Mongol music later
	Sound_SetMusicRaceCode("chinese")
	
	-- Music Triggers	
    AudioTrigger_InitAreaTrigger({
		marker = mkr_jin_shunyi,
		audioCue = MUSIC_COMBAT,
		triggeringPlayer = g_playerMongol,
		startAboveUnitCount = 5,
		duration = 10,
	})
	
	AudioTrigger_InitAreaTrigger({
		marker = mkr_jin_tongzhou,
		audioCue = MUSIC_COMBAT,
		triggeringPlayer = g_playerMongol,
		startAboveUnitCount = 5,
		duration = 30,
	})
	
	AudioTrigger_InitAreaTrigger({
		marker = mkr_jin_fangshan,
		audioCue = MUSIC_TENSE_COMBAT,
		triggeringPlayer = g_playerMongol,
		startAboveUnitCount = 5,
		duration = 30,
	})
	
	AudioTrigger_InitAreaTrigger({
		marker = mkr_jin_daxing,
		audioCue = MUSIC_TENSE_COMBAT,
		triggeringPlayer = g_playerMongol,
		startAboveUnitCount = 5,
		duration = 30,
	})	
	
	AudioTrigger_InitAreaTrigger({
		marker = mkr_jin_zhongdu,
		audioCue = MUSIC_COMBAT_RARE,
		triggeringPlayer = g_playerMongol,
		startAboveUnitCount = 5,
		duration = 40,
	})
	
	SGroup_Clear(sg_temp)
	SGroup_AddGroup(sg_temp, sg_intro_troops)
	SGroup_Filter(sg_temp, "scar_scout", FILTER_KEEP)
	if SGroup_Count(sg_temp) > 1 then
		local scoutSquad = SGroup_GetSpawnedSquadAt(sg_temp, 1)
		SGroup_SetWorldOwned(sg_intro_sheep)
		print("Herding sheep!")
	end
	
	Cmd_FormationMove(sg_intro_caravan, mkr_mongol_start_destination_2, false)
	Cmd_FormationMove(sg_intro_troops, mkr_mongol_start_destination_1, false)
	Cmd_FormationMove(sg_intro_riders, mkr_mongol_start_destination_riders, false)
	Rule_AddOneShot(GenghisMove_Intro, 12) --changed from 8 to 12
	
end

function GenghisMove_Intro()
	
	Cmd_FormationMove(g_leaderGenghisKhan.sgroup, mkr_mongol_start_leader, false, false, Util_GetFacingFromDirection(Marker_GetPosition(mkr_mongol_start_leader), Marker_GetDirection(mkr_mongol_start_leader)))
	
end

--? @shortdesc Is the SIXTH function called during setup
function Mission_Start()
	
	print("Mission Start with difficulty "..Game_GetSPDifficulty())
	
	-- start the opening objectives (if you're using ObjectiveTable style objectives)
	Objective_Start(OBJ_Raid)
	
	-- Sets initial player resources
	Player_SetResource(g_playerMongol, RT_Food, 0)
	Player_SetResource(g_playerMongol, RT_Wood, 0)
	Player_SetResource(g_playerMongol, RT_Stone, 0)
	Player_SetResource(g_playerMongol, RT_Gold, 0)
	
	for idx = 1, 6 do
		local moduleName = "WallArchers"..tostring(idx)
		local archerSgroup = MissionOMatic_FindModule(moduleName).sgroup
		LocalCommand_SquadExt(g_playerJin, archerSgroup, SCMD_HoldPosition, 1, false)
	end
	
	TrackTradeCartsForPlayers({g_playerJin})
	
	local testScout = SGroup_GetSquadAt(sg_scouts_waiting, 1)
	print(string.format("ZHONGDU: Scout health at %s of %s", Squad_GetHealth(testScout), Squad_GetHealthMax(testScout)))
	SGroup_SetAvgHealth(sg_scouts_waiting, 1.0)
	
	Zhongdu_SetupSheepRallyHint()
	
	Zhongdu_UpdateDefences(2)
	
end

