--
-- Juyong 1213 - Primary Objectives Phase 4
--
--
-- TO USE THIS TEMPLATE:
-- 1. Decide on a prefix for this objective / section of the mission
-- 2. save this template as a new file in the same directory as your mission script - use "obj_<prefix>.scar" for the name 
-- 3. import this file into your main mission script with import("obj_<prefix>.scar")
-- 4. call the <prefix>_InitObjectives function from inside you main mission script's Mission_SetupVariables function
--

--? @shortdesc Initializes the main objectives for Lumen Shan
function Juyong_InitObjectives_Phase4()

	OBJ_Juyong = { Title = "$11180874", -- Breach the Great Wall
		Type = ObjectiveType_Primary,
		
		PreStart = function()
			Util_AutoSave()
			Objective_Start(SOBJ_BuildSiege, false)
		end,
		
		OnStart = function()
			Util_StartIntel(EVENTS["BurnKeep_Juyong"])
			Objective_Start(SOBJ_RazeKeepJuyong, false)
			Objective_Start(SOBJ_BuildSiege, false)
			MissionTutorial_Blacksmith()
			
			if UI_IsXboxControllerUI() then
				MissionTutorial_SiegeEngineer_Xbox()
			else
				MissionTutorial_SiegeEngineer()
			end
			
			MissionTutorial_Ram()
		end,
		
		IsComplete = function()
			return Objective_IsComplete(SOBJ_RazeKeepJuyong)
		end,
		
		OnComplete = function()
			Mission_Complete()
		end,
		
		IsFailed = Juyong_CheckTotalFailure, 
		
		OnFail = function()
			Mission_Fail()
		end,
		
		Cheat = Joyong_CheatToObjective,
		
	}
	
	SOBJ_RazeKeepJuyong = { Title = "$11180876",  -- Raze the keep
		Type = ObjectiveType_Primary, Parent = OBJ_Juyong,
		
		OnStart = function()
			Sound_SetMinimumMusicCombatIntensity(801, 0)
			hint_Juyong = Objective_AddUIElements(SOBJ_RazeKeepJuyong, base_juyong, true, 11180877, true, nil, nil, nil, "icons/races/mongols/abilities/unpack" ) -- Juyong

		end,
		
		OnComplete = function()
			HintPoint_Remove(hint_Juyong)
			Objective_Complete(SOBJ_BuildSiege, false, false)
		end,
	}
	
	SOBJ_BuildSiege = { Title = "$11180875", -- Optional: Construct siege towers or rams
		Type = ObjectiveType_Primary, Parent = OBJ_Juyong,

		counterGoal = 4,
		
		PreStart = function()
			Objective_SetCounter(SOBJ_BuildSiege, 0, SOBJ_BuildSiege.counterGoal)
		end,
		
		OnStart = function()
		end,
		
		IsComplete = function()
			return Objective_GetCounter(SOBJ_BuildSiege) >= SOBJ_BuildSiege.counterGoal
		end,
		
		OnComplete = function()
		end,
	}
	
	OBJ_DebugComplete = {
		Title = LOC("Debug Complete"),
		Type = ObjectiveType_Primary,
		showTitle = false,
		Cheat = function()
			Player_GetAll(g_playerJin)
            EGroup_Filter(eg_allentities, EBP.CHINESE.BUILDING_DEFENSE_GREATWALL_GATE_CMP_CHI, FILTER_KEEP)
            EGroup_DestroyAllEntities(eg_allentities)
			Mission_Complete()
		end,
	}
	
	--
	-- REGISTRATION
	--
	Objective_Register(OBJ_Juyong)
	Objective_Register(SOBJ_RazeKeepJuyong)
	Objective_Register(SOBJ_BuildSiege)
	Objective_Register(OBJ_DebugComplete)
	
	
end

function Juyong_GroupWallsForObjectives()
	
	print("")
	Player_GetAllEntitiesNearMarker(g_playerJin, eg_jin_greatwall, base_juyong, 250)
	EGroup_Filter(eg_jin_greatwall, { "stone_wall", "stone_gate" }, FILTER_KEEP)
	
	startingcount_greatWall = EGroup_Count(eg_jin_greatwall)
	
end

function Juyong_ApproachGreatWall()
	Player_GetAll(g_playerMongol)
	if Prox_AreSquadsNearMarker(sg_allsquads,base_juyong, ANY, 85) then
		Rule_RemoveMe()
		Music_PlayStinger("mus_camp_cust_mongol_drum_short_finalbattle_dry")
		Rule_Remove(Juyong_RetreatOffMap)
	end 
end

function Juyong_CheckGreatWallBreached()
	if startingcount_greatWall > EGroup_Count(eg_jin_greatwall) then
		EGroup_Clear(eg_allentities)
		World_GetEntitiesNearMarker(g_playerJin, eg_allentities, mkr_juyong_gate, OT_Player)
		EGroup_Filter(eg_allentities, "wall", FILTER_KEEP)
		
		EGroup_DestroyAllEntities(eg_allentities)
		EGroup_DestroyAllEntities(eg_gate_impass)
		
		Rule_RemoveMe()
		Rule_Remove(Juyong_JuyongWave)
		
		Util_StartIntel(EVENTS["BreachWall"])
	end 
end

function Juyong_ShowGreatWall()
	Player_GetAll(g_playerMongol)
	if Prox_AreSquadsNearMarker(sg_allsquads,juyong_reveal_1, ANY, 85) then
		FOW_RevealMarker(juyong_reveal_1, 10)
		FOW_RevealMarker(juyong_reveal_2, 10)
		FOW_RevealMarker(juyong_reveal_3, 10)
		FOW_RevealMarker(juyong_reveal_4, 10)
		FOW_RevealMarker(juyong_reveal_5, 10)
		Rule_RemoveMe()
	end
end

