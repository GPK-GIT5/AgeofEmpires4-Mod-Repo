function Joyong_CheatToObjective()
	
	Module_StopAndDelete("JinPostZhangjiakou1")
	Module_StopAndDelete("JinForestPost")
	Module_StopAndDelete("ZhangjiakouArchersNorth1")
	Module_StopAndDelete("ZhangjiakouArchersNorth2")
	Module_StopAndDelete("ZhangjiakouArchersNorth3")
	Module_StopAndDelete("ZhangjiakouArchersNorth4")
	Module_StopAndDelete("ZhangjiakouArchersSouth1")
	Module_StopAndDelete("ZhangjiakouArchersSouth2")
	Module_StopAndDelete("ZhangjiakouArchersSouth3")
	Module_StopAndDelete("ZhangjiakouArchersSouth4")
	Module_StopAndDelete("ZhangjiakouDefend")
	Module_StopAndDelete("ZhangjiakouRetreaters")
	Module_StopAndDelete("JinRoadPost1")
	Module_StopAndDelete("JinRoadPost2")
	Module_StopAndDelete("JinRoadPost7")
	Module_StopAndDelete("JinYanqing")
	Module_StopAndDelete("MountainPatrol1")
	Module_StopAndDelete("MountainPatrol2")
	Module_StopAndDelete("FieldPatrol1")
	Module_StopAndDelete("FieldPatrol3")
	Module_StopAndDelete("YanqingPatrol")
	Module_StopAndDelete("NorthPatrol")
	Module_StopAndDelete("SouthPatrol")
	Module_StopAndDelete("NorthDefend")
	Module_StopAndDelete("MidfieldDefend")
	
	VillagerLife_Stop("villagerlife_north")
	VillagerLife_Stop("villagerlife_south1")
	VillagerLife_Stop("villagerlife_south2")
	VillagerLife_Stop("villagerlife_south3")
	VillagerLife_Stop("villagerlife_south4")
	VillagerLife_Stop("villagerlife_yan")
	VillagerLife_Stop("villagerlife_zhang")
	VillagerLife_Stop("villagerlife_midfield")
	
	Capture_Location("Zhangjiakou")
	Capture_Location("ZhangjiakouGate")
	Capture_Location("Yanqing")
	Capture_Location("Midfield")

	Juyong_CleanUpIntro()
	
	Player_SetCurrentAge(g_playerMongol, AGE_FEUDAL)
	
	Player_SetRelationship(g_playerJin, g_playerMongol, R_ENEMY)	
	
	Player_CompleteUpgrade(g_playerMongol, UPG.MONGOL.UPGRADE_UNIT_SPEARMAN_2_MON)
	Player_CompleteUpgrade(g_playerMongol, UPG.MONGOL.UPGRADE_UNIT_HORSEMAN_2_MON)

	Player_CompleteUpgrade(g_playerMongol, UPG.MONGOL.UPGRADE_IMPROVED_SIEGE_ENGINEERS_MON)
	Player_CompleteUpgrade(g_playerMongol, UPG.MONGOL.UPGRADE_MELEE_DAMAGE_I_IMPROVED_MON)
	Player_CompleteUpgrade(g_playerMongol, UPG.MONGOL.UPGRADE_MELEE_ARMOR_I_IMPROVED_MON)
	
	Player_SetResource(g_playerMongol, RT_Food, 1000)
	Player_SetResource(g_playerMongol, RT_Wood, 1000)
	Player_SetResource(g_playerMongol, RT_Gold, 700)
	Player_SetResource(g_playerMongol, RT_Stone, 500)
	
	-- military units
	local units = {
		{type = "scar_scout", numSquads = 2},
		{type = "scar_spearman", numSquads = 30},
		{type = "scar_archer", numSquads = 20},
		{type = "scar_horseman", numSquads = 10},
	}
	local options = {
		facing = Util_GetPosition(mkr_juyong_outrospawn16),
	}
	UnitEntry_DeploySquads(g_playerMongol, sg_blah, units, mkr_juyong_outrospawn18, nil, nil, options)
	
	-- rams (spawn them behind the main units)
	local units = {
		{type = "scar_ram", numSquads = 3},
		{type = "scar_villager", numSquads = 4},
	}
	local options = {
		facing = Util_GetPosition(mkr_juyong_outrospawn17),
	}
	UnitEntry_DeploySquads(g_playerMongol, sg_blah, units, mkr_juyong_outrospawn24, nil, nil, options)
	
	Camera_MoveTo(mkr_juyong_outrospawn20)
	
end

function Module_StopAndDelete(name)
	
	local module = MissionOMatic_FindModule(name)

	if module ~= nil then 
		
		local sgroup = Prefab_DoAction(module, "GetSGroup")
		
		Prefab_DoAction(module, "Stop")
		
		SGroup_DestroyAllSquads(sgroup)
				
	end
	
end

function VillagerLife_Stop(name)
	
	local instance = VillagerLife_Find(name)
	
	if instance ~= nil then 
		
		SGroup_DestroyAllSquads(instance.sg_villagers)
		
	end

end	

function Capture_Location(name)
	
	local location = LOCATION(name)
	
	if location ~= nil then 
		
		-- add the ground reticule (else the next bit will FSE)
		local size = math.max(Marker_GetProximityRadiusOrDefault(location.marker, 0), 10)
		location.data.captureReticuleID = UI_ModalVisual_CreateReticule(BP_GetReticuleBlueprint("campaign_capturelocation_enemy"), size)
		UI_ModalVisual_SetPosition(location.data.captureReticuleID, Util_GetPosition(location.marker))

		location.data.villagerCount = 0
		location.data.extraVillagerCount = 0
		
		Location_Capture(location, g_playerMongol)

	end
	
end