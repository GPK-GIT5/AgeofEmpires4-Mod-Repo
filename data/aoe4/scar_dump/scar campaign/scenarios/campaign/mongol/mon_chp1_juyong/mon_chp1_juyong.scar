function Juyong_InitPlayerUnits()

	--UnitEntry_DeploySquads(g_playerMongol, sg_intro_deer,  { sbp = SBP.GAIA.GAIA_HUNTABLE_DEER, numSquads = 1 }, mkr_intro_deer )
	
	UnitEntry_DeploySquads(g_playerMongol, sg_mon_scout,  { type = "scar_scout", numSquads = 1 }, mkr_intro_scout1 )
	UnitEntry_DeploySquads(g_playerMongol, sg_mon_scout,  { type = "scar_scout", numSquads = 1 }, mkr_intro_scout4 )
	UnitEntry_DeploySquads(g_playerIntro, sg_mon_introkhan, { sbp = BP_GetSquadBlueprint("unit_genghis_khan_cmp_mon"), numSquads = 1 }, mkr_introkhan1 )
	
	--needs sgroup defined and new spawn marker
	UnitEntry_DeploySquads(g_playerIntro, sg_mon_intro_mangudai,  { type = "scar_horsearcher", numSquads = 2 }, mkr_intro_mangudai )
	UnitEntry_DeploySquads(g_playerJin, sg_jin_villager01, {type = "scar_villager", numSquads = 3}, mkr_intro_villager_spawn01)
	UnitEntry_DeploySquads(g_playerJin, sg_jin_villager02, {type = "scar_villager", numSquads = 4}, mkr_intro_villager_spawn02)
	UnitEntry_DeploySquads(g_playerJin, sg_jin_villager03, {type = "scar_villager", numSquads = 3}, mkr_intro_villager_spawn03)
	
	Cmd_FormationMove(sg_jin_villager01, mkr_intro_villager_target01)
	Cmd_FormationMove(sg_jin_villager02, mkr_intro_villager_target02)
	Cmd_FormationMove(sg_jin_villager03, mkr_intro_villager_target03)
	
	Cmd_FormationMove(sg_intro_jin_move, post_zhangjiakou_2)
	Cmd_FormationMove(sg_intro_jin_move1, base_zhangjiakou)
	
	Rule_AddOneShot(Juyong_SendIntroUnits, 10, { sgroup = sg_mon_scout, 		markerList = { mkr_intro_scout2 } })
	Rule_AddOneShot(Juyong_SendIntroUnits, 18, { sgroup = sg_mon_scout, 	markerList = { mkr_intro_scout3 } })
																						 
	--Rule_AddOneShot(Juyong_SendIntroUnits, 3, { sgroup = sg_mon_introkhan, 	markerList = { mkr_introkhan2 } })
	Rule_AddOneShot(Juyong_SendIntroUnits, 14, { sgroup = sg_mon_introkhan, markerList = { mkr_introkhan2, mkr_introkhan3 } })
	Rule_AddOneShot(Juyong_SendIntroUnits, 15, { sgroup = sg_mon_intro_mangudai, markerList = { mkr_introkhan2, mkr_introkhan3 } })
	
	Modify_UnitSpeed(sg_mon_introkhan, 1.1)
	Modify_UnitSpeed(sg_mon_intro_mangudai, 1.2)
	
	Rule_AddOneShot(Juyong_CleanUpIntro, 23)
	
end

function Juyong_InitEnemyUnits()
	
	Cmd_HoldPosition(sg_jin_zarchers)

end

function Juyong_SendIntroUnits(context, data)
	
	-- Add the others as waypoints
	for index, marker in pairs(data.markerList) do
		
		if scartype(marker) == ST_MARKER then
			if index <= #data.markerList then
				Cmd_FormationMove(data.sgroup, marker, true)
			end
		end
	end
	
	if data.destination ~= nil then
		Cmd_FormationMove(data.sgroup, data.destination, true)
	end
end

function Juyong_CheckJuyongKeepDestroyed()
	if EGroup_IsEmpty(eg_juyong_keep) then
		
		Player_GetAllSquadsNearMarker(g_playerMongol, sg_mon_army, base_juyong, 200)
		Sound_PlayWallaCelebrateOnSGroup(sg_mon_army)
		Util_StartIntel(EVENTS["BurnKeep_Complete"])
		Objective_Complete(SOBJ_BuildSiege, false, false)
		
		Rule_RemoveMe()
		Mission_Complete()
	end
end

function Juyong_SkipIntro()
	Juyong_CleanUpIntro()
	SGroup_DestroyAllSquads(sg_mon_scout)
	UnitEntry_DeploySquads(g_playerMongol, nil,  { type = "scar_scout", numSquads = 2 }, mkr_intro_scout3 )
end

function Juyong_CleanUpIntro()
	SGroup_DestroyAllSquads(sg_mon_introkhan)
	SGroup_DestroyAllSquads(sg_mon_intro_mangudai)
	SGroup_DestroyAllSquads(sg_jin_villager01)
	SGroup_DestroyAllSquads(sg_jin_villager02)
	SGroup_DestroyAllSquads(sg_jin_villager03)
end

--? @shortdesc A security check for utter failure, i.e. no units left that aren't Scouts
function Juyong_CheckTotalFailure(context)
	
	if scout_phase_complete ~= true then
		return false
	end
	
	Player_GetAll(g_playerMongol)
	SGroup_Filter(sg_allsquads, "scar_scout", FILTER_REMOVE)
	return SGroup_Count(sg_allsquads) <= 0
	
end

-- Achievement tracking for Achievement #18 - Yeah, Well, You Should See The Other Guy - Lose a unit to the Front Gate of Zhangjiakou
function Achievement_ScoutDiesAtFrontGate(context)
		
	if Squad_IsValid(Squad_GetID(context.victim)) and context.killer then
		
		-- Check that victim is not gaia
		if not World_OwnsSquad(context.victim) then
			
			local victimOwner = Squad_GetPlayerOwner(context.victim)
			
			-- Check that owner of victim is the local player
			if victimOwner == g_playerMongol then
				
				-- Check that killer entity is valid
				if Entity_IsValid(Entity_GetID(context.killer)) then
					
					-- Check if killer is a Tower in the Zhangjiakou Defenses group 	
					if EGroup_ContainsEntity(eg_zhangjiakou_defenses, context.killer) then
						
						-- Grant achievement completion
						Game_SendCustomChallengeEvent(g_playerMongol, CE_ACHIEVDIEDTOZHANGJIAKOUGATE, 1)
						Rule_RemoveMe()
						return
					end
					
					-- Retrieve squad information
					local squadKiller = Entity_GetSquad(context.killer)
					
					-- Is squadKiller valid
					if squadKiller then
						
						--Check if killer is a squad manning the wall
						if SGroup_ContainsSquad(sg_jin_zarchersnorth, Squad_GetID(squadKiller), false) or SGroup_ContainsSquad(sg_jin_zarcherssouth, Squad_GetID(squadKiller), false) then
							
							-- Grant achievement completion
							Game_SendCustomChallengeEvent(g_playerMongol, CE_ACHIEVDIEDTOZHANGJIAKOUGATE, 1)
							Rule_RemoveMe()
						end
					end
				end
			end
		end
	end
end