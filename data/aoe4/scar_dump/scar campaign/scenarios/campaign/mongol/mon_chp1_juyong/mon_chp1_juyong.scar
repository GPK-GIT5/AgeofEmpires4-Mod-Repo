--? @shortdesc Checks for constructed entities (buildings, field weapons, etc)
function Juyong_OnConstructionComplete(context)
	
	local buildingOwner = Entity_GetPlayerOwner(context.entity)
	if buildingOwner == g_playerMongol and Entity_IsOfType(context.entity, "siege") then
		
		local objective = SOBJ_BuildSiege
		if Objective_IsCounterSet(objective) then
			Objective_IncreaseCounter(objective)
		elseif Objective_IsComplete(objective) == true then
			Rule_RemoveGlobalEvent(Juyong_OnConstructionComplete)
			print("Removing Juyong_OnConstructionComplete")
		end
	end
end

--? @shortdesc Checks for miscellaneous mission-related conditions
function Juyong_SpecialChecks(context)

	-- Has the temple module been defeated?
	if g_templeStands == true and Condition_ModuleDefeated_Check({ moduleName = "TempleGuards", }) == true then
		
		print("Temple defeated!")
		g_templeStands = false
		
		local resultSGroup = SGroup_CreateUnique()
		local units = {
			{ sbp = BP_GetSquadBlueprint("unit_manatarms_4_chi"), numSquads = 4, },
			{ sbp = BP_GetSquadBlueprint("unit_archer_4_chi"), numSquads = 4, },
		}
		
		UnitEntry_DeploySquads(g_playerMongol, resultSGroup, units, misc_temple)

		-- Now give them their bonuses
		local modHealth = Modifier_Create(MAT_Entity, "health_maximum_modifier", MUT_Multiplication, false, 10, "")
		local modRegen = Modifier_Create(MAT_Entity, "health_regeneration_modifier", MUT_Addition, false, 10, "")
		
		local function _BoostEntities(gid, idx, sid)
			local entity = Squad_GetFirstEntity(sid)
			Modifier_ApplyToEntity(modHealth, entity, 0)
			Modifier_ApplyToEntity(modRegen, entity, 0)
		end
		
		-- Apply this
		SGroup_ForEach(resultSGroup, _BoostEntities)
	end
end

