function Mission_SetRestrictions()	-- set up any restrictions (i.e. locking out units, etc) in here
	
	-- Make sure Jin fortifications actually shoot
	Player_GetAll(g_playerJin, eg_zhangjiakou_defenses)
	EGroup_Filter(eg_zhangjiakou_defenses, EBP.CHINESE.BUILDING_DEFENSE_TOWER_CHI, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_zhangjiakou_defenses, UPG.COMMON.UPGRADE_TOWER_CANNON)
	Player_CompleteUpgrade(g_playerJin, UPG.COMMON.UPGRADE_TECH_UNIVERSITY_MURDER_HOLES_4)
	
	-- Make sure Jin fortifications actually shoot
	Player_GetAll(g_playerJin)
	EGroup_Filter(eg_allentities, EBP.CHINESE.BUILDING_DEFENSE_OUTPOST_CHI, FILTER_KEEP)
	Cmd_InstantUpgrade(eg_allentities, UPG.CHINESE.UPGRADE_OUTPOST_HANDCANNONSLITS_CHI)
	
	-- People hate the slow Mongol buildings, justifiably, so just give them the upgrade
	Player_CompleteUpgrade(g_playerMongol, UPG.MONGOL.UPGRADE_UNIT_TOWN_CENTER_FASTER_PACKING_1_MON)
	
	--Player does not reach an age to make use of improved siege options
	Player_SetUpgradeAvailability(g_playerMongol, UPG.MONGOL.UPGRADE_IMPROVED_SIEGE_ENGINEERS_MON, ITEM_REMOVED)

end

function Mission_Preset()	-- any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)
	
	-- Enable player colours
	PlayerColour_Enable()
   
    Game_SetPlayerSlotColour(g_playerMongol, 1)
    Game_SetPlayerUISlotColour(g_playerMongol, 1)
	
    Game_SetPlayerSlotColour(g_playerJin, 2)
    Game_SetPlayerUISlotColour(g_playerJin, 2)
	
	Game_SetPlayerSlotColour(g_playerNeutral, 1)
    Game_SetPlayerUISlotColour(g_playerNeutral, 1)
	
	-- Special rules for this scenario
	Rule_AddGlobalEvent(Juyong_OnConstructionComplete, GE_ConstructionComplete)
	
	-- Achievement tracking for Achievement #18 - Yeah, Well, You Should See The Other Guy - Lose a unit to the Front Gate of Zhangjiakou
	Rule_AddGlobalEvent(Achievement_ScoutDiesAtFrontGate, GE_SquadKilled)
	
	--Rule_AddInterval(Juyong_SpecialChecks, 1)
	
	-- Buff Zhangjiakou walls and wall towers
	Player_GetAllEntitiesNearMarker(g_playerJin, eg_temp, base_zhangjiakougate, 80)
	EGroup_Filter(eg_temp, {"wall", "tower"}, FILTER_REMOVE, eg_zhangjiakou_wall)
	
	Modify_ReceivedDamage(eg_zhangjiakou_wall, 0.01)
	Modify_OnFireDamagePerTick(eg_zhangjiakou_wall, MUT_Multiplication, 0.01)
	
	EGroup_Filter(eg_zhangjiakou_wall, {"tower"}, FILTER_KEEP)
	Modify_WeaponDamage(eg_zhangjiakou_wall, "hardpoint_01", 2)
	Modify_WeaponDamage(eg_zhangjiakou_wall, "hardpoint_02", 2)
	Modify_WeaponDamage(eg_zhangjiakou_wall, "hardpoint_03", 2)
	Modify_WeaponDamage(eg_zhangjiakou_wall, "hardpoint_04", 2)
	
	-- Great Wall Group
	Juyong_GroupWallsForObjectives()
	
	--Intro Action
	Juyong_InitPlayerUnits()
	
	-- Audio considerations

	-- Force Music play non-stop when music intensity is locked, allow music to play with silence system when music intensity is unlocked. 
	if Music_UnlockIntensity then
		Sound_SetForceMusic(false)
		else
		Sound_SetForceMusic(true)
		end
	
		-- Set sound intensity for Juyong
	Sound_ResetMusicIntensityMapping();
	Sound_AddMusicIntensityMappingPoint(50, 200) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(100, 1250) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(150, 2500) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(200, 4000) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(300, 5500) -- point 2 raw value to point 2 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(400, 7250) -- point 1 raw value to point 1 scaled intensity value
	Sound_AddMusicIntensityMappingPoint(550, 9999) -- raw value max to scaled value max 
	
	
	-- Set up audio triggers
	--AudioTrigger_InitAreaTrigger({
		--marker = base_zhangjiakou,
		--audioCue = MUSIC_COMBAT,
		--triggeringPlayer = g_playerMongol,
		--startAboveUnitCount = 5,
		--duration = 30,
	--})
	
	AudioTrigger_InitAreaTrigger({
		marker = base_yanqing,
		audioCue = MUSIC_TENSE_COMBAT,
		triggeringPlayer = g_playerMongol,
		startAboveUnitCount = 8,
		duration = 20,
	})
	
	AudioTrigger_InitAreaTrigger({
		marker = base_juyong,
		audioCue = MUSIC_COMBAT_RARE,
		triggeringPlayer = g_playerMongol,
		startAboveUnitCount = 4,
		priority = 1,
	})
	
	AudioTrigger_InitConditionalTrigger({
		audioCue = MUSIC_TENSE,
		startCondition = {
			condition = "ModuleDefeated",
			moduleName = "JinForestPost",
		},
		endCondition = {
			condition = "BuildingsSpotted",
			egroup = eg_zhangjiakou,
		},
		priority = 2,
	})
	
	Game_TransitionToState("steppes_morning", 300)
		
end

-- This is triggered after the intro, just as control is passed to the player
function Mission_Start()	
	
	-- on console don't restore VPS at first 
	Cardinal_EnablePartialXboxUI(true, {VF_XboxUIVillagerPriorities})

	-- Early Mission Complete Check
	Rule_AddInterval(Juyong_CheckJuyongKeepDestroyed, 1)
	
	
	-- Sets initial player resources
	Player_SetResource(g_playerMongol, RT_Food, 0)
	Player_SetResource(g_playerMongol, RT_Wood, 0)
	Player_SetResource(g_playerMongol, RT_Stone, 0)
	Player_SetResource(g_playerMongol, RT_Gold, 0)
	
	UI_SetPlayerDataContext(g_playerMongol, { PopulationCapOn = false })
	
	Objective_Start(OBJ_Prepare, false, true)
	
end

