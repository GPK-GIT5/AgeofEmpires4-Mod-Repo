	OBJ_RaidSettlements = {
		Title = "$11191314",
		Type = ObjectiveType_Optional,
		
		counterTarget = 2000,
		counterCurrent = 0,
		
		Intel_Start = EVENTS.Burn_Farms_Hint,
		
		PreStart = function()
			local current_res = Player_GetResources(player1)
			
			player_res = {
				food = current_res.food,
				wood = current_res.wood,
				gold = current_res.gold,
				stone = current_res.stone }
			
			Objective_SetCounter(OBJ_RaidSettlements, OBJ_RaidSettlements.counterCurrent, OBJ_RaidSettlements.counterTarget)
		end,
		
		IsComplete = function()
			
			--Check and update minimum player resources
			local current_res = Player_GetResources(player1)
			
			if player_res.gold < current_res.gold then
				local gold_difference = current_res.gold - player_res.gold
				OBJ_RaidSettlements.counterCurrent = OBJ_RaidSettlements.counterCurrent + gold_difference
				player_res.gold = current_res.gold
			elseif player_res.gold > current_res.gold then
				player_res.gold = current_res.gold
			end
			
			--Update the counter and check if player has gathered enough resources.
			Objective_SetCounter(OBJ_RaidSettlements, OBJ_RaidSettlements.counterCurrent, OBJ_RaidSettlements.counterTarget)
			
			if OBJ_RaidSettlements.counterCurrent >= OBJ_RaidSettlements.counterTarget then
				return true
			end
			
			return false
		end,
	}
	
