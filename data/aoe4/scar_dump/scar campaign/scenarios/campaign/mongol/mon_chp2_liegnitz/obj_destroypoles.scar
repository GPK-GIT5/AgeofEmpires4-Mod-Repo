function DestroyPoles_CheckPlayerStatus()	-- check for fail conditions
	
	local playerHasNoUnits = Player_GetUnitCount(player1) == 0
	
	if playerHasNoUnits == true then 
		
		local _CheckProductionQueueIsEmpty = function(gid, idx, eid)		
			if Entity_HasProductionQueue(eid) == false then
				return true 
			else
				return Entity_GetProductionQueueSize(eid) == 0
			end
		end
		
		local playerHasNoProductionBuildings = EGroup_IsEmpty(eg_player_production_structures)
		local playerHasNoUnitsInProduction = EGroup_ForEachAllOrAny(eg_player_production_structures, ALL, _CheckProductionQueueIsEmpty)
		local playerHasNoResources = Player_GetResource(player1, RT_Food) < 110 or (Player_GetResource(player1, RT_Wood) < 10 and Player_GetResource(player1, RT_Gold) < 50)
		
		return playerHasNoProductionBuildings or (playerHasNoResources and playerHasNoUnitsInProduction)
		
	end
	 
end

function DestroyPoles_UpdateObjectiveProgress(objectiveID, modules)
	
	local maximum_allowable_deaths = 0
	local current_cumulative_deaths = 0
	
	for i, module in ipairs(modules) do
		maximum_allowable_deaths = maximum_allowable_deaths + ( module.highestUnitCount - (module.highestUnitCount * module.withdrawThreshold) )
		
		if SGroup_CountSpawned(module.sgroup) <= (module.highestUnitCount * module.withdrawThreshold) then
			current_cumulative_deaths = current_cumulative_deaths + ( module.highestUnitCount - (module.highestUnitCount * module.withdrawThreshold))
		else
			current_cumulative_deaths = current_cumulative_deaths + (module.highestUnitCount - SGroup_CountSpawned(module.sgroup))
		end
	end
	
	Obj_SetProgress(objectiveID, current_cumulative_deaths / maximum_allowable_deaths)
	
end

function DestroyPoles_CanPlayerSeeSGroups(context, data)
	
	for i in pairs(data.modules) do
		if Player_CanSeeSGroup(player1, data.modules[i].sgroup, ANY) then
			Objective_Start(data.objective, not Objective_IsFailed(OBJ_BohemianTimer))
			Rule_RemoveMe()
			break
		end
	end

end

function DestroyPoles_UpdateObjectiveCounter(objectiveID)
	
	local maximum_allowable_deaths = 0
	local current_cumulative_deaths = 0
	
	for i, module in ipairs(objectiveID.modules) do
		maximum_allowable_deaths = maximum_allowable_deaths + ( module.highestUnitCount - (module.highestUnitCount * module.withdrawThreshold) )
		
		if SGroup_CountSpawned(module.sgroup) <= (module.withdrawThreshold * module.highestUnitCount) then
			current_cumulative_deaths = current_cumulative_deaths + ( module.highestUnitCount - (module.highestUnitCount * module.withdrawThreshold))
		else
			current_cumulative_deaths = current_cumulative_deaths + (module.highestUnitCount - SGroup_CountSpawned(module.sgroup))
		end
	end
	
	Objective_SetCounter(objectiveID, current_cumulative_deaths, maximum_allowable_deaths)
	
	return current_cumulative_deaths >= maximum_allowable_deaths
	
end

function DestroyPoles_UpdateHintpoints(context, data)
	
	--Check that the objective the hintpoints are tied to is still valid and the hintpoints down if they aren't.
	if Objective_IsComplete(data.objective) or Objective_IsFailed(data.objective) then
		if data.hpid ~= nil then 
			Objective_RemoveUIElements(data.objective, data.hpid)
			data.hpid = nil
		end
		Rule_RemoveMe()
	else
		
		--Check that all modules provided to check are not withdrawn or dissolved. Disable the hintpoint and stop the rule if they are.
		local module_isActive = false
		for i, module in ipairs(data.modules) do
			if not (module.isWithdrawn or module.status == "Dissolved") then
				module_isActive = true
				break
			end
		end
		
		if not module_isActive then
			if data.hpid ~= nil then 
				Objective_RemoveUIElements(data.objective, data.hpid)
				data.hpid = nil
			end
			Rule_RemoveMe()
		end
	end
	
end

function DestroyPoles_StartKnightsOBJ()
	Objective_Start(SOBJ_RovingKnights)
end

function DestroyPoles_BohemiaAttack()
	local units = {
		{ squad = sg_bohemian_units, sbp = SBP.HRE.UNIT_KNIGHT_3_HRE, 	numSquads = Util_DifVar({6, 7, 10, 14}) }, 
		{ squad = sg_bohemian_units, sbp = SBP.HRE.UNIT_HORSEMAN_3_HRE, 	numSquads = Util_DifVar({6, 7, 10, 14}) }, 
		{ squad = sg_bohemian_units, sbp = SBP.HRE.UNIT_ARCHER_3_HRE, 	numSquads = Util_DifVar({6, 7, 10, 14}) }, 
		{ squad = sg_bohemian_units, sbp = SBP.HRE.UNIT_MANATARMS_3_HRE, 	numSquads = Util_DifVar({6, 7, 10, 14}) }, 
	}

	SpawnUnitsToModule(units, "roving_bohemians", mkr_bohemia_start)
end

function DestroyPoles_DelayStartBohemianArmyUI()
	--Objective_AddUIElements(OBJ_DestroyBohemianArmy, sg_bohemian_units, true, 11176011, false)
	ThreatArrow_CreateGroup("Bohemian army", sg_bohemian_units)
