			end
			return false
		end,
		
		IsFailed = function()
			if Objective_GetTimerSeconds(OBJ_BohemianTimer) <= 0 and not Objective_IsComplete(OBJ_DestroyPolishArmy) then
				return true
			else 
				return false
			end
		end,
		
		PreFail = function()
			Objective_Start(OBJ_DestroyBohemianArmy)
		end,
		
	}
	
	OBJ_DestroyPolishArmy = {
		
