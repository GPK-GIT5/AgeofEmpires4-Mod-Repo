function DestroyPoles_BohemiaWarningTimer()
	
	if not Objective_IsComplete(OBJ_BohemianTimer) then
		Util_StartIntel(EVENTS.Bohemian_Army)
		
	end
	
end

function DestroyPoles_OnSquadKilled(context)
	
	local victim = context.victim
	
	if Player_OwnsSquad(player2, victim) or Player_OwnsSquad(player3, victim) then
		last_killed_position = Squad_GetPosition(victim)
	end
	
end

function DestroyPoles_BurnFieldsReminder(context)
	--This is called after an initial delay, should only be called once.
	--if b_fieldsWereBurned ~= true then
	Objective_Start(OBJ_RaidSettlements)
	--end
end

function DestroyPoles_FarmAttacked(context)
	--This is called on an interval of 1 second.
	Player_GetAll(player2)
	--EGroup_Filter(eg_allentities, EBP.HRE.BUILDING_RESOURCE_FARM_HRE, FILTER_KEEP)
	if EGroup_IsBurning(eg_allentities, ANY) then
		Util_StartIntel(EVENTS.Burn_Farms_Complete)
		b_fieldsWereBurned = true
		Rule_RemoveMe()
	end
end

function DestroyPoles_BeesReminder(context)
	--This is called on an interval and checks if the bees are selected before playing the VO
	if b_BeesHaveKilledBeforeAndWillDoItAgain ~= true and Misc_IsSGroupSelected(sg_rocketsiege, ANY) then
		Util_StartIntel(EVENTS.Bees_Interact)
		Rule_AddOneShot(Liegnitz_InitializeBeesTrainingHints, 17)
		Rule_RemoveMe()
	end
end

function DestroyPoles_BeesAttackCheck(context)
	--This is called whenever something is damaged, it looks for military units that have been attacked by the nests of bees.
	if context.victimSquad ~= nil and context.attacker ~= nil then
		if Entity_GetBlueprint(context.attacker) == EBP.CHINESE.UNIT_NEST_OF_BEES_4_CHI then
			if Entity_IsOfType(context.victim, "military") and Squad_GetPlayerOwner(context.victimSquad) == player2 then
				b_BeesHaveKilledBeforeAndWillDoItAgain = true
				print("THE BEES HAVE CLAIMED ANOTHER VICTIM")
				--Util_StartIntel(EVENTS.Bees_Damage) --This VO line has been removed as the AI doesn't look like they cower in fear
				Rule_RemoveMe()
			end
		end
	end
end

function DestroyPoles_AddDelayedUIElement(context, data)
	Objective_AddUIElements(data.objective, data.module.sgroup, true)
end

function DestroyPoles_FindHiddenStables(context, data)
	if not EGroup_IsEmpty(eg_player_production_structures) then
		local new_stable_position = Entity_GetPosition(EGroup_GetEntityAt(eg_player_production_structures, 1))
		if new_stable_position ~= stable_position then
			stable_position = new_stable_position
			
			--Apply new stable position target to modules
			RovingArmy_SetTargets(field_defend_left, {stable_position, mkr_field_left} )
			RovingArmy_SetTargets(field_defend_center, {stable_position, mkr_field_center} )
			RovingArmy_SetTargets(field_defend_right, {stable_position, mkr_field_right} )
			RovingArmy_SetTargets(field_patrol, {stable_position, mkr_field_patrol_4, mkr_field_patrol_5, mkr_field_patrol_6, mkr_field_patrol_1, mkr_field_patrol_2} )
			
			RovingArmy_SetTargets(ridge_defend_left, {stable_position, mkr_ridge_left} )
			RovingArmy_SetTargets(ridge_defend_center, {stable_position, mkr_ridge} )
			RovingArmy_SetTargets(ridge_defend_right, {stable_position, mkr_ridge_right} )
			RovingArmy_SetTargets(ridge_patrol, {mkr_village_tl_4, stable_position, mkr_village_tl_4, mkr_ridge_patrol_2, mkr_ridge_patrol_3, mkr_ridge_patrol_4, mkr_ridge_patrol_5, mkr_ridge_patrol_1} )
			
			RovingArmy_SetTargets(valley_defend_front, {stable_position, mkr_valley_front} )
			RovingArmy_SetTargets(valley_defend_center, {stable_position, mkr_valley_center} )
			RovingArmy_SetTargets(valley_defend_back, {stable_position, mkr_valley_back} )
			RovingArmy_SetTargets(valley_defend_left, {stable_position, mkr_valley_left} )
			RovingArmy_SetTargets(valley_defend_right, {stable_position, mkr_valley_right} )
			RovingArmy_SetTargets(valley_patrol, {stable_position, mkr_valley_patrol_4, mkr_valley_patrol_5, mkr_valley_patrol_1, mkr_valley_patrol_2} )
			
			RovingArmy_SetTargets(roving_templars, {
					stable_position,
					mkr_templar_10,
					mkr_templar_11,
					mkr_templar_12,
					mkr_templar_13,
					mkr_templar_14,
					mkr_templar_15,
					mkr_templar_2,
					mkr_templar_3,
					mkr_templar_4,
					mkr_templar_5,
				mkr_templar_6})
			
			RovingArmy_SetTargets(roving_bohemians, {
					stable_position,
					mkr_bohemia_1,
					mkr_bohemia_2,
					mkr_bohemia_3,
					mkr_bohemia_4,
					mkr_bohemia_5,
				mkr_bohemia_6})
		end
	else
		Rule_RemoveMe()
	end
end