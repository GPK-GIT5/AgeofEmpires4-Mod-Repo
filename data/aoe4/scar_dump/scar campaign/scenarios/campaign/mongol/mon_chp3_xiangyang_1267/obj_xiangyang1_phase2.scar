--
-- Xiangyang 1267 - Primary Objectives Phase 2
--
--
-- TO USE THIS TEMPLATE:
-- 1. Decide on a prefix for this objective / section of the mission
-- 2. save this template as a new file in the same directory as your mission script - use "obj_<prefix>.scar" for the name 
-- 3. import this file into your main mission script with import("obj_<prefix>.scar")
-- 4. call the <prefix>_InitObjectives function from inside you main mission script's Mission_SetupVariables function
--

SALLY_WEST = "west"
SALLY_NORTH = "north"
SALLY_EAST = "east"

--? @shortdesc Initializes the main objectives for Xiangyang 1267
function Xiangyang1267_InitObjectives_Phase2()

	OBJ_CampUp = { Title = "$11179216", Type = ObjectiveType_Primary,
		
		-- This is Objective: 7
		Cheat = function()
			print("CHEAT: Cheating into Phase 2")
			-- Delete all units and buildings outside the city; the player should have killed these off
			Xiangyang1267_CheatDeleteOutlyingUnits(3)
			-- Destroy the bridge
			EGroup_SetAvgHealth(eg_sally_bridge, 0.0)
			-- Spawn the allies and reinforcements that should be here
			Xiangyang1267_SpawnAllies()
			Xiangyang1267_TopUpWithAllies()
			--Remove and destroy the trebuchets
			SGroup_Clear(sg_temp)
			SGroup_Filter(sg_allies, "scar_trebuchet_traction", FILTER_REMOVE, sg_temp)
			SGroup_DestroyAllSquads(sg_temp)
			-- Send off the rest of the allies to defend
			Xiangyang_HandleLeftovers()
			-- Finally, teleport the starting units
			SGroup_FormationWarpToMarker(sg_all_intro_units, mkr_mongol_rally_1)
			Camera_MoveTo(mkr_mongol_rally_1)
			-- Bring in the buildings
			Xiangyang1267_SpawnAllCamps()
			-- And make sure this stops
			if Rule_Exists(Xiangyang1267_SpawnRoadPatrol) == true then
				Rule_Remove(Xiangyang1267_SpawnRoadPatrol)
			end
		end,
		
		PreStart = function()
			-- We locked the gates at the start of the mission, so unlock them now to allow raiders out!
			Missionomatic_SetGateLock(eg_songCityGates, false)
			-- Show popcap data again
			UI_SetPlayerDataContext(g_playerMongol, { PopulationCapOn = true })
			-- Start the VO rule
			Rule_AddInterval(Xiangyang1267_MonitorBridgeheadVO, 3)
			-- Kick off this rule to show the player the woods, though we should put the hintpoint here earlier just in case
			Rule_AddInterval(Xiangyang1267_RevealWoods, 1)
		end,
		
		OnStart = function()
			FOW_RevealMarker(mkr_fancheng_reveal, 0.125)
			FOW_RevealMarker(mkr_xiangyang_reveal, 0.125)
			-- Trigger a sally
			if Game_GetSPDifficulty() >= GD_NORMAL then
				Xiangyang1267_SmallPokeAttack()
				Rule_AddInterval(Xiangyang1267_SmallPokeAttack, 180)
			end
			--Autosave soonish, but not right this second, because usually combat is still happening
			Rule_AddOneShot(Xiangyang1267_DelayedAutoSave, 20)
			-- Kick an atmo transition
			Game_TransitionToState("subtropical_morning_smoky", 120)
		end,
		
		IsComplete = function()
			if Objective_IsStarted(OBJ_FinaleTimer) == false then
				-- How many "complete" do we have?
				local numComplete = 0
				if Xiangyang1267_BridgeheadRatioWest() >= 1.0 then
					numComplete = numComplete + 1
				end
				if Xiangyang1267_BridgeheadRatioNorth() >= 1.0 then
					numComplete = numComplete + 1
				end
				if Xiangyang1267_BridgeheadRatioSouth() >= 1.0 then
					numComplete = numComplete + 1
				end
				
				-- What's the lowest completion ratio?
				local lowestRatio = math.min(Xiangyang1267_BridgeheadRatioSouth(), Xiangyang1267_BridgeheadRatioNorth(), Xiangyang1267_BridgeheadRatioWest())
				
				-- What's the overall completion level?
				local totalSurroundRatio = Xiangyang1267_BridgeheadRatioSouth() + Xiangyang1267_BridgeheadRatioNorth() + Xiangyang1267_BridgeheadRatioWest()
				totalSurroundRatio = totalSurroundRatio / 3.0
				
				-- If we've "completed" at least one, the player has seen the "Keep units here" messaging and should know to station units
				-- We can start the objective
				if numComplete >= 2 and lowestRatio >= 0.75 then
					Objective_Start(OBJ_FinaleTimer)
				end
			end
			return Objective_IsComplete(OBJ_ContainFinalSally)
		end,
		
		OnComplete = function()
			Mission_Complete()
		end,
		
		IsFailed = function()
			Player_GetAll(g_playerMongol)
			SGroup_Filter(sg_allsquads, "gaia", FILTER_REMOVE)
			
			local lostAllUnits = (SGroup_Count(sg_allsquads) + EGroup_Count(eg_allentities)) <= 0
			return Objective_IsFailed(OBJ_ContainFinalSally) or lostAllUnits
		end,
		
		OnFail = function()
			Music_PlayStinger("mon_camp_mus_stinger_mission_fail")
			Mission_Fail()
		end,
	}
	SOBJ_SurroundWest = { Title = "$11179225", Type = ObjectiveType_Battle, Parent = OBJ_CampUp, StartAlongsideParent = true,

		showTitle = false,
		
		PreStart = function()
			Objective_AddUIElements(SOBJ_SurroundWest, mkr_bridgehead_1, true, "$11179228", true)
			FOW_RevealMarker(mkr_bridgehead_1, -1)
			Objective_SetProgressBar(SOBJ_SurroundWest, 0.0)
			Objective_AddGroundReticule(SOBJ_SurroundWest, mkr_bridgehead_1)
		end,
		
		OnStart = function()
			
		end,
		
		IsFailed = function()
			local endGame = Objective_IsStarted(OBJ_ContainFinalSally)
			local ratio = Xiangyang1267_BridgeheadRatioWest(endGame, endGame)
			
			if Objective_IsStarted(OBJ_ContainFinalSally) == false then
				if ratio >= 1.0 and g_unitsInWest ~= true then
					g_unitsInWest = true
					Obj_SetTitle(SOBJ_SurroundWest.ID, "$11201947")
				elseif g_unitsInWest == true and ratio < 1.0 then
					g_unitsInWest = false
					Obj_SetTitle(SOBJ_SurroundWest.ID, "$11179225")
				end
				Objective_SetCounter(SOBJ_SurroundWest, ratio * g_bridgeheadDenominator, g_bridgeheadDenominator)
			end
			
			Objective_SetProgressBar(SOBJ_SurroundWest, ratio)
			
			return ratio <= 0.0 and (Objective_IsTimerSet(OBJ_ContainFinalSally) and Objective_GetTimerSeconds(OBJ_ContainFinalSally) <= 0)
		end,
	}
	SOBJ_SurroundNorth = { Title = "$11179226", Type = ObjectiveType_Battle, Parent = OBJ_CampUp, StartAlongsideParent = true,

		showTitle = false,
		
		PreStart = function()
			Objective_AddUIElements(SOBJ_SurroundNorth, mkr_bridgehead_2, true, "$11179229", true)
			FOW_RevealMarker(mkr_bridgehead_2, -1)
			Objective_SetProgressBar(SOBJ_SurroundNorth, 0.0)
			Objective_AddGroundReticule(SOBJ_SurroundNorth, mkr_bridgehead_2)
		end,
		
		OnStart = function()
			
		end,
		
		IsFailed = function()
			local endGame = Objective_IsStarted(OBJ_ContainFinalSally)
			local ratio = Xiangyang1267_BridgeheadRatioNorth(endGame, endGame)
			if Objective_IsStarted(OBJ_ContainFinalSally) == false then
				if ratio >= 1.0 and g_unitsInNorth ~= true then
					g_unitsInNorth = true
					Obj_SetTitle(SOBJ_SurroundNorth.ID, "$11201948")
				elseif g_unitsInNorth == true and ratio < 1.0 then
					g_unitsInNorth = false
					Obj_SetTitle(SOBJ_SurroundNorth.ID, "$11179226")
				end
				Objective_SetCounter(SOBJ_SurroundNorth, ratio * g_bridgeheadDenominator, g_bridgeheadDenominator)
			end
			
			Objective_SetProgressBar(SOBJ_SurroundNorth, ratio)
			return ratio <= 0.0 and (Objective_IsTimerSet(OBJ_ContainFinalSally) and Objective_GetTimerSeconds(OBJ_ContainFinalSally) <= 0)
		end,
	}
	SOBJ_SurroundSouth = { Title = "$11179227", Type = ObjectiveType_Battle, Parent = OBJ_CampUp, StartAlongsideParent = true,

		showTitle = false,
		
		PreStart = function()
			Objective_AddUIElements(SOBJ_SurroundSouth, mkr_bridgehead_3, true, "$11179230", true)
			FOW_RevealMarker(mkr_bridgehead_3, -1)
			Objective_SetProgressBar(SOBJ_SurroundSouth, 0.0)
			Objective_AddGroundReticule(SOBJ_SurroundSouth, mkr_bridgehead_3)
		end,
		
		OnStart = function()
			
		end,
		
		IsFailed = function()
			local endGame = Objective_IsStarted(OBJ_ContainFinalSally)
			local ratio = Xiangyang1267_BridgeheadRatioSouth(endGame, endGame)
			if Objective_IsStarted(OBJ_ContainFinalSally) == false then
				if ratio >= 1.0 and g_unitsInSouth ~= true then
					g_unitsInSouth = true
					Obj_SetTitle(SOBJ_SurroundSouth.ID, "$11201949")
				elseif g_unitsInSouth == true and ratio < 1.0 then
					g_unitsInSouth = false
					Obj_SetTitle(SOBJ_SurroundSouth.ID, "$11179227")
				end
				Objective_SetCounter(SOBJ_SurroundSouth, ratio * g_bridgeheadDenominator, g_bridgeheadDenominator)
			end
			
			Objective_SetProgressBar(SOBJ_SurroundSouth, ratio)
			return ratio <= 0.0 and (Objective_IsTimerSet(OBJ_ContainFinalSally) and Objective_GetTimerSeconds(OBJ_ContainFinalSally) <= 0)
		end,
	}
	OBJ_FinaleTimer = { Title = "$11198605", Type = ObjectiveType_Information,

		Intel_Start = EVENTS.CounterAttack_TimerStart,
		
		duration = 45,
		Intel_Complete = EVENTS.CounterAttack_Begins,
		
		OnStart = function()
			Objective_StartTimer(OBJ_FinaleTimer, COUNT_DOWN, OBJ_FinaleTimer.duration, 10)
		end,
		
		IsComplete = function()
			local timerSeconds = Objective_GetTimerSeconds(OBJ_FinaleTimer)
			print(string.format("Finale timer at %s", timerSeconds))
			return timerSeconds <= 0
		end,
		
		OnComplete = function()
			if Objective_IsStarted(OBJ_ContainFinalSally) == false then
				Objective_Start(OBJ_ContainFinalSally)
			end
		end,
	}
	OBJ_ContainFinalSally = { Title = "$11179232", Type = ObjectiveType_Information,
		
		wavesDefeated = 0,
		wavesMax = 0,

		PreStart = function()
			Xiangyang1267_InitFinalSally()
			Xiangyang1267_TriggerWarningSally()
			Objective_SetProgressBar(OBJ_ContainFinalSally, 0.0)
		end,
		
		OnStart = function()
			Obj_SetTitle(SOBJ_SurroundWest.ID, "$11197410")
			Obj_SetTitle(SOBJ_SurroundNorth.ID, "$11197411")
			Obj_SetTitle(SOBJ_SurroundSouth.ID, "$11197412")
			
			Objective_StopCounter(SOBJ_SurroundWest)
			Objective_StopCounter(SOBJ_SurroundNorth)
			Objective_StopCounter(SOBJ_SurroundSouth)
		end,
		
		IsComplete = function()
			OBJ_ContainFinalSally.showTitle = false
			local completeRatio = 1.0
			local bridgeRepairState = EGroup_GetAvgHealth(eg_southern_bridges)
			if g_finalWavesStarted ~= true and bridgeRepairState >= completeRatio then
				-- Play the intel announcing the attack
				-- Start the attack
				Rule_AddOneShot(Xiangyang1267_LaunchFinaleWave, 10, { timeToNext = (g_finalWaveTiming - 10) })
				Rule_AddInterval(Xiangyang1267_LaunchFinaleWave, g_finalWaveTiming, { timeToNext = g_finalWaveTiming })
				-- And get rid of those villagers
				if SGroup_Count(sg_repair_1) > 0 then
					Cmd_FormationMoveToAndDestroy(sg_repair_1, mkr_base_xiangyang, false)
				end
				if SGroup_Count(sg_repair_2) > 0 then
					Cmd_FormationMoveToAndDestroy(sg_repair_2, mkr_base_xiangyang, false)
				end
				-- Just for completeness' sake
				EGroup_SetAvgHealth(eg_southern_bridges, 1.0)
				-- Notify that the final wave has started
				g_finalWavesStarted = true
				print("Bridges fixed, final waves started!")
			end
			
			return (OBJ_ContainFinalSally.wavesDefeated / OBJ_ContainFinalSally.wavesMax) >= 1.0
		end,
		
		PreComplete = function()
			Music_StopMedium()
			Modifier_Remove(g_fanchengBridgeInvulnerability)
		end,
		
		IsFailed = Xiangyang1267_CheckPlayerDefeat,
	}
	OBJ_DebugComplete = { Title = LOC("Debug Complete"), Type = ObjectiveType_Primary, showTitle = false,
		Cheat = function()
			Rule_RemoveAll()
			--Xiangyang1267_RunOutro()
			Mission_Complete()
		end,
	}
	
	--
	-- REGISTRATION
	--
	-- This one needs to be at the top, so it appears at the top of the screen!
	Objective_Register(OBJ_FinaleTimer)
	Objective_Register(OBJ_ContainFinalSally)
	-- Now do the rest
	Objective_Register(OBJ_CampUp)
	Objective_Register(SOBJ_SurroundWest)
	Objective_Register(SOBJ_SurroundNorth)
	Objective_Register(SOBJ_SurroundSouth)
	
	Objective_Register(OBJ_DebugComplete)
	
end

--? @shortdesc Watches for VO and tries to play is correctly
function Xiangyang1267_MonitorBridgeheadVO(context, data)
	
	if Objective_IsStarted(OBJ_FinaleTimer) == true then
		Rule_RemoveMe()
		return
	end
	
	g_totalBridgeheadsTriggered = g_totalBridgeheadsTriggered or 0
	local runNewVO = false
	local endGame = Objective_IsStarted(OBJ_ContainFinalSally)
	
	local ratioWest = Xiangyang1267_BridgeheadRatioWest(endGame, endGame)
	if ratioWest >= 1.0 and g_westVO ~= true then
		g_westVO = true
		runNewVO = true
		g_totalBridgeheadsTriggered = g_totalBridgeheadsTriggered + 1
	end
	
	local ratioNorth = Xiangyang1267_BridgeheadRatioNorth(endGame, endGame)
	if ratioNorth >= 1.0 and g_northVO ~= true then
		g_northVO = true
		runNewVO = true
		g_totalBridgeheadsTriggered = g_totalBridgeheadsTriggered + 1
	end
	
	local ratioSouth = Xiangyang1267_BridgeheadRatioSouth(endGame, endGame)
	if ratioSouth >= 1.0 and g_southVO ~= true then
		g_southVO = true
		runNewVO = true
		g_totalBridgeheadsTriggered = g_totalBridgeheadsTriggered + 1
	end

	if runNewVO == true then
		if g_totalBridgeheadsTriggered == 1 then
			Util_StartIntel(EVENTS.SeizePoint1)
		elseif g_totalBridgeheadsTriggered == 2 then
			Util_StartIntel(EVENTS.SeizePoint2)
		elseif g_totalBridgeheadsTriggered >= 3 then
			-- Nothing needed here, the next objective takes care of it
		end
	end
	
end

--? @shortdesc Spawns a whole bunch of Mongol forces and sends them in three different directions
function Xiangyang1267_SpawnAllCamps()
	
	-- Give them resources
	Action_AddResources_Do({
		player = g_playerMongol,
		resources = {
			food = 1800,
			gold = 900,
			wood = 900,
		},
	})
	
	-- We'll spawn things into here
	local unitList = {}

	--What's the final leeway?
	local buildingCount = 9
	local targetPop = (10 * 3) + Player_GetCurrentPopulation(g_playerMongol, CT_Personnel)
	local finalPop = math.min(targetPop, 140)
	local unitsTotal = finalPop - buildingCount - Player_GetCurrentPopulation(g_playerMongol, CT_Personnel)
	
	local unitsPerType = unitsTotal / 15.0
	if unitsPerType < 0 then
		unitsPerType = 0
	end
	
	-- Spawn the EASTWARD camp
	local mongol_campers_east = SGroup_CreateUnique("mongol_campers_east")
	local sg_camper_buildings = SGroup_CreateUnique("sg_camper_buildings")
	local sg_camper_units = SGroup_CreateUnique("sg_camper_units")
	Action_SpawnUnits_Do({
		player = g_playerMongol,
		spawnLocation = mkr_mongol_campers_east,
		sgroup = mongol_campers_east,
		units = {
			{ type = "scar_spearman", numSquads = unitsPerType, sgroup = sg_camper_units, },
			{ type = "scar_manatarms", numSquads = unitsPerType, sgroup = sg_camper_units, },
			{ type = "scar_archer", numSquads = unitsPerType, sgroup = sg_camper_units, },
			{ type = "scar_knight", numSquads = unitsPerType, sgroup = sg_camper_units, },
			{ type = "scar_horsearcher", numSquads = unitsPerType, sgroup = sg_camper_units, },
			{ sbp = SBP.MONGOL.BUILDING_ECON_MARKET_MOVING_MON, sgroup = sg_camper_buildings, numSquads = 1, },
			{ sbp = SBP.MONGOL.BUILDING_UNIT_RANGED_MOVING_MON, sgroup = sg_camper_buildings, numSquads = 1, },
			{ sbp = SBP.MONGOL.BUILDING_UNIT_INFANTRY_MOVING_MON, sgroup = sg_camper_buildings, numSquads = 1, },
			{ sbp = SBP.MONGOL.BUILDING_UNIT_CAVALRY_MOVING_MON, sgroup = sg_camper_buildings, numSquads = 1, },
		},
	})
	
	MissionOMatic_SGroupCommandDelayed(sg_camper_units, mkr_mongol_campdest_1c, false, 1)
	MissionOMatic_SGroupCommandDelayed(sg_camper_buildings, mkr_mongol_campdest_1b, false, 1)
	
	-- Spawn the NORTHERN camp
	local mongol_campers_north = SGroup_CreateUnique("mongol_campers_north")
	sg_camper_buildings = SGroup_CreateUnique("sg_camper_buildings")
	sg_camper_units = SGroup_CreateUnique("sg_camper_units")
	Action_SpawnUnits_Do({
		player = g_playerMongol,
		spawnLocation = mkr_mongol_campers_north,
		sgroup = mongol_campers_north,
		units = {
			{ type = "scar_spearman", numSquads = unitsPerType, sgroup = sg_camper_units, },
			{ type = "scar_manatarms", numSquads = unitsPerType, sgroup = sg_camper_units, },
			{ type = "scar_crossbowman", numSquads = unitsPerType, sgroup = sg_camper_units, },
			{ type = "scar_knight", numSquads = unitsPerType, sgroup = sg_camper_units, },
			{ type = "scar_horsearcher", numSquads = unitsPerType, sgroup = sg_camper_units, },
			{ sbp = SBP.MONGOL.BUILDING_WONDER_AGE3_STUPA_MOVING_MON, sgroup = sg_camper_buildings, numSquads = 1, },
			{ sbp = SBP.MONGOL.BUILDING_UNIT_RANGED_MOVING_MON, sgroup = sg_camper_buildings, numSquads = 1, },
			{ sbp = SBP.MONGOL.BUILDING_UNIT_INFANTRY_MOVING_MON, sgroup = sg_camper_buildings, numSquads = 1, },
			{ sbp = SBP.MONGOL.BUILDING_UNIT_CAVALRY_MOVING_MON, sgroup = sg_camper_buildings, numSquads = 1, },
		},
	})
	
	-- These lines expose at least two fairly bad bugs that we don't have time to look at right now
	-- Please preserve for future investigation
	--Cmd_FormationMove(sg_camper_units, mkr_song_post_1, false)
	--Cmd_FormationMove(sg_camper_buildings, mkr_song_post_1, false)
	
	MissionOMatic_SGroupCommandDelayed(sg_camper_units, {mkr_road_patrol_6, mkr_road_patrol_3, mkr_mongol_campdest_2c}, false, 1)
	MissionOMatic_SGroupCommandDelayed(sg_camper_buildings, {mkr_road_patrol_6, mkr_road_patrol_3, mkr_mongol_campdest_2b}, false, 1)
	
	-- Spawn the WESTWARD camp
	local mongol_campers_west = SGroup_CreateUnique("mongol_campers_west")
	sg_camper_buildings = SGroup_CreateUnique("sg_camper_buildings")
	sg_camper_units = SGroup_CreateUnique("sg_camper_units")
	Action_SpawnUnits_Do({
		player = g_playerMongol,
		spawnLocation = mkr_mongol_campers_west,
		sgroup = mongol_campers_west,
		units = {
			{ type = "scar_spearman", numSquads = unitsPerType, sgroup = sg_camper_units, },
			{ type = "scar_manatarms", numSquads = unitsPerType, sgroup = sg_camper_units, },
			{ type = "scar_archer", numSquads = unitsPerType, sgroup = sg_camper_units, },
			{ type = "scar_knight", numSquads = unitsPerType, sgroup = sg_camper_units, },
			{ type = "scar_horsearcher", numSquads = unitsPerType, sgroup = sg_camper_units, },
			{ sbp = SBP.MONGOL.BUILDING_TECH_UNIT_INFANTRY_MOVING_MON, sgroup = sg_camper_buildings, numSquads = 1, },
			{ sbp = SBP.MONGOL.BUILDING_UNIT_RANGED_MOVING_MON, sgroup = sg_camper_buildings, numSquads = 1, },
			{ sbp = SBP.MONGOL.BUILDING_UNIT_INFANTRY_MOVING_MON, sgroup = sg_camper_buildings, numSquads = 1, },
			{ sbp = SBP.MONGOL.BUILDING_UNIT_CAVALRY_MOVING_MON, sgroup = sg_camper_buildings, numSquads = 1, },
		},
	})
	
	-- These lines expose at least two fairly bad bugs that we don't have time to look at right now
	-- Please preserve for future investigation
	--Cmd_FormationMove(sg_camper_units, mkr_road_patrol_3, false)
	--Cmd_FormationMove(sg_camper_buildings, mkr_road_patrol_3, false)
	
	MissionOMatic_SGroupCommandDelayed(sg_camper_units, {mkr_road_patrol_6, mkr_road_patrol_3, mkr_mongol_campdest_3c}, false, 1)
	MissionOMatic_SGroupCommandDelayed(sg_camper_buildings, {mkr_road_patrol_6, mkr_road_patrol_3, mkr_mongol_campdest_3b}, false, 1)
	
	-- Call to action: The Eastern army has arrived with supplies!
	Sound_Play2D("mus_stinger_campaign_triumph_short")
	EventCues_CallToAction("$11189197", CTA_CELEBRATE, EVENTS.Setup_Camp, nil, mongol_campers_east, 180)
	
end

--? @shortdesc Tries to figure out how many things we can spawn in as player camps without breaking popcap
function Xiangyang1267_CalcSpawns(spawnsAfterThis, buildingCount)

	local groupSizeGoal = 30
	local leeway = 190 - (spawnsAfterThis * groupSizeGoal)
	local targetPop = groupSizeGoal + Player_GetCurrentPopulation(g_playerMongol, CT_Personnel)
	local finalPop = math.min(leeway, targetPop)
	
	local unitsToBuild = finalPop - buildingCount - Player_GetCurrentPopulation(g_playerMongol, CT_Personnel)
	if unitsToBuild <= 0 then
		print(string.format("XIANGYANG: unitsToBuild=0, leeway %s, targetPop %s, finalPop %s, playerPop %s)", leeway, targetPop, finalPop, Player_GetCurrentPopulation(g_playerMongol, CT_Personnel)))
		return { spawnsCavalry = 0, spawnsInfantry = 0, }
	end
	
	local result = { spawnsCavalry = (unitsToBuild / 2) * 0.4, spawnsInfantry = (unitsToBuild * 0.6) / 3, }
	
	print(string.format("XIANGYANG: leeway %s, targetPop %s, finalPop %s, playerPop %s)", leeway, targetPop, finalPop, Player_GetCurrentPopulation(g_playerMongol, CT_Personnel)))
	print(string.format("XIANGYANG: unitsToBuild=%s, total %s, %s (Math: %s - %s - %s)", unitsToBuild, result.spawnsCavalry, result.spawnsInfantry, targetPop, buildingCount, Player_GetCurrentPopulation(g_playerMongol, CT_Personnel)))
	return result
	
end

--? @shortdesc Launches a small sally from the city
function Xiangyang1267_SmallPokeAttack(context, data)
	
	if g_stopSpawingRaiders ~= true and g_finalWaveInitialized ~= true then
		
		Player_GetAll(g_playerMongol)
		local randomPlayerBuilding = EGroup_GetRandomSpawnedEntity(eg_allentities)
		if scartype(randomPlayerBuilding) == ST_ENTITY then
			local songPokePos = Util_GetPosition(randomPlayerBuilding)
			Raiding_TriggerRaid(songPokePos, true)
			print(string.format("SONG FORTRESS: Poke attack on position of entity %s", randomPlayerBuilding))
			return
		end
		
		local randomTarget = Table_GetRandomItem({ mkr_village_2, mkr_village_3, mkr_village_4, mkr_village_5, mkr_village_6, })
		Raiding_TriggerRaid(randomTarget, true)
		print(string.format("SONG FORTRESS: Poke attack on marker %s", randomTarget))
	end
	
end

--? @shortdesc Reveal a path through the woods
function Xiangyang1267_RevealWoods(context, data)
	if EGroup_IsOnScreen(g_playerMongol, eg_spotter_lumbermill, ANY) then
		FOW_RevealArea(Util_GetPosition(mkr_reveal_woods), Marker_GetProximityRadiusOrDefault(mkr_reveal_woods, 0), 20)
		Rule_RemoveMe()
	end
end

--? @shortdesc Tests whether the western camp location has been occupied
function Xiangyang1267_BridgeheadRatioWest(bigRange, includeAllies)
	
	local checkRange = Marker_GetProximityRadiusOrDefault(mkr_bridgehead_1, 125)
	if bigRange == true then
		checkRange = 125
	end
	
	local allyBonus = 0
	if includeAllies == true then
		SGroup_Clear(sg_temp)
		Player_GetAllSquadsNearMarker(g_playerAllies, sg_temp, mkr_bridgehead_1, checkRange)
		allyBonus = SGroup_CountPopulation(sg_temp)
	end
	
	SGroup_Clear(sg_temp)
	Player_GetAllSquadsNearMarker(g_playerMongol, sg_temp, mkr_bridgehead_1, checkRange)
	
	minimumRatio = minimumRatio or 0
	local realRatio = (SGroup_CountPopulation(sg_temp) + allyBonus) / g_bridgeheadDenominator
	local adjustedRatio = (realRatio - minimumRatio) / (1.0 - minimumRatio)
	return adjustedRatio
end

