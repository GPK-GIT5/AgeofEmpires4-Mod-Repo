--? @shortdesc Triggers an initial breakthrough from Fancheng, and starts the bridge repair
function Xiangyang1267_TriggerWarningSally()
	
	-- Start one wave right away
	Rule_AddOneShot(Xiangyang1267_LaunchFinaleWave, 0)
	-- Unlock the gates, so the villagers can work
	Missionomatic_SetGateLock(eg_songCityGates, false)
	-- But unlocking takes a second or two because reasons, so delay the repair slightly
	Rule_AddOneShot(Xiangyang1267_StartBridgeRepair, 2)
	
end

--? @shortdesc Triggers the final assault against the Mongols from the cities of Fancheng and Xiangyang
function Xiangyang1267_InitFinalSally()
	
	if g_finalWaveInitialized == true then
		return
	end
		
	-- New sally stage
	g_finalWaveInitialized = true
	
	-- We re-locked the gates at the start of this primary objective, so re-unlock them now!
	Missionomatic_SetGateLock(eg_songCityGates, false)
	
	-- Figure out what we're sending
	g_finalSallySplit = 0
	g_finaleValidDirections = {}
	OBJ_ContainFinalSally.allSallies = {}
	sg_all_sally_ever = SGroup_CreateIfNotFound("sg_all_sally_ever")
	
	local westCamp = Objective_IsComplete(SOBJ_SurroundWest)
	if westCamp == true then 
		g_finalSallySplit = g_finalSallySplit + 1
		table.insert(g_finaleValidDirections, SALLY_WEST)
	end
	
	local northCamp = Objective_IsComplete(SOBJ_SurroundNorth)
	if northCamp == true then
		g_finalSallySplit = g_finalSallySplit + 1
		table.insert(g_finaleValidDirections, SALLY_NORTH)
	end
	
	local eastCamp = Objective_IsComplete(SOBJ_SurroundSouth)
	if eastCamp == true then
		g_finalSallySplit = g_finalSallySplit + 1
		table.insert(g_finaleValidDirections, SALLY_EAST)
	end
	
	-- Debug; this happens if we cheat our way through the objective, but should never happen otherwise
	if (westCamp == false and northCamp == false and eastCamp == false) then
		print("SONG FORTRESS: No camps at all, proceeding under assumption of debug cheating")
		westCamp = true
		northCamp = true
		eastCamp = true
		g_finalSallySplit = 3
		g_finaleValidDirections = { SALLY_WEST, SALLY_NORTH, SALLY_EAST, }
	end
	
	-- Setup what types will go where
	local enemiesMelee = { "scar_spearman", "scar_manatarms", "scar_spearman", "scar_manatarms", }
	local enemiesRanged = { "scar_archer", "scar_repeater_crossbow", "scar_archer", "scar_repeater_crossbow", }
	
	-- Some Chinese ranged units are especially challenging to deal with if players aren't paying close enough attention
	-- So reserve those for higher difficulty settings
	if Game_GetSPDifficulty() == GD_HARD then
		enemiesRanged = { "scar_archer", "scar_grenadier", "scar_archer", "scar_repeater_crossbow", }
	elseif Game_GetSPDifficulty() == GD_EXPERT then
		enemiesRanged = { "scar_archer", "scar_crossbowman", "scar_grenadier", "scar_repeater_crossbow", }
	end
	
	-- TODO: Ensure there are more ranged types if there are 
	local rangedPerDirection = 4 - g_finalSallySplit
	local perTypeRatio = 1 / (rangedPerDirection + 1)
	
	-- Set up the RovingArmy data that will be cloned
	g_finalSallyDirections = {}
	-- West
	if westCamp == true then
		local typeMelee = Table_GetRandomItem(enemiesMelee, 1)
		Table_RemoveFirstItem(enemiesMelee, typeMelee)
		local typeRanged1 = Table_GetRandomItem(enemiesRanged, 1)
		Table_RemoveFirstItem(enemiesRanged, typeRanged1)
		
		g_finalSallyDirections[SALLY_WEST] = {
			descriptor = "SongSallyWest",
			type = "RovingArmy",
			player = g_playerSong,
			spawnLocation = mkr_song_finale_1,
			units = {
				{ type = typeMelee, numSquads = perTypeRatio, },
				{ type = typeRanged1, numSquads = perTypeRatio, },
			},
			idleTimeOverride = 0,
			targetingType = ARMY_TARGETING_PROX,
			targets = {
				mkr_bridgehead_1,
				mkr_bridgehead_2,
				mkr_bridgehead_3,
			},
			combatRange = 50,
			leashRange = 60,
			preVictoryFunction = Xiangyang1267_FinalWaveAreaComplete,
			onDeathFunction = Xiangyang1267_FinalWaveDeath,
		}
		if rangedPerDirection > 1 then
			local typeRanged2 = Table_GetRandomItem(enemiesRanged, 1)
			Table_RemoveFirstItem(enemiesRanged, typeRanged2)
			table.insert(g_finalSallyDirections[SALLY_WEST].units, { type = typeMelee, numSquads = perTypeRatio, })
		end
		if rangedPerDirection > 2 then
			local typeRanged3 = Table_GetRandomItem(enemiesRanged, 1)
			Table_RemoveFirstItem(enemiesRanged, typeRanged3)
			table.insert(g_finalSallyDirections[SALLY_WEST].units, { type = typeMelee, numSquads = perTypeRatio, })
		end
	end
	-- North
	if northCamp == true then
		local typeMelee = Table_GetRandomItem(enemiesMelee, 1)
		Table_RemoveFirstItem(enemiesMelee, typeMelee)
		local typeRanged1 = Table_GetRandomItem(enemiesRanged, 1)
		Table_RemoveFirstItem(enemiesRanged, typeRanged1)
		
		g_finalSallyDirections[SALLY_NORTH] = {
			descriptor = "SongSallyNorth",
			type = "RovingArmy",
			player = g_playerSong,
			spawnLocation = mkr_song_finale_2,
			units = {
				{ type = typeMelee, numSquads = perTypeRatio, },
				{ type = typeRanged1, numSquads = perTypeRatio, },
			},
			idleTimeOverride = 0,
			targetingType = ARMY_TARGETING_PROX,
			targets = {
				mkr_bridgehead_2,
				mkr_bridgehead_3,
				mkr_bridgehead_1,
			},
			combatRange = 50,
			leashRange = 60,
			preVictoryFunction = Xiangyang1267_FinalWaveAreaComplete,
			onDeathFunction = Xiangyang1267_FinalWaveDeath,
		}
		if rangedPerDirection > 1 then
			local typeRanged2 = Table_GetRandomItem(enemiesRanged, 1)
			Table_RemoveFirstItem(enemiesRanged, typeRanged2)
			table.insert(g_finalSallyDirections[SALLY_NORTH].units, { type = typeMelee, numSquads = perTypeRatio, })
		end
		if rangedPerDirection > 2 then
			local typeRanged3 = Table_GetRandomItem(enemiesRanged, 1)
			Table_RemoveFirstItem(enemiesRanged, typeRanged3)
			table.insert(g_finalSallyDirections[SALLY_NORTH].units, { type = typeMelee, numSquads = perTypeRatio, })
		end
	end
	-- East
	if eastCamp == true then
		local typeMelee = Table_GetRandomItem(enemiesMelee, 1)
		Table_RemoveFirstItem(enemiesMelee, typeMelee)
		local typeRanged1 = Table_GetRandomItem(enemiesRanged, 1)
		Table_RemoveFirstItem(enemiesRanged, typeRanged1)
		
		g_finalSallyDirections[SALLY_EAST] = {
			descriptor = "SongSallyEast",
			type = "RovingArmy",
			player = g_playerSong,
			spawnLocation = mkr_song_finale_3,
			units = {
				{ type = typeMelee, numSquads = perTypeRatio, },
				{ type = typeRanged1, numSquads = perTypeRatio, },
			},
			idleTimeOverride = 0,
			targetingType = ARMY_TARGETING_PROX,
			targets = {
				mkr_bridgehead_3,
				mkr_bridgehead_2,
				mkr_bridgehead_1,
			},
			combatRange = 50,
			leashRange = 60,
			preVictoryFunction = Xiangyang1267_FinalWaveAreaComplete,
			onDeathFunction = Xiangyang1267_FinalWaveDeath,
		}
		if rangedPerDirection > 1 then
			local typeRanged2 = Table_GetRandomItem(enemiesRanged, 1)
			Table_RemoveFirstItem(enemiesRanged, typeRanged2)
			table.insert(g_finalSallyDirections[SALLY_EAST].units, { type = typeMelee, numSquads = perTypeRatio, })
		end
		if rangedPerDirection > 2 then
			local typeRanged3 = Table_GetRandomItem(enemiesRanged, 1)
			Table_RemoveFirstItem(enemiesRanged, typeRanged3)
			table.insert(g_finalSallyDirections[SALLY_EAST].units, { type = typeMelee, numSquads = perTypeRatio, })
		end
	end
	
	-- What will the unit count structures be like?
	g_waveStructure = {}
	g_waveStructure[1] = {
		unitCount = g_finalWaveTotalSize * (2/20),
		splitMax = 1,
		fixedDirs = {
			SALLY_WEST,
		}
	}
	g_waveStructure[2] = {
		unitCount = g_finalWaveTotalSize * (3/20),
		splitMax = 3,
	}
	g_waveStructure[3] = {
		unitCount = g_finalWaveTotalSize * (4/20),
		splitMax = 1,
	}
	g_waveStructure[4] = {
		unitCount = g_finalWaveTotalSize * (5/20),
		splitMax = 2,
	}
	g_waveStructure[5] = {
		unitCount = g_finalWaveTotalSize * (6/20),
		splitMax = 3,
	}
	
	OBJ_ContainFinalSally.wavesMax = 10
	
end

--? @shortdesc Manages the launching of final sallies
function Xiangyang1267_LaunchFinaleWave(context, data)
	
	-- Sally indices
	g_sallyIndex = g_sallyIndex or 1
	-- Manage wave succession and end
	if g_waveIndex ~= nil then
		g_waveIndex = g_waveIndex + 1
		if g_waveIndex > #g_waveStructure then
			g_readyToCheckVictory = true
			Rule_RemoveMe()
			return
		end
	else
		g_waveIndex = 1
	end
	
	-- Also
	local unitsPerCamp = g_waveStructure[g_waveIndex].unitCount / g_finalSallySplit
	print(string.format("XIANGYANG: Launching sally wave %s with %s units per camp, total %s", g_waveIndex, unitsPerCamp, g_waveStructure[g_waveIndex].unitCount))

	-- How many directions this time?
	local countDir = g_waveStructure[g_waveIndex].splitMax
	if countDir > g_finalSallySplit then
		countDir = g_finalSallySplit
	end
	
	local currentDirections = {}
	
	-- If we're providing fixed directions, use those directly and assume they match  the split count
	if scartype(g_waveStructure[g_waveIndex].fixedDirs) == ST_TABLE then
		currentDirections = g_waveStructure[g_waveIndex].fixedDirs
		
	-- Otherwise, pick a random set of them
	else
		print("XIANGYANG: Picking directions...")
		local directionsCopy = Table_Copy(g_finaleValidDirections)
		for idx = 1, countDir do
			local thisDirection = Table_GetRandomItem(directionsCopy)
			Table_RemoveFirstItem(directionsCopy, thisDirection)
			table.insert(currentDirections, thisDirection)
			print(string.format("XIANGYANG: Picked %s", thisDirection))
			if #directionsCopy <= 0 then
				break
			end
		end
	end
	
	-- These will be used for the reveal
	local sgroupsToReveal = {}
	local thisWholeSally = SGroup_CreateUnique("sg_final_sally_wave_"..tostring(g_waveIndex))
	-- Now for each of those, make an army and launch it!
	for index, sally in pairs(currentDirections) do
		-- Get and adjust the sally data
		local sallyData = Table_Copy(g_finalSallyDirections[sally])
		sallyData.descriptor = sallyData.descriptor..tostring(g_sallyIndex)
		sallyData.sgroup = SGroup_CreateUnique(sallyData.descriptor)
		
		for index, unitType in pairs(sallyData.units) do
			unitType.numSquads = unitType.numSquads * unitsPerCamp
		end
		
		print(string.format("XIANGYANG: Preparing sally %s", sallyData.descriptor))
		local thisSally = RovingArmy_Init(sallyData)
		table.insert(OBJ_ContainFinalSally.allSallies, thisSally)
		table.insert(sgroupsToReveal, sallyData.sgroup)
		SGroup_AddGroup(thisWholeSally, sallyData.sgroup)
		ThreatArrow_CreateGroup("enemy squad", sallyData.sgroup)
		g_sallyIndex = g_sallyIndex + 1
		
	end
	
	-- Set up the reveal
	local timeUnderFOW = 5
	Rule_AddOneShot(Xiangyang1267_DelayedReveal, timeUnderFOW, { fullSGroup = thisWholeSally, splitSGroups = sgroupsToReveal, })
	
	-- Also add to what we're using to check victory
	SGroup_AddGroup(sg_all_sally_ever, thisWholeSally)
	
	-- Wrap up
	print("XIANGYANG: Sally launched!")
	
end

--? @shortdesc Reveal the units after their speed boost ends
function Xiangyang1267_DelayedReveal(context, data)
	
	MissionOMatic_RevealMovingSGroup(data.fullSGroup)
	
	--Also play audio on the individual SGroups
	for index, sgroup in pairs(data.splitSGroups) do
		if SGroup_Count(sgroup) > 0 then
			Sound_PlayWallaChargeOnSGroup(sgroup)
			print(string.format("WALLA: Playing walla on final sally SGroup: %s", SGroup_GetName(sgroup)))
		end
	end
end

--? @shortdesc Called whenever one of the final waves is defeated
function Xiangyang1267_FinalWaveAreaComplete(rovingArmy)
	
	if rovingArmy == nil or rovingArmy.sgroup == nil or SGroup_Count(rovingArmy.sgroup) <= 0 then
		print("Invalid army attempting to trigget preVictoryFunction!")
		return
	end
	
	-- Search the surrounding area for a new target
	Player_GetAllSquadsNearMarker(g_playerMongol, sg_temp, Util_GetPosition(rovingArmy.sgroup), g_bridgeheadBuffer)
	if SGroup_Count(sg_temp) <= 0 then
		return
	end
	
	-- If there are player units nearby that aren't dead, target them
	local areaSearchTarget = SGroup_CreateUnique("area_search")
	SGroup_AddGroup(areaSearchTarget, sg_temp)
	-- We're using skipTransition to make sure it doesn't automatically start the next target
	-- Because the next target WON'T be the one we just added
	-- This being PRE-victory, this function will get called BEFORE _RovingArmy_OnEncounterSuccessAttack calls _RovingArmy_UpdateTarget
	-- And we need _RovingArmy_UpdateTarget to happen for this new target to be resolved into the next target
	RovingArmy_AddTarget(rovingArmy, areaSearchTarget, nil, nil, true)
	print(string.format("SONG FORTRESS: %s added new target of %s player units", rovingArmy.descriptor, SGroup_Count(areaSearchTarget)))
	
end

--? @shortdesc Called whenever one of the final waves is defeated
function Xiangyang1267_FinalWaveDeath()
	
	OBJ_ContainFinalSally.wavesDefeated = OBJ_ContainFinalSally.wavesDefeated + 1
	Objective_SetProgressBar(OBJ_ContainFinalSally, OBJ_ContainFinalSally.wavesDefeated / OBJ_ContainFinalSally.wavesMax)
	Sound_Play2D("sfx_campaign_scripted_large_group_celebrate")
	
end
	
--? @shortdesc Checks for the player being pushed out of all three zones
function Xiangyang1267_CheckPlayerDefeat()
	
	local ratioWarn = 0.5
	local ratioFail = 0.1
	
	-- Operate the timers
	g_timeCheckLast = g_timeCheckLast or World_GetGameTime()
	g_timeCheckNow = World_GetGameTime()
	local elapsedTime = (g_timeCheckNow - g_timeCheckLast)
	
	-- Make sure we can't warn the player too often, or it'll get irritating
	g_bridgeheadWarningTimer = g_bridgeheadWarningTimer or 0
	if g_bridgeheadWarningTimer > 0 then
		g_bridgeheadWarningTimer = g_bridgeheadWarningTimer - elapsedTime
		g_timeCheckLast = g_timeCheckNow
	end
	
	-- Check the west
	local ratioWest = Xiangyang1267_BridgeheadRatioWest(true, true)
	if ratioWest <= ratioWarn and g_bridgeheadWarningTimer <= 0 then
		if ratioWest >= ratioFail then
			Xiangyang1267_WarnAboutBridgehead("$11197410")
			g_bridgeheadWarningTimer = 10
		end
		if g_failFlashWest == nil then
			g_failFlashWest = UI_FlashObjectiveIcon(SOBJ_SurroundWest.ID, false)
		end
	elseif ratioWest > ratioWarn and g_failFlashWest ~= nil then
		UI_StopFlashing(g_failFlashWest)
		g_failFlashWest = nil
	end
	
	-- Check the north
	local ratioNorth = Xiangyang1267_BridgeheadRatioNorth(true, true)
	if ratioNorth <= ratioWarn and ratioNorth >= ratioFail and g_bridgeheadWarningTimer <= 0 then
		if ratioNorth >= ratioFail then
			Xiangyang1267_WarnAboutBridgehead("$11197411")
			g_bridgeheadWarningTimer = 10
		end
		if g_failFlashNorth == nil then
			g_failFlashNorth = UI_FlashObjectiveIcon(SOBJ_SurroundNorth.ID, false)
		end
	elseif ratioNorth > ratioWarn and g_failFlashNorth ~= nil then
		UI_StopFlashing(g_failFlashNorth)
		g_failFlashNorth = nil
	end
	
	-- Check the south
	local ratioEast = Xiangyang1267_BridgeheadRatioSouth(true, true)
	if ratioEast <= ratioWarn and ratioEast >= ratioFail and g_bridgeheadWarningTimer <= 0 then
		if ratioEast >= ratioFail then
			Xiangyang1267_WarnAboutBridgehead("$11197412")
			g_bridgeheadWarningTimer = 10
		end
		if g_failFlashSouth == nil then
			g_failFlashSouth = UI_FlashObjectiveIcon(SOBJ_SurroundSouth.ID, false)
		end
	elseif ratioNorth > ratioWarn and g_failFlashSouth ~= nil then
		UI_StopFlashing(g_failFlashSouth)
		g_failFlashSouth = nil
	end
	
	local inFailState = ratioWest < ratioFail or ratioNorth < ratioFail or ratioEast < ratioFail
	
	-- Manage the failure grace period failure timer
	if inFailState == true then
		
		g_failGraceLeft = g_failGraceLeft - elapsedTime
		
		if g_failGraceTimerActive ~= true then
			-- Update the objective
			Obj_SetTitle(OBJ_ContainFinalSally.ID, "$11198632")
			Objective_StartTimer(OBJ_ContainFinalSally, COUNT_DOWN, g_failGracePeriod, g_failGracePeriod / 4)
			
			-- Also issue a final, timed warning
			if ratioWest < ratioFail then
				Xiangyang1267_WarnAboutBridgehead("$11198629")
			elseif ratioNorth < ratioFail then
				Xiangyang1267_WarnAboutBridgehead("$11198630")
			elseif ratioEast < ratioFail then
				Xiangyang1267_WarnAboutBridgehead("$11198631")
			end
			
			-- And activate the flag for later
			g_failGraceTimerActive = true
			
		end
		
	elseif g_failGraceTimerActive == true then
		g_failGraceLeft = g_failGracePeriod
		g_failGraceTimerActive = false
		Objective_StopTimer(OBJ_ContainFinalSally)
		Obj_SetTitle(OBJ_ContainFinalSally.ID, "$11179232")
	end
	
	if g_failGraceLeft <= 0 then
		print("g_failGraceLeft <= 0")
	end
	
	if (Objective_IsTimerSet(OBJ_ContainFinalSally) and Objective_GetTimerSeconds(OBJ_ContainFinalSally) <= 0) then
		print("Objective_GetTimerSeconds(OBJ_ContainFinalSally) <= 0")
	end
	
	return inFailState and (Objective_IsTimerSet(OBJ_ContainFinalSally) and Objective_GetTimerSeconds(OBJ_ContainFinalSally) <= 0)
	
end

--? @shortdesc Sends a few villagers to repair the bridges from Xiangyang
function Xiangyang1267_StartBridgeRepair(context, data)

	EGroup_SetInvulnerable(eg_southern_bridges, true)
	
	-- Try for the first bridge
	if EGroup_Count(eg_southern_bridges) >= 1 then
		sg_repair_1 = SGroup_CreateUnique("sg_repair_1")
		local eg_bridge_1 = EGroup_CreateUnique("")
		EGroup_Add(eg_bridge_1, EGroup_GetEntityAt(eg_southern_bridges, 1))
		UnitEntry_DeploySquads(g_playerSong, sg_temp, {
			{type = "scar_villager", numSquads = 2, spawn = mkr_bridge_repair_1, sgroup = sg_repair_1},
		}, mkr_bridge_repair_1)
		Cmd_Ability(sg_repair_1, BP_GetAbilityBlueprint("villager_repair"), eg_bridge_1)
		SGroup_SetInvulnerable(sg_repair_1, true)
	else
		print("OH NO - There isn't 1 bridge to the south of the cities anymore")
	end
	
	-- Now try for the second bridge
	if EGroup_Count(eg_southern_bridges) >= 2 then
		sg_repair_2 = SGroup_CreateUnique("sg_repair_2")
		local eg_bridge_2 = EGroup_CreateUnique("")
		EGroup_Add(eg_bridge_2, EGroup_GetEntityAt(eg_southern_bridges, 2))
		UnitEntry_DeploySquads(g_playerSong, sg_temp, {
				{type = "scar_villager", numSquads = 2, spawn = mkr_bridge_repair_2, sgroup = sg_repair_2},
			}, mkr_bridge_repair_2)
		Cmd_Ability(sg_repair_2, BP_GetAbilityBlueprint("villager_repair"), eg_bridge_2)
		SGroup_SetInvulnerable(sg_repair_2, true)
	else
		print("OH NO - There aren't 2 bridges to the south of the cities anymore")
	end
	
	-- Flag this for later
	g_bridgesRepaired = true
	
end

--? @shortdesc This is a workaround due to a buggy bridge repair issue
function Xiangyang1267_BridgeRepairWorkaround(context, data)
	
	if EGroup_GetAvgHealth(data.bridge) >= 1.0 then
		Rule_RemoveMe()
		return
	end
	
	if SGroup_IsIdle(data.villagers) == true then
		Cmd_Ability(data.villagers, BP_GetAbilityBlueprint("villager_repair"), data.bridge)
	end
	
end

--? @shortdesc Watches for the setup of a group of Mongol buildings
function Xiangyang1267_WatchForSetup(context, data)
	
	if data.timer <= 0 or EGroup_Count(data.egroup) <= 0 then
		if scartype(data.func) == ST_FUNCTION then
			data.func()
		end
		print("ARMIES: Arrived by timeout!")
		Rule_RemoveMe()	
	end
	
	data.timer  = data.timer - 1
	
	local totalUnpacked = 0
	local _IsUnpacked = function(gid, idx, eid)
		if Entity_IsValid(Entity_GetID(eid)) and Entity_IsOfType(eid, "mobile_building") == false then
			totalUnpacked = totalUnpacked + 1
		end
	end
	EGroup_ForEach(data.egroup, _IsUnpacked)
	
	if totalUnpacked >= EGroup_Count(data.egroup) then
		if scartype(data.func) == ST_FUNCTION then
			Rule_AddOneShot(data.func, data.delay)
		end
		print("ARMIES: Arrived by setup!")
		Rule_RemoveMe()
	end
	
end

--? @shortdesc Issues a warning to the player about one of the bridgeheads being near loss
function Xiangyang1267_WarnAboutBridgehead(warningLoc)
	
	local currentTime = World_GetGameTime()
	local elapsedTime = 10
	-- We're using a global timer to prevent overlaps
	if g_failWarningGlobalTimer == nil then
		g_failWarningGlobalTimer = currentTime
	else
		elapsedTime = currentTime - g_failWarningGlobalTimer
	end
	
	if elapsedTime >= 10 then
		UI_CreateEventCue(Loc_FormatText(warningLoc, g_failGraceLeft), Loc_Empty(), "high_priority_negative", "", "sfx_ui_event_queue_campaign_high_priority_negative_play", ECV_Title)
		g_failWarningGlobalTimer = currentTime
	end
end

function Xiangyang1267_DelayedAutoSave(context, data)
	Util_AutoSave()
end