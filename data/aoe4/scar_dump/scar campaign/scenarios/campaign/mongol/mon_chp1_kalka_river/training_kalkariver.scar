function Tutorials_Kalka_ControlGroups()

	sg_currentSelection = SGroup_CreateIfNotFound("sg_currentSelection")
	
	local goal_bandbox_selection = "bandbox_selection_kalka"
	
	if UI_IsXboxControllerUI() then -- Xbox
		
		-- Control Groups
		local controlGroupGoal = Training_Goal("Squad", 
			{ID= "Press LT and RT to open the control groups menu. Here you can assign a group of units to a control group and easily command large forces.",
				Message="$1001160", DataTemplate="GenericTrainingDataTemplate"}, UserHasCreatedAnyControlGroup)
	
		local bandBoxSelectGoalSequence = Training_GoalSequence(goal_bandbox_selection,
			1, 0, 
			UserHasMultipleUnitsOnScreen,
			CampaignTraining_TimeoutIgnorePredicate, 
			nil, 
			UserHasCreatedAnyControlGroup,
			false, 
			{controlGroupGoal})
		Training_AddGoalSequence(bandBoxSelectGoalSequence)
		
	else -- KBM
		
		-- Control Groups
		local controlGroupGoal = Training_Goal("Squad", 
			{ID= "Selected units can be moved in groups.Press CTRL + [0-9] to create a Control Group.", Message="$11184916", DataTemplate="GenericTrainingDataTemplate"}, 
			UserHasCreatedAnyControlGroup)

		local bandBoxSelectGoalSequence = Training_GoalSequence(goal_bandbox_selection,
			1, 0, 
			UserHasMultipleUnitsOnScreen,
			CampaignTraining_TimeoutIgnorePredicate, 
			nil, 
			UserHasCreatedAnyControlGroup,
			false, 
			{controlGroupGoal})
		Training_AddGoalSequence(bandBoxSelectGoalSequence)
		
	end
end

function Tutorials_Kalka_KhanAbility_Xbox()
	
	Rule_AddGlobalEvent(kalka_OnAbilityExecutedRightTime, GE_AbilityExecuted)
	
	local goalSelectKhan = Training_Goal(
		"Squad", 
		{
			ID = "Leaders have unique abilities they can activate at any time. Press D-Pad Right to select General Subutai.", 
			Message ="$11249016", 
			DataTemplate ="GenericTrainingDataTemplate"
		},
		UserHasSelectedKhan
	)
	
	local GoalOnOpenRadial = Training_Goal(
		"Squad",
		{
			ID = "Hold RT to see General Subutai's abilities.",
			Message = "$11249017",
			DataTemplate = "GenericTrainingDataTemplate",
		},
		UserHasOpenedContextualRadial
	)
	
	local sequenceKhanAbility = Training_GoalSequence(
		"khan_kalka_ability", 
		1,
		0, --repeat max and remind max
		HasIdleKhanOnScreen_Xbox, --trigger
		TimerORIgnore_UserCannotSeeSquadKey, --ignore
		nil, --remind
		UserHasSelectedKhan, --bypass 
		true, --can regress
		{goalSelectKhan, GoalOnOpenRadial}
	)
	Training_AddGoalSequence(sequenceKhanAbility)
	
end

