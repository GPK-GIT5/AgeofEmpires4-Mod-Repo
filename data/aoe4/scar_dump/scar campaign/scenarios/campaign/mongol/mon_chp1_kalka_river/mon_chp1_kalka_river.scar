function Mission_SetRestrictions()
	
	PlayerUpgrades_Auto(player1, true)
	PlayerUpgrades_Auto(player2)
	PlayerUpgrades_Auto(player3)
		
	Kalka_UnlockCavalryUpgrades()
	
end



function Mission_Preset() -- Any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)
	
	PlayerColour_Enable()
	
	Game_SetPlayerSlotColour(player1, 1) --player
	Game_SetPlayerUISlotColour(player1, 1) 
	Game_SetPlayerSlotColour(player2, 2) -- Rus  
	Game_SetPlayerUISlotColour(player2, 2) 
	Game_SetPlayerSlotColour(player3, 1) -- Leader holder  
	Game_SetPlayerUISlotColour(player3, 1)
	
	SetupTheRusAmbush_InitObjectives()
	LureTheRusToAmbush_InitObjectives()
	AmbushAttack_InitObjectives()
	DefeatEnclosedRus_InitObjectives()
	
	
	Player_GetAll(player1, sg_temp)
	SGroup_Filter(sg_temp, SBP.MONGOL.UNIT_SUBUTAI_3_CMP_MON, FILTER_KEEP)
	Modify_AbilityRechargeTime(SGroup_GetSquadAt(sg_temp, 1), BP_GetAbilityBlueprint("khan_attack_speed_signal_arrow_mon"), 0.4, MUT_Multiplication)
	SGroup_RemoveAbility(sg_temp, BP_GetAbilityBlueprint("khan_defensive_signal_arrow_mon"))
--	Modify_AbilityRechargeTime(SGroup_GetSquadAt(sg_temp, 1), BP_GetAbilityBlueprint("khan_defensive_signal_arrow_mon"), 0.4, MUT_Multiplication)
	Modify_AbilityRechargeTime(SGroup_GetSquadAt(sg_temp, 1), BP_GetAbilityBlueprint("khan_maneuver_signal_arrow_mon"), 0.4, MUT_Multiplication)
	subutai_sight_modifier = Modify_SightRadius(sg_temp, 1.7)
	
	-- Control group hint has a kbm and Xbox version
	Rule_AddOneShot(Tutorials_Start_ControlGroup, 8)
	
	Kalka_MoveStartingUnits()
	
	-- Force Music play non-stop when music intensity is locked, allow music to play with silence system when music intensity is unlocked. 
	if Music_UnlockIntensity then
		Sound_SetForceMusic(false)
		else
		Sound_SetForceMusic(true)
		end
	
	
	Music_PersistentStop()	
	
	
	UI_SetPlayerDataContext(player1, { PopulationCapOn = false })
	
end -- Mission_Preset()

function Mission_SetDifficulty()

	t_difficulty = {
		
	}
end

function Tutorials_Start_ControlGroup()
	
	Tutorials_Kalka_ControlGroups()
end

function Mission_Start() -- This is triggered after the intro, just as control is passed to the player
	
	-- on console don't restore econ HUD for this mission 
	Cardinal_EnablePartialXboxUI(true, {VF_XboxUIVillagerPriorities, VF_XboxUIResourceCard})
	
	Player_SetResource( player1, RT_Gold, 0) 
	Player_SetResource( player1, RT_Wood, 0) 
	Player_SetResource( player1, RT_Food, 0)  
	Player_SetResource( player1, RT_Stone,0) 
	
	Objective_Start(OBJ_SetupTheRusAmbush,true, true)
	Objective_Start(OBJ_RusTimer,false,false)
	
	Rule_AddInterval(CheckUnitsLeftKalka,2)
end 

function StartKhanAbilityTuto()
	if b_used_khan_ability == false then
		
		if UI_IsXboxControllerUI() then
			Tutorials_Kalka_KhanAbility_Xbox()
		else
			Tutorials_Kalka_KhanAbility()
		end
		
		Rule_RemoveGlobalEvent(kalka_OnAbilityExecuted)
	end
end

