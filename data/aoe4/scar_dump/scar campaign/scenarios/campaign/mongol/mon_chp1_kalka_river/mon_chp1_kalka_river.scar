function Mission_SetupPlayers()
	
	-- Player IDs
	player1 = World_GetPlayerAt(1)
	player2 = World_GetPlayerAt(2)
	player3 = World_GetPlayerAt(3)
	
	-- Player 1 - Mongols
	Setup_SetPlayerName(player1, Loc_GetString("$11172112")) -- General Subutai
	Player_SetCurrentAge(player1, AGE_FEUDAL)
	Player_SetMaximumAge(player1, AGE_FEUDAL)
	
	-- Player 2 - Mstislav
	Setup_SetPlayerName(player2, Loc_GetString("$11172113")) -- Mstislav
	Player_SetCurrentAge(player2, AGE_FEUDAL)
	Player_SetMaximumAge(player2, AGE_FEUDAL)
	
	-- Player 3 - Subutai
	Setup_SetPlayerName(player3, Loc_GetString("$11172114")) -- Mongols
	Player_SetCurrentAge(player3, AGE_FEUDAL)
	Player_SetMaximumAge(player3, AGE_FEUDAL)
		
	 -- Relationship to player
    Player_SetRelationship(player1, player3, R_ALLY)
    Player_SetRelationship(player3, player1, R_ALLY)
    -- Enemy also needs to consider this player an ally, so they don't attack neutral units
    Player_SetRelationship(player2, player3, R_NEUTRAL)
		
end -- Mission_SetupPlayers()

