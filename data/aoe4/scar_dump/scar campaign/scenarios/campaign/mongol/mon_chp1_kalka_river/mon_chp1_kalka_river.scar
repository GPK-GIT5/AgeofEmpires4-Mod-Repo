--
-- Battle of the Kalka River 1223
--
-- The Mongol Horde, Mission 1
--


import("MissionOMatic/MissionOMatic.scar") -- This imports the Cardinal scripts as well

import("obj_slowdowntherus.scar")
import("obj_setupambush.scar")
