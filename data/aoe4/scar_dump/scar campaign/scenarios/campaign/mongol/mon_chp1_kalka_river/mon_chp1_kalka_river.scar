function Kalka_MoveStartingUnits()
	
	SGroup_SetInvulnerable( sg_roving_rus_scout, true)
	Modify_WeaponEnabled(sg_mon_horsearchers,"hardpoint_01",false)
	
	Cmd_FormationMove(sg_roving_rus_scout, mkr_mainspawn_4_moveto)
	Cmd_FormationMove(sg_roving_rus_scout, mkr_scoutAttack03,true)
	
	-- mangudai
	Cmd_FormationMove(sg_mon_horsearchers, mkr_mainspawn_3_moveto)
	Cmd_FormationMove(sg_mon_horsearchers, mkr_mainspawn_3_moveto_a,true)
	Cmd_FormationMove(sg_mon_horsearchers, mkr_mainspawn_2b_moveto,true)
	Cmd_FormationMove(sg_mon_horsearchers, mkr_mainspawn_ha_movetoFinal,true,false,Marker_GetPosition(mkr_mainspawn_right_facing))
	
	-- right knights
	Cmd_FormationMove(sg_ambush_group_2, mkr_mainspawn_2_moveto)
	Cmd_FormationMove(sg_ambush_group_2, mkr_mainspawn_ha_moveto,true)
	Cmd_FormationMove(sg_ambush_group_2, mkr_mainspawn_3b_movetob,true,false,Marker_GetPosition(mkr_mainspawn_right_facing))
	
	-- central knights
	Cmd_FormationMove(sg_ambush_group_3, mkr_mainspawn_3_moveto)
	Cmd_FormationMove(sg_ambush_group_3, mkr_mainspawn_3_moveto_a,true)
	Cmd_FormationMove(sg_ambush_group_3, mkr_mainspawn_3b_moveto,true)
	Cmd_FormationMove(sg_ambush_group_3, mkr_mainspawn_3b_moveto02,true,false,Marker_GetPosition(mkr_mainspawn_right_facing))
	
	-- left knights
	Cmd_FormationMove(sg_ambush_group_4, mkr_mainspawn_4_moveto) 
	Cmd_FormationMove(sg_ambush_group_4, mkr_mainspawn_3b_moveto02,true)
	Cmd_FormationMove(sg_ambush_group_4, mkr_mainspawn_3b_moveto,true,false,Marker_GetPosition(mkr_mainspawn_left_facing))

	Rule_Add(Monitor_scoutsForAmbush)
	
end

function Monitor_scoutsForAmbush()
	
	if Prox_AreSquadsNearMarker( sg_roving_rus_scout, mkr_intro_ambush, ANY ) then
		
		Rule_AddOneShot(intro_setvulnerable,3)
		Sound_PlayOnSquad(WALLA_CAMP_CHARGE_SMALL, g_leaderSubutai.sgroup)
		Cmd_AttackMove(g_leaderSubutai.sgroup,mkr_mainspawn_khan_moveto)
		
		Cmd_AttackMove(sg_ambush_group_introcam, mkr_scoutAttack03)
		Cmd_AttackMove(sg_ambush02_group_introcam, mkr_scoutAttack03)
		Rule_Add(waitScoutinMiddle)
		Rule_RemoveMe()
		Rule_Add(MonitorScoutDeath)
	end
end

function waitScoutinMiddle()
	if Prox_AreSquadsNearMarker( sg_roving_rus_scout, mkr_scoutAttack03, ANY, 10 ) then

		Cmd_Attack(sg_roving_rus_scout,sg_ambush02_group_introcam )
		
	end
	
end

function intro_setvulnerable()
	SGroup_SetInvulnerable( sg_roving_rus_scout, false)	
	SGroup_SetAvgHealth(sg_roving_rus_scout, 0.1) -- was 0.5
end


function MonitorScoutDeath()
	
	if SGroup_CountSpawned(sg_roving_rus_scout) <= 0 then
		
		-- end point for subutai - delay to avoid clashing with knights
		Rule_AddOneShot(MoveSubutaiAcrossRiver, 1.5)
		
		-- end point for left ambush group
		--Cmd_FormationMove(sg_ambush_group_introcam, mkr_mainspawn_3b_moveto,false,false,Marker_GetPosition(mkr_mainspawn_left_facing))
		Cmd_FormationMove(sg_ambush_group_introcam, mkr_mainspawn_4b_moveto,false,false,Marker_GetPosition(mkr_mainspawn_left_facing))
		
		-- end point for right ambush group
		--Cmd_FormationMove(sg_ambush02_group_introcam, mkr_mainspawn_3b_movetob,false,false,Marker_GetPosition(mkr_mainspawn_right_facing02))
		Cmd_FormationMove(sg_ambush02_group_introcam, mkr_mainspawn_ha_moveto02,false,false,Marker_GetPosition(mkr_mainspawn_right_facing))
		
		Rule_RemoveMe()
		Modify_WeaponEnabled(sg_mon_horsearchers,"hardpoint_01",true)
	end
end

function MoveSubutaiAcrossRiver()
	-- end point for subutai
	Cmd_FormationMove(g_leaderSubutai.sgroup, mkr_khan_ambush_loc,true,false,Marker_GetPosition(mkr_mainspawn_right_facing))
end


function Kalka_UnlockCavalryUpgrades()
	
	print("Cavalry upgrades unlocked")
	Player_CompleteUpgrade(player1, UPG.MONGOL.UPGRADE_MELEE_ARMOR_I_IMPROVED_MON)
	Player_CompleteUpgrade(player1, UPG.MONGOL.UPGRADE_MELEE_DAMAGE_I_IMPROVED_MON)
	Player_CompleteUpgrade(player1, UPG.MONGOL.UPGRADE_RANGED_ARMOR_I_IMPROVED_MON)
	Player_CompleteUpgrade(player1, UPG.MONGOL.UPGRADE_RANGED_DAMAGE_I_IMPROVED_MON)
	
	Player_CompleteUpgrade(player1, UPG.MONGOL.UPGRADE_RANGED_BODKIN_MON)
	Player_CompleteUpgrade(player1, UPG.MONGOL.UPGRADE_RANGED_ARCHER_QUIVVER_MON)
	Player_CompleteUpgrade(player1, UPG.MONGOL.UPGRADE_CAVALRY_GRAPERED_LANCE_MON)

	Player_GetAll(player1)
	EGroup_Filter(eg_allentities, EBP.MONGOL.BUILDING_DEFENSE_OUTPOST_MON, FILTER_KEEP)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS)
	
end

function StartNewParade()
	
	Rule_AddOneShot(ParadeArmy, 3)
	
end

function ParadeArmy()
	
	if Objective_IsComplete(SOBJ_MeetTheRus) == false then 
		
		b_phaseTaken = Table_GetRandomItem(g_commanderPhases)
		
		if Rule_Exists(TriggerCheeringNearKnight) == false then
			KnightPhase02_ID = Rule_AddInterval(TriggerCheeringNearKnight, 2)
		end
		
		if b_phaseTaken == "phase1" then
			
			if previousPhase == nil then
				TransferModuleIntoModule("RovingRusGetLurePos_knighta","RovingRusGetLurePos_knighta_Phase01")
			elseif previousPhase == "phase1" then
				RovingArmy_SetTargets(MissionOMatic_FindModule("RovingRusGetLurePos_knighta_Phase01"),{mkr_rus_Knight_moveright, mkr_rus_Knight_moveleft,mkr_rus_roving_army_Knight_ab1})
			else
				RovingArmy_SetTargets(MissionOMatic_FindModule("RovingRusGetLurePos_knighta_Phase01"),{mkr_rus_Knight_moveright, mkr_rus_Knight_moveleft,mkr_rus_roving_army_Knight_ab1})
				TransferModuleIntoModule("RovingRusGetLurePos_knighta_Phase02","RovingRusGetLurePos_knighta_Phase01")
			end
			previousPhase = "phase1"
				
		else
			if previousPhase == nil then
				TransferModuleIntoModule("RovingRusGetLurePos_knighta","RovingRusGetLurePos_knighta_Phase02")
			elseif previousPhase == "phase2" then
				RovingArmy_SetTargets(MissionOMatic_FindModule("RovingRusGetLurePos_knighta_Phase02"),{mkr_rus_Knight_moveright,mkr_rus_Knight_moverightBack, mkr_rus_Knight_moveright ,mkr_rus_Knight_moveleft,mkr_mainspawn_4_moveto,mkr_rus_Knight_moveleft,mkr_rus_roving_army_Knight_ab1})
			else
				RovingArmy_SetTargets(MissionOMatic_FindModule("RovingRusGetLurePos_knighta_Phase02"),{mkr_rus_Knight_moveright,mkr_rus_Knight_moverightBack, mkr_rus_Knight_moveright ,mkr_rus_Knight_moveleft,mkr_mainspawn_4_moveto,mkr_rus_Knight_moveleft,mkr_rus_roving_army_Knight_ab1})
				TransferModuleIntoModule("RovingRusGetLurePos_knighta_Phase01","RovingRusGetLurePos_knighta_Phase02")
				
			end
			previousPhase = "phase2"
			
		end
	end
	
end

function makeLeaderCheer()
	
	SGroup_EnableCheering(sg_first_army_knight, true, 2, WALLA_CAMP_CELEBRATE_MEDIUM)
	
end

function KnightFirstPhaseShowOff_Phase01()

	SGroup_EnableCheering(sg_first_army_knight, true, 4, WALLA_CAMP_CELEBRATE_MEDIUM)

end

function TriggerCheeringNearKnight(context, data)

	if Objective_IsComplete(SOBJ_MeetTheRus) == true then
		Rule_RemoveMe()
		return
	end
	
	local checkDistance = 15
	
	if Prox_AreSquadsNearMarker(sg_first_army_knight, mkr_rus_Knight_moveright, ALL, checkDistance ) == true then
		SGroup_EnableCheering(sg_rus_army_1, true, 2, WALLA_CAMP_CELEBRATE_MEDIUM)
		
	elseif Prox_AreSquadsNearMarker(sg_first_army_knight, mkr_moveShootCheck, ALL, checkDistance ) == true then
		SGroup_EnableCheering(sg_rus_army_2, true, 2, WALLA_CAMP_CELEBRATE_MEDIUM)
		SGroup_EnableCheering(sg_rus_army_2a, true, 2, WALLA_CAMP_CELEBRATE_MEDIUM)
			
	elseif Prox_AreSquadsNearMarker(sg_first_army_knight, mkr_rus_Knight_moverightBack, ALL, checkDistance ) == true then
		SGroup_EnableCheering(sg_rus_army_3, true, 2, WALLA_CAMP_CELEBRATE_MEDIUM)
		SGroup_EnableCheering(sg_rus_army_3a, true, 2, WALLA_CAMP_CELEBRATE_MEDIUM)
				
	elseif Prox_AreSquadsNearMarker(sg_first_army_knight, mkr_rus_Knight_moveleft, ALL, checkDistance ) == true then
		SGroup_EnableCheering(sg_rus_army_1a, true, 2, WALLA_CAMP_CELEBRATE_MEDIUM)
		SGroup_EnableCheering(sg_rus_army_1b, true, 2, WALLA_CAMP_CELEBRATE_MEDIUM)
					
	elseif Prox_AreSquadsNearMarker(sg_first_army_knight, mkr_mainspawn_1_moveto, ALL, checkDistance ) == true then
		SGroup_EnableCheering(sg_rus_army_2b, true, 2, WALLA_CAMP_CELEBRATE_MEDIUM)
		SGroup_EnableCheering(sg_rus_army_2c, true, 2, WALLA_CAMP_CELEBRATE_MEDIUM)
							
	elseif Prox_AreSquadsNearMarker(sg_first_army_knight, mkr_mainspawn_4_moveto, ALL, checkDistance ) == true then
		SGroup_EnableCheering(sg_rus_army_3b, true, 2, WALLA_CAMP_CELEBRATE_MEDIUM)
		SGroup_EnableCheering(sg_rus_army_3c, true, 2, WALLA_CAMP_CELEBRATE_MEDIUM)
		
	end
	
end


function CheckUnitsLeftKalka()
	
	Player_GetAll(player1,sg_allsquads)
	if SGroup_CountSpawned(sg_allsquads) <= 0 then
		Mission_Fail()
	end
	
end

-- Achievement tracking for Achievement #17 - Twinkle Hooves - Don't lose any Horse Archers
function Achievement_OnSquadKilled(context)
	
	-- Check if squad is valid
	if Squad_IsValid(Squad_GetID(context.victim)) then
		
		-- Check if killed squad belongs to local player and is a Horse Archer
		local owner = Squad_GetPlayerOwner(context.victim)
		if owner == player1 and Squad_IsOfType(context.victim, "scar_horsearcher") then
			
			horseArchersKilled = true
			Rule_RemoveMe()
		end
	end
	
end