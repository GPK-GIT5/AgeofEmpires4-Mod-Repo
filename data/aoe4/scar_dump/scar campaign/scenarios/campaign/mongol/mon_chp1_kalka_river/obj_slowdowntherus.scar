--
-- kalka river 1223 - Objective Lure the Rus(attract them)
--


function LureTheRusToAmbush_InitObjectives()		-- rename this function to use your prefix for this part of the mission

	OBJ_DestroyTheRusUltimate = {
	
		Title = "$11172115",--Destroy the Rus army
		Type = ObjectiveType_Primary,
		Intel_Start = EVENTS.Lure_Rus,
		PreStart = ReDestroyTheRus_preStart,	
		OnStart = ReDestroyTheRus_start,
		OnComplete = DefeatRusUltimate_OnComplete,
	}
	
	SOBJ_MeetTheRus = {
	
		Title = "$11172124", --Use some units to lure the Rus over the river
		Type = ObjectiveType_Primary,
		Parent = OBJ_DestroyTheRusUltimate,
		StartAlongsideParent = false, 
		OnStart = MeetTheRus_Start,
		PreComplete = MeetTheRus_OnComplete,
	}
	
	SOBJ_GetRusToAmbushPt = {
		
		Title = "$11172125", --Lead the Rus army to the ambush point
		Type = ObjectiveType_Primary,
		Parent = OBJ_DestroyTheRusUltimate,
		StartAlongsideParent = false,
		Intel_Start = EVENTS.Rus_Pursuit,
		SetupUI = GetRusToAmbushPt_UI,
		
		PreStart = function()
			
			DissolveModuleIntoModule("RovingRusGetLurePos_knighta", "rus_attack")
			
			DissolveModuleIntoModule("RovingRusGetLurePos_knighta_Phase01", "rus_attack")
			DissolveModuleIntoModule("RovingRusGetLurePos_knighta_Phase02", "rus_attack")
			DissolveModuleIntoModule("RovingRusGetLurePos_Scouta", "rus_attack")
			DissolveModuleIntoModule("RovingRusGetLurePos_Scoutb", "rus_attack")
			DissolveModuleIntoModule("RovingRusGetLurePos", "rus_attack")
			DissolveModuleIntoModule("RovingRusGetLurePos_01a", "rus_attack_a")
			DissolveModuleIntoModule("RovingRusGetLurePos_01b", "rus_attack_b")
			DissolveModuleIntoModule("patrol_area","rus_attack")
			DissolveModuleIntoModule("RovingRusGetLurePos02", "rus_attack02")
			DissolveModuleIntoModule("RovingRusGetLurePos02a", "rus_attack02_a")
			DissolveModuleIntoModule("RovingRusGetLurePos02b", "rus_attack02_b")
			DissolveModuleIntoModule("RovingRusGetLurePos02c", "rus_attack02_c")
			DissolveModuleIntoModule("patrol_area02","rus_attack02")
			DissolveModuleIntoModule("RovingRusGetLurePos03", "rus_attack03")
			DissolveModuleIntoModule("RovingRusGetLurePos03a", "rus_attack03_a")
			DissolveModuleIntoModule("RovingRusGetLurePos03b", "rus_attack03_b")
			DissolveModuleIntoModule("RovingRusGetLurePos03c", "rus_attack03_c")
			
		end,
		
		OnStart = GetRusToAmbushPt_Start,
		OnFail = GetRusToAmbush_Failed,
		OnComplete = GetRusToAmbushPt_OnComplete,
	}
	
	Objective_Register(OBJ_DestroyTheRusUltimate)
	Objective_Register(SOBJ_MeetTheRus)
	Objective_Register(SOBJ_GetRusToAmbushPt)

end


function ReDestroyTheRus_preStart()
	Util_AutoSave()
end

function ReDestroyTheRus_start()
	Music_LockIntensity(MUSIC_EXPLORE_RARE)
	Objective_Start(SOBJ_MeetTheRus,true,true)
	Rule_AddOneShot(Start_Tutorial_MoveShoot,3)
end

function Start_Tutorial_MoveShoot()
	Tutorials_kalkariver_MoveShoot()
end

function DestroyTheRusUltimate_IsFailed()
	
	Player_GetAll(player1,sg_allsquads)
	
	if SGroup_CountSpawned(sg_allsquads) <= 0 then
		return true
	else
		return false
	end
	
end

function DestroyTheRusUltimate_OnFailed()
	Mission_Fail()
end

function MeetTheRus_UI()
	
	hpid_MeetRus = Objective_AddUIElements(SOBJ_MeetTheRus, sg_rus_army_1, true,nil, false, nil, nil, nil)
end 


function MeetTheRus_Start()
	
	local units000a = { 
		{ type = "scar_knight", numSquads = 1,spawn = mkr_rus_roving_army_Knight_spawn_aa1, tag = "first_Rusarmy", sgroup = sg_first_army_knight},
	}
	SpawnUnitsToModule(units000a, "RovingRusGetLurePos_knighta", mkr_rus_roving_army_Knight_spawn_aa1)
	
	local units00a = { 
		{ type = "scar_scout", numSquads = 2,spawn = mkr_rus_spawn_scout_01a, tag = "first_Rusarmy", sgroup = sg_first_army_scout},
	}
	SpawnUnitsToModule(units00a, "RovingRusGetLurePos_Scouta", mkr_rus_spawn_scout_01a)

	local units00b = { 
		{ type = "scar_scout", numSquads = 2,spawn = mkr_rus_spawn_scout_01b, tag = "first_Rusarmy", sgroup = sg_first_army_scout},
	}
	SpawnUnitsToModule(units00b, "RovingRusGetLurePos_Scoutb", mkr_rus_spawn_scout_01b)

	local actionContext = {}
	
	local actionDataFirstRus = {
		module = "RovingRusGetLurePos",
		spawnLocation = mkr_rus_spawn_west_06,
		units = {
			{ type = "scar_spearman",	numSquads = i_Troops01Player2, tag = "first_Rusarmy", sgroup = sg_first_army },
		}, 
	}
		
	Action_SpawnUnitsToModule_Do(actionDataFirstRus, actionContext)	
	
	local units01a = { 
		{ type = "scar_spearman", numSquads = i_Troops01Player2,spawn = mkr_rus_spawn_west_06a, tag = "first_Rusarmy", sgroup = sg_first_army},
	}
	SpawnUnitsToModule(units01a, "RovingRusGetLurePos_01a", mkr_rus_spawn_west_06a)

	local units01b = { 
		{ type = "scar_spearman", numSquads = i_Troops01Player2,spawn = mkr_rus_spawn_west_06b, tag = "first_Rusarmy", sgroup = sg_first_army},
	}
	SpawnUnitsToModule(units01b, "RovingRusGetLurePos_01b", mkr_rus_spawn_west_06b)

	SGroup_AddGroup(sg_rus_global, MissionOMatic_FindModule("RovingRusGetLurePos_knighta").sgroup)
	SGroup_AddGroup(sg_rus_global, MissionOMatic_FindModule("RovingRusGetLurePos_Scouta").sgroup)
	SGroup_AddGroup(sg_rus_global, MissionOMatic_FindModule("RovingRusGetLurePos_Scoutb").sgroup)
	SGroup_AddGroup(sg_rus_global, MissionOMatic_FindModule("RovingRusGetLurePos").sgroup)
	SGroup_AddGroup(sg_rus_global, MissionOMatic_FindModule("RovingRusGetLurePos_01a").sgroup)
	SGroup_AddGroup(sg_rus_global, MissionOMatic_FindModule("RovingRusGetLurePos_01b").sgroup)

	hpid_MeetRus = Objective_AddUIElements(SOBJ_MeetTheRus, sg_first_army, true, nil, false, nil, nil, nil)

	Rule_AddOneShot(SpawnUnitsRus02, 5)
	
	Rule_AddOneShot(StartKhanAbilityTuto,1)

end

function Kalka_ModifyRusSpeed(value)
	
	Player_GetAll(player2)
	Modify_UnitSpeed(sg_allsquads, value)
end

