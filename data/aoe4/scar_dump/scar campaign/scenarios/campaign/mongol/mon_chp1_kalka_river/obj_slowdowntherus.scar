function MeetTheRusMonitor()
	
	if SGroup_CountSpawned(sg_first_army_knight) > 0 then 
		if Prox_ArePlayersNearMarker(player1, SGroup_GetPosition(sg_first_army_knight), ANY, 30) or SGroup_IsUnderAttack(sg_first_army_knight,ANY,1) then
			Rule_RemoveMe()
			Sound_PlayOnSquad(WALLA_CAMP_CHARGE_LARGE,sg_first_army_knight)
			Sound_PlayOnSquad(WALLA_CAMP_CHARGE_LARGE,sg_first_army)
			Sound_PlayOnSquad(WALLA_CAMP_CHARGE_LARGE,sg_second_army)
			Sound_PlayOnSquad(WALLA_CAMP_CHARGE_LARGE,sg_third_army)
			
			if Objective_IsComplete(SOBJ_MeetTheRus) == false then
				Objective_Complete(SOBJ_MeetTheRus)
			end
		end
	end

	if SGroup_CountSpawned(sg_first_army_scout) > 0 then 
		if Prox_ArePlayersNearMarker(player1, SGroup_GetPosition(sg_first_army_scout), ANY, 30) or SGroup_IsUnderAttack(sg_first_army_scout,ANY,1) then
			Rule_RemoveMe()
			Sound_PlayOnSquad(WALLA_CAMP_CHARGE_LARGE,sg_first_army_scout)
			Sound_PlayOnSquad(WALLA_CAMP_CHARGE_LARGE,sg_first_army)
			Sound_PlayOnSquad(WALLA_CAMP_CHARGE_LARGE,sg_second_army)
	
			if Objective_IsComplete(SOBJ_MeetTheRus) == false then
				Objective_Complete(SOBJ_MeetTheRus)
			end
		end
	end

	if SGroup_CountSpawned(sg_first_army) > 0 then 
		if Prox_ArePlayersNearMarker(player1, SGroup_GetPosition(sg_first_army), ANY, 30) or SGroup_IsUnderAttack(sg_first_army,ANY,1) then
			Rule_RemoveMe()
			Sound_PlayOnSquad(WALLA_CAMP_CHARGE_LARGE,sg_first_army)
			Sound_PlayOnSquad(WALLA_CAMP_CHARGE_LARGE,sg_second_army)
			if Objective_IsComplete(SOBJ_MeetTheRus) == false then
				Objective_Complete(SOBJ_MeetTheRus)
			end
		end
	end
	
	if SGroup_CountSpawned(sg_second_army) > 0 then 
		if Prox_ArePlayersNearMarker(player1, SGroup_GetPosition(sg_second_army), ANY, 30) or SGroup_IsUnderAttack(sg_second_army,ANY,1) then
			Rule_RemoveMe()
			Sound_PlayOnSquad(WALLA_CAMP_CHARGE_LARGE,sg_third_army)
			Sound_PlayOnSquad(WALLA_CAMP_CHARGE_LARGE,sg_second_army)
			if Objective_IsComplete(SOBJ_MeetTheRus) == false then
				Objective_Complete(SOBJ_MeetTheRus)
			end
		end
	end
	
	if SGroup_CountSpawned(sg_third_army) > 0 then 
		if Prox_ArePlayersNearMarker(player1, SGroup_GetPosition(sg_third_army), ANY, 30) or SGroup_IsUnderAttack(sg_third_army,ANY,1) then
			Rule_RemoveMe()
			Sound_PlayOnSquad(WALLA_CAMP_CHARGE_LARGE,sg_third_army)
			Sound_PlayOnSquad(WALLA_CAMP_CHARGE_LARGE,sg_second_army)
			if Objective_IsComplete(SOBJ_MeetTheRus) == false then
				Objective_Complete(SOBJ_MeetTheRus)
			end
		end
	end
	
end

function MeetTheRus_OnComplete()
    Music_LockIntensity(MUSIC_COMBAT)
--	Objective_Start(SOBJ_AttackTheRusCavalry,true,true)
	Objective_Start(SOBJ_GetRusToAmbushPt,true,true)
	
	if hpid_MeetRus ~= nil then
		Objective_RemoveUIElements(SOBJ_MeetTheRus,hpid_MeetRus)
	end
	if hpid_MeetRusLoop ~= nil then
		Objective_RemoveUIElements(SOBJ_MeetTheRus,hpid_MeetRusLoop)
	end
	
end


function GetRusToAmbushPt_UI()
	
 hpid_AmbushPt = Objective_AddUIElements(SOBJ_GetRusToAmbushPt, mkr_ambush_pointRiver02_b, true,"$11180183", true, nil, nil)

end

function GetRusToAmbushPt_Start()
	Rule_Add(GetToAmbushPointMonitor)
	Rule_AddInterval(CheckifAllRusKilledEarlyMonitor, 5)
end

---if all enemies are killed before getting to ambush
function CheckifAllRusKilledEarlyMonitor()

	local enemyUnits = SGroup_CountSpawned(sg_rus_global)
	
	if enemyUnits <= earlyKillThreshold then
		if Objective_IsComplete(SOBJ_GetRusToAmbushPt) == false then
			--RusKilledEarly = true
			Objective_Fail(SOBJ_GetRusToAmbushPt,false,false)
		end
		Rule_RemoveMe()
	end
	
end

function GetRusToAmbush_Failed()
	
	Rule_Remove(GetToAmbushPointMonitor)
	Objective_RemoveUIElements(SOBJ_GetRusToAmbushPt, hpid_AmbushPt)
	Objective_Start(SOBJ_KillAllRusAmbushPt, true, true)
	g_ambushFailed = true
	
end

function GetToAmbushPointMonitor()
	
	if Prox_ArePlayersNearMarker(player2, Marker_GetPosition(mkr_ambush_point),ANY,100,SBP.RUS.UNIT_SCOUT_1_RUS,FILTER_REMOVE) then
		Rule_RemoveMe()

		Objective_Complete(SOBJ_GetRusToAmbushPt)
		Rule_Remove(CheckifAllRusKilledEarlyMonitor)
	end
	
end

function GetRusToAmbushPt_OnComplete()
	Util_StartIntel(EVENTS.Rus_Ambush)
	
	Objective_RemoveUIElements(SOBJ_GetRusToAmbushPt, hpid_AmbushPt)
	
	if RusKilledEarly == false then
		Objective_Start(SOBJ_KillAllRusAmbushPt, true, true)		
	else
		Objective_Start(SOBJ_KillAllEnclosedRus,true,true)
	    Rule_Add(CheckMongolApproaching)
	end
end


function DefeatRusUltimate_OnComplete()
	
--	Util_StartIntel(EVENTS.Victory)
	Music_LockIntensity(MUSIC_COMBAT_RARE)
	Mission_Complete()
--	Mongol_prepare_outro()
end
