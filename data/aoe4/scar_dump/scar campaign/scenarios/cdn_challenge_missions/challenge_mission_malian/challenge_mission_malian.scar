function Mission_PreInit()
	
	ChallengeMission_HideTributeMenu()
end

function Mission_Preset()
	
	-- Enable player colours
	PlayerColour_Enable()
	
	
	
	ChallengeMission_OnGameSetup()
	ChallengeMission_SetPlayerUpgrades()
	ChallengeMission_SpawnPlayerUnits()
	ChallengeMission_SetupDiplomacy()
	
	--delete wolves
	if(region_dist_gaia_wolf ~= nil) then
		if(SGroup_CountSpawned(region_dist_gaia_wolf) > 0) then
			SGroup_DestroyAllSquads(region_dist_gaia_wolf)
		end
	end
	
end

function Mission_Start()
	
	startTime = World_GetGameTime()
	Malian_PreIntro_Clean_Scenes()
	
	Player_SetResource( localPlayer, RT_Food, 	0)
	Player_SetResource( localPlayer, RT_Wood, 	0)
	Player_SetResource( localPlayer, RT_Gold, 	1000)
	challengeGoldSpent = -1000
	Player_SetResource( localPlayer, RT_Stone, 	0)
	
	ChallengeMission_SetupGbetoScouts()
	
	-- Initialize Objectives 
	ChallengeMission_InitializeObjectives()
	-- Initialize starting Objectives 
	ChallengeMission_PathSetupObjectives()
	
	Rule_AddInterval(ChallengeMission_Update, 0.125)
	Rule_AddInterval(ChallengeMission_GuideWaves, .15)
	Rule_AddInterval(ChallengeMission_SwitchTarget, 5)
	Rule_AddInterval(ChallengeMission_TargetMines, 6)
	
	FOW_ExploreAll()
	
	UI_DeleteMinimapBlip(minimapBlips[1].blip)
	minimapBlips[1].blip  = UI_CreateMinimapBlip(mkr_gold1, -1, "objective_primary")
	UI_DeleteMinimapBlip(minimapBlips[2].blip)
	minimapBlips[2].blip  = UI_CreateMinimapBlip(mkr_gold2, -1, "objective_primary")
	UI_DeleteMinimapBlip(minimapBlips[3].blip)
	minimapBlips[3].blip  = UI_CreateMinimapBlip(mkr_gold3, -1, "objective_primary")
	
	Rule_AddInterval(ChallengeMission_UpdateTorches, .25)
	
	Rule_AddOneShot(ChallengeMission_IntroduceDiplomacyUI, 5)
	
	Rule_AddInterval(ChallengeMission_PulseThreatBlip, 5)
	
	
	hint_path1 = HintPoint_Add(mkr_path_1_scout_10, true, "$11224804", 5, HPAT_Attack, "icons/threat_group_arrow", nil, true, nil)
	HintPoint_SetVisible(hint_path1, true)
	
	hint_path2 = HintPoint_Add(mkr_path_2_scout_07, true, "$11224805", 5, HPAT_Attack, "icons/threat_group_arrow", nil, true, nil)
	HintPoint_SetVisible(hint_path2, true)
	
	hint_path3 = HintPoint_Add(mkr_path_3_scout_07, true, "$11224806", 5, HPAT_Attack, "icons/threat_group_arrow", nil, true, nil)
	HintPoint_SetVisible(hint_path3, false)
	
	hint_path4 = HintPoint_Add(mkr_path_2_scout_07, true, "$11224807", 5, HPAT_Attack, "icons/threat_group_arrow", nil, true, nil)
	HintPoint_SetVisible(hint_path4, false)
	
	FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_reinforce_barracks), 20, -1)
	FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_reinforce_archery), 20, -1)
	
	--check if lane is inactive
	ChallengeMission_CheckLaneActive(1)
	ChallengeMission_CheckLaneActive(2)
	ChallengeMission_CheckLaneActive(3)
	
	--light torches and set owner on lanes 1 and 2
	ChallengeMission_SetupMinimapPath(waveWaypointPathsList[1], 1, 0)
	ChallengeMission_SetupMinimapPath(waveWaypointPathsList[2], 2, 0)
	
	--explore enemy base area
	FOW_RevealArea(Util_GetPosition(mkr_enemy_base), 120, .2)
	FOW_RevealArea(Util_GetPosition(mkr_allied_base), 120, .2)
	
	local allyWalls = EGroup_CreateIfNotFound("allyWalls")
	local enemyWalls = EGroup_CreateIfNotFound("allyWalls")
	allyWalls = Player_GetAllEntitiesFromType(allyPlayer, "wall")
	enemyWalls = Player_GetAllEntitiesFromType(enemyPlayer, "wall")
	Modify_EnableIsVisibleInFOW(allyWalls, true, -1)
	Modify_EnableIsVisibleInFOW(enemyWalls, true, -1)
	
	
	--set up house groups for each pit mine
	
	eg_houses1 = EGroup_CreateIfNotFound("eg_houses1")
	Player_GetAllEntitiesNearMarker(localPlayer, eg_houses1, Util_GetPosition(mkr_gold1), 40)
	EGroup_Filter(eg_houses1, "pit_mine", FILTER_REMOVE)
	house1StartingCount = EGroup_CountSpawned(eg_houses1)
		
	eg_houses2 = EGroup_CreateIfNotFound("eg_houses2")
	Player_GetAllEntitiesNearMarker(localPlayer, eg_houses2, Util_GetPosition(mkr_gold2), 40)
	EGroup_Filter(eg_houses2, "pit_mine", FILTER_REMOVE)
	house2StartingCount = EGroup_CountSpawned(eg_houses2)
		
	eg_houses3 = EGroup_CreateIfNotFound("eg_houses3")
	Player_GetAllEntitiesNearMarker(localPlayer, eg_houses3, Util_GetPosition(mkr_gold3), 40)
	EGroup_Filter(eg_houses3, "pit_mine", FILTER_REMOVE)
	house3StartingCount = EGroup_CountSpawned(eg_houses3)
		
	
	-- Play dialogue
	Util_StartIntel(EVENTS.NarrIntro)
	
	
end
		
function GetRecipe()
	
	localPlayer = World_GetPlayerAt(1) --Player
	enemyPlayer = World_GetPlayerAt(2) --enemy AI player
	allyPlayer = World_GetPlayerAt(3) --ally AI player
	enemyPlayer2 = World_GetPlayerAt(4) --enemy AI player 2
	neutralPlayer = World_GetPlayerAt(5) --ally AI player scouts
	scoutPlayer = World_GetPlayerAt(6) --ally AI player scouts
	
	local recipe = {
	
		--enableShroud = true,
		
		introNIS = EVENTS.PreIntro,
		--outroNIS = EVENTS.Victory,
		
		locations = {
			{ descriptor = "path1Capture", marker = mkr_path1Capture, player = enemyPlayer },
			{ descriptor = "path2Capture", marker = mkr_path2Capture, player = enemyPlayer },
		},  -- end of LOCATIONS table
		
		--
		-- Modules
		--
		modules = {
		},

		onWin = {
		},
		
		onLose = {
		},
	}
	
	return recipe
end

-- Initialize Objectives
function ChallengeMission_InitializeObjectives()
	
	OBJ_Victory = {
		
		Title = "$11226357",
		Type = ObjectiveType_Primary,
		
		PreStart = function()
			
		end,
		OnStart = function()
			Rule_AddGlobalEvent(ChallengeMission_OnSquadKilled, GE_SquadKilled)
			Rule_AddGlobalEvent(ChallengeMission_OnDestruction, GE_EntityKilled)
		end,
		IsComplete = function()
			return false
		end,
		OnComplete = function()
			
			Mission_Complete()
		end,
	}
	
	OBJ_AmbushWaves = {
		
		Title = "$11224799",
		Type = ObjectiveType_Battle,
		Parent = OBJ_Victory,
		StartAlongsideParent = false, 
		
		PreStart = function()
			
		end,
		
		OnComplete = function()
			
		end,
	}
	
	OBJ_DefendMines = {
		
		Title = "$11224798",
		Type = ObjectiveType_Battle,
		Parent = OBJ_Victory,
		StartAlongsideParent = true, 
		
		PreStart = function()
			
		end,
		
		OnComplete = function()
			
		end,
	}
	
	_challenge.benchmarks.unplaced.objective = {
				-- Set Objective Title Collect %1GoldCollected% Gold for Bronze Medal
				Title = Loc_FormatText("$11224800", _challenge.benchmarks.unplaced.minimumGoldCollected),
				-- Set Objective Type
				Type = OT_Bonus,
				-- Set Objective Icon
				Icon = _challenge.icons.noMedalObjective,
				}
	_challenge.benchmarks.bronze.objective = {
				-- Set Objective Title
				Title = Loc_FormatText("$11224801", _challenge.benchmarks.bronze.minimumGoldCollected),
				-- Set Objective Type
				Type = OT_Bonus,
				-- Set Objective Icon
				Icon = _challenge.icons.bronzeMedalObjective,
				}
	_challenge.benchmarks.silver.objective = {
				-- Set Objective Title
				Title = Loc_FormatText("$11224802", _challenge.benchmarks.silver.minimumGoldCollected),
				-- Set Objective Type
				Type = OT_Bonus,
				-- Set Objective Icon
				Icon = _challenge.icons.silverMedalObjective,
				}
	_challenge.benchmarks.gold.objective = {
				-- Set Objective Title
				Title = Loc_FormatText("$11224803"),
				-- Set Objective Type
				Type = OT_Bonus,
				-- Set Objective Icon
				Icon = _challenge.icons.goldMedalObjective,
				}
	
	
	Objective_Register(OBJ_Victory)
	Objective_Register(OBJ_AmbushWaves)
	Objective_Register(OBJ_DefendMines)
	
	
	_challenge.currentBenchmark = _challenge.benchmarks.unplaced
	-- Register Medal objective
	Objective_Register(_challenge.currentBenchmark.objective, localPlayer.id)
		
	Objective_SetCounter(_challenge.currentBenchmark.objective, 0)
	
	
end

