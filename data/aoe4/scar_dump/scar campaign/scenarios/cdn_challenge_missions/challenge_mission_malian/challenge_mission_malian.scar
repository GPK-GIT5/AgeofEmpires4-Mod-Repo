	-- Set up Players
	player1 = Missionomatic_InitPlayer(1, { name = "$11215009", currentAge = AGE_IMPERIAL })
	player2 = Missionomatic_InitPlayer(2, { name = "$11202489", currentAge = AGE_IMPERIAL })
