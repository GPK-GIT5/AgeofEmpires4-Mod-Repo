function ChallengeMission_SetPlayerUpgrades()
	
	local bp_siege_engineers = BP_GetUpgradeBlueprint("upgrade_siege_engineers")
	Player_CompleteUpgrade(enemyPlayer, bp_siege_engineers)
	
	Player_SetEntityProductionAvailability(localPlayer, BP_GetEntityBlueprint("building_house_mal"), ITEM_UNLOCKED)
	Player_SetEntityProductionAvailability(localPlayer, BP_GetEntityBlueprint("building_open_pit_mine_mal"), ITEM_REMOVED)
	Player_SetEntityProductionAvailability(localPlayer, BP_GetEntityBlueprint("building_town_center_mal"), ITEM_REMOVED)
	
	Player_SetUpgradeAvailability(localPlayer, UPG.MALIAN.UPGRADE_ARCHER_POISON_ARROW_MAL, ITEM_UNLOCKED)
	Player_SetUpgradeAvailability(localPlayer, UPG.MALIAN.UPGRADE_STEALTH_HEALING_MAL, ITEM_UNLOCKED)
	Player_SetUpgradeAvailability(localPlayer, UPG.MALIAN.UPGRADE_DONSO_PRECISION_TRAINING_MAL, ITEM_UNLOCKED)
