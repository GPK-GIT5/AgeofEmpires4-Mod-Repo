	Player_SetUpgradeAvailability(localPlayer, UPG.MALIAN.UPGRADE_UNIT_SPEARMAN_4_MAL, ITEM_UNLOCKED)
	Player_SetUpgradeAvailability(localPlayer, UPG.MALIAN.UPGRADE_UNIT_JAVELIN_4_MAL, ITEM_UNLOCKED)
	Player_SetUpgradeAvailability(localPlayer, UPG.MALIAN.UPGRADE_UNIT_GBETO_4_MAL, ITEM_UNLOCKED)
	
	--remove outpost upgrades
	Player_SetUpgradeAvailability(localPlayer, UPG.COMMON.UPGRADE_OUTPOST_ARROWSLITS, ITEM_REMOVED)
	Player_SetUpgradeAvailability(localPlayer, UPG.COMMON.UPGRADE_OUTPOST_CANNON, ITEM_REMOVED)
	Player_SetUpgradeAvailability(localPlayer, UPG.COMMON.UPGRADE_OUTPOST_SPRINGALD, ITEM_REMOVED)
	Player_SetUpgradeAvailability(localPlayer, UPG.COMMON.UPGRADE_OUTPOST_STONE, ITEM_REMOVED)
	Player_SetUpgradeAvailability(localPlayer, UPG.MALIAN.UPGRADE_OUTPOST_TOLL_MAL, ITEM_REMOVED)
	
	-- Add Local Player Upgrades
	Player_CompleteUpgrade(localPlayer, UPG.MALIAN.UPGRADE_ARCHER_POISON_ARROW_MAL)
	Player_CompleteUpgrade(localPlayer, UPG.MALIAN.UPGRADE_STEALTH_HEALING_MAL)
	Player_CompleteUpgrade(localPlayer, UPG.MALIAN.UPGRADE_DONSO_PRECISION_TRAINING_MAL)
	Player_CompleteUpgrade(localPlayer, UPG.MALIAN.UPGRADE_UNIT_ARCHER_4_MAL)
	Player_CompleteUpgrade(localPlayer, UPG.MALIAN.UPGRADE_UNIT_SPEARMAN_4_MAL)
	Player_CompleteUpgrade(localPlayer, UPG.MALIAN.UPGRADE_UNIT_JAVELIN_4_MAL)
	Player_CompleteUpgrade(localPlayer, UPG.MALIAN.UPGRADE_UNIT_GBETO_4_MAL)
	
	-- Hide Building Scuttle
	Player_SetAbilityAvailability(localPlayer, BP_GetAbilityBlueprint("core_building_scuttle"), ITEM_REMOVED)
	
	-- Hide Death (delete units)
	Player_SetAbilityAvailability(localPlayer, BP_GetAbilityBlueprint("core_unit_death"), ITEM_REMOVED)
		
end

wavesStarted = false
nextEndlessWaveTime = 5
endlessWaveCostRemaining = 800
endlessWaveCost = 800 --cost of the units in the next wave
endlessWavesType = 1 --which of the preset unit compositions and lanes to use

--variables for gold income adjustment
incomeIntervalsPassed = 0
goldIncomeRate = 0
previousGoldCollected = 0
timeSinceGoldCollected = 0
extraGoldIncome = 1

-- Update Objectives - Called by a rule every simtic
function ChallengeMission_Update()
	
	local timeElapsed = World_GetGameTime() - startTime
	
	if(wavesStarted == true) then
		if(timeElapsed >= nextEndlessWaveTime) then
			ChallengeMission_AddNewWave()
		end
	end
	
	
	--start waves when the timer is up
	for i, waveObject in pairs(waveObjectList) do
		if(timeElapsed > waveObject["waveStartTime"] and waveObject["waveStarted"] == false) then
			
			ChallengeMission_SendWave(waveObject["waveNumber"])
			waveObject["waveStarted"] = true
		end
		
	end
	
	--set waves as finished when they reach the end of the path
	for i, waveObject in pairs(waveObjectList) do
		if(waveObject["waveStarted"] == true and waveObject["wavePathFinished"] == false and 
				waveObject["waveDefeated"] == false) then
			
			--get path length minus the final node
			currentPathLength = #waveWaypointPathsList[waveObject["wavePath"]] - 1
	
			if(waveObject["wavePathProgress"] == currentPathLength) then
				waveObject["wavePathFinished"] = true
			end
		end
	end
	
	
	if(Objective_IsCounterSet(_challenge.currentBenchmark.objective)) then
		
		
		challengeGoldCollected = Player_GetResource(localPlayer, RT_Gold) + challengeGoldSpent
		Objective_SetCounter(_challenge.currentBenchmark.objective, challengeGoldCollected)
		
		--check the first 2 intervals to determine the base income rate
		if(incomeIntervalsPassed < 2) then
			local goldCollectedThisInterval = challengeGoldCollected - previousGoldCollected
			previousGoldCollected = challengeGoldCollected
			local goldCollectionInterval = timeElapsed - timeSinceGoldCollected
			if(goldCollectedThisInterval > 0 and goldCollectionInterval > 0) then
				
				goldIncomeRate = goldCollectedThisInterval / goldCollectionInterval
				
				timeSinceGoldCollected = timeElapsed
				incomeIntervalsPassed = incomeIntervalsPassed + 1
				--once income is calculated, add a rule adding income over time
				if(incomeIntervalsPassed == 2) then
					--calculate difference from target income per minute
					local goldIncomeDiff = 411 - (goldIncomeRate * 60)
					if(goldIncomeDiff > 0) then
						--calculate income for the 10 second interval
						extraGoldIncome = goldIncomeDiff / 6
						--grant refund for first full interval missed
						ChallengeMission_GrantExtraGoldIncome()
						--add rule for continuing income adjustment every 10 seconds
						Rule_AddInterval(ChallengeMission_GrantExtraGoldIncome, 10)
					end
				end
			end
		end
		
		if(_challenge.currentBenchmark.minimumGoldCollected ~= nil and Objective_GetCounter(_challenge.currentBenchmark.objective) >= _challenge.currentBenchmark.minimumGoldCollected) then
			ChallengeMission_UpdateMedals()
		end
	end
	
end


function ChallengeMission_GrantExtraGoldIncome()
	Player_SetResource( localPlayer, RT_Gold, Player_GetResource(localPlayer, RT_Gold) + extraGoldIncome)
	
end


function ChallengeMission_PulseThreatBlip()
	
	for i, waveObject in pairs(waveObjectList) do
		if(waveObject["waveStarted"] == true and 
				waveObject["wavePathFinished"] == false and 
				waveObject["waveDefeated"] == false) then
			
			if(SGroup_CountSpawned(waveObject["waveGroup"]) > 0) then
				
				
				--pulse minimap blip
				UI_CreateMinimapBlip(Util_GetPosition(waveObject["waveGroup"]), 1, "threat_group")
			end
		end
	end
end

relicSpawnedCount = 0
function ChallengeMission_SendWave(sendWaveIndex)
	--waves can last well into the next wave to spawn so we can't reuse the sgroups
	local shouldSpawnRelic = false
	
	--start spawning relics on the 15th group and after the 1st repeat
	if(sendWaveIndex > 21 or sendWaveIndex == 15) then
		shouldSpawnRelic = true
	end
	
	local waveSpawnMarker = waveWaypointPathsList[waveObjectList[sendWaveIndex]["wavePath"]][1]
	
	for i, unitMakeup in pairs(waveObjectList[sendWaveIndex]["waveUnits"]) do
		
		--spread out units on combined waves
		if(waveObjectList[sendWaveIndex]["waveSpawnPoint"] == 2) then
			waveSpawnMarker = mkr_path_2_spawn_2
		elseif(waveObjectList[sendWaveIndex]["waveSpawnPoint"] == 3) then
			waveSpawnMarker = mkr_path_2_spawn_3
		elseif(waveObjectList[sendWaveIndex]["waveSpawnPoint"] == 4) then
			waveSpawnMarker = mkr_path_2_spawn_4
		elseif(waveObjectList[sendWaveIndex]["waveSpawnPoint"] == 5) then
			waveSpawnMarker = mkr_path_2_spawn_5
		end
		
		UnitEntry_DeploySquads(enemyPlayer, waveObjectList[sendWaveIndex]["waveGroup"], {sbp = unitMakeup["waveUnitBP"], numSquads = unitMakeup["waveUnitCount"] }, waveSpawnMarker)
		FOW_PlayerRevealSGroup(localPlayer, waveObjectList[sendWaveIndex]["waveGroup"],20,-1)
		
		--add temporary slow to cavalry group
		if(waveObjectList[sendWaveIndex]["waveSpeedModifier"] < 1) then
			Modify_UnitSpeed(waveObjectList[sendWaveIndex]["waveGroup"], waveObjectList[sendWaveIndex]["waveSpeedModifier"], 20)
		end
		
		--spawn in a relic for later waves
		if(shouldSpawnRelic == true) then
			local sbp_monk_sul = BP_GetSquadBlueprint("unit_monk_2_sul")
			if(unitMakeup["waveUnitBP"] == sbp_monk_sul) then
				--sg_single monk and pick up relic
				eg_relic_01 = EGroup_CreateIfNotFound("eg_relic_01")
				Util_CreateEntities(enemyPlayer, eg_relic_01, BP_GetEntityBlueprint("relic"), waveWaypointPathsList[waveObjectList[sendWaveIndex]["wavePath"]][1], 1, nil, nil, true)
				
				Rule_AddOneShot(ChallengeMission_PickUpRelic, 1, {waveObjectIndex = sendWaveIndex})
				
				Cmd_Ability(waveObjectList[sendWaveIndex]["waveGroup"], BP_GetAbilityBlueprint("pickup_relic"), eg_relic_01, nil, nil, false)
				relicSpawnedCount = relicSpawnedCount + 1
			end
		end
	end
	
	--get path length minus the final node
	currentPathLength = #waveWaypointPathsList[waveObjectList[sendWaveIndex]["wavePath"]] - 1
	
	--reveal path
	for w = 1, currentPathLength do
		if(w <= currentPathLength) then
			FOW_PlayerRevealArea(localPlayer, Util_GetPosition(waveWaypointPathsList[waveObjectList[sendWaveIndex]["wavePath"]][w]), 20, -1)
		end
	end
	
	
	Cmd_FormationMove(waveObjectList[sendWaveIndex]["waveGroup"], waveSpawnMarker, true, false, waveWaypointPathsList[waveObjectList[sendWaveIndex]["wavePath"]][2])
	
	
	--place path markers on minimap
	ChallengeMission_SetupMinimapPath(waveWaypointPathsList[waveObjectList[sendWaveIndex]["wavePath"]], waveObjectList[sendWaveIndex]["wavePath"], sendWaveIndex)
	
end

function ChallengeMission_GuideWaves()
	for i, waveObject in pairs(waveObjectList) do
		
		
		local timeElapsed = World_GetGameTime() - startTime
		if(timeElapsed > waveObject["waveDelayTime"] and waveObject["waveDelayFinished"] == false) then
			waveObject["waveDelayFinished"] = true
			Cmd_FormationAttackMove(waveObject["waveGroup"], waveWaypointPathsList[waveObject["wavePath"]][1], true, false)
	
		end
		
		if(waveObject["waveStarted"] == true and waveObject["wavePathFinished"] == false 
				and waveObject["waveDefeated"] == false and waveObject["waveDelayFinished"] == true) then
			
			if(SGroup_CountSpawned(waveObject["waveGroup"]) > 0) then
				
				--create group without monks to compare distance to next marker
				local sg_GroupWithoutMonks = SGroup_CreateIfNotFound("sg_GroupWithoutMonks")
				SGroup_Clear(sg_GroupWithoutMonks)
				SGroup_AddGroup(sg_GroupWithoutMonks, waveObject["waveGroup"])
				SGroup_Filter(sg_GroupWithoutMonks,  "monk", FILTER_REMOVE)
				--add back monks if nothing is left
				if(SGroup_CountSpawned(sg_GroupWithoutMonks) == 0) then
					SGroup_AddGroup(sg_GroupWithoutMonks, waveObject["waveGroup"])
				end
				
				--get path length minus the final node
				currentPathLength = #waveWaypointPathsList[waveObject["wavePath"]] - 1
				
				--actual path markers
				for w = waveObject["wavePathProgress"], currentPathLength do
					if(w == 0) then
						w = 1
					end
					if(waveObject["wavePathProgress"] < w and Util_GetDistance(sg_GroupWithoutMonks, waveWaypointPathsList[waveObject["wavePath"]][w]) < 10) then
						if(w <= currentPathLength) then
							if(waveObject["waveAttacking"] == false) then
								Cmd_FormationAttackMove(waveObject["waveGroup"], waveWaypointPathsList[waveObject["wavePath"]][w + 1], false, false)
							else
								Cmd_FormationAttackMove(waveObject["waveGroup"], waveWaypointPathsList[waveObject["wavePath"]][w + 1], false, false)
							end
							waveObject["waveAttacking"] = false
							if(ChallengeMission_CheckNodeInUse(i, waveObject["wavePath"], w) == false) then
								--unreveal previous point
								FOW_PlayerUnRevealArea(localPlayer, Util_GetPosition(waveWaypointPathsList[waveObject["wavePath"]][w]))
							end
							
						end
						waveObject["wavePathProgress"] = w
					end
				end
				
				currentScoutPathLength = #gbetoScoutPath[waveObject["wavePath"]] - 1
				
				
				
				--slightly delayed attack move if wave is under attack
				if(waveObject["waveAttacking"] == false) then
					if(SGroup_IsUnderAttack(waveObject["waveGroup"], ANY, 4) == true) then
						Rule_AddOneShot(ChallengeMission_GuideWaveAttack, .5, {waveObjectIndex = i})
						waveObject["waveAttacking"] = true
					end
				end
				
				
				--check for monks, order them to stop and heal if the group is attacked
				if(waveObject["waveAttacking"] == true) then
					for i2 = 1, SGroup_CountSpawned(waveObject["waveGroup"]) do
						local squad = SGroup_GetSquadAt(waveObject["waveGroup"], i2)
						if(Squad_IsOfType(squad, "monk") == true) then
							SGroup_Single(sg_single, squad)
							--check if monk is carrying a relic
							if(Squad_CanCastAbilityOnSquad(squad, BP_GetAbilityBlueprint("monk_conversion"), squad) == true) then
								
								--check if there are enemy units nearby
								sg_conversionTargets = SGroup_CreateIfNotFound("sg_conversionTargets")
								SGroup_Clear(sg_conversionTargets)
								Player_GetAllSquadsNearMarker(localPlayer, sg_conversionTargets, Util_GetPosition(sg_single), 10)
								
								if(SGroup_CountSpawned(sg_conversionTargets) > 0) then
									Cmd_Ability(sg_single, BP_GetAbilityBlueprint("monk_conversion"), sg_single, nil, nil, false)
									waveObject["conversionStarted"] = true
									waveObject["conversionTime"] = timeElapsed + 10
									
								end
							end
						end
					end
				end
				
				--check if relic conversion has completed and drop relic
				if(waveObject["conversionStarted"] == true and waveObject["conversionTime"] < timeElapsed) then
					for i2 = SGroup_CountSpawned(waveObject["waveGroup"]), 1, -1 do
						local squad = SGroup_GetSquadAt(waveObject["waveGroup"], i2)
						if(Squad_IsOfType(squad, "monk") == true) then
							SGroup_Single(sg_single, squad)
							if(SGroup_IsEmpty(sg_single) == false) then
								--check if monk is carrying a relic
								if(Squad_CanCastAbilityOnSquad(squad, BP_GetAbilityBlueprint("monk_statetree_drop_relic"), squad) == true) then
									
									Cmd_Ability(sg_single, BP_GetAbilityBlueprint("monk_statetree_drop_relic"), sg_single, nil, nil, false)
									waveObject["conversionStarted"] = false
									ChallengeMission_DespawnRelic(Util_GetPosition(sg_single))
									ChallengeMission_OrderConverts()
								end
							end
						end
					end
				end
				
				
				--check if group is idle and set attacking to false
				if(SGroup_IsIdle(waveObject["waveGroup"], ALL)) then
					waveObject["waveAttacking"] = false
				end
				
			end
			
		end
		
		
	end
	
	
end

function ChallengeMission_DespawnRelic(relicPos)
	
	eg_relic_dropped = EGroup_CreateIfNotFound("eg_relic_dropped")
	
	World_GetAllNeutralEntities(eg_relic_dropped)
	EGroup_Filter(eg_relic_dropped, "relic", FILTER_KEEP)
	
	for i = EGroup_CountSpawned(eg_relic_dropped), 1, -1 do
		local entity = EGroup_GetEntityAt(eg_relic_dropped, i)	
		EGroup_Single(eg_single, entity)	
		if(relicPos ~= nil) then
			if(Util_GetDistance(eg_single, relicPos) < 10) then
				Entity_Destroy(entity)
			end
		end
	end
end

function ChallengeMission_OrderConverts()
	
	--find Mali units owned by the enemy and order them to the nearest pit mine
	sg_converts = SGroup_CreateIfNotFound("sg_converts")
	SGroup_Clear(sg_converts)
	sg_converts = Player_GetSquads(enemyPlayer)
	SGroup_Filter(sg_converts, {SBP.MALIAN.UNIT_GBETO_4_MAL, SBP.MALIAN.UNIT_SPEARMAN_4_MAL, SBP.MALIAN.UNIT_ARCHER_4_MAL, SBP.MALIAN.UNIT_JAVELIN_4_MAL, SBP.MALIAN.UNIT_HANDCANNON_4_MAL}, FILTER_KEEP)
	
	
	for c = 1, SGroup_CountSpawned(sg_converts) do
		local squad = SGroup_GetSquadAt(sg_converts, c)
		SGroup_Single(sg_single, squad)	
		if(SGroup_IsEmpty(sg_single) == false) then
			eg_pit_mines = EGroup_CreateIfNotFound("eg_pit_mines")
			EGroup_Clear(eg_pit_mines)
			eg_pit_mines = Player_GetAllEntitiesFromType(localPlayer, "building")
			EGroup_Filter(eg_pit_mines, "pit_mine", FILTER_KEEP)
			
			if(eg_pit_mines ~= nil) then
				if(EGroup_IsEmpty(eg_pit_mines) == false) then
					--find the closest remaining pit mine
					local nearestPitMine = 1
					local distToPitMine = -1
					for i = 1, EGroup_CountSpawned(eg_pit_mines) do
						local entity = EGroup_GetEntityAt(eg_pit_mines, i)	
						local currentHealth = Entity_GetHealthPercentage(entity)
						if(currentHealth > 0) then
							if(distToPitMine == -1 or Util_GetDistance(sg_single, entity) < distToPitMine) then
								distToPitMine = Util_GetDistance(sg_single, entity)
								nearestPitMine = i
							end
						end
					end
					
					--attack move towards mine
					if(distToPitMine > 5) then
						local entity = EGroup_GetEntityAt(eg_pit_mines, nearestPitMine)	
						EGroup_Single(eg_single, entity)
						if(EGroup_IsEmpty(eg_single) == false) then
							Cmd_AttackMove(sg_single, Util_GetPosition(eg_single), false)
						end
					end
				end
			end
		end
	end
end


function ChallengeMission_CheckForIdleWaves()
	for i, waveObject in pairs(waveObjectList) do
		
		if(waveObject["waveStarted"] == true and waveObject["wavePathFinished"] == false 
				and waveObject["waveDefeated"] == false and waveObject["waveDelayFinished"] == true) then
			if(SGroup_CountSpawned(waveObject["waveGroup"]) > 0) then
				
				--get path length minus the final node
				currentPathLength = #waveWaypointPathsList[waveObject["wavePath"]] - 1
				
				local currentMarker = mkr_gold1
				for p = 1, 3 do
					if(p == 2) then
						currentMarker = mkr_gold2
					elseif(p == 3) then
						currentMarker = mkr_gold3
					end
					
					--set path as completed if any units in the group are at the mines
					local waveReachedMine = false
					for i2 = 1, SGroup_CountSpawned(waveObject["waveGroup"]) do
						if(waveReachedMine == false) then
							local squad = SGroup_GetSquadAt(waveObject["waveGroup"], i2)
							if(Util_GetDistance(squad, currentMarker) < 15) then
								waveReachedMine = true
							end
						end
					end
					if(waveReachedMine == true) then
						waveObject["wavePathProgress"] = currentPathLength
					end
					
				end
			end
		end
	end
end

function ChallengeMission_PickUpRelic(context, data)
	sg_monksInWave = SGroup_CreateIfNotFound("sg_monksInWave")
	SGroup_Clear(sg_monksInWave)
	local eg_nearbyRelic = EGroup_CreateIfNotFound("eg_nearbyRelic")
	
	World_GetAllNeutralEntities(eg_nearbyRelic)
	EGroup_Filter(eg_nearbyRelic, "relic", FILTER_KEEP)
	
	
	
	SGroup_AddGroup(sg_monksInWave, waveObjectList[data.waveObjectIndex]["waveGroup"])
	SGroup_Filter(sg_monksInWave, "monk", FILTER_KEEP)
	if(SGroup_CountSpawned(sg_monksInWave) > 0) then
		if(EGroup_CountSpawned(eg_nearbyRelic) > 0) then
			for i = 1, EGroup_CountSpawned(eg_nearbyRelic) do
				local entity = EGroup_GetEntityAt(eg_nearbyRelic, i)	
				EGroup_Single(eg_single, entity)	
				
				if(Util_GetDistance(eg_single, sg_monksInWave) < 30) then
					Cmd_Ability(sg_monksInWave, BP_GetAbilityBlueprint("pickup_relic"), eg_single, nil, nil, false)
				end
			end
		end
	end
end

function ChallengeMission_GuideWaveAttack(context, data)
	for i, waveObject in pairs(waveObjectList) do
		if(i == data.waveObjectIndex and waveObject["waveStarted"] == true and 
				waveObject["wavePathFinished"] == false and waveObject["waveDefeated"] == false) then
			
			if(SGroup_CountSpawned(waveObject["waveGroup"]) > 0) then
				
				Cmd_FormationAttackMove(waveObject["waveGroup"], waveWaypointPathsList[waveObject["wavePath"]][waveObject["wavePathProgress"] + 1], false, false)
			end
		end
	end
end


function Malian_Wave_SpawnRelic(context, data)
	--test of spawning relic and converting
	--
	sg_preintro2_enemy_monk_01 = SGroup_CreateIfNotFound("sg_preintro2_enemy_monk_01")
	UnitEntry_DeploySquads(enemyPlayer, sg_preintro2_enemy_monk_01, {{sbp = BP_GetSquadBlueprint("unit_monk_2_sul"), numSquads = 1 }}, mkr_path_2_scout_01)
	
	eg_relic_01 = EGroup_CreateIfNotFound("eg_relic_01")
	Util_CreateEntities(enemyPlayer, eg_relic_01, BP_GetEntityBlueprint("relic"), mkr_path_2_s_rally_03, 1, nil, nil, true)
	
	Cmd_Ability(sg_preintro2_enemy_monk_01, BP_GetAbilityBlueprint("pickup_relic"), eg_relic_01, nil, nil, false)
	Rule_AddOneShot(Malian_Wave_Convert, 5)
	--
end
function Malian_Wave_Convert(context, data)
	
	
	Cmd_Ability(sg_preintro2_enemy_monk_01, BP_GetAbilityBlueprint("monk_conversion"), sg_preintro2_enemy_monk_01, nil, nil, false)
	--add another rule to change owner of allied scouts back
end

--returns true if the marker is used by any other unfinished wave groups
function ChallengeMission_CheckNodeInUse(checkWaveObject, checkPathIndex, checkNodeIndex)
	for i, waveObject in pairs(waveObjectList) do
		if(i ~= checkWaveObject) then
			if(waveObject["waveStarted"] == true and waveObject["wavePathFinished"] == false and 
					waveObject["waveDefeated"] == false) then
				if(SGroup_CountSpawned(waveObject["waveGroup"]) > 0) then
					if(waveObject["wavePath"] == checkPathIndex and 
							waveObject["wavePathProgress"] < checkNodeIndex) then
						return true
					end
				end
			end
		end
	end
	return false
end

function ChallengeMission_SwitchTarget()
	
	for i, waveObject in pairs(waveObjectList) do
		if(waveObject["waveStarted"] == true and waveObject["wavePathFinished"] == true and waveObject["waveDefeated"] == false) then
			--attack move towards nearest pit mine
			
			if(SGroup_CountSpawned(waveObject["waveGroup"]) > 0) then
				eg_pit_mines = EGroup_CreateIfNotFound("eg_pit_mines")
				EGroup_Clear(eg_pit_mines)
				eg_pit_mines = Player_GetAllEntitiesFromType(localPlayer, "building")
				EGroup_Filter(eg_pit_mines, "pit_mine", FILTER_KEEP)
				
				--get all houses
				eg_houses = EGroup_CreateIfNotFound("eg_houses")
				eg_houses = Player_GetAllEntitiesFromType(localPlayer, "building")
				EGroup_Filter(eg_houses, "pit_mine", FILTER_REMOVE)
				
				if(eg_pit_mines ~= nil) then
					--find the closest remaining pit mine
					local nearestPitMine = 1
					local distToPitMine = -1
					for i = 1, EGroup_CountSpawned(eg_pit_mines) do
						local entity = EGroup_GetEntityAt(eg_pit_mines, i)	
						local currentHealth = Entity_GetHealthPercentage(entity)
						if(currentHealth > 0) then
							if(distToPitMine == -1 or Util_GetDistance(waveObject["waveGroup"], entity) < distToPitMine) then
								distToPitMine = Util_GetDistance(waveObject["waveGroup"], entity)
								nearestPitMine = i
							end
						end
					end
					
					local nearestHouse = 1
					local distToNearestHouse = -1
					for i = 1, EGroup_CountSpawned(eg_houses) do
						local entity = EGroup_GetEntityAt(eg_houses, i)	
						local currentHealth = Entity_GetHealthPercentage(entity)
						if(currentHealth > 0) then
							if(distToNearestHouse == -1 or Util_GetDistance(waveObject["waveGroup"], entity) < distToNearestHouse) then
								distToNearestHouse = Util_GetDistance(waveObject["waveGroup"], entity)
								nearestHouse = i
							end
						end
					end
					
					if(distToPitMine ~= -1 and distToNearestHouse ~= -1) then
						--find pit mine cloeset to the cloeset house
						local nearestPitMine2 = 1
						local distToPitMine2 = -1
						for i = 1, EGroup_CountSpawned(eg_pit_mines) do
							local entity = EGroup_GetEntityAt(eg_pit_mines, i)	
							local currentHealth = Entity_GetHealthPercentage(entity)
							if(currentHealth > 0) then
								if(distToPitMine2 == -1 or Util_GetDistance(entity, EGroup_GetEntityAt(eg_houses, nearestHouse)) < distToPitMine2) then
									distToPitMine2 = Util_GetDistance(entity, EGroup_GetEntityAt(eg_houses, nearestHouse))
									nearestPitMine2 = i
								end
							end
						end
						
						local entity = EGroup_GetEntityAt(eg_pit_mines, nearestPitMine)	
						EGroup_Single(eg_single, entity)
						if(distToPitMine2 ~= -1) then
							--true when the current pit mine has been destroyed
							if(distToPitMine2 > 50) then
								if(distToPitMine > 50 and SGroup_IsUnderAttack(waveObject["waveGroup"], ANY, 4) == false) then
									--attack next mine (ignore nearby houses)
									Cmd_Move(waveObject["waveGroup"], eg_single, false, false)
								else
									--attack move (also targets houses/units)
									Cmd_AttackMove(waveObject["waveGroup"], eg_single, false, false)
								end
							else
							end
						end
					end
				end
			end
		end
	end
	
end


function ChallengeMission_TargetMines()
	
	eg_pit_mines = EGroup_CreateIfNotFound("eg_pit_mines")
	sg_UnitsNearMine = SGroup_CreateIfNotFound("sg_UnitsNearMine")
	
	
	local minesTargeted = false
	local currentMarker = mkr_gold1
	local housesLost = house1StartingCount - EGroup_CountSpawned(eg_houses1)
	for p = 1, 3 do
		if(p == 2) then
			currentMarker = mkr_gold2
			housesLost = house2StartingCount - EGroup_CountSpawned(eg_houses2)
		elseif(p == 3) then
			currentMarker = mkr_gold3
			housesLost = house3StartingCount - EGroup_CountSpawned(eg_houses3)
		end
		
		EGroup_Clear(eg_pit_mines)
		Player_GetAllEntitiesNearMarker(localPlayer, eg_pit_mines, Util_GetPosition(currentMarker), 40)
		EGroup_Filter(eg_pit_mines, "pit_mine", FILTER_KEEP)
		
		--if 2 houses have been destroyed already target the pit mine
		if(EGroup_CountSpawned(eg_pit_mines) > 0 and housesLost >= 2) then
			local entity = EGroup_GetEntityAt(eg_pit_mines, 1)
			if(Entity_GetHealth(entity) > 1) then
				
				Player_GetAllSquadsNearMarker(enemyPlayer, sg_UnitsNearMine, Util_GetPosition(currentMarker), 40)
				
				if(SGroup_CountSpawned(sg_UnitsNearMine) > 0) then
					
					minesTargeted = true
					
					for i = 1, SGroup_CountSpawned(sg_UnitsNearMine) do
						local squad = SGroup_GetSquadAt(sg_UnitsNearMine, i)
						if(Squad_IsUnderAttack(squad, 4) == false and SGroup_IsUnderAttack(sg_UnitsNearMine, ANY, 4) == false) then
							SGroup_Single(sg_single, squad)	
							Cmd_Attack(sg_single, eg_pit_mines, false)
						else
							SGroup_Single(sg_single, squad)	
							Cmd_AttackMove(sg_single, eg_pit_mines, false)
						end
					end
					
				end
			end
		end
		
		
	end
	
	--only call if any mines are threatened
	if(minesTargeted == true) then
		ChallengeMission_CheckForIdleWaves()
	end
end


function ChallengeMission_OnSquadKilled(context)
	local victim = context.victim
	
	if(World_OwnsSquad(victim) == true) then
		return
	end
	
	if Squad_GetPlayerOwner(victim) == player2 then
		--unreveal all areas on the squad's path that are not used by another group
		
		for i, waveObject in pairs(waveObjectList) do
			
			if(waveObject["waveDefeated"] == false) then
				if(waveObject["waveGroup"] ~= nil) then
					if(SGroup_CountSpawned(waveObject["waveGroup"]) == 0) then
						waveObject["waveDefeated"] = true
						
						--unreveal all nodes not in use
						currentPathLength = #waveWaypointPathsList[waveObject["wavePath"]]
						for w = 1, currentPathLength do
							if(ChallengeMission_CheckNodeInUse(i, waveObject["wavePath"], w) == false) then
								--unreveal previous point
								FOW_PlayerUnRevealArea(localPlayer, Util_GetPosition(waveWaypointPathsList[waveObject["wavePath"]][w]))
							end
						end
					end
				end
			end
			
		end
		
		--if unit is a monk, check for dropped relic and destroy it
		if(Squad_IsOfType(victim, "monk")) then
			ChallengeMission_DespawnRelic(Util_GetPosition(victim))
		end
		
		--check if lane is inactive
		ChallengeMission_CheckLaneActive(1)
		ChallengeMission_CheckLaneActive(2)
		ChallengeMission_CheckLaneActive(3)
	end
end


function ChallengeMission_CheckLaneActive(laneIndex)
	local laneActive = false
	for i, waveObject in pairs(waveObjectList) do
		
		if(waveObject["waveDefeated"] == false) then
			
			if(waveObject["wavePath"] == laneIndex) then
				laneActive = true
			end
		end
	end
	
	if(laneActive == false) then
		--unreveal all nodes not in use
		currentPathLength = #waveWaypointPathsList[laneIndex]
		for w = 1, currentPathLength do
			if(ChallengeMission_CheckNodeInUse(i, laneIndex, w) == false) then
				--unreveal previous point
				FOW_PlayerUnRevealArea(localPlayer, Util_GetPosition(waveWaypointPathsList[laneIndex][w]))
			end
		end
		
		--change owner of scouts
		for i = 1, #gbetoScoutPath[laneIndex] do
			gbetoScoutPath[laneIndex][i]["torchLit"] = false
			SGroup_SetPlayerOwner(gbetoScoutPath[laneIndex][i]["sGroup"], neutralPlayer)
			SGroup_Hide(gbetoScoutPath[laneIndex][i]["sGroup"], true)
		end
	end
	
end

-- A building is destroyed
function ChallengeMission_OnDestruction(context)
	
	if(context.victimOwner == localPlayer) then
		if Entity_IsOfType(context.victim,"pit_mine") then
			local refundAmount = 0
			if(Util_GetDistance(mkr_gold1, context.victim) < 10) then
				UI_DeleteMinimapBlip(minimapBlips[1].blip)
				-- Play dialogue
				Util_StartIntel(EVENTS.NarrWestMineDestroyed)
				--grant extra gold after mine is destroyed
				challengeGoldSpent = challengeGoldSpent - refundAmount
				Player_SetResource( localPlayer, RT_Gold, Player_GetResource(localPlayer, RT_Gold) + refundAmount)
			end
			if(Util_GetDistance(mkr_gold2, context.victim) < 10) then
				UI_DeleteMinimapBlip(minimapBlips[2].blip)
				-- Play dialogue
				Util_StartIntel(EVENTS.NarrSouthMineDestroyed)
				--grant extra gold after mine is destroyed
				challengeGoldSpent = challengeGoldSpent - refundAmount
				Player_SetResource( localPlayer, RT_Gold, Player_GetResource(localPlayer, RT_Gold) + refundAmount)
			end
			if(Util_GetDistance(mkr_gold3, context.victim) < 10) then
				UI_DeleteMinimapBlip(minimapBlips[3].blip)
				-- Play dialogue
				Util_StartIntel(EVENTS.NarrEastMineDestroyed)
				--grant extra gold after mine is destroyed
				challengeGoldSpent = challengeGoldSpent - refundAmount
				Player_SetResource( localPlayer, RT_Gold, Player_GetResource(localPlayer, RT_Gold) + refundAmount)
			end
			
			
			eg_pit_mines = SGroup_CreateIfNotFound("eg_pit_mines")
			eg_pit_mines = Player_GetAllEntitiesFromType(localPlayer, "pit_mine")
			
			
			if(EGroup_Count(eg_pit_mines) == 0) then
				if(_challenge.currentBenchmark == _challenge.benchmarks.unplaced)then
					--fail if current objective is unplaced
					Objective_Fail(OBJ_Victory, true, false)
					Rule_AddOneShot(ChallengeMission_CheckVictory, 1)
				else
					Rule_AddOneShot(ChallengeMission_CheckVictory, 1)
				end
			end
			
			--check for unfinished paths
			ChallengeMission_CheckForIdleWaves()
		end
	end
end

--? @shortdesc Creates a set of minimap paths along a list of markers
function ChallengeMission_SetupMinimapPath(markerPath, pathIndex, waveIndex)
	
	--show blips for first 2 sets of waves and first big wave
	for i = 1, #markerPath, 2 do
		--add minimap blip
		if((waveIndex > 0 and waveIndex <= 4) or waveIndex == 7) then
			Rule_AddOneShot(ChallengeMission_SetupMinimapNode, i * .15, {markerPath = markerPath, pathIndex = pathIndex, nodeIndex = i})
		end
	end
	
	local timeElapsed = World_GetGameTime() - startTime
	
	--light all torches along the path
	for i = 1, #gbetoScoutPath[pathIndex] do
		--allyPlayer
		SGroup_SetPlayerOwner(gbetoScoutPath[pathIndex][i]["sGroup"], allyPlayer)
		SGroup_Hide(gbetoScoutPath[pathIndex][i]["sGroup"], false)
		Modify_UnitSpeed(gbetoScoutPath[pathIndex][i]["sGroup"], 0, -1)
		Cmd_HoldPosition(gbetoScoutPath[pathIndex][i]["sGroup"], gbetoScoutPath[pathIndex][i]["marker"], false)
		SGroup_WarpToMarker(gbetoScoutPath[pathIndex][i]["sGroup"], gbetoScoutPath[pathIndex][i]["marker"])
		Rule_AddOneShot(ChallengeMission_ScoutHoldPos, 3, {sIndex = pathIndex, sNode = i })
		
		SGroup_WarpToMarker(gbetoScoutPath[pathIndex][i]["sGroup"], gbetoScoutPath[pathIndex][i]["marker"])
		gbetoScoutPath[pathIndex][i]["torchVisible"] = false
		gbetoScoutPath[pathIndex][i]["torchLit"] = true
		gbetoScoutPath[pathIndex][i]["torchStartTime"] = timeElapsed
		
	end
end

function ChallengeMission_ScoutHoldPos(context, data)
	
	local position = Util_GetPosition(gbetoScoutPath[data.sIndex][data.sNode]["marker"])
	local facing1 = Util_GetPosition(mkr_enemy_house_01)
	local facing2 = Util_GetPosition(mkr_enemy_house_02)
	
	
	local squad = SGroup_GetSquadAt(gbetoScoutPath[data.sIndex][data.sNode]["sGroup"], 1)
	
	local entity = Squad_GetFirstEntity(squad)
	Squad_SetPosition(squad, position, facing2)
	Entity_SetPosition(entity, position)
	Cmd_Stop(sg_temp)
		
	local unit = {
		squadID = Squad_GetID(squad),
		position = position,
		facing = facing2,
		row = row,
	}
	ChallengeMission_ScoutHoldGround(unit) 
	
	--Cmd_Attack(gbetoScoutPath[data.sIndex][data.sNode]["sGroup"], eg_enemy_building_01, false)
	
end

--
-- turn the "lock into the wall" on and off for a particular unit
--
function ChallengeMission_ScoutHoldGround(unit) 

	if Squad_IsValid(unit.squadID) then
	
		local squad = Squad_FromID(unit.squadID)
		
		if Squad_Count(squad) >= 1 then 
			
			local entity = Squad_GetFirstEntity(squad)

			SGroup_Single(sg_temp, squad)																-- shield wall units:
			unit.modid_damage = Modify_WeaponDamage(sg_temp, "hardpoint_01", 3)								-- have more damage
			unit.modid_shield = Modify_ReceivedDamage(sg_temp, 0.75)										-- take less damage themselves
			
			Entity_SetRangedBlocksPerAttacks(entity, 1, 1)
			Entity_SetProjectileBlocksPerAttacks(entity, 1, 1)
			Entity_SetMeleeBlocksPerAttacks(entity, 19, 20)
			
			
			Cmd_HoldPosition(sg_temp, true, true)		-- hold position at current location
			
		end
		
	end
	
end

function ChallengeMission_UpdateTorches()
	local timeElapsed = World_GetGameTime() - startTime
	
	--torches do not light if triggered offscreen so we need to check to light them again
	for p = 1, #gbetoScoutPath do
		for i = 1, #gbetoScoutPath[p] do
			if(gbetoScoutPath[p][i]["torchLit"] == true and gbetoScoutPath[p][i]["torchVisible"] == false) then
				
				if(timeElapsed >= gbetoScoutPath[p][i]["torchStartTime"] + 7) then
					
					if(Misc_IsPosOnScreen(Util_GetPosition(gbetoScoutPath[p][i]["sGroup"]), 1) == true) then
						
						SGroup_WarpToMarker(gbetoScoutPath[p][i]["sGroup"], gbetoScoutPath[p][i]["marker"])
						
						SGroup_DestroyAllSquads(gbetoScoutPath[p][i]["sGroup"])
						SGroup_Clear(gbetoScoutPath[p][i]["sGroup"])
						
						UnitEntry_DeploySquads(neutralPlayer, gbetoScoutPath[p][i]["sGroup"], {{sbp = SBP.MALIAN.UNIT_GBETO_4_ONLY_TORCH_MAL, numSquads = 1 }}, gbetoScoutPath[p][i]["marker"])
						
						if(gbetoScoutPath[p][i]["roadSide"] == "right") then
							Cmd_Attack(gbetoScoutPath[p][i]["sGroup"], eg_enemy_building_01, false)
						else
							Cmd_Attack(gbetoScoutPath[p][i]["sGroup"], eg_enemy_building_02, false)
						end
						
						Modify_UnitSpeed(gbetoScoutPath[p][i]["sGroup"], 0, -1)
						Cmd_HoldPosition(gbetoScoutPath[p][i]["sGroup"], gbetoScoutPath[p][i]["marker"], false)
						SGroup_WarpToMarker(gbetoScoutPath[p][i]["sGroup"], gbetoScoutPath[p][i]["marker"])
						SGroup_SetInvulnerable(gbetoScoutPath[p][i]["sGroup"], true, -1)
						
						
						gbetoScoutPath[p][i]["torchVisible"] = true
						Cmd_HoldPosition(gbetoScoutPath[p][i]["sGroup"], true, true)
					end
				end
			end
		end
	end
	
	
end

--? @shortdesc Create temporary minimap blip at a marker
function ChallengeMission_SetupMinimapNode(context, data)
	--markerPath, pathIndex, nodeIndex
	
	if(data.nodeIndex == #(data.markerPath)) then
		--add threat blip at target
		UI_CreateMinimapBlip(data.markerPath[#data.markerPath], .5, "threat_group")
		--objective_capture
	end
	
	--add minimap blip
	local entry = {
		id = data.nodeIndex,
		--blip  = UI_CreateMinimapBlip(data.markerPath[data.nodeIndex], 1.5, "general")
		blip = UI_CreateMinimapBlipOnMarkerFrom(allyPlayer, data.markerPath[data.nodeIndex], 1.5, "general")
	}
	table.insert(path1Blips, entry)
	
	
end



function ChallengeMission_IntroduceDiplomacyUI()
	
	ChallengeMission_ShowTributeMenu()
	
	Rule_AddInterval(ChallengeMission_CheckDiplomacyReminder, 1)
end

function ChallengeMission_CheckDiplomacyReminder()
	
	current_gold_total = Player_GetResource(player1, RT_Gold)
	
	if current_gold_total >= 500 and current_gold_total > prev_gold_total and Diplomacy_IsExpanded() == false then
		
		if UI_IsXboxUI() then
			
			MalianTrainingGoals_AddDiplomacyPanelHint()
			Rule_RemoveMe()
			
		else
			Diplomacy_ShowDiplomacyUI(true)
		end
	end
	
	prev_gold_total = current_gold_total
end

function ChallengeMission_ShowTributeMenu()
	Diplomacy_ShowUI(true)
	
	UI_ReinforcePanel_UpdateData()
	Rule_AddInterval(UI_ReinforcePanel_UpdateData, 1)
	
end

function ChallengeMission_HideTributeMenu()

	Core_CallDelegateFunctions("DiplomacyEnabled", false)
	Diplomacy_ShowUI(false)
end


--this function orders units to form a line form startPos to endPos with the curvature curveStrength
function ArcFormation(startPos, endPos, inGroup, curveStrength, inQueued, inOffset)
	if(SGroup_CountSpawned(inGroup) == 0) then
		return
	end
	
	local fLine = Util_GetPosition(startPos)
	fLine["x"] = endPos["x"] - startPos["x"]
	fLine["z"] = endPos["z"] - startPos["z"]
	
	local tLine = Util_GetPosition(startPos)
	tLine["x"] = fLine["z"]
	tLine["z"] = -fLine["x"]
	
	
	for i = 1, SGroup_Count(inGroup) do
		--offset should be from 0 to 1
		local pointD = (i - inOffset) / SGroup_Count(inGroup)
		
		local unitDest = Util_GetPosition(startPos)
		--calculate the destination for each unit
		unitDest["x"] = startPos["x"] + (pointD * fLine["x"])
		unitDest["z"] = startPos["z"] + (pointD * fLine["z"])
		
		local curveMultiplier = pointD - .5
		
		curveMultiplier = curveMultiplier * curveMultiplier
		curveMultiplier = .25 - curveMultiplier
		
		unitDest["x"] = unitDest["x"] + (tLine["x"] * curveMultiplier * curveStrength)
		unitDest["z"] = unitDest["z"] + (tLine["z"] * curveMultiplier * curveStrength)
		
		--isolate each unit and give it a move order
		local squad = SGroup_GetSquadAt(inGroup, i)
		SGroup_Single(sg_single, squad)
		Cmd_Move(sg_single, unitDest, inQueued)
	end
	
end

