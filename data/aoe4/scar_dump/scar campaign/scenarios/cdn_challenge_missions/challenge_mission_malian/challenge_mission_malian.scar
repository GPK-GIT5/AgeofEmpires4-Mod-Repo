function ChallengeMission_SetupDiplomacy()
	
	
	Player_SetRelationship(localPlayer, allyPlayer, R_ALLY)
	Player_SetRelationship(allyPlayer, localPlayer, R_ALLY)
	
	Player_SetRelationship(localPlayer, enemyPlayer, R_ENEMY)
	
	Player_SetRelationship(enemyPlayer, allyPlayer, R_ALLY)
	Player_SetRelationship(allyPlayer, enemyPlayer, R_ALLY)
	
	Player_SetRelationship(localPlayer, neutralPlayer, R_ALLY)
	Player_SetRelationship(neutralPlayer, localPlayer, R_ALLY)
	
	Player_SetRelationship(enemyPlayer, neutralPlayer, R_ALLY)
	Player_SetRelationship(neutralPlayer, enemyPlayer, R_ALLY)
	
	Player_SetRelationship(allyPlayer, enemyPlayer2, R_ENEMY)
	Player_SetRelationship(enemyPlayer2, allyPlayer, R_ENEMY)
	
	Player_SetRelationship(neutralPlayer, enemyPlayer2, R_ENEMY)
	Player_SetRelationship(enemyPlayer2, neutralPlayer, R_ENEMY)
	
	World_EnableSharedLineOfSight(localPlayer, neutralPlayer, false)
	
	World_EnableSharedLineOfSight(localPlayer, allyPlayer, false)
	World_EnableSharedLineOfSight(allyPlayer, localPlayer, false)
	World_EnableSharedLineOfSight(allyPlayer, enemyPlayer2, true)
	
	World_EnableSharedLineOfSight(localPlayer, enemyPlayer2, false)
	
	-----
	
end

--return the number of units of type rounded down to stay under remaining cost
function ChallengeMission_GetWaveUnitCount(waveUnitPercent, waveUnitBP)
	
	local unitCostAllResources = Player_GetSquadBPCost(enemyPlayer, waveUnitBP)
	local unitCost = unitCostAllResources.food + unitCostAllResources.wood + unitCostAllResources.gold
	local idealCount = math.ceil((endlessWaveCost * waveUnitPercent) / unitCost)
	
	--reduce idealCount if there is not enough remaining resources, but keep >= 1
	while(idealCount * unitCost > endlessWaveCostRemaining and idealCount > 1) do
		idealCount = idealCount - 1
	end
	
	endlessWaveCostRemaining = endlessWaveCostRemaining - (idealCount * unitCost)
	return idealCount
end

function ChallengeMission_AddNewWave()
	--adds a new wave from the pattern of endless wave unit makeups
	--waves follow a pattern and increase in strength and frequency
	
	local newWaveIndex = #waveObjectList + 1
	
	--add event for the 2nd wave (contains groups 3 and 4)
	if(newWaveIndex == 3) then
		-- Play dialogue
		Util_StartIntel(EVENTS.Narr2ndWave)
	end
	
	if(newWaveIndex == 5) then
		-- Play dialogue (removed, this line now used in preintro)
		--Util_StartIntel(EVENTS.NarrHealInStealth)
	end
	
	--add event for big combined waves
	if(endlessWavesType == waveRepeatMark or endlessWavesType == 4) then
		-- Play dialogue
		Util_StartIntel(EVENTS.NarrBigWave)
		Sound_Play2D("sfx_campaign_scripted_attack_horn_under_attack_high")
	end
	
	--set hints to invisible
	HintPoint_SetVisible(hint_path1, false)
	HintPoint_SetVisible(hint_path2, false)
	HintPoint_SetVisible(hint_path3, false)
	HintPoint_SetVisible(hint_path4, false)
	
	
	
	for i = 1, #endlessWavePattern do
		--reset endless wave remaining cost
		endlessWaveCostRemaining = endlessWaveCost
		
		--add the wave unit data
		if(endlessWavePattern[i]["wave"] == endlessWavesType) then
			local sg_endlessWave = SGroup_Create("sgEndless" .. tostring(newWaveIndex))
			
			waveUnitMakeup = {}
			for u = 1, #endlessWavePattern[i]["waveMakeup"] do
				
				local uCount = ChallengeMission_GetWaveUnitCount(endlessWavePattern[i]["waveMakeup"][u]["waveUnitPercent"], endlessWavePattern[i]["waveMakeup"][u]["waveUnitBP"])
				waveUnitMakeup[u] = {waveUnitBP = endlessWavePattern[i]["waveMakeup"][u]["waveUnitBP"], waveUnitCount = uCount}
			end
			waveObjectList[newWaveIndex] = {waveNumber = newWaveIndex, wavePath = endlessWavePattern[i]["path"], waveGroup = sg_endlessWave, 
				waveUnits = waveUnitMakeup, waveSpawnPoint = endlessWavePattern[i]["spawnPoint"], waveSpeedModifier = endlessWavePattern[i]["speedModifier"], waveStartTime = 0, waveStarted = false, waveAttacking = false,
				wavePathProgress = 0, scoutPathProgress = 0, wavePathFinished = false, waveDefeated = false, conversionStarted = false, conversionTime = 0,
				waveDelayFinished = false, waveDelayTime = (World_GetGameTime() - startTime) + 10}
			
			
			--give hint text
			if(waveObjectList[newWaveIndex]["wavePath"] == 1) then
				HintPoint_SetVisible(hint_path1, true)
				blip_hint = UI_CreateMinimapBlip(mkr_path_1_scout_10, 5, "question_here")
			elseif(waveObjectList[newWaveIndex]["wavePath"] == 2) then
				if(endlessWavesType == 4 or endlessWavesType == 7) then
					HintPoint_SetVisible(hint_path4, true)
				else
					HintPoint_SetVisible(hint_path2, true)
				end
				blip_hint = UI_CreateMinimapBlip(mkr_path_2_scout_07, 5, "question_here")
			elseif(waveObjectList[newWaveIndex]["wavePath"] == 3) then
				HintPoint_SetVisible(hint_path3, true)
				blip_hint = UI_CreateMinimapBlip(mkr_path_3_scout_07, 5, "question_here")
			end
			
			
			newWaveIndex = #waveObjectList + 1
		end
	end
	
	
	--give more time after the big middle waves
	if(endlessWavesType == waveRepeatMark or endlessWavesType == 4) then
		nextEndlessWaveTime = nextEndlessWaveTime + 20
	end
	
	
	--cycle to next composition type
	endlessWavesType = endlessWavesType + 1
	if(endlessWavesType > waveRepeatMark) then
		endlessWavesType = 1
	end
	
	--adjust next wave time and cost
	if(nextEndlessWaveTime > 960) then
		nextEndlessWaveTime = nextEndlessWaveTime + 40
		endlessWaveCost = endlessWaveCost + 75
	elseif(nextEndlessWaveTime > 720) then
		nextEndlessWaveTime = nextEndlessWaveTime + 41
		endlessWaveCost = endlessWaveCost + 70
	elseif(nextEndlessWaveTime > 480) then
		nextEndlessWaveTime = nextEndlessWaveTime + 43
		endlessWaveCost = endlessWaveCost + 65
	elseif(nextEndlessWaveTime > 330) then
		nextEndlessWaveTime = nextEndlessWaveTime + 45
		endlessWaveCost = endlessWaveCost + 60
	else
		nextEndlessWaveTime = nextEndlessWaveTime + 50
		endlessWaveCost = endlessWaveCost + 50
	end
	
	--give more time before the big middle waves
	if(endlessWavesType == waveRepeatMark or endlessWavesType == 4) then
		nextEndlessWaveTime = nextEndlessWaveTime + 30
	end
	
	--give more time after the first wave (groups 1 and 2)
	if(newWaveIndex == 3) then
		nextEndlessWaveTime = nextEndlessWaveTime + 15
	end
end

