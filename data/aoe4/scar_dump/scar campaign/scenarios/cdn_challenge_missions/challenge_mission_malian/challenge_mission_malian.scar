-- Called when Mission loads
function Mission_OnInit()
	
	if UI_IsXboxUI() then
		_challenge.benchmarks.unplaced = {
			minimumGoldCollected = 2500,
			objective = {},
		}
		_challenge.benchmarks.bronze = {
			minimumGoldCollected = 4000,
			objective = {},
		}
		_challenge.benchmarks.silver = {
			minimumGoldCollected = 6500,
			objective = {},
		}
		_challenge.benchmarks.gold = {
			minimumGoldCollected = 6500,
			objective = {},
		}
	end
end

