--objectives for delay before mission start
function ChallengeMission_PathSetupObjectives()

	local location = LOCATION("path1Capture")
	
	    OBJ_PrepareForAmbush = 
	{
         
        Title = "$11226358",
        Type = ObjectiveType_Capture,
    }
	
	SOBJ_Path1 = 
	{
		Title = "$11226359", 
		Type = ObjectiveType_Capture,
		Parent = OBJ_PrepareForAmbush,
		StartAlongsideParent = true, 
	}
	
	SOBJ_Path2 = 
	{
		Title = "$11226360", 
		Type = ObjectiveType_Capture,
		Parent = OBJ_PrepareForAmbush,
		StartAlongsideParent = true, 
	}
	
		OBJ_Recruit = 
	{
		Title = "$11226361", 
		Type = ObjectiveType_Optional,
	}
	
	SOBJ_RecruitPanel = 
	{
		Title = "$11226362", 
		Type = ObjectiveType_Optional,
		Parent = OBJ_Recruit,
		StartAlongsideParent = true, 
	}
	
	Objective_Register(OBJ_PrepareForAmbush)
	Objective_Register(SOBJ_Path1)
	Objective_Register(SOBJ_Path2)
	
	Objective_Register(OBJ_Recruit)
	Objective_Register(SOBJ_RecruitPanel)
	
	path1Capturing = false
	path2Capturing = false
	path1CaptureTime = 0
	path2CaptureTime = 0
	pathCaptureDuration = 2
	
	location.objectivePrimary = OBJ_PrepareForAmbush
	location.objectiveSecondary = SOBJ_Path1
	location.objectiveSecondary = SOBJ_Path2
	
	
	Objective_Start(OBJ_PrepareForAmbush, false, false)
	Objective_Start(SOBJ_Path1, false, false)
	Objective_Start(SOBJ_Path2, false, false)
	
	Objective_Start(OBJ_Recruit, false, false)
	Objective_Start(SOBJ_RecruitPanel, false, false)
	
	-- Add UI Elements
	Objective_AddUIElements(SOBJ_Path1, mkr_path1Capture, false, "$11226363", true, -2)
	Objective_AddUIElements(SOBJ_Path2, mkr_path2Capture, false, "$11226364", true, -2)
	Objective_AddUIElements(OBJ_PrepareForAmbush, mkr_path3Capture, false, "$11226365", true, -2)
	
	-----
	-----
	
	
	
	local bp_reticule = BP_GetReticuleBlueprint("capture_neutral_holy_site")--medium width white circle
	local reticulePos = Util_GetPosition(mkr_path1Capture)
	local size = 15
	captureReticuleID1 = UI_ModalVisual_CreateReticule(bp_reticule, size)
	UI_ModalVisual_SetPosition(captureReticuleID1, reticulePos)
	
	captureReticuleID2 = UI_ModalVisual_CreateReticule(bp_reticule, size)
	reticulePos = Util_GetPosition(mkr_path2Capture)
	UI_ModalVisual_SetPosition(captureReticuleID2, reticulePos)
	
	
	Rule_AddInterval(ChallengeMission_CheckPathSetupObjectives, .5)
end

function ChallengeMission_CheckPathSetupObjectives()

	
	sg_player_startUnits = SGroup_CreateIfNotFound("sg_player_startUnits")
	
	SGroup_Clear(sg_player_startUnits)
	Player_GetAllSquadsNearMarker(localPlayer, sg_player_startUnits, Util_GetPosition(mkr_path1Capture), 15)
	if(SGroup_CountSpawned(sg_player_startUnits) > 0) then
		
		if(Objective_IsComplete(SOBJ_Path1) == false and path1Capturing == false) then
			path1Capturing = true
			path1CaptureTime = World_GetGameTime() + pathCaptureDuration
			Rule_AddInterval(ChallengeMission_CapturePath1, .025)
			
			local bp_reticule = BP_GetReticuleBlueprint("campaign_capturelocation_self")-- blue circle
			local reticulePos = Util_GetPosition(mkr_path1Capture)
			local size = 15
			
			captureReticuleID1_blue1 = UI_ModalVisual_CreateReticule(bp_reticule, size)
			UI_ModalVisual_SetPosition(captureReticuleID1_blue1, reticulePos)
			
		end
	elseif(Objective_IsComplete(SOBJ_Path1) == false and path1Capturing == true) then
		path1Capturing = false
		if(captureReticuleID1_blue1 ~= nil) then
			UI_ModalVisual_Destroy(captureReticuleID1_blue1)
		end
		if(captureReticuleID1_blue2 ~= nil) then
			UI_ModalVisual_Destroy(captureReticuleID1_blue2)
		end
		if(Rule_Exists(ChallengeMission_CapturePath1)) then
			Rule_Remove(ChallengeMission_CapturePath1)
		end
	elseif(Objective_IsComplete(SOBJ_Path1) == true) then
		Objective_Stop(SOBJ_Path1, false, false)
		Objective_Start(SOBJ_Path1, false, false)
		
		if(captureReticuleID1_blue1 ~= nil) then
			UI_ModalVisual_Destroy(captureReticuleID1_blue1)
		end
		if(captureReticuleID1_blue2 ~= nil) then
			UI_ModalVisual_Destroy(captureReticuleID1_blue2)
		end
		--respawn white circle
		local bp_reticule = BP_GetReticuleBlueprint("capture_neutral_holy_site")--medium width white circle
		local reticulePos = Util_GetPosition(mkr_path1Capture)
		local size = 15
		captureReticuleID1 = UI_ModalVisual_CreateReticule(bp_reticule, size)
		UI_ModalVisual_SetPosition(captureReticuleID1, reticulePos)
	end

	SGroup_Clear(sg_player_startUnits)
	Player_GetAllSquadsNearMarker(localPlayer, sg_player_startUnits, Util_GetPosition(mkr_path2Capture), 15)
	if(SGroup_CountSpawned(sg_player_startUnits) > 0) then
		
		if(Objective_IsComplete(SOBJ_Path2) == false and path2Capturing == false) then
			path2Capturing = true
			path2CaptureTime = World_GetGameTime() + pathCaptureDuration
			Rule_AddInterval(ChallengeMission_CapturePath2, .025)
			
			local bp_reticule = BP_GetReticuleBlueprint("campaign_capturelocation_self")-- blue circle
			local reticulePos = Util_GetPosition(mkr_path2Capture)
			local size = 15
			
			captureReticuleID2_blue1 = UI_ModalVisual_CreateReticule(bp_reticule, size)
			UI_ModalVisual_SetPosition(captureReticuleID2_blue1, reticulePos)
			
		end
	elseif(Objective_IsComplete(SOBJ_Path2) == false and path2Capturing == true) then
		path2Capturing = false
		if(captureReticuleID2_blue1 ~= nil) then
			UI_ModalVisual_Destroy(captureReticuleID2_blue1)
		end
		if(captureReticuleID2_blue2 ~= nil) then
			UI_ModalVisual_Destroy(captureReticuleID2_blue2)
		end
		if(Rule_Exists(ChallengeMission_CapturePath2)) then
			Rule_Remove(ChallengeMission_CapturePath2)
		end
	elseif(Objective_IsComplete(SOBJ_Path2) == true) then
		Objective_Stop(SOBJ_Path2, false, false)
		Objective_Start(SOBJ_Path2, false, false)
		
		if(captureReticuleID2_blue1 ~= nil) then
			UI_ModalVisual_Destroy(captureReticuleID2_blue1)
		end
		if(captureReticuleID2_blue2 ~= nil) then
			UI_ModalVisual_Destroy(captureReticuleID2_blue2)
		end
		--respawn white circle
		local bp_reticule = BP_GetReticuleBlueprint("capture_neutral_holy_site")--medium width white circle
		local reticulePos = Util_GetPosition(mkr_path2Capture)
		local size = 15
		captureReticuleID2 = UI_ModalVisual_CreateReticule(bp_reticule, size)
		UI_ModalVisual_SetPosition(captureReticuleID2, reticulePos)
	end
	
	--check if both capture objectives are complete
	if(Objective_IsComplete(SOBJ_Path1) and Objective_IsComplete(SOBJ_Path2)) then
		Objective_Complete(OBJ_PrepareForAmbush, true, false)
		
		if(captureReticuleID1_blue1 ~= nil) then
			UI_ModalVisual_Destroy(captureReticuleID1_blue1)
		end
		if(captureReticuleID2_blue1 ~= nil) then
			UI_ModalVisual_Destroy(captureReticuleID2_blue1)
		end
		
		--replace allied pit mines with player pit mines to start resource collection
		EGroup_DestroyAllEntities(eg_gold_mines)
		EGroup_Clear(eg_gold_mines)
		
		eg_goldDeposits = EGroup_CreateIfNotFound("eg_goldDeposits")
		World_GetAllNeutralEntities(eg_goldDeposits)
		if(eg_goldDeposits ~= nil) then
			if(EGroup_Count(eg_goldDeposits) > 0) then
				EGroup_Filter(eg_goldDeposits, "gold", FILTER_KEEP)
				
				if(EGroup_Count(eg_goldDeposits) > 0) then
					for i = 1, EGroup_Count(eg_goldDeposits) do
						local entity = EGroup_GetEntityAt(eg_goldDeposits, i)	
						EGroup_Single(eg_single, entity)	
						
						if(Util_GetDistance(eg_single, mkr_gold1) < 30) then
							Util_CreateEntities(localPlayer, eg_gold_mines, EBP.MALIAN.BUILDING_OPEN_PIT_MINE_MAL, Util_GetPosition(eg_single), 1, nil, nil, false)
						end
						if(Util_GetDistance(eg_single, mkr_gold2) < 30) then
							Util_CreateEntities(localPlayer, eg_gold_mines, EBP.MALIAN.BUILDING_OPEN_PIT_MINE_MAL, Util_GetPosition(eg_single), 1, nil, nil, false)
						end
						if(Util_GetDistance(eg_single, mkr_gold3) < 30) then
							Util_CreateEntities(localPlayer, eg_gold_mines, EBP.MALIAN.BUILDING_OPEN_PIT_MINE_MAL, Util_GetPosition(eg_single), 1, nil, nil, false)
						end
					end
				end
			end
		end
		
		
		wavesStarted = true
		startTime = World_GetGameTime()
		
		--start main objectives
		Objective_Start(OBJ_Victory)
		Objective_Start(OBJ_AmbushWaves)
		Objective_Start(_challenge.currentBenchmark.objective, false, false)
		
		Util_StartIntel(EVENTS.NarrMissionStart)
		
		
		--make sure white circles are removed
		UI_ModalVisual_Destroy(captureReticuleID1)
		UI_ModalVisual_Destroy(captureReticuleID2)
		
		Rule_RemoveMe()
	end
end


function ChallengeMission_CapturePath1()
	
	
	local timeElapsed = World_GetGameTime()
	if(captureReticuleID1_blue2 ~= nil) then
		UI_ModalVisual_Destroy(captureReticuleID1_blue2)
	end
	
	local bp_reticule = BP_GetReticuleBlueprint("campaign_capturelocation_self")-- blue circle
	local size = 15 - (15 * ((path1CaptureTime - timeElapsed) / pathCaptureDuration))
	local reticulePos = Util_GetPosition(mkr_path1Capture)
	
	captureReticuleID1_blue2 = UI_ModalVisual_CreateReticule(bp_reticule, size)
	UI_ModalVisual_SetPosition(captureReticuleID1_blue2, reticulePos)
	
	if(timeElapsed >= path1CaptureTime) then
		
		path1Capturing = false
		
		-- Mark Objective as Complete
		Objective_Complete(SOBJ_Path1, false, false)
		UI_ModalVisual_Destroy(captureReticuleID1)
		
		if(captureReticuleID1_blue2 ~= nil) then
			UI_ModalVisual_Destroy(captureReticuleID1_blue2)
		end
		Rule_RemoveMe()
		return
	end
	
end

function ChallengeMission_CapturePath2()
	
	
	local timeElapsed = World_GetGameTime()
	if(captureReticuleID2_blue2 ~= nil) then
		UI_ModalVisual_Destroy(captureReticuleID2_blue2)
	end
	
	local bp_reticule = BP_GetReticuleBlueprint("campaign_capturelocation_self")-- blue circle
	local size = 15 - (15 * ((path2CaptureTime - timeElapsed) / pathCaptureDuration))
	local reticulePos = Util_GetPosition(mkr_path2Capture)
	
	captureReticuleID2_blue2 = UI_ModalVisual_CreateReticule(bp_reticule, size)
	UI_ModalVisual_SetPosition(captureReticuleID2_blue2, reticulePos)
	
	if(timeElapsed >= path2CaptureTime) then
		
		path2Capturing = false
		
		-- Mark Objective as Complete
		Objective_Complete(SOBJ_Path2, false, false)
		UI_ModalVisual_Destroy(captureReticuleID2)
		
		if(captureReticuleID2_blue2 ~= nil) then
			UI_ModalVisual_Destroy(captureReticuleID2_blue2)
		end
		
		Rule_RemoveMe()
		return
	end
	
end


-----

function ChallengeMission_UpdateMedals()
	
	if(_challenge.currentBenchmark == _challenge.benchmarks.unplaced)then
		Util_StartIntel(EVENTS.NarrBronzeThreshold )
		Objective_Complete(_challenge.currentBenchmark.objective, false, false)
		_challenge.currentBenchmark = _challenge.benchmarks.bronze
		Objective_Register(_challenge.currentBenchmark.objective, localPlayer.id)
		Objective_Start(_challenge.currentBenchmark.objective, false, false)
		Objective_SetCounter(_challenge.currentBenchmark.objective, challengeGoldCollected)
	elseif(_challenge.currentBenchmark == _challenge.benchmarks.bronze)then
		Util_StartIntel(EVENTS.NarrSilverThreshold )
		Objective_Complete(_challenge.currentBenchmark.objective, false, false)
		_challenge.currentBenchmark = _challenge.benchmarks.silver
		Objective_Register(_challenge.currentBenchmark.objective, localPlayer.id)
		Objective_Start(_challenge.currentBenchmark.objective, false, false)
		Objective_SetCounter(_challenge.currentBenchmark.objective, challengeGoldCollected)
	elseif(_challenge.currentBenchmark == _challenge.benchmarks.silver)then
		Util_StartIntel(EVENTS.NarrGoldThreshold )
		Objective_Complete(_challenge.currentBenchmark.objective, false, false)
		_challenge.currentBenchmark = _challenge.benchmarks.gold
		Objective_Register(_challenge.currentBenchmark.objective, localPlayer.id)
		Objective_Start(_challenge.currentBenchmark.objective, false, false)
		Objective_SetCounter(_challenge.currentBenchmark.objective, challengeGoldCollected)
	end
	
end


function ChallengeMission_CheckVictory()
	
	-- Store completion loss counter
	local points = Objective_GetCounter(_challenge.currentBenchmark.objective)
	-- Package completion time for Data Store
	local trialInformation = {kpi = points}
	
	-- Provide completion time to Stats system via Data Store
	Game_StoreTableData("trial", trialInformation)
	
	if(_challenge.currentBenchmark == _challenge.benchmarks.unplaced)then
		--fail if current objective is unplaced
		Rule_AddOneShot(Mission_Fail, 0)
	else
		-- Set victory objective to complete
		Objective_Complete(OBJ_Victory, false, true)
		-- After a short delay end the mission.
		Rule_AddOneShot(ChallengeMission_EndChallenge, 0)
	end

end

function ChallengeMission_EndChallenge()
	
	
	-- Play dialogue
	if(_challenge.currentBenchmark == _challenge.benchmarks.bronze)then
		Util_StartIntel(EVENTS.NarrMissionEndBronze)
	elseif(_challenge.currentBenchmark == _challenge.benchmarks.silver)then
		Util_StartIntel(EVENTS.NarrMissionEndSilver)
	elseif(_challenge.currentBenchmark == _challenge.benchmarks.gold)then
		Util_StartIntel(EVENTS.NarrMissionEndGold)
		Game_SendCustomChallengeEvent(player1, CE_MALIANSARTGOLD, 1)
	end
	
	Mission_Complete()
	--Core_SetPlayerVictorious(localPlayer, nil, WR_OBJECTIVECOMPLETE)
	
end

-- Setup functionality for mission
function ChallengeMission_OnGameSetup()
	
	-- Create player references
	localPlayer = World_GetPlayerAt(1) --Player
	enemyPlayer = World_GetPlayerAt(2) --enemy AI player
	allyPlayer = World_GetPlayerAt(3) --ally AI player
	enemyPlayer2 = World_GetPlayerAt(4) --enemy AI player 2
	neutralPlayer = World_GetPlayerAt(5) --ally AI player scouts
	scoutPlayer = World_GetPlayerAt(6) --ally AI player scouts
	
end

function ChallengeMission_SpawnPlayerUnits()
	
	sg_player_musofadi_01 = SGroup_CreateIfNotFound("sg_player_musofadi_01")
	
	UnitEntry_DeploySquads(localPlayer, sg_player_musofadi_01, {{sbp = BP_GetSquadBlueprint("unit_gbeto_4_mal"), numSquads = 8 }}, mkr_musofadi_spawn_01)
	UnitEntry_DeploySquads(localPlayer, sg_player_musofadi_01, {{sbp = BP_GetSquadBlueprint("unit_javelin_4_mal"), numSquads = 10 }}, mkr_javelin_spawn_01)
	UnitEntry_DeploySquads(localPlayer, sg_player_musofadi_01, {{sbp = BP_GetSquadBlueprint("unit_spearman_4_mal"), numSquads = 10 }}, mkr_donso_spawn_01)
	
	--spawn mines for ally player to prevent gaining gold before mission start
	eg_gold_mines = EGroup_CreateIfNotFound("eg_gold_mines")
	
	eg_goldDeposits = EGroup_CreateIfNotFound("eg_goldDeposits")
	World_GetAllNeutralEntities(eg_goldDeposits)
	if(eg_goldDeposits ~= nil) then
		if(EGroup_Count(eg_goldDeposits) > 0) then
			EGroup_Filter(eg_goldDeposits, "gold", FILTER_KEEP)
			
			for i = 1, EGroup_Count(eg_goldDeposits) do
				local entity = EGroup_GetEntityAt(eg_goldDeposits, i)	
				EGroup_Single(eg_single, entity)	
				
				if(Util_GetDistance(eg_single, mkr_gold1) < 30) then
					Util_CreateEntities(allyPlayer, eg_gold_mines, EBP.MALIAN.BUILDING_OPEN_PIT_MINE_MAL, Util_GetPosition(eg_single), 1, nil, nil, false)
				end
				if(Util_GetDistance(eg_single, mkr_gold2) < 30) then
					Util_CreateEntities(allyPlayer, eg_gold_mines, EBP.MALIAN.BUILDING_OPEN_PIT_MINE_MAL, Util_GetPosition(eg_single), 1, nil, nil, false)
				end
				if(Util_GetDistance(eg_single, mkr_gold3) < 30) then
					Util_CreateEntities(allyPlayer, eg_gold_mines, EBP.MALIAN.BUILDING_OPEN_PIT_MINE_MAL, Util_GetPosition(eg_single), 1, nil, nil, false)
				end
			end
		end
	end
	
end


