LateSiege_PreIntro_CleanUp05 = function()
	
	--remove all enemy buildings in the cinematic area
	local distanceThreshold = 90
	
	-- Create EGroup
	eg_preIntro05_building_cleanup = EGroup_CreateIfNotFound("eg_preIntro05_building_cleanup")
	eg_preIntro05_neutral_cleanup = EGroup_CreateIfNotFound("eg_preIntro05_neutral_cleanup")
	
	-- Create SGroup
	sg_preIntro05_unit_cleanup = SGroup_CreateIfNotFound("sg_preIntro05_unit_cleanup")
	
	
	--get buildings in area
	Player_GetAllEntitiesNearMarker(enemyPlayer, eg_preIntro05_building_cleanup, mkr_preintro_base_area, distanceThreshold)
	--get units in area
	Player_GetAllSquadsNearMarker(enemyPlayer, sg_preIntro05_unit_cleanup, mkr_preintro_base_area, distanceThreshold)
	--get neutral entities
	World_GetNeutralEntitiesNearMarker(eg_preIntro05_neutral_cleanup, mkr_preintro_base_area)
	
	
	-- Check if entities are buildings
	EGroup_Filter(eg_preIntro05_building_cleanup, "building", FILTER_KEEP)
	EGroup_Filter(eg_preIntro05_neutral_cleanup, "building", FILTER_KEEP)
	
	EGroup_DestroyAllEntities(eg_preIntro05_building_cleanup)
	EGroup_DestroyAllEntities(eg_preIntro05_neutral_cleanup)
	SGroup_DestroyAllSquads(sg_preIntro05_unit_cleanup)
	----
	
	
	-- Create SGroup
	sg_preIntro05_player_cleanup = SGroup_CreateIfNotFound("sg_preIntro05_player_cleanup")
	--get squads in area
	Player_GetAllSquadsNearMarker(localPlayer, sg_preIntro05_player_cleanup, mkr_preintro_base_area, distanceThreshold + 10)
	--remove any remaining player units (partially constructed siege weapons)
	SGroup_DestroyAllSquads(sg_preIntro05_player_cleanup)
	
	
	--temporary reveal for testing cinematic
	FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_preintro_base_area), 90, -1)
	Rule_AddOneShot(LateSiege_PreIntro_CleanUp05_Unreveal_Map, .5)
	
	--reset player resources (if cinematic is cancelled during construction of a ram/siege tower, the player will get extra wood)
	Rule_AddOneShot(LateSiege_PreIntro_CleanUp_ResetResources, 0)
end


--unreveal the map in the cinematic area
LateSiege_PreIntro_CleanUp05_Unreveal_Map = function()
	
	--unhide naval building
	eg_preIntro05_hidden_buildings = EGroup_CreateIfNotFound("eg_preIntro05_hidden_buildings")
	--get buildings in area
	Player_GetAllEntitiesNearMarker(enemyPlayer, eg_preIntro05_hidden_buildings, mkr_preintro_base_area, 150)
	-- Check if entities are buildings
	EGroup_Filter(eg_preIntro05_hidden_buildings, "naval_production_building", FILTER_KEEP)
	EGroup_Hide(eg_preIntro05_hidden_buildings, false)
	
	--reset fog of war
	FOW_PlayerUnRevealArea(localPlayer, Util_GetPosition(mkr_preintro_base_area))
	FOW_PlayerUnExploreAll(localPlayer)
	FOW_PlayerUnRevealAll(localPlayer)
	FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_player_siege1_rally), 60, -1)
	FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_east_zone), 60, -1)
	FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_inner_zone), 50, -1)
	FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_gate_zone), 60, -1)
	FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_west_zone), 60, -1)
	FOW_PlayerRevealArea(localPlayer, Util_GetPosition(mkr_player_warelephants1_rally), 60, -1)
	
	
end


--reset wood resources from cancelled siege towers and rams
LateSiege_PreIntro_CleanUp_ResetResources = function()
	
	CalculateLateSiegeStartingResources()
	Player_SetResource(localPlayer, RT_Food, _challenge.startingResources.food)
	Player_SetResource(localPlayer, RT_Wood, _challenge.startingResources.wood)
	Player_SetResource(localPlayer, RT_Gold, _challenge.startingResources.gold)
	Player_SetResource(localPlayer, RT_Stone, _challenge.startingResources.stone)
end
