LateSiege_PreIntro_CleanUpAll = function()
	
	LateSiege_PreIntro_CleanUp01()
	LateSiege_PreIntro_CleanUp02()
	LateSiege_PreIntro_CleanUp03()
	LateSiege_PreIntro_CleanUp04()
	LateSiege_PreIntro_CleanUp05()
end

LateSiege_PreIntro_CleanUp01 = function()
	
	
	if(SGroup_Exists("sg_preintro_01_spearmen_enemy1")) then
		SGroup_DestroyAllSquads(sg_preintro_01_spearmen_enemy1)
	end
	if(SGroup_Exists("sg_preintro_01_menatarms_enemy1")) then
		SGroup_DestroyAllSquads(sg_preintro_01_menatarms_enemy1)
	end
	
	Rule_Remove(LateSiege_PreIntro_Shot01_Face_Archers)
	Rule_Remove(LateSiege_PreIntro_Shot01_Face_Archers2)
	
end

LateSiege_PreIntro_CleanUp02 = function()
	
	
	if(SGroup_Exists("sg_preintro_02_menatarms1")) then
		SGroup_DestroyAllSquads(sg_preintro_02_menatarms1)
	end
	if(SGroup_Exists("sg_preintro_02_menatarms2")) then
		SGroup_DestroyAllSquads(sg_preintro_02_menatarms2)
	end
	if(SGroup_Exists("sg_preintro_02_menatarms3")) then
		SGroup_DestroyAllSquads(sg_preintro_02_menatarms3)
	end
	
	--find and destroy siege tower and ram
	
	-- Create SGroups
	sg_preIntro02_siege_tower = SGroup_CreateIfNotFound("sg_preIntro02_siege_tower")
	sg_preIntro02_ram = SGroup_CreateIfNotFound("sg_preIntro02_ram")
	local distanceThreshold = 10
	
	--get siege tower
	Player_GetAllSquadsNearMarker(localPlayer, sg_preIntro02_siege_tower, mrk_build_siegetower_location, distanceThreshold)
	
	-- Check if any squads are a siege tower
	SGroup_Filter(sg_preIntro02_siege_tower, "siege_tower", FILTER_KEEP)
	
	SGroup_DestroyAllSquads(sg_preIntro02_siege_tower)
	
	----
	
	--get 2nd siege tower
	Player_GetAllSquadsNearMarker(localPlayer, sg_preIntro02_siege_tower, mrk_build_siegetower_location2, distanceThreshold)
	
	-- Check if any squads are a siege tower
	SGroup_Filter(sg_preIntro02_siege_tower, "siege_tower", FILTER_KEEP)
	
	SGroup_DestroyAllSquads(sg_preIntro02_siege_tower)
	
	----
	
	--get ram
	Player_GetAllSquadsNearMarker(localPlayer, sg_preIntro02_ram, mrk_build_ram_location, distanceThreshold)
	
	-- Check if any squads are a ram
	SGroup_Filter(sg_preIntro02_ram, "ram", FILTER_KEEP)
	
	SGroup_DestroyAllSquads(sg_preIntro02_ram)
	
end


