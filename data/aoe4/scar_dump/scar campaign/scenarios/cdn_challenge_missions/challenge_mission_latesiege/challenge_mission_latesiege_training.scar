-- trebuchet Built Predicate
function TrebuchetBuiltPredicate(goalSequence)
	if(selectTrebuchetCount >= selectTrebuchetMax) then
		return true
	end

	local localPlayer = Game_GetLocalPlayer()
	local sg_player_units = Player_GetSquads(localPlayer)
		
	-- Check player units
	for i = 1, SGroup_Count(sg_player_units) do
		
		local squad = SGroup_GetSquadAt(sg_player_units, i)
		
		-- Check for unit on screen
		if Squad_IsOfType(squad, "trebuchet_counterweight") then
			
			-- Assign key to unit
			goalSequence.goals[1].key = Squad_GetID(squad)
			-- Check if a key was found for unit before continuing
			if goalSequence.goals[1].key == nil or scartype(goalSequence.goals[1].key) ~= ST_NUMBER then
				return false
			end
	
			return true
		end
		-- Check for unit on screen
		if Squad_IsOfType(squad, "trebuchet_traction") then
			
			-- Assign key to unit
			goalSequence.goals[1].key = Squad_GetID(squad)
			-- Check if a key was found for unit before continuing
			if goalSequence.goals[1].key == nil or scartype(goalSequence.goals[1].key) ~= ST_NUMBER then
				return false
			end
	
			return true
		end
	end
	
	
	-- End function
	return false
end

-- Player has selected a trebuchet
function UserHasSelectedTrebuchet(goal)
	if(selectTrebuchetCount >= selectTrebuchetMax) then
		return true
	end
	
	local localPlayer = Game_GetLocalPlayer()
	local sg_currentSelection = SGroup_CreateIfNotFound("sg_currentSelection")
	
	Misc_GetSelectedSquads(sg_currentSelection, false)
	
	-- Check player units
	for i = 1, SGroup_Count(sg_currentSelection) do
		local squad = SGroup_GetSquadAt(sg_currentSelection, i)
		
		-- Check that unit is a trebuchet
		if Squad_IsOfType(squad, "trebuchet_counterweight") then 
			
			if(selectTrebuchetActive == false) then
				selectTrebuchetActive = true
				selectTrebuchetCount = selectTrebuchetCount + 1
			end
			-- Player has selected the trebuchet
			return true
		end
		-- Check that unit is a trebuchet
		if Squad_IsOfType(squad, "trebuchet_traction") then 
			
			if(selectTrebuchetActive == false) then
				selectTrebuchetActive = true
				selectTrebuchetCount = selectTrebuchetCount + 1
			end
			-- Player has selected the trebuchet
			return true
		end
	end
	
	selectTrebuchetActive = false
	return false
end

