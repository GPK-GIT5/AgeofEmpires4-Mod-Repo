garrisonSiegeTowerActive = false
garrisonSiegeTowerCount = 0
garrisonSiegeTowerMax = 1
garrisonSiegeTowerStartTime = -1
--

unloadSiegeTowerActive = false
unloadSiegeTowerCount = 0
