import("training/coretrainingconditions.scar")
import("training/coretraininggoals.scar")

Core_RegisterModule("LateSiegeTrainingGoals")

local goal_sequence_siege_tower = "build_siege_tower"
local goal_sequence_garrison_siege_tower = "garrison_siege_tower"
local goal_sequence_unload_siege_tower = "unload_siege_tower"

local goal_sequence_battering_ram = "build_battering_ram"
local goal_sequence_siege_tower_intro = "build_siege_tower_intro"
local goal_sequence_springald = "build_springald"
local goal_sequence_mangonel = "build_mangonel"
local goal_sequence_trebuchet = "build_trebuchet"
local goal_sequence_bombard = "build_bombard"

local training_goals_late_siege =
{
	goal_sequence_siege_tower,
	goal_sequence_garrison_siege_tower,
	goal_sequence_unload_siege_tower,
	goal_sequence_battering_ram,
	goal_sequence_siege_tower_intro,
	goal_sequence_springald,
	goal_sequence_mangonel,
	goal_sequence_trebuchet,
	goal_sequence_bombard
}

function TrainingGoal_EnableLateSiegeGoals()
	for i, goalSequenceID in ipairs(training_goals_late_siege) do
		Training_EnableGoalSequenceByID(goalSequenceID, true)
	end
end

function TrainingGoal_DisableLateSiegeGoals()
	for i, goalSequenceID in ipairs(training_goals_late_siege) do
		Training_EnableGoalSequenceByID(goalSequenceID, false)
	end
end

function LateSiegeTrainingGoals_InitBuildSiegeTowerHint_Xbox()
	
	local selectSiegeEngineerGoal = Training_Goal("Entity",
		{ID= "Select a military unit to build a Siege Tower.", Message= "$11202714", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedSiegeEngineer)
	
	local openRadialGoal = Training_Goal("Squad",
		{ID= "Press RT to open the radial menu.", Message= "$1000968", DataTemplate="GenericTrainingDataTemplate"}, 
		UserHasOpenedContextualRadial)
	
	local selectSiegeTowerGoal = Training_Goal("PBG",
		{ID= "Select this option to build a Siege Tower.", Message= "$11249167", DataTemplate="LeftClickTrainingDataTemplate"},
		UserIsBuildingSiegeTower)
	
	local siegeTowerSequence = Training_GoalSequence(goal_sequence_siege_tower,
		-1, 0, 
		CanBuildSiegeTowerPredicate_Xbox, 
		nil, 
		nil,
		UserHasBuiltSiegeTower,
		false, 
		{selectSiegeEngineerGoal, openRadialGoal, selectSiegeTowerGoal})
	Training_AddGoalSequence(siegeTowerSequence)
end

function LateSiegeTrainingGoals_InitBuildSiegeTowerHint()
	
	local selectSiegeEngineerGoal = Training_Goal("Entity",
		{ID= "Select a military unit to build a Siege Tower.", Message= "$11202714", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedSiegeEngineer)
	local openMilitaryTabGoal = Training_Goal("MilitaryCommandCardTab",
		{ID= "Open the Military tab", Message= 1001508, DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasMilitaryCommandCardTabOpen)
	local selectSiegeTowerGoal = Training_Goal("PBG",
		{ID= "Click here to build a Siege Tower.", Message= "$11202715", DataTemplate="LeftClickTrainingDataTemplate"},
		UserIsBuildingSiegeTower)
	local buildSiegeTowerGoal = Training_Goal("Cursor",
		{ID= "Click a valid location to start construction.", Message= "$11202716", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasBuiltSiegeTower)
	
	local siegeTowerSequenceGoals = {selectSiegeEngineerGoal, selectSiegeTowerGoal, buildSiegeTowerGoal}
	if(UI_IsXboxKBMUI()) then
		siegeTowerSequenceGoals = {selectSiegeEngineerGoal, openMilitaryTabGoal, selectSiegeTowerGoal, buildSiegeTowerGoal}
	end
	
	local siegeTowerSequence = Training_GoalSequence(goal_sequence_siege_tower,
		-1, 0, 
		CanBuildSiegeTowerPredicate, 
		nil, 
		nil,
		UserHasBuiltSiegeTower,
		false, 
		siegeTowerSequenceGoals)
	Training_AddGoalSequence(siegeTowerSequence)
end

function LateSiegeTrainingGoals_OnInit()
	
	-- Disable core training goals for testing purposes
