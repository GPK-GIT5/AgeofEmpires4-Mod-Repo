	TrainingGoal_DisableCoreEconGoals()
	
	-------------------------------------------------------------------------
	---- Goal Sequences
	-------------------------------------------------------------------------
	
	-- Build a Siege Tower
	if UI_IsXboxControllerUI() then
		LateSiegeTrainingGoals_InitBuildSiegeTowerHint_Xbox()
	else
		LateSiegeTrainingGoals_InitBuildSiegeTowerHint()
	end
	
	-- Garrison a Siege Tower
	local selectSiegeTowerForGarrisonGoal = Training_Goal("Entity",
		{ID= "Siege Towers can be garrisoned and used to scale enemy stone walls.", Message= "$11202484", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedSiegeTowerForGarrison)
	local selectUnitsToGarrisonGoal = Training_Goal("PBG",
		{ID= "Select several military units to enter the Siege Tower.", Message= "$11202717", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedMilitaryUnitsForGarrison)
	local garrisonUnitsGoal = Training_Goal("Cursor",
		{ID= "Right-click / Press A on the Siege Tower to garrison units.", Message= UI_PickIDForInputMode(11202718, 11249169), DataTemplate="RightClickTrainingDataTemplate"},
		UserHasGarrisonedSiegeTower)
	local garrisonSiegeTowerSequence = Training_GoalSequence(goal_sequence_garrison_siege_tower,
		-1, 0, 
		HasSiegeTowerPredicateForGarrison, 
		nil, 
		nil,
		UserHasGarrisonedSiegeTower,
		false, 
		{selectSiegeTowerForGarrisonGoal, selectUnitsToGarrisonGoal, garrisonUnitsGoal})
	Training_AddGoalSequence(garrisonSiegeTowerSequence)
	
	-- Unload a Garrisoned Siege Tower 
	local selectSiegeTowerForUnloadGoal = Training_Goal("Entity",
		{ID= "Select a garrisoned Siege Tower to scale enemy walls.", Message= "$11202719", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedSiegeTowerForUnload)
	local unloadUnitsOnWallGoal = Training_Goal("Cursor",
		{ID= "RIGHT CLICK / Press A on enemy walls to unload garrisoned units.", Message= UI_PickIDForInputMode(11202720, 1000592), DataTemplate="RightClickTrainingDataTemplate"},
		UserHasUnloadedSiegeTower)
	local unloadSiegeTowerSequence = Training_GoalSequence(goal_sequence_unload_siege_tower,
		-1, 0, 
		HasGarrisonedSiegeTowerNearWallPredicate, 
		nil, 
		nil,
		UserHasUnloadedSiegeTower,  -- Was nil
		false, 
		{selectSiegeTowerForUnloadGoal, unloadUnitsOnWallGoal})
	Training_AddGoalSequence(unloadSiegeTowerSequence)
	
	----
	
	--player built a battering ram
	local builtBatteringRamGoal = Training_Goal("Entity",
		{ID= "Battering Rams are strong against walls and buildings, but do not have the benefit of long range.", Message= "$11202485", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedBatteringRam)
	local builtBatteringRamSequence = Training_GoalSequence(goal_sequence_battering_ram,
		-1, 0, 
		RamBuiltPredicate, 
		UserHasSelectedBatteringRam,
		nil, 
		nil,
		true, 
		{builtBatteringRamGoal})
	Training_AddGoalSequence(builtBatteringRamSequence)
	
	----
	
	--player built a springald
	local builtSpringaldGoal = Training_Goal("Entity",
		{ID= "Springalds are strong against units, but will not make much of a dent in walls.", Message= "$11202483", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedSpringald)
	local builtSpringaldSequence = Training_GoalSequence(goal_sequence_springald,
		-1, 0, 
		SpringaldBuiltPredicate, 
		nil, 
		nil,
		UserHasSelectedSpringald,
		true, 
		{builtSpringaldGoal})
	Training_AddGoalSequence(builtSpringaldSequence)
	
	----
	
	
	-- Player built a mangonel
	local builtMangonelGoal = Training_Goal("Entity",
		{ID= "Mangonels are strong against groups of units, but weak against walls and buildings.", Message= "$11202486", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedMangonel)
	local builtMangonelSequence = Training_GoalSequence(goal_sequence_mangonel,
		-1, 0, 
		MangonelBuiltPredicate, 
		nil, 
		nil,
		UserHasSelectedMangonel,
		true, 
		{builtMangonelGoal})
	Training_AddGoalSequence(builtMangonelSequence)
	
	----
	
	
	-- Player built a trebuchet
	--Trebuchets have extremely long range and are strong against walls and buildings. They fire in an arc, making them capable of targeting assets behind walls but less effective against enemy units. 
	local builtTrebuchetGoal = Training_Goal("Entity",
		{ID= "Trebuchets have very long range, fire in an arc, and are strong against walls and buildings.", Message= "$11202487", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedTrebuchet)
	local builtTrebuchetSequence = Training_GoalSequence(goal_sequence_trebuchet,
		-1, 0, 
		TrebuchetBuiltPredicate, 
		nil, 
		nil,
