import("GameScarUtil.scar")
import("Prefabs.scar")
import("standard.scar")
import("scarutil.scar")
import("team.scar")

import("core.scar")

--state data for automated testing scripts
_challengeTestState = {
	wave1Spawned = false,
	wave2Spawned = false,
	wave3Spawned = false,
	wave4Spawned = false,
	wave5Spawned = false,
	wave6Spawned = false
}

--enumeration for objective status
statusTable = {
	NotRun = 0, 
	InProgress = 1,
	Pass = 2,
	Fail = 3
}

-------------------------------------------------------------------------
-- [[ ONINIT ]]
-------------------------------------------------------------------------

function OnInit()

	--Smoketest_Debug()        
	--Smoketest_Setup()

end

Scar_AddInit(OnInit)

function Smoketest_Debug()
	
	-- looks for the command line option [-debug]
	if Misc_IsCommandLineOptionSet("debug") then
		g_debug = true
	end
end

--this function should be called from the mission's main scar file's Mission_Start()
--after all objectives have been initialized
function AutomatedMission_Start()
	print("AutomatedMission_Start() called")
	for i, v in pairs(_challenge) do
		for i2, v2 in pairs(_challenge.objective) do
	            AutomatedMission_SetupCheckpoints()
	            Rule_AddInterval(AutomatedMission_Update, 0.25)
	            Rule_RemoveMe()
			return
		end
	end
end

--create a list of objectives to check
function AutomatedMission_SetupCheckpoints()
	print("AutomatedMission_SetupCheckpoints() called")
	----------
	--checkpointObjective: the objective
	--checkpointName: string with descriptive name of the checkpoint
	--checkpointState: 0 = not started, 1 = started, 2 = completed, 3 = timed out
	--checkpointStartTime: game time when this objective has completed or failed
	--checkpointCompletionTime: game time when this objective has completed or failed
	--checkpointTimeLimit: time in seconds allowed between checkpointStartTime and checkpointCompletionTime
	----------
	challengeCheckpointList = {}
	challengeCheckpointList[1] = {checkpointObjective = _challenge.objective.surviveWave1, checkpointName = "surviveWave1", 
		checkpointState = 0, checkpointStartTime = 0, checkpointCompletionTime = 0, checkpointTimeLimit = 150}
	challengeCheckpointList[2] = {checkpointObjective = _challenge.objective.surviveWave2, checkpointName = "surviveWave2", 
		checkpointState = 0, checkpointStartTime = 0, checkpointCompletionTime = 0, checkpointTimeLimit = 150}
	challengeCheckpointList[3] = {checkpointObjective = _challenge.objective.surviveWave3, checkpointName = "surviveWave3", 
		checkpointState = 0, checkpointStartTime = 0, checkpointCompletionTime = 0, checkpointTimeLimit = 150}
	challengeCheckpointList[4] = {checkpointObjective = _challenge.objective.surviveWave4, checkpointName = "surviveWave4", 
		checkpointState = 0, checkpointStartTime = 0, checkpointCompletionTime = 0, checkpointTimeLimit = 150}
	challengeCheckpointList[5] = {checkpointObjective = _challenge.objective.surviveWave5, checkpointName = "surviveWave5", 
		checkpointState = 0, checkpointStartTime = 0, checkpointCompletionTime = 0, checkpointTimeLimit = 150}
	challengeCheckpointList[6] = {checkpointObjective = _challenge.objective.surviveWave6, checkpointName = "surviveWave6", 
		checkpointState = 0, checkpointStartTime = 0, checkpointCompletionTime = 0, checkpointTimeLimit = 150}
	
	challengeCheckpointList[7] = {checkpointObjective = _challenge.victory.objectiveVictory, checkpointName = "objectiveVictory", 
		checkpointState = 0, checkpointStartTime = 0, checkpointCompletionTime = 0, checkpointTimeLimit = 1050}
	
	--call functions to register checkpoints
	
	CampaignAutotest_RegisterCheckpoint(challengeCheckpointList[1]["checkpointName"], "150")
	CampaignAutotest_RegisterCheckpoint(challengeCheckpointList[2]["checkpointName"], "150")
	CampaignAutotest_RegisterCheckpoint(challengeCheckpointList[3]["checkpointName"], "150")
	CampaignAutotest_RegisterCheckpoint(challengeCheckpointList[4]["checkpointName"], "150")
	CampaignAutotest_RegisterCheckpoint(challengeCheckpointList[5]["checkpointName"], "150")
	CampaignAutotest_RegisterCheckpoint(challengeCheckpointList[6]["checkpointName"], "150")
	CampaignAutotest_RegisterCheckpoint(challengeCheckpointList[7]["checkpointName"], "150")
	
end

--main update loop
function AutomatedMission_Update()
	if(Objective_IsStarted(_challenge.objective.trainWave1) and _challengeTestState.wave1Spawned == false) then
		AutomatedMission_Spawn_Wave1()
		CampaignAutotest_SetCheckpointStatus(challengeCheckpointList[1]["checkpointName"], statusTable["InProgress"])
		
	end
	if(Objective_IsStarted(_challenge.objective.trainWave2) and _challengeTestState.wave2Spawned == false) then
		AutomatedMission_Spawn_Wave2()
		CampaignAutotest_SetCheckpointStatus(challengeCheckpointList[2]["checkpointName"], statusTable["InProgress"])
		
	end
	if(Objective_IsStarted(_challenge.objective.trainWave3) and _challengeTestState.wave3Spawned == false) then
		AutomatedMission_Spawn_Wave3()
		CampaignAutotest_SetCheckpointStatus(challengeCheckpointList[3]["checkpointName"], statusTable["InProgress"])
		
	end
	if(Objective_IsStarted(_challenge.objective.trainWave4) and _challengeTestState.wave4Spawned == false) then
		AutomatedMission_Spawn_Wave4()
		CampaignAutotest_SetCheckpointStatus(challengeCheckpointList[4]["checkpointName"], statusTable["InProgress"])
		
	end
	if(Objective_IsStarted(_challenge.objective.trainWave5) and _challengeTestState.wave5Spawned == false) then
		AutomatedMission_Spawn_Wave5()
		CampaignAutotest_SetCheckpointStatus(challengeCheckpointList[5]["checkpointName"], statusTable["InProgress"])
		
	end
	if(Objective_IsStarted(_challenge.objective.trainWave6) and _challengeTestState.wave6Spawned == false) then
		AutomatedMission_Spawn_Wave6()
		CampaignAutotest_SetCheckpointStatus(challengeCheckpointList[6]["checkpointName"], statusTable["InProgress"])
		
	end
	
	--check for checkpoint completion
	AutomatedMission_UpdateCheckpoints()
end


--check for completion or failure for each objective
function AutomatedMission_UpdateCheckpoints()
	for i, checkpointObject in pairs(challengeCheckpointList) do
		if(checkpointObject["checkpointState"] == statusTable["NotRun"]) then
			if(Objective_IsStarted(checkpointObject["checkpointObjective"]) == true) then
				checkpointObject["checkpointState"] = statusTable["InProgress"]
				checkpointObject["checkpointStartTime"] = World_GetGameTime()
			end
		elseif(checkpointObject["checkpointState"] == statusTable["InProgress"]) then
			if(Objective_IsComplete(checkpointObject["checkpointObjective"]) == true) then
				checkpointObject["checkpointState"] = statusTable["Pass"]
				checkpointObject["checkpointCompletionTime"] = World_GetGameTime()
				--call function to update checkpoint
				CampaignAutotest_SetCheckpointStatus(checkpointObject["checkpointName"], statusTable["Pass"])
				
			elseif(Objective_IsFailed(checkpointObject["checkpointObjective"])) then
				checkpointObject["checkpointState"] = statusTable["Pass"]
				checkpointObject["checkpointCompletionTime"] = World_GetGameTime()
				--call function to update checkpoint
				CampaignAutotest_SetCheckpointStatus(checkpointObject["checkpointName"], statusTable["Pass"])
				
			elseif(World_GetGameTime() - checkpointObject["checkpointStartTime"] > checkpointObject["checkpointTimeLimit"]) then
				--checkpoint has timed out
				checkpointObject["checkpointState"] = statusTable["Fail"]
				checkpointObject["checkpointCompletionTime"] = World_GetGameTime()
				--call function to update checkpoint
				CampaignAutotest_SetCheckpointStatus(checkpointObject["checkpointName"], statusTable["Fail"])
				
			end
		end
	end
end

function AutomatedMission_AttackStart()
	Rule_AddInterval(AutomatedMission_Attack, 1)
end

function AutomatedMission_Attack()
	
	local sg_all_enemy_units = SGroup_CreateIfNotFound("sg_all_enemy_units")
	local sg_all_player_units = SGroup_CreateIfNotFound("sg_all_player_units")
	
	sg_all_enemy_units = Player_GetSquads(enemyPlayer)
	sg_all_player_units = Player_GetSquads(localPlayer)
	
	local unitsInCombat = false
	for i = 1, SGroup_CountSpawned(sg_all_enemy_units) do
		local squad = SGroup_GetSquadAt(sg_all_enemy_units, i)	
		if(Squad_IsUnderAttack(squad, 3)) then
			unitsInCombat = true
		end
	end
	
	if(unitsInCombat == false) then
		if(SGroup_Count(sg_all_player_units) > 0 and SGroup_Count(sg_all_enemy_units) > 0) then
			Cmd_FormationAttackMove(sg_all_player_units, Util_GetPosition(sg_all_enemy_units), flase)
			if(Rule_Exists(AutomatedMission_FormationMove)) then
				Rule_Remove(AutomatedMission_FormationMove)
			end
		end
	end
	
end

function AutomatedMission_FormationMove()
	
	local sg_all_enemy_units = SGroup_CreateIfNotFound("sg_all_enemy_units")
	local sg_all_player_units = SGroup_CreateIfNotFound("sg_all_player_units")
	
	sg_all_enemy_units = Player_GetSquads(enemyPlayer)
	sg_all_player_units = Player_GetSquads(localPlayer)
	
	if(SGroup_Count(sg_all_player_units) > 0 and SGroup_Count(sg_all_enemy_units) > 0) then
		Cmd_FormationMove(sg_all_player_units, Util_GetPosition(sg_all_player_units), false)
		Cmd_FormationAttackMove(sg_all_player_units, Util_GetPosition(sg_all_enemy_units), true)
	end
	
	Rule_AddOneShot(AutomatedMission_AttackStart, 10)
end

function AutomatedMission_Spawn_Wave1()
	print ("AutomatedMission_Spawn_Wave1() called")
	if(EGroup_CountSpawned(_challenge.stable2) > 0) then
		local entity = EGroup_GetEntityAt(_challenge.stable2, 1)
		Misc_SelectEntity(entity)
		_challengeTestState.wave1Spawned = true
		
		if(Rule_Exists(AutomatedMission_Attack)) then
			Rule_Remove(AutomatedMission_Attack)
		end
		Rule_AddOneShot(AutomatedMission_FormationMove, 3)
	end
end

