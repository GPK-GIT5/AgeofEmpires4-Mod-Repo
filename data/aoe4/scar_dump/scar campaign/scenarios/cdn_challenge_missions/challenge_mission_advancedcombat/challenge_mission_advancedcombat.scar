function ChallengeMission_IncreaseBuildingVulnerability()
	
	if(villageBuildings ~= nil) then
		for i = 1, EGroup_CountSpawned(villageBuildings) do
			local entity = EGroup_GetEntityAt(villageBuildings, i)	
			if(Entity_IsUnderAttack(entity, 1)) then
				local currentHealth = Entity_GetHealthPercentage(entity)
				if(currentHealth - .025 > 0) then
					Entity_SetHealth(entity, currentHealth - .025)
				end
			end
		end
	end
end

--make sure AI ignores buildings when any of its units are under attack
function ChallengeMission_RespondToPlayerAttack()
	
	if(villageBuildings ~= nil) then
		
		local sg_all_enemy_units = SGroup_CreateIfNotFound("sg_all_enemy_units")
		local sg_all_player_units = SGroup_CreateIfNotFound("sg_all_player_units")
		local sg_attacking_player_units = SGroup_CreateIfNotFound("sg_attacking_player_units")
		
		sg_all_enemy_units = Player_GetSquads(enemyPlayer)
		sg_all_player_units = Player_GetSquads(localPlayer)
		SGroup_Clear(sg_attacking_player_units)
		
		--check if any enemy units are under attack
		local enemyIsUnderAttack = false
		for i = 1, SGroup_Count(sg_all_enemy_units) do
			local squad = SGroup_GetSquadAt(sg_all_enemy_units, i)
			if(Squad_IsUnderAttack(squad, 3)) then
				enemyIsUnderAttack = true
			end
		end
		
		--check if allied buildings are under attack
		local buildingsUnderAttack = false
		for i = 1, EGroup_Count(villageBuildings) do
			local entity = EGroup_GetEntityAt(villageBuildings, i)
			if(Entity_IsUnderAttack(entity, 3)) then
				buildingsUnderAttack = true
			end
		end
		
		--find which player units are attacking
		for i = 1, SGroup_Count(sg_all_player_units) do
			local squad = SGroup_GetSquadAt(sg_all_player_units, i)
			if(Squad_IsAttacking(squad, 3)) then
				SGroup_Add(sg_attacking_player_units, squad)
				
			end
		end
		
		if(enemyIsUnderAttack == true) then
			--attack with all enemy units that are not attacking
			for i = 1, SGroup_Count(sg_all_enemy_units) do
				local squad = SGroup_GetSquadAt(sg_all_enemy_units, i)
				
				if(Squad_IsAttacking(squad, 3) == false or buildingsUnderAttack == true) then
					--attack player units
					SGroup_Single(sg_single, squad)
					Cmd_Attack(sg_single, sg_attacking_player_units, false)
					Cmd_AttackMove(sg_single, mkr_village_center, true)
					
				end
			end
			
			--disable unit spawning/undo if the player attacks early with 1 out of 2 groups
			if(ChallengeMission_DefenseGroupsRemaining() == 1) then
				ChallengeMission_SendWave()
				ChallengeMission_RemoveProductionUI("all")
				_challenge.waveActive = false
			end
		end
		
		
		
	end
end

function ChallengeMission_UpdateMedals()
	
	if(_challenge.currentBenchmark == _challenge.benchmarks.gold)then
		Util_StartIntel(EVENTS.Narr_GoldFailed )
		Objective_Fail(_challenge.currentBenchmark.objective, false, false)
		_challenge.currentBenchmark = _challenge.benchmarks.silver
		Objective_Register(_challenge.currentBenchmark.objective, localPlayer.id)
		Objective_Start(_challenge.currentBenchmark.objective, false, false)
		Objective_SetCounter(_challenge.currentBenchmark.objective, _challenge.benchmarks.gold.maxUnitsDied + 1, _challenge.currentBenchmark.maxUnitsDied)
	elseif(_challenge.currentBenchmark == _challenge.benchmarks.silver)then
		Util_StartIntel(EVENTS.Narr_SilverFailed )
		Objective_Fail(_challenge.currentBenchmark.objective, false, false)
		_challenge.currentBenchmark = _challenge.benchmarks.bronze
		Objective_Register(_challenge.currentBenchmark.objective, localPlayer.id)
		Objective_Start(_challenge.currentBenchmark.objective, false, false)
		Objective_SetCounter(_challenge.currentBenchmark.objective, _challenge.benchmarks.silver.maxUnitsDied + 1, _challenge.currentBenchmark.maxUnitsDied)
	elseif(_challenge.currentBenchmark == _challenge.benchmarks.bronze)then
		Util_StartIntel(EVENTS.Narr_BronzeFailed )
		Objective_Fail(_challenge.currentBenchmark.objective, false, false)
		_challenge.currentBenchmark = _challenge.benchmarks.unplaced
		Objective_Register(_challenge.currentBenchmark.objective, localPlayer.id)
		Objective_Start(_challenge.currentBenchmark.objective, false, false)
		Objective_SetCounter(_challenge.currentBenchmark.objective, _challenge.benchmarks.bronze.maxUnitsDied + 1, _challenge.benchmarks.bronze.maxUnitsDied)
	end
	
end

function ChallengeMission_WaveWon()
	Util_StartIntel(_challenge.celebrations[_challenge.currentWave])
	Objective_Complete(_challenge.currentSecondObjective,true)
end

function ChallengeMission_WaveLost()
	Util_StartIntel(EVENTS.LostMultipleBuildings)
	Objective_Fail(_challenge.currentSecondObjective,true)
	Rule_Remove(ChallengeMission_SendWave)
	local numBuildings = Objective_GetCounter(_challenge.objective.protectTown);
	numBuildings = numBuildings - 2
	if(numBuildings >= _challenge.maxHousesLost) then
		numBuildings = _challenge.maxHousesLost		
		Objective_Fail(_challenge.objective.protectTown, true, false)
		Rule_AddOneShot(Mission_Fail, _challenge.missionEndDelay)
	end
	Objective_IncreaseCounter(_challenge.objective.protectTown, 2)
	
	-- Sets 2 houses on fire and damages them
	local burnCount = 2
	local houses = Player_GetEntitiesFromType( villagePlayer, "scar_house" )
	
	for i = 1, EGroup_Count(houses) do
		if(burnCount > 0) then
			local house = EGroup_GetRandomSpawnedEntity(houses)
			if(Entity_IsBurning(house) == false)then
				-- Gets random number for fire threshold
				local randFire = World_GetRand(1, 100)
				-- Gets random number for damage
				local randDamage = World_GetRand(20, 80)/100
				-- If number is greater than building threshold
				if (randFire > 0) then				
					-- Damage
					Entity_SetHealth(house, .01)
					-- Set on Fire
					--Entity_SetOnFire(house)
				end
				burnCount = burnCount - 1
			end
		end
	end
	--increase wave lost burn count so houses aren't counted twice
	_challenge.buildingsLostEndOfWave = 2
end


firstUndoSpawn = "none"
secondUndoSpawn = "none"

function ChallengeMission_UpdateBuildingSpawner(inUnitType)
	
	local canAddNewGroup = true
	if(ChallengeMission_DefenseGroupsRemaining() == 0)then
		canAddNewGroup = false
	end
	
	
	--check if one of the production buildings is selected
	if(firstUndoSpawn ~= inUnitType and secondUndoSpawn ~= inUnitType) then
		
		if(canAddNewGroup == true) then
			--spawn a new group of units
			if(inUnitType == "archers") then
				ArcherLeaderSelected()
				Rule_Remove(ChallengeMission_RemindPlayer)
			end
			if(inUnitType == "crossbowmen") then
				CrossbowmanLeaderSelected()
				Rule_Remove(ChallengeMission_RemindPlayer)
			end
			if(inUnitType == "spearmen") then
				SpearmanLeaderSelected()
				Rule_Remove(ChallengeMission_RemindPlayer)
			end
			if(inUnitType == "menatarms") then
				ManatarmsLeaderSelected()
				Rule_Remove(ChallengeMission_RemindPlayer)
			end
			if(inUnitType == "horsemen") then
				HorsemanLeaderSelected()
				Rule_Remove(ChallengeMission_RemindPlayer)
			end
			if(inUnitType == "knights") then
				KnightLeaderSelected()
				Rule_Remove(ChallengeMission_RemindPlayer)
			end
			
			if(firstUndoSpawn ~= "none") then
				secondUndoSpawn = firstUndoSpawn
			end
			firstUndoSpawn = inUnitType
			Misc_ClearSelection()
		end
	
		ChallengeMission_UpdateProductionObjective()
	else
		--reset all spawned units
		ChallengeMission_RemoveProductionUI(inUnitType)
		ChallengeMission_RemoveProductionUI("all")
		ChallengeMission_CleanUpWave()
		ChallengeMission_InitializeWave()
		--ChallengeMissionDeployDummyUnits()
		Misc_ClearSelection()
		firstUndoSpawn = "none"
		secondUndoSpawn = "none"
	end
end

function ChallengeMission_UpdateProductionObjective()
	--remove the "Train _ units" objective when all squads have been trained
	if(ChallengeMission_DefenseGroupsRemaining() == 0)then
		
		if(_challenge.currentWave == 1) then
			Objective_Stop(_challenge.objective.trainWave1)
		elseif(_challenge.currentWave == 2) then
			Objective_Stop(_challenge.objective.trainWave2)
		elseif(_challenge.currentWave == 3) then
			Objective_Stop(_challenge.objective.trainWave3)
		elseif(_challenge.currentWave == 4) then
			Objective_Stop(_challenge.objective.trainWave4)
		elseif(_challenge.currentWave == 5) then
			Objective_Stop(_challenge.objective.trainWave5)
		elseif(_challenge.currentWave == 6) then
			Objective_Stop(_challenge.objective.trainWave6)
		end
		
	end
end


function ChallengeMission_Update()
		
	
	if(_challenge.waveActive == true)then
		
		local buildingSelectionCount = 0
		if Misc_IsEGroupSelected(_challenge.archeryRange1, false) then
			buildingSelectionCount = buildingSelectionCount + 1
		end
		if Misc_IsEGroupSelected(_challenge.archeryRange2, false) then
			buildingSelectionCount = buildingSelectionCount + 1
		end
		if Misc_IsEGroupSelected(_challenge.barracks1, false) then
			buildingSelectionCount = buildingSelectionCount + 1
		end
		if Misc_IsEGroupSelected(_challenge.barracks2, false) then
			buildingSelectionCount = buildingSelectionCount + 1
		end
		if Misc_IsEGroupSelected(_challenge.stable1, false) then
			buildingSelectionCount = buildingSelectionCount + 1
		end
		if Misc_IsEGroupSelected(_challenge.stable2, false) then
			buildingSelectionCount = buildingSelectionCount + 1
		end
		
		--spawn units if only one production building is selected
		if(buildingSelectionCount == 1) then
			if Misc_IsEGroupSelected(_challenge.archeryRange1, false) then
				ChallengeMission_UpdateBuildingSpawner("archers")
			end
			if Misc_IsEGroupSelected(_challenge.archeryRange2, false) then
				ChallengeMission_UpdateBuildingSpawner("crossbowmen")
			end
			if Misc_IsEGroupSelected(_challenge.barracks1, false) then
				ChallengeMission_UpdateBuildingSpawner("spearmen")
			end
			if Misc_IsEGroupSelected(_challenge.barracks2, false) then
				ChallengeMission_UpdateBuildingSpawner("menatarms")
			end
			if Misc_IsEGroupSelected(_challenge.stable1, false) then
				ChallengeMission_UpdateBuildingSpawner("horsemen")
			end
			if Misc_IsEGroupSelected(_challenge.stable2, false) then
				ChallengeMission_UpdateBuildingSpawner("knights")
			end
		end
		
	end
	
end

-- A unit is killed
function ChallengeMission_OnDestruction(context)
	
	if(context.victimOwner == localPlayer) then
		
		if(Objective_IsCounterSet(_challenge.currentBenchmark.objective)) then
			Objective_IncreaseCounter(_challenge.currentBenchmark.objective,1)
			if(_challenge.currentBenchmark.maxUnitsDied ~= nil and Objective_GetCounter(_challenge.currentBenchmark.objective) > _challenge.currentBenchmark.maxUnitsDied) then
				ChallengeMission_UpdateMedals()
			end
		end
		
		if(SGroup_IsAlive(_challenge.currentArmy) == false) then
			if(safeguard ~= World_GetGameTicks()) then
				ChallengeMission_WaveLost()
				ChallengeMission_CleanUpDefense()
				
				if Objective_GetCounter(_challenge.objective.protectTown) < _challenge.maxHousesLost then
					ChallengeMission_NextWave()
				end
				safeguard = World_GetGameTicks()
			end
		end
	elseif(context.victimOwner == enemyPlayer) then
		if(_challenge.currentWaveSquadGroup ~= nil) then
			if(SGroup_IsAlive(_challenge.currentWaveSquadGroup) == false) then
				if(safeguard ~= World_GetGameTicks()) then
					_challenge.currentWaveSquadGroup = nil
					ChallengeMission_WaveWon()
					if Objective_GetCounter(_challenge.objective.protectTown) < _challenge.maxHousesLost then
						ChallengeMission_NextWave()
					end
					safeguard = World_GetGameTicks()
				end
			end
		end		
	elseif(context.victimOwner == villagePlayer) then	-- A building
		if Entity_IsOfType(context.victim,"building") and not Entity_IsOfType(context.victim,"farm") then
			
			--a single building is lost that is not part of the end of a wave
			if(_challenge.buildingsLostEndOfWave == 0) then
				ChallengeMission_BuildingLost()
				Objective_IncreaseCounter(_challenge.objective.protectTown, 1)
			end
			
			if Objective_GetCounter(_challenge.objective.protectTown) >= _challenge.maxHousesLost then		
				Objective_Fail(_challenge.objective.protectTown, true, false)
				Rule_AddOneShot(Mission_Fail, _challenge.missionEndDelay)
			end
		end
	end
end

function ChallengeMission_BuildingLost()
	--do not play message if building was lost as a result of losing a wave
	if(_challenge.currentWaveSquadGroup ~= nil and _challenge.waveActive == false) then
		if(SGroup_Count(_challenge.currentWaveSquadGroup) > 0) then
			if(_challenge.buildingsLostThisWave == 0) then
				Util_StartIntel(EVENTS.LostBuilding)
				_challenge.buildingsLostThisWave = _challenge.buildingsLostThisWave + 1
			elseif(_challenge.buildingsLostThisWave == 1) then
				Util_StartIntel(EVENTS.LostMultipleBuildings)
				_challenge.buildingsLostThisWave = _challenge.buildingsLostThisWave + 1
			else
				_challenge.buildingsLostThisWave = _challenge.buildingsLostThisWave + 1
			end
		end
	end
	
end


function ChallengeMission_CheckVictory()
	
	-- Store completion loss counter
	local points = Objective_GetCounter(_challenge.currentBenchmark.objective)
	-- Package completion time for Data Store
	local trialInformation = {kpi = points}
	
	-- Provide completion time to Stats system via Data Store
	Game_StoreTableData("trial", trialInformation)
	
	
	-- Set victory objective to complete
	Objective_Complete(_challenge.victory.objectiveVictory, false, true)
	Objective_Complete(_challenge.victory.objectiveVictory2, false, false)

	-- After a short delay end the mission.
	Rule_AddOneShot(ChallengeMission_EndChallenge, 0)
end

function ChallengeMission_EndChallenge()
Util_StartIntel(EVENTS.Narr_Outro)
	Mission_Complete()
	--Core_SetPlayerVictorious(localPlayer, nil, WR_OBJECTIVECOMPLETE)
	
end

--this function orders units to form a line form startPos to endPos with the curvature curveStrength
function ArcFormation(startPos, endPos, inGroup, curveStrength, inQueued, inOffset)
	if(SGroup_CountSpawned(inGroup) == 0) then
		return
	end
	
	local fLine = Util_GetPosition(startPos)
	fLine["x"] = endPos["x"] - startPos["x"]
	fLine["z"] = endPos["z"] - startPos["z"]
	
	local tLine = Util_GetPosition(startPos)
	tLine["x"] = fLine["z"]
	tLine["z"] = -fLine["x"]
	
	
	for i = 1, SGroup_Count(inGroup) do
		--offset should be from 0 to 1
		local pointD = (i - inOffset) / SGroup_Count(inGroup)
		
		local unitDest = Util_GetPosition(startPos)
		--calculate the destination for each unit
		unitDest["x"] = startPos["x"] + (pointD * fLine["x"])
		unitDest["z"] = startPos["z"] + (pointD * fLine["z"])
		
		local curveMultiplier = pointD - .5
		
		curveMultiplier = curveMultiplier * curveMultiplier
		curveMultiplier = .25 - curveMultiplier
		
		unitDest["x"] = unitDest["x"] + (tLine["x"] * curveMultiplier * curveStrength)
		unitDest["z"] = unitDest["z"] + (tLine["z"] * curveMultiplier * curveStrength)
		
		--isolate each unit and give it a move order
		local squad = SGroup_GetSquadAt(inGroup, i)
		SGroup_Single(sg_single, squad)
		Cmd_Move(sg_single, unitDest, inQueued)
	end
	
end
