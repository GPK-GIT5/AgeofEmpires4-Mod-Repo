function ChallengeMission_SixthWave_Split()	
	
	if(sg_wave6_knights ~= nil) then
		if Prox_AreSquadsNearMarker(sg_wave6_knights, mkr_path1_4, ANY, 37) then
			
			Cmd_AttackMove(sg_wave6_knights, mkr_path1_5, false)
			Rule_RemoveMe()
		end
	end
	
end


function ChallengeMission_SendWave()
	if(_challenge.currentWaveAttackPath ~= nil and _challenge.currentWaveSquadGroup ~= nil) then
		for i,point in ipairs(_challenge.currentWaveAttackPath) do
			if(_challenge.currentWaveSquadGroup ~= nil) then
				if(SGroup_Count(_challenge.currentWaveSquadGroup) > 0) then
					Cmd_FormationAttackMove(_challenge.currentWaveSquadGroup, point, true, false)
				end
			end
		end
		if(_challenge.currentWaveAttackStartDialogue~= nil) then
			Util_StartIntel(_challenge.currentWaveAttackStartDialogue)
		end
	end
	
	--prevent respawning units
	_challenge.waveActive = false
	
	Objective_Expire(_challenge.currentTrainingObjective, false, false)
	
	
	--remove undo ui
	hasUnselectedBuilding = false
	lastSelectedBuilding = nil
	Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_undo_archers)
	Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_undo_crossbowmen)
	Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_undo_spearmen)
	Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_undo_menatarms)
	Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_undo_horsemen)
	Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_undo_knights)
end

function ChallengeMission_NextWave()
	-- Clean up wave
	SGroup_SetPlayerOwner(_challenge.currentArmy, villagePlayer)
	Rule_AddOneShot(ChallengeMission_CleanUpWave, 5)	
	Rule_Remove(ChallengeMission_IncreaseBuildingVulnerability)
	
	-- Make sure the player has no buildings selected
	Misc_ClearSelection()
	
	firstUndoSpawn = "none"
	secondUndoSpawn = "none"
	
	_challenge.waveActive = false
	
	_challenge.currentWave = _challenge.currentWave + 1
	Objective_IncreaseCounter(_challenge.victory.objectiveVictory, 1)
	if(_challenge.waves[_challenge.currentWave]~=nil) then
		Rule_AddOneShot(_challenge.waves[_challenge.currentWave], _challenge.revealDelay)
		Rule_AddOneShot(ChallengeMission_InitializeWave, _challenge.revealDelay + _challenge.selectionDelay)
		--ChallengeMissionDeployDummyUnits()
	else
		ChallengeMission_CheckVictory()
	end
end

function ChallengeMission_CleanUpWave()
	-- Kill current army without causing the player death count to increase
	SGroup_DestroyAllSquads(_challenge.currentArmy)
	--FOW_PlayerUnRevealAll(localPlayer)
	
	--reset defense setup
	Rule_Remove(ChallengeMission_SendWave)
	_challenge.archerDefense = false
	_challenge.crossbowmanDefense = false
	_challenge.spearmanDefense = false
	_challenge.manatarmsDefense = false
	_challenge.horsemanDefense = false
	_challenge.knightDefense = false

end

function ChallengeMission_IsDefenseSetup()
	local defenseTypesCount = 0
	if(_challenge.archerDefense == true) then
		defenseTypesCount = defenseTypesCount + 1
	end
	if(_challenge.crossbowmanDefense == true) then
		defenseTypesCount = defenseTypesCount + 1
	end
	if(_challenge.spearmanDefense == true) then
		defenseTypesCount = defenseTypesCount + 1
	end
	if(_challenge.manatarmsDefense == true) then
		defenseTypesCount = defenseTypesCount + 1
	end
	if(_challenge.horsemanDefense == true) then
		defenseTypesCount = defenseTypesCount + 1
	end
	if(_challenge.knightDefense == true) then
		defenseTypesCount = defenseTypesCount + 1
	end
	if(_challenge.currentWave <= 3) then		
		return  defenseTypesCount >= 1
	else
		return defenseTypesCount >= 2
	end
end

function ChallengeMission_DefenseGroupsRemaining()
	
	if(_challenge.waveActive == false) then
		return 0
	end
	
	
	local defenseTypesCount = 0
	if(_challenge.archerDefense == true) then
		defenseTypesCount = defenseTypesCount + 1
	end
	if(_challenge.crossbowmanDefense == true) then
		defenseTypesCount = defenseTypesCount + 1
	end
	if(_challenge.spearmanDefense == true) then
		defenseTypesCount = defenseTypesCount + 1
	end
	if(_challenge.manatarmsDefense == true) then
		defenseTypesCount = defenseTypesCount + 1
	end
	if(_challenge.horsemanDefense == true) then
		defenseTypesCount = defenseTypesCount + 1
	end
	if(_challenge.knightDefense == true) then
		defenseTypesCount = defenseTypesCount + 1
	end
	if(_challenge.currentWave <= 3) then		
		return (1 - defenseTypesCount)
	else		
		return (2 - defenseTypesCount)
	end
end

function ChallengeMission_CleanUpDefense()
	SGroup_DestroyAllSquads(_challenge.currentWaveSquadGroup)
end

function ChallengeMission_RemoveProductionUI(inBuildingType)
	if(inBuildingType == "archers") then
		--SGroup_DestroyAllSquads(_challenge.archerLeader)
		Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_recruit_archers)
		Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_undo_archers)
	end
	if(inBuildingType == "crossbowmen") then
		--SGroup_DestroyAllSquads(_challenge.crossbowmanLeader)
		Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_recruit_crossbowmen)
		Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_undo_crossbowmen)
	end
	if(inBuildingType == "spearmen") then
		--SGroup_DestroyAllSquads(_challenge.spearmanLeader)
		Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_recruit_spearmen)
		Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_undo_spearmen)
	end
	if(inBuildingType == "menatarms") then
		--SGroup_DestroyAllSquads(_challenge.manatarmsLeader)
		Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_recruit_menatarms)
		Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_undo_menatarms)
	end
	if(inBuildingType == "horsemen") then
		--SGroup_DestroyAllSquads(_challenge.horsemanLeader)
		Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_recruit_horsemen)
		Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_undo_horsemen)
	end
	if(inBuildingType == "knights") then
		--SGroup_DestroyAllSquads(_challenge.knightLeader)
		Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_recruit_knights)
		Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_undo_knights)
	end
	
	if(inBuildingType == "all") then
		--[[
		SGroup_DestroyAllSquads(_challenge.archerLeader)
		SGroup_DestroyAllSquads(_challenge.crossbowmanLeader)
		SGroup_DestroyAllSquads(_challenge.spearmanLeader)
		SGroup_DestroyAllSquads(_challenge.manatarmsLeader)
		SGroup_DestroyAllSquads(_challenge.horsemanLeader)
		SGroup_DestroyAllSquads(_challenge.knightLeader)
		--]]
		Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_recruit_archers)
		Objective_RemoveUIElements(_challenge.victory.objectiveVictory, hintPoint_recruit_spearmen)
		Objective_RemoveUIElements(_challenge.victory.objectiveVictory, hintPoint_recruit_horsemen)
		Objective_RemoveUIElements(_challenge.victory.objectiveVictory, hintPoint_recruit_menatarms)
		Objective_RemoveUIElements(_challenge.victory.objectiveVictory, hintPoint_recruit_crossbowmen)
		Objective_RemoveUIElements(_challenge.victory.objectiveVictory, hintPoint_recruit_knights)
		
	end
end

function ArcherLeaderSelected()
	if(_challenge.archerDefense == false)then
		local sbp_archer_hre = BP_GetSquadBlueprint("unit_archer_3_hre")
		SGroup_Clear(_challenge.currentArmy2)
		UnitEntry_DeploySquads(localPlayer, _challenge.currentArmy2, {{sbp = sbp_archer_hre, numSquads = _challenge.balance.defenderArcherCount }}, mkr_village_archer_spawn)
		Cmd_FormationMove(_challenge.currentArmy2, mkr_player_archer_rally, true, false)
		SGroup_AddGroup(_challenge.currentArmy, _challenge.currentArmy2)
		_challenge.archerDefense = true
		ChallengeMission_RemoveProductionUI("archers")
		
		Misc_ClearSelection()
		lastSelectedBuilding = "archers"
		hasUnselectedBuilding = false
		
		-- LEFT CLICK / PRESS A to undo.
		hintPoint_undo_archers = Objective_AddUIElements(_challenge.victory.objectiveVictory, _challenge.archeryRange1, false, UI_PickIDForInputMode(11219072, 11251412), true, 2 )
	
		if(ChallengeMission_DefenseGroupsRemaining() == 0) then
			Rule_AddOneShot(ChallengeMission_SendWave, _challenge.attackDelay[_challenge.currentWave])
			ChallengeMission_RemoveProductionUI("all")
		end
	end
end

function CrossbowmanLeaderSelected()
	if(_challenge.crossbowmanDefense == false)then
		local sbp_archer_hre = BP_GetSquadBlueprint("unit_crossbowman_3_hre")
		SGroup_Clear(_challenge.currentArmy2)
		UnitEntry_DeploySquads(localPlayer, _challenge.currentArmy2, {{sbp = sbp_archer_hre, numSquads = _challenge.balance.defenderCrossbowmanCount }}, mkr_village_crossbowman_spawn)
		Cmd_FormationMove(_challenge.currentArmy2, mkr_player_crossbowman_rally, true, false)
		SGroup_AddGroup(_challenge.currentArmy, _challenge.currentArmy2)
		_challenge.crossbowmanDefense = true
		ChallengeMission_RemoveProductionUI("crossbowmen")
		
		Misc_ClearSelection()
		lastSelectedBuilding = "crossbowmen"
		hasUnselectedBuilding = false
		
		-- LEFT CLICK / PRESS A to undo.
		hintPoint_undo_crossbowmen = Objective_AddUIElements(_challenge.victory.objectiveVictory, _challenge.archeryRange2, false, UI_PickIDForInputMode(11219072, 11251412), true, 2 )
	
		if(ChallengeMission_DefenseGroupsRemaining() == 0) then
			Rule_AddOneShot(ChallengeMission_SendWave, _challenge.attackDelay[_challenge.currentWave])
			ChallengeMission_RemoveProductionUI("all")
		end
	end
end


