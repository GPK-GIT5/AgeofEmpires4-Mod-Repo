-- Called when Mission loads
function Mission_OnInit()
	
	if UI_IsXboxUI() then
		_challenge.benchmarks.bronze = {
			maxUnitsDied = 45,
			objective = {},
		}
		_challenge.benchmarks.silver = {
			maxUnitsDied = 35,
			objective = {},
		}
		_challenge.benchmarks.gold = {
			maxUnitsDied = 18,
			objective = {},
		}
	end
	
	--FOW_RevealAll()
	--Game_FadeToBlack(FADE_OUT, 0)
	
	_challenge.waves[#_challenge.waves+1] = ChallengeMission_FirstWave 
	_challenge.waves[#_challenge.waves+1] = ChallengeMission_SecondWave 
	_challenge.waves[#_challenge.waves+1] = ChallengeMission_ThirdWave 
	_challenge.waves[#_challenge.waves+1] = ChallengeMission_FourthWave 
	_challenge.waves[#_challenge.waves+1] = ChallengeMission_FifthWave 
	_challenge.waves[#_challenge.waves+1] = ChallengeMission_SixthWave 
	_challenge.celebrations[#_challenge.celebrations+1] = EVENTS.Narr_Celebration1 
	_challenge.celebrations[#_challenge.celebrations+1] = EVENTS.Narr_Celebration2
	_challenge.celebrations[#_challenge.celebrations+1] = EVENTS.Narr_Celebration3 
	_challenge.celebrations[#_challenge.celebrations+1] = EVENTS.Narr_Celebration4
	_challenge.celebrations[#_challenge.celebrations+1] = EVENTS.Narr_Celebration5	
	_challenge.celebrations[#_challenge.celebrations+1] = EVENTS.Narr_Celebration6		
	_challenge.attackDelay[#_challenge.attackDelay+1] = 10
	_challenge.attackDelay[#_challenge.attackDelay+1] = 10
	_challenge.attackDelay[#_challenge.attackDelay+1] = 10
	_challenge.attackDelay[#_challenge.attackDelay+1] = 10
	_challenge.attackDelay[#_challenge.attackDelay+1] = 10
	_challenge.attackDelay[#_challenge.attackDelay+1] = 10
	
end

-- Mission Preset
function Mission_Preset()
	
	-- Setup Game and Players
	ChallengeMission_SetupChallengePlayers()
	ChallengeMission_SetupDiplomacy()
	
end

-- Called before Mission Start
function Mission_PreStart()
	
	-- Spawn Starting Units
	ChallengeMission_InitStartingUnits()
	
	-- Start pre-intro cinematic
	AdvancedCombat_PreIntro_Setup_Scenes()
	Util_StartIntel(EVENTS.AdvancedCombat_PreIntro)
	
	-- Check for end of Event
	Rule_AddInterval(Mission_PreStart_IntroNISFinished, 0.125)
	-- Hold off on starting the mission until cinematic finishes
	StartMission_Hold()
	
	-- set music intensity
	Music_LockIntensity(MUSIC_TENSE_RARE)
	
end

-- Called at Mission Start
function Mission_Start()
	--reset diplomacy
	ChallengeMission_SetupDiplomacy()
	
	-- Setup Challenge Mission
	ChallengeMission_SetupChallenge()
	
	-- Initialize Objectives
	ChallengeMission_InitializeObjectives()
	
	--Missionomatic_ChallengeInit({ kpiType = "unitsLost", goalBronze = 40, goalSilver = 30, goalGold = 15 }) -- only in XP1
	
	-- Register callbacks for global events
	Rule_AddGlobalEvent(ChallengeMission_OnDestruction, GE_EntityKilled)
	
	Rule_AddInterval(ChallengeMission_Update, 0.25)
	Rule_AddInterval(ChallengeMission_RespondToPlayerAttack, 1.5)
	
	Rule_AddOneShot(ChallengeMission_FirstWave, _challenge.revealDelay)
	Rule_AddOneShot(ChallengeMission_InitializeWave, _challenge.revealDelay + _challenge.selectionDelay)

	
	--add point of interest labels
	HintPoint_StealthForest1 = HintPoint_Add(mkr_stealth_forest_01, true, "$11202377")
	HintPoint_StealthForest2 = HintPoint_Add(mkr_stealth_forest_02, true, "$11202377")
	HintPoint_Cliffs = HintPoint_Add(mkr_cliffs, true, "$11217933")
	
	-- Disable dynamic training
	TrainingGoal_DisableAgeUpGoals()
	TrainingGoal_DisableCoreControlGoals()
	TrainingGoal_DisableCoreEconGoals()
	
	if Util_GetCommandLineArgument("CampaignAutoTest") then
		print("CampaignAutoTest parameter detected")
		AutomatedMission_Start()
	end
end

-----------------------------------------------------------------------
-- Functions
-----------------------------------------------------------------------
function GetRecipe()

	local recipe = {
		
		introNIS = EVENTS.PreIntro,
	}
end

function ChallengeMission_SetupDiplomacy()
	
	Player_SetRelationship(localPlayer, villagePlayer, R_ALLY)
	Player_SetRelationship(localPlayer, enemyPlayer, R_ENEMY)
	Player_SetRelationship(enemyPlayer, villagePlayer, R_ENEMY)
	Player_SetRelationship(localPlayer, trainingPlayer, R_ALLY)
	Player_SetRelationship(enemyPlayer, trainingPlayer, R_ALLY)
	Player_SetRelationship(localPlayer, trainingPlayer2, R_ALLY)
	Player_SetRelationship(enemyPlayer, trainingPlayer2, R_ALLY)
	Player_SetRelationship(trainingPlayer2, localPlayer, R_ALLY)
	Player_SetRelationship(trainingPlayer2, enemyPlayer, R_ALLY)
	
	World_EnableSharedLineOfSight(localPlayer,villagePlayer,true)
	World_EnableSharedLineOfSight(enemyPlayer, trainingPlayer, false)
	World_EnableSharedLineOfSight(enemyPlayer, trainingPlayer2, false)
	
end

-- Configure Players
function ChallengeMission_SetupChallengePlayers()
	--[[
	--only in XP1
	localPlayer = Missionomatic_InitPlayer(1, { name = "$11202380", currentAge = AGE_CASTLE, maxAge = AGE_CASTLE, playerColorSlot = 1 })
	enemyPlayer = Missionomatic_InitPlayer(2, { name = "Abbasid", currentAge = AGE_CASTLE, maxAge = AGE_CASTLE, playerColorSlot = 2 }) --Enemy
	villagePlayer = Missionomatic_InitPlayer(3, { name = "$11202382", currentAge = AGE_CASTLE, maxAge = AGE_CASTLE, playerColorSlot = 3 }) --Ally
	trainingPlayer = Missionomatic_InitPlayer(4, { name = "$11202382", currentAge = AGE_FEUDAL, maxAge = AGE_FEUDAL, playerColorSlot = 3 }) --Allied Production
	trainingPlayer2 = Missionomatic_InitPlayer(5, { name = "$11202382", currentAge = AGE_CASTLE, maxAge = AGE_CASTLE, playerColorSlot = 3 }) --Allied Production
	--]]
	--use old player setup methods
	
	-- player 1 - Player
	localPlayer = World_GetPlayerAt(1) --Player
	Setup_SetPlayerName(localPlayer, "$11202380")
	Player_SetCurrentAge(localPlayer, AGE_CASTLE)
	Player_SetMaximumAge(localPlayer, AGE_CASTLE)
	
	-- player 2 - Enemy
	enemyPlayer = World_GetPlayerAt(2) --Enemy
	Setup_SetPlayerName(enemyPlayer, "$11183528")
	Player_SetCurrentAge(enemyPlayer, AGE_CASTLE)
	Player_SetMaximumAge(enemyPlayer, AGE_CASTLE)
	
	villagePlayer = World_GetPlayerAt(3) --Ally
	Setup_SetPlayerName(villagePlayer, "$11202382")
	Player_SetCurrentAge(villagePlayer, AGE_CASTLE)
	Player_SetMaximumAge(villagePlayer, AGE_CASTLE)
	
	trainingPlayer = World_GetPlayerAt(4) --Ally
	Setup_SetPlayerName(trainingPlayer, "$11202382")
	Player_SetCurrentAge(trainingPlayer, AGE_FEUDAL)
	Player_SetMaximumAge(trainingPlayer, AGE_FEUDAL)
	
	trainingPlayer2 = World_GetPlayerAt(5) --Ally
	Setup_SetPlayerName(trainingPlayer2, "$11202382")
	Player_SetCurrentAge(trainingPlayer2, AGE_CASTLE)
	Player_SetMaximumAge(trainingPlayer2, AGE_CASTLE)
	
	-- Set Player Colors
	Game_SetPlayerSlotColour(villagePlayer, 3)
	Game_SetPlayerUISlotColour(villagePlayer, 3)
	
	Game_SetPlayerSlotColour(trainingPlayer, 3)
	Game_SetPlayerUISlotColour(trainingPlayer, 3)
	
	Game_SetPlayerSlotColour(trainingPlayer2, 3)
	Game_SetPlayerUISlotColour(trainingPlayer2, 3)
	
end

function ChallengeMission_SetupChallenge()

	-- Set starting resources
	Player_SetResource(localPlayer, RT_Food, _challenge.startingResources.food)
	Player_SetResource(localPlayer, RT_Wood, _challenge.startingResources.wood)
	Player_SetResource(localPlayer, RT_Gold, _challenge.startingResources.gold)
	Player_SetResource(localPlayer, RT_Stone, _challenge.startingResources.stone)
	
	-- Hide Death (delete units)
	Player_SetAbilityAvailability(localPlayer, BP_GetAbilityBlueprint("core_unit_death"), ITEM_REMOVED)
	
	-- Hide Building Scuttle (delete buildings)
	Player_SetAbilityAvailability(localPlayer, BP_GetAbilityBlueprint("core_building_scuttle"), ITEM_REMOVED)
	
	-- Hide Garrison Ability
	Player_SetCommandAvailability(localPlayer, SCMD_Load, ITEM_REMOVED)
	
	-- Set priority enemy attackers
	villageBuildings = Player_GetAllEntities(villagePlayer)	
	EGroup_Filter(villageBuildings, {"stable", "archery_range", "barracks"}, FILTER_REMOVE)
	
end

function ChallengeMission_InitStartingUnits()
	
	-- Create groups for the Player
	_challenge.currentArmy = SGroup_CreateIfNotFound("sg_current_army")
	_challenge.currentArmy2 = SGroup_CreateIfNotFound("sg_current_army2")
	
	-- Create groups for the Village
	_challenge.archerLeader = SGroup_CreateIfNotFound("sg_archer_leader")
	_challenge.crossbowmanLeader = SGroup_CreateIfNotFound("sg_crossbowman_leader")
	_challenge.spearmanLeader = SGroup_CreateIfNotFound("sg_spearman_leader")
	_challenge.manatarmsLeader = SGroup_CreateIfNotFound("sg_manatarms_leader")
	_challenge.horsemanLeader = SGroup_CreateIfNotFound("sg_horseman_leader")
	_challenge.knightLeader = SGroup_CreateIfNotFound("sg_knight_leader")
	
	
	_challenge.archeryRange1 = EGroup_CreateIfNotFound("eg_archery_range1")
	Player_GetAllEntitiesNearMarker(trainingPlayer, _challenge.archeryRange1, mkr_archer_range, 3)
	EGroup_Filter(_challenge.archeryRange1, "archery_range", FILTER_KEEP)
	
	
	_challenge.archeryRange2 = EGroup_CreateIfNotFound("eg_archery_range2")
	Player_GetAllEntitiesNearMarker(trainingPlayer2, _challenge.archeryRange2, mkr_crossbowman_range, 3)
	EGroup_Filter(_challenge.archeryRange2, "archery_range", FILTER_KEEP)
	
	
	_challenge.barracks1 = EGroup_CreateIfNotFound("eg_barracks1")
	Player_GetAllEntitiesNearMarker(trainingPlayer, _challenge.barracks1, mkr_spearman_barracks, 3)
	EGroup_Filter(_challenge.barracks1, "barracks", FILTER_KEEP)
	
	_challenge.barracks2 = EGroup_CreateIfNotFound("eg_barracks2")
	Player_GetAllEntitiesNearMarker(trainingPlayer2, _challenge.barracks2, mkr_manatarms_barracks, 3)
	EGroup_Filter(_challenge.barracks2, "barracks", FILTER_KEEP)
	
	_challenge.stable1 = EGroup_CreateIfNotFound("eg_stable1")
	Player_GetAllEntitiesNearMarker(trainingPlayer, _challenge.stable1, mkr_horseman_stable, 3)
	EGroup_Filter(_challenge.stable1, "stable", FILTER_KEEP)
	
	_challenge.stable2 = EGroup_CreateIfNotFound("eg_stable2")
	Player_GetAllEntitiesNearMarker(trainingPlayer2, _challenge.stable2, mkr_knight_stable, 3)
	EGroup_Filter(_challenge.stable2, "stable", FILTER_KEEP)
	
end

