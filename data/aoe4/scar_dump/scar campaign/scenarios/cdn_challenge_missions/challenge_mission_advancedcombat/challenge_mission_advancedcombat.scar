	}
	_challenge.objective.surviveWave1 =
	{
		Title = "$11217918", -- Defeat the approaching men at arms
		Type = OT_Bonus,
		Parent = _challenge.victory.objectiveVictory,
	}
	_challenge.objective.trainWave1 =
	{
		Title = "$11217924",
		Type = ObjectiveType_Information,
	}
	_challenge.objective.surviveWave2 =
	{
		Title = "$11217919", -- Defeat the approaching crossbowmen
		Type = OT_Bonus,
		Parent = _challenge.victory.objectiveVictory,
	}
	_challenge.objective.trainWave2 =
	{
		Title = "$11217924",
		Type = ObjectiveType_Information,
	}
	_challenge.objective.surviveWave3 =
	{
		Title = "$11217920", -- Defeat the approaching Knights
		Type = OT_Bonus,
		Parent = _challenge.victory.objectiveVictory,
	}
	_challenge.objective.trainWave3 =
	{
		Title = "$11217924",
		Type = ObjectiveType_Information,
	}
	_challenge.objective.surviveWave4 =
	{
		Title = "$11217921", -- Defeat the approaching Spearmen and crossbowmen
		Type = OT_Bonus,
		Parent = _challenge.victory.objectiveVictory,
	}
	_challenge.objective.trainWave4 =
	{
		Title = "$11217925",
		Type = ObjectiveType_Information,
	}
	_challenge.objective.surviveWave5 =
	{
		Title = "$11217922", -- Defeat the approaching men-at-arms and Horsemen
		Type = OT_Bonus,
		Parent = _challenge.victory.objectiveVictory,
	}
	_challenge.objective.trainWave5 =
	{
		Title = "$11217925",
		Type = ObjectiveType_Information,
	}
	_challenge.objective.surviveWave6 =
	{
		Title = "$11217923", -- Defeat the approaching Archers and Knights
		Type = OT_Bonus,
		Parent = _challenge.victory.objectiveVictory,
	}
	_challenge.objective.trainWave6 =
	{
		Title = "$11217925",
		Type = ObjectiveType_Information,
	}
	_challenge.victory.objectiveVictory2 = {
		-- Set Objective Title
		Title = "$11202325", -- Do not let the enemy burn down your village!
		-- Set Objective Type
		Type = OT_Primary
	}
	_challenge.objective.protectTown =
	{
		Title = "$11202332", -- You will lose if too many buildings are burned down
		Type = OT_Bonus,
		Parent = _challenge.victory.objectiveVictory2,
	}	
	_challenge.benchmarks.unplaced.objective = {
				-- Set Objective Title
				Title = "$11202197", 
				-- Set Objective Type
				Type = OT_Bonus,
				-- Set Objective Icon
				Icon = _challenge.icons.noMedalObjective,
				}
	_challenge.benchmarks.bronze.objective = {
				-- Set Objective Title
				Title = Loc_FormatText("$11202194", _challenge.benchmarks.bronze.maxUnitsDied+1),
				TelemetryTitle = "UnitsLost_BronzeMedal",
				-- Set Objective Type
				Type = OT_Bonus,
				-- Set Objective Icon
				Icon = _challenge.icons.bronzeMedalObjective,
				}
	_challenge.benchmarks.silver.objective = {
				-- Set Objective Title
				Title = Loc_FormatText("$11202195", _challenge.benchmarks.silver.maxUnitsDied+1),
				TelemetryTitle = "UnitsLost_SilverMedal",
				-- Set Objective Type
				Type = OT_Bonus,
				-- Set Objective Icon
				Icon = _challenge.icons.silverMedalObjective,
				}
	_challenge.benchmarks.gold.objective = {
				-- Set Objective Title
				Title = Loc_FormatText("$11202196", _challenge.benchmarks.gold.maxUnitsDied+1),
				TelemetryTitle = "UnitsLost_GoldMedal",
				-- Set Objective Type
				Type = OT_Bonus,
				-- Set Objective Icon
				Icon = _challenge.icons.goldMedalObjective,
				}
	
	-- Set player's current benchmark as Gold
	_challenge.currentBenchmark = _challenge.benchmarks.gold
	
	-- Register Primary objectives
	Objective_Register(_challenge.victory.objectiveVictory, localPlayer.id)
	Objective_Register(_challenge.victory.objectiveVictory2, localPlayer.id)
	
	-- Register Medal objective
	Objective_Register(_challenge.benchmarks.gold.objective, localPlayer.id)
	
	
	-- Register Sub objective
	Objective_Register(_challenge.objective.surviveWave1, localPlayer.id)
	Objective_Register(_challenge.objective.surviveWave2, localPlayer.id)
	Objective_Register(_challenge.objective.surviveWave3, localPlayer.id)
	Objective_Register(_challenge.objective.surviveWave4, localPlayer.id)
	Objective_Register(_challenge.objective.surviveWave5, localPlayer.id)	
	Objective_Register(_challenge.objective.surviveWave6, localPlayer.id)	
	Objective_Register(_challenge.objective.protectTown, localPlayer.id)		
	
	Objective_Register(_challenge.objective.trainWave1, localPlayer.id)
	Objective_Register(_challenge.objective.trainWave2, localPlayer.id)
	Objective_Register(_challenge.objective.trainWave3, localPlayer.id)
	Objective_Register(_challenge.objective.trainWave4, localPlayer.id)
	Objective_Register(_challenge.objective.trainWave5, localPlayer.id)
	Objective_Register(_challenge.objective.trainWave6, localPlayer.id)
	
	-- Start objectives
	Objective_Start(_challenge.victory.objectiveVictory, false, false)
	Objective_Start(_challenge.victory.objectiveVictory2, false, false)
	Objective_Start(_challenge.objective.protectTown, false, false)	
	Objective_Start(_challenge.benchmarks.gold.objective, false, false)
	
	-- Add Counters to track progress
	Objective_SetCounter(_challenge.victory.objectiveVictory, 0, #_challenge.waves)
	Objective_SetCounter(_challenge.objective.protectTown, 0, _challenge.maxHousesLost)	
	Objective_SetCounter(_challenge.benchmarks.gold.objective, 0, _challenge.benchmarks.gold.maxUnitsDied)
end

function AdvancedCombat_Intro_Units()
	sg_intro_horsemen = SGroup_CreateIfNotFound("sg_intro_horsemen")
	local sbp_horseman_hre = BP_GetSquadBlueprint("unit_horseman_3_hre")
	UnitEntry_DeploySquads(localPlayer, sg_intro_horsemen, {sbp = sbp_horseman_hre, numSquads = 3 }, mkr_intro_01_player_horsemen_spawn)
	
	Cmd_Ability(sg_intro_horsemen, BP_GetAbilityBlueprint("core_formation_wedge"))
	Cmd_FormationMove(sg_intro_horsemen, mkr_intro_01_player_horsemen_rally_01, false)
	Cmd_FormationMove(sg_intro_horsemen, mkr_intro_01_player_horsemen_rally_02, true)
	Cmd_FormationMove(sg_intro_horsemen, mkr_intro_01_player_horsemen_rally_03, true)
	Cmd_FormationMove(sg_intro_horsemen, mkr_intro_01_player_horsemen_rally_04, true)
	
	ChallengeMissionDeployDummyUnits()
end

function AdvancedCombat_Intro_Cleanup()
	
	if(SGroup_Exists("sg_intro_horsemen")) then
		SGroup_DestroyAllSquads(sg_intro_horsemen)
	end
	
end

-- Checks if intro Event is running
function Mission_PreStart_IntroNISFinished()
    if Event_IsAnyRunning() == false then
		
		AdvancedCombat_Intro_Cleanup()
		
        Rule_RemoveMe()
        StartMission_ReleaseHold()
    end
end

function ChallengeMissionDeployDummyUnits()
	
	-- Deploy example units
	local bp_Archer = BP_GetSquadBlueprint("unit_archer_3_hre")
	local bp_Crossbowman = BP_GetSquadBlueprint("unit_crossbowman_3_hre")
	local bp_Spearman = BP_GetSquadBlueprint("unit_spearman_3_hre")
	local bp_Manatarms = BP_GetSquadBlueprint("unit_manatarms_3_hre")
	local bp_Horseman = BP_GetSquadBlueprint("unit_horseman_3_hre")
	local bp_Knight = BP_GetSquadBlueprint("unit_knight_3_hre")
	
	UnitEntry_DeploySquads(trainingPlayer2, _challenge.archerLeader, {{sbp = bp_Archer, numSquads = 1 }}, mkr_village_archer_spawn)
	Cmd_FormationMove(_challenge.archerLeader, mkr_village_archer_spawn, false, false, mkr_player_archer_rally)
	Modify_WeaponEnabled(_challenge.archerLeader, "hardpoint_01", false)
	
	UnitEntry_DeploySquads(trainingPlayer2, _challenge.crossbowmanLeader, {{sbp = bp_Crossbowman, numSquads = 1 }}, mkr_village_crossbowman_spawn)
	Cmd_FormationMove(_challenge.crossbowmanLeader, mkr_village_crossbowman_spawn, false, false, mkr_player_crossbowman_rally)
	Modify_WeaponEnabled(_challenge.crossbowmanLeader, "hardpoint_01", false)
	
	UnitEntry_DeploySquads(trainingPlayer2, _challenge.spearmanLeader, {{sbp = bp_Spearman, numSquads = 1 }}, mkr_village_spearman_spawn)
	Cmd_FormationMove(_challenge.spearmanLeader, mkr_village_spearman_spawn, false, false, mkr_player_spearman_rally)
	Modify_WeaponEnabled(_challenge.spearmanLeader, "hardpoint_01", false)
	
	UnitEntry_DeploySquads(trainingPlayer2, _challenge.manatarmsLeader, {{sbp = bp_Manatarms, numSquads = 1 }}, mkr_village_manatarms_spawn)
	Cmd_FormationMove(_challenge.manatarmsLeader, mkr_village_manatarms_spawn, false, false, mkr_player_manatarms_rally)
	Modify_WeaponEnabled(_challenge.manatarmsLeader, "hardpoint_01", false)
	
	UnitEntry_DeploySquads(trainingPlayer2, _challenge.horsemanLeader, {{sbp = bp_Horseman, numSquads = 1 }}, mkr_village_horseman_spawn)
	Cmd_FormationMove(_challenge.horsemanLeader, mkr_village_horseman_spawn, false, false, mkr_player_horseman_rally)
	Modify_WeaponEnabled(_challenge.horsemanLeader, "hardpoint_01", false)
	
	UnitEntry_DeploySquads(trainingPlayer2, _challenge.knightLeader, {{sbp = bp_Knight, numSquads = 1 }}, mkr_village_knight_spawn)
	Cmd_FormationMove(_challenge.knightLeader, mkr_village_knight_spawn, false, false, mkr_player_knight_rally)
	Modify_WeaponEnabled(_challenge.knightLeader, "hardpoint_01", false)
	
end


-- Prepares for the next attack wave.
function ChallengeMission_InitializeWave()
	
	-- Make sure the player has no buildings selected
	Misc_ClearSelection()
	
	-- LEFT CLICK / PRESS A to train 15 Archers.
	hintPoint_recruit_archers = Objective_AddUIElements(_challenge.victory.objectiveVictory, _challenge.archeryRange1, false, UI_PickIDForInputMode(11217926, 11251404), true, 2 ) 
	
	-- LEFT CLICK / PRESS A to train 10 Crossbowmen.
	hintPoint_recruit_crossbowmen = Objective_AddUIElements(_challenge.victory.objectiveVictory, _challenge.archeryRange2, false, UI_PickIDForInputMode(11217927, 11251405), true, 2 )
	
	-- LEFT CLICK / PRESS A to train 15 Spearmen.
	hintPoint_recruit_spearmen = Objective_AddUIElements(_challenge.victory.objectiveVictory, _challenge.barracks1, false, UI_PickIDForInputMode(11217928, 11251406), true, 2 ) 
	
	-- LEFT CLICK / PRESS A to train 10 Men at Arms.
	hintPoint_recruit_menatarms = Objective_AddUIElements(_challenge.victory.objectiveVictory, _challenge.barracks2, false, UI_PickIDForInputMode(11217929, 11251407), true, 2 ) 
	
	-- LEFT CLICK / PRESS A to train 10 Horsemen.
	hintPoint_recruit_horsemen = Objective_AddUIElements(_challenge.victory.objectiveVictory, _challenge.stable1, false, UI_PickIDForInputMode(11217930, 11251408), true, 2 ) 
	
	-- LEFT CLICK / PRESS A to train 5 Knights.
	hintPoint_recruit_knights = Objective_AddUIElements(_challenge.victory.objectiveVictory, _challenge.stable2, false, UI_PickIDForInputMode(11217931, 11251409), true, 2 ) 
	
	--remove any undo hints
	Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_undo_archers)
	Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_undo_crossbowmen)
	Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_undo_spearmen)
	Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_undo_menatarms)
	Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_undo_horsemen)
	Objective_RemoveUIElements(_challenge.victory.objectiveVictory,hintPoint_undo_knights)
	
	Cmd_HoldPosition(_challenge.archerLeader,true,true)
	Cmd_HoldPosition(_challenge.crossbowmanLeader,true,true)
	Cmd_HoldPosition(_challenge.spearmanLeader,true,true)
	Cmd_HoldPosition(_challenge.manatarmsLeader,true,true)
	Cmd_HoldPosition(_challenge.horsemanLeader,true,true)
	Cmd_HoldPosition(_challenge.knightLeader,true,true)
	
	_challenge.archerDefense = false
	_challenge.crossbowmanDefense = false
	_challenge.spearmanDefense = false
	_challenge.manatarmsDefense = false
	_challenge.horsemanDefense = false
	_challenge.knightDefense = false
	
	Rule_AddOneShot(ChallengeMission_RemindPlayer, _challenge.reminderDelay)
	
	-- TODO create a marker for this
	UI_CreateMinimapBlip(mkr_village_archer_spawn, 10, "question_here")
	
	_challenge.waveActive = true
	
	--display hint for training 1 or 2 groups
	if(_challenge.currentWave == 1) then
		_challenge.currentTrainingObjective = _challenge.objective.trainWave1
	elseif(_challenge.currentWave == 2) then
		_challenge.currentTrainingObjective = _challenge.objective.trainWave2
	elseif(_challenge.currentWave == 3) then
		_challenge.currentTrainingObjective = _challenge.objective.trainWave3
	elseif(_challenge.currentWave == 4) then
		_challenge.currentTrainingObjective = _challenge.objective.trainWave4
	elseif(_challenge.currentWave == 5) then
		_challenge.currentTrainingObjective = _challenge.objective.trainWave5
	else
		_challenge.currentTrainingObjective = _challenge.objective.trainWave6
	end
	Objective_Start(_challenge.currentTrainingObjective,true,false)
	
	firstUndoSpawn = "none"
	secondUndoSpawn = "none"
		
	_challenge.buildingsLostThisWave = 0
	_challenge.buildingsLostEndOfWave = 0
end

-- Remind the player to deploy an army
function ChallengeMission_RemindPlayer()
	if(SGroup_Count(_challenge.currentArmy) == 0) then
		Util_StartIntel(EVENTS.Narr_NothingSelected)
	end
	Rule_RemoveMe()
end

function ChallengeMission_FirstWave()
	
	---- Create SGroups
	local sg_wave = SGroup_CreateIfNotFound("sg_wave")
	
	_challenge.currentWaveSquadGroup = sg_wave
	_challenge.currentWaveAttackPath = {mkr_path1_1, mkr_path1_2, mkr_path1_3, mkr_path1_4, mkr_path1_5}
	_challenge.currentWaveAttackStartDialogue = EVENTS.Narr_WaveIncoming
	
	EventCues_CallToAction("$11217934","cta_focus_change",nil,nil,Marker_GetPosition(mkr_path1_1),30, "icons/cta/illustrations/04_lord_roberts_b") -- Enemy Spotted!
	Util_StartIntel(EVENTS.Narr_Wave1Setup)
	_challenge.currentSecondObjective = _challenge.objective.surviveWave1
	Objective_Start(_challenge.currentSecondObjective,true,false)
	
	---- Get unit blueprints
	local bp_unit = BP_GetSquadBlueprint("unit_manatarms_3_generic_abb")
	
	---- Deploy and show squad	
	UnitEntry_DeploySquads(enemyPlayer, sg_wave, {{sbp = bp_unit, numSquads = _challenge.balance.wave1Count}}, mkr_path1_1)
	Cmd_FormationMove(sg_wave, mkr_path1_1, true, false, mkr_path1_2)
	FOW_PlayerRevealSGroup(localPlayer, sg_wave,30,-1)
		
	UI_CreateMinimapBlip(sg_wave, 10, "threat_group")
	
	-- Make sure the player has no buildings selected
	Misc_ClearSelection()
	
end

