-- Called when Mission loads
function Mission_OnInit()
	
	Game_FadeToBlack(FADE_OUT, 0)
	
	if UI_IsXboxUI() then
		_challenge.benchmarks.bronze = {
			goal_m = 20, -- 20 minutes
			goal_s = 0, -- 0 seconds
			time = 20*60+0,
			objective = {},
		}
		_challenge.benchmarks.silver = {
			goal_m = 16, -- 16 minutes
			goal_s = 0, -- 0 seconds
			time = 16*60+0,
			objective = {},
		}
		_challenge.benchmarks.gold = {
			goal_m = 10, -- 10 minutes
			goal_s = 45, -- 45 seconds
			time = 10*60+45,
			objective = {},
		}
	end
	
	-- Setup Victory Objectives
	_challenge.victory.objectiveVictory = {
				-- Set Objective Title
				Title = "$11202274", -- Build a booming economy
				-- Set Objective Type
				Type = OT_Primary,
				-- Completed when sub objectives are all complete
				IsComplete = function()
					return Objective_AreSubObjectivesComplete(_challenge.victory.objectiveVictory, ALL)
				end,
				-- Function called when Objective is complete
				OnComplete = ChallengeMission_OnComplete,
				}
	_challenge.victory.objectiveVillagers = {
				-- Set Objective Title
				Title = "$11202275", -- Train Additional Villagers
				-- Set Objective Type
				Type = OT_Secondary,
				Parent = _challenge.victory.objectiveVictory,
				}	
	_challenge.victory.objectiveTraders = {
				-- Set Objective Title
				Title = "$11202276", -- Train Additional Traders
				-- Set Objective Type
				Type = OT_Secondary,
				Parent = _challenge.victory.objectiveVictory,
				}	
	_challenge.victory.objectiveLandmark = {
			-- Set Objective Title
			Title = "$11202277", -- Build a Landmark and advance to the Imperial Age
			-- Set Objective Type
			Type = OT_Secondary,
			Parent = _challenge.victory.objectiveVictory,
			}
	
	_challenge.victory.villagerRequirement = 80 -- 60
	_challenge.victory.traderRequirement = 30 -- 40
	_challenge.victory.constructionRequirement = "wonder_imperial_age"
	_challenge.secondary.townCenterRequirement = 4
	_challenge.secondary.marketRequirement = 4
	_challenge.secondary.farmRequirement = 20
	_challenge.secondary.technologyRequirement = 3
	_challenge.secondary.populationPercentage = 0.85
	
	-- Setup Secondary Objectives
	_challenge.secondary.objectiveVictory = {
				-- Set Objective Title
				Title = "$11200775", --"Expand your base"
				-- Set Objective Type
				Type = OT_Secondary,
				-- Completed when sub objectives are all complete
		IsComplete = function()
			return Objective_AreSubObjectivesComplete(_challenge.secondary.objectiveVictory, ALL)
		end
		,
		}
	_challenge.secondary.objectiveSecondTownCenter = {
		
				-- Set Objective Title
				Title = "$11200776", -- "Build a second Town Center"
				-- Set Objective Type
				Type = OT_Secondary,
				Parent = _challenge.secondary.objectiveVictory,
				}
	_challenge.secondary.objectiveAddTownCenters = {
		
				-- Set Objective Title
				Title = "$11200777", -- "Build additional Town Centers"
				-- Set Objective Type
				Type = OT_Secondary,
				Parent = _challenge.secondary.objectiveVictory,
				}
	_challenge.secondary.objectiveAddMarkets = {
		
				-- Set Objective Title
				Title = "$11200778", -- "Build additional Markets"
				-- Set Objective Type
				Type = OT_Secondary,
				Parent = _challenge.secondary.objectiveVictory,
				}
	_challenge.secondary.objectiveAddHouses = {
		
				-- Set Objective Title
				Title = "$11200779", -- "Build additional Houses"
				-- Set Objective Type
				Type = OT_Secondary,
				Parent = _challenge.secondary.objectiveVictory,
				}
	_challenge.secondary.objectiveAddFarms = {
		
				-- Set Objective Title
				Title = "$11200780", -- "Build additional Farms"
				-- Set Objective Type
				Type = OT_Secondary,
				Parent = _challenge.secondary.objectiveVictory,
				}
	_challenge.secondary.objectiveResearchTechs = {
		
				-- Set Objective Title
				Title = "$11200781", -- "Research economic technologies"
				-- Set Objective Type
				Type = OT_Secondary,
				Parent = _challenge.secondary.objectiveVictory,
				}
	
	
	-- Setup Benchmark Objectives
	_challenge.benchmarks.unplaced.objective = {
				-- Set Objective Title
				Title = "$11166938", -- "Time Elapsed"
				-- Set Objective Type
				Type = OT_Bonus,
				-- Set Objective Icon
				Icon = _challenge.icons.noMedalObjective,
				}
	_challenge.benchmarks.bronze.objective = {
				-- Set Objective Title
				Title = Loc_FormatText("$11200672", _challenge.benchmarks.bronze.goal_m, _challenge.benchmarks.gold.goal_s), -- "Bronze Medal (Goal %1TIME_REQUIREMENT%m %2TIME_REQUIREMENT%s) - "
				TelemetryTitle = "TimeRequired_BronzeMedal",
				-- Set Objective Type
				Type = OT_Bonus,
				-- Set Objective Icon
				Icon = _challenge.icons.bronzeMedalObjective,
				}
	_challenge.benchmarks.silver.objective = {
				-- Set Objective Title
				Title = Loc_FormatText("$11200673", _challenge.benchmarks.silver.goal_m, _challenge.benchmarks.gold.goal_s), -- "Silver Medal (Goal %1TIME_REQUIREMENT%m %2TIME_REQUIREMENT%s) - "
				TelemetryTitle = "TimeRequired_SilverMedal",
				-- Set Objective Type
				Type = OT_Bonus,
				-- Set Objective Icon
				Icon = _challenge.icons.silverMedalObjective,
				}
	_challenge.benchmarks.gold.objective = {
				-- Set Objective Title
				Title = Loc_FormatText("$11200674", _challenge.benchmarks.gold.goal_m, _challenge.benchmarks.gold.goal_s), -- "Gold Medal (Goal %1TIME_REQUIREMENT%m %2TIME_REQUIREMENT%s) - "
				TelemetryTitle = "TimeRequired_GoldMedal",
				-- Set Objective Type
				Type = OT_Bonus,
				-- Set Objective Icon
				Icon = _challenge.icons.goldMedalObjective,
				}
	
	--Cache the cost of the cheapest unit that can be made from each type of building.
	for i, player in pairs(PLAYERS) do
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			
			-- Setup table to store cheapest squad
			player._annihilation = {cheapest_squad_cost = {}}
			
			
			for entity_type, squad_type in pairs(_challenge.annihilation.type_map) do 
				
				local sbp = Cardinal_ConvertTypeToSquadBlueprint(squad_type, player.id)
				
				if sbp == nil then
					
					print(string.format("Annihilation_OnInit() - No squad blueprint found for %s %s", player.raceName, squad_type))
					
				else
					
					player._annihilation.cheapest_squad_cost[entity_type] = Player_GetSquadBPCost(player.id, sbp)
					
				end
			end
		end
	end
end

-----------------------------------------------------------------------
-- Mission Functions
-----------------------------------------------------------------------

-- Mission Preset
function Mission_Preset()
	
	-- Setup Game and Players
	ChallengeMission_OnGameSetup()
	ChallengeMission_SetupPlayer()
	
	-- Add unit and upgrade restrictions
	ChallengeMission_SetRestrictions()
	
	--Audio Considerations	
	--Allow silence system working in music 
	if Music_UnlockIntensity then
		Sound_SetForceMusic(false)
	else
		Sound_SetForceMusic(true)
	end
	
end

-- Called before Mission Start
function Mission_PreStart()
	
	-- Get map resources
	ChallengeMission_FindAllResources()
	-- Add Starting Upgrades
	ChallengeMission_InitStartingUpgrades()
	
	-- Play intro Intel
	
	EarlyEconomy_PreIntro_Setup_Scenes()
	Util_StartIntel(EVENTS.LateEconomy_PreIntro)
	
	-- Check for end of Event
	Rule_AddInterval(Mission_PreStart_IntroNISFinished, 0.125)
	-- Hold off on starting the mission until cinematic finishes
	StartMission_Hold()
end

-- Called at Mission Start
function Mission_Start()
	
	-- Setup Challenge Mission
	ChallengeMission_SetupChallenge()
	
	-- Initialize Objectives
	ChallengeMission_InitializeObjectives()
	
	-- First VO line to get the player started
	Util_StartIntel(EVENTS.Narr_Start)
	
	-- Register callbacks for global events
	Rule_AddGlobalEvent(ChallengeMission_OnUpgradeComplete, GE_UpgradeComplete)
	Rule_AddGlobalEvent(ChallengeMission_OnConstructionComplete, GE_ConstructionComplete)
	Rule_AddGlobalEvent(ChallengeMission_OnDestruction, GE_EntityKilled)
	
	-- Check the player's progress
	Rule_AddInterval(ChallengeMission_NarrativeHintSecondTownCenter, 0.5)
	Rule_AddInterval(ChallengeMission_NarrativeHintMarkets, 0.5)
	Rule_AddInterval(ChallengeMission_NarrativeHintHouses, 3)
	Rule_AddInterval(ChallengeMission_NarrativeHintFarms, 0.5)
	Rule_AddInterval(ChallengeMission_NarrativeHintTechnologies, 0.5)
	Rule_AddInterval(ChallengeMission_CheckAgingUp, 0.5)
	Rule_AddInterval(ChallengeMission_CheckUnitCount, 0.5)
	
	-- Update Objectives and check for Victory
	Rule_AddInterval(ChallengeMission_Update, 0.125)
	
	-- Add hintpoints for trading posts
	eg_tradingPosts = EGroup_CreateIfNotFound("eg_tradingPosts")
	World_GetAllNeutralEntities(eg_tradingPosts)
	EGroup_Filter(eg_tradingPosts, "settlement", FILTER_KEEP)	-- building_trade_post_east
	HintPoint_Add(eg_tradingPosts, true, "$11202314") -- Send your Traders to this Trading Post to generate Gold.
	--hintPoint_tradingPosts = Objective_AddUIElements(_challenge.victory.objectiveVictory, eg_tradingPosts , false, "Send your Trade Carts to this Trading Post to generate Gold.", true, 2 ) --
		
end

-- Checks if intro Event is running
function Mission_PreStart_IntroNISFinished()
	
	-- If the event has finished running
	if not Event_IsAnyRunning() then  
		
		-- Release hold on mission start
		StartMission_ReleaseHold()		
		
	-- Set starting resources
	Player_SetResource(localPlayer, RT_Food, _challenge.startingResources.food)
	Player_SetResource(localPlayer, RT_Wood, _challenge.startingResources.wood)
	Player_SetResource(localPlayer, RT_Gold, _challenge.startingResources.gold)
	Player_SetResource(localPlayer, RT_Stone, _challenge.startingResources.stone)
		
		-- Remove this rule
		Rule_RemoveMe()
	end
	
end

