end

function LateEconomyTrainingGoals_OnInit()
	
	-- Disable core training goals for testing purposes
	-- TrainingGoal_DisableCoreControlGoals()
	-- TrainingGoal_DisableCoreEconGoals()
	
	-------------------------------------------------------------------------
	---- Goal Sequences
	-------------------------------------------------------------------------
	
	-- Train a villager
	-- Train a trader
	if UI_IsXboxControllerUI() then
		LateEconomyTrainingGoals_InitVillagerTraining_Xbox()
		LateEconomyTrainingGoals_InitTraderTraining_Xbox()
	else
		LateEconomyTrainingGoals_InitVillagerTraining()
		LateEconomyTrainingGoals_InitTraderTraining()
	end
	
	
	-- Use idle Villager
	local selectNextIdleVillagerGoal = Training_Goal("PBG",
		{ID= "Select the next idle Villager and assign it to a job.", Message= "$11202189", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedAnIdleVillager)
	local selectNextIdleVillagerSequence = Training_GoalSequence(goal_sequence_idle_villager,
		__t_challengeIdleVillagerRepeatMax, 0,
		SelectNextIdleIfVillagersIdle, 
		NoIdleVillagers, 
		nil,
		nil,
		true,
		{selectNextIdleVillagerGoal})
	Training_AddGoalSequence(selectNextIdleVillagerSequence)
	
	-- Use idle Trader
	local selectNextIdleTraderGoal = Training_Goal("PBG",
		{ID= "Select any idle Traders and task them to travel to a Trading Post.", Message= "$11202193", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedAnIdleTrader)
	local selectNextIdleTraderSequence = Training_GoalSequence(goal_sequence_idle_trader,
		__t_challengeIdleTraderRepeatMax, 0,
		SelectNextIdleIfTradersIdle, 
		NoIdleTraders, 
		nil,
		nil,
		true,
		{selectNextIdleTraderGoal})
	Training_AddGoalSequence(selectNextIdleTraderSequence)
	
	-- Use idle scout
	local selectScoutGoal = Training_Goal("Squad",
		{ID= "Do not forget about your Scout. You must explore to find more resources.", Message= "$11202190", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedAScout)
	local selectScoutSequence = Training_GoalSequence(goal_sequence_idle_scout,
		__t_challengeIdleScoutRepeatMax, 0,
		UserHasIdleScout, 
		EnoughMarkersExplored, 
		nil,
		nil,
		true,
		{selectScoutGoal})
	Training_AddGoalSequence(selectScoutSequence)
	
end


-----------------------------------------------------------------------
-- Functions, Goals, & Predicates
-----------------------------------------------------------------------

-- Predicate - When the player's Town Center is idle it will prompt the player to select it.
function UserHasIdleTownCenter_Xbox(goalSequence)
	
	-- For every player
	for i, player in pairs(PLAYERS) do
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			if player._challenge ~= nil then
				local currentTime = Timer_GetElapsed(goalSequence.timerID)
				local timeElapsed = World_GetGameTime() - player._challenge.startTime
				
				-- give the player some time at the start
				if timeElapsed >= __t_challengeStartIdleVillager then
					
					local currentTime = Timer_GetElapsed(goalSequence.timerID)
					if currentTime > __t_challengeIntervalIdleVillager then
						local localPlayer = Game_GetLocalPlayer()
						local villagerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", localPlayer)
						
						Player_GetAll(localPlayer)
						EGroup_Filter(eg_allentities, "town_center", FILTER_KEEP)
						EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
						local aTownCenterExists = EGroup_Count(eg_allentities) > 0

						if aTownCenterExists then
							local townCenter = EGroup_GetEntityAt(eg_allentities, 1)	
							local villagerCost = Player_GetSquadBPCost(localPlayer, villagerBP)
							local foodResources = Player_GetResource(localPlayer, RT_Food)
							
							-- Check if the player still needs to train villagers
							if Objective_IsComplete(_challenge.victory.objectiveVillagers) then
								return false						
							end
							
							-- Check if the town center is producing a villager
							if Entity_IsProducingSquad(townCenter, villagerBP) then
								return false
							end
							
							-- Check if the player has the resources and population space to train more villagers
							if foodResources >= villagerCost.food and Player_GetCurrentPopulation(localPlayer, CT_Personnel) < Player_GetCurrentPopulationCap(localPlayer, CT_Personnel) then
								goalSequence.goals[1].key = Entity_GetID(townCenter)
								goalSequence.goals[2].key = Entity_GetID(townCenter)
								goalSequence.goals[3].key = villagerBP
								return true
							end
						end
					end
				end
			end
		end
	end
	
	return false
	
end

function UserHasIdleTownCenter(goalSequence)
	
	-- For every player
	for i, player in pairs(PLAYERS) do
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			if player._challenge ~= nil then
				local currentTime = Timer_GetElapsed(goalSequence.timerID)
				local timeElapsed = World_GetGameTime() - player._challenge.startTime
				
				-- give the player some time at the start
				if timeElapsed >= __t_challengeStartIdleVillager then
					
					local currentTime = Timer_GetElapsed(goalSequence.timerID)
					if currentTime > __t_challengeIntervalIdleVillager then
						local localPlayer = Game_GetLocalPlayer()
						local villagerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", localPlayer)
						goalSequence.goals[1].key = nil
						
						Player_GetAll(localPlayer)
						EGroup_Filter(eg_allentities, "town_center", FILTER_KEEP)
						EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
						local aTownCenterExists = EGroup_Count(eg_allentities) > 0

						if aTownCenterExists then
							for i = 1, EGroup_Count(eg_allentities) do
								local townCenter = EGroup_GetEntityAt(eg_allentities, i)	
								
								-- Check if the town center is producing a villager
								if not Entity_IsProducingSquad(townCenter, villagerBP) then
									goalSequence.goals[1].key = Entity_GetID(townCenter)
									break
								end							
							end
							
							-- Check if the player still needs to train villagers
							if Objective_IsComplete(_challenge.victory.objectiveVillagers) then
								return false
							end
							
							-- Check if any town center is producing a villager
							if goalSequence.goals[1].key == nil then
								return false									
							end		
							
							local villagerCost = Player_GetSquadBPCost(localPlayer, villagerBP)
							local foodResources = Player_GetResource(localPlayer, RT_Food)
							
							-- Check if the player has the resources and population space to train more villagers
							if foodResources >= villagerCost.food and Player_GetCurrentPopulation(localPlayer, CT_Personnel) < Player_GetCurrentPopulationCap(localPlayer, CT_Personnel) then
								goalSequence.goals[2].key = villagerBP
								return true
							end
						end						
					end
				end
			end
		end
	end	
	return false
end


-- IsComplete - Check whether the user is training a Villager.
function UserIsTrainingVillager(goalSequence)
	local localPlayer = Game_GetLocalPlayer()
	local villagerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", localPlayer)
	
	Player_GetAll(localPlayer)
	EGroup_Filter(eg_allentities, "town_center", FILTER_KEEP)
	EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
	local aTownCenterExists = EGroup_Count(eg_allentities) > 0

	if aTownCenterExists then
		local townCenter = EGroup_GetEntityAt(eg_allentities, 1)
	
		if Entity_IsProducingSquad(townCenter, villagerBP) then
			return true
		end
	end
	
	return false
end

-- IsComplete - Check whether the player has selected the Town Center.
function UserHasSelectedTownCenter(goal)
	Misc_GetSelectedEntities(eg_currentSelection, false)
	if EGroup_Count(eg_currentSelection) == 1 then
		local entity = EGroup_GetEntityAt(eg_currentSelection, 1)
		if Entity_GetID(entity) == goal.key then
			return true
		end
	else --Multiple entitites were selected
		for i = 1, EGroup_Count(eg_currentSelection) do
			local entity = EGroup_GetEntityAt(eg_currentSelection, i)
			if Entity_GetID(entity) == goal.key then
				return true
			end			
		end		
	end
	return false
end

-- IsComplete - Check whether the player has started to train a Villager at the selected Town Center.
function TCHasStartedToTrainAVillager(goal)
	local villagerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", Game_GetLocalPlayer())
	
	Misc_GetSelectedEntities(eg_currentSelection, false)
	EGroup_Filter(eg_currentSelection, "town_center", FILTER_KEEP)
	if EGroup_Count(eg_currentSelection) == 1 then
		local townCenter = EGroup_GetEntityAt(eg_currentSelection, 1)
		return Entity_IsProducingSquad(townCenter, villagerBP)	
	else --Multiple entitites were selected
		for i = 1, EGroup_Count(eg_currentSelection) do
			local townCenter = EGroup_GetEntityAt(eg_currentSelection, i)
			-- Checks if one Town Center is producing villagers (should it check if all of them are?)
			if Entity_IsProducingSquad(townCenter, villagerBP) then
				return true
			end			
		end		
	end
	
	return false
end

-- Ignore - Check whether the player can still train a Villager
function UserHasNoMeansTownCenter(goal)
	local localPlayer = Game_GetLocalPlayer()
	local villagerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", localPlayer)
	local villagerCost = Player_GetSquadBPCost(localPlayer, villagerBP)
	local foodResources = Player_GetResource(localPlayer, RT_Food)
	
	-- Check if the player has the resources and population space to train more villagers
	if foodResources < villagerCost.food and Player_GetCurrentPopulation(localPlayer, CT_Personnel) >= Player_GetCurrentPopulationCap(localPlayer, CT_Personnel) then
		return true
	end
	
	return false
end

