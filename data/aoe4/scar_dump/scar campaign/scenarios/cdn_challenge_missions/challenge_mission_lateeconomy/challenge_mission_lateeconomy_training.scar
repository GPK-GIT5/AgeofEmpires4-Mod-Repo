		for i = 1, EGroup_Count(eg_currentSelection) do
			local entity = EGroup_GetEntityAt(eg_currentSelection, i)
			if Entity_GetID(entity) == goal.key then
				return true
			end			
		end		
	end
	return false
end

-- IsComplete - Check whether the player has started to train a Trader at the selected Market.
function MarketHasStartedToTrainATrader(goal)
	local traderBP = Cardinal_ConvertTypeToSquadBlueprint("scar_trade_cart", Game_GetLocalPlayer())
	
	Misc_GetSelectedEntities(eg_currentSelection, false)
	EGroup_Filter(eg_currentSelection, "trade_post", FILTER_KEEP)
	if EGroup_Count(eg_currentSelection) == 1 then
		local market = EGroup_GetEntityAt(eg_currentSelection, 1)
		return Entity_IsProducingSquad(market, traderBP)	
	else --Multiple entitites were selected
		for i = 1, EGroup_Count(eg_currentSelection) do
			local market = EGroup_GetEntityAt(eg_currentSelection, i)
			-- Checks if one Market is producing traders (should it check if all of them are?)
			if Entity_IsProducingSquad(market, traderBP) then
				return true
			end			
		end		
	end
	
	return false
end

-- Ignore - Check whether the player can still train a Trader
function UserHasNoMeansMarket(goal)
	local localPlayer = Game_GetLocalPlayer()
	local traderBP = Cardinal_ConvertTypeToSquadBlueprint("scar_trade_cart", Game_GetLocalPlayer())
	local traderCost = Player_GetSquadBPCost(localPlayer, traderBP)
	local woodResources = Player_GetResource(localPlayer, RT_Wood)
	local goldResources = Player_GetResource(localPlayer, RT_Gold)
	
	-- Check if the player has the resources and population space to train more traders
	if woodResources < traderCost.wood or goldResources < traderCost.gold or Player_GetCurrentPopulation(localPlayer, CT_Personnel) >= Player_GetCurrentPopulationCap(localPlayer, CT_Personnel) then
		return true
	end	
	
	return false
end

----------------------------------------------------------------------------------------------
-- Predicate - If a villager is idle for a certain amount of time it prompts the player to click on the "population button".
function SelectNextIdleIfVillagersIdle(goalSequence)
	
	-- For every player
	for i, player in pairs(PLAYERS) do
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			if player._challenge ~= nil then
				local timeElapsed = World_GetGameTime() - player._challenge.startTime
				
				-- give the player some time at the start
				if timeElapsed >= __t_challengeStartIdleVillager then
					
					local villagerIsIdle = false
					local localPlayer = Game_GetLocalPlayer()
					local villagerBP = Cardinal_ConvertTypeToSquadBlueprint("scar_villager", localPlayer)
					local squads = Player_GetSquads(localPlayer)
					
					goalSequence.goals[1].idleVillagers = {}
					
					for i = 1, SGroup_Count(squads) do
						local squad = SGroup_GetSquadAt(squads, i)
						
						if Squad_IsIdle(squad) and Squad_GetBlueprint(squad) == villagerBP then
							villagerIsIdle = true
							break
						end
					end
					
					if villagerIsIdle then
						if Timer_IsPaused(goalSequence.timerID) then
							Timer_Resume(goalSequence.timerID)
						end
					else
						if not Timer_IsPaused(goalSequence.timerID) then
							Timer_Pause(goalSequence.timerID)
						end
					end
					
					local currentTime = Timer_GetElapsed(goalSequence.timerID)
					if currentTime > __t_challengeIntervalIdleVillager and villagerIsIdle then
						goalSequence.goals[1].key = "PopulationButton"
						return true
					end
					
					goalSequence.goals[1].key = nil
				end
			end
		end
	end
	
	return false
end

----------------------------------------------------------------------------------------------
-- Predicate - If a trader is idle for a certain amount of time it prompts the player to click on the "population button".
function SelectNextIdleIfTradersIdle(goalSequence)
	
	-- For every player
	for i, player in pairs(PLAYERS) do
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			if player._challenge ~= nil then
				local timeElapsed = World_GetGameTime() - player._challenge.startTime
				
				-- give the player some time at the start
				if timeElapsed >= __t_challengeStartIdleTrader then
					
					local traderIsIdle = false
					local localPlayer = Game_GetLocalPlayer()
					local traderBP = Cardinal_ConvertTypeToSquadBlueprint("scar_trade_cart", localPlayer)
					local squads = Player_GetSquads(localPlayer)
					
					goalSequence.goals[1].idleTraders = {}
					
					for i = 1, SGroup_Count(squads) do
						local squad = SGroup_GetSquadAt(squads, i)
						
						if Squad_IsIdle(squad) and Squad_GetBlueprint(squad) == traderBP then
							traderIsIdle = true
							break
						end
					end
					
					if traderIsIdle then
						if Timer_IsPaused(goalSequence.timerID) then
							Timer_Resume(goalSequence.timerID)
						end
					else
						if not Timer_IsPaused(goalSequence.timerID) then
							Timer_Pause(goalSequence.timerID)
						end
					end
					
					local currentTime = Timer_GetElapsed(goalSequence.timerID)
					if currentTime > __t_challengeIntervalIdleTrader and traderIsIdle then
						goalSequence.goals[1].key = "PopulationButton"
						return true
					end
					
					goalSequence.goals[1].key = nil
				end
			end
		end
	end
	
	return false
end

function UserHasSelectedAnIdleTrader(goal)
	local localPlayer = Game_GetLocalPlayer()
	local traderBP = Cardinal_ConvertTypeToSquadBlueprint("scar_trade_Cart", localPlayer)
	local squads = Player_GetSquads(localPlayer)
	
	if goal.idleTraders ~= nil then
		RemoveTagsFromElements(goal.idleTraders)
	end
	
	goal.idleTraders = {}
	
	Misc_GetSelectedSquads(sg_currentSelection, false)
	for i = 1, SGroup_Count(sg_currentSelection) do
		local squad = SGroup_GetSquadAt(sg_currentSelection, i)
		if Squad_GetBlueprint(squad) == traderBP and Squad_IsIdle(squad) then
			return true
		end
	end
	
	for i = 1, SGroup_Count(squads) do
		local squad = SGroup_GetSquadAt(squads, i)
		
		if Squad_IsIdle(squad) and Squad_GetBlueprint(squad) == traderBP then
			goal.idleTraders[i] = {}
			goal.idleTraders[i].element = squad
			goal.idleTraders[i].id = 0
		end
	end
	
	if goal.idleTraders.length then
		return true
	end
	
	return false
end

----------------------------------------------------------------------------------------------

-- Predicate - If a Scout is idle it will prompt the player to use it.
function UserHasIdleScout(goalSequence)
	
	-- For every player
	for i, player in pairs(PLAYERS) do
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			if player._challenge ~= nil then
				local timeElapsed = World_GetGameTime() - player._challenge.startTime
				local currentTime = Timer_GetElapsed(goalSequence.timerID)
				-- give the player some time at the start
				if timeElapsed >= __t_challengeStartIdleScout then
					
					local scoutIsIdle = false
					local localPlayer = Game_GetLocalPlayer()
					local scoutBP = Cardinal_ConvertTypeToSquadBlueprint("scout", localPlayer)
					local squads = Player_GetSquads(localPlayer)
					
					goalSequence.goals[1].idleScout = {}
					
					local scout = nil
					for i = 1, SGroup_Count(squads) do
						local squad = SGroup_GetSquadAt(squads, i)
						
						if Squad_IsIdle(squad) and Squad_GetBlueprint(squad) == scoutBP then
							scoutIsIdle = true
							scout = SGroup_GetSquadAt(squads, i)
							break
						end
					end
					
					if scoutIsIdle then
						if Timer_IsPaused(goalSequence.timerID) then
							Timer_Resume(goalSequence.timerID)
						end
					else
						if not Timer_IsPaused(goalSequence.timerID) then
							Timer_Pause(goalSequence.timerID)
						end
					end
					
					local currentTime = Timer_GetElapsed(goalSequence.timerID)
					if currentTime > __t_challengeIntervalIdleScout and scoutIsIdle and __n_challengeScoutRepeatMaxCurrentSession < 5 then
						goalSequence.goals[1].key = Squad_GetID(scout)
						__n_challengeScoutRepeatMaxCurrentSession = __n_challengeScoutRepeatMaxCurrentSession + 1
						return true
					end
					
					goalSequence.goals[1].key = nil
				end
			end
		end
	end
	return false	
end

-- Ignore - Checks whether the player has explored __n_challengeScoutAreasToExplore areas.
function EnoughMarkersExplored(goalSequence)
	
	local westMarker = Marker_GetPosition(mkr_exploration_west)
	local eastMarker = Marker_GetPosition(mkr_exploration_east)
	local northMarker = Marker_GetPosition(mkr_exploration_north)
	local southMarker = Marker_GetPosition(mkr_exploration_south)
	
	if Player_CanSeePosition(localPlayer, westMarker) and exploredWest == false then
		areasExplored = areasExplored + 1
		exploredWest = true
	end
	if Player_CanSeePosition(localPlayer, eastMarker) and exploredEast == false then
		areasExplored = areasExplored + 1
		exploredEast = true
	end
	if Player_CanSeePosition(localPlayer, northMarker) and exploredNorth == false then
		areasExplored = areasExplored + 1
		exploredNorth = true
	end
	if Player_CanSeePosition(localPlayer, southMarker) and exploredSouth == false then
		areasExplored = areasExplored + 1
		exploredSouth = true
	end
	
	if areasExplored >= __n_challengeScoutAreasToExplore then
		return true
	end
	return false
end
