-- Predicate - When one of the Player's Markets is idle it will prompt the player to select it.
function UserHasIdleMarket_Xbox(goalSequence)
	
	-- For every player
	for i, player in pairs(PLAYERS) do
		
		-- If the player is local (not one of the AI players)
		if player.isLocal then
			if player._challenge ~= nil then
				local currentTime = Timer_GetElapsed(goalSequence.timerID)
				local timeElapsed = World_GetGameTime() - player._challenge.startTime
				
				-- give the player some time at the start
				if timeElapsed >= __t_challengeStartIdleTrader then
					
					local currentTime = Timer_GetElapsed(goalSequence.timerID)
					if currentTime > __t_challengeIntervalIdleTrader then
						local localPlayer = Game_GetLocalPlayer()
						local traderBP = Cardinal_ConvertTypeToSquadBlueprint("scar_trade_cart", localPlayer)
						goalSequence.goals[1].key = nil
						goalSequence.goals[2].key = nil
						
						Player_GetAll(localPlayer)
						EGroup_Filter(eg_allentities, "trade_post", FILTER_KEEP)
						EGroup_FilterUnderConstruction(eg_allentities, FILTER_REMOVE)
						local aMarketExists = EGroup_Count(eg_allentities) > 0
						

						if aMarketExists then						
							for i = 1, EGroup_Count(eg_allentities) do
								
								local market = EGroup_GetEntityAt(eg_allentities, i)	
								
								-- Check if the market is producing a trader
								if not Entity_IsProducingSquad(market, traderBP) then
									goalSequence.goals[1].key = Entity_GetID(market)
									goalSequence.goals[2].key = Entity_GetID(market)
									break
								end
							end
							
							-- Check if any market is producing a trader
							if goalSequence.goals[1].key == nil then
								return false
							end
							
							
							-- Check if the player still needs to train traders
							if Objective_IsComplete(_challenge.victory.objectiveTraders) then
								return false						
							end
							
							
							local traderCost = Player_GetSquadBPCost(localPlayer, traderBP)
							local woodResources = Player_GetResource(localPlayer, RT_Wood)
							local goldResources = Player_GetResource(localPlayer, RT_Gold)
							
							-- Check if the player has the resources and population space to train more traders
							if woodResources >= traderCost.wood and goldResources >= traderCost.gold and Player_GetCurrentPopulation(localPlayer, CT_Personnel) < Player_GetCurrentPopulationCap(localPlayer, CT_Personnel) then
								goalSequence.goals[3].key = traderBP
								return true
							end													
						end
					end
				end
			end
		end
	end
	
	return false
	
end

