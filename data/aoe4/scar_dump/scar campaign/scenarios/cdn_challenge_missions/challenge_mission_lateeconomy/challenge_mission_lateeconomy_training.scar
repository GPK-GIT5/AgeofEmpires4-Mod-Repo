---- Challenge Mission: Late Economy - Tutorial Elements
-------------------------------------------------------------------------

import("training/coretrainingconditions.scar")
import("training/coretraininggoals.scar")

Core_RegisterModule("LateEconomyTrainingGoals")

--------------------------------------------------------------------------------------
-- Variables for the dynamic training hints - Feel free to adjust this.
__t_challengeStartIdleTC = 15
__t_challengeIntervalIdleTC = 5
__t_challengeIdleTCRepeatMax = -1
__t_challengeStartIdleMarket = 20
__t_challengeIntervalIdleMarket = 5
__t_challengeIdleMarketRepeatMax = -1
__t_challengeStartIdleVillager = 10
__t_challengeIntervalIdleVillager = 5
__t_challengeIdleVillagerRepeatMax = -1
__t_challengeStartIdleTrader = 15
__t_challengeIntervalIdleTrader = 10
__t_challengeIdleTraderRepeatMax = -1
__t_challengeStartIdleScout = 30
__t_challengeIntervalIdleScout = 20
__t_challengeIdleScoutRepeatMax = -1
__n_challengeScoutAreasToExplore = 3
local __n_challengeScoutRepeatMaxCurrentSession = 0
--------------------------------------------------------------------------------------


local exploredWest = false
local exploredEast = false
local exploredNorth = false 
local exploredSouth = false
local areasExplored = 0

local goal_sequence_villager_training = "train_villager"
local goal_sequence_trader_training = "train_trader"
local goal_sequence_idle_villager = "idle_villager"
local goal_sequence_idle_trader = "idle_trader"
local goal_sequence_idle_scout = "idle_scout"

local training_goals_late_economy = 
{ 
	goal_sequence_villager_training,
	goal_sequence_trader_training,
	goal_sequence_idle_villager,
	goal_sequence_idle_trader,
	goal_sequence_idle_scout	
} 

function TrainingGoal_EnableLateEconomyGoals()
	for i, goalSequenceID in ipairs(training_goals_late_economy) do
		Training_EnableGoalSequenceByID(goalSequenceID, true)
	end
end

function TrainingGoal_DisableLateEconomyGoals()
	for i, goalSequenceID in ipairs(training_goals_late_economy) do
		Training_EnableGoalSequenceByID(goalSequenceID, false)
	end
end

function LateEconomyTrainingGoals_InitVillagerTraining_Xbox()
	
	-- Train a villager
	local selectTCGoal = Training_Goal("Entity",
		{ID="Select your Town Center to train Villagers.", Message= "$11202187", DataTemplate="GenericTrainingDataTemplate"},
		UserHasSelectedTownCenter)
	
	local openRadialGoal = Training_Goal("Entity",
		{ID= "Press RT to open the radial menu.", Message= "$1000968", DataTemplate="GenericTrainingDataTemplate"}, 
		UserHasOpenedContextualRadial)
	
	local buildVillGoal = Training_Goal("PBG",
		{ID= "Select this option to queue production of additional Villagers.", Message= "$11249020", DataTemplate="GenericTrainingDataTemplate"}, 
		TCHasStartedToTrainAVillager)
	
	local trainVillagerSequence = Training_GoalSequence(goal_sequence_villager_training,
		__t_challengeIdleTCRepeatMax, 0,
		UserHasIdleTownCenter_Xbox, 
		nil,--NoIdleVillagers, 
		nil,
		nil,
		true,
		{selectTCGoal, openRadialGoal, buildVillGoal})
	Training_AddGoalSequence(trainVillagerSequence)
end

function LateEconomyTrainingGoals_InitVillagerTraining()
	
	-- Train a villager
	local selectTCGoal = Training_Goal("Entity",
		{ID="Select your Town Center to train Villagers.", Message= "$11202187", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedTownCenter)
	
	local buildVillGoal = Training_Goal("PBG",
		{ID= "Click here to queue up additional Villagers.", Message= "$11202188", DataTemplate="LeftClickTrainingDataTemplate"}, 
		TCHasStartedToTrainAVillager)
	
	local trainVillagerSequence = Training_GoalSequence(goal_sequence_villager_training,
		__t_challengeIdleTCRepeatMax, 0,
		UserHasIdleTownCenter, 
		nil,--NoIdleVillagers, 
		nil,
		nil,
		true,
		{selectTCGoal, buildVillGoal})
	Training_AddGoalSequence(trainVillagerSequence)
end

function LateEconomyTrainingGoals_InitTraderTraining_Xbox()
	
	local selectMarketGoal = Training_Goal("Entity",
		{ID="Select your Market to train Traders.", Message= "$11202191", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedMarket)
	
	local openRadialGoal = Training_Goal("Entity",
		{ID= "Press RT to open the radial menu.", Message= "$1000968", DataTemplate="GenericTrainingDataTemplate"}, 
		UserHasOpenedContextualRadial)
	
	local buildTraderGoal = Training_Goal("PBG",
		{ID= "Select this option to queue up additional Traders.", Message= "$11249130", DataTemplate="LeftClickTrainingDataTemplate"}, 
		MarketHasStartedToTrainATrader)
	
	local trainTraderSequence = Training_GoalSequence(goal_sequence_trader_training,
		__t_challengeIdleMarketRepeatMax, 0,
		UserHasIdleMarket_Xbox, 
		UserHasNoMeansMarket, -- Ignore if player has no resources or pop space 
		nil,
		nil,
		true,
		{selectMarketGoal, openRadialGoal, buildTraderGoal})
	Training_AddGoalSequence(trainTraderSequence)
end

function LateEconomyTrainingGoals_InitTraderTraining()
	
	local selectMarketGoal = Training_Goal("Entity",
		{ID="Select your Market to train Traders.", Message= "$11202191", DataTemplate="LeftClickTrainingDataTemplate"},
		UserHasSelectedMarket)
	local buildTraderGoal = Training_Goal("PBG",
		{ID= "Click here to queue up additional Traders.", Message= "$11202192", DataTemplate="LeftClickTrainingDataTemplate"}, 
		MarketHasStartedToTrainATrader)
	local trainTraderSequence = Training_GoalSequence(goal_sequence_trader_training,
		__t_challengeIdleMarketRepeatMax, 0,
		UserHasIdleMarket, 
		UserHasNoMeansMarket, -- Ignore if player has no resources or pop space 
		nil,
		nil,
		true,
		{selectMarketGoal, buildTraderGoal})
