			arrivalTime = CalculateArrivalTime(false),
			laneName = "east", subLaneName = "mid", hasIcon = true, attackBuildings = true,
			units = {
				{ type = "scar_ram", 		numSquads = 2 },
				{ type = "scar_spearman",	numSquads = 12 },
			},
		},
		{
			arrivalTime = CalculateArrivalTime(false),
			laneName = "east", subLaneName = "left", hasIcon = false, attackBuildings = true,
			units = {
				{ type = "scar_ram", 		numSquads = 2 },
				{ type = "scar_spearman",	numSquads = 12 },
			},
		},
		{
			arrivalTime = CalculateArrivalTime(false),
			laneName = "east", subLaneName = "right", hasIcon = false, attackBuildings = true,
			units = {
				{ type = "scar_ram", 		numSquads = 2 },
				{ type = "scar_spearman",	numSquads = 12 },
			},
		},
	}
	
	for laneName, lane in pairs(lanes) do
		lane.distance = Util_GetDistance(lane.subLanes.mid.spawn, mkr_base_boundary) - Marker_GetProximityRadius(mkr_base_boundary)
	end
	
	for i, round in ipairs(rounds) do
		round.lane = lanes[round.laneName]
		round.subLane = round.lane.subLanes[round.subLaneName]
		round.cost = GetRoundCost(round)
		round.moveSpeed = GetSlowestUnitSpeed(round.units)
		round.sgroup = SGroup_CreateUniqueWithPrefix("sg_round_"..i)
		round.moveTime = round.lane.distance / (round.moveSpeed * 4) --4m per tile
		round.launchTime = round.arrivalTime - math.floor(round.moveTime)
		round.moveTimeString = Util_ConvertIntegerSecondsToStringTime(round.moveTime)
		round.arrivalTimeString = Util_ConvertIntegerSecondsToStringTime(round.arrivalTime)
		round.launchTimeString = Util_ConvertIntegerSecondsToStringTime(round.launchTime)
	end
	
	local metaRoundID = 0
	local metaRoundArrivalTime = 0
	metaRounds = {}
	for i, round in ipairs(rounds) do
		if metaRoundArrivalTime ~= round.arrivalTime then
			metaRoundArrivalTime = round.arrivalTime
			metaRoundID = metaRoundID + 1
			metaRounds[metaRoundID] = { 
				id = metaRoundID, 
				arrivalTime = round.arrivalTime, 
				arrivalTimeString = round.arrivalTimeString,
				cost = 0, 
				lanes = {}, 
				subLanes = {}, 
				rounds = {} 
			}
		end
		local metaRound = metaRounds[metaRoundID]
		metaRound.cost = metaRound.cost + round.cost
		if Table_Contains(metaRound.lanes, round.lane) == false then
			table.insert(metaRound.lanes, round.lane)
		end
		if Table_Contains(metaRound.subLanes, round.subLane) == false then
			table.insert(metaRound.subLanes, round.subLane)
		end
		round.metaRound = metaRound
		table.insert(metaRound.rounds, round)
	end
	
	for i, metaRound in ipairs(metaRounds) do
		local earliestLaunchTime = 9999
		for j, round in ipairs(metaRound.rounds) do
			if round.launchTime < earliestLaunchTime then
				earliestLaunchTime = round.launchTime
			end
		end
		for j, round in ipairs(metaRound.rounds) do
			round.spawnTime = earliestLaunchTime
			round.launchDelay = 12 + round.launchTime - round.spawnTime
		end
	end
	
	WRAP_TIME_END = metaRounds[#metaRounds].arrivalTime
	WRAP_TIME_START = metaRounds[#metaRounds-ROUNDS_REPEATED].arrivalTime
	
	metaRoundStrings = {}
	for i, metaRound in ipairs(metaRounds) do
		metaRoundStrings[i] = GetMetaRoundString(metaRound)
		metaRound.string = GetMetaRoundString(metaRound)
	end
end

function Ottoman_InitData2()
	
end

function CreateAssaultModule(spawn, targets, attackBuildings)
	local attackMoveStyle
	if attackBuildings then
		attackMoveStyle = attackMoveStyle_attackEverything
	else
		attackMoveStyle = attackMoveStyle_ignoreEverything
	end
	
	assault_index = assault_index or 0
	assault_index = assault_index + 1
	local params = {
		type = "RovingArmy",
		descriptor = "assualt_module_"..assault_index,
		player = player2,	
		spawnLocation = Clone(spawn),
		units = {},
		targets = Clone(targets),
		onDeathDissolve = true,
		scanRangeEnRoute = 30,
		attackMove = attackMoveStyle,
		onCompleteFunction = function(module)
			if module.hasResolved ~= true then
				module.hasResolved = true
				module.attackMove = attackMoveStyle_attackEverything
				RovingArmy_SetTarget(module, mkr_final_target_center)
			end
		end,
		onlyAtTargetForFinal = true,
	}
	return RovingArmy_Init(params)
end

function GetRoundCost(round)
	local cost = 0
	for i, unitRow in ipairs(round.units) do
		local unitType = GetUnitTypeFromUnitRow(unitRow)
		cost = cost + unitTypeCosts[unitType] * unitRow.numSquads
	end
	return cost
end

function CalculateArrivalTime(isNextRound)
	arrivalTime = arrivalTime or FIRST_ARRIVAL_TIME
	if isNextRound then
		increment = increment or INCREMENT_MAX
		arrivalTime = arrivalTime + increment
		increment = increment - INCREMENT_DELTA
		increment = math.max(increment, INCREMENT_MIN)
	end
	return arrivalTime
end

function GetMetaRoundString(metaRound)
	return tostring(metaRound.id).." - "..metaRound.arrivalTimeString.." - Cost:"..metaRound.cost.. "- Lanes:"..#metaRound.lanes
end

function GetSlowestUnitSpeed(unitTable)
	assert(scartype(unitTable) == ST_TABLE, "unitTable must be a table")
	
	local slowestSpeed = 9999
	local slowestUnit = nil
	for i, unitRow in ipairs(unitTable) do
		local unitType = GetUnitTypeFromUnitRow(unitRow)
		if unitTypeMoveSpeeds[unitType] < slowestSpeed then
			slowestSpeed = unitTypeMoveSpeeds[unitType]
			slowestUnit = unitType
		end
	end
	if slowestUnit then
		return slowestSpeed	
	else
		assert(false, "no valid unitRows in unitTable")
	end
end

function GetUnitTypeFromUnitRow(unitRow)
	local unitType = unitRow.type
	if unitType == nil then
		unitType = sbpToUnitType[unitRow.sbp]
	end
	return unitType
end
