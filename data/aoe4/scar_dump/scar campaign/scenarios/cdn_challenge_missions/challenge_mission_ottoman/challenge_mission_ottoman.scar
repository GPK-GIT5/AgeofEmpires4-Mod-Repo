import("cardinal.scar")
import("MissionOMatic/MissionOMatic.scar")		
import("MissionOMatic/MissionOMatic_utility.scar")
import("missionomatic/missionomatic_artofwar.scar")
import("challenge_mission_ottoman_objectives.scar")
import("challenge_mission_ottoman_data.scar")
import("training/coretraininggoals.scar")
import("challenge_mission_ottoman.events")
import("challenge_mission_ottoman_automated.scar")

function Mission_SetupPlayers()
	content_pack = CONTENT_PACK_ART_OF_WAR
	
	player1 = Missionomatic_InitPlayer(1, { name = "$11224443", currentAge = AGE_IMPERIAL})
	player2 = Missionomatic_InitPlayer(2, { name = "$11224283", currentAge = AGE_IMPERIAL})

	PlayerColour_Enable()
	Game_SetPlayerSlotColour(player1, 1)
    Game_SetPlayerUISlotColour(player1, 1)
	Game_SetPlayerSlotColour(player2, 2)
    Game_SetPlayerUISlotColour(player2, 2)
end

function Mission_SetupVariables()
	print("Mission_SetupVariables")
	Ottoman_InitData1()
end

function Mission_Preset()
	
	ottExclusionList = {}
	--these techs need to be granted only once the Vizier Bonus to unlock the unit is chosen
	table.insert(ottExclusionList, UPG.OTTOMAN.UPGRADE_UNIT_HORSEARCHER_3_OTT)
	table.insert(ottExclusionList, UPG.OTTOMAN.UPGRADE_UNIT_HORSEARCHER_4_OTT)
	
	for _, player in ipairs({ player1, player2 }) do
		TechTree_GiveUnitUpgrades(player, 4, TT_INCLUDE_BOTH, ottExclusionList)
		TechTree_GiveEconUpgrades(player, 4, TT_INCLUDE_BOTH, ottExclusionList)
		TechTree_GiveMilitaryUpgrades(player, 4, TT_INCLUDE_TIERED, ottExclusionList)		
	end
	
	Player_CompleteUpgrade(player1, UPG.OTTOMAN.UPGRADE_RANGED_JANISSARY_GUNS_OTT)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_VILLAGER_HEALTH)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_SCOUT_FORESTER)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_SCOUT_LOS_INCREASE)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_UNIT_RELIGIOUS_HERBAL_MEDICINE_4)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_UNIT_RELIGIOUS_PIETY_4)
	--university
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_MANATARMS_ELITE_ARMY_TACTICS)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_RANGED_INCENDIARY)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_TECH_UNIVERSITY_BIOLOGY)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_SIEGE_WORKS)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_MANATARMS_ELITE_ARMY_TACTICS)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_SIEGE_CHEMISTRY)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_TECH_UNIVERSITY_ARCHITECTURE_4)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_RANGED_ARCHER_SILKSTRING)
	--siege
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_SIEGE_ROLLER_TRIGGER)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_SIEGE_ADJUSTABLE_CROSSBAR)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_SIEGE_WEAPON_SPEED)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_SIEGE_MATHEMATICS)
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_RAM_SCALING)
	
	
	
	Player_SetEntityProductionAvailability(player1, EBP.OTTOMAN.BUILDING_TOWN_CENTER_OTT, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.OTTOMAN.BUILDING_DEFENSE_PALISADE_OTT, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.OTTOMAN.BUILDING_DEFENSE_PALISADE_GATE_OTT, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.OTTOMAN.BUILDING_DEFENSE_WALL_OTT, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.OTTOMAN.BUILDING_DEFENSE_WALL_GATE_OTT, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.OTTOMAN.BUILDING_DEFENSE_TOWER_OTT, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(player1, EBP.OTTOMAN.BUILDING_UNIT_NAVAL_OTT, ITEM_REMOVED)
	
	Player_SetUpgradeAvailability(player1, UPG.COMMON.UPGRADE_SIEGE_ENGINEERS, ITEM_REMOVED)
	
	Cmd_InstantUpgrade(eg_starting_outposts, UPG.COMMON.UPGRADE_OUTPOST_SPRINGALD)
	Cmd_InstantUpgrade(eg_starting_outposts, UPG.COMMON.UPGRADE_OUTPOST_STONE)
	Player_SetConstructionMenuAvailability(player1, "siege_engineer", ITEM_REMOVED)
	
	local unit_types = {
		EBP.ABBASID.UNIT_ARCHER_4_ABB,
		EBP.ABBASID.UNIT_CROSSBOWMAN_4_ABB,
		EBP.ABBASID.UNIT_HANDCANNON_4_ABB,
		EBP.ABBASID.UNIT_MANATARMS_4_ABB,
		EBP.ABBASID.UNIT_SPEARMAN_4_ABB,
		EBP.ABBASID.UNIT_RAM_3_ABB,
		EBP.ABBASID.UNIT_MANGONEL_3_ABB,
		EBP.ABBASID.UNIT_TREBUCHET_4_CW_ABB,
		EBP.ABBASID.UNIT_BOMBARD_4_ABB,
		EBP.ABBASID.UNIT_CULVERIN_4_ABB,
	}
	for i, ebp in ipairs(unit_types) do
		local modifier = Modifier_Create(MAT_EntityType, "speed_maximum_modifier", MUT_Set, true, MOVE_SPEED_IN_METERS, ebp)	
		Modifier_ApplyToPlayer(modifier, player2, 0)
	end
	
	eg_walls = Player_GetAllEntitiesFromType(player2, "wall")
	eg_towers = Player_GetAllEntitiesFromType(player2, "tower") 
	EGroup_SetInvulnerable(eg_walls, true)
	EGroup_SetInvulnerable(eg_towers, true)
	EGroup_SetTargetingType(eg_walls, Targeting_None)
	EGroup_SetTargetingType(eg_towers, Targeting_None)
	

	EnableProductionForEGroup(eg_starting_military_schools, false)
	
	Ottoman_InitObjectives()
	Ottoman_InitData2()
	AutoTest_OnInit()
end

function Mission_PreStart()
	playerResources = Player_GetResources(player1)
	for i, resource in ipairs({ RT_Wood, RT_Food, RT_Gold, RT_Stone }) do
		Player_SetResource(player1, resource, 0)
	end
	
	Player_SetStateModelFloat(player1, "imperial_council_exp_ott", 0)
	Player_SetStateModelFloat(player1, "imperial_council_level_ott", 60)
	Player_SetStateModelInt(player1, "total_viziers_ott", 1)	
	Player_SetResource(player1, 1, 1) 
end
	

function Mission_Start()
	mission_has_started = true
	Objective_Start(SOBJ_AttackNotice)
	Util_StartIntel(EVENTS.PreStart)
	Camera_FocusOnPosition(Marker_GetPosition(mkr_camera_start))
	Player_SetStateModelInt(player1, "military_school_count", 1)

	Rule_AddInterval(CheckForUnpause)
	Rule_AddInterval(CheckForAkinji)
	
	Intro_Unreveal_Map()
	FOW_PlayerRevealAll(player2)
end

function CheckForAkinji()
	if(Player_HasUpgrade(player1, UPG.OTTOMAN.UPGRADE_TIMARIOTS_OTT) == true) then
		--complete upgrades once the vizier point has been unlocked
		Player_CompleteUpgrade(player1, UPG.OTTOMAN.UPGRADE_UNIT_HORSEARCHER_3_OTT)
		Player_CompleteUpgrade(player1, UPG.OTTOMAN.UPGRADE_UNIT_HORSEARCHER_4_OTT)
		Rule_RemoveMe()
	end
end

function CheckForUnpause()
	if Player_GetResource(player1, 1) == 0 then
		Event_Skip()
		Rule_RemoveMe()
		Mission_Unpause()
		if objective_started == true then
			Objective_Complete(OBJ_VizierBonus)	
		else
			Objective_Start(OBJ_Defend, false, false)
			Objective_Start(OBJ_Survive)
			Objective_StartTimer(OBJ_Survive, COUNT_UP, 0)	
		end
		mission_unpaused = true
	end
end

function Mission_Unpause()
	SpawnVillagersAndAssign(mkr_villager_wood_group, AssignVillagersToWood)
	SpawnVillagersAndAssign(mkr_villager_stone_group, AssignVillagersToStone)
	SpawnVillagersAndAssign(mkr_villager_food_group, AssignVillagersToBerries)
	SpawnVillagersAndAssign(mkr_villager_gold_group, AssignVillagersToGold)
	
	CreateUnits(player1, {type="scar_mehter"}, mkr_spawn_mehter)
	CreateUnits(player1, {type="scar_spearman", numSquads = 3}, mkr_spawn_spearmen)
	
	EnableProductionForEGroup(eg_starting_military_schools, true)
	
	Player_SetResource(player1, RT_Food, playerResources.food)
	Player_SetResource(player1, RT_Wood, playerResources.wood)
	Player_SetResource(player1, RT_Gold, playerResources.gold)
	Player_SetResource(player1, RT_Stone, playerResources.stone)
	
	Rule_AddInterval(PerSecond, 1)
	Rule_Add(PerTic)
end
		
function GetRecipe()
	local recipe = {		
		victory_message = "$39257",
		introNIS = EVENTS.PreIntro,
		locations = {},  
		modules = {},
		onWin = {},
		onLose = {},
	}
	return recipe
end

function PerTic()
	if Entity_GetStateModelBool(EGroup_GetEntityAt(eg_player_tc, 1), "landmark_active") == false then
		Game_StoreTableData("trial", { kpi = mission_seconds[1] })
		local total_pop = Player_GetTotalPopulation(player1)
		print("Defeated at "..mission_seconds_string.." - PlayerPop:"..math.floor(total_pop))	
		if mission_seconds[1] >= SOBJ_BronzeMedal.KPI then
			if missionCompleteEvent ~= nil then
				Util_StartIntel(missionCompleteEvent)
			end
			Mission_Complete()
		else
			Mission_Fail()
		end
		Rule_RemoveMe()
	end
end

function PerSecond(context, data)
	mission_seconds[1] = mission_seconds[1] + 1
	if mission_seconds_wrapped == WRAP_TIME_END then
		mission_seconds_wrapped = WRAP_TIME_START
	end
	mission_seconds_wrapped = mission_seconds_wrapped + 1
	mission_seconds_string = Util_ConvertIntegerSecondsToStringTime(mission_seconds[1])		
	
	--print a situation report every metaRound
	for index, metaRound in pairs(metaRounds) do
		if metaRound.arrivalTime == mission_seconds_wrapped then
			metaRoundIndex = metaRoundIndex + 1 
			local player_pop_string = math.floor(Player_GetTotalPopulation(player1))
			print(mission_seconds_string.."  -  Round:"..metaRound.id.."  RoundCost: "..metaRound.cost..GetPlayerReport())
		end
	end
	
	for index, round in ipairs(rounds) do
		if round.spawnTime == mission_seconds_wrapped then
			SpawnAttack(round)
		end
	end	
	
	if mission_seconds[1] == CHALLENGE_TIMER_SECONDS then  
		Game_SendCustomChallengeEvent(player1,CE_OTTOMANSARTTIMER,1)
	end
	
	if OBJ_CurrentMedal and OBJ_CurrentMedal.KPI == mission_seconds[1] then
		missionCompleteEvent = OBJ_CurrentMedal.missionCompleteEvent
		UI_CreateEventCue(OBJ_CurrentMedal.eventQueueString, Loc_Empty(), "", "", "sfx_ui_event_queue_high_priority_play")
		Objective_Complete(OBJ_CurrentMedal, true, true)
		OBJ_CurrentMedal = OBJ_CurrentMedal.nextObjective
	end
end

function SpawnAttack(round)
	SGroup_Clear(round.sgroup)
	CreateUnits(player2, round.units, round.subLane.spawn, round.sgroup)
	if round.hasIcon then	
		UI_CreateMinimapBlip(round.sgroup, 14, "general")
		local UI_element = Objective_AddUIElements(SOBJ_AttackNotice, round.sgroup, true, "test", false)
		Rule_Add(MonitorAttack, { UI_element = UI_element, sgroup = round.sgroup })
	end
	if round.metaRound.hasPlayedHorn ~= true then
		round.metaRound.hasPlayedHorn = true
		Sound_Play2D("sfx_campaign_scripted_attack_horn_under_attack_high")
	end
	SGroup_AttackMove(round.sgroup, round.subLane.staging)
	Rule_AddOneShot(LaunchAttack, round.launchDelay, {round = round})
	Rule_AddOneShot(LaunchAttackUI, 14, {round = round})
end

function LaunchAttack(context, data)
	local round = data.round
	round.rovingArmy = CreateAssaultModule(round.subLane.spawn, round.subLane.targets, round.attackBuildings)
	RovingArmy_AddSGroup(round.rovingArmy, round.sgroup)
end

function LaunchAttackUI(context, data)
	local round = data.round
	if first_attack_has_triggered ~= true then
		first_attack_has_triggered = true
		Util_StartIntel(EVENTS.FirstAttackers)
	end
end

function MonitorAttack(context, data)
	local UI_element = data.UI_element
	local sgroup = data.sgroup
	if Prox_AreSquadsNearMarker(sgroup, mkr_remove_icon, ANY) then
		Objective_RemoveUIElements(SOBJ_AttackNotice, UI_element)
		Rule_RemoveMe()
	end
end

function GetPlayerReport()
	Player_GetAll(player1, sg_allsquads)
	local sg_villagers = SGroup_CreateUnique("")
	local sg_traders = SGroup_CreateUnique("")
	SGroup_Filter(sg_allsquads, "scar_villager", FILTER_REMOVE, sg_villagers)
	SGroup_Filter(sg_allsquads, "scar_trade_cart", FILTER_REMOVE, sg_traders)
	local villagerCount = SGroup_CountSpawned(sg_villagers)
	local traderCount = SGroup_CountSpawned(sg_traders)
	local militaryCount = SGroup_CountSpawned(sg_allsquads)
	local militaryCost = 0

	for i = 1, SGroup_Count(sg_allsquads) do
		local squad = SGroup_GetSquadAt(sg_allsquads, i)
		local cost = Player_GetSquadBPCost(player1, Squad_GetBlueprint(squad))
		militaryCost = militaryCost + math.floor(cost.food + cost.gold + cost.stone + cost.wood)
	end
	SGroup_Destroy(sg_villagers)
	SGroup_Destroy(sg_traders)
	return "  -  Villagers:"..villagerCount.."  Traders:"..traderCount.."  Military:"..militaryCount.."  MilitaryCost:"..militaryCost
end

function SpawnVillagersAndAssign(marker_table, gatherFunction)
	local sgroup = SGroup_CreateUnique("")
	for i, marker in ipairs(marker_table) do
		CreateUnits(player1, {type="scar_villager"},marker,sgroup)
	end
	gatherFunction(sgroup)
	SGroup_Destroy(sgroup)
end