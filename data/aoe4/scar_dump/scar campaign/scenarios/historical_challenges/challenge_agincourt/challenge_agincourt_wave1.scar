
import("MissionOMatic/MissionOMatic.scar")		-- this imports the Cardinal scripts as well
import("missionomatic/missionomatic_artofwar.scar")
import("training/coretraininggoals.scar")
import("challenge_agincourt.events")
import("cardinal.scar")



function HC_Agincourt_SpawnFrenchWave1()
	
	-- Spawn the units into their SGroups
	HC_Agincourt_Wave1_SpawnUnits()
	
	-- Apply player visibility factors
	FOW_PlayerRevealSGroup(localPlayer, sg_enemyRow1_horsemen1,20,-1)
	UI_CreateMinimapBlip(sg_enemyRow1_horsemen1, 10, "threat_group")
	
	FOW_PlayerRevealSGroup(localPlayer, sg_enemyRow1_knights3,20,-1)
	UI_CreateMinimapBlip(sg_enemyRow1_knights3, 10, "threat_group")
	
	FOW_PlayerRevealSGroup(localPlayer, sg_enemyRow1_horsemen5,20,-1)
	UI_CreateMinimapBlip(sg_enemyRow1_horsemen5, 10, "threat_group")
	
	FOW_PlayerRevealSGroup(localPlayer, sg_enemyRow1_leader,20,-1)
	UI_CreateMinimapBlip(sg_enemyRow1_leader, 10, "threat_group")
	Modify_EntityMaxHealth(sg_enemyRow1_leader, 2.5, MUT_Multiplication)
	
	-- Group units
	sg_wave1_AllUnits = SGroup_CreateIfNotFound("sg_wave1_AllUnits")
	SGroup_AddGroups(sg_wave1_AllUnits, {sg_enemyRow1_horsemen1, sg_enemyRow1_knights2, sg_enemyRow1_knights3, sg_enemyRow1_knights4, sg_enemyRow1_horsemen5})
	
	sg_wave1_AllWaitingUnits = SGroup_CreateIfNotFound("sg_wave1_AllWaitingUnits")
	SGroup_AddGroups(sg_wave1_AllWaitingUnits, {sg_enemyRow1_horsemen1, sg_enemyRow1_knights2, sg_enemyRow1_knights3, sg_enemyRow1_knights4, sg_enemyRow1_horsemen5})
	
	Cmd_FormationMove(sg_enemyRow1_horsemen1, mkr_frenchArmy1_1, true, false, mkr_playerBase)
	Cmd_FormationMove(sg_enemyRow1_knights2, mkr_frenchArmy1_2, true, false, mkr_playerBase)
	Cmd_FormationMove(sg_enemyRow1_knights3, mkr_frenchArmy1_3, true, false, mkr_playerBase)
	Cmd_FormationMove(sg_enemyRow1_knights4, mkr_frenchArmy1_4, true, false, mkr_playerBase)
	Cmd_FormationMove(sg_enemyRow1_horsemen5, mkr_frenchArmy1_5, true, false, mkr_playerBase)
	Cmd_FormationMove(sg_enemyRow1_leader, mkr_frenchArmyL1, true, false, mkr_playerBase)
	
	local unit_types = {
		SBP.FRENCH.UNIT_HORSEMAN_2_FRE,
		SBP.FRENCH.UNIT_KNIGHT_2_FRE,
	}
	
	for i, sbp in ipairs(unit_types) do
		local mod_speed = Modifier_Create(MAT_EntityType, "speed_maximum_modifier", MUT_Multiplication, true, .8, sbp)	
		Modifier_ApplyToPlayer(mod_speed, enemyPlayer, 0)
		Modifier_ApplyToPlayer(mod_speed, enemyPlayer3, 0)
		
		local mod_damageTaken = Modifier_Create(MAT_EntityType, "received_damage_modifier", MUT_Multiplication, true, 2.5, sbp)
		Modifier_ApplyToPlayer(mod_damageTaken, enemyPlayer3, 0)
	end
	
	Sound_Play2D("sfx_campaign_scripted_medium_group_engage")
	Sound_Play2D(MUS_STINGER_ALERT)
	
	HC_Agincourt_Wave1_PreStart()
	Rule_AddOneShot(HC_Agincourt_Wave1_CheckCenter, .5)
end

function HC_Agincourt_Wave1_SpawnUnits()
	
	sg_enemyRow1_horsemen1 = SGroup_CreateIfNotFound("sg_enemyRow1_horsemen1")
	sg_enemyRow1_knights2 = SGroup_CreateIfNotFound("sg_enemyRow1_knights2")
	sg_enemyRow1_knights3 = SGroup_CreateIfNotFound("sg_enemyRow1_knights3")
	sg_enemyRow1_knights4 = SGroup_CreateIfNotFound("sg_enemyRow1_knights4")
	sg_enemyRow1_horsemen5 = SGroup_CreateIfNotFound("sg_enemyRow1_horsemen5")
	sg_enemyRow1_leader = SGroup_CreateIfNotFound("sg_enemyRow1_leader")
	
	sg_enemyRow1_horsemen1Center = SGroup_CreateIfNotFound("sg_enemyRow1_horsemen1Center")
	sg_enemyRow1_knights2Center = SGroup_CreateIfNotFound("sg_enemyRow1_knights2Center")
	sg_enemyRow1_knights3Center = SGroup_CreateIfNotFound("sg_enemyRow1_knights3Center")
	sg_enemyRow1_knights4Center = SGroup_CreateIfNotFound("sg_enemyRow1_knights4Center")
	sg_enemyRow1_horsemen5Center = SGroup_CreateIfNotFound("sg_enemyRow1_horsemen5Center")
	
	local sbp_horsemen_fre = SBP.FRENCH.UNIT_HORSEMAN_2_FRE
	local sbp_knight_fre = SBP.FRENCH.UNIT_KNIGHT_2_FRE
	local sbp_leader1 = SBP.FRENCH.UNIT_BOUCICAUT_CMP_FRE
	
	local facingPos = Marker_GetPosition(mkr_playerBase)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemyRow1_horsemen1, {sbp = sbp_horsemen_fre, numSquads = 16, facing = facingPos }, mkr_frenchArmyS1_1)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemyRow1_horsemen1, {sbp = sbp_knight_fre, numSquads = 2, facing = facingPos }, mkr_frenchArmyS1_1)
	
	UnitEntry_DeploySquads(enemyPlayer, sg_enemyRow1_knights2, {sbp = sbp_horsemen_fre, numSquads = 6, facing = facingPos }, mkr_frenchArmyS1_2)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemyRow1_knights2, {sbp = sbp_knight_fre, numSquads = 14, facing = facingPos }, mkr_frenchArmyS1_2)
	
	UnitEntry_DeploySquads(enemyPlayer, sg_enemyRow1_knights3, {sbp = sbp_knight_fre, numSquads = 24, facing = facingPos }, mkr_frenchArmyS1_3)
	
	UnitEntry_DeploySquads(enemyPlayer, sg_enemyRow1_knights4, {sbp = sbp_horsemen_fre, numSquads = 6, facing = facingPos }, mkr_frenchArmyS1_4)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemyRow1_knights4, {sbp = sbp_knight_fre, numSquads = 14, facing = facingPos }, mkr_frenchArmyS1_4)
	
	UnitEntry_DeploySquads(enemyPlayer, sg_enemyRow1_horsemen5, {sbp = sbp_horsemen_fre, numSquads = 16, facing = facingPos }, mkr_frenchArmyS1_5)
	UnitEntry_DeploySquads(enemyPlayer, sg_enemyRow1_horsemen5, {sbp = sbp_knight_fre, numSquads = 2, facing = facingPos }, mkr_frenchArmyS1_5)
	
	local options = {
		destination = mkr_frenchArmyL1,
		dynamicSpawnType = DST_FURTHEST_HIDDEN,
		holdPosition = true,
	}
	UnitEntry_DeploySquads(enemyPlayer, sg_enemyRow1_leader, {sbp = sbp_leader1, numSquads = 1, facing = facingPos }, mkr_frenchArmyL1S, nil, nil, options)
	
	--set up the number of units to split off in each mini-wave in a table
	wave1SplitUnitCounts = {}
	wave1SplitUnitCounts[1] = {4,4,6,4,4}
	wave1SplitUnitCounts[2] = {4,4,6,4,4}
	wave1SplitUnitCounts[3] = {4,5,6,5,4}
	
end

function HC_Agincourt_Wave1_PreStart()
	
	wave1PreStartTime = World_GetGameTime()
	
	--track each group's progress down the battlefield
	w1_lane1_progress = 0
	w1_lane2_progress = 0
	w1_lane3_progress = 0
	w1_lane4_progress = 0
	w1_lane5_progress = 0
	
	wave1_Vanguard1Attacking = false
	wave1_Vanguard2Attacking = false
	wave1_Vanguard3Attacking = false
	
	reformingLanes = false
	
	w1_leader_target = 0
	w1_leader_target_changed = true
	
	gatheringAroundLeader = false
	gatherAroundTimeLimit = 15
	wave1SearchRadius = 15
	gatheringAroundLeaderCount = 0
	rallyTimeMax = 5
	wave1RallyUnitMax = 12
	wave1RallyUnitMaxConqFailed = 6
	
	w1_leader_rallyPosition = Util_GetPosition(mkr_frenchArmyL1)
	
	
	Rule_AddInterval(HC_Agincourt_Wave1_UpdateLeader, 1)
	
	w1_lastStepI = 0
	w1_set_progress = 0
	w1_farthestStart = .8 --this is the farthest the wave will advance before attacking
	Rule_AddInterval(HC_Agincourt_Wave1_PreUpdate, 1)
	
	w1_inCombat = false
	w1_finishedAdvance = false -- true when it reaches the maximum limit of the battlefield
end

function HC_Agincourt_Wave1_PreUpdate()
	
	if(w1_inCombat == true) then
		return
	end
	
	wave1CurrentTime = World_GetGameTime() - wave1PreStartTime
	
	if(wave1CurrentTime >= 60 * 8) then
		HC_Agincourt_Wave1_Start()
		Objective_Complete(SOBJ_AttackWave1, false, false)
		Rule_RemoveMe()
		return
	end
	
	--check if wave has been attacked
	if(SGroup_IsUnderAttackByPlayer(sg_wave1_AllWaitingUnits, localPlayer, 1)) then
		HC_Agincourt_Wave1_Start()
		return
	end
	--also check if waves 2 or 3 have been attacked to prevent players from sneaking around the first waves without consequences
	if(SGroup_IsUnderAttackByPlayer(sg_wave2_AllWaitingUnits, localPlayer, 1) or SGroup_IsUnderAttackByPlayer(sg_wave3_AllUnits, localPlayer, 1)) then
		HC_Agincourt_Wave1_Start()
		return
	end
	
	local waveMoved = false
	local waveNextStep = w1_set_progress
	local stepDist = .0225
	local nextStepI = 0
	--start at .3 to match wave 1's starting position
	local stepStartDist = .3 - stepDist
	local stepCount = (w1_farthestStart - stepStartDist) / stepDist
	for i = 1, stepCount do
		--step forward every 15 seconds
		if(wave1CurrentTime > i * 15 and w1_set_progress < (i * stepDist) + stepStartDist) then
			waveNextStep = (i * stepDist) + stepStartDist
			waveMoved = true
			nextStepI = i
		end
	end
	
	if(waveMoved == true and nextStepI > w1_lastStepI and w1_set_progress < w1_farthestStart) then
		
		--reduce target progress to 90% of total path
		w1_set_progress = waveNextStep * .9 
		
		HC_Agincourt_Wave1_SendBackToLane(sg_enemyRow1_horsemen1, 1, w1_set_progress, true, false)
		HC_Agincourt_Wave1_SendBackToLane(sg_enemyRow1_knights2, 2, w1_set_progress, true, false)
		HC_Agincourt_Wave1_SendBackToLane(sg_enemyRow1_knights3, 3, w1_set_progress, true, false)
		HC_Agincourt_Wave1_SendBackToLane(sg_enemyRow1_knights4, 4, w1_set_progress, true, false)
		HC_Agincourt_Wave1_SendBackToLane(sg_enemyRow1_horsemen5, 5, w1_set_progress, true, false)
		HC_Agincourt_Wave1_SendBackToLane(sg_enemyRow1_leader, 3, w1_set_progress + .01, true, false)
		
		Rule_AddOneShot(HC_Agincourt_Wave1_CheckCenter, .5)
		
		--set last step to prevent the above functions from being called unnecessarily
		w1_lastStepI = nextStepI
	end
	
	--send smaller groups to attack after 2 minutes if not already in battle
	if(wave1_Vanguard1Attacking == false and missionTime >= 2 * 60) then
		
		Sound_Play2D("sfx_campaign_scripted_attack_horn_under_attack_high")
		Sound_Play2D("sfx_campaign_scripted_medium_group_engage")
		Sound_Play2D(MUS_STINGER_ALERT)
		
		--create new group with part of the existing group
		sg_wave1Vanguard1Attack1 = SGroup_CreateIfNotFound("sg_wave1Vanguard1Attack1")
		for i = 1, wave1SplitUnitCounts[1][1] do
			if(SGroup_CountSpawned(sg_enemyRow1_horsemen1) > 0) then
				SGroup_Add(sg_wave1Vanguard1Attack1, SGroup_GetSquadAt(sg_enemyRow1_horsemen1, 1))
				SGroup_Remove(sg_wave1_AllWaitingUnits, SGroup_GetSquadAt(sg_enemyRow1_horsemen1, 1))
				SGroup_Remove(sg_enemyRow1_horsemen1, SGroup_GetSquadAt(sg_enemyRow1_horsemen1, 1))
			end
		end
		Cmd_FormationAttackMove(sg_wave1Vanguard1Attack1, mkr_ArmyAttack1_3, false, false)
		Cmd_FormationAttackMove(sg_wave1Vanguard1Attack1, mkr_playerBase, true, false)
		--
		sg_wave1Vanguard1Attack2 = SGroup_CreateIfNotFound("sg_wave1Vanguard1Attack2")
		for i = 1, wave1SplitUnitCounts[1][2] do
			if(SGroup_CountSpawned(sg_enemyRow1_knights2) > 0) then
				SGroup_Add(sg_wave1Vanguard1Attack2, SGroup_GetSquadAt(sg_enemyRow1_knights2, 1))
				SGroup_Remove(sg_wave1_AllWaitingUnits, SGroup_GetSquadAt(sg_enemyRow1_knights2, 1))
				SGroup_Remove(sg_enemyRow1_knights2, SGroup_GetSquadAt(sg_enemyRow1_knights2, 1))
			end
		end
		Cmd_FormationAttackMove(sg_wave1Vanguard1Attack2, mkr_ArmyAttack2_3, false, false)
		Cmd_FormationAttackMove(sg_wave1Vanguard1Attack2, mkr_playerBase, true, false)
		--
		sg_wave1Vanguard1Attack3 = SGroup_CreateIfNotFound("sg_wave1Vanguard1Attack3")
		for i = 1, wave1SplitUnitCounts[1][3] do
			if(SGroup_CountSpawned(sg_enemyRow1_knights3) > 0) then
				SGroup_Add(sg_wave1Vanguard1Attack3, SGroup_GetSquadAt(sg_enemyRow1_knights3, 1))
				SGroup_Remove(sg_wave1_AllWaitingUnits, SGroup_GetSquadAt(sg_enemyRow1_knights3, 1))
				SGroup_Remove(sg_enemyRow1_knights3, SGroup_GetSquadAt(sg_enemyRow1_knights3, 1))
			end
		end
		Cmd_FormationAttackMove(sg_wave1Vanguard1Attack3, mkr_ArmyAttack3_3, false, false)
		Cmd_FormationAttackMove(sg_wave1Vanguard1Attack3, mkr_playerBase, true, false)
		--
		sg_wave1Vanguard1Attack4 = SGroup_CreateIfNotFound("sg_wave1Vanguard1Attack4")
		for i = 1, wave1SplitUnitCounts[1][4] do
			if(SGroup_CountSpawned(sg_enemyRow1_knights4) > 0) then
				SGroup_Add(sg_wave1Vanguard1Attack4, SGroup_GetSquadAt(sg_enemyRow1_knights4, 1))
				SGroup_Remove(sg_wave1_AllWaitingUnits, SGroup_GetSquadAt(sg_enemyRow1_knights4, 1))
				SGroup_Remove(sg_enemyRow1_knights4, SGroup_GetSquadAt(sg_enemyRow1_knights4, 1))
			end
		end
		Cmd_FormationAttackMove(sg_wave1Vanguard1Attack4, mkr_ArmyAttack4_3, false, false)
		Cmd_FormationAttackMove(sg_wave1Vanguard1Attack4, mkr_playerBase, true, false)
		--
		sg_wave1Vanguard1Attack5 = SGroup_CreateIfNotFound("sg_wave1Vanguard1Attack5")
		for i = 1, wave1SplitUnitCounts[1][5] do
			if(SGroup_CountSpawned(sg_enemyRow1_horsemen5) > 0) then
				SGroup_Add(sg_wave1Vanguard1Attack5, SGroup_GetSquadAt(sg_enemyRow1_horsemen5, 1))
				SGroup_Remove(sg_wave1_AllWaitingUnits, SGroup_GetSquadAt(sg_enemyRow1_horsemen5, 1))
				SGroup_Remove(sg_enemyRow1_horsemen5, SGroup_GetSquadAt(sg_enemyRow1_horsemen5, 1))
			end
		end
		Cmd_FormationAttackMove(sg_wave1Vanguard1Attack5, mkr_ArmyAttack5_3, false, false)
		Cmd_FormationAttackMove(sg_wave1Vanguard1Attack5, mkr_playerBase, true, false)
		--
		
		wave1_Vanguard1Attacking = true
	end
	--send smaller groups to attack after 5 minutes if not already in battle
	if(wave1_Vanguard2Attacking == false and missionTime >= 5 * 60) then
		
		Sound_Play2D("sfx_campaign_scripted_attack_horn_under_attack_high")
		Sound_Play2D("sfx_campaign_scripted_medium_group_engage")
		Sound_Play2D(MUS_STINGER_ALERT)
		
		--create new group with part of the existing group
		sg_wave1Vanguard2Attack1 = SGroup_CreateIfNotFound("sg_wave1Vanguard2Attack1")
		for i = 1, wave1SplitUnitCounts[2][1] do
			if(SGroup_CountSpawned(sg_enemyRow1_horsemen1) > 0) then
				SGroup_Add(sg_wave1Vanguard2Attack1, SGroup_GetSquadAt(sg_enemyRow1_horsemen1, 1))
				SGroup_Remove(sg_wave1_AllWaitingUnits, SGroup_GetSquadAt(sg_enemyRow1_horsemen1, 1))
				SGroup_Remove(sg_enemyRow1_horsemen1, SGroup_GetSquadAt(sg_enemyRow1_horsemen1, 1))
			end
		end
		Cmd_FormationAttackMove(sg_wave1Vanguard2Attack1, mkr_ArmyAttack1_3, false, false)
		Cmd_FormationAttackMove(sg_wave1Vanguard2Attack1, mkr_playerBase, true, false)
		--
		sg_wave1Vanguard2Attack2 = SGroup_CreateIfNotFound("sg_wave1Vanguard2Attack2")
		for i = 1, wave1SplitUnitCounts[2][2] do
			if(SGroup_CountSpawned(sg_enemyRow1_knights2) > 0) then
				SGroup_Add(sg_wave1Vanguard2Attack2, SGroup_GetSquadAt(sg_enemyRow1_knights2, 1))
				SGroup_Remove(sg_wave1_AllWaitingUnits, SGroup_GetSquadAt(sg_enemyRow1_knights2, 1))
				SGroup_Remove(sg_enemyRow1_knights2, SGroup_GetSquadAt(sg_enemyRow1_knights2, 1))
			end
		end
		Cmd_FormationAttackMove(sg_wave1Vanguard2Attack2, mkr_ArmyAttack2_3, false, false)
		Cmd_FormationAttackMove(sg_wave1Vanguard2Attack2, mkr_playerBase, true, false)
		--
		sg_wave1Vanguard2Attack3 = SGroup_CreateIfNotFound("sg_wave1Vanguard2Attack3")
		for i = 1, wave1SplitUnitCounts[2][3] do
			if(SGroup_CountSpawned(sg_enemyRow1_knights3) > 0) then
				SGroup_Add(sg_wave1Vanguard2Attack3, SGroup_GetSquadAt(sg_enemyRow1_knights3, 1))
				SGroup_Remove(sg_wave1_AllWaitingUnits, SGroup_GetSquadAt(sg_enemyRow1_knights3, 1))
				SGroup_Remove(sg_enemyRow1_knights3, SGroup_GetSquadAt(sg_enemyRow1_knights3, 1))
			end
		end
		Cmd_FormationAttackMove(sg_wave1Vanguard2Attack3, mkr_ArmyAttack3_3, false, false)
		Cmd_FormationAttackMove(sg_wave1Vanguard2Attack3, mkr_playerBase, true, false)
		--
		sg_wave1Vanguard2Attack4 = SGroup_CreateIfNotFound("sg_wave1Vanguard2Attack4")
		for i = 1, wave1SplitUnitCounts[2][4] do
			if(SGroup_CountSpawned(sg_enemyRow1_knights4) > 0) then
				SGroup_Add(sg_wave1Vanguard2Attack4, SGroup_GetSquadAt(sg_enemyRow1_knights4, 1))
				SGroup_Remove(sg_wave1_AllWaitingUnits, SGroup_GetSquadAt(sg_enemyRow1_knights4, 1))
				SGroup_Remove(sg_enemyRow1_knights4, SGroup_GetSquadAt(sg_enemyRow1_knights4, 1))
			end
		end
		Cmd_FormationAttackMove(sg_wave1Vanguard2Attack4, mkr_ArmyAttack4_3, false, false)
		Cmd_FormationAttackMove(sg_wave1Vanguard2Attack4, mkr_playerBase, true, false)
		--
		sg_wave1Vanguard2Attack5 = SGroup_CreateIfNotFound("sg_wave1Vanguard2Attack5")
		for i = 1, wave1SplitUnitCounts[2][5] do
			if(SGroup_CountSpawned(sg_enemyRow1_horsemen5) > 0) then
				SGroup_Add(sg_wave1Vanguard2Attack5, SGroup_GetSquadAt(sg_enemyRow1_horsemen5, 1))
				SGroup_Remove(sg_wave1_AllWaitingUnits, SGroup_GetSquadAt(sg_enemyRow1_horsemen5, 1))
				SGroup_Remove(sg_enemyRow1_horsemen5, SGroup_GetSquadAt(sg_enemyRow1_horsemen5, 1))
			end
		end
		Cmd_FormationAttackMove(sg_wave1Vanguard2Attack5, mkr_ArmyAttack5_3, false, false)
		Cmd_FormationAttackMove(sg_wave1Vanguard2Attack5, mkr_playerBase, true, false)
		--
		
		wave1_Vanguard2Attacking = true
	end
	--send smaller groups to attack after 6 minutes 30 seconds if not already in battle
	if(wave1_Vanguard3Attacking == false and missionTime >= (6 * 60) + 30) then
		
		Sound_Play2D("sfx_campaign_scripted_attack_horn_under_attack_high")
		Sound_Play2D("sfx_campaign_scripted_medium_group_engage")
		Sound_Play2D(MUS_STINGER_ALERT)
		
		--create new group with part of the existing group
		sg_wave1Vanguard3Attack1 = SGroup_CreateIfNotFound("sg_wave1Vanguard3Attack1")
		for i = 1, wave1SplitUnitCounts[3][1] do
			if(SGroup_CountSpawned(sg_enemyRow1_horsemen1) > 0) then
				SGroup_Add(sg_wave1Vanguard3Attack1, SGroup_GetSquadAt(sg_enemyRow1_horsemen1, 1))
				SGroup_Remove(sg_wave1_AllWaitingUnits, SGroup_GetSquadAt(sg_enemyRow1_horsemen1, 1))
				SGroup_Remove(sg_enemyRow1_horsemen1, SGroup_GetSquadAt(sg_enemyRow1_horsemen1, 1))
			end
		end
		Cmd_FormationAttackMove(sg_wave1Vanguard3Attack1, mkr_ArmyAttack1_3, false, false)
		Cmd_FormationAttackMove(sg_wave1Vanguard3Attack1, mkr_playerBase, true, false)
		--
		sg_wave1Vanguard3Attack2 = SGroup_CreateIfNotFound("sg_wave1Vanguard3Attack2")
		for i = 1, wave1SplitUnitCounts[3][2] do
			if(SGroup_CountSpawned(sg_enemyRow1_knights2) > 0) then
				SGroup_Add(sg_wave1Vanguard3Attack2, SGroup_GetSquadAt(sg_enemyRow1_knights2, 1))
				SGroup_Remove(sg_wave1_AllWaitingUnits, SGroup_GetSquadAt(sg_enemyRow1_knights2, 1))
				SGroup_Remove(sg_enemyRow1_knights2, SGroup_GetSquadAt(sg_enemyRow1_knights2, 1))
			end
		end
		Cmd_FormationAttackMove(sg_wave1Vanguard3Attack2, mkr_ArmyAttack2_3, false, false)
		Cmd_FormationAttackMove(sg_wave1Vanguard3Attack2, mkr_playerBase, true, false)
		--
		sg_wave1Vanguard3Attack3 = SGroup_CreateIfNotFound("sg_wave1Vanguard3Attack3")
		for i = 1, wave1SplitUnitCounts[3][3] do
			if(SGroup_CountSpawned(sg_enemyRow1_knights3) > 0) then
				SGroup_Add(sg_wave1Vanguard3Attack3, SGroup_GetSquadAt(sg_enemyRow1_knights3, 1))
				SGroup_Remove(sg_wave1_AllWaitingUnits, SGroup_GetSquadAt(sg_enemyRow1_knights3, 1))
				SGroup_Remove(sg_enemyRow1_knights3, SGroup_GetSquadAt(sg_enemyRow1_knights3, 1))
			end
		end
		Cmd_FormationAttackMove(sg_wave1Vanguard3Attack3, mkr_ArmyAttack3_3, false, false)
		Cmd_FormationAttackMove(sg_wave1Vanguard3Attack3, mkr_playerBase, true, false)
		--
		sg_wave1Vanguard3Attack4 = SGroup_CreateIfNotFound("sg_wave1Vanguard3Attack4")
		for i = 1, wave1SplitUnitCounts[3][4] do
			if(SGroup_CountSpawned(sg_enemyRow1_knights4) > 0) then
				SGroup_Add(sg_wave1Vanguard3Attack4, SGroup_GetSquadAt(sg_enemyRow1_knights4, 1))
				SGroup_Remove(sg_wave1_AllWaitingUnits, SGroup_GetSquadAt(sg_enemyRow1_knights4, 1))
				SGroup_Remove(sg_enemyRow1_knights4, SGroup_GetSquadAt(sg_enemyRow1_knights4, 1))
			end
		end
		Cmd_FormationAttackMove(sg_wave1Vanguard3Attack4, mkr_ArmyAttack4_3, false, false)
		Cmd_FormationAttackMove(sg_wave1Vanguard3Attack4, mkr_playerBase, true, false)
		--
		sg_wave1Vanguard3Attack5 = SGroup_CreateIfNotFound("sg_wave1Vanguard3Attack5")
		for i = 1, wave1SplitUnitCounts[3][5] do
			if(SGroup_CountSpawned(sg_enemyRow1_horsemen5) > 0) then
				SGroup_Add(sg_wave1Vanguard3Attack5, SGroup_GetSquadAt(sg_enemyRow1_horsemen5, 1))
				SGroup_Remove(sg_wave1_AllWaitingUnits, SGroup_GetSquadAt(sg_enemyRow1_horsemen5, 1))
				SGroup_Remove(sg_enemyRow1_horsemen5, SGroup_GetSquadAt(sg_enemyRow1_horsemen5, 1))
			end
		end
		Cmd_FormationAttackMove(sg_wave1Vanguard3Attack5, mkr_ArmyAttack5_3, false, false)
		Cmd_FormationAttackMove(sg_wave1Vanguard3Attack5, mkr_playerBase, true, false)
		--
		
		wave1_Vanguard3Attacking = true
	end
	
end

function HC_Agincourt_Wave1_CheckCenter()
	
	--remove UI elements if there are no waiting units or the battlefield promotion event is active
	if(SGroup_CountSpawned(sg_wave1_AllWaitingUnits) == 0 or gatheringAroundLeader == true or w1_finishedAdvance == true) then
		if(wave1Label1 ~= nil) then
			Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label1)
		end
		if(wave1Label2 ~= nil) then
			Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label2)
		end
		if(wave1Label3 ~= nil) then
			Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label3)
		end
		if(wave1Label4 ~= nil) then
			Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label4)
		end
		if(wave1Label5 ~= nil) then
			Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label5)
		end
		
		return
	end
	
	--get the center unit in each group
	if(SGroup_CountSpawned(sg_enemyRow1_horsemen1) > 0) then
		if(SGroup_IsMoving(sg_enemyRow1_horsemen1, ANY) == true) then
			SGroup_Clear(sg_enemyRow1_horsemen1Center)
			squad = SGroup_GetClosestSquad(sg_enemyRow1_horsemen1, SGroup_GetPosition(sg_enemyRow1_horsemen1))
			SGroup_Add(sg_enemyRow1_horsemen1Center, squad)
			if(wave1Label1 ~= nil) then
				Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label1)
			end
			wave1Label1 = Objective_AddUIElements(SOBJ_AttackWave1, sg_enemyRow1_horsemen1Center, false, "$11268424", true, 5)
		end
	end
	if(SGroup_CountSpawned(sg_enemyRow1_knights2) > 0) then
		if(SGroup_IsMoving(sg_enemyRow1_knights2, ANY) == true) then
			SGroup_Clear(sg_enemyRow1_knights2Center)
			squad = SGroup_GetClosestSquad(sg_enemyRow1_knights2, SGroup_GetPosition(sg_enemyRow1_knights2))
			SGroup_Add(sg_enemyRow1_knights2Center, squad)
			if(wave1Label2 ~= nil) then
				Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label2)
			end
			wave1Label2 = Objective_AddUIElements(SOBJ_AttackWave1, sg_enemyRow1_knights2Center, false, "$11268424", true, 5)--French Vanguard
		end
	end
	if(SGroup_CountSpawned(sg_enemyRow1_knights3) > 0) then
		if(SGroup_IsMoving(sg_enemyRow1_knights3, ANY) == true) then
			SGroup_Clear(sg_enemyRow1_knights3Center)
			squad = SGroup_GetClosestSquad(sg_enemyRow1_knights3, SGroup_GetPosition(sg_enemyRow1_knights3))
			SGroup_Add(sg_enemyRow1_knights3Center, squad)
			if(wave1Label3 ~= nil) then
				Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label3)
			end
			wave1Label3 = Objective_AddUIElements(SOBJ_AttackWave1, sg_enemyRow1_knights3Center, false, "$11268424", true, 5)--French Vanguard
		end
	end
	if(SGroup_CountSpawned(sg_enemyRow1_knights4) > 0) then
		if(SGroup_IsMoving(sg_enemyRow1_knights4, ANY) == true) then
			SGroup_Clear(sg_enemyRow1_knights4Center)
			squad = SGroup_GetClosestSquad(sg_enemyRow1_knights4, SGroup_GetPosition(sg_enemyRow1_knights4))
			SGroup_Add(sg_enemyRow1_knights4Center, squad)
			if(wave1Label4 ~= nil) then
				Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label4)
			end
			wave1Label4 = Objective_AddUIElements(SOBJ_AttackWave1, sg_enemyRow1_knights4Center, false, "$11268424", true, 5)--French Vanguard
		end
	end
	if(SGroup_CountSpawned(sg_enemyRow1_horsemen5) > 0) then
		if(SGroup_IsMoving(sg_enemyRow1_horsemen5, ANY) == true) then
			SGroup_Clear(sg_enemyRow1_horsemen5Center)
			squad = SGroup_GetClosestSquad(sg_enemyRow1_horsemen5, SGroup_GetPosition(sg_enemyRow1_horsemen5))
			SGroup_Add(sg_enemyRow1_horsemen5Center, squad)
			if(wave1Label5 ~= nil) then
				Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label5)
			end
			wave1Label5 = Objective_AddUIElements(SOBJ_AttackWave1, sg_enemyRow1_horsemen5Center, false, "$11268424", true, 5)--French Vanguard
		end
	end
end

function HC_Agincourt_Wave1_Start()
	
	w1_inCombat = true
	
	Sound_Play2D("sfx_campaign_scripted_attack_horn_under_attack_high")
	Sound_Play2D("sfx_campaign_scripted_medium_group_engage")
	Sound_Play2D(MUS_STINGER_ALERT)
	
	Cmd_FormationAttackMove(sg_enemyRow1_horsemen1, mkr_ArmyAttack1_3, true, false)
	Cmd_FormationAttackMove(sg_enemyRow1_knights2, mkr_ArmyAttack2_3, true, false)
	Cmd_FormationAttackMove(sg_enemyRow1_knights3, mkr_ArmyAttack3_3, true, false)
	Cmd_FormationAttackMove(sg_enemyRow1_knights4, mkr_ArmyAttack4_3, true, false)
	Cmd_FormationAttackMove(sg_enemyRow1_horsemen5, mkr_ArmyAttack5_3, true, false)
	
	Cmd_FormationAttackMove(sg_enemyRow1_horsemen1, mkr_playerBase, true, false)
	Cmd_FormationAttackMove(sg_enemyRow1_knights2, mkr_playerBase, true, false)
	Cmd_FormationAttackMove(sg_enemyRow1_knights3, mkr_playerBase, true, false)
	Cmd_FormationAttackMove(sg_enemyRow1_knights4, mkr_playerBase, true, false)
	Cmd_FormationAttackMove(sg_enemyRow1_horsemen5, mkr_playerBase, true, false)
	Cmd_FormationAttackMove(sg_enemyRow1_leader, mkr_playerBase, true, false)
	
	if(Rule_Exists(HC_Agincourt_Wave1_Update) == false) then
		Rule_AddInterval(HC_Agincourt_Wave1_Update, 0.125)
	end
	
	rallyStartTime = World_GetGameTime()
	
	
end



function HC_Agincourt_Wave1_Update()
	
	rallyTime = World_GetGameTime() - rallyStartTime
	
	if(rallyTime > rallyTimeMax and gatheringAroundLeader == false) then
		HC_Agincourt_Wave1_UpdateLeaderCombat()
	end
	
	if(missionTime < 8 * 60 and w1_finishedAdvance == false) then
		HC_Agincourt_Wave1_CheckProgress()
	else
		w1_finishedAdvance = true
	end
	
	if(SGroup_CountSpawned(sg_wave1_AllUnits) == 0) then
		if(missionTime < 5 * 60) then
			conquerorModeActivated = true
			--inform game code that the conqueror mode was activated during the mission
			Game_StoreTableData("conquerorMode", {activated = true})
			
			EventCues_CallToAction("$11266822", CTA_ALARM, nil, nil, sg_enemyRow2_leader, 30, "icons/cta/illustrations/alarm")--Conqueror Mode Activated
			Sound_Play2D("sfx_campaign_scripted_attack_horn_under_attack_high")
			Sound_Play2D(MUS_STING_TRIUMPHANT)
			
			Util_StartIntel(EVENTS.Conqueror_Unlock)
			
			if Objective_IsStarted(OBJ_Conqueror) then
				Objective_Complete(OBJ_Conqueror, true, true)
			end
			--remove gold medal objective
			if(Objective_IsStarted(OBJ_GoldMedal)) then
				Objective_Complete(OBJ_GoldMedal, false, false)
				Objective_Show(OBJ_GoldMedal, false, false)
			end
			--add auras to wave 2 leaders only in conqueror mode
			if(SGroup_CountSpawned(sg_enemyRow2_leader2) > 0) then
				squad = SGroup_GetSquadAt(sg_enemyRow2_leader2, 1)
				Squad_AddAbility(squad, ABILITY.GENERAL_AURA_ARMOR)
			end
			if(SGroup_CountSpawned(sg_enemyRow2_leader) > 0) then
				squad = SGroup_GetSquadAt(sg_enemyRow2_leader, 1)
				Squad_AddAbility(squad, ABILITY.LORD_OF_LANCASTER_AURA_LAN)
			end
			
			--add +1 attack upgrades to enemy units
			Player_CompleteUpgrade(enemyPlayer, UPG.COMMON.UPGRADE_MELEE_DAMAGE_I)
			Player_CompleteUpgrade(enemyPlayer, UPG.COMMON.UPGRADE_RANGED_DAMAGE_I)
			
		end
		
		Objective_Complete(SOBJ_AttackWave1, false, false)
		
		--reveal and mark next wave
		HC_Agincourt_RevealFrenchWave2()
		
		--start counterattack and raids
		if(conquerorModeActivated == true) then
			HC_Agincourt_StartCounterAttacks()
		else
			Rule_AddOneShot(HC_Agincourt_StartCounterAttacks, 60)
		end
		
		Rule_RemoveMe()
	end
	
end

--increase size of inner reticule over time
function HC_Agincourt_Wave1_UpdateLeaderReticule()
	
	
	chargeUpTime = World_GetGameTime() - chargeUpStartTime
	if(chargeUpTime < gatherAroundTimeLimit) then
		
		--set reticule
		local bp_reticule = BP_GetReticuleBlueprint("ability_white_standard")
		local reticulePos = w1_leader_rallyPosition
		local size = 8 * (chargeUpTime / gatherAroundTimeLimit)
		
		Obj_SetProgress(SOBJ_W1LeaderRally.ID, (chargeUpTime / gatherAroundTimeLimit))
		
		if(rallyReticuleID2 ~= nil) then
			UI_ModalVisual_Destroy(rallyReticuleID2)
		end
		
		rallyReticuleID2 = UI_ModalVisual_CreateReticule(bp_reticule, size)
		UI_ModalVisual_SetPosition(rallyReticuleID2, reticulePos)
	else
		if(rallyReticuleID2 ~= nil) then
			UI_ModalVisual_Destroy(rallyReticuleID2)
		end
		Obj_SetProgressVisible(SOBJ_W1LeaderRally.ID, false)
		Obj_SetVisible(SOBJ_W1LeaderRally.ID, false)
		if(wave1PromotionLabel ~= nil) then
			Objective_RemoveUIElements(SOBJ_W1LeaderRally, wave1PromotionLabel)
		end
		Rule_RemoveMe()
	end
	
end

--gather units to be promoted around the leader
function HC_Agincourt_Wave1_GatherAroundLeader()
	
	sg_wave1_RallyUnits = SGroup_CreateIfNotFound("sg_wave1_RallyUnits")
	sg_wave1_DebuffedUnits = SGroup_CreateIfNotFound("sg_wave1_DebuffedUnits")
	sg_wave1_PromotedUnits = SGroup_CreateIfNotFound("sg_wave1_PromotedUnits")
	
	if(SGroup_CountSpawned(sg_enemyRow1_leader) == 0) then
		Rule_RemoveMe()
		if(rallyReticuleID1 ~= nil) then
			UI_ModalVisual_Destroy(rallyReticuleID1)
		end
		--switch to the standard enemy player
		SGroup_SetPlayerOwner(sg_wave1_DebuffedUnits, enemyPlayer)
		
		gatheringAroundLeader = false
		return
	end
	
	chargeUpTime = World_GetGameTime() - chargeUpStartTime
	if(chargeUpTime > gatherAroundTimeLimit) then
		if(rallyReticuleID1 ~= nil) then
			UI_ModalVisual_Destroy(rallyReticuleID1)
		end
		Modifier_RemoveAllFromSGroup(sg_wave1_DebuffedUnits)
		
		Player_GetAllSquadsNearMarker(enemyPlayer3, sg_wave1_PromotedUnits, w1_leader_rallyPosition, 7)
		
		SGroup_RemoveGroup(sg_wave1_DebuffedUnits, sg_wave1_PromotedUnits)
		
		--apply upgrades
		Cmd_InstantUpgrade(sg_wave1_PromotedUnits, UPG.FRENCH.UPGRADE_UNIT_KNIGHT_4_FRE)
		Cmd_InstantUpgrade(sg_wave1_PromotedUnits, UPG.COMMON.UPGRADE_UNIT_HORSEMAN_4)
		
		--switch to the upgraded enemy player
		SGroup_SetPlayerOwner(sg_wave1_PromotedUnits, enemyPlayer2)
		Cmd_FormationAttackMove(sg_wave1_PromotedUnits, mkr_playerBase, false, false)
		Cmd_FormationAttackMove(sg_enemyRow1_leader, mkr_playerBase, false, false)
		
		--switch remaining units to the standard enemy player
		sg_wave1_DebuffedUnits = Player_GetSquads(enemyPlayer3)
		SGroup_SetPlayerOwner(sg_wave1_DebuffedUnits, enemyPlayer)
		
		gatheringAroundLeader = false
		rallyStartTime = World_GetGameTime()
		--increase delay before ability activates again
		rallyTimeMax = rallyTimeMax + 3
		Rule_RemoveMe()
		return
	end
	
	
	sg_wave1_DebuffedUnits = Player_GetSquads(enemyPlayer3)
	--if there are not enough units being rallied, attempt to find more
	if(SGroup_CountSpawned(sg_wave1_DebuffedUnits) < wave1RallyUnitMax and gatheringAroundLeaderCount < wave1RallyUnitMax) then
		Player_GetAllSquadsNearMarker(enemyPlayer, sg_wave1_RallyUnits, SGroup_GetAvgPosition(sg_enemyRow1_leader), wave1SearchRadius)
		if(SGroup_CountSpawned(sg_wave1_RallyUnits) > 0) then
			
			--keep a maximum count to limit the number of units gathered
			local combinedGatherCount = SGroup_CountSpawned(sg_wave1_RallyUnits) + SGroup_CountSpawned(sg_wave1_DebuffedUnits)
			if(combinedGatherCount > wave1RallyUnitMax) then
				--remove extra units over the limit
				for i = 1, combinedGatherCount - wave1RallyUnitMax do
					if(SGroup_CountSpawned(sg_wave1_RallyUnits) >= 1) then
						local squad = SGroup_GetSquadAt(sg_wave1_RallyUnits, 1)
						SGroup_Remove(sg_wave1_RallyUnits, squad)
					end
				end
				gatheringAroundLeaderCount = combinedGatherCount
			end
			combinedGatherCount = SGroup_CountSpawned(sg_wave1_RallyUnits) + SGroup_CountSpawned(sg_wave1_DebuffedUnits)
			
			--switch to the debuffed enemy player
			SGroup_SetPlayerOwner(sg_wave1_RallyUnits, enemyPlayer3)
		end
		--increase search radius for the next iteration
		if(wave1SearchRadius < 20) then
			wave1SearchRadius = wave1SearchRadius + 1
		end
	end
	
	sg_wave1_DebuffedUnits = Player_GetSquads(enemyPlayer3)
	if(SGroup_CountSpawned(sg_wave1_DebuffedUnits) > 0) then
		
		Cmd_Move(sg_enemyRow1_leader, w1_leader_rallyPosition, false, false, w1_leader_rallyPosition)
		for i = 1, SGroup_CountSpawned(sg_wave1_DebuffedUnits) do
			local squad = SGroup_GetSquadAt(sg_wave1_DebuffedUnits, i)
			SGroup_Single(sg_single, squad)
			Cmd_Move(sg_single, w1_leader_rallyPosition, false, false, w1_leader_rallyPosition)
			Cmd_Ability(sg_single, BP_GetAbilityBlueprint("combat_unit_hold_position"), nil, nil, nil, true)
			
			if Squad_Count(squad) >= 1 then 
				local entity = Squad_GetFirstEntity(squad)
				Entity_SetAnimatorAction(entity, "gameplay_add_debuff")
				Entity_SetStateModelBool(entity, "smoke_reaction", true)
			end
		end
	end
	
end

function HC_Agincourt_Wave1_UpdateLeaderCombat()
	
	if(SGroup_CountSpawned(sg_enemyRow1_leader) == 0) then
		Rule_RemoveMe()
		if(rallyReticuleID1 ~= nil) then
			UI_ModalVisual_Destroy(rallyReticuleID1)
		end
		return
	end
	
	w1_leader_rallyPosition = SGroup_GetAvgPosition(sg_enemyRow1_leader)
	sg_wave1_RallyUnits = SGroup_CreateIfNotFound("sg_wave1_RallyUnits")
	Player_GetAllSquadsNearMarker(enemyPlayer, sg_wave1_RallyUnits, w1_leader_rallyPosition, 10)
	
	if(SGroup_CountSpawned(sg_wave1_RallyUnits) > 0) then
		
		--also get nearby player units to make sure there is a real battle and not a few units
		sg_wave1_NearbyPlayerUnits = SGroup_CreateIfNotFound("sg_wave1_NearbyPlayerUnits")
		Player_GetAllSquadsNearMarker(localPlayer, sg_wave1_NearbyPlayerUnits, w1_leader_rallyPosition, 15)
		
		if(SGroup_IsUnderAttack(sg_wave1_RallyUnits, ANY, 5) == true and SGroup_CountSpawned(sg_wave1_NearbyPlayerUnits) > 5) then
			
			--set leader target position behind the enemy line
			w1_leader_rallyPosition["x"] = w1_leader_rallyPosition["x"] + 8
			w1_leader_rallyPosition["z"] = w1_leader_rallyPosition["z"] + 8
			
			--set reticule
			local bp_reticule = BP_GetReticuleBlueprint("marquee_additive")
			local reticulePos = w1_leader_rallyPosition
			local size = 8
			if(rallyReticuleID1 ~= nil) then
				UI_ModalVisual_Destroy(rallyReticuleID1)
			end
			rallyReticuleID1 = UI_ModalVisual_CreateReticule(bp_reticule, size)
			UI_ModalVisual_SetPosition(rallyReticuleID1, reticulePos)
			
			size = 0
			if(rallyReticuleID2 ~= nil) then
				UI_ModalVisual_Destroy(rallyReticuleID2)
			end
			rallyReticuleID2 = UI_ModalVisual_CreateReticule(bp_reticule, size)
			UI_ModalVisual_SetPosition(rallyReticuleID2, reticulePos)
			
			--continue gathering units
			chargeUpStartTime = World_GetGameTime()
			gatheringAroundLeader = true
			wave1SearchRadius = 15
			gatheringAroundLeaderCount = 0
			Rule_AddInterval(HC_Agincourt_Wave1_GatherAroundLeader, .5)
			Rule_AddInterval(HC_Agincourt_Wave1_UpdateLeaderReticule, .125)
			
			Obj_SetVisible(SOBJ_W1LeaderRally.ID, true)
			Obj_SetProgressVisible(SOBJ_W1LeaderRally.ID, true)
			wave1PromotionLabel = Objective_AddUIElements(SOBJ_W1LeaderRally, reticulePos, false, "$11268423", true, -5) --Battlefield Promotion
			
			rallyStartTime = World_GetGameTime()
			chargeUpStartTime = World_GetGameTime()
			
			--remove other UI elements so the battlefied promition element isn't hidden
			if(wave1Label1 ~= nil) then
				Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label1)
			end
			if(wave1Label2 ~= nil) then
				Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label2)
			end
			if(wave1Label3 ~= nil) then
				Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label3)
			end
			if(wave1Label4 ~= nil) then
				Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label4)
			end
			if(wave1Label5 ~= nil) then
				Objective_RemoveUIElements(SOBJ_AttackWave1, wave1Label5)
			end
		end
	end
	
end

function HC_Agincourt_Wave1_UpdateLeader()
	
	
	--only update if the leader isn't rallying units
	if(gatheringAroundLeader == true) then
		return
	end
	
	if(SGroup_CountSpawned(sg_enemyRow1_leader) == 0) then
		Rule_RemoveMe()
		return
	end
	
	local currentGroupPos = SGroup_GetAvgPosition(sg_enemyRow1_leader)
	
	local previousLaneTarget = w1_leader_target
	
	local highestGroupCount = 0
	--default to the middle lane
	w1_leader_target = 3
	highestGroupCount = SGroup_CountSpawned(sg_enemyRow1_knights3)
	if(SGroup_CountSpawned(sg_enemyRow1_horsemen1) > highestGroupCount) then
		highestGroupCount = SGroup_CountSpawned(sg_enemyRow1_horsemen1)
		w1_leader_target = 1
	end
	if(SGroup_CountSpawned(sg_enemyRow1_knights2) > highestGroupCount) then
		highestGroupCount = SGroup_CountSpawned(sg_enemyRow1_knights2)
		w1_leader_target = 2
	end
	if(SGroup_CountSpawned(sg_enemyRow1_knights3) > highestGroupCount) then
		highestGroupCount = SGroup_CountSpawned(sg_enemyRow1_knights3)
		w1_leader_target = 3
	end
	if(SGroup_CountSpawned(sg_enemyRow1_knights4) > highestGroupCount) then
		highestGroupCount = SGroup_CountSpawned(sg_enemyRow1_knights4)
		w1_leader_target = 4
	end
	if(SGroup_CountSpawned(sg_enemyRow1_horsemen5) > highestGroupCount) then
		highestGroupCount = SGroup_CountSpawned(sg_enemyRow1_horsemen5)
		w1_leader_target = 5
	end
	
	
	
	
	if(w1_leader_target == 1) then
		if(SGroup_CountSpawned(sg_enemyRow1_horsemen1) > 0) then
			currentGroupPos = SGroup_GetAvgPosition(sg_enemyRow1_horsemen1)
		end
	end
	if(w1_leader_target == 2) then
		if(SGroup_CountSpawned(sg_enemyRow1_knights2) > 0) then
			currentGroupPos = SGroup_GetAvgPosition(sg_enemyRow1_knights2)
		end
	end
	if(w1_leader_target == 3) then
		if(SGroup_CountSpawned(sg_enemyRow1_knights3) > 0) then
			currentGroupPos = SGroup_GetAvgPosition(sg_enemyRow1_knights3)
		end
	end
	if(w1_leader_target == 4) then
		if(SGroup_CountSpawned(sg_enemyRow1_knights4) > 0) then
			currentGroupPos = SGroup_GetAvgPosition(sg_enemyRow1_knights4)
		end
	end
	if(w1_leader_target == 5) then
		if(SGroup_CountSpawned(sg_enemyRow1_horsemen5) > 0) then
			currentGroupPos = SGroup_GetAvgPosition(sg_enemyRow1_horsemen5)
		end
	end
	
	
	if(previousLaneTarget == w1_leader_target) then
		w1_leader_target_changed = true
		--only move if the group average position is different from the leader's position
		local currentLeaderPos = SGroup_GetAvgPosition(sg_enemyRow1_leader)
		if(Util_GetDistance(currentLeaderPos, currentGroupPos) > 5) then
			Cmd_FormationMove(sg_enemyRow1_leader, currentGroupPos, false, false)
		end
	else
		w1_leader_target_changed = false
		Cmd_FormationAttackMove(sg_enemyRow1_leader, currentGroupPos, false, false)
	end
	
	
end

function HC_Agincourt_Wave1_CheckProgress()
	
	--ignore groups with less than this many units for tracking progress
	local w1_minGroupCount = 5
	
	if(SGroup_CountSpawned(sg_enemyRow1_horsemen1) >= w1_minGroupCount) then
		w1_lane1_progress = HC_Agincourt_Wave1_CheckLaneProgress(SGroup_GetAvgPosition(sg_enemyRow1_horsemen1), 1, SOBJ_Progress1)
	else
		w1_lane1_progress = 0
	end
	
	if(SGroup_CountSpawned(sg_enemyRow1_knights2) >= w1_minGroupCount) then
		w1_lane2_progress = HC_Agincourt_Wave1_CheckLaneProgress(SGroup_GetAvgPosition(sg_enemyRow1_knights2), 2, SOBJ_Progress2)
	else
		w1_lane2_progress = 0
	end
	
	if(SGroup_CountSpawned(sg_enemyRow1_knights3) >= w1_minGroupCount) then
		w1_lane3_progress = HC_Agincourt_Wave1_CheckLaneProgress(SGroup_GetAvgPosition(sg_enemyRow1_knights3), 3, SOBJ_Progress3)
	else
		w1_lane3_progress = 0
	end
	
	if(SGroup_CountSpawned(sg_enemyRow1_knights4) >= w1_minGroupCount) then
		w1_lane4_progress = HC_Agincourt_Wave1_CheckLaneProgress(SGroup_GetAvgPosition(sg_enemyRow1_knights4), 4, SOBJ_Progress4)
	else
		w1_lane4_progress = 0
	end
	
	if(SGroup_CountSpawned(sg_enemyRow1_horsemen5) >= w1_minGroupCount) then
		w1_lane5_progress = HC_Agincourt_Wave1_CheckLaneProgress(SGroup_GetAvgPosition(sg_enemyRow1_horsemen5), 5, SOBJ_Progress5)
	else
		w1_lane5_progress = 0
	end
	
	local w1_avg_progress = 0
	local w1_activeLanes = 0
	if(w1_lane1_progress > 0) then
		if(SGroup_CountSpawned(sg_enemyRow1_horsemen1) >= w1_minGroupCount) then
			if(SGroup_IsUnderAttack(sg_enemyRow1_horsemen1, ANY, 5) == false) then
				w1_avg_progress = w1_avg_progress + w1_lane1_progress
				w1_activeLanes = w1_activeLanes + 1
			end
		end
	end
	if(w1_lane2_progress > 0) then
		if(SGroup_CountSpawned(sg_enemyRow1_knights2) >= w1_minGroupCount) then
			if(SGroup_IsUnderAttack(sg_enemyRow1_knights2, ANY, 5) == false) then
				w1_avg_progress = w1_avg_progress + w1_lane2_progress
				w1_activeLanes = w1_activeLanes + 1
			end
		end
	end
	if(w1_lane3_progress > 0) then
		if(SGroup_CountSpawned(sg_enemyRow1_knights3) >= w1_minGroupCount) then
			if(SGroup_IsUnderAttack(sg_enemyRow1_knights3, ANY, 5) == false) then
				w1_avg_progress = w1_avg_progress + w1_lane3_progress
				w1_activeLanes = w1_activeLanes + 1
			end
		end
	end
	if(w1_lane4_progress > 0) then
		if(SGroup_CountSpawned(sg_enemyRow1_knights4) >= w1_minGroupCount) then
			if(SGroup_IsUnderAttack(sg_enemyRow1_knights4, ANY, 5) == false) then
				w1_avg_progress = w1_avg_progress + w1_lane4_progress
				w1_activeLanes = w1_activeLanes + 1
			end
		end
	end
	if(w1_lane5_progress > 0) then
		if(SGroup_CountSpawned(sg_enemyRow1_horsemen5) >= w1_minGroupCount) then
			if(SGroup_IsUnderAttack(sg_enemyRow1_horsemen5, ANY, 5) == false) then
				w1_avg_progress = w1_avg_progress + w1_lane5_progress
				w1_activeLanes = w1_activeLanes + 1
			end
		end
	end
	
	
	if(w1_activeLanes > 0) then
		w1_avg_progress = w1_avg_progress / w1_activeLanes
	end
	
	--if the average position is past the final position, set w1_finishedAdvance to true
	if(w1_avg_progress >= w1_farthestStart + .1) then
		w1_finishedAdvance = true
	end
	
	--for testing
	--Objective_SetProgressBar(SOBJ_Fit1, w1_lane1_fit)
	
	local maxLaneProgressDiff = .05
	local minLaneProgressDiff = .2
	local reformLanesNeeded = false
	if(SGroup_CountSpawned(sg_enemyRow1_horsemen1) >= w1_minGroupCount) then
		if(SGroup_IsUnderAttack(sg_enemyRow1_horsemen1, ANY, 5) == false) then
			local progressDiff = math.abs(w1_avg_progress - w1_lane1_progress)
			if(progressDiff > maxLaneProgressDiff and progressDiff < minLaneProgressDiff) then
				reformLanesNeeded = true
			end
		end
	end
	if(SGroup_CountSpawned(sg_enemyRow1_knights2) >= w1_minGroupCount) then
		if(SGroup_IsUnderAttack(sg_enemyRow1_knights2, ANY, 5) == false) then
			local progressDiff = math.abs(w1_avg_progress - w1_lane2_progress)
			if(progressDiff > maxLaneProgressDiff and progressDiff < minLaneProgressDiff) then
				reformLanesNeeded = true
			end
		end
	end
	if(SGroup_CountSpawned(sg_enemyRow1_knights3) >= w1_minGroupCount) then
		if(SGroup_IsUnderAttack(sg_enemyRow1_knights3, ANY, 5) == false) then
			local progressDiff = math.abs(w1_avg_progress - w1_lane3_progress)
			if(progressDiff > maxLaneProgressDiff and progressDiff < minLaneProgressDiff) then
				reformLanesNeeded = true
			end
		end
	end
	if(SGroup_CountSpawned(sg_enemyRow1_knights4) >= w1_minGroupCount) then
		if(SGroup_IsUnderAttack(sg_enemyRow1_knights4, ANY, 5) == false) then
			local progressDiff = math.abs(w1_avg_progress - w1_lane4_progress)
			if(progressDiff > maxLaneProgressDiff and progressDiff < minLaneProgressDiff) then
				reformLanesNeeded = true
			end
		end
	end
	if(SGroup_CountSpawned(sg_enemyRow1_horsemen5) >= w1_minGroupCount) then
		if(SGroup_IsUnderAttack(sg_enemyRow1_horsemen5, ANY, 5) == false) then
			local progressDiff = math.abs(w1_avg_progress - w1_lane5_progress)
			if(progressDiff > maxLaneProgressDiff and progressDiff < minLaneProgressDiff) then
				reformLanesNeeded = true
			end
		end
	end
	
	--if any of the groups has been completely defeated, continue the attack despite time limits
	local w1_anyLaneDefeated = false
	if(SGroup_CountSpawned(sg_enemyRow1_horsemen1) == 0 or SGroup_CountSpawned(sg_enemyRow1_knights2) == 0 or 
			SGroup_CountSpawned(sg_enemyRow1_knights3) == 0 or SGroup_CountSpawned(sg_enemyRow1_knights4) == 0 or 
			SGroup_CountSpawned(sg_enemyRow1_horsemen5) == 0) then
		reformLanesNeeded = false
		w1_anyLaneDefeated = true
	end
	
	--if no units are under attack, wait according to the preset limit until the advance timer has finished
	if(w1_inCombat == true) then
		if(w1_avg_progress > w1_set_progress) then
			if(SGroup_IsUnderAttack(sg_wave1_AllWaitingUnits, ANY, 10) == false
					and SGroup_IsUnderAttack(sg_wave2_AllWaitingUnits, ANY, 10) == false 
					and SGroup_IsUnderAttack(sg_wave3_AllUnits, ANY, 10) == false) then
				if(w1_set_progress < w1_farthestStart and w1_anyLaneDefeated == false) then
					w1_set_progress = w1_avg_progress
					w1_inCombat = false
					
					HC_Agincourt_Wave1_SendBackToLane(sg_enemyRow1_horsemen1, 1, w1_set_progress, true, false)
					HC_Agincourt_Wave1_SendBackToLane(sg_enemyRow1_knights2, 2, w1_set_progress, true, false)
					HC_Agincourt_Wave1_SendBackToLane(sg_enemyRow1_knights3, 3, w1_set_progress, true, false)
					HC_Agincourt_Wave1_SendBackToLane(sg_enemyRow1_knights4, 4, w1_set_progress, true, false)
					HC_Agincourt_Wave1_SendBackToLane(sg_enemyRow1_horsemen5, 5, w1_set_progress, true, false)
					HC_Agincourt_Wave1_SendBackToLane(sg_enemyRow1_leader, 3, w1_set_progress, true, false)
					
				else
					--if the wave has already reached the end, start the full attack
					if(w1_finishedAdvance == false) then
						HC_Agincourt_Wave1_Start()
						Objective_Complete(SOBJ_AttackWave1, false, false)
						w1_finishedAdvance = true
						
					end
				end
			end
			return
		end
	end
	
	if(reformLanesNeeded == true) then
		
		if(SGroup_CountSpawned(sg_enemyRow1_horsemen1) > 0) then
			if(SGroup_IsUnderAttack(sg_enemyRow1_horsemen1, ANY, 5) == false) then
				HC_Agincourt_Wave1_SendBackToLane(sg_enemyRow1_horsemen1, 1, w1_avg_progress, true, false)
			end
		end
		if(SGroup_CountSpawned(sg_enemyRow1_knights2) > 0) then
			if(SGroup_IsUnderAttack(sg_enemyRow1_knights2, ANY, 5) == false) then
				HC_Agincourt_Wave1_SendBackToLane(sg_enemyRow1_knights2, 2, w1_avg_progress, true, false)
			end
		end
		if(SGroup_CountSpawned(sg_enemyRow1_knights3) > 0) then
			if(SGroup_IsUnderAttack(sg_enemyRow1_knights3, ANY, 5) == false) then
				HC_Agincourt_Wave1_SendBackToLane(sg_enemyRow1_knights3, 3, w1_avg_progress, true, false)
			end
		end
		if(SGroup_CountSpawned(sg_enemyRow1_knights4) > 0) then
			if(SGroup_IsUnderAttack(sg_enemyRow1_knights4, ANY, 5) == false) then
				HC_Agincourt_Wave1_SendBackToLane(sg_enemyRow1_knights4, 4, w1_avg_progress, true, false)
			end
		end
		if(SGroup_CountSpawned(sg_enemyRow1_horsemen5) > 0) then
			if(SGroup_IsUnderAttack(sg_enemyRow1_horsemen5, ANY, 5) == false) then
				HC_Agincourt_Wave1_SendBackToLane(sg_enemyRow1_horsemen5, 5, w1_avg_progress, true, false)
			end
		end
		--also send leader back to the middle lane
		if(SGroup_CountSpawned(sg_enemyRow1_leader) > 0) then
			if(SGroup_IsUnderAttack(sg_enemyRow1_leader, ANY, 5) == false) then
				HC_Agincourt_Wave1_SendBackToLane(sg_enemyRow1_leader, 3, w1_avg_progress, true, false)
			end
		end
		reformingLanes = true
	end
	
	
	
	if(reformingLanes == true and reformLanesNeeded == false) then
		Rule_AddOneShot(HC_Agincourt_Wave1_ResumeLanes, 5)
		reformingLanes = false
	end
	
	
	
	
end

function HC_Agincourt_Wave1_ResumeLanes()
	
	if(SGroup_CountSpawned(sg_enemyRow1_horsemen1) > 0) then
		Cmd_FormationAttackMove(sg_enemyRow1_horsemen1, mkr_ArmyAttack1_4, true, false)
		Cmd_FormationAttackMove(sg_enemyRow1_horsemen1, mkr_playerBase, true, false)
	end
		
	if(SGroup_CountSpawned(sg_enemyRow1_knights2) > 0) then
		Cmd_FormationAttackMove(sg_enemyRow1_knights2, mkr_ArmyAttack2_4, true, false)
		Cmd_FormationAttackMove(sg_enemyRow1_knights2, mkr_playerBase, true, false)
	end
	
	if(SGroup_CountSpawned(sg_enemyRow1_knights3) > 0) then
		Cmd_FormationAttackMove(sg_enemyRow1_knights3, mkr_ArmyAttack3_4, true, false)
		Cmd_FormationAttackMove(sg_enemyRow1_knights3, mkr_playerBase, true, false)
	end
	
	if(SGroup_CountSpawned(sg_enemyRow1_knights4) > 0) then
		Cmd_FormationAttackMove(sg_enemyRow1_knights4, mkr_ArmyAttack4_4, true, false)
		Cmd_FormationAttackMove(sg_enemyRow1_knights4, mkr_playerBase, true, false)
	end
	
	if(SGroup_CountSpawned(sg_enemyRow1_horsemen5) > 0) then
		Cmd_FormationAttackMove(sg_enemyRow1_horsemen5, mkr_ArmyAttack5_4, true, false)
		Cmd_FormationAttackMove(sg_enemyRow1_horsemen5, mkr_playerBase, true, false)
	end
	
end


function HC_Agincourt_Wave1_SendBackToLane(sg_LaneSGroup, in_laneNumber, in_avgProgress, in_UseFormation, in_UseAttackMove)
	
	if(in_laneNumber == 1) then
		in_startMarker = mkr_frenchArmyS3_1
		in_endMarker = mkr_ArmyAttack1_4
	elseif(in_laneNumber == 2) then
		in_startMarker = mkr_frenchArmyS3_2
		in_endMarker = mkr_ArmyAttack2_4
	elseif(in_laneNumber == 3) then
		in_startMarker = mkr_frenchArmyS3_3
		in_endMarker = mkr_ArmyAttack3_4
	elseif(in_laneNumber == 4) then
		in_startMarker = mkr_frenchArmyS3_4
		in_endMarker = mkr_ArmyAttack4_4
	elseif(in_laneNumber == 5) then
		in_startMarker = mkr_frenchArmyS3_5
		in_endMarker = mkr_ArmyAttack5_4
	end
	
	if(sg_LaneSGroup ~= nil) then
		if(SGroup_CountSpawned(sg_LaneSGroup) > 0) then
			local distFromStart = Util_GetDistance(sg_LaneSGroup, in_startMarker)
			
			local pA = Util_GetPosition(in_startMarker)
			local pB = Util_GetPosition(in_endMarker)
			local groupAveragePos = SGroup_GetAvgPosition(sg_LaneSGroup)
			local projectedPoint = HC_Agincourt_GetPointOnLane(pA, pB, groupAveragePos)
			
			local avgPointOnLine = Util_GetPosition(in_startMarker)
			avgPointOnLine["x"] = (pB["x"] - pA["x"]) * in_avgProgress
			avgPointOnLine["z"] = (pB["z"] - pA["z"]) * in_avgProgress
			
			avgPointOnLine["x"] = avgPointOnLine["x"] + pA["x"]
			avgPointOnLine["z"] = avgPointOnLine["z"] + pA["z"]

			if(in_UseFormation == true) then
				if(in_UseAttackMove == true) then
					Cmd_FormationAttackMove(sg_LaneSGroup, avgPointOnLine, false, false)
				else
					Cmd_FormationMove(sg_LaneSGroup, avgPointOnLine, false, false, in_endMarker)
				end
			else
				if(in_UseAttackMove == true) then
					Cmd_AttackMove(sg_LaneSGroup, avgPointOnLine, false, false)
				else
					Cmd_Move(sg_LaneSGroup, avgPointOnLine, false, false, in_endMarker)
				end
			end
		end
	end
end


function HC_Agincourt_Wave1_CheckLaneProgress(in_Position, in_laneNumber, in_Objective)
	
	local in_startMarker = mkr_frenchArmyS3_1
	local in_endMarker = mkr_ArmyAttack1_4
	
	if(in_laneNumber == 1) then
		in_startMarker = mkr_frenchArmyS3_1
		in_endMarker = mkr_ArmyAttack1_4
	elseif(in_laneNumber == 2) then
		in_startMarker = mkr_frenchArmyS3_2
		in_endMarker = mkr_ArmyAttack2_4
	elseif(in_laneNumber == 3) then
		in_startMarker = mkr_frenchArmyS3_3
		in_endMarker = mkr_ArmyAttack3_4
	elseif(in_laneNumber == 4) then
		in_startMarker = mkr_frenchArmyS3_4
		in_endMarker = mkr_ArmyAttack4_4
	elseif(in_laneNumber == 5) then
		in_startMarker = mkr_frenchArmyS3_5
		in_endMarker = mkr_ArmyAttack5_4
	end
	
	
	local distFromStart = Util_GetDistance(in_Position, in_startMarker)
	
	local pA = Util_GetPosition(in_startMarker)
	local pB = Util_GetPosition(in_endMarker)
	local groupAveragePos = in_Position
	local projectedPoint = HC_Agincourt_GetPointOnLane(pA, pB, groupAveragePos)

	local pathDist = Util_GetDistance(in_startMarker, in_endMarker)
	if(in_Objective ~= nil) then
		Objective_SetProgressBar(in_Objective, (distFromStart / pathDist))
	end
	return (distFromStart / pathDist)
	
end


function HC_Agincourt_GetPointOnLane(inPA, inPB, inPC)

	local pointA = Util_GetPosition(inPA)
	local pointB = Util_GetPosition(inPB)
	local lineAB = Util_GetPosition(inPA)
	lineAB["x"] = pointB["x"] - pointA["x"]
	lineAB["z"] = pointB["z"] - pointA["z"]
	local pointC = Util_GetPosition(inPC)
	local lineAC = Util_GetPosition(inPC)
	lineAC["x"] = pointC["x"] - pointA["x"]
	lineAC["z"] = pointC["z"] - pointA["z"]
	
	local lengthAB = (lineAB["x"] * lineAB["x"]) + (lineAB["z"] * lineAB["z"])
	local interceptT = ((lineAC["x"] * lineAB["x"]) + (lineAC["z"] * lineAB["z"])) / lengthAB
	
	local projPoint = Util_GetPosition(inPA)
	projPoint["x"] = pointA["x"] + (interceptT * lineAB["x"])
	projPoint["z"] = pointA["z"] + (interceptT * lineAB["z"])
	
	return projPoint
end


