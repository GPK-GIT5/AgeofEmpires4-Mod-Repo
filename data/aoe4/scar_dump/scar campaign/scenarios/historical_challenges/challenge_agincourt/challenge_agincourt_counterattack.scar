
import("MissionOMatic/MissionOMatic.scar")		-- this imports the Cardinal scripts as well
import("missionomatic/missionomatic_artofwar.scar")
import("training/coretraininggoals.scar")
import("challenge_agincourt.events")
import("cardinal.scar")

function HC_Agincourt_StartCounterAttacks()
	
	
	sg_AgincourtRaiders = SGroup_CreateIfNotFound("sg_AgincourtRaiders")
	sg_TramecourtRaiders = SGroup_CreateIfNotFound("sg_TramecourtRaiders")
	
	Rule_AddOneShot(HC_Agincourt_SpawnMainCounterAttack, (60 * 6))
	
	Rule_AddInterval(HC_Agincourt_SpawnAgincourtRaid, 90)
	Rule_AddInterval(HC_Agincourt_SpawnTramecourtRaid, 90)
	
	
	Rule_AddInterval(HC_Agincourt_PulseThreatBlip, 15)
end


function HC_Agincourt_PulseThreatBlip()
	
	if(SGroup_CountSpawned(sg_AgincourtRaiders) > 0) then
		--pulse minimap blip
		UI_CreateMinimapBlip(Util_GetPosition(sg_AgincourtRaiders), 1, "threat_group")
	end
	
	if(SGroup_CountSpawned(sg_TramecourtRaiders) > 0) then
		--pulse minimap blip
		UI_CreateMinimapBlip(Util_GetPosition(sg_TramecourtRaiders), 1, "threat_group")
	end
end

function HC_Agincourt_SpawnMainCounterAttack()
	
	if(agincourtTownAlive == true) then
		if(conquerorModeActivated == true) then
			sg_AgincourtMainRaid = SGroup_CreateIfNotFound("sg_AgincourtMainRaid")
			SGroup_Clear(sg_AgincourtMainRaid)
			local sbp_militia = SBP.FRENCH.UNIT_SHIELD_VILLAGER_CMP_FRE
			UnitEntry_DeploySquads(enemyPlayer, sg_AgincourtMainRaid, {sbp = sbp_militia, numSquads = 12 }, mkr_Agincourt_spawn1)
			
			Cmd_FormationAttackMove(sg_AgincourtMainRaid, mkr_playerBase, false)
		else
			sg_AgincourtMainRaid = SGroup_CreateIfNotFound("sg_AgincourtMainRaid")
			SGroup_Clear(sg_AgincourtMainRaid)
			local sbp_militia = SBP.FRENCH.UNIT_SHIELD_VILLAGER_CMP_FRE
			UnitEntry_DeploySquads(enemyPlayer, sg_AgincourtMainRaid, {sbp = sbp_militia, numSquads = 6 }, mkr_Agincourt_spawn1)
			
			Cmd_FormationAttackMove(sg_AgincourtMainRaid, mkr_playerBase, false)
		end
	end
	
	if(SGroup_CountSpawned(sg_hiddenArmy) > 0) then
		EventCues_CallToAction("$11268428", CTA_ALARM, nil, nil, sg_hiddenArmy, 30, "icons/cta/illustrations/enemy_army_has_entered_off_map")--The French have launched a Counterattack!
		
		Cmd_FormationAttackMove(sg_hiddenArmy, mkr_counterattack2, false)
		Cmd_FormationAttackMove(sg_hiddenArmy, mkr_counterattack3, true)
		Cmd_FormationAttackMove(sg_hiddenArmy, mkr_counterattack4, true)
		Cmd_FormationAttackMove(sg_hiddenArmy, mkr_playerBase, true)
		UI_CreateMinimapBlip(Util_GetPosition(sg_hiddenArmy), 1, "threat_group")
		--reveal group
		FOW_PlayerRevealSGroup(localPlayer, sg_hiddenArmy, 10, -1)
	end
	
end


function HC_Agincourt_SpawnAgincourtRaid()
	
	if(agincourtTownAlive == false) then
		Rule_RemoveMe()
		return
	end
	
	if(conquerorModeActivated == true) then
		SGroup_Clear(sg_AgincourtRaiders)
		local sbp_horsemen_fre = SBP.FRENCH.UNIT_HORSEMAN_3_FRE
		UnitEntry_DeploySquads(enemyPlayer, sg_AgincourtRaiders, {sbp = sbp_horsemen_fre, numSquads = 5 }, mkr_Agincourt_spawn1)
		
		Cmd_FormationAttackMove(sg_AgincourtRaiders, mkr_playerBase, false)
	else
		SGroup_Clear(sg_AgincourtRaiders)
		local sbp_horsemen_fre = SBP.FRENCH.UNIT_HORSEMAN_2_FRE
		UnitEntry_DeploySquads(enemyPlayer, sg_AgincourtRaiders, {sbp = sbp_horsemen_fre, numSquads = 3 }, mkr_Agincourt_spawn1)
		
		Cmd_FormationAttackMove(sg_AgincourtRaiders, mkr_playerBase, false)
	end
end

function HC_Agincourt_SpawnTramecourtRaid()
	
	if(tramecourtTownAlive == false) then
		Rule_RemoveMe()
		return
	end
	
	--use existing defenders before spawning in new units
	if(conquerorModeActivated == true) then
		SGroup_Clear(sg_TramecourtRaiders)
		if(SGroup_CountSpawned(sg_tramecourtDefenders) >= 5) then
			sg_TramecourtRaiders = SGroup_GetClosestSquads(sg_tramecourtDefenders, 5, Util_GetPosition(mkr_playerBase))
		else
			local sbp_crossbowmen_fre = SBP.FRENCH.UNIT_CROSSBOWMAN_3_FRE
			UnitEntry_DeploySquads(enemyPlayer, sg_TramecourtRaiders, {sbp = sbp_crossbowmen_fre, numSquads = 4 }, mkr_Tramecourt_spawn1)
		end
		Cmd_FormationAttackMove(sg_TramecourtRaiders, mkr_playerBase, false)
	else
		SGroup_Clear(sg_TramecourtRaiders)
		if(SGroup_CountSpawned(sg_tramecourtDefenders) >= 3) then
			sg_TramecourtRaiders = SGroup_GetClosestSquads(sg_tramecourtDefenders, 3, Util_GetPosition(mkr_playerBase))
		else
			local  sbp_crossbowmen_fre = SBP.FRENCH.UNIT_CROSSBOWMAN_3_FRE
			UnitEntry_DeploySquads(enemyPlayer, sg_TramecourtRaiders, {sbp = sbp_crossbowmen_fre, numSquads = 2 }, mkr_Tramecourt_spawn1)
		end
		Cmd_FormationAttackMove(sg_TramecourtRaiders, mkr_playerBase, false)
	end
	
end

