function HC_Agincourt_IntroSetup4()
	
	local cannonProgressOffset = .065 -- the distance to offset the cannon and defensive circle behind the wave target
	
	Player_ResetAbilityCooldowns(enemyPlayer, ABILITY.DEPLOY_PAVISE_FRE)
	
	for i = 1, SGroup_CountSpawned(sg_enemyRow3_defenders1) do
		local squad = SGroup_GetSquadAt(sg_enemyRow3_defenders1, i)
		SGroup_Single(sg_single, squad)
		if(SGroup_CountSpawned(sg_single) > 0) then
			local squadPos = Util_GetPosition(sg_single)
			Cmd_Ability(sg_single, ABILITY.DEPLOY_PAVISE_FRE, squadPos, nil, true)
		end
	end
	HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_cannon1, 1, introAdvance3Amount - cannonProgressOffset, true, true, false, false, true)
	
	for i = 1, SGroup_CountSpawned(sg_enemyRow3_defenders3) do
		local squad = SGroup_GetSquadAt(sg_enemyRow3_defenders3, i)
		SGroup_Single(sg_single, squad)
		if(SGroup_CountSpawned(sg_single) > 0) then
			local squadPos = Util_GetPosition(sg_single)
			Cmd_Ability(sg_single, ABILITY.DEPLOY_PAVISE_FRE, squadPos, nil, true)
		end
	end
	HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_cannon3, 3, introAdvance3Amount - cannonProgressOffset, true, true, false, false, true)
	
	for i = 1, SGroup_CountSpawned(sg_enemyRow3_defenders5) do
		local squad = SGroup_GetSquadAt(sg_enemyRow3_defenders5, i)
		SGroup_Single(sg_single, squad)
		if(SGroup_CountSpawned(sg_single) > 0) then
			local squadPos = Util_GetPosition(sg_single)
			Cmd_Ability(sg_single, ABILITY.DEPLOY_PAVISE_FRE, squadPos, nil, true)
		end
	end
	HC_Agincourt_Wave3_SendBackToLane(sg_enemyRow3_cannon5, 5, introAdvance3Amount - cannonProgressOffset, true, true, false, false, true)
	
	
	
end



