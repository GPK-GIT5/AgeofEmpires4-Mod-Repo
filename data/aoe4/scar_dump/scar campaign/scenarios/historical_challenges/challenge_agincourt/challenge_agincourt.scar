function HC_Agincourt_IntroTeardown()
	
	-- Get rid of all those units so that gameplay units can be spawned
	SGroup_DestroyAllSquads(sg_frenchIntroUnits)
	
	-- Get rid of SGroups we won't need anymore
	SGroup_Destroy(sg_frenchIntroUnits)
	SGroup_Destroy(sg_intro_raiders_1)
	SGroup_Destroy(sg_intro_raiders_2)
	
	--remove reticules
	if(cannonReticuleID1 ~= nil) then
		UI_ModalVisual_Destroy(cannonReticuleID1)
	end
	if(cannonReticuleID3 ~= nil) then
		UI_ModalVisual_Destroy(cannonReticuleID3)
	end
	if(cannonReticuleID5 ~= nil) then
		UI_ModalVisual_Destroy(cannonReticuleID5)
	end
	
	--reset ability cooldown
	Player_ResetAbilityCooldowns(localPlayer, ABILITY.YEOMAN_SYNCHRONIZED_LAN)
	
	--remove one shot functions if they haven't been called
	Rule_Remove(HC_Agincourt_IntroSetup2)
