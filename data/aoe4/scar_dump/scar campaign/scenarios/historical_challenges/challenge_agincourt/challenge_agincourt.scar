function Mission_SetupVariables()
	
	-- Bools
	
	conquerorModeActivated = false
	conquerorModeFailed = false
	agincourtSpawnsActive = true
	tramecourtSpawnsActive = true
	agincourtTownAlive = true
	tramecourtTownAlive = true
	prison1Freed = false
	goldMedalFailed = false
	silverMedalFailed = false
	earlyReinforcementsAdded = false
	middleReinforcementsAdded = false
	goldReinforcementsAdded = false
	silverReinforcementsAdded = false
	
	-- Ints
	LANE_MAX_WIDTH = 40
	GOLD_MEDAL_TIME = 16 * 60
	SILVER_MEDAL_TIME = 20 * 60
	henryVBonusHealth = 150
	
	-- Floats
	startTime = 0
	
	-- Sgroups 

	-- Other
	sbp_king_lan = SBP.LANCASTER.UNIT_HENRY_5_CMP_LAN
	
	--for testing army scripting
	showDebugObjectives1 = false
	showDebugObjectives2 = false
	
end

function Mission_SetupPlayers()
	
	PlayerColour_Enable() -- turn on custom colour configuration for this session
	
	-- Set up Players
	player1 = Missionomatic_InitPlayer(1, { name = "$11265366", currentAge = AGE_FEUDAL, maxAge = AGE_IMPERIAL })--House of Lancaster
	player2 = Missionomatic_InitPlayer(2, { name = "$11201649", currentAge = AGE_CASTLE, maxAge = AGE_IMPERIAL })--French
	player3 = Missionomatic_InitPlayer(3, { name = "$11265366", currentAge = AGE_CASTLE, maxAge = AGE_IMPERIAL })
	player4 = Missionomatic_InitPlayer(4, { name = "$11201649", currentAge = AGE_IMPERIAL, maxAge = AGE_IMPERIAL })
	player5 = Missionomatic_InitPlayer(5, { name = "$11201649", currentAge = AGE_IMPERIAL, maxAge = AGE_IMPERIAL })
	player6 = Missionomatic_InitPlayer(6, { name = "$11201649", currentAge = AGE_FEUDAL, maxAge = AGE_IMPERIAL })
	player7 = Missionomatic_InitPlayer(7, { name = "$11265366", currentAge = AGE_FEUDAL, maxAge = AGE_IMPERIAL })
	player8 = Missionomatic_InitPlayer(8, { name = "$11201649", currentAge = AGE_FEUDAL, maxAge = AGE_IMPERIAL })
	
	-- Create player references
	localPlayer = World_GetPlayerAt(1) --Player
	enemyPlayer = World_GetPlayerAt(2) --enemy AI player
	allyPlayer = World_GetPlayerAt(3) --ally AI player
	enemyPlayer2 = World_GetPlayerAt(4) --enemy AI player 2 (fully upgraded units)
	enemyPlayer3 = World_GetPlayerAt(5) --enemy AI player 3 (debuffed units)
	enemyPatrolPlayer = World_GetPlayerAt(6) --player for the downed player leader
	capturedUnitsPlayer = World_GetPlayerAt(7)
	enemyCannonPlayer = World_GetPlayerAt(8)
	
	Game_SetPlayerColour(enemyPlayer, COLOR_RED)
	Game_SetPlayerColour(enemyPlayer2, COLOR_RED)
	Game_SetPlayerColour(enemyPlayer3, COLOR_RED)
	Game_SetPlayerColour(enemyPatrolPlayer, COLOR_RED)
	Game_SetPlayerColour(enemyCannonPlayer, COLOR_RED)
	
	
	--override condensed objectives setting to ensure objectives are visible
	UI_SetPlayerDataContext(player1, { hide_condensed_objectives_override = true})
end

function Mission_SetRestrictions()
	
	
	Player_CompleteUpgrade(localPlayer, UPG.LANCASTER.UPGRADE_SYNCHRONIZEDSHOT_LAN)
	Player_CompleteUpgrade(localPlayer, UPG.LANCASTER.UPGRADE_BILLMEN_LAN)
	Player_CompleteUpgrade(localPlayer, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_2)
	Player_CompleteUpgrade(localPlayer, UPG.COMMON.UPGRADE_RANGED_DAMAGE_I)
	Player_CompleteUpgrade(localPlayer, UPG.COMMON.UPGRADE_MELEE_ARMOR_I)
	
	Player_CompleteUpgrade(enemyPlayer, UPG.COMMON.UPGRADE_ECON_RESOURCE_WOOD_FELL_RATE_1)
	Player_CompleteUpgrade(enemyPlayer, UPG.COMMON.UPGRADE_ECON_RESOURCE_WOOD_HARVEST_RATE_2)
	Player_CompleteUpgrade(enemyPlayer, UPG.COMMON.UPGRADE_ECON_RESOURCE_WOOD_HARVEST_RATE_3)
	Player_CompleteUpgrade(enemyPlayer, UPG.COMMON.UPGRADE_ECON_RESOURCE_WOOD_HARVEST_RATE_4)
	
	Player_SetEntityProductionAvailability(localPlayer, EBP.LANCASTER.BUILDING_DEFENSE_PALISADE_LAN, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(localPlayer, EBP.LANCASTER.BUILDING_DEFENSE_PALISADE_GATE_LAN, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(localPlayer, EBP.LANCASTER.BUILDING_DEFENSE_WALL_LAN, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(localPlayer, EBP.LANCASTER.BUILDING_DEFENSE_WALL_GATE_LAN, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(localPlayer, EBP.LANCASTER.BUILDING_DEFENSE_TOWER_LAN, ITEM_REMOVED)
	Player_SetEntityProductionAvailability(localPlayer, EBP.LANCASTER.BUILDING_UNIT_DOCK_LAN, ITEM_REMOVED)
	
end


function ChallengeMission_SetupDiplomacy()
	
	
	Player_SetRelationship(enemyPlayer, allyPlayer, R_ALLY)
	Player_SetRelationship(allyPlayer, enemyPlayer, R_ENEMY)
	
	Player_SetRelationship(enemyPlayer2, allyPlayer, R_ALLY)
	Player_SetRelationship(allyPlayer, enemyPlayer2, R_ENEMY)
	
	
	Player_SetRelationship(enemyPlayer, capturedUnitsPlayer, R_ALLY)
	Player_SetRelationship(capturedUnitsPlayer, enemyPlayer, R_ALLY)
	Player_SetRelationship(enemyPatrolPlayer, capturedUnitsPlayer, R_NEUTRAL)
	Player_SetRelationship(capturedUnitsPlayer, enemyPatrolPlayer, R_NEUTRAL)
	Player_SetRelationship(localPlayer, capturedUnitsPlayer, R_ALLY)
	Player_SetRelationship(capturedUnitsPlayer, localPlayer, R_ALLY)
	World_EnableSharedLineOfSight(localPlayer, capturedUnitsPlayer, false)
	
	
	Player_SetRelationship(enemyPlayer3, localPlayer, R_ALLY)
	Player_SetRelationship(localPlayer, enemyPlayer3, R_ENEMY)
	
	
	Player_SetRelationship(enemyCannonPlayer, localPlayer, R_NEUTRAL)
	Player_SetRelationship(localPlayer, enemyCannonPlayer, R_ENEMY)
	-----
	
end

function Mission_PreInit()
	
	
	Rule_AddGlobalEvent(HC_Agincourt_OnSquadKilled, GE_SquadKilled)
	Rule_AddGlobalEvent(HC_Agincourt_OnDestruction, GE_EntityKilled)
	Rule_AddGlobalEvent(HC_Agincourt_OnProjectileFired, GE_ProjectileFired)
	Rule_AddGlobalEvent(HC_Agincourt_OnAbilityExecuted, GE_AbilityExecuted)
	
	
end

function Mission_Preset()
	
	ChallengeMission_SetupDiplomacy()
	
end


function Mission_Start()
	
	startTime = World_GetGameTime()
	-- Initialize Objectives 
	HC_Agincourt_InitObjectives()
	

	Rule_AddInterval(HC_Agincourt_Update, 0.125)
	
	
	-- Set starting resources
	Player_SetResource(localPlayer, RT_Food, 500)		
	Player_SetResource(localPlayer, RT_Wood, 600)
	Player_SetResource(localPlayer, RT_Gold, 300)
	Player_SetResource(localPlayer, RT_Stone, 300)
	
	--set landmarks to be rebuildable
	Player_SetStateModelBool(localPlayer, "disable_landmark_rebuild", false)
	
	
	if(playerCapital == nil) then
		playerCapital = EGroup_GetEntityAt(eg_capitalTC, 1)
	end
	
	
	if(enemyTC1 == nil) then
		enemyTC1 = EGroup_GetEntityAt(eg_enemyTC1, 1)
	end
	if(enemyTC2 == nil) then
		enemyTC2 = EGroup_GetEntityAt(eg_enemyTC2, 1)
	end
	
	Objective_AddUIElements(SOBJ_Defend, eg_capitalTC, false, "$11268422", true, 3)--Defend Your Capital Town Center
	
	-- Re-spawn the French army, with objective setup this time
	-- Player and Gaia units should already have been spawned for the intro camera
	HC_Agincourt_SpawnFrenchArmy()
	
	HC_Agincourt_InitObjectiveUI()
	
	--activate starting units
	Cmd_Move(sg_playerScout1, mkr_PlayerSpawn5Dest, false)
	Cmd_Move(sg_playerScout2, mkr_PlayerSpawn6Dest, false)
	
	
	--temp functions for testing
	--FOW_RevealAll()
	--Rule_AddOneShot(test_destroyWave1, 10)
	--Rule_AddOneShot(test_destroyWave2, 20)
end

function test_destroyWave1()
	
	SGroup_Kill(sg_wave1_AllUnits)
	SGroup_Kill(sg_enemyRow1_leader)
end
function test_destroyWave2()
	
	SGroup_Kill(sg_wave2_AllUnits)
	SGroup_Kill(sg_enemyRow2_leader)
	SGroup_Kill(sg_enemyRow2_leader2)
end

