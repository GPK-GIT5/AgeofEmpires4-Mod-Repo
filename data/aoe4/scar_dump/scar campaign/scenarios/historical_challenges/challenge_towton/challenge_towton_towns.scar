		townDataTable[i].reinforcementGroup = SGroup_CreateIfNotFound("sg_reinforcements"..tostring(i))
		townDataTable[i].patrolGroup = SGroup_CreateIfNotFound("patrolGroup"..tostring(i))
	end
	
	HC_Towton_InitDefensiveOutposts()
	
	Rule_AddInterval(HC_Towton_UpdateTowns, 15)
	Rule_AddInterval(HC_Towton_UpdateTownDefenders, 5)
	
