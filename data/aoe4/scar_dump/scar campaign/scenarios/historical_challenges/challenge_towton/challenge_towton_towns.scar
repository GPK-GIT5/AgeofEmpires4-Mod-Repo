	townDataTable[currentTownIndex].beaconMkr = mkr_beaconSE
	townDataTable[currentTownIndex].beaconTowerMarkers = {mkr_towerSE1, mkr_towerSE2, mkr_towerSE3}
	HC_Towton_InitBeacon(currentTownIndex)
	
	--make beacon unselectable
	EGroup_SetSelectable(townDataTable[currentTownIndex].beacon, false)
	
	--set up manual patrol points
	townDataTable[currentTownIndex].patrolMarkers = {mkr_townSE1, mkr_townSE2}
	
	params = {
		player = allyPlayer,
		name = "townArmy_"..tostring(currentTownIndex),
		spawn = mkr_townSE,
		targets = {mkr_townSE1, mkr_townSE2},
		onDeathReset = true,
		targetOrder = TARGET_ORDER_PATROL,
		leashBuffer = 30,
	}
	townDataTable[currentTownIndex].army = Army_Init(params)
	-------------------------------
	-------------------------------
	currentTownIndex = 3
