		local transportSquad = SGroup_GetSquadAt(sg_alliedTransportsNE, i)
		
		Squad_GetSquadsHeld(transportSquad, sg_squadsHeld)
		if(SGroup_CountSpawned(sg_squadsHeld) > 0) then
			--send transport to shore
			SGroup_Single(sg_single, transportSquad)
			Cmd_Move(sg_single, mkr_reinforcement_NE_landing, false)
			--unload transport
			Cmd_UngarrisonSquad(sg_squadsHeld, mkr_reinforcement_NE_landing, true)
			Cmd_Move(sg_squadsHeld, mkr_reinforcement_NE_rally1, true)
			Cmd_AttackMove(sg_squadsHeld, mkr_townNE, true)
		else
			--send empty transport away
			SGroup_Single(sg_single, transportSquad)
			Cmd_Move(sg_single, mkr_reinforcement_NE_spawn, false)
			Cmd_Move(sg_single, mkr_reinforcement_NE_spawn, true, true)
			--remove empty transport
			SGroup_Remove(sg_alliedTransportsNE, transportSquad)
		end
	end
	
	SGroup_GetSquadsHeld(sg_alliedTransportsNE, sg_squadsHeld)
	
	if(SGroup_CountSpawned(sg_squadsHeld) == 0) then
		Rule_RemoveMe()
	end
end
