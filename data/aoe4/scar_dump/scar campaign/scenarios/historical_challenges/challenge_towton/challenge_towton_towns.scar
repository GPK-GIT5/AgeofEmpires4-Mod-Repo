function HC_Towton_StartUnloadAlliedTransportsNW()
	Rule_AddInterval(HC_Towton_UnloadAlliedTransportsNW, .5)
	--add objective showing reinforcements
	Objective_Register(SOBJ_ReinforcementsNW)
	Objective_Start(SOBJ_ReinforcementsNW)
end

function HC_Towton_UnloadAlliedTransportsNW()
	sg_squadsHeld = SGroup_CreateIfNotFound("sg_squadsHeld")
	for i = SGroup_CountSpawned(sg_alliedTransportsNW), 1, -1 do 
		local transportSquad = SGroup_GetSquadAt(sg_alliedTransportsNW, i)
		
		Squad_GetSquadsHeld(transportSquad, sg_squadsHeld)
		if(SGroup_CountSpawned(sg_squadsHeld) > 0) then
			--send transport to shore
			SGroup_Single(sg_single, transportSquad)
			Cmd_Move(sg_single, mkr_reinforcement_NW_landing, false)
			--unload transport
			Cmd_UngarrisonSquad(sg_squadsHeld, mkr_reinforcement_NW_landing, true)
			Cmd_Move(sg_squadsHeld, mkr_reinforcement_NW_rally1, true)
			Cmd_AttackMove(sg_squadsHeld, mkr_townNW, true)
		else
			--send empty transport away
			SGroup_Single(sg_single, transportSquad)
			Cmd_Move(sg_single, mkr_reinforcement_NW_spawn, false)
			Cmd_Move(sg_single, mkr_reinforcement_NW_spawn, true, true)
			--remove empty transport
			SGroup_Remove(sg_alliedTransportsNW, transportSquad)
		end
	end
	
	SGroup_GetSquadsHeld(sg_alliedTransportsNW, sg_squadsHeld)
	
	if(SGroup_CountSpawned(sg_squadsHeld) == 0) then
		Rule_RemoveMe()
	end
end

function HC_Towton_StartUnloadAlliedTransportsNE()
	Rule_AddInterval(HC_Towton_UnloadAlliedTransportsNE, .5)
	--add objective showing reinforcements
	Objective_Register(SOBJ_ReinforcementsNE)
