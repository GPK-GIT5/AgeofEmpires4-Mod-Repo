function HC_Towton_InitTowns()
	
	townDataTable = {}
	--create table entry for each town
	for i = 1, 8 do
		townDataTable[i] = {army = nil, armyMakeup = nil, manor = nil, manorMkr = nil, manorDestroyed = false, 
			beacon = nil, beaconLit = false, beaconFires = nil, beaconMkr = nil, beaconTowerMarkers = nil, 
		reinforcementGroup = nil, patrolGroup = nil, currentPatrolPoint = 1, patrolMarkers = nil}
	end
	
	
	local sbp_spearman1 = SBP.LANCASTER.UNIT_SPEARMAN_1_LAN
	local sbp_yeoman2 = SBP.LANCASTER.UNIT_YEOMAN_2_LAN
	local sbp_hobelar2 = SBP.LANCASTER.UNIT_HOBELAR_2_LAN
	local sbp_monk = SBP.LANCASTER.UNIT_MONK_3_LAN
	local sbp_earlsGuard = SBP.LANCASTER.UNIT_EARLSGUARD_3_LAN
	
	sg_reinforceArmyUnits = SGroup_CreateIfNotFound("sg_reinforceArmyUnits")
	eg_manorGroup = EGroup_CreateIfNotFound("eg_manorGroup")
	
	local bp_reticule = BP_GetReticuleBlueprint("marquee")
	
	-------------------------------
	local currentTownIndex = 1
	--set up NorthEast town (1)
	armyMakeup = {}
	armyMakeup[1] = {unitBP = sbp_earlsGuard, desiredCount = 1, currentCount = 0, spawnMarker = mkr_manorNE}
	armyMakeup[2] = {unitBP = sbp_spearman1, desiredCount = 7, currentCount = 0, spawnMarker = mkr_manorNE}
	armyMakeup[3] = {unitBP = sbp_monk, desiredCount = 2, currentCount = 0, spawnMarker = mkr_manorNE}
	townDataTable[currentTownIndex].armyMakeup = armyMakeup
	
	--add manors to table
	townDataTable[currentTownIndex].manor = EGroup_CreateIfNotFound("eg_manorGroup"..tostring(currentTownIndex))
	townDataTable[currentTownIndex].manorMkr = mkr_manorNE
	Player_GetAllEntitiesNearMarker(allyPlayer, townDataTable[currentTownIndex].manor, mkr_manorNE)
	--make manor untargetable until half of buildings are destroyed
	EGroup_SetTargetingType(townDataTable[currentTownIndex].manor, Targeting_None)
	
	--add beacons to table (these egroups are defined in scenario data, outside of scar files)
	townDataTable[currentTownIndex].beacon = eg_beaconNE
	townDataTable[currentTownIndex].beaconMkr = mkr_beaconNE
	townDataTable[currentTownIndex].beaconTowerMarkers = {mkr_towerNE1, mkr_towerNE2, mkr_towerNE3}
	HC_Towton_InitBeacon(currentTownIndex)
	
	--make beacon unselectable
	EGroup_SetSelectable(townDataTable[currentTownIndex].beacon, false)
	
	--set up manual patrol points
	townDataTable[currentTownIndex].patrolMarkers = {mkr_townNE1, mkr_townNE2}
	
	params = {
		player = allyPlayer,
		name = "townArmy_"..tostring(currentTownIndex),
		spawn = mkr_townNE,
		targets = {mkr_townNE1, mkr_townNE2},
		onDeathReset = true,
		targetOrder = TARGET_ORDER_PATROL,
		leashBuffer = 30,
	}
	townDataTable[currentTownIndex].army = Army_Init(params)
	-------------------------------
	-------------------------------
	currentTownIndex = 2
	--set up SouthEast town (2)
	armyMakeup = {}
	armyMakeup[1] = {unitBP = sbp_earlsGuard, desiredCount = 1, currentCount = 0, spawnMarker = mkr_manorSE}
	armyMakeup[2] = {unitBP = sbp_spearman1, desiredCount = 5, currentCount = 0, spawnMarker = mkr_manorSE}
	armyMakeup[3] = {unitBP = sbp_yeoman2, desiredCount = 5, currentCount = 0, spawnMarker = mkr_manorSE}
	townDataTable[currentTownIndex].armyMakeup = armyMakeup
	
	--add manors to table
	townDataTable[currentTownIndex].manor = EGroup_CreateIfNotFound("eg_manorGroup"..tostring(currentTownIndex))
	townDataTable[currentTownIndex].manorMkr = mkr_manorSE
	Player_GetAllEntitiesNearMarker(allyPlayer, townDataTable[currentTownIndex].manor, mkr_manorSE)
	--make manor untargetable until half of buildings are destroyed
	EGroup_SetTargetingType(townDataTable[currentTownIndex].manor, Targeting_None)
	
	--add beacons to table (these egroups are defined in scenario data, outside of scar files)
