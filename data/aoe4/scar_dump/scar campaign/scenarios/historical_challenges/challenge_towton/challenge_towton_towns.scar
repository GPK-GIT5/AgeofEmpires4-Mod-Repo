	armyMakeup = {}
	armyMakeup[1] = {unitBP = sbp_earlsGuard, desiredCount = 1, currentCount = 0, spawnMarker = mkr_manorSW}
	armyMakeup[2] = {unitBP = sbp_hobelar2, desiredCount = 4, currentCount = 0, spawnMarker = mkr_manorSW}
	armyMakeup[3] = {unitBP = sbp_spearman1, desiredCount = 2, currentCount = 0, spawnMarker = mkr_manorSW}
	townDataTable[currentTownIndex].armyMakeup = armyMakeup
	
	--add manors to table
	townDataTable[currentTownIndex].manor = EGroup_CreateIfNotFound("eg_manorGroup"..tostring(currentTownIndex))
	townDataTable[currentTownIndex].manorMkr = mkr_manorSW
	Player_GetAllEntitiesNearMarker(allyPlayer, townDataTable[currentTownIndex].manor, mkr_manorSW)
	--make manor untargetable until half of buildings are destroyed
	EGroup_SetTargetingType(townDataTable[currentTownIndex].manor, Targeting_None)
	
	--add beacons to table (these egroups are defined in scenario data, outside of scar files)
	townDataTable[currentTownIndex].beacon = eg_beaconSW
	townDataTable[currentTownIndex].beaconMkr = mkr_beaconSW
	townDataTable[currentTownIndex].beaconTowerMarkers = {mkr_towerSW1, mkr_towerSW2, mkr_towerSW3}
	HC_Towton_InitBeacon(currentTownIndex)
	
	--make beacon unselectable
	EGroup_SetSelectable(townDataTable[currentTownIndex].beacon, false)
	
	--set up manual patrol points
	townDataTable[currentTownIndex].patrolMarkers = {mkr_townSW1, mkr_townSW2}
	
	params = {
		player = allyPlayer,
		name = "townArmy_"..tostring(currentTownIndex),
		spawn = mkr_townSW,
		targets = {mkr_townSW1, mkr_townSW2},
		onDeathReset = true,
		targetOrder = TARGET_ORDER_PATROL,
		leashBuffer = 30,
	}
	townDataTable[currentTownIndex].army = Army_Init(params)
	-------------------------------
	-------------------------------
	currentTownIndex = 4
	--set up NorthWest town (4)
	armyMakeup = {}
	armyMakeup[1] = {unitBP = sbp_earlsGuard, desiredCount = 1, currentCount = 0, spawnMarker = mkr_manorNW}
	armyMakeup[2] = {unitBP = sbp_yeoman2, desiredCount = 6, currentCount = 0, spawnMarker = mkr_manorNW}
	armyMakeup[3] = {unitBP = sbp_spearman1, desiredCount = 4, currentCount = 0, spawnMarker = mkr_manorNW}
	townDataTable[currentTownIndex].armyMakeup = armyMakeup
	
	--add manors to table
	townDataTable[currentTownIndex].manor = EGroup_CreateIfNotFound("eg_manorGroup"..tostring(currentTownIndex))
	townDataTable[currentTownIndex].manorMkr = mkr_manorNW
	Player_GetAllEntitiesNearMarker(allyPlayer, townDataTable[currentTownIndex].manor, mkr_manorNW)
	--make manor untargetable until half of buildings are destroyed
	EGroup_SetTargetingType(townDataTable[currentTownIndex].manor, Targeting_None)
	
	--add beacons to table (these egroups are defined in scenario data, outside of scar files)
	townDataTable[currentTownIndex].beacon = eg_beaconNW
	townDataTable[currentTownIndex].beaconMkr = mkr_beaconNW
	townDataTable[currentTownIndex].beaconTowerMarkers = {mkr_towerNW1, mkr_towerNW2, mkr_towerNW3}
	HC_Towton_InitBeacon(currentTownIndex)
	
	--make beacon unselectable
	EGroup_SetSelectable(townDataTable[currentTownIndex].beacon, false)
	
	--set up manual patrol points
	townDataTable[currentTownIndex].patrolMarkers = {mkr_townNW1, mkr_townNW2}
	
	params = {
		player = allyPlayer,
		name = "townArmy_"..tostring(currentTownIndex),
		spawn = mkr_townNW,
		targets = {mkr_townNW1, mkr_townNW2},
		onDeathReset = true,
		targetOrder = TARGET_ORDER_PATROL,
		leashBuffer = 30,
	}
	townDataTable[currentTownIndex].army = Army_Init(params)
	-------------------------------
	-------------------------------
	currentTownIndex = 5
	--set up North Beacon (5)
	
	--add beacons to table (these egroups are defined in scenario data, outside of scar files)
	townDataTable[currentTownIndex].beacon = eg_beaconN
	townDataTable[currentTownIndex].beaconMkr = mkr_beaconN
	townDataTable[currentTownIndex].beaconTowerMarkers = {mkr_towerN1, mkr_towerN2}
	HC_Towton_InitBeacon(currentTownIndex)
	
	--add reticule to beacon
	beaconNorthReticuleID = UI_ModalVisual_CreateReticule(bp_reticule, 5)
	UI_ModalVisual_SetPosition(beaconNorthReticuleID, Util_GetPosition(townDataTable[currentTownIndex].beaconMkr))
	
	-------------------------------
	-------------------------------
	currentTownIndex = 6
	--set up South Beacon (6)
	
	--add beacons to table (these egroups are defined in scenario data, outside of scar files)
	townDataTable[currentTownIndex].beacon = eg_beaconS
	townDataTable[currentTownIndex].beaconMkr = mkr_beaconS
	townDataTable[currentTownIndex].beaconTowerMarkers = {mkr_towerS1}
