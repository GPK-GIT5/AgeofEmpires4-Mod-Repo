	enemyWavePattern[waveIndex] = {waveMakeup = enemyWaveMakeup, path = 1, isConqueror = false, spawnTime = waveTime, spawned = false, ctaScreen = nil}
	
	-----------------------------------------------------------------------------------------------
	--final boss wave (top right base)
	-----------------------------------------------------------------------------------------------
	waveTime = phase5StartTime + 10
	waveIndex = waveIndex + 1
	enemyWaveMakeup = {}
	enemyWaveMakeup[1] = {waveUnitBP = sbp_spearman4, waveUnitMultiplier = .4}
	enemyWaveMakeup[2] = {waveUnitBP = sbp_archer4, waveUnitMultiplier = .3}
	enemyWaveMakeup[3] = {waveUnitBP = sbp_manatarms4, waveUnitMultiplier = .4}
	enemyWaveMakeup[4] = {waveUnitBP = sbp_knight4, waveUnitMultiplier = .4}
	enemyWaveMakeup[5] = {waveUnitBP = sbp_crossbow4, waveUnitMultiplier = .4}
	enemyWaveMakeup[6] = {waveUnitBP = sbp_mangonel, waveUnitMultiplier = .15}
	enemyWaveMakeup[7] = {waveUnitBP = sbp_treb, waveUnitMultiplier = .1}
	enemyWaveMakeup[8] = {waveUnitBP = sbp_ribauldequin, waveUnitMultiplier = .05}
	enemyWaveMakeup[9] = {waveUnitBP = sbp_bombard, waveUnitMultiplier = .05}
	enemyWaveMakeup[10] = {waveUnitBP = sbp_leader, waveUnitMultiplier = .0001}
	enemyWavePattern[waveIndex] = {waveMakeup = enemyWaveMakeup, path = 5, isConqueror = false, spawnTime = waveTime, spawned = false, ctaScreen = iconPath_boss}
	
	
	Rule_AddInterval(HC_Towton_UpdateWaves, .5)
	Rule_AddInterval(HC_Towton_UpdateWaveSiege, 5)
	--delay start of these functions so they don't all hit at the same time
	Rule_AddOneShot(HC_Towton_DelayedStartUpdates1, 1)
	Rule_AddOneShot(HC_Towton_DelayedStartUpdates2, 2)
	
	Rule_AddInterval(HC_Towton_PulseThreatBlip, 5)
end

function HC_Towton_DelayedStartUpdates1()
	
	Rule_AddInterval(HC_Towton_UpdateWaveRaiders, 5)
	
end

function HC_Towton_DelayedStartUpdates2()
	
	Rule_AddInterval(HC_Towton_UpdateWaveSiegeWest, 5)
	Rule_AddInterval(HC_Towton_UpdateWaveSiegeEast, 5)
	
end

function HC_Towton_UpdateWaveSiege()
	--remove siege units from the army once they get close to the player's stone walls so they don't get stuck
	for i = 1, #enemyWavePattern do 
		if(enemyWavePattern[i].spawned == true) then
			waveObject = enemyWavePattern[i].army
			if(waveObject ~= nil) then
				if(Army_GetSGroup(waveObject) ~= nil ) then
					sg_waveSiegeUnits = SGroup_CreateIfNotFound("sg_waveSiegeUnits")
					SGroup_Clear(sg_waveSiegeUnits)
					SGroup_AddGroup(sg_waveSiegeUnits, Army_GetSGroup(waveObject))
					--filter siege units that have entered into the middle area
					SGroup_Filter(sg_waveSiegeUnits, "siege", FILTER_KEEP)
					SGroup_Filter(sg_waveSiegeUnits, "ram", FILTER_REMOVE)
					
					local realPath = enemyWavePattern[i].path
					--convert from alternate paths to main paths
					if(realPath > 5) then
						realPath = realPath - 5
					end
					
					if(realPath == 1 or realPath == 2 or realPath == 5) then
						SGroup_FilterByProximity(sg_waveSiegeUnits, mkr_townE, FILTER_KEEP)
					end
					if(realPath == 3 or realPath == 4) then
						SGroup_FilterByProximity(sg_waveSiegeUnits, mkr_townW, FILTER_KEEP)
					end
					
					if(SGroup_CountSpawned(sg_waveSiegeUnits) > 0) then
						--remove these siege units from the army
						Army_RemoveSGroup(enemyWavePattern[i].army, sg_waveSiegeUnits)
						--send siege units on a simple attack move order
						if(realPath == 1 or realPath == 2 or realPath == 5) then
							SGroup_AddGroup(sg_waveSiegeUnitsE, sg_waveSiegeUnits)
						end
						if(realPath == 3 or realPath == 4) then
							SGroup_AddGroup(sg_waveSiegeUnitsW, sg_waveSiegeUnits)
						end
					end
				end
			end
		end
	end
end

function HC_Towton_UpdateWaveRaiders()
	--every few seconds, remove some melee units from armies once they get close to the allied town
	--if it is a side path, always remove all melee units in range
	--this is important to be able to lower the player's score in the early part of the game without them losing all their units defending the town
	for i = 1, #enemyWavePattern do 
		if(enemyWavePattern[i].spawned == true) then
			
			local realPath = enemyWavePattern[i].path
			local isSidePath = false
			--convert from alternate paths to main paths
			if(realPath > 5) then
				realPath = realPath - 5
				isSidePath = true
			end
			
			--do not split off any units if this is the final boss wave
			if(realPath ~= 5) then
				
				--check if any allied buildings are remaining
				local isTownDestroyed = false
				if(realPath == 4 and EGroup_CountSpawned(eg_townNW) == 0) then
					isTownDestroyed = true
				end
				if(realPath == 3 and EGroup_CountSpawned(eg_townSW) == 0) then
					isTownDestroyed = true
				end
				if(realPath == 2 and EGroup_CountSpawned(eg_townSE) == 0) then
					isTownDestroyed = true
				end
				if(realPath == 1 and EGroup_CountSpawned(eg_townNE) == 0) then
					isTownDestroyed = true
				end
				
				if(enemyWavePattern[i].army ~= nil) then
					if(Army_GetSGroup(enemyWavePattern[i].army) ~= nil ) then
						
						if(SGroup_CountSpawned(Army_GetSGroup(enemyWavePattern[i].army)) > 0 and isTownDestroyed == false) then
							
							sg_tempRaiders = SGroup_CreateIfNotFound("sg_tempRaiders")
							SGroup_Clear(enemyWavePattern[i].sg_removeFromArmy)
							SGroup_AddGroup(enemyWavePattern[i].sg_removeFromArmy, Army_GetSGroup(enemyWavePattern[i].army))
							--filter out ranged units and rams
							SGroup_Filter(enemyWavePattern[i].sg_removeFromArmy, "ranged", FILTER_REMOVE)
							SGroup_Filter(enemyWavePattern[i].sg_removeFromArmy, "ram", FILTER_REMOVE)
							
							if(realPath == 1) then
								SGroup_FilterByProximity(enemyWavePattern[i].sg_removeFromArmy, mkr_townNE, FILTER_KEEP, 50)
							end
							if(realPath == 2) then
								SGroup_FilterByProximity(enemyWavePattern[i].sg_removeFromArmy, mkr_townSE, FILTER_KEEP, 50)
							end
							if(realPath == 3) then
								SGroup_FilterByProximity(enemyWavePattern[i].sg_removeFromArmy, mkr_townSW, FILTER_KEEP, 50)
							end
							if(realPath == 4) then
								SGroup_FilterByProximity(enemyWavePattern[i].sg_removeFromArmy, mkr_townNW, FILTER_KEEP, 50)
							end
							
							--separate only up to 2 units if the wave is not on a side path
							if(isSidePath == false and SGroup_CountSpawned(enemyWavePattern[i].sg_removeFromArmy) > 2) then
								--filter out despawned, to be safe
								SGroup_FilterSpawned(enemyWavePattern[i].sg_removeFromArmy, FILTER_KEEP)
								--filter out all but 2
								SGroup_FilterCount(enemyWavePattern[i].sg_removeFromArmy, 2)
							end
							
							if(SGroup_CountSpawned(enemyWavePattern[i].sg_removeFromArmy) > 0) then
								--add the temporary group to this wave's raiding group
								for sIndex = 1, SGroup_CountSpawned(enemyWavePattern[i].sg_removeFromArmy) do
									local tempSquad = SGroup_GetSquadAt(enemyWavePattern[i].sg_removeFromArmy, sIndex)
									SGroup_Add(enemyWavePattern[i].sg_waveRaiders, tempSquad)
								end
								
								--remove both groups from the army
								Army_RemoveSGroup(enemyWavePattern[i].army, enemyWavePattern[i].sg_removeFromArmy)
								Army_RemoveSGroup(enemyWavePattern[i].army, enemyWavePattern[i].sg_waveRaiders)
							end
						end
						
						
					end
				end
				
				
				if(SGroup_CountSpawned(enemyWavePattern[i].sg_waveRaiders) > 0) then
					
					--set the building for the raiders to target
					if(EGroup_CountSpawned(enemyWavePattern[i].eg_raiderTarget) == 0) then
						if(realPath == 4 and EGroup_CountSpawned(eg_townNW) > 0) then
							local closestEID = EGroup_GetClosestEntity(eg_townNW, Util_GetPosition(enemyWavePattern[i].sg_waveRaiders))
							if closestEID ~= nil then
								EGroup_Clear(enemyWavePattern[i].eg_raiderTarget)
								EGroup_Add(enemyWavePattern[i].eg_raiderTarget, closestEID)
							end
						end
						if(realPath == 3 and EGroup_CountSpawned(eg_townSW) > 0) then
							local closestEID = EGroup_GetClosestEntity(eg_townSW, Util_GetPosition(enemyWavePattern[i].sg_waveRaiders))
							if closestEID ~= nil then
								EGroup_Clear(enemyWavePattern[i].eg_raiderTarget)
								EGroup_Add(enemyWavePattern[i].eg_raiderTarget, closestEID)
							end
						end
						if(realPath == 2 and EGroup_CountSpawned(eg_townSE) > 0) then
							local closestEID = EGroup_GetClosestEntity(eg_townSE, Util_GetPosition(enemyWavePattern[i].sg_waveRaiders))
							if closestEID ~= nil then
								EGroup_Clear(enemyWavePattern[i].eg_raiderTarget)
								EGroup_Add(enemyWavePattern[i].eg_raiderTarget, closestEID)
							end
						end
						if(realPath == 1 and EGroup_CountSpawned(eg_townNE) > 0) then
							local closestEID = EGroup_GetClosestEntity(eg_townNE, Util_GetPosition(enemyWavePattern[i].sg_waveRaiders))
							if closestEID ~= nil then
								EGroup_Clear(enemyWavePattern[i].eg_raiderTarget)
								EGroup_Add(enemyWavePattern[i].eg_raiderTarget, closestEID)
							end
						end
					end
					
					--order raiders to attack the building
					if(EGroup_CountSpawned(enemyWavePattern[i].eg_raiderTarget) > 0) then
						
						--remove from army again to be sure (this can take a while to process)
						Army_RemoveSGroup(enemyWavePattern[i].army, enemyWavePattern[i].sg_waveRaiders)
						
						--make sure the units have switched players to the player that doesn't use any AI
						SGroup_SetPlayerOwner(enemyWavePattern[i].sg_waveRaiders, enemyPlayer2)
						
						--issue attack command
						Cmd_Attack(enemyWavePattern[i].sg_waveRaiders, enemyWavePattern[i].eg_raiderTarget, false)
						
					end
				end
				
				
				
				--check if the current town has been completely destroyed, to merge the raiding groups back into an army
				if(SGroup_CountSpawned(enemyWavePattern[i].sg_waveRaiders) > 0 and isTownDestroyed == true) then
					if(enemyWavePattern[i].army ~= nil) then
						--switch back to the main enemy player
						SGroup_SetPlayerOwner(enemyWavePattern[i].sg_waveRaiders, enemyPlayer)
						
						Army_AddSGroup(enemyWavePattern[i].army, enemyWavePattern[i].sg_waveRaiders)
						SGroup_Clear(enemyWavePattern[i].sg_waveRaiders)
					end
				end
			end
			
		end
	end
end


function HC_Towton_UpdateWaveSiegeEast()
	if(SGroup_CountSpawned(sg_waveSiegeUnitsE) > 0) then
		--if the wall hasn't been breached, attack towards the gate
		if(eastWallBreached == false) then
			Cmd_AttackMove(sg_waveSiegeUnitsE, mkr_pathGateE, false)
		end
		--if the town center is still standing, attack towards the TC
		if(EGroup_Exists("eg_playerTC")) then
			if(EGroup_CountSpawned(eg_playerTC) > 0) then
				Cmd_AttackMove(sg_waveSiegeUnitsE, mkr_path3_9, true)
			end
		end
		--otherwise, attack towards Castle Lancaster
		Cmd_AttackMove(sg_waveSiegeUnitsE, mkr_pathEnd, true)
	end
	
	--additional check to make sure the whole final wave army focuses on the main base if the walls have fallen
	if(sg_finalWaveGroup ~= nil) then
		if(SGroup_CountSpawned(sg_finalWaveGroup) > 0 and eastWallBreached == true) then
			Cmd_AttackMove(sg_finalWaveGroup, mkr_pathEnd, true)
		end
	end
	
end

function HC_Towton_UpdateWaveSiegeWest()
	if(SGroup_CountSpawned(sg_waveSiegeUnitsW) > 0) then
		--if the wall hasn't been breached, attack towards the gate
		if(westWallBreached == false) then
			Cmd_AttackMove(sg_waveSiegeUnitsW, mkr_pathGateW, false)
		end
		--if the town center is still standing, attack towards the TC
		if(EGroup_Exists("eg_playerTC")) then
			if(EGroup_CountSpawned(eg_playerTC) > 0) then
				Cmd_AttackMove(sg_waveSiegeUnitsW, mkr_path3_9, true)
			end
		end
		--otherwise, attack towards Castle Lancaster
		Cmd_AttackMove(sg_waveSiegeUnitsW, mkr_pathEnd, true)
	end
end

function HC_Towton_UpdateWaves()
	--spawn new wave when the spawn time is reached
	for i = 1, #enemyWavePattern do 
		if(missionTime >= enemyWavePattern[i].spawnTime and enemyWavePattern[i].spawned == false) then
			if((enemyWavePattern[i].isConqueror == true and conquerorModeFailed == false) or enemyWavePattern[i].isConqueror ~= true) then
				HC_Towton_AddNewWave(i)
			end
		end
	end
end

function HC_Towton_PulseThreatBlip()
	
	--only pulse minimap blip for the first 30 seconds
	for i = 1, #enemyWavePattern do 
		if(missionTime >= enemyWavePattern[i].spawnTime + 10 and missionTime < enemyWavePattern[i].spawnTime + 30) then
			waveObject = enemyWavePattern[i].army
			if(waveObject ~= nil) then
				if(Army_GetSGroup(waveObject) ~= nil ) then
					if(SGroup_CountSpawned(Army_GetSGroup(waveObject)) > 0) then
						--pulse minimap blip
						UI_CreateMinimapBlip(Util_GetPosition(Army_GetSGroup(waveObject)), 1, "threat_group")
					end
				end
			end
		end
	end
	
end

function HC_Towton_AddNewWave(inWaveIndex)
	--adds a new wave from the wave table
	
	currentWaveStrength = math.ceil(missionTime / 60) + 10
	
	local newArmyIndex = #waveArmyList + 1
		
	--reroute the 2nd intro wave to the northwest base if conqueror mode is not active
	if(inWaveIndex == 2 and conquerorModeFailed == true) then
		enemyWavePattern[inWaveIndex].path = 4
	end
	
	--set up the sgroup which is used to remove units from the army
	enemyWavePattern[inWaveIndex].sg_removeFromArmy = SGroup_CreateIfNotFound("sg_removeFromArmy"..tostring(inWaveIndex))
	--set up the sgroup for raiding units (melee units which focus on ally owned buildings, over units)
	enemyWavePattern[inWaveIndex].sg_waveRaiders = SGroup_CreateIfNotFound("sg_waveRaiders_"..tostring(inWaveIndex))
	--set up the egroup for targeted buildings
	enemyWavePattern[inWaveIndex].eg_raiderTarget = EGroup_CreateIfNotFound("eg_raiderTarget_"..tostring(inWaveIndex))
	
	--create units table from the enemyWavePattern so the Army can use it
	tempArmyUnits = {}
	for i = 1, #enemyWavePattern[inWaveIndex].waveMakeup do 
		--round down but make sure there is at least 1 of each unit type
		local tempUnitCount = math.floor(currentWaveStrength * enemyWavePattern[inWaveIndex].waveMakeup[i].waveUnitMultiplier)
		if(conquerorModeActivated == true) then
			--increase strength for conqueror mode
			tempUnitCount = math.floor(currentWaveStrength * 1.3 * enemyWavePattern[inWaveIndex].waveMakeup[i].waveUnitMultiplier)
		else
			--reduce final wave siege strength if conqueror mode is not active
			if(enemyWavePattern[inWaveIndex].ctaScreen == iconPath_boss) then
				if(i >= 6 and i <= 9) then
					tempUnitCount = tempUnitCount * .8
				end
			end
		end
		
		--decrease strength if the first targeted manor has already been destroyed
		local nextTownIndex = enemyWavePattern[inWaveIndex].path
		if(nextTownIndex > 5) then 
			--convert from alternate paths to main paths
			nextTownIndex = nextTownIndex - 5
		end
		if(nextTownIndex <= #townDataTable and enemyWavePattern[inWaveIndex].ctaScreen ~= iconPath_boss) then
			--decrease strength if the previous manor has been destroyed or gold or silver have been failed
			if(nextTownIndex < 4) then
				if(townDataTable[nextTownIndex + 1].manorDestroyed == true) then
					tempUnitCount = tempUnitCount * .75
				elseif(silverMedalFailed == true) then
					tempUnitCount = tempUnitCount * .825
				elseif(goldMedalFailed == true) then
					tempUnitCount = tempUnitCount * .9
				end
			end
		end
		
		--round up to integer
		tempUnitCount = math.ceil(tempUnitCount)
		--round up so we always have at least one of each unit type
		if(tempUnitCount < 1) then
			tempUnitCount = 1
		end
		
		--change men at arms to scouts for the 2nd intro wave if conqueror mode is not active
		if(inWaveIndex == 2 and conquerorModeFailed == true) then
			if(i == 1) then
				enemyWavePattern[inWaveIndex].waveMakeup[i].waveUnitBP = SBP.ENGLISH.UNIT_SCOUT_1_ENG
				tempUnitCount = 2
			end
		end
		
		tempArmyUnits[i] = {sbp = enemyWavePattern[inWaveIndex].waveMakeup[i].waveUnitBP, numSquads = tempUnitCount}
	end
	
	combatRange = 40
	--increase combat range for later waves (sometimes avoids outlying houses)
	if(inWaveIndex > 6) then
		combatRange = 50
	end
	
	params = {
		player = enemyPlayer,
		name = "wave_"..tostring(newArmyIndex),
		units = tempArmyUnits,
		spawn = enemyPaths[enemyWavePattern[inWaveIndex].path][1],
		targets = enemyPaths[enemyWavePattern[inWaveIndex].path],
		attackMove = true,
		combatRangeEnRoute = combatRange,
		combatRangeAtTarget = combatRange,
	}
	--set up alternate routes for raiding waves with smaller combat ranges enroute
	if(enemyWavePattern[inWaveIndex].path > 5) then
		raidTargets = {}
		for i = 1, #enemyPaths[enemyWavePattern[inWaveIndex].path] do 
			local rangeEnRoute = 40
			local rangeAtTarget = 40
			--reduce combat range so these alternate routes will go around the first line of defense
			--alt path 1
			if(enemyWavePattern[inWaveIndex].path == 6) then
				if(i < 6) then
					rangeEnRoute = 1
					rangeAtTarget = 3
				end
			end
			--alt path 2
			if(enemyWavePattern[inWaveIndex].path == 7) then
				if(i < 8) then
					rangeEnRoute = 1
					rangeAtTarget = 3
				end
			end
			--alt path 3
			if(enemyWavePattern[inWaveIndex].path == 8) then
				if(i < 6) then
					rangeEnRoute = 1
					rangeAtTarget = 3
				end
			end
			--alt path 4
			if(enemyWavePattern[inWaveIndex].path == 9) then
				if(i < 7) then
					rangeEnRoute = 1
					rangeAtTarget = 3
				end
			end
			target = {
				marker = enemyPaths[enemyWavePattern[inWaveIndex].path][i],
				combatRangeEnRoute = rangeEnRoute,
				combatRangeAtTarget = rangeAtTarget,
				attackMove = false
			}
			table.insert(raidTargets, i, target)
		end
		params = {
			player = enemyPlayer,
			name = "wave_"..tostring(newArmyIndex),
			units = tempArmyUnits,
			spawn = enemyPaths[enemyWavePattern[inWaveIndex].path][1],
			targets = raidTargets,
		}
	end
	
	
	waveArmyList[newArmyIndex] = Army_Init(params)
	enemyWavePattern[inWaveIndex].army = waveArmyList[newArmyIndex]
	
	
	
	--start objective for the final wave
	if(enemyWavePattern[inWaveIndex].ctaScreen ~= nil) then
		if(enemyWavePattern[inWaveIndex].ctaScreen == iconPath_boss) then
			finalWaveStarted = true
			
			sg_finalWaveGroupTemp = Army_GetSGroup(waveArmyList[newArmyIndex])
			--add the temporary group to the final group used for tracking victory
			for sIndex = 1, SGroup_CountSpawned(sg_finalWaveGroupTemp) do
				local tempSquad = SGroup_GetSquadAt(sg_finalWaveGroupTemp, sIndex)
				SGroup_Add(sg_finalWaveGroup, tempSquad)
			end
			
			Objective_Start(OBJ_Boss)
			--if conqueror mode is active, add an aura to the leader
			if(conquerorModeActivated == true) then
				sg_leader = Player_GetSquads(enemyPlayer)
				SGroup_Filter(sg_leader, {SBP.ENGLISH.UNIT_ABBEY_KING_2}, FILTER_KEEP)
				SGroup_AddAbility(sg_leader, ABILITY.GENERAL_AURA_COMBAT)
			end
		end
	end
	
	--reveal sgroup after a delay
	Rule_AddOneShot(HC_Towton_RevealNewWave, 5, {revealArmyIndex = newArmyIndex, revealWaveIndex = inWaveIndex})
	Rule_AddOneShot(HC_Towton_AnnounceNewWave, 5, {revealArmyIndex = newArmyIndex, revealWaveIndex = inWaveIndex})
	
	
	enemyWavePattern[inWaveIndex].spawned = true
	currentWaveIndex = inWaveIndex
	
	if(currentWaveIndex >  #enemyWavePattern) then
		currentWaveIndex = 1
	end
end

function HC_Towton_AnnounceNewWave(context, data)
	
	--display call to action screen for the early waves and the first wave in each phase
	if(enemyWavePattern[data.revealWaveIndex].ctaScreen ~= nil) then
		EventCues_CallToAction("$11268464", CTA_ALARM, nil, nil, Army_GetSGroup(waveArmyList[data.revealArmyIndex]), 30, enemyWavePattern[data.revealWaveIndex].ctaScreen)--Enemy Attack Incoming
	end
	
	if(data.revealWaveIndex <= 6) then
		--play sound effect for first 6 waves
		Sound_Play2D("sfx_campaign_scripted_attack_horn_under_attack_high")
		Sound_Play2D("sfx_campaign_scripted_medium_group_engage")
		Sound_Play2D(MUS_STINGER_ALERT)
	elseif(enemyWavePattern[data.revealWaveIndex].ctaScreen == iconPath_boss) then
		Sound_Play2D("sfx_campaign_scripted_attack_horn_under_attack_high")
		Sound_Play2D("sfx_campaign_scripted_large_group_engage")
		Sound_Play2D(MUS_STINGER_ALERT)
	elseif(enemyWavePattern[data.revealWaveIndex].ctaScreen ~= nil) then
		Sound_Play2D("sfx_campaign_scripted_attack_horn_under_attack_high")
		Sound_Play2D("sfx_campaign_scripted_medium_group_engage")
		Sound_Play2D(MUS_STINGER_ALERT)
	end
end



function HC_Towton_RevealNewWave(context, data)
	--reveal group
	FOW_PlayerRevealSGroup(localPlayer, Army_GetSGroup(waveArmyList[data.revealArmyIndex]), 10, -1)
	
end



