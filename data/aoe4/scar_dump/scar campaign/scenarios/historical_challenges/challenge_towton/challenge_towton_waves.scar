	waveIndex = waveIndex + 1
	waveTime = waveTime + 40
	enemyWaveMakeup = {}
	enemyWaveMakeup[1] = {waveUnitBP = sbp_knight4, waveUnitMultiplier = .4}
	enemyWavePattern[waveIndex] = {waveMakeup = enemyWaveMakeup, path = 1, isConqueror = false, spawnTime = waveTime, spawned = false, ctaScreen = nil}
	
	--conqueror only wave
	waveIndex = waveIndex + 1
	enemyWaveMakeup = {}
	enemyWaveMakeup[1] = {waveUnitBP = sbp_crossbow3, waveUnitMultiplier = .3}
