function HC_Towton_InitStartingAttackUI()
	
	
	if(SGroup_CountSpawned(sg_firstScoutsE) > 0) then
		--Optional: Stop the English Scouts
		EventCues_CallToAction("$11172287", CTA_UNIQUE_STAKES, nil, nil, sg_firstScoutsE, 30, "icons/cta/illustrations/alarm")
	end
end

function HC_Towton_InitStartingAttackUI2()
	
	Objective_Register(OBJ_InitialAttacks)
	Objective_Start(OBJ_InitialAttacks)
	
	---set minimap markers
	initialAttackBlipNW = UI_CreateMinimapBlip(Util_GetPosition(mkr_townNW), (60 * 5), "objective_battle")
	initialAttackBlipNE = UI_CreateMinimapBlip(Util_GetPosition(mkr_townNE), (60 * 5), "objective_battle")
	initialAttackBlipSW = UI_CreateMinimapBlip(Util_GetPosition(mkr_townSW), (60 * 5), "objective_battle")
	initialAttackBlipSE = UI_CreateMinimapBlip(Util_GetPosition(mkr_townSE), (60 * 5), "objective_battle")
	
end

function HC_Towton_InitObjectiveUI()
	
	
	Objective_AddUIElements(SOBJ_Defend, eg_landmark, false, "$11268453", true, 3)--The Lancaster Stronghold Must Survive
	
	--get initial building count
	eg_allAlliedBuildings = EGroup_CreateIfNotFound("eg_allAlliedBuildings")
	eg_allAlliedBuildings = Player_GetAllEntitiesFromType(allyPlayer, "building")
	--exclude walls and gates
	EGroup_Filter(eg_allAlliedBuildings, {"wall", "gate", "farm"}, FILTER_REMOVE)
	EGroup_RemoveGroup(eg_allAlliedBuildings, eg_outerHouses)
	allAlliedBuildingsStartingCount = EGroup_CountSpawned(eg_allAlliedBuildings)
	
	Objective_SetCounter(OBJ_Towns, allAlliedBuildingsStartingCount, allAlliedBuildingsStartingCount)
	
end

function HC_Towton_BeginNewPhase(inPhase)
	
	local townPosition = Util_GetPosition(mkr_townNW)
	local bp_reticule = BP_GetReticuleBlueprint("marquee")
	local size = 40
	
	
	
	if(inPhase == 1) then
		reinforcementStartTime1 = World_GetGameTime()
		townPosition = Util_GetPosition(mkr_townNW)
		
		Objective_Register(SOBJ_AttackPhaseNW)
		Objective_Start(SOBJ_AttackPhaseNW)
		Objective_StartTimer(SOBJ_AttackPhaseNW, COUNT_DOWN, phase1Duration)
		Objective_Show(SOBJ_AttackPhaseNW, true, false)
		
		phase1UI = Objective_AddUIElements(SOBJ_AttackPhaseNW, townPosition, false, "$11268463", true, 12)--Awaiting Reinforcements
		Obj_SetVisible(SOBJ_AttackPhaseNW.ID, true)
		Obj_SetProgressVisible(SOBJ_AttackPhaseNW.ID, true)
		--set reticule
		allyTown1ReticuleID = UI_ModalVisual_CreateReticule(bp_reticule, size)
		UI_ModalVisual_SetPosition(allyTown1ReticuleID, townPosition)
		---set minimap marker
		defendTown1Blip = UI_CreateMinimapBlip(townPosition, phase1Duration, "objective_battle")
		attackPhase1Started = true
		--set minimap path
		MarkerPaths_GenerateIcons("path_arrows_NW", AllMarkers_FromName("path_arrows_NW", ""), "military_route_enemy")
		
		--make beacon selectable
		EGroup_SetSelectable(townDataTable[4].beacon, true)
		--add reticule to beacon
		beaconTown1ReticuleID = UI_ModalVisual_CreateReticule(bp_reticule, 5)
		UI_ModalVisual_SetPosition(beaconTown1ReticuleID, Util_GetPosition(townDataTable[4].beaconMkr))
		
	elseif(inPhase == 2) then
		reinforcementStartTime2 = World_GetGameTime()
		townPosition = Util_GetPosition(mkr_townSW)
		
		Objective_Register(SOBJ_AttackPhaseSW)
		Objective_Start(SOBJ_AttackPhaseSW)
		Objective_StartTimer(SOBJ_AttackPhaseSW, COUNT_DOWN, phase2Duration)
		Objective_Show(SOBJ_AttackPhaseSW, true, false)
		
		phase2UI = Objective_AddUIElements(SOBJ_AttackPhaseSW, townPosition, false, "$11268463", true, 12)--Awaiting Reinforcements
		Obj_SetVisible(SOBJ_AttackPhaseSW.ID, true)
		Obj_SetProgressVisible(SOBJ_AttackPhaseSW.ID, true)
		--set reticule
		allyTown2ReticuleID = UI_ModalVisual_CreateReticule(bp_reticule, size)
		UI_ModalVisual_SetPosition(allyTown2ReticuleID, townPosition)
		---set minimap marker
		defendTown2Blip = UI_CreateMinimapBlip(townPosition, phase2Duration, "objective_battle")
		attackPhase2Started = true
		--set minimap path
		MarkerPaths_GenerateIcons("path_arrows_SW", AllMarkers_FromName("path_arrows_SW", ""), "military_route_enemy")
		
		--make beacon selectable
		EGroup_SetSelectable(townDataTable[3].beacon, true)
		--add reticule to beacon
		beaconTown2ReticuleID = UI_ModalVisual_CreateReticule(bp_reticule, 5)
		UI_ModalVisual_SetPosition(beaconTown2ReticuleID, Util_GetPosition(townDataTable[3].beaconMkr))
		
	elseif(inPhase == 3) then
		reinforcementStartTime3 = World_GetGameTime()
		townPosition = Util_GetPosition(mkr_townSE)
		
		Objective_Register(SOBJ_AttackPhaseSE)
		Objective_Start(SOBJ_AttackPhaseSE)
		Objective_StartTimer(SOBJ_AttackPhaseSE, COUNT_DOWN, phase3Duration)
		Objective_Show(SOBJ_AttackPhaseSE, true, false)
		
		phase3UI = Objective_AddUIElements(SOBJ_AttackPhaseSE, townPosition, false, "$11268463", true, 12)--Awaiting Reinforcements
		Obj_SetVisible(SOBJ_AttackPhaseSE.ID, true)
		Obj_SetProgressVisible(SOBJ_AttackPhaseSE.ID, true)
		--set reticule
		allyTown3ReticuleID = UI_ModalVisual_CreateReticule(bp_reticule, size)
		UI_ModalVisual_SetPosition(allyTown3ReticuleID, townPosition)
		---set minimap marker
		defendTown3Blip = UI_CreateMinimapBlip(townPosition, phase3Duration, "objective_battle")
		attackPhase3Started = true
		--set minimap path
		MarkerPaths_GenerateIcons("path_arrows_SE", AllMarkers_FromName("path_arrows_SE", ""), "military_route_enemy")
		
		--make beacon selectable
		EGroup_SetSelectable(townDataTable[2].beacon, true)
		--add reticule to beacon
		beaconTown3ReticuleID = UI_ModalVisual_CreateReticule(bp_reticule, 5)
		UI_ModalVisual_SetPosition(beaconTown3ReticuleID, Util_GetPosition(townDataTable[2].beaconMkr))
		
	elseif(inPhase == 4) then
		reinforcementStartTime4 = World_GetGameTime()
		townPosition = Util_GetPosition(mkr_townNE)
		
		Objective_Register(SOBJ_AttackPhaseNE)
		Objective_Start(SOBJ_AttackPhaseNE)
		Objective_StartTimer(SOBJ_AttackPhaseNE, COUNT_DOWN, phase4Duration)
		Objective_Show(SOBJ_AttackPhaseNE, true, false)
		
		phase4UI = Objective_AddUIElements(SOBJ_AttackPhaseNE, townPosition, false, "$11268463", true, 12)--Awaiting Reinforcements
		Obj_SetVisible(SOBJ_AttackPhaseNE.ID, true)
		Obj_SetProgressVisible(SOBJ_AttackPhaseNE.ID, true)
		--set reticule
		allyTown4ReticuleID = UI_ModalVisual_CreateReticule(bp_reticule, size)
		UI_ModalVisual_SetPosition(allyTown4ReticuleID, townPosition)
		---set minimap marker
		defendTown4Blip = UI_CreateMinimapBlip(townPosition, phase4Duration, "objective_battle")
		attackPhase4Started = true
		--set minimap path
		MarkerPaths_GenerateIcons("path_arrows_NE", AllMarkers_FromName("path_arrows_NE", ""), "military_route_enemy")
		
		--make beacon selectable
		EGroup_SetSelectable(townDataTable[1].beacon, true)
		--add reticule to beacon
		beaconTown4ReticuleID = UI_ModalVisual_CreateReticule(bp_reticule, 5)
		UI_ModalVisual_SetPosition(beaconTown4ReticuleID, Util_GetPosition(townDataTable[1].beaconMkr))
		
	end
	
	
	
end

function HC_Towton_EndOldPhase(inPhase)
	
	if(inPhase == 1) then
		if(Objective_IsStarted(SOBJ_AttackPhaseNW)) then
			Objective_Complete(SOBJ_AttackPhaseNW, true, true)
			Objective_Show(SOBJ_AttackPhaseNW, false, false)
		end
		
		if(phase1UI ~= nil) then
			Objective_RemoveUIElements(SOBJ_AttackPhaseNW, phase1UI)
		end
		if(defendTown1Blip ~= nil) then
			UI_DeleteMinimapBlip(defendTown1Blip)
		end
		if(allyTown1ReticuleID ~= nil) then
			UI_ModalVisual_Destroy(allyTown1ReticuleID)
		end
		MarkerPaths_ClearIcons("path_arrows_NW")
		attackPhase1Started = false
	elseif(inPhase == 2) then
		if(Objective_IsStarted(SOBJ_AttackPhaseSW)) then
			Objective_Complete(SOBJ_AttackPhaseSW, true, true)
			Objective_Show(SOBJ_AttackPhaseSW, false, false)
		end
		
		if(phase2UI ~= nil) then
			Objective_RemoveUIElements(SOBJ_AttackPhaseSW, phase2UI)
		end
		if(defendTown2Blip ~= nil) then
			UI_DeleteMinimapBlip(defendTown2Blip)
		end
		if(allyTown2ReticuleID ~= nil) then
			UI_ModalVisual_Destroy(allyTown2ReticuleID)
		end
		MarkerPaths_ClearIcons("path_arrows_SW")
		attackPhase2Started = false
	elseif(inPhase == 3) then
		if(Objective_IsStarted(SOBJ_AttackPhaseSE)) then
			Objective_Complete(SOBJ_AttackPhaseSE, true, true)
			Objective_Show(SOBJ_AttackPhaseSE, false, false)
		end
		
		if(phase3UI ~= nil) then
			Objective_RemoveUIElements(SOBJ_AttackPhaseSE, phase3UI)
		end
		if(defendTown3Blip ~= nil) then
			UI_DeleteMinimapBlip(defendTown3Blip)
		end
		if(allyTown3ReticuleID ~= nil) then
			UI_ModalVisual_Destroy(allyTown3ReticuleID)
		end
		MarkerPaths_ClearIcons("path_arrows_SE")
		attackPhase3Started = false
	elseif(inPhase == 4) then
		if(Objective_IsStarted(SOBJ_AttackPhaseNE)) then
			Objective_Complete(SOBJ_AttackPhaseNE, true, true)
			Objective_Show(SOBJ_AttackPhaseNE, false, false)
		end
		
		if(phase3UI ~= nil) then
			Objective_RemoveUIElements(SOBJ_AttackPhaseNE, phase3UI)
		end
		if(defendTown4Blip ~= nil) then
			UI_DeleteMinimapBlip(defendTown4Blip)
		end
		if(allyTown4ReticuleID ~= nil) then
			UI_ModalVisual_Destroy(allyTown4ReticuleID)
		end
		MarkerPaths_ClearIcons("path_arrows_NE")
		attackPhase4Started = false
	end
	
end

function HC_Towton_UpdateObjectiveUI()
	
	allAlliedBuildingsCurrentCount = EGroup_CountSpawned(eg_allAlliedBuildings)
	if(allAlliedBuildingsCurrentCount ~= allAlliedBuildingsPreviousCount) then
		Objective_SetCounter(OBJ_Towns, allAlliedBuildingsCurrentCount, allAlliedBuildingsStartingCount)
		Obj_SetProgress(OBJ_Towns.ID, allAlliedBuildingsCurrentCount / allAlliedBuildingsStartingCount)
		allAlliedBuildingsPreviousCount = allAlliedBuildingsCurrentCount
	end
	
	if(Objective_IsStarted(SOBJ_AttackPhaseNW) and Objective_IsVisible(SOBJ_AttackPhaseNW)) then
		reinforcementTime = World_GetGameTime() - reinforcementStartTime1
		Obj_SetProgress(SOBJ_AttackPhaseNW.ID, reinforcementTime  / phase1Duration)
	end
	if(Objective_IsStarted(SOBJ_AttackPhaseSW) and Objective_IsVisible(SOBJ_AttackPhaseSW)) then
		reinforcementTime = World_GetGameTime() - reinforcementStartTime2
		Obj_SetProgress(SOBJ_AttackPhaseSW.ID, reinforcementTime  / phase2Duration)
	end
	if(Objective_IsStarted(SOBJ_AttackPhaseSE) and Objective_IsVisible(SOBJ_AttackPhaseSE)) then
		reinforcementTime = World_GetGameTime() - reinforcementStartTime3
		Obj_SetProgress(SOBJ_AttackPhaseSE.ID, reinforcementTime  / phase3Duration)
	end
	if(Objective_IsStarted(SOBJ_AttackPhaseNE) and Objective_IsVisible(SOBJ_AttackPhaseNE)) then
		reinforcementTime = World_GetGameTime() - reinforcementStartTime4
		Obj_SetProgress(SOBJ_AttackPhaseNE.ID, reinforcementTime  / phase4Duration)
	end
	
end

function HC_Towton_PulseReinforcementsBlipNW()
	if(sg_NavalReinforcementsNW ~= nil) then
		if(SGroup_CountSpawned(sg_NavalReinforcementsNW) > 0) then
			--pulse minimap blip
			UI_CreateMinimapBlip(Util_GetPosition(sg_NavalReinforcementsNW), 1, "objective_bonus")
		end
	end
end

