				Rule_Remove(HC_Towton_PulseReinforcementsBlipNE)
			end
		end,
	}
	SOBJ_ReinforcementsSE = 
	{
		Title = "$11268460",--Reinforcements have arrived.
		Type = OT_Information,
		PreStart = function()
			Sound_Play2D(MUS_STING_TRIUMPHANT)
		end,
		OnStart = function()
