		StartAlongsideParent = true, 
	}
	SOBJ_AttackPhaseNE = 
	{
		Title = "$11268459",--Defend the Northeast Town until reinforcements arrive
		Type = ObjectiveType_Battle,
		StartAlongsideParent = true, 
	}
	
	SOBJ_ReinforcementsNW = 
	{
		Title = "$11268460",--Reinforcements have arrived.
		Type = OT_Information,
		PreStart = function()
			Sound_Play2D(MUS_STING_TRIUMPHANT)
		end,
		OnStart = function()
			if(SGroup_CountSpawned(sg_NavalReinforcementsNW) > 0) then
				local firstSquad = SGroup_GetSquadAt(sg_NavalReinforcementsNW, 1)
				SGroup_Single(sg_single, firstSquad)
				reinforcementsNWLabel = Objective_AddUIElements(SOBJ_ReinforcementsNW, sg_single, false, "$11268461", true, 1)--Reinforcements
				EventCues_CallToAction("$11268460", CTA_CELEBRATE, nil, nil, sg_NavalReinforcementsNW, 40, "icons/cta/illustrations/player_reinforcement_arrived")
				
				Util_StartIntel(EVENTS.Allied_Reinforcements)
				
				--add minimap blip showing where reinforcements are
				Rule_AddInterval(HC_Towton_PulseReinforcementsBlipNW, 5)
			end
		end,
		IsComplete = function()
			if(sg_NavalReinforcementsNW ~= nil) then
				if(SGroup_CountSpawned(sg_NavalReinforcementsNW) > 0) then
					return Misc_IsSGroupSelected(sg_NavalReinforcementsNW, ANY)
				else
					return true
				end
			end
		end,
		OnComplete = function()
			Objective_Show(SOBJ_ReinforcementsNW, false, false)
			UI_ModalVisual_Destroy(reinforcementsNWLabel)
			if(reinforcementsNWLabel ~= nil) then
				Objective_RemoveUIElements(SOBJ_ReinforcementsNW, reinforcementsNWLabel)
			end
			if(Rule_Exists(HC_Towton_PulseReinforcementsBlipNW)) then
				Rule_Remove(HC_Towton_PulseReinforcementsBlipNW)
			end
		end,
	}
