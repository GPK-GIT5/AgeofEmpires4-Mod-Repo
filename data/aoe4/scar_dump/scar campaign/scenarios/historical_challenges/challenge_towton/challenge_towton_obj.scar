function HC_Towton_InitObjectives()
	
	
	OBJ_Victory = {
		
		Title = "$11268447",--Defend against Yorkist attacks
		Type = ObjectiveType_Battle,
		PreComplete = function()
			--send custom event if mission is completed with conqueror mode activated
			if(conquerorModeActivated == true) then
				Game_SendCustomChallengeEvent(player1,CE_TOWTONCONQ,1)
			end
		end,
	}
	
	OBJ_ConquerorMedal = 
	{
		Title = "$11268452",--Conqueror Medal (Survive All Strengthened Enemy Waves)
		Type = ObjectiveType_Bonus,
		Icon = "icons\\fe\\medal_gold.png", --TODO: add new icon
		StartAlongsideParent = true, 
		OnStart = function()
			Sound_Play2D(MUS_STING_TRIUMPHANT)
		end,
	}
	OBJ_GoldMedal = 
	{
		Title = Loc_FormatText("$11268451", 35),--Gold Medal (Save %1BUILDINGS% Allied Buildings)
		Type = ObjectiveType_Bonus,
		Icon = "icons\\fe\\medal_gold.png",
		StartAlongsideParent = true, 
	}
	OBJ_SilverMedal = 
	{
		Title = Loc_FormatText("$11268450", 20),--Silver Medal (Save %1BUILDINGS% Allied Buildings)
		Type = ObjectiveType_Bonus,
		Icon = "icons\\fe\\medal_silver.png",
		StartAlongsideParent = true, 
	}
	OBJ_BronzeMedal = 
	{
		Title = "$11268449",--Bronze Medal (Survive All Enemy Waves)
		Type = ObjectiveType_Bonus,
		Icon = "icons\\fe\\medal_bronze.png",
		StartAlongsideParent = true, 
	}
	OBJ_Towns = 
	{
		Title = "$11268448",--Allied Buildings Remaining
		Type = ObjectiveType_Battle,
		Parent = OBJ_Victory,
		StartAlongsideParent = true, 
		
		SetupUI = function()
			Obj_SetProgressVisible(OBJ_Towns.ID, true)
			Obj_SetProgress(OBJ_Towns.ID, 1.0)
		end,
	}
	
	SOBJ_Defend = 
	{
		Title = "$11268453",--The Lancaster Stronghold Must Survive
		Type = ObjectiveType_Battle,
		Parent = OBJ_Victory,
		StartAlongsideParent = true, 
		
	}
	OBJ_Conqueror = 
	{
		Title = "$11268999",--Prove your ability to defend your allies for a greater challenge
		Type = ObjectiveType_Bonus,
		Parent = OBJ_GoldMedal,
		StartAlongsideParent = true, 
		
	}
	
	OBJ_InitialAttacks = 
	{
		Title = "$11268454",--The Yorkist forces are sending scouting attacks to test our defenses
		Type = ObjectiveType_Battle,
		StartAlongsideParent = true, 
	}
	
	
	SOBJ_AttackPhaseNW = 
	{
		Title = "$11268456",--Defend the Northwest Town until reinforcements arrive
		Type = ObjectiveType_Battle,
		StartAlongsideParent = true, 
	}
	SOBJ_AttackPhaseSW = 
	{
		Title = "$11268457",--Defend the Southwest Town until reinforcements arrive
