			end
		end,
	}
	SOBJ_ReinforcementsS = 
	{
		Title = "$11268460",--Reinforcements have arrived.
		Type = OT_Information,
		PreStart = function()
			Sound_Play2D(MUS_STING_TRIUMPHANT)
		end,
		OnStart = function()
			if(SGroup_CountSpawned(sg_alliedReinforcementsS) > 0) then
				local firstSquad = SGroup_GetSquadAt(sg_alliedReinforcementsS, 1)
