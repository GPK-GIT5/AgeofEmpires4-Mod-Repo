	OBJ_Boss = 
	{
		Title = "$11268462",--Defeat the Duke of York's final attack.
		Type = ObjectiveType_Battle,
		StartAlongsideParent = false, 
	}
	
	
	OBJ_AgeUpHint = 
	{
		Title = "$11192924",--Advance to the Castle Age
		Type = ObjectiveType_Tip,
		Parent = OBJ_Victory,
		StartAlongsideParent = false, 
	}
	
	OBJ_ProductionHint = 
