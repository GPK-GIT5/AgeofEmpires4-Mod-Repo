	defendTown2Blip = nil
	defendTown3Blip = nil
	defendTown4Blip = nil
	allyTown1ReticuleID = nil
	allyTown2ReticuleID = nil
	allyTown3ReticuleID = nil
	allyTown4ReticuleID = nil
