	phase2Duration = 5 * 60
	phase3Duration = 5 * 60
	phase4Duration = 4 * 60
	
	Rule_AddOneShot(HC_Towton_InitStartingAttackUI, 15)
	Rule_AddOneShot(HC_Towton_InitStartingAttackUI2, 60)
	
