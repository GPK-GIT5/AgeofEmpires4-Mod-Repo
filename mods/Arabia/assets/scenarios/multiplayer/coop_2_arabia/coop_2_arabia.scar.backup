function Mission_SetupPlayers()

	-- get player IDs for each player
	player1 = World_GetPlayerAt(1) -- Player Melee
	player2 = World_GetPlayerAt(2) -- Player Ranged
	player3 = World_GetPlayerAt(3) -- Enemey AI
	-- Allies
	Player_SetMaximumAge(player1, AGE_CASTLE)
	Player_SetMaximumAge(player2, AGE_CASTLE)
	-- Enemey
	Player_SetCurrentAge(player3, AGE_CASTLE) 
	Player_SetMaximumAge(player3, AGE_CASTLE)
	
end
-- Creates any extra sgroups, egroups, and mission variables
function Mission_SetupVariables()	
	
	AI_Difficulty = GetAIDifficulty(player3)
	-- Starter Unit spawner
	sg_player1_start = SGroup_CreateIfNotFound("sg_player1_start") -- Player 1, Spearman,Horseman
	sg_player2_start = SGroup_CreateIfNotFound("sg_player2_start") -- Player 2, Spearman,Archers
	sg_start_camp01 = SGroup_CreateIfNotFound("sg_start_camp01") 
	sg_start_patrol01 = SGroup_CreateIfNotFound("sg_start_patrol01")
	sg_start_mining_def = SGroup_CreateIfNotFound("sg_start_mining_def")
	sg_start_gate01 = SGroup_CreateIfNotFound("sg_start_gate01")
	sg_start_gate02 = SGroup_CreateIfNotFound("sg_start_gate02") 
	
	-- Delayed attack waves
	sg_wave0a_city01a = SGroup_CreateIfNotFound("sg_wave0a_city01a") -- Light
	sg_wave0a_city01b = SGroup_CreateIfNotFound("sg_wave0a_city01b") -- Light, flank
	sg_wave0a_city01c = SGroup_CreateIfNotFound("sg_wave0a_city01c") -- Light
	sg_wave0a_city01d = SGroup_CreateIfNotFound("sg_wave0a_city01d") -- flank
	sg_wave0a_city02 = SGroup_CreateIfNotFound("sg_wave0a_city02") -- Siege
	sg_wave0a_city03 = SGroup_CreateIfNotFound("sg_wave0a_city03") -- Armored Cav
	sg_wave0a_city04 = SGroup_CreateIfNotFound("sg_wave0a_city04")
	sg_wave0a_city05 = SGroup_CreateIfNotFound("sg_wave0a_city05")
	sg_wave0a_city06 = SGroup_CreateIfNotFound("sg_wave0a_city06")
	sg_wave0a_city07 = SGroup_CreateIfNotFound("sg_wave0a_city07")
	sg_wave0a_city08 = SGroup_CreateIfNotFound("sg_wave0a_city08")
	
	-- Upgraded attack waves
	sg_wave0b_city01a = SGroup_CreateIfNotFound("sg_wave0b_city01a") -- Light
	sg_wave0b_city01b = SGroup_CreateIfNotFound("sg_wave0b_city01b") -- Cav flank
	
	-- CaptureMine_Reinforcements 
	sg_wave1_mining01 = SGroup_CreateIfNotFound("sg_wave1_mining01") -- Counter-Attacks start after taking town
	sg_wave1_mining02 = SGroup_CreateIfNotFound("sg_wave1_mining02") -- Flanking group 
	sg_player1_town = SGroup_CreateIfNotFound("sg_player1_town") -- Player 1 receive villagers & melee inf
	sg_player2_town = SGroup_CreateIfNotFound("sg_player2_town") -- Player 2 receive villagers & ranged inf
	
	-- Add additional patrols
	sg_siege_gaurds = SGroup_CreateIfNotFound("sg_siege_gaurds") -- Siege security
	sg_village_patrol01 = SGroup_CreateIfNotFound("sg_village_patrol01") -- Patrol #1
	sg_village_patrol02 = SGroup_CreateIfNotFound("sg_village_patrol02") -- Patrol #2
	sg_village_patrol03 = SGroup_CreateIfNotFound("sg_village_patrol03") -- Patrol #3
	sg_village_patrol = SGroup_CreateIfNotFound("sg_village_patrol") -- Add groups for alive check
	SGroup_AddGroup(sg_village_patrol, sg_village_patrol01) 
	SGroup_AddGroup(sg_village_patrol, sg_village_patrol02) 
	SGroup_AddGroup(sg_village_patrol, sg_village_patrol03) 
	count_village_patrol = SGroup_Count(sg_village_patrol)  -- Save total count 
	
	-- DestroyCheckpoint_Waves 
	sg_wave2_city01 = SGroup_CreateIfNotFound("sg_wave2_city01") -- Counter-Attacks start after taking checkpoint
	sg_wave2_city02 = SGroup_CreateIfNotFound("sg_wave2_city02") -- Extra attackers with siege depending on objective condition
	
	-- Objective UI Variables
	i_destroyedCheckpoint = 0 
	i_destroyedSiege = 0 
	i_destroyedKeep = 0 
	
	-- Reinforcements
	sg_player1_reinforcements = SGroup_CreateIfNotFound("sg_player1_reinforcements")
	sg_player2_reinforcements = SGroup_CreateIfNotFound("sg_player2_reinforcements")
	sg_player1_siege = SGroup_CreateIfNotFound("sg_player1_siege")
	sg_player2_siege = SGroup_CreateIfNotFound("sg_player2_siege")
	
	-- Siege Buildings
	eg_siege_targets = EGroup_CreateIfNotFound("eg_siege_targets") -- used in Siege objective
	EGroup_AddEGroup (eg_siege_targets, eg_siege_targets1) 
	EGroup_AddEGroup (eg_siege_targets, eg_siege_targets2)
	count_siege_player2 = EGroup_Count(eg_siege_targets2)
	
	-- Last lines of Defence
	sg_village_blockade01 = SGroup_CreateIfNotFound("sg_village_blockade01")
	sg_village_blockade02 = SGroup_CreateIfNotFound("sg_village_blockade02")
	sg_village_blockade03 = SGroup_CreateIfNotFound("sg_village_blockade03")
	sg_village_blockade04 = SGroup_CreateIfNotFound("sg_village_blockade04")
	sg_village_blockade05 = SGroup_CreateIfNotFound("sg_village_blockade05")
	sg_village_blockade06 = SGroup_CreateIfNotFound("sg_village_blockade06")
	sg_village_blockade07 = SGroup_CreateIfNotFound("sg_village_blockade07")
	sg_village_blockade08 = SGroup_CreateIfNotFound("sg_village_blockade08")
	sg_village_blockade09 = SGroup_CreateIfNotFound("sg_village_blockade09")
	
	-- Player units sg_player_team
	sg_player_team = SGroup_CreateIfNotFound("sg_player_team")
end
-- Setup any restrictions (i.e. locking out units, etc)
function Mission_SetRestrictions()	
	
	
	for _, player in pairs(PLAYERS) do
		local player_civ = Player_GetRaceName(player .id)	
		if player_civ ~= "mongol" then
			Player_SetEntityProductionAvailability(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_STONEWALL), ITEM_REMOVED)
			Player_SetEntityProductionAvailability(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_PALISADE), ITEM_REMOVED)
		else
			
			Player_SetUpgradeAvailability(player1, BP_GetUpgradeBlueprint "upgrade_improved_siege_engineers_mon", ITEM_REMOVED)
			--Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_mangonel_3_field_construct_mon"), ITEM_REMOVED)
			--Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_springald_3_field_construct_mon"), ITEM_REMOVED)
			--Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_trebuchet_4_cw_field_construct_mon"), ITEM_REMOVED)
			--Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_trebuchet_4_tr_field_construct_mon"), ITEM_REMOVED)
		end
		if player_civ == "hre" then
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint ("building_landmark_age3_hohenzollern_castle_hre"), ITEM_REMOVED)
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint ("building_landmark_age3_eltz_castle_hre"), ITEM_REMOVED)
		end
		if player_civ == "english" then
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint ("building_landmark_age2_white_tower_eng"), ITEM_REMOVED)
		end
		if player_civ == "malian" then
			
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_Age3_landmarke_mal"), ITEM_REMOVED)
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_Age3_landmarkf_mal"), ITEM_REMOVED)
		end
		if player_civ == "abbasid" then
			Player_SetUpgradeAvailability(player1, UPG.ABBASID.UPGRADE_ADD_CULTURE_WING_CASTLE, ITEM_LOCKED)
			Player_SetUpgradeAvailability(player1, UPG.ABBASID.UPGRADE_ADD_TRADE_WING_CASTLE, ITEM_LOCKED)
			Player_SetUpgradeAvailability(player1, UPG.ABBASID.UPGRADE_ADD_MILITARY_WING_CASTLE, ITEM_LOCKED)
			Player_SetUpgradeAvailability(player1, UPG.ABBASID.UPGRADE_ADD_ECONOMY_WING_CASTLE, ITEM_LOCKED)
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_mangonel_3_buildable_abb"), ITEM_REMOVED)
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_springald_3_buildable_abb"), ITEM_REMOVED)
			Player_SetAbilityAvailability(player.id, BP_GetAbilityBlueprint ("monk_conversion_faith_abb"), ITEM_REMOVED)
		end
		if player_civ == "chinese" then
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age2_clocktower_control_chi"), ITEM_REMOVED)
		end
		if player_civ == "ottoman" then
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age2_tophane_armory_ott"), ITEM_REMOVED)
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_istanbul_observatory_ott"), ITEM_REMOVED)
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_kilitbahir_castle_ott"), ITEM_REMOVED)
		end
		if AI_Difficulty == 0 then
			Player_CompleteUpgrade(player.id, UPG.COMMON.UPGRADE_MELEE_DAMAGE_I)
			Player_CompleteUpgrade(player.id, UPG.COMMON.UPGRADE_RANGED_ARMOR_I)
		else
			Player_SetEntityProductionAvailability(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_KEEP), ITEM_LOCKED)
		end
		if AI_Difficulty >= 2 then
			Player_SetAbilityAvailability(player.id, BP_GetAbilityBlueprint("monk_conversion"), ITEM_REMOVED)
		else
			Player_CompleteUpgrade(player.id, UPG.COMMON.UPGRADE_RANGED_DAMAGE_I)
			Player_CompleteUpgrade(player.id, UPG.COMMON.UPGRADE_MELEE_ARMOR_I)
		end
		Player_SetEntityProductionAvailability(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_WORKSHOP), ITEM_LOCKED)
	end
end
-- This function will be called before the intro cinematic
function Mission_Preset()	-- any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)
	
	AI_SetPersonality( player3, "default_campaign" )
	-- Population 
	Modifier_ApplyToPlayer(Modifier_Create(MAT_Player, "personnel_cap_player_modifier", MUT_Addition, false, 50, ""), player1, 0)
	Modifier_ApplyToPlayer(Modifier_Create(MAT_Player, "personnel_cap_player_modifier", MUT_Addition, false, 50, ""), player2, 0)
	-- Add professional scout upgrades
	Player_CompleteUpgrade(player1, UPG.COMMON.UPGRADE_SCOUT_FORESTER)
	Player_CompleteUpgrade(player2, UPG.COMMON.UPGRADE_SCOUT_FORESTER)
	-- enable resource pickups
	Player_SetStateModelBool(player2, "player_can_interact_with_resource_pickups", true)

	--[[ Alternative Start 
	Player_SetStateModelFloat(player1, "has_capital", 1.0)
	Player_SetStateModelFloat(player2, "has_capital", 1.0)
	]]

	--Initialize objectives
	SeizeCity_InitObjectives() -- Main
	Capture_EnemiesTownInit()
	DestroyTown_InitObjectives()
	DestroySiege_InitObjectives()
	DestroyKeep_InitObjectives() -- Main-secondary
	
	
end
-- This function will be called after the intro cinematic, before the player takes control
function Mission_Start()	-- this is triggered after the intro, just as control is passed to the player
	-- Set age here instead of Mission_SetupPlayers / FPS FIX
	Player_SetCurrentAge(player1, AGE_FEUDAL) 
	Player_SetCurrentAge(player2, AGE_FEUDAL)
	-- start the opening objectives (if you're using ObjectiveTable style objectives)
	Objective_Start(OBJ_SeizeCity,true, false)
	Objective_Start(OBJ_CaptureEnemiesTown,true, false)
	Objective_Start(SOBJ_Warning,true, false)
	Rule_AddOneShot(Start_Setup, 0) -- Delay to load models from age up
	Rule_Add(CaptureMine_ForceComplete) -- Incase only player 2 has completed objective
	-- Coop_2_Arabia_data.scar
	Rule_AddInterval(SGroup_Tracker, 60, { player = player1 })
	Rule_AddInterval(SGroup_Tracker, 60, { player = player2 })
	
	

end
--The recipe can be used to create initial spawns, set up objectives or completion/failure states
function GetRecipe()
	

	local recipe = {
		
		introNIS = EVENTS.TEMPLATEMISSION_Intro,

		-- Defining Locations for reference in script
		locations = {
			{ 
				descriptor = "settlementStart", 
				marker = mkr_settlement_start, 
				player = player3, 
				sgroup_defenders = sg_start_mining_def, --when setting capture objectives
 			},	
			{ 
				descriptor = "siegeWorkshop", 
				marker = mkr_siege_obj, 
				player = player3, 
				--egroup = eg_start_player1, 
				sgroup_defenders = sg_siege_gaurds, 
 			},	
		},
		
		
		-- Modules
		modules = {
			
		},

		
		-- Playbill
		playbill = {
		},
		
		-- Presentation aspects for the start or end of a mission
		onStart = {
			intelEvent = "",
			expositionCamera = {},
			titleCard = {
				title = "$11207012",   -- Avignon
				--	date =  "$de672d9693184526b0a25e72c219355b:11",   -- 1754
				icon = "icons/campaign/campaign_hundred_disorder"
			},
			actions = {
			},
		},
		
	}
	
	return recipe

end

