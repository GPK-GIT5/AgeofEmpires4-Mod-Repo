-- From Advanced Game Settings by Woprock 
function AGS_GetCivilizationEntity(player_civ, bp_type)
	return BP_GetEntityBlueprint(AGS_ENTITY_TABLE[player_civ][bp_type])
end -- used for AGS_ENTITY_TABLE > Mission_SetRestrictions

-- Setup starter inits for all players, extra settings before launch
function Start_Setup()
	
	local player1_civ = Player_GetRaceName(player1)
	local player2_civ = Player_GetRaceName(player2)
	
	-- Spawn Player 1 / Select faction
	if player1_civ == "malian" then
		UnitEntry_DeploySquads(player1, sg_player1_start, Unit_Types.start_player1_mal, mkr_player1_spawn01)
	elseif player1_civ == "abbasid" then
		UnitEntry_DeploySquads(player1, sg_player1_start, Unit_Types.start_player1_abb, mkr_player1_spawn01)
	elseif player1_civ == "rus" or player1_civ == "french" then -- Calvary
		UnitEntry_DeploySquads(player1, sg_player1_start, Unit_Types.start_player1_cav, mkr_player1_spawn01)
	elseif player1_civ == "english" or player1_civ == "hre" then -- Infantry
		UnitEntry_DeploySquads(player1, sg_player1_start, Unit_Types.start_player1_inf, mkr_player1_spawn01)
	else
		UnitEntry_DeploySquads(player1, sg_player1_start, Unit_Types.start_player1, mkr_player1_spawn01) -- Default
	end
	
	-- Spawn Player 2 / Select faction
	if player2_civ == "malian" then
		UnitEntry_DeploySquads(player2, sg_player2_start, Unit_Types.start_player2_mal, mkr_player2_spawn01)
	elseif player2_civ == "chinese" then
		UnitEntry_DeploySquads(player2, sg_player2_start, Unit_Types.start_player2_chi, mkr_player2_spawn01)
	elseif player2_civ == "abbasid" then
		UnitEntry_DeploySquads(player2, sg_player2_start, Unit_Types.start_player2_abb, mkr_player2_spawn01)
	elseif player2_civ == "mongol" then
		UnitEntry_DeploySquads(player2, sg_player2_start, Unit_Types.start_player2_mon, mkr_player2_spawn01)
	elseif player2_civ == "rus" then
		UnitEntry_DeploySquads(player2, sg_player2_start, Unit_Types.start_player2_rus, mkr_player2_spawn01)
	else
		UnitEntry_DeploySquads(player2, sg_player2_start, Unit_Types.start_player2, mkr_player2_spawn01) -- Default
	end
	
	count_start_player1 = SGroup_Count(sg_player1_start) -- Setup Reinforcements_Player1
	count_start_player2 = SGroup_Count(sg_player2_start) -- Setup Reinforcements_Player2
	
	Rule_Add(Reinforcements_Player1)
	Rule_Add(Reinforcements_Player2)
	if AI_Difficulty >= 2 then -- Add reinforcement rules
		Rule_Add(Reinforcements_Trader)
	end 
	-- Difficulty: Starting guards difficulty
	if AI_Difficulty <= 2 then -- Deploy starter units
		-- Gates Camp /  MAA, Spearman, Archers / 26x
		UnitEntry_DeploySquads(player3, sg_wave1_mining02, Unit_Types.units_camp, mkr_gates_camp)
		-- Gates Base /  MAA, Spearman, Archers / 26x
		UnitEntry_DeploySquads(player3, sg_start_gate01, Unit_Types.units_camp, mkr_gates_base)
		-- Trade Post /  MAA, Spearman, Archers / 26x (1)
		UnitEntry_DeploySquads(player3, sg_start_camp01, Unit_Types.units_camp, mkr_start_trader1)
		-- Patrol /  MAA, Spearman, Archers / 20x (3)
		UnitEntry_DeploySquads(player3, sg_start_patrol01, Unit_Types.units_patrol, mkr_start_mining2)
		
	else
		-- Gates Camp 
		UnitEntry_DeploySquads(player3, sg_wave1_mining02, Unit_Types.units_camp_hard, mkr_gates_camp)
		-- Gates Base
		UnitEntry_DeploySquads(player3, sg_start_gate01, Unit_Types.units_camp_hard, mkr_gates_base)
		-- Trade Post 
		UnitEntry_DeploySquads(player3, sg_start_camp01, Unit_Types.units_camp_hard, mkr_start_trader1)
		-- Patrol / 
		-- UnitEntry_DeploySquads(player3, sg_start_patrol01, Unit_Types.units_patrol_hard, mkr_start_mining2)
		
	end -- AI = Easy, Normal, Hard / Hardest
	count_enemey01_camp = SGroup_Count(sg_start_camp01) -- used for Reinforcements_Trader
	
	
	-- Mining Camp /  MAA, Spearman, Archers / 26x (2)
	UnitEntry_DeploySquads(player3, sg_start_mining_def, Unit_Types.units_camp, mkr_start_mining1)
	count_start_mining_def = SGroup_Count(sg_start_mining_def) -- used for Reinforcements Players
	-- Enable Patrol_Cycle for (1,2,3)
	Rule_AddInterval(Patrol_Cycle, 25, { sgroup = sg_start_camp01, spawn_loc = mkr_start_trader1, dest_loc = mkr_start_trader2, sgroup_all = sg_start_troops, count = count_start_troop }) -- Count check only required once
	Rule_AddInterval(Patrol_Cycle, 45, { sgroup = sg_start_mining_def, spawn_loc = mkr_start_mining1, dest_loc = mkr_start_mining2 })
	Rule_AddInterval(Patrol_Cycle, 90, { sgroup = sg_start_patrol01, spawn_loc = mkr_start_mining2, dest_loc = mkr_start_trader1 })
	-- Disable Patrol_Cycle when all units eliminated
	sg_start_troops = SGroup_CreateIfNotFound("sg_start_troops")
	SGroup_AddGroup(sg_start_troops, sg_start_camp01)
	SGroup_AddGroup(sg_start_troops, sg_start_patrol01)
	SGroup_AddGroup(sg_start_troops, sg_start_mining_def)
	count_start_troop = SGroup_Count(sg_start_troops)
	-- Start Wave attacks
	Unit_Path_Data() -- Init path data	
end

-- Thanks to AGameAnx		
function GetAIDifficulty(player)
	local AIPlayerNames = {
		[Loc_ToAnsi(1309)] = 0,     -- A.I. Easy
		[Loc_ToAnsi(1310)] = 1,     -- A.I. Intermediate
		[Loc_ToAnsi(1311)] = 2,     -- A.I. Hard
		[Loc_ToAnsi(1312)] = 3,     -- A.I. Hardest
		[Loc_ToAnsi(11250912)] = 4, -- A.I. Redicilous
		[Loc_ToAnsi(11250913)] = 5, -- A.I. Outrageous
		[Loc_ToAnsi(11250914)] = 6, -- A.I. Absurd
	}
	return AIPlayerNames[Loc_ToAnsi(Player_GetDisplayName(player))] or 2
end

-- Setup Reinforcements
function Reinforcements_Trader()
	if SGroup_Count(sg_start_camp01) < 0.3 * count_enemey01_camp then
			sg_enemey_qrf_trade = SGroup_CreateIfNotFound("sg_enemey_qrf_trade")
			UnitEntry_DeploySquads(player3, sg_enemey_qrf_trade, Unit_Types.units_reinforcement_trade, mkr_city_reinforcements)
			Cmd_FormationAttackMove(sg_enemey_qrf_trade, mkr_start_trader1)
			Cmd_FormationAttackMove(sg_enemey_qrf_trade, mkr_start_trader2, true)
			Rule_RemoveMe()
	end
end 

function Reinforcements_Player1()
	local player1_civ = Player_GetRaceName(player1)
	
	if SGroup_Count(sg_player1_start) < 0.3 * count_start_player1 then
		if AI_Difficulty <= 2 then -- Disable reinforcements before capture
			
			if player1_civ == "malian" then
				UnitEntry_DeploySquads(player1, sg_player1_reinforcements, Unit_Types.units_player1_reinforce_mal, mkr_player1_spawn01)
			elseif player1_civ == "rus" or player1_civ == "french" then -- Calvary
				UnitEntry_DeploySquads(player1, sg_player1_reinforcements, Unit_Types.units_player1_reinforce_cav, mkr_player1_spawn01)
			elseif player1_civ == "english" or player1_civ == "hre" then -- Infantry
				UnitEntry_DeploySquads(player1, sg_player1_reinforcements, Unit_Types.units_player1_reinforce_inf, mkr_player1_spawn01)
			else
				UnitEntry_DeploySquads(player1, sg_player1_reinforcements, Unit_Types.units_player1_reinforce, mkr_player1_spawn01)
			end
			SendReinforceNotification(mkr_player1_spawn01, "$42813") -- Reinforcements have arrived!
			Rule_RemoveMe()
		end

	elseif SGroup_Count(sg_start_mining_def) < 0.1 * count_start_mining_def then -- Switch spawn location (Mining Camp)
		
		if player1_civ == "malian" then
			UnitEntry_DeploySquads(player1, sg_player1_reinforcements, Unit_Types.units_player1_reinforce_mal, tc_spawn)
		elseif player1_civ == "rus" or player1_civ == "french" then -- Calvary
			UnitEntry_DeploySquads(player1, sg_player1_reinforcements, Unit_Types.units_player1_reinforce_cav, tc_spawn)
		elseif player1_civ == "english" or player1_civ == "hre" then -- Infantry
			UnitEntry_DeploySquads(player1, sg_player1_reinforcements, Unit_Types.units_player1_reinforce_inf, tc_spawn)
		else
			UnitEntry_DeploySquads(player1, sg_player1_reinforcements, Unit_Types.units_player1_reinforce, tc_spawn)
		end
		Rule_RemoveMe()
	end
	
end 

function Reinforcements_Player2()
	local player2_civ = Player_GetRaceName(player2)
	
	if SGroup_Count(sg_player2_start) < 0.3 * count_start_player2 then
		if AI_Difficulty <= 2 then -- Disable reinforcements before capture
			if player2_civ == "malian" then
				UnitEntry_DeploySquads(player2, sg_player2_reinforcements, Unit_Types.units_player2_reinforce_mal, mkr_player2_spawn01)
			elseif player2_civ == "chinese" then
				UnitEntry_DeploySquads(player2, sg_player2_reinforcements, Unit_Types.units_player2_reinforce_chi, mkr_player2_spawn01)
			elseif player2_civ == "abbasid" then
				UnitEntry_DeploySquads(player2, sg_player2_reinforcements, Unit_Types.units_player2_reinforce_abb, mkr_player2_spawn01)
			elseif player2_civ == "rus" or player2_civ == "mongol" then
				UnitEntry_DeploySquads(player2, sg_player2_reinforcements, Unit_Types.units_player2_reinforce_cav, mkr_player2_spawn01)
			else
				UnitEntry_DeploySquads(player2, sg_player2_reinforcements, Unit_Types.units_player2_reinforce, mkr_player2_spawn01)
			end
		
		
			SendReinforceNotification(mkr_player2_spawn01, "$42813") -- Reinforcements have arrived!
			Rule_RemoveMe()

		end
	elseif SGroup_Count(sg_start_mining_def) < 0.1 * count_start_mining_def then -- Switch spawn location (Mining Camp)
		if player2_civ == "malian" then
			UnitEntry_DeploySquads(player2, sg_player2_reinforcements, Unit_Types.units_player2_reinforce_mal, tc_spawn)
		elseif player2_civ == "chinese" then
			UnitEntry_DeploySquads(player2, sg_player2_reinforcements, Unit_Types.units_player2_reinforce_chi, tc_spawn)
		elseif player2_civ == "abbasid" then
			UnitEntry_DeploySquads(player2, sg_player2_reinforcements, Unit_Types.units_player2_reinforce_abb, tc_spawn)
		elseif player2_civ == "rus" or player2_civ == "mongol" then
			UnitEntry_DeploySquads(player2, sg_player2_reinforcements, Unit_Types.units_player2_reinforce_cav, tc_spawn)
		else
			UnitEntry_DeploySquads(player2, sg_player2_reinforcements, Unit_Types.units_player2_reinforce, tc_spawn)
		end

		Rule_RemoveMe()
	end
end

function Reinforcements_Siege()
	-- Spawn Siege Reinforcements for players
	UnitEntry_DeploySquads(player1, sg_player1_siege, Unit_Types.units_siege, tc_spawn)
	Cmd_FormationAttackMove(sg_player1_siege, mkr_start_mining1)
	-- Spawn Siege Reinforcements for players
	UnitEntry_DeploySquads(player2, sg_player2_siege, Unit_Types.units_siege, tc_spawn)
	Cmd_FormationAttackMove(sg_player2_siege, mkr_start_mining1)
end -- AI = Easy, Normal

-- Group all player units for Proximity Marker
function SGroup_Tracker(context, data)
	
	local player = data.player 
	
	Player_GetAll(player)
	SGroup_Filter(sg_allsquads, "military", FILTER_KEEP)
	SGroup_AddGroup(sg_player_team, sg_allsquads)
	
	
end -- used for CaptureMine_Reinforcements() > Rule_EnterProximity 
-- Patrol_Cycle & Units Deploy / Thanks to Foxplot
function Patrol_Cycle(context, data) -- Used to cycle units between waypoints
	
	local sgroup = data.sgroup 
	local spawn_loc = data.spawn_loc
	local dest_loc = data.dest_loc
	local sgroup_all = data.sgroup_all
	local count = data.count
	-- Removed SGroup_IsIdle check because we use Rule_AddInterval
		Cmd_FormationAttackMove(sgroup, spawn_loc)
		Cmd_FormationAttackMove(sgroup, dest_loc, true)		

	if SGroup_Count(sg_start_troops) < 0.1 * count_start_troop  then
		Rule_RemoveMe()
	end
	
end
-- Deploy_Unit & Gaurdian_Raid combined & renamed
function Units_Deploy(context, data) -- Used to spawn units / attack groups

	local player = data.player
	local sgroup = data.sgroup
	local unit_type = data.unit_type
	local spawn_loc = data.spawn_loc
	local path = data.path 


	UnitEntry_DeploySquads(player, sgroup, unit_type, spawn_loc)
	Cmd_FormationAttackMove(sgroup, path[1])
	for index, mkr in pairs(path) do
		if index > 1 then
			Cmd_FormationAttackMove(sgroup, mkr, true)
		end
	end

end

function Defeat_Function()
	
	Mission_Fail()
	local victorTeam = TEAMS[2]
	for i, team in pairs(TEAMS) do
		if team ~= victorTeam then
			Core_SetTeamDefeated(team, -1, 2)
		end
	end
	Core_SetTeamVictorious(victorTeam, -1, 1)
	
end





