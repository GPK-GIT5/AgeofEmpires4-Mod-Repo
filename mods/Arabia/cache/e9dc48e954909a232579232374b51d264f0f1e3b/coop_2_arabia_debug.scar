---Debug_OnPlayerDefeat: Log player elimination.
function Debug_OnPlayerDefeat(player_id, reason)
    if not DEBUG_ENABLED then return end
    
    Debug_Log(DEBUG_EVT_PLAYER_DEFEAT, player_id, "Defeated: " .. (reason or "unknown"))
end

---Debug_OnPlayerVictory: Log player victory.
function Debug_OnPlayerVictory(player_id)
    if not DEBUG_ENABLED then return end
    
    Debug_Log(DEBUG_EVT_PLAYER_VICTORY, player_id, "Victory!")
end

-- ============================================================
-- STATISTICS & ANALYSIS
-- ============================================================

---Debug_PrintStats: Print summary statistics from the event log.
function Debug_PrintStats()
    if not DEBUG_ENABLED or #DEBUG_EVENT_LOG == 0 then return end
    
    local stats = {
        total_events = #DEBUG_EVENT_LOG,
        by_type = {},
        by_player = {},
        first_event_time = DEBUG_EVENT_LOG[1].elapsed_sec,
        last_event_time = DEBUG_EVENT_LOG[#DEBUG_EVENT_LOG].elapsed_sec,
        total_duration = DEBUG_EVENT_LOG[#DEBUG_EVENT_LOG].elapsed_sec - DEBUG_EVENT_LOG[1].elapsed_sec,
    }
    
    -- Aggregate by event type
    for _, evt in ipairs(DEBUG_EVENT_LOG) do
        stats.by_type[evt.event_type] = (stats.by_type[evt.event_type] or 0) + 1
    end
    
    -- Aggregate by player
    for _, evt in ipairs(DEBUG_EVENT_LOG) do
        if evt.player_id ~= "GLOBAL" then
            stats.by_player[evt.player_id] = (stats.by_player[evt.player_id] or 0) + 1
        end
    end
    
    print("[DEBUG] ===== STATISTICS =====")
    print("[DEBUG] Total Events: " .. stats.total_events)
    print("[DEBUG] Mission Duration: " .. string.format("%.1f seconds", stats.total_duration))
    print("")
    print("[DEBUG] Events by Type:")
    for evt_type, count in pairs(stats.by_type) do
        print("[DEBUG]   " .. evt_type .. ": " .. count)
    end
    print("")
    print("[DEBUG] Events by Player:")
    for player_id, count in pairs(stats.by_player) do
        print("[DEBUG]   Player " .. tostring(player_id) .. ": " .. count .. " events")
    end
    print("")
end

---Debug_GetEventsSince: Return all events after a given elapsed time threshold.
-- Useful for filtering to a specific phase or time window.
function Debug_GetEventsSince(elapsed_sec_threshold)
    local result = {}
    for _, evt in ipairs(DEBUG_EVENT_LOG) do
        if evt.elapsed_sec >= elapsed_sec_threshold then
            table.insert(result, evt)
        end
    end
    return result
end

---Debug_GetEventsByType: Return all events of a specific type.
function Debug_GetEventsByType(event_type)
    local result = {}
    for _, evt in ipairs(DEBUG_EVENT_LOG) do
        if evt.event_type == event_type then
            table.insert(result, evt)
        end
    end
    return result
end

---Debug_GetEventsByPlayer: Return all events for a specific player.
function Debug_GetEventsByPlayer(player_id)
    local result = {}
    for _, evt in ipairs(DEBUG_EVENT_LOG) do
        if evt.player_id == player_id then
            table.insert(result, evt)
        end
    end
    return result
end

-- ============================================================
-- TEST HARNESS
-- ============================================================
-- Console-safe functions to simulate mission events for validation.
-- These do NOT call Player_Set* APIs; they only validate the data layer.
-- ============================================================

---Debug_SimulatePlayerProgression: Test harness for player progression chain.
-- Simulates: mission start → players ready → restrictions applied → objectives unlocked.
function Debug_SimulatePlayerProgression()
    print("[TEST] ===== Player Progression Simulation =====")
    
    for _, player in pairs(PLAYERS) do
        local pid = player.id
        local civ = GetPlayerCiv(pid)
        local raceName = string.lower(Player_GetRaceName(pid))
        
        print("")
        print("[TEST] Player " .. tostring(pid) .. " (" .. raceName .. " → " .. civ .. "):")
        
        -- [1] Mission start
        print("[TEST]   [START] Restriction profile applied: 'starting'")
        if DC.restrict_siege then
            print("[TEST]      ✓ Siege locked")
        else
            print("[TEST]      ✗ Siege unlocked (Easy)")
        end
        if DC.restrict_engineers then
            print("[TEST]      ✓ Engineers locked")
        else
            print("[TEST]      ✗ Engineers unlocked (Easy)")
        end
        if DC.restrict_workshop then
            print("[TEST]      ✓ Workshop locked")
        end
        
        -- [2] Phase 2 objectives
        print("[TEST]   [PHASE2] Profile applied: '" .. DC.phase2_siege_profile .. "'")
        if DC.phase2_siege_profile == "siege_available" then
            print("[TEST]      ✓ Siege unlocked")
        elseif DC.phase2_siege_profile == "engineers_available" then
            print("[TEST]      ✓ Siege unlocked + Engineers unlocked")
        end
        if DC.phase2_workshop_unlock then
            print("[TEST]      ✓ Workshop unlocked")
        end
        
        -- [3] Profile chain validation
        local profile_chain = {
            "starting",
            DC.phase2_siege_profile,
        }
        if DC.phase2_workshop_unlock then
            table.insert(profile_chain, "workshop_available")
        end
        
        print("[TEST]   Profile chain:")
        for i, pname in ipairs(profile_chain) do
            local prof = Restriction_Profile[pname]
            if prof then
                print("[TEST]      [" .. i .. "] " .. pname .. " ✓")
            else
                print("[TEST]      [" .. i .. "] " .. pname .. " ✗ NOT FOUND")
            end
        end
    end
    
    print("")
end

---Debug_SimulateDLCResolution: Validate DLC civ resolution for all players.
function Debug_SimulateDLCResolution()
    print("[TEST] ===== DLC Civ Resolution ===== ")
    
    for _, player in pairs(PLAYERS) do
        local pid = player.id
        local raw = string.lower(Player_GetRaceName(pid))
        local resolved = GetPlayerCiv(pid)
        
        print("")
        print("[TEST] Player " .. tostring(pid) .. ":")
        print("[TEST]   Raw: " .. raw)
        print("[TEST]   Resolved: " .. resolved)
        
        -- Verify AGS_ENTITY_TABLE entry exists
        if AGS_ENTITY_TABLE[resolved] then
            print("[TEST]   AGS_ENTITY_TABLE entry: ✓")
        else
            print("[TEST]   AGS_ENTITY_TABLE entry: ✗ MISSING")
        end
        
        -- Verify parent chain if DLC civ
        if raw ~= resolved then
            print("[TEST]   Parent chain: " .. raw .. " → " .. resolved)
            if DLC_CIV_PARENT_MAP[raw] then
                print("[TEST]   DLC registration: ✓")
            else
                print("[TEST]   DLC registration: ✗ NO PARENT MAP")
            end
        else
            print("[TEST]   Parent chain: Base civ (no DLC)")
        end
        
        -- Check siege weapon entry
        local siege_sq = AGS_GetSiegeSquad(resolved, BP_SIEGE_MANGONEL)
        if siege_sq then
            print("[TEST]   Siege weapon (Mangonel): ✓ " .. tostring(siege_sq))
        else
            print("[TEST]   Siege weapon (Mangonel): ✗ MISSING")
        end
    end
    
    print("")
end

---Debug_DumpRestrictionState: Print current restriction state for all players.
function Debug_DumpRestrictionState()
    print("[TEST] ===== Current Restriction State =====")
    
    for _, player in pairs(PLAYERS) do
        local pid = player.id
        local profile = GetPlayerProfile(pid)
        
        print("")
        print("[TEST] Player " .. tostring(pid) .. ":")
        print("[TEST]   Current profile: " .. profile)
        
        -- Show what's locked/unlocked
        if DC.restrict_siege then
            print("[TEST]   Siege: LOCKED")
        else
            print("[TEST]   Siege: UNLOCKED")
        end
        
        if DC.restrict_engineers then
            print("[TEST]   Engineers: LOCKED")
        else
            print("[TEST]   Engineers: UNLOCKED")
        end
        
        if DC.restrict_workshop then
            print("[TEST]   Workshop: LOCKED")
        else
            print("[TEST]   Workshop: UNLOCKED")
        end
    end
    
    print("")
end

---Debug_ComparisonWithJapan: Compare Arabia restrictions vs Japan mod for feature parity.
function Debug_ComparisonWithJapan()
    print("[TEST] ===== Arabia vs Japan: Feature Parity Check =====")
    print("")
    print("[TEST] Arabia v1.4 Features:")
    print("[TEST]   ✓ CBA_SIEGE_TABLE (16 entries: 12 base + 4 DLC with unique attribNames)")
    print("[TEST]   ✓ AGS_GetSiegeSquad / AGS_GetSiegeEntity (DLC-aware, improved)")
    print("[TEST]   ✓ Data-driven landmark tables (LANDMARK_KEEP/AGE4, HOUSE_OF_WISDOM)")
    print("[TEST]   ✓ 4-profile restriction system (starting, siege_available, engineers_available, workshop_available)")
    print("[TEST]   ✓ DC-driven profile selection (phase2_siege_profile, phase2_workshop_unlock)")
    print("[TEST]   ✓ Restriction validators (Validator_RestrictionState, Simulate_PlayerProgression)")
    print("[TEST]   ✓ IsCivFamily / IsCivExact / IsCivFamilyAny helpers")
    print("")
    print("[TEST] Japan v1.3 for reference:")
    print("[TEST]   - Same CBA_SIEGE_TABLE structure")
    print("[TEST]   - Same 4-profile concepts (with minor naming differences)")
    print("[TEST]   - Same DLC resolver + composition map generation")
    print("")
    print("[TEST] Arabia improvements over Japan:")
    print("[TEST]   ✓ Improved siege lookup (check exact civ BEFORE parent chain)")
    print("[TEST]   ✓ Data-driven landmark tables (Japan had some hardcoded)")
    print("[TEST]   ✓ Cleaner restriction profile design (less nested depth)")
    print("")
end

---Debug_SpawnWaveSimulation: Dry-run validation of spawn compositions.
function Debug_SpawnWaveSimulation()
    print("[TEST] ===== Spawn Wave Composition Validation =====")
    print("")
    
    -- Check key compositions exist
    local compositions_to_check = {
        "units_camp",
        "units_patrol_hard",
        "wave_city_5m",
        "wave_city_10m",
        "wave_city_15m",
        "wave_siege",
    }
    
    print("[TEST] Critical spawn compositions:")
    for _, key in ipairs(compositions_to_check) do
        if Unit_Types[key] then
            local count = #Unit_Types[key]
            print("[TEST]   " .. key .. ": ✓ (" .. count .. " unit entries)")
        else
            print("[TEST]   " .. key .. ": ✗ MISSING")
        end
    end
    
    print("")
end

