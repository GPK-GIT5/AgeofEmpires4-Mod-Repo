-- ============================================================
-- CHRONOLOGICAL EVENT LOG
-- ============================================================
-- Tracks events from mission start through objective completion.
-- Each entry: { timestamp_sec, event_type, player_id, detail }
-- Flushed to scarlog in human-readable format.
-- ============================================================

DEBUG_ENABLED = false  -- Set true to enable full logging

-- Event log buffer
DEBUG_EVENT_LOG = {}
DEBUG_START_TIME = 0

-- Event type constants (for filtering/analysis)
DEBUG_EVT_MISSION_START = "MISSION_START"
DEBUG_EVT_MISSION_END = "MISSION_END"
DEBUG_EVT_PLAYER_READY = "PLAYER_READY"
DEBUG_EVT_PLAYER_DISCONNECT = "PLAYER_DISCONNECT"
DEBUG_EVT_PLAYER_TAKEOVER = "PLAYER_TAKEOVER"
DEBUG_EVT_RESTRICTION_APPLIED = "RESTRICTION_APPLIED"
DEBUG_EVT_OBJECTIVE_STARTED = "OBJECTIVE_STARTED"
DEBUG_EVT_OBJECTIVE_COMPLETED = "OBJECTIVE_COMPLETED"
DEBUG_EVT_PHASE_ENTERED = "PHASE_ENTERED"
DEBUG_EVT_SPAWN_WAVE = "SPAWN_WAVE"
DEBUG_EVT_SIEGE_UNLOCK = "SIEGE_UNLOCK"
DEBUG_EVT_WORKSHOP_UNLOCK = "WORKSHOP_UNLOCK"
DEBUG_EVT_PLAYER_DEFEAT = "PLAYER_DEFEAT"
DEBUG_EVT_PLAYER_VICTORY = "PLAYER_VICTORY"

---Debug_Log: Record a timestamped event to the log buffer.
function Debug_Log(event_type, player_id, detail)
    if not DEBUG_ENABLED then return end
    
    local elapsed = World_GetGameTime() - DEBUG_START_TIME
    local entry = {
        elapsed_sec = elapsed,
        event_type = event_type,
        player_id = player_id or "GLOBAL",
        detail = detail or "",
        world_time = World_GetGameTime(),
    }
    table.insert(DEBUG_EVENT_LOG, entry)
end

---Debug_Flush: Output all buffered events to scarlog in chronological order.
function Debug_Flush()
    if not DEBUG_ENABLED or #DEBUG_EVENT_LOG == 0 then return end
    
    print("[DEBUG] ===== CHRONOLOGICAL EVENT LOG (Mission Duration) =====")
    print("[DEBUG] Total Events: " .. tostring(#DEBUG_EVENT_LOG))
    print("")
    
    for idx, evt in ipairs(DEBUG_EVENT_LOG) do
        local formatted = string.format(
            "[%05.2fs] [%02d] %-20s %s",
            evt.elapsed_sec,
            evt.player_id == "GLOBAL" and 0 or tonumber(evt.player_id) or 0,
            evt.event_type,
            evt.detail
        )
        print("[DEBUG] " .. formatted)
    end
    
    print("")
    print("[DEBUG] ===== END EVENT LOG =====")
end

-- ============================================================
-- MISSION LIFECYCLE HOOKS
-- ============================================================

---Debug_OnMissionStart: Call from Mission_Start() to initialize logging.
function Debug_OnMissionStart()
    if not DEBUG_ENABLED then return end
    
    DEBUG_START_TIME = World_GetGameTime()
    Debug_Log(DEBUG_EVT_MISSION_START, "GLOBAL", "Mission initialized, difficulty=" .. tostring(AI_Difficulty))
    
    print("[DEBUG] ===== MISSION START =====")
    print("[DEBUG] Difficulty Tier: " .. AI_Difficulty .. " (" .. DC.label .. ")")
    print("[DEBUG] Player Count: " .. tostring(_CountKeys(PLAYERS)))
    for _, player in pairs(PLAYERS) do
        print("[DEBUG]   Player " .. tostring(player.id) .. ": " .. Player_GetRaceName(player.id) 
            .. " (resolved: " .. GetPlayerCiv(player.id) .. ")")
    end
    print("")
end

---Debug_OnMissionEnd: Call at end of mission (victory/defeat).
-- param end_reason: "victory" or "defeat"
function Debug_OnMissionEnd(end_reason)
    if not DEBUG_ENABLED then return end
    
    Debug_Log(DEBUG_EVT_MISSION_END, "GLOBAL", "Mission ended: " .. end_reason)
    
    print("[DEBUG] ===== MISSION END =====")
    print("[DEBUG] Reason: " .. end_reason)
    print("[DEBUG] Total Events Logged: " .. tostring(#DEBUG_EVENT_LOG))
    print("")
    
    -- Auto-flush summary
    Debug_PrintStats()
    Debug_Flush()
end

---Debug_OnPlayerReady: Called when player has initial army spawned.
function Debug_OnPlayerReady(player)
    if not DEBUG_ENABLED then return end
    
    Debug_Log(DEBUG_EVT_PLAYER_READY, player.id, "Ready to command " .. Player_GetRaceName(player.id))
end

---Debug_OnPlayerDisconnect: Called when player disconnects.
function Debug_OnPlayerDisconnect(player_id)
    if not DEBUG_ENABLED then return end
    
    Debug_Log(DEBUG_EVT_PLAYER_DISCONNECT, player_id, "Disconnected")
end

---Debug_OnPlayerTakeover: Called when AI assumes control of a disconnected player.
function Debug_OnPlayerTakeover(player_id, ai_difficulty)
    if not DEBUG_ENABLED then return end
    
    Debug_Log(DEBUG_EVT_PLAYER_TAKEOVER, player_id, "AI takeover, tier=" .. tostring(ai_difficulty))
end

---Debug_OnRestrictionApplied: Log when a restriction profile is applied.
function Debug_OnRestrictionApplied(player_id, profile_name)
    if not DEBUG_ENABLED then return end
    
    Debug_Log(DEBUG_EVT_RESTRICTION_APPLIED, player_id, "Profile: " .. profile_name)
end

---Debug_OnObjectiveStarted: Log objective activation.
function Debug_OnObjectiveStarted(player_id, obj_name)
    if not DEBUG_ENABLED then return end
    
    Debug_Log(DEBUG_EVT_OBJECTIVE_STARTED, player_id, obj_name)
end

---Debug_OnObjectiveCompleted: Log objective completion with time elapsed.
function Debug_OnObjectiveCompleted(player_id, obj_name)
    if not DEBUG_ENABLED then return end
    
    Debug_Log(DEBUG_EVT_OBJECTIVE_COMPLETED, player_id, obj_name)
end

---Debug_OnPhaseEntered: Log phase transitions.
function Debug_OnPhaseEntered(phase_num, phase_name)
    if not DEBUG_ENABLED then return end
    
    Debug_Log(DEBUG_EVT_PHASE_ENTERED, "GLOBAL", "Phase " .. tostring(phase_num) .. ": " .. phase_name)
end

---Debug_OnSpawnWave: Log AI spawn waves.
function Debug_OnSpawnWave(wave_name, unit_count, spawn_marker)
    if not DEBUG_ENABLED then return end
    
    Debug_Log(DEBUG_EVT_SPAWN_WAVE, "GLOBAL", wave_name .. " | " .. tostring(unit_count) .. " units")
