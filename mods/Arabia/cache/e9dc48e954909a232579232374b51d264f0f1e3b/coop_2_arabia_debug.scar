---Debug_OnSiegeUnlock: Log siege system unlock.
function Debug_OnSiegeUnlock(player_id)
    if not DEBUG_ENABLED then return end
    
    Debug_Log(DEBUG_EVT_SIEGE_UNLOCK, player_id, "Siege weapons unlocked")
