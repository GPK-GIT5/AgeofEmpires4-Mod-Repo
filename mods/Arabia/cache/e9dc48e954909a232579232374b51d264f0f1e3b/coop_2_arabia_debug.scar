---Debug_OnWorkshopUnlock: Log workshop unlock.
function Debug_OnWorkshopUnlock(player_id)
    if not DEBUG_ENABLED then return end
    
    Debug_Log(DEBUG_EVT_WORKSHOP_UNLOCK, player_id, "Siege workshop unlocked")
