-- DLC variants with unique siege attribNames (others inherit parent via DLC_CIV_PARENT_MAP)
local DLC_SIEGE = {
	abbasid_ha_01 = {sfx = "abb_ha_01", over = {mangonel_buildable = "unit_mangonel_3_buildable_abb_ha_01", scar_siegeworkshop = "building_unit_siege_control_abb_ha_01"}},
	chinese_ha_01 = {sfx = "chi_ha_01", over = {ram = "unit_ram_3_chi", nest_of_bees = "unit_nest_of_bees_4_chi_ha_01", ribauldequin = "unit_ribauldequin_4_nrm", scar_siegeworkshop = "building_unit_siege_control_chi_ha_01"}},
	french_ha_01 = {sfx = "fre_ha_01", over = {
		springald = "unit_springald_3_fre", mangonel = "unit_mangonel_3_fre", ribauldequin = "unit_ribauldequin_4_fre",
		culverin = "unit_culverin_4_fre", cannon = "unit_cannon_4_fre", bombard = "unit_bombard_4_fre",
		trebuchet_cw = "unit_trebuchet_4_cw_fre", scar_siegeworkshop = "building_unit_siege_control_fre_ha_01",
		royal_cannon = "unit_cannon_4_royal_fre_ha_01", royal_culverin = "unit_culverin_4_royal_fre_ha_01",
		royal_ribauldequin = "unit_ribauldequin_4_royal_fre_ha_01",
	}},
	hre_ha_01 = {sfx = "hre_ha_01", over = {scar_siegeworkshop = "building_unit_siege_control_hre_ha_01"}},
}
function _BuildSiegeTable()
	CBA_SIEGE_TABLE = {}
	for civ, sfx in pairs(CIV_SUFFIX) do
		local entry = {trebuchet_tr = "unit_trebuchet_4_tr_mon"}
		for _, t in ipairs(SIEGE_TEMPLATE) do entry[t.k] = string.format(t.f, sfx) end
		if SIEGE_OVERRIDES[civ] then for k, v in pairs(SIEGE_OVERRIDES[civ]) do entry[k] = v end end
		CBA_SIEGE_TABLE[civ] = entry
	end
	for dlc, spec in pairs(DLC_SIEGE) do
		local entry = {trebuchet_tr = "unit_trebuchet_4_tr_mon"}
		for _, t in ipairs(SIEGE_TEMPLATE) do entry[t.k] = string.format(t.f, spec.sfx) end
		if spec.over then for k, v in pairs(spec.over) do entry[k] = v end end
		CBA_SIEGE_TABLE[dlc] = entry
	end
end
_BuildSiegeTable()

