-- Landmark & Restriction Helper Functions

---_ResolveGlobalPath: Walk a dot-separated path like "EBP.FRENCH.BUILDING_FOO" into its value.
-- Returns nil if any segment is missing (safe for load-order).
function _ResolveGlobalPath(path)
	local parts = {}
	for part in string.gmatch(path, "[^%.]+") do
		table.insert(parts, part)
	end
	local current = _G
	for _, p in ipairs(parts) do
		current = current[p]
		if current == nil then return nil end
	end
	return current
end

---ApplyLandmarkRestrictions: Apply a list of landmark restrictions from a data table.
-- Each entry: { civ, bp (string attribName) OR ebp (global EBP reference as string) }
-- Uses IsCivExact to match only the exact raceName.
function ApplyLandmarkRestrictions(player_id, restriction_table, item_state)
	for _, entry in ipairs(restriction_table) do
		if IsCivExact(player_id, entry.civ) then
			if entry.bp then
				Player_SetEntityProductionAvailability(player_id, BP_GetEntityBlueprint(entry.bp), item_state)
			elseif entry.ebp then
				local ebp_val = _ResolveGlobalPath(entry.ebp)
				if ebp_val then
					Player_SetEntityProductionAvailability(player_id, ebp_val, item_state)
				end
			end
		end
	end
end

---ApplyHouseOfWisdomRestrictions: Apply HoW upgrade restrictions from data table.
function ApplyHouseOfWisdomRestrictions(player_id, item_state)
	for _, entry in ipairs(HOUSE_OF_WISDOM_AGE4_RESTRICTIONS) do
		if IsCivExact(player_id, entry.civ) then
			for _, upg_path in ipairs(entry.upgrades) do
				local upg_val = _ResolveGlobalPath(upg_path)
				if upg_val then
					Player_SetUpgradeAvailability(player_id, upg_val, item_state)
				end
			end
		end
	end
end

-- Stage 3: Restriction Architecture

-- BALANCE_LOCKS: Explicit balance decisions (not bugs)
BALANCE_LOCKS = {
	{ item = "siege_workshop", reason = "Captured, not built — always ITEM_LOCKED" },
	{ item = BP_SIEGE_MANGONEL_BUILDABLE, civ = "abbasid_ha_01", reason = "Balance: avoid early field construct" },
	{ item = BP_SIEGE_SPRINGALD_BUILDABLE, civ = "abbasid_ha_01", reason = "Balance: avoid early field construct" },
	{ item = BP_SIEGE_TREBUCHET_BUILDABLE, civ = "abbasid_ha_01", reason = "Balance: avoid early field construct" },
	{ item = "upgrade_siege_improved_siege_engineering_1_mon", reason = "Balance: delay Mongol advantage" },
	{ item = "upgrade_siege_improved_siege_engineering_2_mon", reason = "Balance: delay Mongol advantage" },
	{ item = "upgrade_siege_improved_siege_engineering_3_mon", reason = "Balance: delay Mongol advantage" },
}

-- Validator: Check restriction/unlock parity
function Validator_RestrictionParity()
	local result = { ok = true, violations = {}, balance_count = #BALANCE_LOCKS }
	print("[PARITY] Balance locks: " .. tostring(result.balance_count))
	return result
end

-- CIV_CAPABILITIES: What each civ can do at each phase
-- 22 civs: 12 AGS_ENTITY_TABLE base + 10 DLC registered
-- All follow same 4-phase structure; civ-specific unit variants
-- are handled by IsCivFamily/IsCivExact in profile apply logic.
local function _GenerateCIVCapabilities()
	local template = {
		starting = {landmarks = true, siege = true, engineers = true, workshop = true},
		siege_available = {landmarks = true, siege = false, engineers = true, workshop = true},
		engineers_available = {landmarks = true, siege = false, engineers = false, workshop = true},
		workshop_available = {landmarks = true, siege = false, engineers = false, workshop = false},
	}
	local civs = {"english","chinese","french","hre","abbasid","mongol","sultanate","malian","ottoman","rus","japanese","byzantine",
		"abbasid_ha_01","chinese_ha_01","french_ha_01","hre_ha_01","mongol_ha_gol","byzantine_ha_mac","japanese_ha_sen","sultanate_ha_tug","lancaster","templar"}
	local result = {}
	for _, civ in ipairs(civs) do
		result[civ] = template
	end
	return result
end

CIV_CAPABILITIES = _GenerateCIVCapabilities()

-- Extracted Helpers: Siege & Engineer Restrictions
-- Shared logic from profiles. item_state: ITEM_LOCKED to restrict, ITEM_DEFAULT to unlock.

---_ApplySiegeRestrictions: Lock or unlock all siege unit production.
function _ApplySiegeRestrictions(player, item_state)
	-- Mangonel (all civs)
	Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeSquad(player.raceName, BP_SIEGE_MANGONEL), item_state)
	-- Mangonel field construct (abbasid + mongol families)
	if IsCivFamilyAny(player.id, {"abbasid", "mongol"}) then
		Player_SetEntityProductionAvailability(player.id, AGS_GetSiegeEntity(player.raceName, BP_SIEGE_MANGONEL_BUILDABLE), item_state)
	end
	-- Nest of Bees (chinese + mongol + byzantine families)
	if IsCivFamilyAny(player.id, {"chinese", "mongol", "byzantine"}) then
		Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeSquad(player.raceName, BP_SIEGE_NESTOFBEES), item_state)
		if IsCivExact(player.id, "chinese") then
			Player_SetSquadProductionAvailability(player.id, SBP.CHINESE.UNIT_NEST_OF_BEES_4_CLOCKTOWER_CHI, item_state)
		end
	end
	-- Ribauldequin (all except chinese family)
	if not IsCivFamily(player.id, "chinese") then
		Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeSquad(player.raceName, BP_SIEGE_RIBAULDEQUIN), item_state)
		if IsCivFamily(player.id, "french") then
			Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeSquad(player.raceName, BP_SIEGE_ROYAL_RIBAULDEQUIN), item_state)
		end
	end
	-- Ram Tower (Ayyubids only)
	if IsCivExact(player.id, "abbasid_ha_01") then
		Player_SetEntityProductionAvailability(player.id, EBP.ABBASID_HA_01.UNIT_RAM_TOWER_3_ABB_HA_01, item_state)
	end
	-- Mongol doubles
	if IsCivFamily(player.id, "mongol") then
		Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeSquad(player.raceName, BP_SIEGE_MANGONEL_DOUBLE), item_state)
		Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeSquad(player.raceName, BP_SIEGE_RIBAULDEQUIN_DOUBLE), item_state)
	end
	-- Byzantine outpost mangonel upgrade
	if IsCivFamily(player.id, "byzantine") then
		Player_SetUpgradeAvailability(player.id, UPG.BYZANTINE.UPGRADE_OUTPOST_MANGONEL_BYZ, item_state)
	end
end

---_ApplyEngineerRestrictions: Lock or unlock siege engineer upgrades and field constructs.
function _ApplyEngineerRestrictions(player, item_state)
	-- Siege Engineers upgrade
	if not IsCivFamily(player.id, "sultanate") then
		Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint("upgrade_siege_engineers"), item_state)
	else
		Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint("upgrade_siege_engineers_sul"), item_state)
	end
	-- Mongol improved siege engineers — ITEM_REMOVED when locking (balance lock)
	if IsCivFamily(player.id, "mongol") then
		local mongol_state = (item_state == ITEM_DEFAULT) and ITEM_DEFAULT or ITEM_REMOVED
		Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint("upgrade_improved_siege_engineers_mon"), mongol_state)
	end
	-- Abbasid base field construct
	if IsCivExact(player.id, "abbasid") then
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_mangonel_3_buildable_abb"), item_state)
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_springald_3_buildable_abb"), item_state)
	end
	-- Ayyubids field construct
	if IsCivExact(player.id, "abbasid_ha_01") then
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_mangonel_3_buildable_abb_ha_01"), item_state)
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_springald_3_buildable_abb_ha_01"), item_state)
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_ram_tower_3_abb_ha_01"), item_state)
	end
end

-- Stage 4: Restriction Profile System
-- 4 named profiles applied per game phase. Per-player state in PLAYER_RESTRICTION_STATE.

-- Track current restriction profile per player
PLAYER_RESTRICTION_STATE = {}

---GetPlayerProfile: Return current profile for a player (or "none" if unset).
function GetPlayerProfile(player_id)
	return PLAYER_RESTRICTION_STATE[player_id] or "none"
end

---SetPlayerProfile: Update player's current profile in state cache.
function SetPlayerProfile(player_id, profile)
	PLAYER_RESTRICTION_STATE[player_id] = profile
	if DLC_DEBUG then
		print(string.format("[DLC-DBG] Player %s -> profile: %s", tostring(player_id), profile))
	end
end

-- Restriction_Profile: Named profiles per game phase (description + apply function).
Restriction_Profile = {
	-- STARTING: Mission setup (applied to all players)
	starting = {
		description = "Mission start: walls/dock/keep locked, siege locked (diff-scaled), age cap (Hard+)",
		apply = function(player)
			-- Disable Stone/Palisade walls (AI path issues) — skip mongol family
			if not IsCivFamily(player.id, "mongol") then
				Player_SetEntityProductionAvailability(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_STONEWALL), ITEM_REMOVED)
				Player_SetEntityProductionAvailability(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_PALISADE), ITEM_REMOVED)
			end

			-- Dock Available
			Player_SetEntityProductionAvailability(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_DOCK), ITEM_DEFAULT)

			-- Starting upgrades
			Player_CompleteUpgrade(player.id, UPG.COMMON.UPGRADE_SCOUT_FORESTER)

			-- Starting upgrades / Difficulty: Intermediate (see DC.player_upgrades_bonus)
			if DC.player_upgrades_bonus then
				-- Faction shared
				Player_CompleteUpgrade(player.id, UPG.COMMON.UPGRADE_MELEE_DAMAGE_I)
				Player_CompleteUpgrade(player.id, UPG.COMMON.UPGRADE_RANGED_ARMOR_I)
				-- Faction unique (IsCivFamily so lancaster->english, templar->hre)
				if IsCivFamily(player.id, "english") then
					Player_CompleteUpgrade(player.id, UPG.ENGLISH.UPGRADE_UNIT_MANATARMS_2_ENG)
					Player_CompleteUpgrade(player.id, UPG.ENGLISH.UPGRADE_ARMOR_CLAD_ENG)
				end
				if IsCivFamily(player.id, "hre") then
					Player_CompleteUpgrade(player.id, UPG.HRE.UPGRADE_MAN_AT_ARMS_TWO_HANDED_HRE)
					Player_CompleteUpgrade(player.id, UPG.HRE.UPGRADE_INSPIRED_INFANTRY_HRE)
				end
			end

			-- Disable Ability: Conversion (see DC.disable_conversion)
			if DC.disable_conversion then
				Player_SetAbilityAvailability(player.id, BP_GetAbilityBlueprint("monk_conversion"), ITEM_REMOVED)
				if IsCivFamily(player.id, "abbasid") then
					Player_SetAbilityAvailability(player.id, BP_GetAbilityBlueprint("monk_conversion_faith_abb"), ITEM_REMOVED)
				end
			end

			-- Keep Restriction (see DC.restrict_keep)
			if DC.restrict_keep then
				-- All factions
				Player_SetEntityProductionAvailability(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_KEEP), ITEM_REMOVED)
				-- Faction specific (IsCivFamily so lancaster->english)
				if IsCivFamily(player.id, "english") then
					Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age2_white_tower_eng"), ITEM_REMOVED)
				end
				-- Keep landmarks (data-driven) — only at Intermediate (see DC.restrict_keep_landmarks)
				-- CHANGE: Use ITEM_LOCKED instead of ITEM_REMOVED to allow rebuilding destroyed landmarks
				if DC.restrict_keep_landmarks then
					ApplyLandmarkRestrictions(player.id, LANDMARK_KEEP_RESTRICTIONS, ITEM_LOCKED)
				end
			end

			-- Siege Restriction (see DC.restrict_siege)
			if DC.restrict_siege then
				_ApplySiegeRestrictions(player, ITEM_LOCKED)
			end

			-- Siege Engineers Restriction (see DC.restrict_engineers)
			if DC.restrict_engineers then
				_ApplyEngineerRestrictions(player, ITEM_LOCKED)
			end

			-- Workshop Restriction (see DC.restrict_workshop)
			if DC.restrict_workshop then
				Player_SetEntityProductionAvailability(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_WORKSHOP), ITEM_LOCKED)
			end

			-- Age 4 Restriction (see DC.restrict_age4)
			if DC.restrict_age4 then
				-- Restrict max age to Castle Age
				Player_SetMaximumAge(player.id, AGE_CASTLE)
				-- Age 4 Landmarks (data-driven)
			-- CHANGE: Use ITEM_LOCKED instead of ITEM_REMOVED to allow rebuilding destroyed landmarks
			ApplyLandmarkRestrictions(player.id, LANDMARK_AGE4_RESTRICTIONS, ITEM_LOCKED)
			-- House of Wisdom / Age 4 upgrades (data-driven)
			-- CHANGE: Use ITEM_LOCKED instead of ITEM_REMOVED to allow rebuilding destroyed upgrades
			ApplyHouseOfWisdomRestrictions(player.id, ITEM_LOCKED)
				Player_CompleteUpgrade(player.id, UPG.COMMON.UPGRADE_MELEE_ARMOR_I)
			end

			if DLC_DEBUG then
				print(string.format("[PROFILE] 'starting' applied to player %s (diff=%d, tier=%s)", tostring(player.id), AI_Difficulty, DC.label))
			end
		end
	},
	-- SIEGE_AVAILABLE: After capturing siege workshop (Easy/Intermediate)
	siege_available = {
		description = "Siege workshop captured: siege becomes available (difficulty-scaled)",
		apply = function(player)
			_ApplySiegeRestrictions(player, ITEM_DEFAULT)
			if DLC_DEBUG then
				print(string.format("[PROFILE] 'siege_available' applied to player %s", tostring(player.id)))
			end
		end
	},
	-- ENGINEERS_AVAILABLE: After capturing siege workshop (Hard+ difficulty)
	engineers_available = {
		description = "Hard+ difficulty: siege + engineers become available",
		apply = function(player)
			Restriction_Profile.siege_available.apply(player)
			_ApplyEngineerRestrictions(player, ITEM_DEFAULT)
			if DLC_DEBUG then
				print(string.format("[PROFILE] 'engineers_available' applied to player %s", tostring(player.id)))
			end
		end
	},
	-- WORKSHOP_AVAILABLE: Hardest+ only — unlock workshop building
	workshop_available = {
		description = "Hardest+ difficulty: siege workshop becomes available",
		apply = function(player)
			-- Siege Workshop / All factions
			Player_SetEntityProductionAvailability(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_WORKSHOP), ITEM_DEFAULT)

			if DLC_DEBUG then
				print(string.format("[PROFILE] 'workshop_available' applied to player %s", tostring(player.id)))
			end
		end
	},
}

-- Track which profiles have been applied per player (idempotency guard)
PLAYER_PROFILE_APPLIED = {}

---ApplyRestrictionProfile: Unified entry point for restriction management.
-- Idempotent: calling twice with same profile skips re-application.
function ApplyRestrictionProfile(player, profile_name)
	local profile = Restriction_Profile[profile_name]
	if not profile then print("[ERROR] ApplyRestrictionProfile: Unknown profile '" .. tostring(profile_name) .. "'"); return false end
	if PLAYER_PROFILE_APPLIED[player.id] and PLAYER_PROFILE_APPLIED[player.id][profile_name] then
		DebugPrint_Resolver("ApplyRestrictionProfile: SKIPPED player=" .. tostring(player.id) .. " profile=" .. profile_name)
		return true
	end
	profile.apply(player)
	SetPlayerProfile(player.id, profile_name)
	if not PLAYER_PROFILE_APPLIED[player.id] then PLAYER_PROFILE_APPLIED[player.id] = {} end
	PLAYER_PROFILE_APPLIED[player.id][profile_name] = true
	DebugPrint_Resolver("ApplyRestrictionProfile complete: player=" .. tostring(player.id) .. " profile=" .. profile_name)
	return true
end

---Validator_RestrictionState: Check all players have valid profiles.
function Validator_RestrictionState()
	print("[VALIDATOR] Restriction State Check:")
	local valid = {starting = true, siege_available = true, engineers_available = true, workshop_available = true}
	local all_ok, count = true, 0
	for pid, profile in pairs(PLAYER_RESTRICTION_STATE) do
		count = count + 1
		local ok = valid[profile] ~= nil
		print(string.format("  Player %s: %s [%s]", tostring(pid), profile, ok and "OK" or "INVALID"))
		if not ok then all_ok = false end
	end
	if count == 0 then print("  (No players tracked yet)") end
	print(string.format("[VALIDATOR] Players: %d | Result: %s", count, all_ok and "PASS" or "FAIL"))
	return {ok = all_ok, profile_count = count}
end

-- Simulate_PlayerProgression: Dry-run test for civ resolution + profile chain (console-safe).
-- Usage: Simulate_PlayerProgression("english", 0) or Simulate_PlayerProgression("abbasid_ha_01", 3)
function Simulate_PlayerProgression(civ, difficulty)
	print("[PROG-SIM] === Dry-run: " .. civ .. " @ diff " .. tostring(difficulty) .. " ===")
	local civ_lower = string.lower(civ)
	local resolved = ResolveCivKey(civ_lower)
	if not resolved then print("[PROG-SIM] FAIL: '" .. civ .. "' unresolvable"); return end
	print("[PROG-SIM] " .. civ .. " -> " .. resolved .. (resolved ~= civ_lower and " (via parent)" or " (base)"))
	print("[PROG-SIM] AGS_ENTITY_TABLE: " .. (AGS_ENTITY_TABLE[resolved] and "present" or "MISSING"))
	local siege_key = CBA_SIEGE_TABLE[civ_lower] and civ_lower or (CBA_SIEGE_TABLE[resolved] and resolved or nil)
	print("[PROG-SIM] CBA_SIEGE_TABLE: " .. (siege_key and ("'" .. siege_key .. "'") or "MISSING"))
	local dc = Difficulty_Config[difficulty]
	if not dc then print("[PROG-SIM] FAIL: no config for tier " .. tostring(difficulty)); return end
	local profiles = {"starting", dc.phase2_siege_profile}
	if dc.phase2_workshop_unlock then profiles[#profiles + 1] = "workshop_available" end
	local all_valid = true
	for i, name in ipairs(profiles) do
		local p = Restriction_Profile[name]
		if p and p.apply then print(string.format("[PROG-SIM] [%d] '%s': %s", i, name, p.description))
		else print(string.format("[PROG-SIM] [%d] FAIL: '%s' not found!", i, name)); all_valid = false end
	end
	print("[PROG-SIM] === " .. (all_valid and "PASS" or "FAIL") .. " | " .. #profiles .. " profiles | final: '" .. profiles[#profiles] .. "' ===")
end

-- DLC CIVILIZATION RESOLUTION SYSTEM
-- DLC civs inherit blueprints from a base civ. Overrides take precedence.
-- Recursive + cycle-safe. To add a new DLC civ, call RegisterDLCCiv() below.

DLC_DEBUG = false
function DebugPrint_Resolver(msg) if DLC_DEBUG then print("[DLC-DBG] " .. msg) end end
DLC_RESOLVE_MAX_DEPTH = 4
DLC_CIV_PARENT_MAP = {}   -- DLC raceName → base civ key (populated by RegisterDLCCiv)
DLC_CIV_OVERRIDES = {}    -- sparse: [raceName][shortName] = attribName
DLC_PLAYER_CIV_CACHE = {} -- player_id → resolved civ key
DLC_CIV_COMPOSITION = {}  -- role definitions for GenerateCompositionMaps()
function _CountKeys(t) local n = 0; for _ in pairs(t) do n = n + 1 end; return n end

---RegisterDLCCiv: Register a DLC civ variant.
-- spec: {attribName, parent, overrides?, melee_key?, ranged_key?, reinforce_melee_key?, reinforce_ranged_key?}
function RegisterDLCCiv(spec)
	if spec.attribName == nil or spec.parent == nil then
		error("[DLC] RegisterDLCCiv: attribName and parent are required.")
	end
	DLC_CIV_PARENT_MAP[spec.attribName] = spec.parent
	if spec.overrides then
		DLC_CIV_OVERRIDES[spec.attribName] = spec.overrides
	end
	DLC_CIV_COMPOSITION[spec.attribName] = {
		melee_key           = spec.melee_key,
		ranged_key          = spec.ranged_key,
		reinforce_melee_key = spec.reinforce_melee_key,
		reinforce_ranged_key = spec.reinforce_ranged_key,
	}
	DebugPrint_Resolver("RegisterDLCCiv: '" .. spec.attribName .. "' -> parent '" .. spec.parent .. "'"
		.. (spec.overrides and (" with " .. tostring(_CountKeys(spec.overrides)) .. " override(s)") or ""))
end

-- DLC Civ Registrations (10 variants → base civs in AGS_ENTITY_TABLE)
RegisterDLCCiv({attribName = "abbasid_ha_01", parent = "abbasid", melee_key = "start_player1_abb", ranged_key = "start_player2_abb", reinforce_melee_key = "units_player1_reinforce_byz"})
RegisterDLCCiv({attribName = "chinese_ha_01", parent = "chinese", ranged_key = "start_player2_chi"})
RegisterDLCCiv({attribName = "french_ha_01", parent = "french", melee_key = "start_player1_cav"})
RegisterDLCCiv({attribName = "hre_ha_01", parent = "hre", melee_key = "start_player1_inf"})
RegisterDLCCiv({attribName = "mongol_ha_gol", parent = "mongol", ranged_key = "start_player2_mon"})
RegisterDLCCiv({attribName = "byzantine_ha_mac", parent = "byzantine"})
RegisterDLCCiv({attribName = "japanese_ha_sen", parent = "japanese"})
RegisterDLCCiv({attribName = "sultanate_ha_tug", parent = "sultanate"})
RegisterDLCCiv({attribName = "lancaster", parent = "english", melee_key = "start_player1_inf", reinforce_melee_key = "units_player1_reinforce_inf"})
RegisterDLCCiv({attribName = "templar", parent = "hre", melee_key = "start_player1_inf", reinforce_melee_key = "units_player1_reinforce_inf"})

-- Resolution Functions

---ResolveCivKey: Given a raceName, return a valid key in AGS_ENTITY_TABLE.
-- Cycle-safe via depth limit. Returns nil if unresolvable.
function ResolveCivKey(raceName, _depth)
	if raceName == nil then return nil end
	raceName = string.lower(raceName)
	_depth = _depth or 0
	if _depth > DLC_RESOLVE_MAX_DEPTH then
		error("[DLC] ResolveCivKey: parent chain exceeded depth " .. DLC_RESOLVE_MAX_DEPTH .. " for '" .. raceName .. "'")
	end
	if AGS_ENTITY_TABLE[raceName] then
		DebugPrint_Resolver("ResolveCivKey: '" .. raceName .. "' direct match")
		return raceName
	end
	local parent = DLC_CIV_PARENT_MAP[raceName]
	if parent then
		DebugPrint_Resolver("ResolveCivKey: '" .. raceName .. "' -> '" .. parent .. "' (depth " .. tostring(_depth) .. ")")
		return ResolveCivKey(parent, _depth + 1)
	end
	DebugPrint_Resolver("ResolveCivKey: '" .. raceName .. "' UNRESOLVABLE")
	return nil
end

---ResolveCivMapKey: Look up civ in a composition map.
-- Tries exact, then walks DLC parent chain, then returns default_key.
function ResolveCivMapKey(map, civ_name, default_key)
	if civ_name == nil then return default_key end
	civ_name = string.lower(civ_name)
	if map[civ_name] then return map[civ_name] end
	local current = civ_name
	local depth = 0
	while depth < DLC_RESOLVE_MAX_DEPTH do
		current = DLC_CIV_PARENT_MAP[current]
		if current == nil then break end
		if map[current] then
			return map[current]
		end
		depth = depth + 1
	end
	return default_key
end

---GetPlayerCiv: Resolve and cache a player's civ key. Errors on unknown civ.
function GetPlayerCiv(player_id)
	if DLC_PLAYER_CIV_CACHE[player_id] then return DLC_PLAYER_CIV_CACHE[player_id] end
	local raceName = string.lower(Player_GetRaceName(player_id))
	local resolved = ResolveCivKey(raceName)
	if not resolved then
		error("[DLC] GetPlayerCiv: Unknown civ '" .. raceName .. "'")
	end
	if resolved ~= raceName then
		print("[DLC] Player " .. tostring(player_id) .. ": '" .. raceName .. "' -> '" .. resolved .. "'")
	end
	DLC_PLAYER_CIV_CACHE[player_id] = resolved
	return resolved
end

---GetPlayerRawCiv: Return the original (possibly DLC) raceName, lowercased.
-- Used when we need to check overrides against the original civ.
function GetPlayerRawCiv(player_id)
	return string.lower(Player_GetRaceName(player_id))
end

-- Family & Civ Helper Functions

---IsCivFamily: Returns true if the player's resolved civ matches family.
-- Example: IsCivFamily(player.id, "english") → true for lancaster too.
function IsCivFamily(player_id, family)
	return GetPlayerCiv(player_id) == family
end

---IsCivExact: Returns true if the player's raw raceName matches exactly.
-- Example: IsCivExact(player.id, "abbasid_ha_01") → true only for Ayyubids.
function IsCivExact(player_id, civ_name)
	return string.lower(Player_GetRaceName(player_id)) == civ_name
end

---IsCivFamilyAny: Returns true if resolved civ matches any of the listed families.
-- Example: IsCivFamilyAny(player.id, {"chinese", "mongol", "byzantine"})
function IsCivFamilyAny(player_id, families)
	local resolved = GetPlayerCiv(player_id)
	for _, fam in ipairs(families) do
		if resolved == fam then return true end
	end
	return false
end

-- Composition Map Generation

---GenerateCompositionMaps: Populate CIV_*_MAP entries for all
-- registered DLC civs. Inherits from parent when DLC spec is nil.
-- Must be called AFTER AGS_ENTITY_TABLE and base maps are defined.
function GenerateCompositionMaps()
	local MAP_DEFS = {
		{map = CIV_MELEE_MAP,        key = "melee_key"},
		{map = CIV_RANGED_MAP,       key = "ranged_key"},
		{map = REINFORCE_MELEE_MAP,  key = "reinforce_melee_key"},
		{map = REINFORCE_RANGED_MAP, key = "reinforce_ranged_key"},
	}
	for dlc_civ, comp in pairs(DLC_CIV_COMPOSITION) do
		local parent = DLC_CIV_PARENT_MAP[dlc_civ]
		for _, def in ipairs(MAP_DEFS) do
			if comp[def.key] then
				def.map[dlc_civ] = comp[def.key]
			elseif parent and def.map[parent] then
				def.map[dlc_civ] = def.map[parent]
			end
		end
		-- Mining camp maps inherit from parent only
		if parent and MININGCAMP_MELEE_MAP[parent] then MININGCAMP_MELEE_MAP[dlc_civ] = MININGCAMP_MELEE_MAP[parent] end
		if parent and MININGCAMP_RANGED_MAP[parent] then MININGCAMP_RANGED_MAP[dlc_civ] = MININGCAMP_RANGED_MAP[parent] end
	end
	print("[DLC] Composition maps generated for " .. tostring(_CountKeys(DLC_CIV_COMPOSITION)) .. " DLC civs.")
end

-- Validation

---Validator_CivRegistry: Run all validation checks.
-- Call in Mission_SetupVariables BEFORE any spawn or restriction logic.
function Validator_CivRegistry()
	_Validate_ParentCycles()
	_Validate_ParentsExist()
	print("[DLC] Validator_CivRegistry: All checks passed.")
end

-- V1: Detect circular parent chains
function _Validate_ParentCycles()
	for start_civ, _ in pairs(DLC_CIV_PARENT_MAP) do
		local visited = {}
		local current = start_civ
		while current do
			if visited[current] then
				error("[DLC] Circular parent chain detected starting at '" .. start_civ .. "'")
			end
			visited[current] = true
			current = DLC_CIV_PARENT_MAP[current]
		end
	end
end

-- V2: Ensure all referenced parents resolve to AGS_ENTITY_TABLE
function _Validate_ParentsExist()
	for dlc_civ, parent in pairs(DLC_CIV_PARENT_MAP) do
		local resolved = ResolveCivKey(parent)
		if resolved == nil then
			error("[DLC] Parent '" .. parent .. "' of DLC civ '" .. dlc_civ 
				.. "' does not resolve to AGS_ENTITY_TABLE")
		end
	end
end

---Validator_PlayerCivDump: Log each human player's raw/resolved civ and map entries.
function Validator_PlayerCivDump()
	for _, player in pairs(PLAYERS) do
		local raw = string.lower(Player_GetRaceName(player.id))
		local resolved = GetPlayerCiv(player.id)
		print(string.format("[DLC-DUMP] Player %s | raw: %s | resolved: %s | melee: %s | ranged: %s | r_melee: %s | r_ranged: %s",
			tostring(player.id), raw, resolved,
			ResolveCivMapKey(CIV_MELEE_MAP, raw, "start_player1"),
			ResolveCivMapKey(CIV_RANGED_MAP, raw, "start_player2"),
			ResolveCivMapKey(REINFORCE_MELEE_MAP, raw, "units_player1_reinforce"),
			ResolveCivMapKey(REINFORCE_RANGED_MAP, raw, "units_player2_reinforce")))
	end
end

-- Marker Compositions
function Unit_Path_Data()
	city = {mkr_start_mining2, mkr_start_patrol1, mkr_player2_spawn01, mkr_start_patrol2, mkr_start_mining2, mkr_city_reinforcements, mkr_start_mining2}
	city_mid = {mkr_start_patrol1, mkr_start_mining2, mkr_player2_spawn01, mkr_start_patrol2, mkr_start_mining2, mkr_city_reinforcements, mkr_start_mining2}
	city_flank = {mkr_player2_spawn01, mkr_start_patrol2, mkr_start_mining2, mkr_start_patrol1, mkr_city_reinforcements, mkr_start_mining2}
end -- Units_Deploy's paths needs to be called from this function first
