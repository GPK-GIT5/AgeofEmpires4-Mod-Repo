---ResolveCivMapKey: Safely look up a civ in a composition map.
-- Returns mapped value or default_key (never nil).
function ResolveCivMapKey(map, civ_name, default_key)
	if civ_name == nil then return default_key end
	civ_name = string.lower(civ_name)
	return map[civ_name] or default_key
end

-- Marker Compositions
function Unit_Path_Data()
	
		city = {
			mkr_start_mining2,
			mkr_start_patrol1,
			mkr_player2_spawn01,
			mkr_start_patrol2,
			mkr_start_mining2,
			mkr_city_reinforcements, -- Restart if they survive
			mkr_start_mining2,
		} -- Main attack route
		city_mid = {
			mkr_start_patrol1,
			mkr_start_mining2,
			mkr_player2_spawn01,
			mkr_start_patrol2,
			mkr_start_mining2,
			mkr_city_reinforcements, -- Restart if they survive
			mkr_start_mining2,
		} -- Goes middle gold deposit first, then enters camp
		city_flank = {
			mkr_player2_spawn01,
			mkr_start_patrol2,
			mkr_start_mining2,
			mkr_start_patrol1,
			mkr_city_reinforcements, -- Restart if they survive
			mkr_start_mining2,
		} -- Goes spawn, then enters camp from behind
	
end -- Units_Deploy's paths needs to be called from this function first


