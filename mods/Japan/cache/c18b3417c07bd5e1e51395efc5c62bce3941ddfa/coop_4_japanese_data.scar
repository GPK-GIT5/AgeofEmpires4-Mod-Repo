-- Validator: Check restriction/unlock parity
function Validator_RestrictionParity()
    local result = { ok = true, violations = {}, balance_count = #BALANCE_LOCKS }
    print("[PARITY] Balance locks:", result.balance_count)
    return result
end

-- CIV_CAPABILITIES: What each civ can do at each phase
-- 22 civs: 16 AGS_ENTITY_TABLE base + 6 DLC registered
-- All follow same 4-phase structure; civ-specific unit variants
-- are handled by IsCivFamily/IsCivExact in profile apply logic.

---GenerateCIVCapabilities: Build CIV_CAPABILITIES from template
-- All 22 civs share identical 4-phase availability structure.
local function _GenerateCIVCapabilities()
	local template = {
		starting = {landmarks = true, siege = true, engineers = true, workshop = true},
		siege_available = {landmarks = true, siege = false, engineers = true, workshop = true},
		engineers_available = {landmarks = true, siege = false, engineers = false, workshop = true},
		workshop_available = {landmarks = true, siege = false, engineers = false, workshop = false},
	}
	local civs = {"english","chinese","french","hre","abbasid","mongol","sultanate","malian","ottoman","rus","japanese","byzantine",
		"abbasid_ha_01","chinese_ha_01","french_ha_01","hre_ha_01","mongol_ha_gol","byzantine_ha_mac","japanese_ha_sen","sultanate_ha_tug","lancaster","templar"}
	local result = {}
	for _, civ in ipairs(civs) do
		result[civ] = template
	end
	return result
end

CIV_CAPABILITIES = _GenerateCIVCapabilities()

-- ============================================================
-- Stage 4: Restriction Profile System
-- ============================================================
-- Replaces 22 scattered difficulty checks with 4 named profiles.
-- Each profile is mutually exclusive (replaces previous state).
-- Per-player state tracked in PLAYER_RESTRICTION_STATE.
-- ============================================================

-- Track current restriction profile per player
PLAYER_RESTRICTION_STATE = {}

---GetPlayerProfile: Return current profile for a player (or "none" if unset).
function GetPlayerProfile(player_id)
    return PLAYER_RESTRICTION_STATE[player_id] or "none"
end

---SetPlayerProfile: Update player's current profile in state cache.
function SetPlayerProfile(player_id, profile)
    PLAYER_RESTRICTION_STATE[player_id] = profile
    if DLC_DEBUG then
        print(string.format("[DLC-DBG] Player %s -> profile: %s", tostring(player_id), profile))
    end
end

-- Shared helpers: Apply siege/engineer restrictions with a given state (ITEM_LOCKED or ITEM_DEFAULT)
local function _ApplySiegeRestrictions(player, state)
	Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeSquad(player.raceName, BP_SIEGE_MANGONEL), state)
	if IsCivFamilyAny(player.id, {"abbasid", "mongol"}) then
		Player_SetEntityProductionAvailability(player.id, AGS_GetSiegeEntity(player.raceName, BP_SIEGE_MANGONEL_BUILDABLE), state)
	end
	if IsCivFamilyAny(player.id, {"chinese", "mongol", "byzantine"}) then
		Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeSquad(player.raceName, BP_SIEGE_NESTOFBEES), state)
		if IsCivExact(player.id, "chinese") then
			Player_SetSquadProductionAvailability(player.id, SBP.CHINESE.UNIT_NEST_OF_BEES_4_CLOCKTOWER_CHI, state)
		end
	end
	if not IsCivFamily(player.id, "chinese") then
		Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeSquad(player.raceName, BP_SIEGE_RIBAULDEQUIN), state)
		if IsCivFamily(player.id, "french") then
			Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeSquad(player.raceName, BP_SIEGE_ROYAL_RIBAULDEQUIN), state)
		end
	end
	if IsCivExact(player.id, "abbasid_ha_01") then
		Player_SetEntityProductionAvailability(player.id, EBP.ABBASID_HA_01.UNIT_RAM_TOWER_3_ABB_HA_01, state)
	end
	if IsCivFamily(player.id, "mongol") then
		Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeSquad(player.raceName, BP_SIEGE_MANGONEL_DOUBLE), state)
		Player_SetSquadProductionAvailability(player.id, AGS_GetSiegeSquad(player.raceName, BP_SIEGE_RIBAULDEQUIN_DOUBLE), state)
	end
	if IsCivFamily(player.id, "byzantine") then
		Player_SetUpgradeAvailability(player.id, UPG.BYZANTINE.UPGRADE_OUTPOST_MANGONEL_BYZ, state)
	end
end

local function _ApplyEngineerRestrictions(player, state)
	if not IsCivFamily(player.id, "sultanate") then
		Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint("upgrade_siege_engineers"), state)
	else
		Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint("upgrade_siege_engineers_sul"), state)
	end
	if IsCivFamily(player.id, "mongol") then
		Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint("upgrade_improved_siege_engineers_mon"), state == ITEM_LOCKED and ITEM_REMOVED or state)
	end
	if IsCivExact(player.id, "abbasid") then
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_mangonel_3_buildable_abb"), state)
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_springald_3_buildable_abb"), state)
	end
	if IsCivExact(player.id, "abbasid_ha_01") then
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_mangonel_3_buildable_abb_ha_01"), state)
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_springald_3_buildable_abb_ha_01"), state)
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_ram_tower_3_abb_ha_01"), state)
	end
end

-- Restriction_Profile: Named availability profiles per game phase
-- Each profile has a description + apply function.
-- Key naming: "_available" indicates what becomes available at that phase.
Restriction_Profile = {

    -- --------------------------------------------------------
    -- STARTING: Mission setup (applied to all players)
    -- --------------------------------------------------------
    starting = {
        description = "Mission start: walls/dock/keep locked, siege locked (diff-scaled), age cap (Hard+)",
        apply = function(player)
            -- [1] Disable Stone/Palisade walls (AI path issues) — skip mongol family
            if not IsCivFamily(player.id, "mongol") then
                Player_SetEntityProductionAvailability(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_STONEWALL), ITEM_REMOVED)
                Player_SetEntityProductionAvailability(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_PALISADE), ITEM_REMOVED)
            end

            -- [2] Disable Dock (Default)
            Player_SetEntityProductionAvailability(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_DOCK), ITEM_REMOVED)

            -- [3] Starting upgrades (Default)
            Player_CompleteUpgrade(player.id, UPG.COMMON.UPGRADE_SCOUT_FORESTER)

            -- [4] Starting upgrades / Difficulty: Intermediate - (see DC.player_starting_upgrades_bonus)
            if DC.player_starting_upgrades_bonus then
                -- Faction shared
                Player_CompleteUpgrade(player.id, UPG.COMMON.UPGRADE_MELEE_DAMAGE_I)
                Player_CompleteUpgrade(player.id, UPG.COMMON.UPGRADE_RANGED_ARMOR_I)
                -- Faction unique (IsCivFamily so lancaster->english, templar->hre)
                if IsCivFamily(player.id, "english") then
                    Player_CompleteUpgrade(player.id, UPG.ENGLISH.UPGRADE_UNIT_MANATARMS_2_ENG)
                    Player_CompleteUpgrade(player.id, UPG.ENGLISH.UPGRADE_ARMOR_CLAD_ENG)
                end
                if IsCivFamily(player.id, "hre") then
                    Player_CompleteUpgrade(player.id, UPG.HRE.UPGRADE_MAN_AT_ARMS_TWO_HANDED_HRE)
                    Player_CompleteUpgrade(player.id, UPG.HRE.UPGRADE_INSPIRED_INFANTRY_HRE)
                end
            end

            -- [5] Disable Ability: Conversion (see DC.disable_conversion)
            if DC.disable_conversion then
                Player_SetAbilityAvailability(player.id, BP_GetAbilityBlueprint("monk_conversion"), ITEM_REMOVED)
                if IsCivFamily(player.id, "abbasid") then
                    Player_SetAbilityAvailability(player.id, BP_GetAbilityBlueprint("monk_conversion_faith_abb"), ITEM_REMOVED)
                end
            end

            -- [6] Keep Restriction (see DC.restrict_keep)
            if DC.restrict_keep then
                -- All factions
                Player_SetEntityProductionAvailability(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_KEEP), ITEM_REMOVED)
                -- Faction specific (IsCivFamily so lancaster->english)
                if IsCivFamily(player.id, "english") then
                    Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age2_white_tower_eng"), ITEM_REMOVED)
                end
                -- Keep landmarks (data-driven) — only at Intermediate (see DC.restrict_keep_landmarks)
                if DC.restrict_keep_landmarks then
                    ApplyLandmarkRestrictions(player.id, LANDMARK_KEEP_RESTRICTIONS, ITEM_REMOVED)
                end
            end

            -- [7] Siege Restriction (see DC.restrict_siege)
            if DC.restrict_siege then _ApplySiegeRestrictions(player, ITEM_LOCKED) end

            -- [8] Siege Engineers Restriction (see DC.restrict_engineers)
            if DC.restrict_engineers then _ApplyEngineerRestrictions(player, ITEM_LOCKED) end

            -- [9] Workshop Restriction (see DC.restrict_workshop)
            if DC.restrict_workshop then
                Player_SetEntityProductionAvailability(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_WORKSHOP), ITEM_LOCKED)
            end

            -- [10] Age 4 Restriction (see DC.restrict_age4)
            if DC.restrict_age4 then
                -- Restrict max age to Castle Age
                Player_SetMaximumAge(player.id, AGE_CASTLE)
                -- Age 4 Landmarks (data-driven)
                ApplyLandmarkRestrictions(player.id, LANDMARK_AGE4_RESTRICTIONS, ITEM_REMOVED)
                -- House of Wisdom / Age 4 upgrades (data-driven)
                ApplyHouseOfWisdomRestrictions(player.id, ITEM_REMOVED)
            end

            if DLC_DEBUG then
                print(string.format("[PROFILE] 'starting' applied to player %s (diff=%d, tier=%s)", tostring(player.id), AI_Difficulty, DC.label))
            end
        end
    },

    -- --------------------------------------------------------
    -- SIEGE_AVAILABLE: Phase 2 objective complete (Easy/Intermediate)
    -- --------------------------------------------------------
    siege_available = {
        description = "Phase 2 complete: siege becomes available (difficulty-scaled)",
        apply = function(player)
            _ApplySiegeRestrictions(player, ITEM_DEFAULT)
            if DLC_DEBUG then print(string.format("[PROFILE] 'siege_available' applied to player %s", tostring(player.id))) end
        end
    },

    -- --------------------------------------------------------
    -- ENGINEERS_AVAILABLE: Phase 2 objective (Hard+ difficulty)
    -- --------------------------------------------------------
    engineers_available = {
        description = "Hard+ difficulty: siege + engineers become available",
        apply = function(player)
            _ApplySiegeRestrictions(player, ITEM_DEFAULT)
            _ApplyEngineerRestrictions(player, ITEM_DEFAULT)
            if DLC_DEBUG then print(string.format("[PROFILE] 'engineers_available' applied to player %s", tostring(player.id))) end
        end
    },

    -- --------------------------------------------------------
    -- WORKSHOP_AVAILABLE: Phase 3 objective (Absurd / Difficulty == 6)
    -- --------------------------------------------------------
    workshop_available = {
        description = "Absurd difficulty: siege workshop becomes available",
        apply = function(player)
            -- Siege Workshop / All factions
            Player_SetEntityProductionAvailability(player.id, AGS_GetCivilizationEntity(player.raceName, AGS_BP_WORKSHOP), ITEM_DEFAULT)

            if DLC_DEBUG then
                print(string.format("[PROFILE] 'workshop_available' applied to player %s", tostring(player.id)))
            end
        end
    },
}

-- Track which profiles have been applied per player (idempotency guard)
PLAYER_PROFILE_APPLIED = {}

---ApplyRestrictionProfile: Unified entry point for restriction management.
-- Validates profile name, applies profile logic, updates per-player state.
-- Idempotent: calling twice with same profile skips re-application.
function ApplyRestrictionProfile(player, profile_name)
    local profile = Restriction_Profile[profile_name]
    if not profile then
        print(string.format("[ERROR] ApplyRestrictionProfile: Unknown profile '%s'", tostring(profile_name)))
        return false
    end

    -- Idempotency guard: skip if this exact profile was already applied to this player
    if PLAYER_PROFILE_APPLIED[player.id] and PLAYER_PROFILE_APPLIED[player.id][profile_name] then
        if DLC_DEBUG then
            print(string.format("[DLC-DBG] ApplyRestrictionProfile: SKIPPED (already applied) player=%s profile=%s", tostring(player.id), profile_name))
        end
        return true
    end

    -- Apply the profile
    profile.apply(player)

    -- Update state tracking
    SetPlayerProfile(player.id, profile_name)

    -- Mark this profile as applied for this player
    if not PLAYER_PROFILE_APPLIED[player.id] then
        PLAYER_PROFILE_APPLIED[player.id] = {}
    end
    PLAYER_PROFILE_APPLIED[player.id][profile_name] = true

    if DLC_DEBUG then
        print(string.format("[DLC-DBG] ApplyRestrictionProfile complete: player=%s profile=%s", tostring(player.id), profile_name))
    end
    return true
end

---Validator_RestrictionState: Check all players have valid profiles.
-- Returns true if all tracked players have a recognized profile.
function Validator_RestrictionState()
    print("[VALIDATOR] Restriction State Check:")
    local valid_profiles = { starting = true, siege_available = true, engineers_available = true, workshop_available = true }
    local all_valid = true
    local tracked = 0

    for player_id, profile in pairs(PLAYER_RESTRICTION_STATE) do
        tracked = tracked + 1
        local is_valid = valid_profiles[profile] ~= nil
        print(string.format("  Player %s: %s [%s]", tostring(player_id), profile, is_valid and "OK" or "INVALID"))
        if not is_valid then all_valid = false end
    end

    if tracked == 0 then
        print("  (No players tracked yet — profiles not applied)")
    end

    print(string.format("[VALIDATOR] Players tracked: %d | Result: %s", tracked, all_valid and "PASS" or "FAIL"))
    return { ok = all_valid, profile_count = tracked }
end

-- Simulate_PlayerProgression: Dry-run test harness for progression simulation (console-safe)
-- Validates civ resolution + profile chain WITHOUT calling SCAR C++ APIs.
-- The apply functions call Player_Set*/Player_GetRaceName which require real Player* objects,
-- so this harness validates the data layer only (civ resolver + profile lookup + chain order).
-- Usage: Simulate_PlayerProgression("english", 0)
--        Simulate_PlayerProgression("abbasid_ha_01", 6)
function Simulate_PlayerProgression(civ, difficulty)
    print(string.format("[PROG-SIM] === Dry-run: %s at difficulty %d ===", civ, difficulty))

    -- Step 1: Validate civ resolves through DLC resolver
    local civ_lower = string.lower(civ)
    local resolved = ResolveCivKey(civ_lower)
    if resolved == nil then
        print(string.format("[PROG-SIM] FAIL: '%s' not in AGS_ENTITY_TABLE or DLC_CIV_PARENT_MAP", civ))
        return
    end
    if resolved ~= civ_lower then
        print(string.format("[PROG-SIM] Civ '%s' resolved via parent to family '%s'", civ, resolved))
    else
        print(string.format("[PROG-SIM] Civ '%s' is a base civ (no DLC resolution needed)", civ))
    end

    -- Step 2: Verify civ has entity table entry
    if AGS_ENTITY_TABLE[resolved] then
        print(string.format("[PROG-SIM] AGS_ENTITY_TABLE['%s']: present", resolved))
    else
        print(string.format("[PROG-SIM] WARN: AGS_ENTITY_TABLE['%s'] missing — apply would fail", resolved))
    end

    -- Step 3: Build profile chain from Difficulty_Config
    local dc = Difficulty_Config[difficulty]
    if dc == nil then
        print(string.format("[PROG-SIM] FAIL: No Difficulty_Config for tier %d", difficulty))
        return
    end
    local profiles = {"starting"}
    profiles[#profiles + 1] = dc.phase2_siege_profile
    if dc.phase2_workshop_unlock then
        profiles[#profiles + 1] = "workshop_available"
    end

    -- Step 4: Validate each profile exists and has an apply function
    local all_valid = true
    for i, name in ipairs(profiles) do
        local profile = Restriction_Profile[name]
        if profile and profile.apply then
            print(string.format("[PROG-SIM] [%d/%d] '%s': %s", i, #profiles, name, profile.description))
        else
            print(string.format("[PROG-SIM] [%d/%d] FAIL: profile '%s' not found!", i, #profiles, name))
            all_valid = false
        end
    end

    -- Step 5: Report result
    print(string.format("[PROG-SIM] === Result: %s | %d profiles | final: '%s' ===",
        all_valid and "PASS" or "FAIL", #profiles, profiles[#profiles]))
end

-- ============================================================
-- DLC Civilization Resolution System (Stage 1)
-- ============================================================
-- Supports DLC civs that inherit blueprints from a base civ.
-- Overrides take precedence. Recursive + cycle-safe fallback.
-- Fails fast on unknown civs. Validates at init before mission.
--
-- To add a new DLC civ, call RegisterDLCCiv() below.
-- ============================================================

-- ============================================================
-- Debug & Test Harness (Stage 2)
-- ============================================================
-- Set DLC_DEBUG = true to enable verbose resolver logging.
-- Call Validator_PlayerCivDump() in setup to log all player
-- resolutions to the warnings log for testing.
-- ============================================================

-- Toggle: set to true to enable verbose resolver logging
DLC_DEBUG = false

---DebugPrint_Resolver: Conditional print — only outputs when DLC_DEBUG is true.
function DebugPrint_Resolver(msg)
	if DLC_DEBUG then
		print("[DLC-DBG] " .. msg)
	end
end

---Validator_PlayerCivDump: Log each human player's raw civ, resolved civ,
-- and composition map entries. Call in Mission_SetupVariables for diagnostics.
function Validator_PlayerCivDump()
	for _, player in pairs(PLAYERS) do
		local raw = string.lower(Player_GetRaceName(player.id))
		local resolved = GetPlayerCiv(player.id)
		local melee_key = ResolveCivMapKey(CIV_MELEE_MAP, raw, "start_player_melee")
		local ranged_key = ResolveCivMapKey(CIV_RANGED_MAP, raw, "start_player_ranged")
		local reinf_melee = ResolveCivMapKey(REINFORCE_MELEE_MAP, raw, "units_player_melee_reinforce")
		local reinf_ranged = ResolveCivMapKey(REINFORCE_RANGED_MAP, raw, "units_player_ranged_reinforce")
		
		print("[DLC-DUMP] Player " .. tostring(player.id)
			.. " | raw: " .. raw
			.. " | resolved: " .. resolved
			.. " | melee: " .. melee_key
			.. " | ranged: " .. ranged_key
			.. " | reinf_melee: " .. reinf_melee
			.. " | reinf_ranged: " .. reinf_ranged)
	end
end

-- Maximum parent chain depth (prevents infinite recursion)
DLC_RESOLVE_MAX_DEPTH = 4

-- Parent map: DLC raceName → base civ key in AGS_ENTITY_TABLE
-- Populated by RegisterDLCCiv(); do not edit directly.
DLC_CIV_PARENT_MAP = {}

-- Sparse override table: DLC_CIV_OVERRIDES[raceName][shortName] = attribName
-- Only entries that DIFFER from parent need to be listed.
DLC_CIV_OVERRIDES = {}

-- Per-player resolved civ cache: player_id → resolved civ key
DLC_PLAYER_CIV_CACHE = {}

-- Composition role definitions for GenerateCompositionMaps()
-- melee_key/ranged_key: key into Unit_Types for starting army
-- unique_melee/unique_ranged: entry for UNIQUE_UNIT maps (nil = use parent or default)
-- reinforce_melee_key/reinforce_ranged_key: key into Unit_Types for reinforcements
DLC_CIV_COMPOSITION = {}

-- ============================================================
-- Registration
-- ============================================================

---RegisterDLCCiv: Register a DLC civ with parent inheritance.
-- spec: {attribName, parent, overrides?, melee_key?, ranged_key?, unique_melee?, unique_ranged?, reinforce_melee_key?, reinforce_ranged_key?}
-- Override precedence: DLC_CIV_OVERRIDES[civ][key] > AGS_ENTITY_TABLE[resolved][key] > error
function RegisterDLCCiv(spec)
	if spec.attribName == nil or spec.parent == nil then
		error("[DLC] RegisterDLCCiv: attribName and parent are required.")
	end
	DLC_CIV_PARENT_MAP[spec.attribName] = spec.parent
	if spec.overrides then
		DLC_CIV_OVERRIDES[spec.attribName] = spec.overrides
	end
	DLC_CIV_COMPOSITION[spec.attribName] = {
		melee_key           = spec.melee_key,
		ranged_key          = spec.ranged_key,
		unique_melee        = spec.unique_melee,
		unique_ranged       = spec.unique_ranged,
		reinforce_melee_key = spec.reinforce_melee_key,
		reinforce_ranged_key = spec.reinforce_ranged_key,
	}
	DebugPrint_Resolver("RegisterDLCCiv: '" .. spec.attribName .. "' -> parent '" .. spec.parent .. "'"
		.. (spec.overrides and (" with " .. tostring(_CountKeys(spec.overrides)) .. " override(s)") or ""))
end

-- DLC Civ Registrations (Dynasties of the East + Knights of Cross and Rose)
RegisterDLCCiv({attribName = "mongol_ha_gol", parent = "mongol", ranged_key = "start_player_ranged_mon", reinforce_ranged_key = "units_player_ranged_reinforce_cav"})
RegisterDLCCiv({attribName = "byzantine_ha_mac", parent = "byzantine"})
RegisterDLCCiv({attribName = "japanese_ha_sen", parent = "japanese", melee_key = "start_player_melee_inf"})
RegisterDLCCiv({attribName = "sultanate_ha_tug", parent = "sultanate"})
RegisterDLCCiv({attribName = "lancaster", parent = "english", melee_key = "start_player_melee_inf", reinforce_melee_key = "units_player_melee_reinforce_inf"})
RegisterDLCCiv({attribName = "templar", parent = "hre", melee_key = "start_player_melee_inf", reinforce_melee_key = "units_player_melee_reinforce_inf"})

-- ============================================================
-- Resolution Functions
-- ============================================================

---ResolveCivKey: Given a raceName, return a valid key in AGS_ENTITY_TABLE.
-- Checks AGS directly first, then walks DLC_CIV_PARENT_MAP recursively.
-- Returns nil if unresolvable (caller must handle).
-- Cycle-safe via depth limit.
function ResolveCivKey(raceName, _depth)
	if raceName == nil then return nil end
	raceName = string.lower(raceName)
	_depth = _depth or 0
	if _depth > DLC_RESOLVE_MAX_DEPTH then
		error("[DLC] ResolveCivKey: parent chain exceeded depth " 
			.. DLC_RESOLVE_MAX_DEPTH .. " for '" .. raceName 
			.. "'. Possible circular mapping.")
	end
	-- Direct match in AGS
	if AGS_ENTITY_TABLE[raceName] then
		DebugPrint_Resolver("ResolveCivKey: '" .. raceName .. "' direct match in AGS_ENTITY_TABLE")
		return raceName
	end
	-- Try parent
	local parent = DLC_CIV_PARENT_MAP[raceName]
	if parent then
		DebugPrint_Resolver("ResolveCivKey: '" .. raceName .. "' -> parent '" .. parent .. "' (depth " .. tostring(_depth) .. ")")
		return ResolveCivKey(parent, _depth + 1)
	end
	-- Unresolvable
	DebugPrint_Resolver("ResolveCivKey: '" .. raceName .. "' UNRESOLVABLE")
	return nil
end

---ResolveCivMapKey: Safely look up a civ in a composition map.
-- Tries exact raceName, then parent chain, then returns default_key.
-- Never returns nil (default_key is the final fallback).
function ResolveCivMapKey(map, raceName, default_key)
	if raceName == nil then return default_key end
	raceName = string.lower(raceName)
	-- Direct match
	if map[raceName] then
		return map[raceName]
	end
	-- Walk parent chain
	local current = raceName
	local depth = 0
	while depth < DLC_RESOLVE_MAX_DEPTH do
		current = DLC_CIV_PARENT_MAP[current]
		if current == nil then break end
		if map[current] then
			return map[current]
		end
		depth = depth + 1
	end
	-- Fallback to default
	return default_key
end

---ResolveUniqueUnit: Safely look up civ in UNIQUE_UNIT maps.
-- Returns the entry or UNIQUE_UNIT_DEFAULT.
function ResolveUniqueUnit(map, raceName)
	if raceName and map[raceName] then
		return map[raceName]
	end
	-- Walk parent chain
	local current = raceName
	local depth = 0
	while depth < DLC_RESOLVE_MAX_DEPTH do
		current = DLC_CIV_PARENT_MAP[current]
		if current == nil then break end
		if map[current] then
			return map[current]
		end
		depth = depth + 1
	end
	return UNIQUE_UNIT_DEFAULT
end

---GetPlayerCiv: Resolve and cache a player's civ key.
-- Returns a valid AGS_ENTITY_TABLE key, or errors.
function GetPlayerCiv(player_id)
	if DLC_PLAYER_CIV_CACHE[player_id] then
		return DLC_PLAYER_CIV_CACHE[player_id]
	end
	local raceName = string.lower(Player_GetRaceName(player_id))
	local resolved = ResolveCivKey(raceName)
	if resolved == nil then
		error("[DLC] GetPlayerCiv: Unknown civilization '" .. raceName 
			.. "' for player " .. tostring(player_id) 
			.. ". Not in AGS_ENTITY_TABLE or DLC_CIV_PARENT_MAP.")
	end
	if resolved ~= raceName then
		print("[DLC] Player " .. tostring(player_id) .. ": '" .. raceName 
			.. "' resolved via parent to '" .. resolved .. "'")
	end
	DLC_PLAYER_CIV_CACHE[player_id] = resolved
	return resolved
end

---GetPlayerRawCiv: Return the original (possibly DLC) raceName, lowercased.
-- Used when we need to check overrides against the original civ.
function GetPlayerRawCiv(player_id)
	return string.lower(Player_GetRaceName(player_id))
end

-- ============================================================
-- Composition Map Generation
-- ============================================================

---GenerateCompositionMaps: Populate CIV_*_MAP entries for all registered DLC civs.
-- Inherits from parent when DLC spec field is nil.
function GenerateCompositionMaps()
	local maps = {
		{m = CIV_MELEE_MAP, k = "melee_key"}, {m = CIV_RANGED_MAP, k = "ranged_key"},
		{m = UNIQUE_UNIT_MELEE, k = "unique_melee"}, {m = UNIQUE_UNIT_RANGED, k = "unique_ranged"},
		{m = REINFORCE_MELEE_MAP, k = "reinforce_melee_key"}, {m = REINFORCE_RANGED_MAP, k = "reinforce_ranged_key"},
	}
	for dlc_civ, comp in pairs(DLC_CIV_COMPOSITION) do
		local parent = DLC_CIV_PARENT_MAP[dlc_civ]
		for _, def in ipairs(maps) do
			if comp[def.k] then def.m[dlc_civ] = comp[def.k]
			elseif parent and def.m[parent] then def.m[dlc_civ] = def.m[parent] end
		end
	end
	print("[DLC] Composition maps generated for " .. tostring(_CountKeys(DLC_CIV_COMPOSITION)) .. " DLC civs.")
end

-- ============================================================
-- Validation
-- ============================================================

---Validator_CivRegistry: Run all validation checks.
-- Call in Mission_SetupVariables BEFORE any spawn or restriction logic.
-- Errors immediately on failure (fail fast).
function Validator_CivRegistry()
	_Validate_ParentCycles()
	_Validate_ParentsExist()
	_Validate_OverrideStructure()
	_Validate_CompositionSync()
	print("[DLC] Validator_CivRegistry: All checks passed.")
end

-- V1: Detect circular parent chains
function _Validate_ParentCycles()
	for start_civ, _ in pairs(DLC_CIV_PARENT_MAP) do
		local visited = {}
		local current = start_civ
		while current do
			if visited[current] then
				error("[DLC] VALIDATION FAILED — Circular parent chain detected: '"
					.. start_civ .. "' loops back to '" .. current .. "'.")
			end
			visited[current] = true
			current = DLC_CIV_PARENT_MAP[current]
		end
	end
end

-- V2: Ensure all referenced parents resolve to AGS_ENTITY_TABLE
function _Validate_ParentsExist()
	for dlc_civ, parent in pairs(DLC_CIV_PARENT_MAP) do
		local resolved = ResolveCivKey(parent)
		if resolved == nil then
			error("[DLC] VALIDATION FAILED — Parent '" .. parent 
				.. "' for DLC civ '" .. dlc_civ 
				.. "' does not resolve to AGS_ENTITY_TABLE.")
		end
	end
end

-- V3: Validate override table structure (no nil subtables, valid keys)
function _Validate_OverrideStructure()
	for dlc_civ, overrides in pairs(DLC_CIV_OVERRIDES) do
		if type(overrides) ~= "table" then
			error("[DLC] VALIDATION FAILED — DLC_CIV_OVERRIDES['" .. dlc_civ 
				.. "'] is not a table.")
		end
		-- Verify each override key exists in the parent's table
		local parent_key = ResolveCivKey(dlc_civ)
		if parent_key then
			for bp_type, attrib in pairs(overrides) do
				if type(attrib) ~= "string" then
					error("[DLC] VALIDATION FAILED — Override '" .. tostring(bp_type) 
						.. "' for '" .. dlc_civ .. "' is not a string.")
				end
				-- Warn if override key doesn't exist in parent (typo detection)
				if AGS_ENTITY_TABLE[parent_key][bp_type] == nil then
					print("[DLC] WARNING: Override key '" .. bp_type 
						.. "' for '" .. dlc_civ 
						.. "' does not exist in parent '" .. parent_key .. "' table.")
				end
			end
		end
	end
end

-- V4: Ensure all base civs in AGS_ENTITY_TABLE that are also in 
-- composition maps are synchronized (no orphan entries)
function _Validate_CompositionSync()
	-- Check all DLC civs have been generated into composition maps
	for dlc_civ, _ in pairs(DLC_CIV_PARENT_MAP) do
		-- Not an error if missing from composition maps (defaults apply),
		-- but warn if parent has a specific entry and DLC doesn't
		local parent = DLC_CIV_PARENT_MAP[dlc_civ]
		if parent then
			if CIV_MELEE_MAP[parent] and not CIV_MELEE_MAP[dlc_civ] then
				print("[DLC] WARNING: '" .. dlc_civ 
					.. "' missing from CIV_MELEE_MAP (parent '" .. parent .. "' has entry)."
					.. " Will use default fallback.")
			end
			if CIV_RANGED_MAP[parent] and not CIV_RANGED_MAP[dlc_civ] then
				print("[DLC] WARNING: '" .. dlc_civ 
					.. "' missing from CIV_RANGED_MAP (parent '" .. parent .. "' has entry)."
					.. " Will use default fallback.")
			end
		end
	end
end

-- Utility: count keys in a table
function _CountKeys(t)
	local n = 0
	for _ in pairs(t) do n = n + 1 end
	return n
end

-- ============================================================
-- Family & Civ Helper Functions (Stage 2)
-- ============================================================
-- Use these instead of ad-hoc resolved_civ == "english" checks.
-- IsCivFamily uses the resolver so DLC variants are covered.
-- IsCivExact checks the raw (unresolved) Player_GetRaceName value.
-- ============================================================

---IsCivFamily: Returns true if the player's resolved civ matches family.
-- Example: IsCivFamily(player.id, "english") → true for lancaster too.
function IsCivFamily(player_id, family)
	return GetPlayerCiv(player_id) == family
end

---IsCivExact: Returns true if the player's raw raceName matches exactly.
-- Example: IsCivExact(player.id, "abbasid_ha_01") → true only for Ayyubids.
function IsCivExact(player_id, civ_name)
	return string.lower(Player_GetRaceName(player_id)) == civ_name
end

---IsCivFamilyAny: Returns true if resolved civ matches any of the listed families.
-- Example: IsCivFamilyAny(player.id, {"chinese", "mongol", "byzantine"})
function IsCivFamilyAny(player_id, families)
	local resolved = GetPlayerCiv(player_id)
	for _, fam in ipairs(families) do
		if resolved == fam then return true end
	end
	return false
end

-- Civ suffix map (shared by AGS_ENTITY_TABLE + CBA_SIEGE_TABLE generators)
local CIV_SUFFIX = {
	english = "eng", chinese = "chi", french = "fre", hre = "hre", rus = "rus",
	abbasid = "abb", mongol = "mon", sultanate = "sul", malian = "mal",
	ottoman = "ott", japanese = "jpn", byzantine = "byz",
}

-- AGS_ENTITY_TABLE — Generated from template + per-civ overrides
-- Universal keys: always pattern_{suffix}
local AGS_UNIVERSAL = {
	{k="town_center_capital", f="building_town_center_capital_%s"},
	{k="town_center",         f="building_town_center_%s"},
	{k="castle",              f="building_defense_keep_%s"},
	{k="villager",            f="unit_villager_1_%s"},
	{k="scout",               f="unit_scout_1_%s"},
	{k="king",                f="unit_king_1_%s"},
	{k="scar_dock",           f="building_unit_naval_%s"},
	{k="palisade_wall",       f="building_defense_palisade_%s"},
	{k="palisade_gate",       f="building_defense_palisade_gate_%s"},
	{k="monk",                f="unit_monk_3_%s"},
	{k="crossbow",            f="unit_crossbowman_3_%s"},
	{k="stone_wall",          f="building_defense_wall_%s"},
}
-- Variant keys: "control" civs get ctrl format, others get base format
local AGS_VARIANT = {
	{k="market",        ctrl="building_econ_market_control_%s",        base="building_econ_market_%s"},
	{k="monastery",     ctrl="building_unit_religious_control_%s",     base="building_unit_religious_%s"},
	{k="barracks",      ctrl="building_unit_infantry_control_%s",      base="building_unit_infantry_%s"},
	{k="stable",        ctrl="building_unit_cavalry_control_%s",       base="building_unit_cavalry_%s"},
	{k="archery_range", ctrl="building_unit_ranged_control_%s",        base="building_unit_ranged_%s"},
	{k="siege_workshop",ctrl="building_unit_siege_control_%s",         base="building_unit_siege_%s"},
	{k="house",         ctrl="building_house_control_%s",              base="building_house_%s"},
	{k="blacksmith",    ctrl="building_tech_unit_infantry_control_%s", base="building_tech_unit_infantry_%s"},
	{k="mining_camp",   ctrl="building_econ_mining_camp_control_%s",   base="building_econ_mining_camp_%s"},
	{k="lumber_camp",   ctrl="building_econ_wood_control_%s",          base="building_econ_wood_%s"},
	{k="mill",          ctrl="building_econ_food_control_%s",          base="building_econ_food_%s"},
	{k="arsenal",       ctrl="building_tech_unit_ranged_control_%s",   base="building_tech_unit_ranged_%s"},
}
local AGS_IS_CTRL = {eng=true, chi=true, fre=true, hre=true, rus=true, sul=true, byz=true, abb=true}
-- Per-civ overrides (wonder + entries that differ from template)
local AGS_OVERRIDES = {
	english = {town_center_landmark = "building_landmark_age2_westminster_palace_eng", wonder_imperial_age = "building_wonder_age4_canterbury_cathedral_eng"},
	chinese = {wonder_imperial_age = "building_wonder_age4_forbidden_control_chi"},
	french = {wonder_imperial_age = "building_wonder_age4_la_grande_cathedral_fre"},
	hre = {town_center_landmark = "building_landmark_age3_hohenzollern_castle_hre", monk = "unit_monk_1_hre", wonder_imperial_age = "building_wonder_age4_glucksburg_castle_hre"},
	rus = {castle = "building_defense_keep_control_rus", wonder_imperial_age = "building_wonder_age4_saint_basils_cathedral_control_rus"},
	abbasid = {
		castle = "building_defense_keep_control_abb", springald_buildable = "unit_springald_3_buildable_abb",
		mangonel_buildable = "unit_mangonel_3_buildable_abb", house_of_wisdom = "building_house_of_wisdom_control_abb",
		wonder_imperial_age = "building_wonder_age4_great_mosque_control_abb",
	},
	mongol = {
		castle = "building_defense_keep_control_nov", town_center_capital_moving = "building_town_center_capital_moving_mon",
		scout = "unit_khan_1_mon", house_moving = "building_house_moving_mon",
		wonder_imperial_age = "building_wonder_age4_final_wonder_mon",
		mining_camp = "building_house_mon", lumber_camp = "building_house_mon", mill = "building_house_mon",
	},
	sultanate = {castle = "building_defense_keep_control_sul", monk = "unit_monk_2_sul", wonder_imperial_age = "building_wonder_age4_agra_fort_control_sul"},
	malian = {wonder_imperial_age = "building_wonder_age4_great_mosque_control_mal", arsenal = "building_tech_unit_ranged_control_nrm"},
	ottoman = {wonder_imperial_age = "building_wonder_age4_blue_mosque_ott", arsenal = "building_tech_unit_ranged_control_lith"},
	japanese = {wonder_imperial_age = "building_wonder_age4_great_mosque_control_jpn", mill = "building_house_jpn", arsenal = "building_tech_unit_ranged_control_nrm"},
	byzantine = {wonder_imperial_age = "building_wonder_age4_forbidden_control_byz", arsenal = "building_tech_unit_ranged_control_abb"},
}
local AGS_REMOVE = {
	mongol = {palisade_wall=true, palisade_gate=true, stone_wall=true},
	malian = {crossbow=true}, ottoman = {crossbow=true}, japanese = {crossbow=true},
}
-- Expansion civs (all use _control_ variant)
local DLC_AGS = {
	abbasid_ha_01 = {sfx = "abb_ha_01", over = {
		castle = "building_defense_keep_control_abb_ha_01", springald_buildable = "unit_springald_3_buildable_abb_ha_01",
		mangonel_buildable = "unit_mangonel_3_buildable_abb_ha_01", house_of_wisdom = "building_house_of_wisdom_control_abb_ha_01",
		wonder_imperial_age = "building_wonder_age4_great_mosque_control_abb_ha_01",
	}},
	chinese_ha_01 = {sfx = "chi_ha_01", over = {wonder_imperial_age = "building_wonder_age4_forbidden_control_chi_ha_01"}},
	french_ha_01 = {sfx = "fre_ha_01", over = {wonder_imperial_age = "building_wonder_age4_la_grande_cathedral_fre_ha_01"}},
	hre_ha_01 = {sfx = "hre_ha_01", over = {
		town_center_landmark = "building_landmark_age3_hohenzollern_castle_hre_ha_01",
		monk = "unit_monk_1_hre_ha_01", wonder_imperial_age = "building_wonder_age4_glucksburg_castle_hre_ha_01",
	}},
}
function _BuildEntityTable()
	AGS_ENTITY_TABLE = {}
	for civ, sfx in pairs(CIV_SUFFIX) do
		local entry = {}
		local is_ctrl = AGS_IS_CTRL[sfx]
		for _, t in ipairs(AGS_UNIVERSAL) do entry[t.k] = string.format(t.f, sfx) end
		for _, t in ipairs(AGS_VARIANT) do entry[t.k] = string.format(is_ctrl and t.ctrl or t.base, sfx) end
		if AGS_OVERRIDES[civ] then for k, v in pairs(AGS_OVERRIDES[civ]) do entry[k] = v end end
		if AGS_REMOVE[civ] then for k, _ in pairs(AGS_REMOVE[civ]) do entry[k] = nil end end
		AGS_ENTITY_TABLE[civ] = entry
	end
	for dlc, spec in pairs(DLC_AGS) do
		local entry = {}
		for _, t in ipairs(AGS_UNIVERSAL) do entry[t.k] = string.format(t.f, spec.sfx) end
		for _, t in ipairs(AGS_VARIANT) do entry[t.k] = string.format(t.ctrl, spec.sfx) end
		if spec.over then for k, v in pairs(spec.over) do entry[k] = v end end
		AGS_ENTITY_TABLE[dlc] = entry
	end
end
_BuildEntityTable()

