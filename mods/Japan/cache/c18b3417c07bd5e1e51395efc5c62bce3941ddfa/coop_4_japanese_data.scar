-- Batch-create numbered SGroup/EGroup globals
local function _SGroupBatch(prefix, count)
	for i = 1, count do _G[prefix..i] = SGroup_CreateIfNotFound(prefix..i) end
end
local function _EGroupBatch(prefix, count)
	for i = 1, count do _G[prefix..i] = EGroup_CreateIfNotFound(prefix..i) end
end

-- Mission_SetupVariables
function SetupVariables_data()
	
	-- AI Difficulty
	AI_Difficulty = GetAIDifficulty(player6)
	
	-- Initialize centralized difficulty config (sets global DC)
	Difficulty_Init()
	
	-- SGroup Tracker
	sg_player_team = SGroup_CreateIfNotFound("sg_player_team") 
	
	-- Garrison_Building
	sg_garrison = SGroup_CreateIfNotFound("sg_garrison")
	
	
	-------------
	-- Phase 1 --
	-------------
	
	-- Allied / Player-indexed SGroups (start, scout, reinforcements, unique, villagers, checkpoint)
	sg_players_all_start = SGroup_CreateIfNotFound("sg_players_all_start")
	for i = 1, 4 do
		_G["sg_player"..i.."_start"] = SGroup_CreateIfNotFound("sg_player"..i.."_start")
		_G["sg_player"..i.."_scout"] = SGroup_CreateIfNotFound("sg_player"..i.."_scout")
		_G["sg_player"..i.."_reinforcements"] = SGroup_CreateIfNotFound("sg_player"..i.."_reinforcements")
		_G["sg_player"..i.."_unique"] = SGroup_CreateIfNotFound("sg_player"..i.."_unique")
		_G["sg_player"..i.."_villagers"] = SGroup_CreateIfNotFound("sg_player"..i.."_villagers")
		_G["sg_player"..i.."_reinforcements_cp"] = SGroup_CreateIfNotFound("sg_player"..i.."_reinforcements_cp")
	end
	-- Allied / Village / AI Reinforcements
	_SGroupBatch("sg_allied_reinforcements_", 4)
	sg_allied_reinforcements_group1 = SGroup_CreateIfNotFound("sg_allied_reinforcements_group1")
	-- Enemy / Village Side / Guards + Starting Battle
	_SGroupBatch("sg_village_defender_", 6)
	_SGroupBatch("sg_cav_start_", 2)
	-- Enemy / Village Main / Guards
	_SGroupBatch("sg_village_guards_", 4)
	-- Enemy / Middle / Guards (1-4 regular, 5-8 choke points) + TC Flanks
	_SGroupBatch("sg_middle_guards_", 8)
	_SGroupBatch("sg_middle_flank_", 4)
	
	-- Objectives -- 
	
	-- Start / EGroups / Spawn_TC
	eg_player_tc = EGroup_CreateIfNotFound("eg_player_tc")
	for i = 1, 4 do _G["eg_player"..i.."_tc"] = EGroup_CreateIfNotFound("eg_player"..i.."_tc") end
	
	-- Village_Enemey_condition / Side 1
	guards_moving_1 = false
	guards_moving_2 = false
	guards_outpost_1 = false
	-- Village_Enemey_condition / Side 2
	guards_moving_3 = false
	guards_moving_4 = false
	guards_outpost_2 = false
	
	-- Reinforcements (Villager group)
	group_spawned = false
	
	-- Objective / Phase1_Barracks_Side_Outposts_rule
	outpost_captured_1 = false
	outpost_captured_2 = false
	-- Objective / Phase1_Barracks_Side_Rule_Counters
	rip_side_outposts1 = false
	rip_side_outposts2 = false
	-- Objective / Phase1_Barracks_Side_food / DISABLED
	eg_side1_food = EGroup_CreateIfNotFound("eg_side1_food")
	eg_side2_food = EGroup_CreateIfNotFound("eg_side2_food")
	
	-- Objective / Phase1_Village_Main_Rule_Counters
	eg_outpost_obj1 = EGroup_GetClosestEntity(eg_objective_village, mkr_objective_tc)
	eg_outpost_obj2 = EGroup_GetClosestEntity(eg_objective_village, mkr_village_main_2)
	rip_outpost1 = false
	rip_outpost2 = false
	-- Objective / Phase1_Village_Main_OnComplete
	eg_religious_1 = EGroup_CreateIfNotFound("eg_religious_1")
	
	-- Objective / Phase1_Village_Main_Defence_Start
	eg_tc_main = EGroup_CreateIfNotFound("eg_tc_main")

	-------------
	-- Phase 2 --
	-------------
	
	-- Side / Top
	sg_ally_siege_1 = SGroup_CreateIfNotFound("sg_ally_siege_1")
	sg_city_outer_counter_1a = SGroup_CreateIfNotFound("sg_city_outer_counter_1a")
	sg_city_outer_counter_1b = SGroup_CreateIfNotFound("sg_city_outer_counter_1b")
	sg_top_ambush_1 = SGroup_CreateIfNotFound("sg_top_ambush_1")
	sg_top_ambush_2 = SGroup_CreateIfNotFound("sg_top_ambush_2")
	sg_top_ambush_3 = SGroup_CreateIfNotFound("sg_top_ambush_3")
	sg_top_trench_1 = SGroup_CreateIfNotFound("sg_top_trench_1")
	sg_top_trench_2 = SGroup_CreateIfNotFound("sg_top_trench_2")
	
	-- Side / Middle
	sg_middle_entry_cliff = SGroup_CreateIfNotFound("sg_middle_entry_cliff")
	sg_middle_entry_cliff_2 = SGroup_CreateIfNotFound("sg_middle_entry_cliff_2")
	sg_middle_entry_1 = SGroup_CreateIfNotFound("sg_middle_entry_1")
	sg_middle_entry_2 = SGroup_CreateIfNotFound("sg_middle_entry_2")
	sg_middle_entry_ambush_1 = SGroup_CreateIfNotFound("sg_middle_entry_ambush_1")
	sg_middle_entry_ambush_2 = SGroup_CreateIfNotFound("sg_middle_entry_ambush_2")
	sg_middle_entry_ambush_3 = SGroup_CreateIfNotFound("sg_middle_entry_ambush_3")
	
	-- Objective / Phase2_ReinforcementKeep_condition
	sg_middle_entry_all = SGroup_CreateIfNotFound("sg_middle_entry_all")
	top_ambush_threshold = 0
	top_ambush = false
	top_cleared = false
	
	-- Objective / Phase2_CaptureSiege_Attacks
	sg_workshop_attack_1 = SGroup_CreateIfNotFound("sg_workshop_attack_1")
	sg_ally_siege_2 = SGroup_CreateIfNotFound("sg_ally_siege_2")
	middle_cleared = false
	-- Objective / Phase2_CaptureSiege_Condition
	middle_ambush = false
	workshop_captured = false
	-- Objective / Phase2_CaptureSiege_OnComplete
	_EGroupBatch("eg_siege_p", 4)
	
	-- Objective / Phase2_CaptureCity_Setup
	sg_general_1 = SGroup_CreateIfNotFound("sg_general_1")
	_SGroupBatch("sg_city1_defender_", 9)
	sg_city1_defender_all = SGroup_CreateIfNotFound("sg_city1_defender_all")
	-- Objective / Phase2_CaptureCity_Condition
	wall_breached = false
	city_ownership_changed = false

	-------------
	-- Phase 3 --
	-------------
	
	_SGroupBatch("sg_city2_defender_", 6)
	
	-- Objective / Phase3_
	sg_general_2 = SGroup_CreateIfNotFound("sg_general_2")
	_SGroupBatch("sg_general_security_", 2)
	general_eliminated = false
	


	-------------
	--  Waves  --
	-------------
	
	-- Delayed attack waves: Sides 1 (P1&P2) and 2 (P3&P4)
	-- 01a-01d: Light/flank, 02: Siege, 03: Armored Cav, 04-07: Standard, 08-11: Hardest only
	local wave_suffixes = {"01a","01b","01c","01d","02","03","04","05","06","07","08","09","10","11"}
	for _, side in ipairs({"1","2"}) do
		for _, s in ipairs(wave_suffixes) do
			local name = "sg_waves_main_"..side.."_"..s
			_G[name] = SGroup_CreateIfNotFound(name)
		end
	end
	
	-- Patrols
	_SGroupBatch("sg_middle_patrol_", 4)
	
	-- Extra Waves (01-02: Phase2_CaptureCity_Completed, 03-04: Condition, 05-06: Standard)
	for i = 1, 6 do
		local name = string.format("sg_waves_main_3_%02d", i)
		_G[name] = SGroup_CreateIfNotFound(name)
	end
end

-- Marker path compositions (single-line for compactness)
function Unit_Path_Data()
	-- Allied Waves (village raids #1-4, city raids #1-3)
	ally_assault_1 = {mkr_ally_raid1_1, mkr_ally_raid1_2, mkr_ally_raid1_3}
