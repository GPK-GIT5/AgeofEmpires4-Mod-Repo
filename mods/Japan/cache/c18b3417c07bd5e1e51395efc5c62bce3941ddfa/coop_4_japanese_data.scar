	wave_path_2_flank = {mkr_wave_2_path_1, mkr_wave_2_path_2, mkr_wave_path_village, mkr_wave_resources_1, mkr_wave_2_compound, mkr_wave_2_trade, mkr_wave_2_flank_1, mkr_wave_2_flank_2, mkr_village_main_2, mkr_objective_tc}
