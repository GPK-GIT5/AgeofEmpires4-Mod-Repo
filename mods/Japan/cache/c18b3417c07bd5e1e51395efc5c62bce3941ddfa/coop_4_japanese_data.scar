	patrol_village_main = {mkr_village_main_3, mkr_village_main_2, mkr_village_main_1a, mkr_wave_2_flank_2, mkr_village_main_1a, mkr_wave_1_resources_3, mkr_village_main_1a, mkr_village_main_3}
	patrol_village_1 = {mkr_wave_2_resources_2, mkr_wave_2_resources_3, mkr_wave_2_trade, mkr_wave_2_compound, mkr_wave_1_resources_1, mkr_side_1_compound, mkr_wave_1_flank_2, mkr_wave_1_resources_3, mkr_wave_2_resources_2, mkr_wave_2_resources_3, mkr_wave_2_trade, mkr_wave_2_compound}
