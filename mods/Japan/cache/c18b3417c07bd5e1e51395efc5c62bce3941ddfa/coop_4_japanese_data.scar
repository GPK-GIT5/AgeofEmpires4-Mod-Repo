	-- Attack Waves (side #1: main, flank, resources; side #2: main, flank, resources)
	wave_path_1 = {mkr_wave_1_path_1, mkr_wave_1_path_2, mkr_wave_1_path_3, mkr_wave_1_path_4, mkr_wave_path_village, mkr_village_main_2, mkr_objective_tc}
