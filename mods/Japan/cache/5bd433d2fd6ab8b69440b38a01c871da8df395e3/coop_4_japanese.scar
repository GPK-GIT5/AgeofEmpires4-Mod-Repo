-------------------------------------------
-- Functions 
-------------------------------------------

-------------------------------------------
-- HUD Objective Helpers (top-left UI panel)
-- Pattern from template3v: Obj_Create with "ConquestObjectiveTemplate"
-- creates a reliable top-left HUD element for the local player.
-- Uses Game_GetLocalPlayer() so each client creates only ONE HUD entry,
-- avoiding duplicates in 4-player multiplayer.
-------------------------------------------

-- Icon used for all HUD objectives
HUD_ICON = "icons/objectives/objectives_warning"

-- Stores a single HUD ID per key (one per local client)
g_hud = {}

-- Stores SCAR timer IDs for HUD objectives that use countdown timers
g_hud_timers = {}

-- Create a top-left HUD objective for the local player only
-- Each client calls this, so every player sees exactly one entry
-- Optional 'icon' parameter overrides the default HUD_ICON
function CreateHUDObjective(title, key, icon)
	local localPlayer = Game_GetLocalPlayer()
	local objIcon = icon or HUD_ICON
	local id = Obj_Create(localPlayer, title, Loc_Empty(), objIcon,
		"ConquestObjectiveTemplate", "", OT_Primary, 0, key)
	Obj_SetState(id, OS_Incomplete)
	Obj_SetVisible(id, true)
	g_hud[key] = id
	return id
end

-- Create a top-left HUD objective with a counter (e.g. 0/2)
-- Optional 'icon' parameter overrides the default HUD_ICON
function CreateHUDObjectiveWithCounter(title, key, count, max, icon)
	CreateHUDObjective(title, key, icon)
	Obj_SetCounterType(g_hud[key], COUNTER_CountUpTo)
	Obj_SetCounterCount(g_hud[key], count)
	Obj_SetCounterMax(g_hud[key], max)
end

-- Create a top-left HUD objective with a countdown timer
-- 'seconds' is the total countdown duration; the HUD auto-updates each second
-- Optional 'icon' parameter overrides the default HUD_ICON
function CreateHUDObjectiveWithTimer(title, key, seconds, icon)
	CreateHUDObjective(title, key, icon)
	-- Set counter to countdown-timer mode
	Obj_SetCounterType(g_hud[key], COUNTER_TimerDecreasing)
	-- Create a SCAR timer to track remaining time
	local timerID = key .. "_timer"
	Timer_Start(timerID, seconds)
	-- Push the initial value into the HUD
	Obj_SetCounterTimerSeconds(g_hud[key], Timer_GetRemaining(timerID))
	-- Store timer info for the periodic update rule
	g_hud_timers[key] = timerID
	-- Start the 1-second update rule if not already running
	if not Rule_Exists(_UpdateHUDTimers) then
		Rule_AddInterval(_UpdateHUDTimers, 1)
	end
end

-- Interval rule: pushes remaining time into every active HUD timer each second
function _UpdateHUDTimers()
	local anyActive = false
	for key, timerID in pairs(g_hud_timers) do
		if g_hud[key] ~= nil and Timer_Exists(timerID) then
			Obj_SetCounterTimerSeconds(g_hud[key], Timer_GetRemaining(timerID))
			anyActive = true
		end
	end
	-- Remove this rule when no active timers remain
	if not anyActive then
		Rule_RemoveMe()
	end
end

-- Update the counter value on the HUD objective for a given key
function UpdateHUDCounter(key, count)
	if g_hud[key] ~= nil then
		Obj_SetCounterCount(g_hud[key], count)
	end
end

-- Hide then complete a HUD objective (hide-first prevents blank popup)
-- Also cleans up any associated countdown timer
function CompleteHUDObjective(key)
	if g_hud[key] ~= nil then
		Obj_SetVisible(g_hud[key], false)
		Obj_SetState(g_hud[key], OS_Complete)
	end
	-- Clean up any associated timer
	if g_hud_timers[key] ~= nil then
		if Timer_Exists(g_hud_timers[key]) then
			Timer_End(g_hud_timers[key])
		end
		g_hud_timers[key] = nil
	end
end

-- Hide then fail a HUD objective
-- Also cleans up any associated countdown timer
function FailHUDObjective(key)
	if g_hud[key] ~= nil then
		Obj_SetVisible(g_hud[key], false)
		Obj_SetState(g_hud[key], OS_Failed)
	end
	-- Clean up any associated timer
	if g_hud_timers[key] ~= nil then
		if Timer_Exists(g_hud_timers[key]) then
			Timer_End(g_hud_timers[key])
		end
		g_hud_timers[key] = nil
	end
end

-- Track original human/AI state for personality enforcement
g_original_player_types = {}

-- TODO: When a player leaves, consider transferring their units to another player.
-- Use Player_GetResources() on the leaving player and distribute those resources
-- to the recipient player(s) using Player_AddResource().

-- Prevent AI takeover
-- Registered as both Rule_AddGlobalEvent (GE_AIPlayer_Migrated + GE_AITakeOver) and Rule_AddInterval (1s)
-- Event catches migration/takeover immediately; interval catches silent personality drift from Relic systems

-- All player slots indexed for Reset_AI iteration
ALL_PLAYER_SLOTS = {}  -- populated in Mission_Start after player globals exist

function Reset_AI(context)
	-- Check all 6 player slots (human co-op players 1–4 + AI allies/enemies 5–6)
	for i, pid in ipairs(ALL_PLAYER_SLOTS) do
		
		-- Only enforce AI personality if player is currently AI-controlled
		-- (either started as AI, or was human but disconnected → AI takeover)
		if not Player_IsHuman(pid) then
			local current_personality = AI_GetPersonality(pid)
			if current_personality ~= "default_campaign" then
				if DLC_DEBUG then
					local role = g_original_player_types[i] and "disconnected human" or "AI"
					print(string.format("[AI] Personality drift on player%d (%s): '%s' → 'default_campaign'", 
						i, role, current_personality))
				end
				AI_SetPersonality(pid, "default_campaign")
			end
		end
	end
end

-- Unlocks Chinese Dynasty UI
function DynastyUI_unlocked()
	
	for i, player in pairs(PLAYERS) do 

		if IsCivFamily(player.id, "chinese") then 
			-- Dynasties unlocked
			Player_CompleteUpgrade(player.id, BP_GetUpgradeBlueprint "player_dynasty1_chi")
			Player_SetStateModelBool(player.id, "dynasty_1_was_completed_chi",true) 
			Player_CompleteUpgrade(player.id, BP_GetUpgradeBlueprint "player_dynasty2_chi")
			Player_SetStateModelBool(player.id, "dynasty_2_was_completed_chi",true) 

			-- Update UI
			Player_SetStateModelFloat(player.id, "current_dynasty_chi",1)
			if Game_GetLocalPlayer() == player.id then 
				DynastyUI_Update()
			end

			Player_SetStateModelFloat(player.id, "current_dynasty_chi",2)
			if Game_GetLocalPlayer() == player.id then 
				DynastyUI_Update()
			end
		end
	end
	
end

-- Group all Player units for Proximity Marker
function SGroup_Tracker(context, data)
	
	local player = data.player 
	
	Player_GetAll(player)
	SGroup_Filter(sg_allsquads, "military", FILTER_REMOVE, sg_player_team)
	--SGroup_AddGroup(sg_player_team, sg_allsquads)
	
	
end 

-- Difficulty check / Thanks to AGameAnx		
function GetAIDifficulty(player)
	local AIPlayerNames = {
		[Loc_ToAnsi(1309)] = 0,     -- A.I. Easy
		[Loc_ToAnsi(1310)] = 1,     -- A.I. Intermediate
		[Loc_ToAnsi(1311)] = 2,     -- A.I. Hard
		[Loc_ToAnsi(1312)] = 3,     -- A.I. Hardest
		[Loc_ToAnsi(11250912)] = 4, -- A.I. Redicilous
		[Loc_ToAnsi(11250913)] = 5, -- A.I. Outrageous
		[Loc_ToAnsi(11250914)] = 6, -- A.I. Absurd
	}
	return AIPlayerNames[Loc_ToAnsi(Player_GetDisplayName(player))] or 2
end

-- Patrol_Cycle & Units_Deploy / Thanks to Foxplot
function Patrol_Cycle(context, data) -- Used to cycle units between waypoints
	
	local sgroup = data.sgroup 
	local path = data.path 
	
	Cmd_FormationAttackMove(sgroup, path[1])
	for index, mkr in pairs(path) do
		if index > 1 then
			Cmd_FormationAttackMove(sgroup, mkr, true)
		end
	end	
	
end

-- 'Deploy_Unit' & 'Gaurdian_Raid' combined
function Units_Deploy(context, data) -- Used to spawn units / attack groups

	local player = data.player
	local sgroup = data.sgroup
	local unit_type = data.unit_type
	local spawn_loc = data.spawn_loc
	local path = data.path 


	UnitEntry_DeploySquads(player, sgroup, unit_type, spawn_loc)
	Cmd_FormationAttackMove(sgroup, path[1])
	for index, mkr in pairs(path) do
		if index > 1 then
			Cmd_FormationAttackMove(sgroup, mkr, true)
		end
	end

end

-- Puts archers in selected building
function Garrison_Building(context, data)
    
    local egroup = data.egroup
    local amount = data.amount
    local player = data.player

    local units = {
        {type = "scar_archer", spawn = egroup, numSquads = amount},
    }
    
    UnitEntry_DeploySquads(player, sg_garrison, units)
    Cmd_Garrison(sg_garrison, egroup, nil, false, true)
    
end

-- ============================================================
-- Safe AGS Blueprint Retrieval (DLC-aware)
-- Override precedence: DLC_CIV_OVERRIDES[original] > AGS_ENTITY_TABLE[resolved]
-- ============================================================

-- From Advanced Game Settings by Woprock (wrapped for DLC safety)
function AGS_GetCivilizationEntity(player_civ, bp_type)
	local original_civ = string.lower(player_civ)
	-- G3: Overrides take precedence over inherited values
	if DLC_CIV_OVERRIDES[original_civ] and DLC_CIV_OVERRIDES[original_civ][bp_type] then
		return BP_GetEntityBlueprint(DLC_CIV_OVERRIDES[original_civ][bp_type])
	end
	-- Resolve to base civ
	local resolved = ResolveCivKey(original_civ)
	if resolved == nil then
		error("[DLC] AGS_GetCivilizationEntity: Civ '" .. original_civ 
			.. "' is not resolvable. Add to AGS_ENTITY_TABLE or DLC_CIV_PARENT_MAP.")
	end
	local tbl = AGS_ENTITY_TABLE[resolved]
	if tbl == nil then
		error("[DLC] AGS_GetCivilizationEntity: Resolved civ '" .. resolved 
			.. "' has no AGS_ENTITY_TABLE entry.")
	end
	local attrib = tbl[bp_type]
	if attrib == nil then
		error("[DLC] AGS_GetCivilizationEntity: Blueprint key '" .. tostring(bp_type) 
			.. "' missing for civ '" .. original_civ 
			.. "' (resolved: '" .. resolved .. "').")
	end
	return BP_GetEntityBlueprint(attrib)
end

-- From Onslaught / Copy of AGS method above (wrapped for DLC safety)
function AGS_GetSiegeEntity(player_civ, bp_type)
	local original_civ = string.lower(player_civ)
	local resolved = ResolveCivKey(original_civ)
	if resolved == nil then
		error("[DLC] AGS_GetSiegeEntity: Civ '" .. original_civ 
			.. "' is not resolvable.")
	end
	local tbl = CBA_SIEGE_TABLE[resolved]
	if tbl == nil then
		error("[DLC] AGS_GetSiegeEntity: Resolved civ '" .. resolved 
			.. "' has no CBA_SIEGE_TABLE entry.")
	end
	local attrib = tbl[bp_type]
	if attrib == nil then
		error("[DLC] AGS_GetSiegeEntity: Siege key '" .. tostring(bp_type) 
			.. "' missing for civ '" .. original_civ 
			.. "' (resolved: '" .. resolved .. "').")
	end
	return BP_GetEntityBlueprint(attrib)
end

function AGS_GetSiegeSquad(player_civ, bp_type)
	local original_civ = string.lower(player_civ)
	local resolved = ResolveCivKey(original_civ)
	if resolved == nil then
		error("[DLC] AGS_GetSiegeSquad: Civ '" .. original_civ 
			.. "' is not resolvable.")
	end
	local tbl = CBA_SIEGE_TABLE[resolved]
	if tbl == nil then
		error("[DLC] AGS_GetSiegeSquad: Resolved civ '" .. resolved 
			.. "' has no CBA_SIEGE_TABLE entry.")
	end
	local attrib = tbl[bp_type]
	if attrib == nil then
		error("[DLC] AGS_GetSiegeSquad: Siege key '" .. tostring(bp_type) 
			.. "' missing for civ '" .. original_civ 
			.. "' (resolved: '" .. resolved .. "').")
	end
	return BP_GetSquadBlueprint(attrib)
end

-- End scenario
g_gameOver = false

function Defeat_Function()
	if g_gameOver then return end
	g_gameOver = true
	Rule_RemoveGlobalEvent(Reset_AI)
	if Rule_Exists(Reset_AI) then Rule_Remove(Reset_AI) end
	local defeatTeam = TEAMS[1]
	for i, team in pairs(TEAMS) do
		if team ~= defeatTeam then
			Core_SetTeamVictorious(team, Annihilation_WinnerPresentation, WR_ANNIHILATION)
		end
	end
	Core_SetTeamDefeated(defeatTeam, Annihilation_LoserPresentation, WR_ANNIHILATION)
	
end

function Victory_Function()
	if g_gameOver then return end
	g_gameOver = true
	Rule_RemoveGlobalEvent(Reset_AI)
	if Rule_Exists(Reset_AI) then Rule_Remove(Reset_AI) end
	local defeatTeam = TEAMS[2]
	for i, team in pairs(TEAMS) do
		if team ~= defeatTeam then
			Core_SetTeamVictorious(team, Annihilation_WinnerPresentation, WR_ANNIHILATION)
		end
	end
	Core_SetTeamDefeated(defeatTeam, Annihilation_LoserPresentation, WR_ANNIHILATION)
	
end