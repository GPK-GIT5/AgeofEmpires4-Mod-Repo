-- ============================================================
-- QUICK REFERENCE: DIFFICULTY VARIABLE → COMPOSITION → UNIT_TYPES
-- ============================================================
--
-- PHASE 1 (VILLAGE WAVES):
--   waves_5min_flank       → true/false  → village_waves.flank_early     → "wave_city_5m"
--   waves_late_extra       → true/false  → village_waves.late_extra_40m  → "wave_city_40m"
--   waves_hardest_extra    → true/false  → village_waves.hardest_extra   → "wave_city_25m"
--   hard_waves_siege       → true/false  → village_waves.siege           → "wave_siege"
--   hard_waves_infantry    → true/false  → village_waves.infantry_hard   → "wave_no_siege"
--
-- PHASE 2 (COUNTER-ATTACKS):
--   phase2_spawn_tier      → "easy"      → phase2_spawns.easy            → "wave_city_10m"
--   phase2_spawn_tier      → "hard"      → phase2_spawns.hard            → "wave_city_15m"
--   counter_attack_village → true/false  (uses workshop_counter_type as wave key)
--   workshop_counter_type  → wave key    → Unit_Types[key]
--
-- PHASE 3 (CITY #2):
--   city2_defender_strength → "easy"     → city2_defense.defender_easy    → "units_cityguards"
--   city2_defender_strength → "hard"     → city2_defense.defender_hard    → "units_cityguards_hard"
--   city2_counter_wave      → wave key  → Unit_Types[key]
--   city2_flank_wave        → true/false (enables extra flank wave)
--   city2_late_extra        → true/false (enables 40/45 min extra waves)
--   city2_hardest_extra     → true/false (enables hardest-tier waves)
--
-- PATROLS:
--   patrol_strength              → "easy" → patrols.easy          → "units_camp"
--   patrol_strength              → "hard" → patrols.hard          → "units_patrol_hard"
--   village_defender_strength    → "easy" → patrols.village_easy   → "units_camp_easy"
--   village_defender_strength    → "hard" → patrols.village_hard   → "units_patrol_hard"
--
-- TO CHANGE UNITS: Follow the chain above to find the Unit_Types
-- key, then search for it in the Unit_Types table below.
-- ============================================================

