-- AI Difficulty selects upgrades for AI (see DC.ai_upgrade_tier)
function Difficulty_Upgrades_Phase1()
	
	-- Add upgrades to AI
	if DC.ai_upgrade_tier == "ridiculous" then 
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_UNIT_ARCHER_3)
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_MELEE_ARMOR_I)
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_MELEE_DAMAGE_I)
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_RANGED_DAMAGE_I)
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_RANGED_ARMOR_I)
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_RANGED_ARMOR_I)
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_TECH_UNIVERSITY_MURDER_HOLES_4)
		
	elseif DC.ai_upgrade_tier == "outrageous_plus" then 
		-- Faction: CHI
		Player_CompleteUpgrade(player6, UPG.CHINESE.UPGRADE_UNIT_REPEATER_CROSSBOW_3_CHI)
		-- Default
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_3)
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_UNIT_ARCHER_3)
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_UNIT_HORSEMAN_3)
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_MELEE_ARMOR_II)
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_MELEE_DAMAGE_II)
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_RANGED_DAMAGE_II)
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_RANGED_ARMOR_II)
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_RANGED_ARMOR_II)
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_TECH_UNIVERSITY_MURDER_HOLES_4)
		
		
	else
		-- Enemy AI
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_2)
		-- Allied AI / Difficulty: Easy, Intermediate
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_3)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_ARCHER_3)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_HORSEMAN_3)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_MELEE_ARMOR_II)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_MELEE_DAMAGE_II)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_DAMAGE_II)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_ARMOR_II)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_ARMOR_II)
		
	end 
	
	-- 10 minute delay
	Rule_AddOneShot(Difficulty_Upgrades_Phase2, 600)
												
end
														
