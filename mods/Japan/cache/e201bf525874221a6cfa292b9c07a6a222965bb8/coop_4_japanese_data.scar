---ApplyLandmarkRestrictions: Apply a list of landmark restrictions from a data table.
-- Each entry: { civ, bp (string attribName) OR ebp (global EBP reference as string) }
-- Uses IsCivExact to match only the exact raceName.
function ApplyLandmarkRestrictions(player_id, restriction_table, item_state)
	for _, entry in ipairs(restriction_table) do
		if IsCivExact(player_id, entry.civ) then
			if entry.bp then
				Player_SetEntityProductionAvailability(player_id, BP_GetEntityBlueprint(entry.bp), item_state)
			elseif entry.ebp then
				-- Resolve global EBP constant (stored as string to avoid load-order issues)
				local ebp_val = _ResolveGlobalPath(entry.ebp)
				if ebp_val then
					Player_SetEntityProductionAvailability(player_id, ebp_val, item_state)
				end
			end
		end
	end
end

---ApplyHouseOfWisdomRestrictions: Apply HoW upgrade restrictions from data table.
function ApplyHouseOfWisdomRestrictions(player_id, item_state)
	for _, entry in ipairs(HOUSE_OF_WISDOM_AGE4_RESTRICTIONS) do
		if IsCivExact(player_id, entry.civ) then
			for _, upg_path in ipairs(entry.upgrades) do
				local upg_val = _ResolveGlobalPath(upg_path)
				if upg_val then
					Player_SetUpgradeAvailability(player_id, upg_val, item_state)
				end
			end
		end
	end
end

---_ResolveGlobalPath: Walk a dot-separated path like "EBP.FRENCH.BUILDING_FOO" into its value.
-- Returns nil if any segment is missing (safe for load-order).
function _ResolveGlobalPath(path)
	local parts = {}
	for part in string.gmatch(path, "[^%.]+") do
		table.insert(parts, part)
	end
	local current = _G
	for _, p in ipairs(parts) do
		current = current[p]
		if current == nil then return nil end
	end
	return current
end

