{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Auto Changelog",
      "detail": "Detects git changes and logs them to changelog/scopes/ if 24+ hours since last run",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/changelog/scripts/auto-changelog.ps1"
      ],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false
      },
      "problemMatcher": []
    }
  ]
}
