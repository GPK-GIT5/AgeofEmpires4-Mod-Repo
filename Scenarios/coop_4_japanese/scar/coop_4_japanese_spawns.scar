-- Setup allied starter units / Reinforcements
function Start_Setup_Players()
	
	-- Player config: { player, sg_start, sg_scout, sg_reinforce, sg_unique, spawn marker, role }
	local players = {
		{ id = player1, sg_start = sg_player1_start, sg_scout = sg_player1_scout, sg_reinforce = sg_player1_reinforcements, sg_unique = sg_player1_unique, mkr = mkr_spawn_1, role = "melee" },
		{ id = player2, sg_start = sg_player2_start, sg_scout = sg_player2_scout, sg_reinforce = sg_player2_reinforcements, sg_unique = sg_player2_unique, mkr = mkr_spawn_2, role = "ranged" },
		{ id = player3, sg_start = sg_player3_start, sg_scout = sg_player3_scout, sg_reinforce = sg_player3_reinforcements, sg_unique = sg_player3_unique, mkr = mkr_spawn_3, role = "melee" },
		{ id = player4, sg_start = sg_player4_start, sg_scout = sg_player4_scout, sg_reinforce = sg_player4_reinforcements, sg_unique = sg_player4_unique, mkr = mkr_spawn_4, role = "ranged" },
	}
	
	-- Deploy starting squads + unique units for each player
	for _, p in ipairs(players) do
		local civ = Player_GetRaceName(p.id)
		_Deploy_Starting_Squad(p.id, civ, p.sg_start, p.role, p.mkr)
		_Deploy_Unique_Unit(p.id, civ, p.sg_unique, p.role, p.mkr)
	end
	
	-- Setup Reinforcements_Player rules (data-driven, single generic function)
	if DC.player_reinforcements then
		for _, p in ipairs(players) do
			-- Capture per-player config via context table
			p.count_start = SGroup_Count(p.sg_start) + SGroup_Count(p.sg_unique)
			Rule_AddInterval(Reinforcements_PlayerRule, 5, { player_config = p })
		end
	end -- see DC.player_reinforcements
	
	-- Objective: Regroup / Merge all player units
	for _, p in ipairs(players) do
		SGroup_AddGroup(sg_players_all_start, p.sg_start)
		SGroup_AddGroup(sg_players_all_start, p.sg_unique)
	end
	
	-- Separate scouts to avoid their instant death
	for _, p in ipairs(players) do
		SGroup_Filter(p.sg_start, "scar_scout", FILTER_REMOVE, p.sg_scout)
	end
	
end

-- Setup enemey defenders / Spawns
function Spawn_Village_Enemey()
	
	-- Spawn enemies / Village Main
	UnitEntry_DeploySquads(player6, sg_village_guards_1, Unit_Types.units_camp, mkr_village_main_3) -- patrol
	UnitEntry_DeploySquads(player6, sg_village_guards_2, Unit_Types.units_camp_hard, mkr_village_main_2)
	UnitEntry_DeploySquads(player6, sg_village_guards_3, Unit_Types.units_camp, mkr_village_main_1a)
	UnitEntry_DeploySquads(player6, sg_village_guards_4, Unit_Types.units_ranged_light, mkr_village_main_1b)
	-- Set position for Springald
	Cmd_FormationMove(sg_middle_guards_1, sg_village_guards_4, false, false, mkr_wave_path_village)
	
	-- Spawn enemies / Village Side / Side #1
	UnitEntry_DeploySquads(player6, sg_village_defender_1, Unit_Types.units_camp, mkr_side_1_compound)
	UnitEntry_DeploySquads(player6, sg_village_defender_2, Unit_Types.units_camp, mkr_side_1_camp)  
	if DC.village_defender_strength == "hard" then
		UnitEntry_DeploySquads(player6, sg_village_defender_3, Unit_Types.units_patrol_hard, mkr_wave_1_flank_2) -- Hard
	else
		UnitEntry_DeploySquads(player6, sg_village_defender_3, Unit_Types.units_camp_easy, mkr_wave_1_flank_2)   -- Easy 
	end
	
	-- Spawn enemies / Village Side / Side #2
	UnitEntry_DeploySquads(player6, sg_village_defender_4, Unit_Types.units_camp, mkr_wave_2_compound)
	UnitEntry_DeploySquads(player6, sg_village_defender_5, Unit_Types.units_camp, mkr_side_2_camp)
	if DC.village_defender_strength == "hard" then
		UnitEntry_DeploySquads(player6, sg_village_defender_6, Unit_Types.units_patrol_hard, mkr_wave_2_trade) -- Hard
	else
		UnitEntry_DeploySquads(player6, sg_village_defender_6, Unit_Types.units_camp_easy, mkr_wave_2_trade)   -- Easy 
	end
	
	-- Enable patrol / Main
	Rule_AddInterval(Patrol_Cycle, 105, { sgroup = sg_village_guards_1, path = patrol_village_main })
	-- Enable patrol / Side
	Rule_AddInterval(Patrol_Cycle, 240, { sgroup = sg_village_defender_3, path = patrol_village_1 })
	Rule_AddInterval(Patrol_Cycle, 240, { sgroup = sg_village_defender_6, path = patrol_village_2 })
	
	-- Start patrol movement
	Cmd_FormationAttackMove(sg_village_defender_3, mkr_wave_2_trade, false, false)
	Cmd_FormationAttackMove(sg_village_defender_6, mkr_side_1_compound, false, false)
	
	
	-- Spawn enemies / Middle
	UnitEntry_DeploySquads(player6, sg_middle_guards_1, Unit_Types.units_camp_hard, mkr_middle_guards_1)
	UnitEntry_DeploySquads(player6, sg_middle_guards_2, Unit_Types.units_camp_hard, mkr_middle_guards_2)
	UnitEntry_DeploySquads(player6, sg_middle_guards_3, Unit_Types.units_camp_hard, mkr_middle_guards_3)
	UnitEntry_DeploySquads(player6, sg_middle_guards_4, Unit_Types.units_camp_hard, mkr_middle_guards_4)
	-- Set Direction / Middle
	Cmd_FormationMove(sg_middle_guards_1, mkr_middle_guards_1, false, false, mkr_wave_path_village)
	Cmd_FormationMove(sg_middle_guards_2, mkr_middle_guards_2, false, false, mkr_wave_path_village)
	Cmd_FormationMove(sg_middle_guards_3, mkr_middle_guards_3, false, false, mkr_wave_path_village)
	Cmd_FormationMove(sg_middle_guards_4, mkr_middle_guards_4, false, false, mkr_wave_path_village)
	
	
	-- Spawn enemies / Middle / Choke Points
	UnitEntry_DeploySquads(player6, sg_middle_guards_5, Unit_Types.units_camp_hard, mkr_allied_position_1)
	UnitEntry_DeploySquads(player6, sg_middle_guards_6, Unit_Types.units_camp_hard, mkr_allied_position_2)
--	UnitEntry_DeploySquads(player6, sg_middle_guards_7, Unit_Types.units_camp_hard, mkr_middle_guards_3)
--	UnitEntry_DeploySquads(player6, sg_middle_guards_8, Unit_Types.units_camp_hard, mkr_middle_guards_4)
	
	-- Set Direction / Middle / Choke Points
	Cmd_FormationMove(sg_middle_guards_5, mkr_allied_position_1, false, false, mkr_wave_1_flank_1)
	Cmd_FormationMove(sg_middle_guards_6, mkr_allied_position_2, false, false, mkr_side_2_camp)
--	Cmd_FormationMove(sg_middle_guards_7, mkr_middle_guards_3, false, false, mkr_wave_path_village)
--	Cmd_FormationMove(sg_middle_guards_8, mkr_middle_guards_4, false, false, mkr_wave_path_village)
	
	
	-- Spawn enemies / Middle / Choke Points
	UnitEntry_DeploySquads(player6, sg_middle_flank_1, Unit_Types.units_camp, mkr_village_flank_1a)
	UnitEntry_DeploySquads(player6, sg_middle_flank_2, Unit_Types.units_camp, mkr_village_flank_1b)
	UnitEntry_DeploySquads(player6, sg_middle_flank_3, Unit_Types.units_camp, mkr_village_flank_2a)
	UnitEntry_DeploySquads(player6, sg_middle_flank_4, Unit_Types.units_camp, mkr_village_flank_2b)
	
	-- Set Direction / Middle / Choke Points
	Cmd_FormationMove(sg_middle_flank_1, mkr_village_flank_1a, false, false, mkr_wave_1_resources_3)
	Cmd_FormationMove(sg_middle_flank_2, mkr_village_flank_1b, false, false, mkr_village_main_3)
	Cmd_FormationMove(sg_middle_flank_3, mkr_village_flank_2a, false, false, mkr_wave_2_resources_2)
	Cmd_FormationMove(sg_middle_flank_4, mkr_village_flank_2b, false, false, mkr_village_main_3)
	
	
end

-- Reinforcements (generic, data-driven for all 4 players)
-- p = player config from Start_Setup_Players: { id, sg_start, sg_reinforce, sg_unique, mkr, role, count_start }
function Reinforcements_Player(p)
	local civ = Player_GetRaceName(p.id)
	local total_alive = SGroup_Count(p.sg_start) + SGroup_Count(p.sg_unique)
	
	-- Resolve reinforcement Unit_Types key from civ lookup tables (DLC-safe)
	local reinforce_map = (p.role == "melee") and REINFORCE_MELEE_MAP or REINFORCE_RANGED_MAP
	local default_key = (p.role == "melee") and "units_player_melee_reinforce" or "units_player_ranged_reinforce"
	local reinforce_key = ResolveCivMapKey(reinforce_map, civ, default_key)
	
	-- Condition 1: Unit threshold (<30% of starting count)
	local deployed_reinforcements = false
	if total_alive < 0.3 * p.count_start then
		
		if DC.reinforcement_pre_capture then -- Deploy reinforcements before village capture
			UnitEntry_DeploySquads(p.id, p.sg_reinforce, Unit_Types[reinforce_key], p.mkr)
			SendReinforceNotification(p.mkr, "$11176787") -- Reinforcements have arrived!
			deployed_reinforcements = true
		end
	
	-- Condition 2: Village captured
	elseif EGroup_Count(eg_objective_village) == 0 then
		UnitEntry_DeploySquads(p.id, p.sg_reinforce, Unit_Types[reinforce_key], p.mkr)
		deployed_reinforcements = true
	end
	
	-- Special unit respawn: if unique unit is dead, respawn it
	if SGroup_Count(p.sg_unique) == 0 then
		_Deploy_Unique_Unit(p.id, civ, p.sg_unique, p.role, p.mkr)
	end
	
	-- Remove rule after reinforcement deployment (special respawn is one-shot with reinforcements)
	if deployed_reinforcements then
		Rule_RemoveMe()
	end
	
end

-- Reinforcements_PlayerRule: Named wrapper for Rule_AddInterval (data-driven approach)
-- Extracts player config from context table and calls Reinforcements_Player
function Reinforcements_PlayerRule(context, data)
	Reinforcements_Player(data.player_config)
end

