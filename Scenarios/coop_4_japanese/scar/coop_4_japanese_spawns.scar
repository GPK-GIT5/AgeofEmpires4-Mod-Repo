-- Patrol_Cycle & Units_Deploy / Thanks to Foxplot
function Patrol_Cycle(context, data) -- Used to cycle units between waypoints
	local sgroup = data.sgroup
	local path = data.path
	Cmd_FormationAttackMove(sgroup, path[1])
	for index, mkr in pairs(path) do
		if index > 1 then
			Cmd_FormationAttackMove(sgroup, mkr, true)
		end
	end
end

-- 'Deploy_Unit' & 'Gaurdian_Raid' combined
function Units_Deploy(context, data) -- Used to spawn units / attack groups
	local player = data.player
	local sgroup = data.sgroup
	local unit_type = data.unit_type
	local spawn_loc = data.spawn_loc
	local path = data.path
	UnitEntry_DeploySquads(player, sgroup, unit_type, spawn_loc)
	Cmd_FormationAttackMove(sgroup, path[1])
	for index, mkr in pairs(path) do
		if index > 1 then
			Cmd_FormationAttackMove(sgroup, mkr, true)
		end
	end
end

-- Puts archers in selected building
function Garrison_Building(context, data)
	local egroup = data.egroup
	local amount = data.amount
	local player = data.player
	local units = {
		{type = "scar_archer", spawn = egroup, numSquads = amount},
	}
	UnitEntry_DeploySquads(player, sg_garrison, units)
	Cmd_Garrison(sg_garrison, egroup, nil, false, true)
end

-- Group all Player units for Proximity Marker
function SGroup_Tracker(context, data)
	local player = data.player
	Player_GetAll(player)
	SGroup_Filter(sg_allsquads, "military", FILTER_REMOVE, sg_player_team)
end

-- Deploy allied siege with notification (parameterized)
function _DeployAlliedSiege(sgroup, spawn_mkr, path)
	if sgroup == nil then
		print("[SPAWN-DBG] _DeployAlliedSiege skipped: sgroup is nil")
		return
	end
	if spawn_mkr == nil then
		print("[SPAWN-DBG] _DeployAlliedSiege skipped: spawn marker is nil")
		return
	end
	if path == nil or path[1] == nil then
		print("[SPAWN-DBG] _DeployAlliedSiege skipped: path is nil/empty")
		return
	end
	if SGroup_Count(sgroup) == 0 then
		local event_cue_text_reinforcements = Loc_FormatText("$11179775")  -- "Reinforcements arriving soon"
		UI_CreateEventCueClickable(-1, 40, -1, 0, event_cue_text_reinforcements, "", "low_priority", "", "sfx_campaign_scripted_ui_objective_counter_update", 255, 255, 255, 255, ECV_Queue, nothing)
		UI_CreateMinimapBlip(spawn_mkr, 40, "general")
		Rule_AddOneShot(Units_Deploy, 40, { player = player5, sgroup = sgroup, unit_type = Unit_Types.wave_allied_siege, spawn_loc = spawn_mkr, path = path })
	end
end

-- Respawn a single patrol if depleted (parameterized)
function _RespawnPatrol(sgroup, hard_type, normal_type, spawn_mkr, waypoint_mkr)
	if sgroup == nil then
		print("[SPAWN-DBG] _RespawnPatrol skipped: sgroup is nil")
		return
	end
	if spawn_mkr == nil or waypoint_mkr == nil then
		print("[SPAWN-DBG] _RespawnPatrol skipped: marker is nil")
		return
	end
	if DC == nil then
		print("[SPAWN-DBG] _RespawnPatrol skipped: DC is nil")
		return
	end
	if SGroup_Count(sgroup) == 0 then
		if DC.patrol_strength == "hard" then
			UnitEntry_DeploySquads(player6, sgroup, hard_type, spawn_mkr)
		else
			UnitEntry_DeploySquads(player6, sgroup, normal_type, spawn_mkr)
		end
		Cmd_FormationAttackMove(sgroup, waypoint_mkr)
	end
end

-- Deploy starting army based on civ and role (melee/ranged)
-- Uses ResolveCivMapKey for DLC-safe parent fallback
function _Deploy_Starting_Squad(player, civ, sg_start, role, spawn)
	local map = (role == "melee") and CIV_MELEE_MAP or CIV_RANGED_MAP
	local default = (role == "melee") and "start_player_melee" or "start_player_ranged"
	local key = ResolveCivMapKey(map, civ, default)
	UnitEntry_DeploySquads(player, sg_start, Unit_Types[key], spawn)
end

-- Deploy unique unit (Khan, King, Jeanne, or default Monks)
-- Uses ResolveUniqueUnit for DLC-safe parent fallback
-- sg_unique: separate squad group for tracking alive/dead state
function _Deploy_Unique_Unit(player, civ, sg_unique, role, spawn)
	local map = (role == "melee") and UNIQUE_UNIT_MELEE or UNIQUE_UNIT_RANGED
	local entry = ResolveUniqueUnit(map, civ)
	-- Clone entry and attach spawn marker
	local deploy = {numSquads = entry.numSquads, spawn = spawn}
	if entry.type then deploy.type = entry.type end
	if entry.sbp then deploy.sbp = entry.sbp end
	UnitEntry_DeploySquads(player, sg_unique, deploy, spawn)
end

