-- TC vision suppression tracking (pre-objective lock phase).
g_tc_vision_mods = {}
g_tc_vision_applied = {}

local function _GetPlayerTCEGroup(player_id)
	if player_id == player1 then return eg_player1_tc end
	if player_id == player2 then return eg_player2_tc end
	if player_id == player3 then return eg_player3_tc end
	if player_id == player4 then return eg_player4_tc end
	return nil
end

function _ApplyTC_VisionSuppression(player_id, sight_multiplier)
	if g_tc_vision_applied[player_id] then
		return
	end

	local tc_group = _GetPlayerTCEGroup(player_id)
	if tc_group == nil or EGroup_Count(tc_group) == 0 then
		return
	end

	local multiplier = sight_multiplier
	if multiplier == nil then
		multiplier = 0
	end

	local modSight = Modifier_Create(MAT_Entity, "sight_radius_modifier", MUT_Multiplication, false, multiplier, "")
	g_tc_vision_mods[player_id] = {}

	for i = 1, EGroup_Count(tc_group) do
		local eid = EGroup_GetEntityAt(tc_group, i)
		if Entity_IsValid(Entity_GetID(eid)) then
			table.insert(g_tc_vision_mods[player_id], Modifier_ApplyToEntity(modSight, eid, 0))
		end
	end

	g_tc_vision_applied[player_id] = true
end

function _RemoveTC_VisionSuppression(player_id)
	local mods = g_tc_vision_mods[player_id]
	if scartype(mods) == ST_TABLE then
		for _, modifier in pairs(mods) do
			Modifier_Remove(modifier)
		end
	end

	g_tc_vision_mods[player_id] = {}
	g_tc_vision_applied[player_id] = false
end


