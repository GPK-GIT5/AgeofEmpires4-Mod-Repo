-- Precache age-gated squad blueprints during loading phase (before game world renders).
-- Uses Scar_AddInit per Rogue campaign pattern: "Precaching resources must be done
-- before the game loading completes." Called unconditionally for all risky variants
-- since player civ data is unavailable at this stage.
-- Covers STARTING and REINFORCEMENT units only (excludes enemy wave compositions).
local function _PrecacheOnLoading()
	local targets = {
		-- DLC-only MAA variants (no _2 tier → red box at Feudal Age start)
		"unit_manatarms_3_tem",
		"unit_manatarms_3_mon_ha_gol",
		"unit_manatarms_3_sul_ha_tug",
		-- Knights: Age 3 units for all civs (used in start_player_melee_cav, reinforcements)
		"unit_knight_3_abb",
		"unit_knight_3_abb_ha_01",
		"unit_knight_3_chi",
		"unit_knight_3_chi_ha_01",
		"unit_knight_3_eng",
		"unit_knight_3_fre",
		"unit_knight_3_hre",
		"unit_knight_3_hre_ha_01",
		"unit_knight_3_sul",
		"unit_knight_3_sul_ha_tug",
		"unit_horseman_3_mal",
		"unit_knight_3_ott",
		"unit_knight_3_mon",
		"unit_knight_3_rus",
		"unit_knight_3_jpn",
		"unit_knight_3_jpn_ha_sen",
		"unit_knight_3_byz",
		"unit_knight_3_byz_ha_mac",
		"unit_knight_3_lan",
		"unit_knight_hospitaller_3_tem",
		"unit_knight_templar_3_tem",
		-- Abbasid-family Camel Rider (Age 3 unit used in Age 2 start composition)
		"unit_camel_rider_3_abb",
		-- Repeater Crossbow (Chinese family, Age 3 variants)
		"unit_repeater_crossbowman_3_chi",
		"unit_repeater_crossbowman_3_chi_ha_01",
		-- Javelin (Malian, Age 3)
		"unit_javelin_3_mal",
		-- Monks: verified _3-tier variants
		"unit_monk_3_abb",
		"unit_monk_3_chi",
		"unit_monk_3_eng",
		"unit_monk_3_fre",
		"unit_monk_3_mal",
		"unit_monk_3_mon",
		"unit_monk_3_ott",
		"unit_monk_3_rus",
		-- Monks: Japanese variants (both religious paths)
		"unit_monk_buddhist_3_jpn",
		"unit_monk_shinto_3_jpn",
		-- Monks: DLC variants with verified _3 tier variants
		"unit_monk_3_cambulance_abb_ha_01",
		"unit_monk_3_mon_ha_gol",
		"unit_monk_ikko_3_jpn_ha_sen",
		"unit_monk_3_lan",
		"unit_monk_3_tem",
		"unit_monk_3_chi_ha_01",
	}
	local loaded = 0
	local skipped = 0
	for _, attrib in ipairs(targets) do
		local ok, sbp = pcall(BP_GetSquadBlueprint, attrib)
		if ok and sbp ~= nil then
			Scar_PrecachePrematchResource(sbp)
			loaded = loaded + 1
		else
			skipped = skipped + 1
			print("[PRECACHE][WARN] Woodland: unresolved squad blueprint: " .. tostring(attrib))
		end
	end
	print("[PRECACHE] Woodland: warmed " .. tostring(loaded) .. " age-gated squad blueprints; skipped " .. tostring(skipped) .. ".")
end
Scar_AddInit(_PrecacheOnLoading)

