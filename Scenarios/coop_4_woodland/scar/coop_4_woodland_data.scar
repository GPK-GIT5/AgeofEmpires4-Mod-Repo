-- AI Difficulty selects upgrades for AI 
function Difficulty_Phase1_Upgrades()
	
	-- Add upgrades to AI
	if AI_Difficulty == 2 then 
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_ARCHER_3)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_MELEE_ARMOR_I)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_MELEE_DAMAGE_I)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_DAMAGE_I)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_ARMOR_I)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_ARMOR_I)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_TECH_UNIVERSITY_MURDER_HOLES_4)
		
	elseif AI_Difficulty >= 3 then 
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_3)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_ARCHER_3)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_HORSEMAN_3)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_MELEE_ARMOR_II)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_MELEE_DAMAGE_II)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_DAMAGE_II)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_ARMOR_II)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_ARMOR_II)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_TECH_UNIVERSITY_MURDER_HOLES_4)
		
	else
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_2)
	end 
												
end
														
-- AI Difficulty selects upgrades for AI 
function Difficulty_Phase2_Upgrades()
	
	if AI_Difficulty == 2 then 
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_MELEE_ARMOR_II)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_MELEE_DAMAGE_II)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_DAMAGE_II)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_ARMOR_II)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_ARMOR_II)
		-- Faction: HRE
		Player_CompleteUpgrade(player5, UPG.HRE.UPGRADE_UNIT_MANATARMS_3_HRE)
		
	elseif AI_Difficulty >= 3 then	
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_4)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_ARCHER_4)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_HORSEMAN_4)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_MELEE_ARMOR_III)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_MELEE_DAMAGE_III)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_DAMAGE_III)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_ARMOR_III)
		-- Faction: HRE
		Player_CompleteUpgrade(player5, UPG.HRE.UPGRADE_UNIT_MANATARMS_3_HRE)
		Player_CompleteUpgrade(player5, UPG.HRE.UPGRADE_RIVETED_CHAIN_ARMOUR_HRE)
		Player_CompleteUpgrade(player5, UPG.HRE.UPGRADE_MAN_AT_ARMS_TWO_HANDED_HRE)
	end
	
	-- 10 minute delay
	Rule_AddOneShot(Difficulty_Phase3_Upgrades, 600)
	
end

function Difficulty_Phase3_Upgrades()

	if AI_Difficulty == 2 then				
		--Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_MANATARMS_4)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_MELEE_ARMOR_III)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_MELEE_DAMAGE_III)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_DAMAGE_III)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_ARMOR_III)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_4)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_ARCHER_4)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_HORSEMAN_4)
		Player_CompleteUpgrade(player5, UPG.HRE.UPGRADE_RIVETED_CHAIN_ARMOUR_HRE)
		-- Faction: HRE
		Player_CompleteUpgrade(player5, UPG.HRE.UPGRADE_MAN_AT_ARMS_TWO_HANDED_HRE)
		
	elseif AI_Difficulty >= 3 then	
		-- Unit Upgrades
		--Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_MANATARMS_4)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_KNIGHT_4)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_CROSSBOWMAN_4)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_TECH_UNIVERSITY_BIOLOGY)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_INCENDIARY)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_MANATARMS_ELITE_ARMY_TACTICS)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_SPEARMAN_ELITE_SPEAR_TACTICS)
		-- Siege Upgrades
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_SIEGE_CHEMISTRY)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_SIEGE_ADJUSTABLE_CROSSBAR)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_SIEGE_WEAPON_SPEED)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_SIEGE_STEEL_BORE)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_SIEGE_WORKS)
		-- Faction: HRE
		Player_CompleteUpgrade(player5, UPG.HRE.UPGRADE_UNIT_MANATARMS_4_HRE)
		Player_CompleteUpgrade(player5, UPG.HRE.UPGRADE_UNIT_LANDSKNECHT_4_HRE)
		Player_CompleteUpgrade(player5, UPG.HRE.UPGRADE_LANDSKNECHT_CHARGE_DRILLS_HRE)
		Player_CompleteUpgrade(player5, UPG.HRE.UPGRADE_MAN_AT_ARMS_MACES_HRE)
		Player_CompleteUpgrade(player5, UPG.HRE.UPGRADE_KNIGHT_BARDING_HRE)
		
	elseif AI_Difficulty == 1 then	
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_SPEARMAN_3)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_ARCHER_3)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_UNIT_HORSEMAN_3)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_MELEE_ARMOR_I)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_MELEE_DAMAGE_I)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_DAMAGE_I)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_ARMOR_I)
		Player_CompleteUpgrade(player5, UPG.COMMON.UPGRADE_RANGED_ARMOR_I)
	end
end