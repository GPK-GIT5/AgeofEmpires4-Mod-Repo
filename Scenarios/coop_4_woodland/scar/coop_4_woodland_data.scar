---ApplyLandmarkRestrictions: Apply restrictions from a landmark table for a player.
-- Uses IsCivFamily to apply restrictions to DLC variants via parent civ matching.
function ApplyLandmarkRestrictions(player_id, landmark_table, state)
	for _, entry in ipairs(landmark_table) do
		if IsCivExact(player_id, entry.civ) or IsCivFamily(player_id, entry.civ) then
			Player_SetEntityProductionAvailability(player_id, BP_GetEntityBlueprint(entry.bp), state)
		end
	end
end

---ApplyHouseOfWisdomRestrictions: Restrict House of Wisdom age-up wings.
function ApplyHouseOfWisdomRestrictions(player_id, state)
	if IsCivExact(player_id, "abbasid") then
		Player_SetUpgradeAvailability(player_id, UPG.ABBASID.UPGRADE_ADD_CULTURE_WING_CASTLE, state)
		Player_SetUpgradeAvailability(player_id, UPG.ABBASID.UPGRADE_ADD_TRADE_WING_CASTLE, state)
		Player_SetUpgradeAvailability(player_id, UPG.ABBASID.UPGRADE_ADD_MILITARY_WING_CASTLE, state)
		Player_SetUpgradeAvailability(player_id, UPG.ABBASID.UPGRADE_ADD_ECONOMY_WING_CASTLE, state)
	end
	if IsCivExact(player_id, "abbasid_ha_01") then
		Player_SetUpgradeAvailability(player_id, UPG.ABBASID_HA_01.UPGRADE_ADD_CULTURE_WING_CASTLE_A_ABB_HA_01, state)
		Player_SetUpgradeAvailability(player_id, UPG.ABBASID_HA_01.UPGRADE_ADD_CULTURE_WING_CASTLE_B_ABB_HA_01, state)
		Player_SetUpgradeAvailability(player_id, UPG.ABBASID_HA_01.UPGRADE_ADD_TRADE_WING_CASTLE_A_ABB_HA_01, state)
		Player_SetUpgradeAvailability(player_id, UPG.ABBASID_HA_01.UPGRADE_ADD_TRADE_WING_CASTLE_B_ABB_HA_01, state)
		Player_SetUpgradeAvailability(player_id, UPG.ABBASID_HA_01.UPGRADE_ADD_ECONOMY_WING_CASTLE_A_ABB_HA_01, state)
		Player_SetUpgradeAvailability(player_id, UPG.ABBASID_HA_01.UPGRADE_ADD_ECONOMY_WING_CASTLE_B_ABB_HA_01, state)
		Player_SetUpgradeAvailability(player_id, UPG.ABBASID_HA_01.UPGRADE_ADD_MILITARY_WING_CASTLE_A_ABB_HA_01, state)
		Player_SetUpgradeAvailability(player_id, UPG.ABBASID_HA_01.UPGRADE_ADD_MILITARY_WING_CASTLE_B_ABB_HA_01, state)
	end
end

-- Restriction profile table
Restriction_Profile = {

	-- STARTING: Applied to all players during Mission_SetRestrictions
	starting = {
		description = "Mission start: walls removed, keep/siege locked (diff-scaled), age cap (Absurd+)",
		apply = function(player)
			-- [1] Disable Stone/Palisade walls (AI path issues) — capability-gated
			local ebp_stone = TryGetCivilizationEntity(player.raceName, AGS_BP_STONEWALL)
			if ebp_stone then
				Player_SetEntityProductionAvailability(player.id, ebp_stone, ITEM_REMOVED)
			end
			local ebp_palisade = TryGetCivilizationEntity(player.raceName, AGS_BP_PALISADE)
			if ebp_palisade then
				Player_SetEntityProductionAvailability(player.id, ebp_palisade, ITEM_REMOVED)
			end

			-- [2] Starting upgrades (Default)
			Player_CompleteUpgrade(player.id, UPG.COMMON.UPGRADE_SCOUT_FORESTER)

			-- [3] Starting upgrades / Difficulty: Intermediate -
			if DC.player_starting_upgrades_bonus then
				Player_CompleteUpgrade(player.id, UPG.COMMON.UPGRADE_MELEE_DAMAGE_I)
				Player_CompleteUpgrade(player.id, UPG.COMMON.UPGRADE_RANGED_ARMOR_I)
				-- IsCivFamily: applies to parent civ and all DLC variants
				if IsCivFamily(player.id, "english") then
					Player_CompleteUpgrade(player.id, UPG.ENGLISH.UPGRADE_UNIT_MANATARMS_2_ENG)
					Player_CompleteUpgrade(player.id, UPG.ENGLISH.UPGRADE_ARMOR_CLAD_ENG)
				end
				if IsCivFamily(player.id, "hre") then
					Player_CompleteUpgrade(player.id, UPG.HRE.UPGRADE_MAN_AT_ARMS_TWO_HANDED_HRE)
					Player_CompleteUpgrade(player.id, UPG.HRE.UPGRADE_INSPIRED_INFANTRY_HRE)
				end
			end

			-- [4] Disable Ability: Conversion / Difficulty: Hard +
			if DC.disable_conversion then
				Player_SetAbilityAvailability(player.id, BP_GetAbilityBlueprint("monk_conversion"), ITEM_REMOVED)
				if IsCivFamily(player.id, "abbasid") then
					Player_SetAbilityAvailability(player.id, BP_GetAbilityBlueprint("monk_conversion_faith_abb"), ITEM_REMOVED)
				end
			end

			-- [5] Keep Restriction
			if DC.restrict_keep then
				local ebp_keep = TryGetCivilizationEntity(player.raceName, AGS_BP_KEEP)
				if ebp_keep then
					Player_SetEntityProductionAvailability(player.id, ebp_keep, ITEM_REMOVED)
				end
				if IsCivFamily(player.id, "english") then
					Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age2_white_tower_eng"), ITEM_REMOVED)
				end
			end

			-- [5b] Keep landmark restriction
			if DC.restrict_keep_landmarks then
				ApplyLandmarkRestrictions(player.id, LANDMARK_KEEP_RESTRICTIONS, ITEM_REMOVED)
			end

			-- [6] Siege Restriction
			if DC.restrict_siege then
				_ApplySiegeRestrictions(player, ITEM_LOCKED)
			end

			-- [7] Age 4 Restriction
			if DC.restrict_age4 then
				Player_SetMaximumAge(player.id, AGE_CASTLE)
				ApplyLandmarkRestrictions(player.id, LANDMARK_AGE4_RESTRICTIONS, ITEM_REMOVED)
				ApplyHouseOfWisdomRestrictions(player.id, ITEM_REMOVED)
			end

			-- [8] Workshop Restriction
			if DC.restrict_workshop then
				local ebp_workshop = TryGetCivilizationEntity(player.raceName, AGS_BP_WORKSHOP)
				if ebp_workshop then
					Player_SetEntityProductionAvailability(player.id, ebp_workshop, ITEM_LOCKED)
				end
			end

			if DLC_DEBUG then
				print(string.format("[PROFILE] 'starting' applied to player %s (tier=%s)", tostring(player.id), DC.label))
			end
		end
	},
}

---ApplyRestrictionProfile: Unified entry point for restriction management.
-- Idempotent: calling twice with same profile skips re-application.
function ApplyRestrictionProfile(player, profile_name)
	local profile = Restriction_Profile[profile_name]
	if not profile then
		print(string.format("[ERROR] ApplyRestrictionProfile: Unknown profile '%s'", tostring(profile_name)))
		return false
	end
	if PLAYER_PROFILE_APPLIED[player.id] and PLAYER_PROFILE_APPLIED[player.id][profile_name] then
		if DLC_DEBUG then
			print(string.format("[DLC-DBG] ApplyRestrictionProfile: SKIPPED (already applied) player=%s profile=%s", tostring(player.id), profile_name))
		end
		return true
	end
	profile.apply(player)
	if not PLAYER_PROFILE_APPLIED[player.id] then
		PLAYER_PROFILE_APPLIED[player.id] = {}
	end
	PLAYER_PROFILE_APPLIED[player.id][profile_name] = true
	return true
end

---_Validate_RestrictionCoverage: Startup check that DLC civs have overrides for restriction-relevant keys.
function _Validate_RestrictionCoverage()
	local restriction_keys = {AGS_BP_STONEWALL, AGS_BP_PALISADE, AGS_BP_KEEP, AGS_BP_WORKSHOP}
	for dlc_civ, _ in pairs(DLC_CIV_PARENT_MAP) do
		local resolved = ResolveCivKey(dlc_civ)
		if resolved then
			local base_entry = AGS_ENTITY_TABLE[resolved]
			for _, key in ipairs(restriction_keys) do
				local parent_has = base_entry and base_entry[key] ~= nil
				local dlc_has_override = DLC_CIV_OVERRIDES[dlc_civ] and DLC_CIV_OVERRIDES[dlc_civ][key] ~= nil
				if parent_has and not dlc_has_override then
					print(string.format("[DLC-WARN] '%s' inherits '%s' from parent '%s' without override — restriction will target parent blueprint", dlc_civ, key, resolved))
				end
			end
		end
	end
end

