	UnitEntry_DeploySquads(player5, sg_city_walls_3a, Unit_Types.units_ranged, mkr_patrol_mid_8) -- #3
	Cmd_FormationMove(sg_city_walls_3a, mkr_defender_a_3, false, false, mkr_patrol_mid_2)
	UnitEntry_DeploySquads(player5, sg_city_walls_4a, Unit_Types.units_ranged, mkr_patrol_mid_8) -- #4
	Cmd_FormationMove(sg_city_walls_4a, mkr_defender_a_4, false, false, mkr_patrol_mid_2)
	-- Side 2
	UnitEntry_DeploySquads(player5, sg_city_walls_1b, Unit_Types.units_ranged_final, mkr_patrol_mid_8) -- #1
	Cmd_FormationMove(sg_city_walls_1b, mkr_defender_b_1, false, false, mkr_defender_b_4)
	UnitEntry_DeploySquads(player5, sg_city_walls_2b, Unit_Types.units_ranged, mkr_patrol_mid_8) -- #2
	Cmd_FormationMove(sg_city_walls_2b, mkr_defender_b_2, false, false, mkr_defender_b_4)
	UnitEntry_DeploySquads(player5, sg_city_walls_3b, Unit_Types.units_ranged, mkr_patrol_mid_8) -- #3
	Cmd_FormationMove(sg_city_walls_3b, mkr_defender_b_3, false, false, mkr_defender_b_4)
	UnitEntry_DeploySquads(player5, sg_city_walls_4b, Unit_Types.units_cityguards_final, mkr_patrol_mid_8) -- #4
	Cmd_FormationMove(sg_city_walls_4b, mkr_defender_b_4, false, false, mkr_patrol_mid_6)
	
end

function Hard_Waves()
	
	-- Siege waves
	if DC.hard_waves_siege then
		Rule_AddInterval(Units_Deploy, 480, { player = player5, sgroup = sg_waves_main_3_05, unit_type = Unit_Types.wave_siege, spawn_loc = mkr_wave1_1a, path = wave_1a })
		Rule_AddInterval(Units_Deploy, 480, { player = player5, sgroup = sg_waves_main_3_06, unit_type = Unit_Types.wave_siege, spawn_loc = mkr_wave2_1, path = wave_2a })
	end
	-- Extra Infantry waves
	if DC.hard_waves_infantry then
		-- Side 1
		Rule_AddInterval(Units_Deploy, 240, { player = player5, sgroup = sg_waves_main_1_11, unit_type = Unit_Types.wave_no_siege, spawn_loc = mkr_wave1_1a, path = wave_1a })
		-- Side 2
		Rule_AddInterval(Units_Deploy, 240, { player = player5, sgroup = sg_waves_main_2_11, unit_type = Unit_Types.wave_no_siege, spawn_loc = mkr_wave2_1, path = wave_2a })
	end
end

-------------------------------------------
-- Phase 3  
-------------------------------------------

function BreachWalls_Reinforcements()
	
	-- Final Keep gate defenders
	UnitEntry_DeploySquads(player5, sg_city_gates_1, Unit_Types.units_cityguards_final, mkr_city_gate_in1) -- #1
	Cmd_FormationMove(sg_city_gates_1, mkr_city_gate_1, false, false, mkr_wave2_2a)
	UnitEntry_DeploySquads(player5, sg_city_gates_2, Unit_Types.units_cityguards_final, mkr_city_gate_in1) -- #2
	Cmd_FormationMove(sg_city_gates_2, mkr_city_gate_2, false, false, mkr_wave1_4a)
	UnitEntry_DeploySquads(player5, sg_city_gates_3, Unit_Types.units_cityguards_final, mkr_city_gate_in1) -- #3
	Cmd_FormationMove(sg_city_gates_3, mkr_city_gate_3, false, false, mkr_wave1_2)
	UnitEntry_DeploySquads(player5, sg_city_gates_4, Unit_Types.units_cityguards_final, mkr_city_gate_in2) -- #4
	Cmd_FormationMove(sg_city_gates_4, mkr_wave2_2a, false, false, mkr_city_gate_1)
	UnitEntry_DeploySquads(player5, sg_city_gates_5, Unit_Types.units_cityguards_final, mkr_city_gate_in2) -- #5
	Cmd_FormationMove(sg_city_gates_5, mkr_wave2_2b, false, false, mkr_wave2_3b)
	
	-- Spawn Patrol / Inner City
	UnitEntry_DeploySquads(player5, sg_city_patrol_1, Unit_Types.units_cityguards_hard, mkr_wave1_1a) -- #1
	Rule_AddInterval(Patrol_Cycle, 80, { sgroup = sg_city_patrol_1, path = patrol_city_1 })
	UnitEntry_DeploySquads(player5, sg_city_patrol_2, Unit_Types.units_cityguards_hard, mkr_wave2_1) -- #1
	Rule_AddInterval(Patrol_Cycle, 80, { sgroup = sg_city_patrol_2, path = patrol_city_2 })
	
	-- Spawn additional counter-attacks
	if DC.breach_reinforcements then
		-- Knight Rush
		Rule_AddOneShot(Units_Deploy, 5, { player = player5, sgroup = sg_waves_main_3_01, unit_type = Unit_Types.wave_city_45m, spawn_loc = mkr_wave1_1a, path = wave_1a })
		Rule_AddOneShot(Units_Deploy, 5, { player = player5, sgroup = sg_waves_main_3_02, unit_type = Unit_Types.wave_city_45m, spawn_loc = mkr_wave2_1, path = wave_2a })
		-- Last effort AI push
		Rule_AddOneShot(Units_Deploy, 60, { player = player5, sgroup = sg_waves_main_3_03, unit_type = Unit_Types.wave_city_40m, spawn_loc = mkr_city_gate_in1, path = wave_3a })
		Rule_AddOneShot(Units_Deploy, 60, { player = player5, sgroup = sg_waves_main_3_04, unit_type = Unit_Types.wave_city_40m, spawn_loc = mkr_city_gate_in2, path = wave_3b })
	end
	
	
end



