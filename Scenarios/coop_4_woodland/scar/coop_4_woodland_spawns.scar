-- Begin building up main counter offensive
function Main_Waves()
	-- SIDE #1
	
	-- 05 min
	Rule_AddInterval(Units_Deploy, 300, { player = player5, sgroup = sg_waves_main_1_01a, unit_type = Unit_Types.wave_city_5m, spawn_loc = mkr_wave1_1a, path = wave_1a })
	if DC.waves_5min_flank then
	Rule_AddInterval(Units_Deploy, 300, { player = player5, sgroup = sg_waves_main_1_01b, unit_type = Unit_Types.wave_city_5m, spawn_loc = mkr_wave1_1b, path = wave_1b })
	end
	-- 10 min
	Rule_AddInterval(Units_Deploy, 610, { player = player5, sgroup = sg_waves_main_1_01c, unit_type = Unit_Types.wave_city_10m, spawn_loc = mkr_wave1_1a, path = wave_1a })
	Rule_AddInterval(Units_Deploy, 600, { player = player5, sgroup = sg_waves_main_1_01d, unit_type = Unit_Types.wave_city_10m_flank, spawn_loc = mkr_wave1_1b, path = wave_1b })
	-- ~15 min
	Rule_AddInterval(Units_Deploy, 930, { player = player5, sgroup = sg_waves_main_1_02, unit_type = Unit_Types.wave_city_15m, spawn_loc = mkr_wave1_1a, path = wave_1a })
	-- ~20 min
	Rule_AddInterval(Units_Deploy, 1100, { player = player5, sgroup = sg_waves_main_1_03, unit_type = Unit_Types.wave_city_20m, spawn_loc = mkr_wave1_1b, path = wave_1b })
	if DC.waves_late_25_30 then
		-- 25 min
		Rule_AddInterval(Units_Deploy, 1500, { player = player5, sgroup = sg_waves_main_1_04, unit_type = Unit_Types.wave_city_25m, spawn_loc = mkr_wave1_1a, path = wave_1a })
		-- 30 min
		Rule_AddInterval(Units_Deploy, 1800, { player = player5, sgroup = sg_waves_main_1_05, unit_type = Unit_Types.wave_city_30m, spawn_loc = mkr_wave1_1a, path = wave_1a })
	end
	if DC.waves_hard_40_45 then 
	-- 40 min
	Rule_AddInterval(Units_Deploy, 2400, { player = player5, sgroup = sg_waves_main_1_06, unit_type = Unit_Types.wave_city_40m, spawn_loc = mkr_wave1_1a, path = wave_1a })
	-- 45 min
	Rule_AddInterval(Units_Deploy, 2700, { player = player5, sgroup = sg_waves_main_1_07, unit_type = Unit_Types.wave_city_45m, spawn_loc = mkr_wave1_1b, path = wave_1b })
	end
	if DC.waves_hardest_extra then
		-- ~20 min
		Rule_AddInterval(Units_Deploy, 1200, { player = player5, sgroup = sg_waves_main_1_08, unit_type = Unit_Types.wave_city_20m, spawn_loc = mkr_wave1_1b, path = wave_1b })
		-- 35 min
		Rule_AddInterval(Units_Deploy, 2100, { player = player5, sgroup = sg_waves_main_1_09, unit_type = Unit_Types.wave_city_45m, spawn_loc = mkr_wave1_1b, path = wave_1b })
		-- ~45 min
		Rule_AddInterval(Units_Deploy, 2900, { player = player5, sgroup = sg_waves_main_1_10, unit_type = Unit_Types.wave_city_45m, spawn_loc = mkr_wave1_1a, path = wave_1a })
	end
	
	
	-- SIDE #2 
	
	-- 05 min
	Rule_AddInterval(Units_Deploy, 300, { player = player5, sgroup = sg_waves_main_2_01a, unit_type = Unit_Types.wave_city_10m, spawn_loc = mkr_wave2_1, path = wave_2a })
	if DC.waves_5min_flank then
	Rule_AddInterval(Units_Deploy, 310, { player = player5, sgroup = sg_waves_main_2_01b, unit_type = Unit_Types.wave_city_10m, spawn_loc = mkr_wave2_1, path = wave_2b })
	end
	-- 10 min
	Rule_AddInterval(Units_Deploy, 610, { player = player5, sgroup = sg_waves_main_2_01c, unit_type = Unit_Types.wave_city_10m, spawn_loc = mkr_wave2_1, path = wave_2a })
	Rule_AddInterval(Units_Deploy, 600, { player = player5, sgroup = sg_waves_main_2_01d, unit_type = Unit_Types.wave_city_10m_flank, spawn_loc = mkr_wave2_1, path = wave_2b })
	-- ~15 min
	Rule_AddInterval(Units_Deploy, 930, { player = player5, sgroup = sg_waves_main_2_02, unit_type = Unit_Types.wave_city_15m, spawn_loc = mkr_wave2_1, path = wave_2a })
	-- ~20 min
	Rule_AddInterval(Units_Deploy, 1100, { player = player5, sgroup = sg_waves_main_2_03, unit_type = Unit_Types.wave_city_20m, spawn_loc = mkr_wave2_1, path = wave_2b })
	if DC.waves_late_25_30 then
		-- 25 min
		Rule_AddInterval(Units_Deploy, 1500, { player = player5, sgroup = sg_waves_main_2_04, unit_type = Unit_Types.wave_city_25m, spawn_loc = mkr_wave2_1, path = wave_2a })
		-- 30 min
		Rule_AddInterval(Units_Deploy, 1800, { player = player5, sgroup = sg_waves_main_2_05, unit_type = Unit_Types.wave_city_30m, spawn_loc = mkr_wave2_1, path = wave_2a })
	end
	if DC.waves_hard_40_45 then
	-- 40 min
	Rule_AddInterval(Units_Deploy, 2400, { player = player5, sgroup = sg_waves_main_2_06, unit_type = Unit_Types.wave_city_40m, spawn_loc = mkr_wave2_1, path = wave_2a })
	-- 45 min
	Rule_AddInterval(Units_Deploy, 2700, { player = player5, sgroup = sg_waves_main_2_07, unit_type = Unit_Types.wave_city_45m, spawn_loc = mkr_wave2_1, path = wave_2b })
	end
	if DC.waves_hardest_extra then
		-- ~20 min
		Rule_AddInterval(Units_Deploy, 1200, { player = player5, sgroup = sg_waves_main_2_08, unit_type = Unit_Types.wave_city_20m, spawn_loc = mkr_wave2_1, path = wave_2b })
		-- 35 min
		Rule_AddInterval(Units_Deploy, 2100, { player = player5, sgroup = sg_waves_main_2_09, unit_type = Unit_Types.wave_city_45m, spawn_loc = mkr_wave2_1, path = wave_2b })
		-- ~45 min
		Rule_AddInterval(Units_Deploy, 2900, { player = player5, sgroup = sg_waves_main_2_10, unit_type = Unit_Types.wave_city_45m, spawn_loc = mkr_wave2_1, path = wave_2a })
	end
	
	-- Hardest AI waves
	Rule_AddOneShot(Hard_Waves, 1800)
	
	
end

