-------------------------------------------
-- Main: Seize City / Timer (DISABLED) 
-------------------------------------------
function SeizeCity_InitObjectives()
	OBJ_SeizeCity = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:47", -- Seize the HRE City
		Type = ObjectiveType_Information, 
		OnStart = SeizeCity_Start, --when objective start call function
		SetupUI = SeizeCity_UI, -- seting up how objective is presented
		
	}
	
	Objective_Register(OBJ_SeizeCity)
end

function SeizeCity_UI()
	
	Objective_StartTimer(OBJ_SeizeCity, COUNT_DOWN, DC.seize_city_timer, 10)
	
end

function SeizeCity_Start()
	
	Rule_AddOneShot(SeizeCity_End, DC.seize_city_timer)
	
end
-- Set player team defeated
function SeizeCity_End() 
	
	if EGroup_Count(eg_keep_targets) >= 1 then
		Objective_Fail(OBJ_SeizeCity, true, false)
		-- Eliminate players
		Core_SetPlayerDefeated(player1, Elimination_LoserPresentation, WR_ELIMINATION)
		Core_SetPlayerDefeated(player2, Elimination_LoserPresentation, WR_ELIMINATION)
		Core_SetPlayerDefeated(player3, Elimination_LoserPresentation, WR_ELIMINATION)
		Core_SetPlayerDefeated(player4, Elimination_LoserPresentation, WR_ELIMINATION)
		Elimination_CheckVictory()
	end
	
end 

-------------------------------------------
-- Objective #1: Capture Gold Mine 
-------------------------------------------

function CaptureGold_InitObjectives()
	
	OBJ_CaptureGold_Main = {
		Title =  "$ae948c95a8c5425d8de28e0c193e0be9:51",  -- "Secure the Gold Camps to receive villagers"
		Type = ObjectiveType_Battle, 
		SetupUI = CaptureGold_UI, -- seting up how objective is presented
		OnStart = CaptureGold_Start, --when objective start call function
		OnComplete = CaptureGold_OnComplete, -- when objective completes, call function
	}
	OBJ_CaptureGold_side1 = {
		Title =  "$ae948c95a8c5425d8de28e0c193e0be9:49",  -- "Defeat the resistance near the Western Camp"
		Type = ObjectiveType_Battle, 
		SetupUI = CaptureGold_UI, -- seting up how objective is presented
		Parent = OBJ_CaptureGold_Main,
		--OnComplete = CaptureGold_side_OnComplete, -- when objective completes, call function
	}
	OBJ_CaptureGold_side2 = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:50",  -- "Defeat the resistance near the Eastern Camp"
		Type = ObjectiveType_Battle, 
		SetupUI = CaptureGold_UI, -- seting up how objective is presented
		Parent = OBJ_CaptureGold_Main,
		--OnComplete = CaptureGold_side_OnComplete, -- when objective completes, call function
	}
	
	Objective_Register(OBJ_CaptureGold_Main)
	Objective_Register(OBJ_CaptureGold_side1)
	Objective_Register(OBJ_CaptureGold_side2)
	
end

function CaptureGold_UI()
	
	-- Main
	Objective_SetCounter(OBJ_CaptureGold_Main, 0, 2) --Set the counter in the UI
	-- Side 1 
	Objective_SetCounter(OBJ_CaptureGold_side1, 0, 1) 
	Objective_AddUIElements(OBJ_CaptureGold_side1, mkr_spawn_gold_1, true, "$11105784", true)
	-- Side 2
	Objective_AddUIElements(OBJ_CaptureGold_side2, mkr_spawn_gold_2, true, "$11105784", true)
	Objective_SetCounter(OBJ_CaptureGold_side2, 0, 1) 
	
end

function CaptureGold_Start()

	Rule_Add(CaptureGold_count_side1)
	Rule_Add(CaptureGold_count_side2)
	
	-- Add hints 
	HintPoint_Add(mkr_side1_hint, true, "$11176017", LOCATION_LABEL_HEIGHT) -- "Your army must survive!"
	HintPoint_Add(mkr_side2_hint, true, "$11176017", LOCATION_LABEL_HEIGHT) -- "Your army must survive!"
	
end

function CaptureGold_count_side1()
	
	if Objective_IsComplete(OBJ_CaptureGold_Main) == false then
		if SGroup_Count(sg_gold_guards_1) == 0 then
			if Objective_IsComplete(OBJ_CaptureGold_side1) == false then
				Objective_Complete(OBJ_CaptureGold_side1, true, true) 
			end
			-- Main Objective +1
			if Objective_IsCounterSet(OBJ_CaptureGold_Main) then
				Objective_IncreaseCounter(OBJ_CaptureGold_Main)

				if Obj_GetCounterCount(OBJ_CaptureGold_Main.ID) == Obj_GetCounterMax(OBJ_CaptureGold_Main.ID) then 
					Objective_Complete(OBJ_CaptureGold_Main, true, true) 
					
				end
			end
			Rule_RemoveMe()
		end
		
	else
		Rule_RemoveMe()
	end	
end

function CaptureGold_count_side2()
	
	if Objective_IsComplete(OBJ_CaptureGold_Main) == false then
		if SGroup_Count(sg_gold_guards_2) == 0 then
			if Objective_IsComplete(OBJ_CaptureGold_side2) == false then
				Objective_Complete(OBJ_CaptureGold_side2, true, true) 
			end
			-- Main Objective +1
			if Objective_IsCounterSet(OBJ_CaptureGold_Main) then
				
				Objective_IncreaseCounter(OBJ_CaptureGold_Main)

				if Obj_GetCounterCount(OBJ_CaptureGold_Main.ID) == Obj_GetCounterMax(OBJ_CaptureGold_Main.ID) then 
					Objective_Complete(OBJ_CaptureGold_Main, true, true) 
					
				end
			end
			Rule_RemoveMe()
		end
		
	else
		Rule_RemoveMe()
	end
	
end

function CaptureGold_OnComplete()
	
	-- Set interactive zone / Unlock all
	World_SetInteractionStage(1)
	
	-- Enable Bridge Objectives
	Objective_Start(OBJ_CaptureBridges_Main,true, false)
	Objective_Start(OBJ_CaptureBridges_side1, false, false)
	Objective_Start(OBJ_CaptureBridges_side2, false, false)
	-- Notification timer for counter attacks
	Objective_Start(OBJ_PrepareDefences,true, false)
	
	-- Setup spawners
	Setup_Spawns()
	Main_Waves()
	
	-- Difficulty: Grant player resources
	for _, pid in pairs({player1, player2, player3, player4}) do
		Player_AddResource(pid, RT_Food, DC.starting_food)
		Player_AddResource(pid, RT_Gold, DC.starting_gold)
		Player_AddResource(pid, RT_Wood, DC.starting_wood)
	end
	
	-- Enable population UI (keep condensed objectives disabled)
	UI_SetPlayerDataContext(player1, { PopulationCapOn = true, hide_condensed_objectives_override = true })
	UI_SetPlayerDataContext(player2, { PopulationCapOn = true, hide_condensed_objectives_override = true })
	UI_SetPlayerDataContext(player3, { PopulationCapOn = true, hide_condensed_objectives_override = true })
	UI_SetPlayerDataContext(player4, { PopulationCapOn = true, hide_condensed_objectives_override = true })
	
	-- Difficulty: Select AI upgrades
	Difficulty_Phase1_Upgrades()
	
	-- TC player
	EGroup_SetPlayerOwner(eg_player1_tc, player1)
	EGroup_SetPlayerOwner(eg_player2_tc, player2)
	EGroup_SetPlayerOwner(eg_player3_tc, player3)
	EGroup_SetPlayerOwner(eg_player4_tc, player4)
	-- Set targeting / TC group
	EGroup_SetTargetingType(eg_player_tc, Targeting_Automatic)
	EGroup_SetSelectable(eg_player_tc, true)
	EGroup_SetInvulnerable(eg_player_tc, false)
	for _, player in pairs(PLAYERS) do
		local player_civ = Player_GetRaceName(player.id)
		Player_SetEntityProductionAvailability(player.id, AGS_GetCivilizationEntity(player_civ, AGS_BP_CAPITAL), ITEM_DEFAULT)
		_RemoveTC_VisionSuppression(player.id)
	end
	
	-- Disable warning hint / Crossing 
	HintPoint_RemoveAll()

end	

-------------------------------------------
-- Objective #2: Capture Bridges 
-------------------------------------------

function CaptureBridges_InitObjectives()
	
	OBJ_CaptureBridges_Main = {
		Title =  "$ae948c95a8c5425d8de28e0c193e0be9:45",  -- "Capture the bridges"
		Type = ObjectiveType_Battle, 
		SetupUI = CaptureBridges_UI, -- seting up how objective is presented
		OnStart = CaptureBridges_Start, --when objective start call function
		OnComplete = CaptureBridges_OnComplete, -- when objective completes, call function
	}
	OBJ_CaptureBridges_side1 = {
		Title =  "$ae948c95a8c5425d8de28e0c193e0be9:46",  -- "Defeat the resistance near the Western Bridge"
		Type = ObjectiveType_Battle, 
		SetupUI = CaptureBridges_UI, -- seting up how objective is presented
		Parent = OBJ_CaptureBridges_Main,
		--OnComplete = CaptureBridges_side_OnComplete, -- when objective completes, call function
	}
	OBJ_CaptureBridges_side2 = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:48",  -- "Defeat the resistance near the Eastern Bridge"
		Type = ObjectiveType_Battle, 
		SetupUI = CaptureBridges_UI, -- seting up how objective is presented
		Parent = OBJ_CaptureBridges_Main,
		--OnComplete = CaptureBridges_side_OnComplete, -- when objective completes, call function
	}
	
	Objective_Register(OBJ_CaptureBridges_Main)
	Objective_Register(OBJ_CaptureBridges_side1)
	Objective_Register(OBJ_CaptureBridges_side2)
	
end

function CaptureBridges_UI()
	
	-- Main
	Objective_SetCounter(OBJ_CaptureBridges_Main, 0, 2) --Set the counter in the UI
	-- Side 1 
	Objective_SetCounter(OBJ_CaptureBridges_side1, 0, 1) 
	-- Side 2
	Objective_SetCounter(OBJ_CaptureBridges_side2, 0, 1) 
	
end

function CaptureBridges_Start()

	Rule_Add(CaptureBridges_count_side1)
	Rule_Add(CaptureBridges_count_side2)
	
end

function CaptureBridges_count_side1()
	
	if Objective_IsComplete(OBJ_CaptureBridges_Main) == false then
		if SGroup_Count(sg_checkpoint_group_1) == 0 then
			if Objective_IsComplete(OBJ_CaptureBridges_side1) == false then
				Objective_Complete(OBJ_CaptureBridges_side1, true, true) 
			end
			-- Main Objective +1
			if Objective_IsCounterSet(OBJ_CaptureBridges_Main) then
				Objective_IncreaseCounter(OBJ_CaptureBridges_Main)

				if Obj_GetCounterCount(OBJ_CaptureBridges_Main.ID) == Obj_GetCounterMax(OBJ_CaptureBridges_Main.ID) then 
					Objective_Complete(OBJ_CaptureBridges_Main, true, true) 
					
				end
			end
			Rule_RemoveMe()
		end
		
	else
		Rule_RemoveMe()
	end
	
end

function CaptureBridges_count_side2()
	
	if Objective_IsComplete(OBJ_CaptureBridges_Main) == false then
		if SGroup_Count(sg_checkpoint_group_2) == 0 then
			if Objective_IsComplete(OBJ_CaptureBridges_side2) == false then
				Objective_Complete(OBJ_CaptureBridges_side2, true, true) 
			end
			-- Main Objective +1
			if Objective_IsCounterSet(OBJ_CaptureBridges_Main) then
				
				Objective_IncreaseCounter(OBJ_CaptureBridges_Main)

				if Obj_GetCounterCount(OBJ_CaptureBridges_Main.ID) == Obj_GetCounterMax(OBJ_CaptureBridges_Main.ID) then 
					Objective_Complete(OBJ_CaptureBridges_Main, true, true) 
					
				end
			end
			Rule_RemoveMe()
		end
		
	else
		Rule_RemoveMe()
	end
	
end

function CaptureBridges_OnComplete()

	Objective_Start(OBJ_BreachWalls,true, false)
	
	-- Difficulty: Select AI upgrades
	Difficulty_Phase2_Upgrades()
	
	-- Spawn AI Reinforcements @ Bridge
	if DC.breach_reinforcements then
		UnitEntry_DeploySquads(player5, sg_bridge_reinforcement_1, Unit_Types.units_reinforcement_bridge, mkr_wave1_1b)
		Cmd_FormationAttackMove(sg_bridge_reinforcement_1, mkr_side1_position2)
		UnitEntry_DeploySquads(player5, sg_bridge_reinforcement_2, Unit_Types.units_reinforcement_bridge, mkr_wave2_1)
		Cmd_FormationAttackMove(sg_bridge_reinforcement_2, mkr_side2_position2)
	end
	
	Rule_EnterProximity(BreachWalls_OnProximity, ANY, sg_player_team, mkr_city_prox_1, 40, false, {})
	Rule_EnterProximity(BreachWalls_OnProximity, ANY, sg_player_team, mkr_city_prox_2, 40, false, {})
	
	-- Add upgrade 'Siege Engineers' for all players
	for _, player in pairs(PLAYERS) do
		if not IsCivFamily(player.id, "sultanate") then
			Player_CompleteUpgrade(player.id, BP_GetUpgradeBlueprint "upgrade_siege_engineers")
		else
			Player_CompleteUpgrade(player.id, BP_GetUpgradeBlueprint "upgrade_siege_engineers_sul")
		end
		if IsCivFamily(player.id, "mongol") then
			Player_CompleteUpgrade(player.id, BP_GetUpgradeBlueprint "upgrade_improved_siege_engineers_mon")
		end
		if IsCivExact(player.id, "abbasid") then
			if DC.abbasid_easy_mangonel then
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_mangonel_3_buildable_abb"), ITEM_UNLOCKED)
			end
			Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_springald_3_buildable_abb"), ITEM_UNLOCKED)
		end
	end
	
	-- Notification
	local event_cue_siege = Loc_FormatText("$ae948c95a8c5425d8de28e0c193e0be9:52")  -- "Siege Engineers unlocked for infantry!"
	UI_CreateEventCueClickable(-1, 15, -1, 0, event_cue_siege, "", "low_priority", "", "sfx_ui_event_queue_campaign_high_priority", 255, 255, 255, 255, ECV_Queue, nothing)

end

-------------------------------------------
-- Warning: Prepare for counter attacks
-------------------------------------------

function PrepareDefences_InitObjectives()
	
	OBJ_PrepareDefences = {
		Title = "$11226358" ,  -- "Prepare for the enemey waves"
		Type = ObjectiveType_Information, 
		SetupUI = PrepareDefences_UI, -- seting up how objective is presented
		OnStart = PrepareDefences_Start, --when objective start call function
	}

	
	Objective_Register(OBJ_PrepareDefences)

	
end

function PrepareDefences_UI()
	
	Objective_StartTimer(OBJ_PrepareDefences, COUNT_DOWN, DC.prepare_defences_timer, 10)
	
end

function PrepareDefences_Start()
	
	Rule_AddOneShot(PrepareDefences_End, DC.prepare_defences_timer + 30)
	
end

function PrepareDefences_End()
	
	Objective_Complete(OBJ_PrepareDefences, true, false)

	
end

-------------------------------------------
-- Objective #3: Breach City Walls 
-------------------------------------------

function BreachWalls_EnemiesTownInit()
	
	OBJ_BreachWalls = {
		
		Title = "$11172042" ,  -- "Breach the city gates"
		Type = ObjectiveType_Battle, 
		--OnStart = BreachWalls_Start, --when objective start call function
		OnComplete = BreachWalls_OnComplete, -- when objective completes, call function
		Parent = OBJ_SeizeCity,
	}
	
	
	Objective_Register(OBJ_BreachWalls)
	
end

-- Set completed when moving past objective
function BreachWalls_OnProximity()
	
	Objective_Complete(OBJ_BreachWalls, true, false) 

	
end

function BreachWalls_OnComplete()
	
	if DC.breach_reinforcements then
		BreachWalls_Reinforcements()
	end
	
	Objective_Start(OBJ_DestroyKeep,true, false)
	
	Rule_Remove(SGroup_Tracker)
	
end

-------------------------------------------
--Main: Destroy Keep / Final objective
-------------------------------------------
function DestroyKeep_InitObjectives()
	
	OBJ_DestroyKeep = {
		
		Title = "$11172043" ,  -- "Destroy the keep"
		Type = ObjectiveType_Battle, 
		SetupUI = DestroyKeep_UI, -- seting up how objective is presented
		OnStart = DestroyKeep_Start, --when objective start call function
		OnComplete = DestroyKeep_OnComplete, -- when objective completes, call function
--		Parent = OBJ_SeizeCity,
	}
	
	
	
	Objective_Register(OBJ_DestroyKeep)
	
end

function DestroyKeep_UI()
	
	--count the number of buildings and put into a variable (set in main scar file)
	i_destroyedKeep = EGroup_CountSpawned(eg_keep_targets)
	
	--Set the counter in the UI
	Objective_SetCounter(OBJ_DestroyKeep, 0, i_destroyedKeep)	
	
	-- Set UI Locations
	keep1_id = Objective_AddUIElements(OBJ_DestroyKeep, eg_keep_target1, true, "$11119598", true)
	keep2_id = Objective_AddUIElements(OBJ_DestroyKeep, eg_keep_target2, true, "$11119598", true)
	
end

function DestroyKeep_Start()
	
	--start a rule that will check when an entity is destroyed
	Rule_AddEGroupEvent(DestroyKeep_OnEntityKilled, eg_keep_targets, GE_EntityKilled)
	Rule_Add(DestroyKeep_MarkerUI)
	
end

function DestroyKeep_OnEntityKilled(context)
	
	if context.victimOwner == player5 then
	
		-- Set counter / Main
		if Objective_IsComplete(OBJ_DestroyKeep) == false then
			if Objective_IsCounterSet(OBJ_DestroyKeep) then
				Objective_IncreaseCounter(OBJ_DestroyKeep)

				if Obj_GetCounterCount(OBJ_DestroyKeep.ID) == Obj_GetCounterMax(OBJ_DestroyKeep.ID) then 
					Objective_Complete(OBJ_DestroyKeep, true, false) 
					Rule_RemoveMe()
				end
			end
		else
			Rule_RemoveMe()
		end
		
	end	
	
end

function DestroyKeep_MarkerUI()
	
	-- Remove UI per keep
		if EGroup_Count(eg_keep_target1) == 0 then
			Objective_RemoveUIElements(OBJ_DestroyKeep, keep1_id)
		elseif EGroup_Count(eg_keep_target2) == 0 then
			Objective_RemoveUIElements(OBJ_DestroyKeep, keep2_id)
		end

	end

-- Set player team victorious 
function DestroyKeep_OnComplete()
	
	-- Finish scenario
	Rule_AddOneShot(Victory_Function, 1)
	
	--[[ Mission_Complete() 
	--World_KillPlayer(player5, KPR_Lost)
	Core_SetPlayerDefeated(player5, Elimination_LoserPresentation, WR_ELIMINATION)
	Core_SetPlayerVictorious(player1, Elimination_WinnerPresentation, WR_ELIMINATION)	
	Core_SetPlayerVictorious(player2, Elimination_WinnerPresentation, WR_ELIMINATION)	
	Core_SetPlayerVictorious(player3, Elimination_WinnerPresentation, WR_ELIMINATION)	
	Core_SetPlayerVictorious(player4, Elimination_WinnerPresentation, WR_ELIMINATION)	
	Elimination_CheckVictory()
	]]
	
end






