-- Unlocks Chinese Dynasty UI
function DynastyUI_unlocked()
	
	for i, player in pairs(PLAYERS) do 

		if Player_GetRaceName(player.id) == "chinese" then 
			-- Dynasties unlocked
			Player_CompleteUpgrade(player.id, BP_GetUpgradeBlueprint "player_dynasty1_chi")
			Player_SetStateModelBool(player.id, "dynasty_1_was_completed_chi",true) 
			Player_CompleteUpgrade(player.id, BP_GetUpgradeBlueprint "player_dynasty2_chi")
			Player_SetStateModelBool(player.id, "dynasty_2_was_completed_chi",true) 

			-- Update UI
			Player_SetStateModelFloat(player.id, "current_dynasty_chi",1)
			if Game_GetLocalPlayer() == player.id then 
				DynastyUI_Update()
			end

			Player_SetStateModelFloat(player.id, "current_dynasty_chi",2)
			if Game_GetLocalPlayer() == player.id then 
				DynastyUI_Update()
			end
		end
	end
	
end

-- Group all Player units for Proximity Marker
function SGroup_Tracker(context, data)
	
	local player = data.player 
	
	Player_GetAll(player)
	SGroup_Filter(sg_allsquads, "military", FILTER_KEEP)
	SGroup_AddGroup(sg_player_team, sg_allsquads)
	
	
end 

-- Patrol_Cycle & Units_Deploy / Thanks to Foxplot
function Patrol_Cycle(context, data) -- Used to cycle units between waypoints
	
	local sgroup = data.sgroup 
	local path = data.path 
	
	Cmd_FormationAttackMove(sgroup, path[1])
	for index, mkr in pairs(path) do
		if index > 1 then
			Cmd_FormationAttackMove(sgroup, mkr, true)
		end
	end	
	
end

-- 'Deploy_Unit' & 'Gaurdian_Raid' combined
-- Helper: Resolve bombard SBP for a specific player's civ
function GetBombardSBP(player)
	local civ = string.lower(Player_GetRaceName(player))
	local resolved = ResolveCivKey(civ) or civ
	local bombard_attrib = CBA_SIEGE_TABLE[resolved] and CBA_SIEGE_TABLE[resolved].bombard
	if bombard_attrib then
		return BP_GetSquadBlueprint(bombard_attrib)
	end
	return nil
end

-- Helper: Convert scar_bombard type strings to actual SBPs for a player
function ConvertBombardTypes(player, unit_type_table)
	local converted = {}
	for i, entry in ipairs(unit_type_table) do
		local new_entry = {}
		for k, v in pairs(entry) do
			new_entry[k] = v
		end
		
		if new_entry.type == "scar_bombard" then
			local sbp = GetBombardSBP(player)
			if sbp then
				new_entry.sbp = sbp
				new_entry.type = nil  -- Remove type key
			else
				print("[WARN] Could not resolve bombard SBP for " .. Player_GetRaceName(player))
			end
		end
		
		converted[i] = new_entry
	end
	return converted
end

function Units_Deploy(context, data) -- Used to spawn units / attack groups

	local player = data.player
	local sgroup = data.sgroup
	local unit_type = data.unit_type
	local spawn_loc = data.spawn_loc
	local path = data.path 

	-- Convert any scar_bombard entries to actual SBPs
	local resolved_units = ConvertBombardTypes(player, unit_type)

	UnitEntry_DeploySquads(player, sgroup, resolved_units, spawn_loc)
	Cmd_FormationAttackMove(sgroup, path[1])
	for index, mkr in pairs(path) do
		if index > 1 then
			Cmd_FormationAttackMove(sgroup, mkr, true)
		end
	end

end

-- From Advanced Game Settings by Woprock (DLC-safe: resolves through DLC_CIV_PARENT_MAP)
function AGS_GetCivilizationEntity(player_civ, bp_type)
	local resolved = ResolveCivKey(player_civ)
	if resolved == nil then
		error("[AGS] Unknown civ '" .. tostring(player_civ) .. "' in AGS_GetCivilizationEntity")
	end
	local bp = AGS_ENTITY_TABLE[resolved][bp_type]
	if bp == nil or bp == false then return nil end
	return BP_GetEntityBlueprint(bp)
end 

-- Duplicate for siege units
function AGS_GetSiegeEntity(player_civ, bp_type)
	local resolved = ResolveCivKey(player_civ)
	if resolved == nil then
		error("[AGS] Unknown civ '" .. tostring(player_civ) .. "' in AGS_GetSiegeEntity")
	end
	return BP_GetEntityBlueprint(CBA_SIEGE_TABLE[resolved][bp_type])
end

function AGS_GetSiegeSquad(player_civ, bp_type)
	local resolved = ResolveCivKey(player_civ)
	if resolved == nil then
		error("[AGS] Unknown civ '" .. tostring(player_civ) .. "' in AGS_GetSiegeSquad")
	end
	return BP_GetSquadBlueprint(CBA_SIEGE_TABLE[resolved][bp_type])
end

-- End scenario
g_gameOver = false

function Defeat_Function()
	if g_gameOver then return end
	g_gameOver = true
	Tribute_Cleanup()
	for _, player in ipairs(PLAYERS) do
		_RemoveTC_VisionSuppression(player.id)
	end
	Rule_RemoveGlobalEvent(Reset_AI_OnMigrated)
	Rule_RemoveGlobalEvent(Reset_AI_OnTakeOver)
	if Rule_Exists(Reset_AI) then Rule_Remove(Reset_AI) end

	Core_SetTeamDefeated(TEAMS[1], Annihilation_LoserPresentation, WR_ANNIHILATION)
	
end

function Victory_Function()
	if g_gameOver then return end
	g_gameOver = true
	Tribute_Cleanup()
	for _, player in ipairs(PLAYERS) do
		_RemoveTC_VisionSuppression(player.id)
	end
	Rule_RemoveGlobalEvent(Reset_AI_OnMigrated)
	Rule_RemoveGlobalEvent(Reset_AI_OnTakeOver)
	if Rule_Exists(Reset_AI) then Rule_Remove(Reset_AI) end

	Core_SetTeamDefeated(TEAMS[2], Annihilation_LoserPresentation, WR_ANNIHILATION)
	
end