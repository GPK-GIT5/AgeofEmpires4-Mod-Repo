	overrides = {stone_wall = "building_defense_wall_jpn_ha_sen", palisade_wall = "building_defense_palisade_jpn_ha_sen", castle = "building_defense_keep_crow_discount_jpn_ha_sen", siege_workshop = "building_unit_siege_jpn_ha_sen", town_center_capital = "building_town_center_capital_jpn_ha_sen"}})
