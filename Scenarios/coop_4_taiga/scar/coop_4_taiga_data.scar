-- Marker Compositions
function Unit_Path_Data()

	-- Allied Waves
	ally_assault_1 = {
		mkr_ally_raid1_1,
		mkr_ally_raid1_2,
		mkr_ally_raid1_3, 
	} -- Village raid #1
	ally_assault_2 = {
		mkr_ally_raid2_1,
		mkr_ally_raid2_2,
		mkr_ally_raid2_3,
		mkr_ally_raid2_4,
	} -- Village raid #2
	ally_assault_3 = {
		mkr_ally_raid3_1,
		mkr_ally_raid3_2,
		mkr_ally_raid3_3,
		mkr_ally_raid3_4,
	} -- Village raid #3
	ally_assault_4 = {
		mkr_ally_raid4_1,
		mkr_ally_raid4_2,
		mkr_ally_raid4_3, 
	} -- Village raid #4
	
	-- Allied Siege: approach-only routes (one-way march to siege area)
	ally_siege_approach_1 = {
		mkr_ally_raid1_1,
		mkr_ally_raid1_2,
		mkr_ally_raid1_3,
		mkr_spawn_south_1,
		mkr_dest_siege_1,
	} -- Approach to siege area #1
	ally_siege_approach_2 = {
		mkr_ally_raid2_1,
		mkr_ally_raid2_2,
		mkr_ally_raid2_3,
		mkr_ally_raid2_4,
