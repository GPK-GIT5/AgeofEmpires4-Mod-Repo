-- ============================================================
-- BLUEPRINT_REVERSE_MAP: attribName → AGS key
-- Used by the player disconnect system for faction-safe asset conversion.
-- ============================================================
function _BuildReverseLookups()
	BLUEPRINT_REVERSE_MAP = {}
	for _, tbl in pairs(AGS_ENTITY_TABLE) do
		for key, attrib in pairs(tbl) do
			if type(attrib) == "string" then
				BLUEPRINT_REVERSE_MAP[attrib] = key
			end
		end
	end
	-- Also index DLC override attribNames
	for _, overrides in pairs(DLC_CIV_OVERRIDES) do
		for key, attrib in pairs(overrides) do
			if type(attrib) == "string" then
				BLUEPRINT_REVERSE_MAP[attrib] = key
			end
		end
	end
end
_BuildReverseLookups()

