		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_UNIT_HORSEMAN_4)
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_MELEE_ARMOR_III)
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_MELEE_DAMAGE_III)
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_RANGED_DAMAGE_III)
		Player_CompleteUpgrade(player6, UPG.COMMON.UPGRADE_RANGED_ARMOR_III)
		-- Faction: HRE
		--Player_CompleteUpgrade(player6, UPG.HRE.UPGRADE_UNIT_MANATARMS_3_HRE)
		--Player_CompleteUpgrade(player6, UPG.HRE.UPGRADE_RIVETED_CHAIN_ARMOUR_HRE)
		--Player_CompleteUpgrade(player6, UPG.HRE.UPGRADE_MAN_AT_ARMS_TWO_HANDED_HRE)
	end
	
	-- 10 minute delay
	Rule_AddOneShot(Difficulty_Phase3_Upgrades, 600)
	
end

