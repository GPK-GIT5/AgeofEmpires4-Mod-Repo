	-- Populate ALL_PLAYER_SLOTS for disconnect + debug modules
	ALL_PLAYER_SLOTS = { player1, player2, player3, player4, player5, player6 }
	
	-- SGroup Tracker
	sg_player_team = SGroup_CreateIfNotFound("sg_player_team") 
	-- Garrison_Building
	sg_garrison = SGroup_CreateIfNotFound("sg_garrison")
	event_cue_text = Loc_FormatText("$2158694")  -- "Point captured"
	
	-------------
	-- Phase 1 --
	-------------
	
	-- Phase1_VillageNorth_Assault_raid
	raid_started_1 = false
	raid_started_2 = false
	raid_started_3 = false
	raid_started_4 = false
