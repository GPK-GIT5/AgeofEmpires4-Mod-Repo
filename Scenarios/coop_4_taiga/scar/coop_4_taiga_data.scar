		mkr_ally_raid3_2,
		mkr_ally_raid3_3,
		mkr_ally_raid3_4,
		mkr_spawn_south_2,
		mkr_dest_siege_3,
	} -- Approach to siege area #3
	ally_siege_approach_4 = {
		mkr_ally_raid4_1,
		mkr_ally_raid4_2,
		mkr_ally_raid4_3,
		mkr_spawn_south_2,
		mkr_dest_siege_4,
	} -- Approach to siege area #4
	
	-- Allied Siege: siege-area patrol routes (Roving Army loop)
	-- Route: front gate -> side keep -> next gate -> remaining keep
	-- Sides 1-2 attack mkr_dest_gate_1; sides 3-4 attack mkr_dest_gate_2
	siege_patrol_1 = {
		mkr_dest_siege_1,       -- Front gate attack point
		mkr_dest_siege_keep1,   -- Side keep
		mkr_dest_gate_1,        -- Next gate attack point
		mkr_dest_siege_keep2,   -- Remaining keep
	} -- Siege patrol #1
	siege_patrol_2 = {
		mkr_dest_siege_2,       -- Front gate attack point
		mkr_dest_siege_keep1,   -- Side keep
		mkr_dest_gate_1,        -- Next gate attack point
		mkr_dest_siege_keep2,   -- Remaining keep
	} -- Siege patrol #2
	siege_patrol_3 = {
		mkr_dest_siege_3,       -- Front gate attack point
		mkr_dest_siege_keep2,   -- Side keep
		mkr_dest_gate_2,        -- Next gate attack point
		mkr_dest_siege_keep1,   -- Remaining keep
	} -- Siege patrol #3
	siege_patrol_4 = {
		mkr_dest_siege_4,       -- Front gate attack point
		mkr_dest_siege_keep2,   -- Side keep
		mkr_dest_gate_2,        -- Next gate attack point
		mkr_dest_siege_keep1,   -- Remaining keep
	} -- Siege patrol #4
	
	-- Attack Waves
	wave_path_1 = {
		mkr_wave_1_path_1,
		mkr_wave_1_path_2,
		mkr_spawn_south_1,
		mkr_spawn_south_2,
		mkr_spawn_village_3, -- TC #1
	}
	wave_path_1_flank = {
		mkr_wave_1_path_1,
		mkr_wave_1_path_2,
		mkr_wave_1_path_flank,
		mkr_spawn_village_1,
		mkr_spawn_village_2,
		mkr_spawn_village_3, -- TC #1
	}
	wave_path_1_resources = {
		mkr_wave_1_path_1,
		mkr_wave_1_path_2,
		mkr_wave_1_path_flank,
		mkr_wave_1_resources_1,
		mkr_wave_1_resources_2,
		mkr_wave_1_resources_3,
		mkr_wave_2_resources_3,
		mkr_wave_2_resources_2,
		mkr_wave_2_resources_1,
		mkr_spawn_1,
		mkr_spawn_2,
		mkr_spawn_3,
		mkr_spawn_4,
		mkr_spawn_village_3, -- TC #1
	}
	wave_path_2 = {
		mkr_wave_2_path_1,
		mkr_wave_2_path_2,
		mkr_spawn_south_2,
		mkr_spawn_south_1,
		mkr_spawn_village_3, -- TC #1
	}
	wave_path_2_flank = {
		mkr_wave_2_path_1,
		mkr_wave_2_path_2,
		mkr_wave_2_path_flank,
		mkr_spawn_village_4,
		mkr_spawn_village_3, -- TC #1
	}
	wave_path_2_resources = {
		mkr_wave_2_path_flank,
		mkr_wave_2_resources_1,
		mkr_wave_2_resources_2,
		mkr_wave_2_resources_3,
		mkr_wave_1_resources_3,
		mkr_wave_1_resources_2,
		mkr_wave_1_resources_1,
		mkr_spawn_4,
		mkr_spawn_3,
		mkr_spawn_2,
		mkr_spawn_1,
		mkr_spawn_village_3, -- TC #1
	}
	
	-- Patrols
	patrol_mid_1 = {
		mkr_spawn_camp_1,
		mkr_spawn_outpost_1,
		mkr_spawn_outpost_2,
		mkr_spawn_outpost_3_wp,
		mkr_spawn_outpost_4_wp,
		mkr_wave_2_resources_1,
	}
	patrol_mid_2 = {
		mkr_wave_2_resources_1,
		mkr_spawn_outpost_4_wp,
		mkr_spawn_outpost_3_wp,
		mkr_spawn_outpost_2,
		mkr_spawn_outpost_1,
		mkr_spawn_camp_1,
	}
	patrol_city_1 = {
		mkr_dest_siege_keep1,
		mkr_dest_siege_keep2,
		mkr_spawn_wave_1,
	}
	patrol_city_2 = {
		mkr_dest_siege_keep2,
		mkr_dest_siege_keep1,
		mkr_spawn_wave_4,
	}
	patrol_roving_side1_cycle = {
		mkr_spawn_outpost_1,
		mkr_spawn_outpost_1_rng,
