	sg_river_guards_1 = SGroup_CreateIfNotFound("sg_river_guards_1")
	sg_river_guards_2 = SGroup_CreateIfNotFound("sg_river_guards_2")
	-- Camp Guards
	sg_camp_guards_1 = SGroup_CreateIfNotFound("sg_camp_guards_1")
	sg_camp_guards_2 = SGroup_CreateIfNotFound("sg_camp_guards_2")
	 
	-------------
	-- Phase 2 --
	-------------
	
	-- Filter entities / Objective: Defend Village
	eg_tc_north = EGroup_CreateIfNotFound("eg_tc_north")
	eg_tc_south = EGroup_CreateIfNotFound("eg_tc_south")
	eg_tc_group = EGroup_CreateIfNotFound("eg_tc_group")
	-- Ping when attacked
	tc_north_msg = false
	tc_south_msg = false
	
	-- Filter entities / Objective: Capture Village (South)
	entity_kremlin = EGroup_GetClosestEntity(eg_village_south, mkr_spawn_south_1_rng)
	entity_outpost_bridge = EGroup_GetClosestEntity(eg_village_south, mkr_spawn_south_2_rng)
	entity_outpost_south = EGroup_GetClosestEntity(eg_village_south, mkr_spawn_south_5)
