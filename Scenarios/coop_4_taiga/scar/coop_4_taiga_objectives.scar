function Phase3_CityAssault_InitObjectives()
	
	OBJ_Phase3_CityAssault_Main = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:23",  -- "Clear a path for Siege Reinforcements"
		Type = ObjectiveType_Battle, 
		OnStart = Phase3_CityAssault_Start, --when objective start call function
		OnComplete = Phase3_CityAssault_OnComplete, -- when objective completes, call function
	}
	OBJ_Phase3_CityAssault_side1 = {
		Title =  "$ae948c95a8c5425d8de28e0c193e0be9:24",  -- "Defeat all resistance near the Checkpoints"
		Type = ObjectiveType_Battle, 
		Parent = OBJ_Phase3_CityAssault_Main,
	}
	OBJ_Phase3_CityAssault_side2 = {
		Title =  "$ae948c95a8c5425d8de28e0c193e0be9:24",  -- "Defeat all resistance near the Checkpoints"
		Type = ObjectiveType_Battle, 
		Parent = OBJ_Phase3_CityAssault_Main,
	}
	OBJ_Phase3_CityAssault_side3 = {
		Title =  "$ae948c95a8c5425d8de28e0c193e0be9:24",  -- "Defeat all resistance near the Checkpoints"
		Type = ObjectiveType_Battle, 
		Parent = OBJ_Phase3_CityAssault_Main,
	}
	
	Objective_Register(OBJ_Phase3_CityAssault_Main)
	Objective_Register(OBJ_Phase3_CityAssault_side1)
	Objective_Register(OBJ_Phase3_CityAssault_side2)
	Objective_Register(OBJ_Phase3_CityAssault_side3)

end

function Phase3_CityAssault_Start()
	
	-- Init siege army system
	AlliedSiege_Init()
	
	-- Enable rule
	Rule_AddInterval(Phase3_CityAssault_CountConditions, 1)
	
	-- Add UI
	Objective_AddUIElements(OBJ_Phase3_CityAssault_Main, mkr_spawn_outer_city_1b, true, "$ae948c95a8c5425d8de28e0c193e0be9:15", true) -- "Checkpoint"
	Objective_AddUIElements(OBJ_Phase3_CityAssault_Main, mkr_spawn_outer_city_2b, true, "$ae948c95a8c5425d8de28e0c193e0be9:15", true) -- "Checkpoint"
	Objective_AddUIElements(OBJ_Phase3_CityAssault_Main, mkr_spawn_outer_city_3a, true, "$ae948c95a8c5425d8de28e0c193e0be9:15", true) -- "Checkpoint"

	
end

function Phase3_CityAssault_CountConditions()
	
	local event_cue_text_cleared = Loc_FormatText("$ae948c95a8c5425d8de28e0c193e0be9:25")  -- "Position has been cleared"
	
	if Objective_IsComplete(OBJ_Phase3_CityAssault_Main) == false then
		
		-- Side #1
		if SGroup_Count(sg_city_defender_group_1) <= 5 and city_ex_group1_kia == false then
			if Objective_IsComplete(OBJ_Phase3_CityAssault_side1) == false then
				
				-- Enable allied siege waves
				AlliedSiege_Deploy(1)
				
				-- Remove UI
				Objective_RemoveUIElements(OBJ_Phase3_CityAssault_Main, 1)
				
				-- End objective
				Objective_Complete(OBJ_Phase3_CityAssault_side1, true, false)
				
				-- Notification: Text & Ping
				UI_CreateEventCueClickable(-1, 20, -1, 0, event_cue_text_cleared, "", "low_priority", "", "sfx_campaign_scripted_ui_objective_counter_update", 255, 255, 255, 255, ECV_Queue, nothing)
				UI_CreateMinimapBlip(mkr_spawn_outer_city_1b, 60, "general")
				
				-- Switch
				city_ex_group1_kia = true
			end
		end
		
		-- Side #2
		if SGroup_Count(sg_city_defender_group_2) <= 5 and city_ex_group2_kia == false then
			if Objective_IsComplete(OBJ_Phase3_CityAssault_side2) == false then
				
				-- Enable allied siege waves
				AlliedSiege_Deploy(2)
				
				-- Remove UI
				Objective_RemoveUIElements(OBJ_Phase3_CityAssault_Main, 2)
				
				-- End objective
				Objective_Complete(OBJ_Phase3_CityAssault_side2, true, false)
				
				-- Notification: Text & Ping
				UI_CreateEventCueClickable(-1, 20, -1, 0, event_cue_text_cleared, "", "low_priority", "", "sfx_campaign_scripted_ui_objective_counter_update", 255, 255, 255, 255, ECV_Queue, nothing)
				UI_CreateMinimapBlip(mkr_spawn_outer_city_2b, 60, "general")
				
				-- Switch
				city_ex_group2_kia = true
			end
		end
		
		-- Side #3
		if SGroup_Count(sg_city_defender_group_3) <= 5 and city_ex_group3_kia == false then
			if Objective_IsComplete(OBJ_Phase3_CityAssault_side3) == false then
				
				-- Enable allied siege waves
				AlliedSiege_Deploy(3)
				
				-- Remove UI
				Objective_RemoveUIElements(OBJ_Phase3_CityAssault_Main, 3)
				
				-- End objective
				Objective_Complete(OBJ_Phase3_CityAssault_side3, true, false)
				
				-- Notification: Text & Ping
				UI_CreateEventCueClickable(-1, 20, -1, 0, event_cue_text_cleared, "", "low_priority", "", "sfx_campaign_scripted_ui_objective_counter_update", 255, 255, 255, 255, ECV_Queue, nothing)
				UI_CreateMinimapBlip(mkr_spawn_outer_city_3a, 60, "general")
				
				-- Switch
				city_ex_group3_kia = true
			end
		end
		
		-- Cleared / complete objective
		if SGroup_Count(sg_city_defender_group_all) == 0 then
			Objective_Complete(OBJ_Phase3_CityAssault_Main)
			Rule_RemoveMe()
		end
		
	else
		Rule_RemoveMe()
	end		
end

function Phase3_CityAssault_OnComplete()
	
	-- Start siege respawn monitor so armies continue through FinalKeep phase
	if Rule_Exists(AlliedSiege_RespawnMonitor) == false then
		Rule_AddInterval(AlliedSiege_RespawnMonitor, 10)
	end
	
end

-------------------------------------------
-- Allied Siege — Roving Army System
-------------------------------------------
-- Replaces legacy Units_Deploy siege waves with Roving Army patrol
-- instances. Each side spawns, approaches via attack-move, then
-- creates a Roving Army that loops between siege targets.
-- On arrival at gate markers the army pauses and issues
-- Cmd_Attack on nearby gate entities. After gates are destroyed
-- the army resumes patrol toward the keeps.
-------------------------------------------

-- Per-side configuration table
-- gate_markers: ordered list of markers where gates should be attacked (matched by distance)
-- Sides 1-2 share mkr_dest_gate_1; sides 3-4 share mkr_dest_gate_2
local ALLIED_SIEGE_SIDE_COUNT = 4
local ALLIED_SIEGE_DEBUG_LOGS = false
local ALLIED_SIEGE_CONFIG = {
	[1] = { sgroup = "sg_allied_siege_1", spawn = "mkr_spawn_1", approach = "ally_siege_approach_1", patrol = "siege_patrol_1", gate_markers = { "mkr_dest_siege_1", "mkr_dest_gate_1" } },
	[2] = { sgroup = "sg_allied_siege_2", spawn = "mkr_spawn_2", approach = "ally_siege_approach_2", patrol = "siege_patrol_2", gate_markers = { "mkr_dest_siege_2", "mkr_dest_gate_1" } },
	[3] = { sgroup = "sg_allied_siege_3", spawn = "mkr_spawn_3", approach = "ally_siege_approach_3", patrol = "siege_patrol_3", gate_markers = { "mkr_dest_siege_3", "mkr_dest_gate_2" } },
	[4] = { sgroup = "sg_allied_siege_4", spawn = "mkr_spawn_4", approach = "ally_siege_approach_4", patrol = "siege_patrol_4", gate_markers = { "mkr_dest_siege_4", "mkr_dest_gate_2" } },
}

-- Runtime state (set in AlliedSiege_Init)
local _allied_siege_spawned = { false, false, false, false }
local _allied_siege_respawn_due = { 0, 0, 0, 0 }
local _allied_siege_attacking_gate = { false, false, false, false }
local _allied_siege_active_gate_mkr = { nil, nil, nil, nil }  -- tracks which gate marker is currently being attacked
local _allied_siege_respawn_monitor_active = false
local _allied_siege_gate_lookup_last = {}  -- marker key -> "source:count"

-- Resolve a config field that may reference a global variable by name
local function _AlliedSiege_Resolve(field)
	if type(field) == "string" then
		return _G[field]
	end
	return field
end

local function _AlliedSiege_Log(message)
	if ALLIED_SIEGE_DEBUG_LOGS then
		print(message)
	end
end

local function _AlliedSiege_LogGateLookup(gate_mkr, source, count)
	local marker_key = tostring(gate_mkr)
	local current = source .. ":" .. tostring(count)
	if _allied_siege_gate_lookup_last[marker_key] ~= current then
		_allied_siege_gate_lookup_last[marker_key] = current
		_AlliedSiege_Log(string.format("[ALLIED_SIEGE] Gate lookup(%s): found %d", source, count))
	end
end

-- Resolve gate targets near a marker. If direct type scans fail,
-- return nil so monitor can resume patrol when local stage gates are gone.
local function _AlliedSiege_FindGateTargets(gate_mkr)
	local eg_temp = Player_GetEntitiesFromTypeInArea(player6, "stone_gate", gate_mkr, ALLIED_SIEGE_GATE_SEARCH_RADIUS)
	if eg_temp ~= nil and EGroup_Count(eg_temp) > 0 then
		_AlliedSiege_LogGateLookup(gate_mkr, "stone_gate", EGroup_Count(eg_temp))
		return eg_temp
	end

	eg_temp = Player_GetEntitiesFromTypeInArea(player6, "gate", gate_mkr, ALLIED_SIEGE_GATE_SEARCH_RADIUS)
	if eg_temp ~= nil and EGroup_Count(eg_temp) > 0 then
		_AlliedSiege_LogGateLookup(gate_mkr, "gate", EGroup_Count(eg_temp))
		return eg_temp
	end
	_AlliedSiege_LogGateLookup(gate_mkr, "none", 0)
	return nil
end

-----------------------------------------------------------
-- AlliedSiege_Init()
-- Called from Phase3_CityAssault_Start. Populates gate
-- EGroups using pre-placed Content Editor entities.
-----------------------------------------------------------
function AlliedSiege_Init()
	
	_allied_siege_spawned = { false, false, false, false }
	_allied_siege_respawn_due = { 0, 0, 0, 0 }
	_allied_siege_attacking_gate = { false, false, false, false }
	_allied_siege_active_gate_mkr = { nil, nil, nil, nil }
	_allied_siege_respawn_monitor_active = false
	_allied_siege_gate_lookup_last = {}
	
	-- Scan for gate entities near each unique gate marker
	-- Collect unique markers from all sides to avoid duplicate scans
	local scanned = {}  -- marker name -> true
	for side = 1, ALLIED_SIEGE_SIDE_COUNT do
		local cfg = ALLIED_SIEGE_CONFIG[side]
		for _, mkr_name in ipairs(cfg.gate_markers) do
			if not scanned[mkr_name] then
				scanned[mkr_name] = true
				local mkr = _G[mkr_name]
				if mkr ~= nil then
					local eg_temp = _AlliedSiege_FindGateTargets(mkr)
					local count = (eg_temp ~= nil) and EGroup_Count(eg_temp) or 0
					_AlliedSiege_Log(string.format("[ALLIED_SIEGE] Init gate scan: %s -> %d entities", mkr_name, count))
				else
					_AlliedSiege_Log(string.format("[ALLIED_SIEGE] Init gate scan: %s -> marker NOT FOUND", mkr_name))
				end
			end
		end
	end
	
	_AlliedSiege_Log("[ALLIED_SIEGE] Init complete (staged gate markers)")
end

-----------------------------------------------------------
-- AlliedSiege_Deploy(side)
-- Triggers spawn notification and delayed deployment for
-- the given side (1, 2, or 3). Replaces Allied_Siege_N().
-----------------------------------------------------------
function AlliedSiege_Deploy(side)
	
	local cfg = ALLIED_SIEGE_CONFIG[side]
	local sgroup = _AlliedSiege_Resolve(cfg.sgroup)
	
	if SGroup_Count(sgroup) > 0 then
		return
	end
	if _allied_siege_spawned[side] == true then
		return
	end
	
	_allied_siege_spawned[side] = true
	
	-- Notification: Text & Ping
	local event_cue_text = Loc_FormatText("$11179775")  -- "Reinforcements arriving soon"
	local spawn_mkr = _AlliedSiege_Resolve(cfg.spawn)
	UI_CreateEventCueClickable(-1, 40, -1, 0, event_cue_text, "", "low_priority", "", "sfx_campaign_scripted_ui_objective_counter_update", 255, 255, 255, 255, ECV_Queue, nothing)
	UI_CreateMinimapBlip(spawn_mkr, 40, "general")
	
	-- Delayed spawn + approach
	Rule_AddOneShot(_AlliedSiege_SpawnAndApproach, 40, { side = side })
	
	_AlliedSiege_Log(string.format("[ALLIED_SIEGE] Side %d: deploy scheduled (40s)", side))
end

-----------------------------------------------------------
-- _AlliedSiege_SpawnAndApproach(context, data)
-- OneShot callback: spawns units and attack-moves them
-- through approach waypoints toward the siege area.
-----------------------------------------------------------
function _AlliedSiege_SpawnAndApproach(context, data)
	
	local side = data.side
	local cfg = ALLIED_SIEGE_CONFIG[side]
	local sgroup = _AlliedSiege_Resolve(cfg.sgroup)
	local spawn_mkr = _AlliedSiege_Resolve(cfg.spawn)
	local approach = _AlliedSiege_Resolve(cfg.approach)
	
	-- Spawn units
	UnitEntry_DeploySquads(player5, sgroup, Unit_Types.wave_allied_siege, spawn_mkr)
	
	-- Queue attack-move through approach waypoints
	if approach ~= nil and #approach >= 1 then
		Cmd_FormationAttackMove(sgroup, approach[1])
		for idx = 2, #approach do
			Cmd_FormationAttackMove(sgroup, approach[idx], true)
		end
	end
	
	-- Start approach monitor
	Rule_AddInterval(_AlliedSiege_ApproachMonitor, 3, { side = side })
	
	_AlliedSiege_Log(string.format("[ALLIED_SIEGE] Side %d: spawned %d squads, approaching", side, SGroup_Count(sgroup)))
end

-----------------------------------------------------------
-- _AlliedSiege_ApproachMonitor(context, data)
-- Polls distance to first siege patrol target. When close
-- enough, creates the Roving Army and removes self.
-----------------------------------------------------------
function _AlliedSiege_ApproachMonitor(context, data)
	
	local side = data.side
	local cfg = ALLIED_SIEGE_CONFIG[side]
	local sgroup = _AlliedSiege_Resolve(cfg.sgroup)
	local patrol = _AlliedSiege_Resolve(cfg.patrol)
	
	-- Death during approach
	if SGroup_Count(sgroup) <= 0 then
		_AlliedSiege_Log(string.format("[ALLIED_SIEGE] Side %d: wiped during approach", side))
		_AlliedSiege_ScheduleRespawn(side)
		Rule_RemoveMe()
		return
	end
	
	-- Check distance to first siege-area target
	local ok, dist = pcall(Util_GetDistance, sgroup, patrol[1])
	if not ok then
		return
	end
	
	if dist <= 30 then
		_AlliedSiege_CreatePatrol(side)
		Rule_RemoveMe()
	end
end

-----------------------------------------------------------
-- _AlliedSiege_CreatePatrol(side)
-- Creates a Roving Army instance for the siege-area loop.
-----------------------------------------------------------
function _AlliedSiege_CreatePatrol(side)
	
	local cfg = ALLIED_SIEGE_CONFIG[side]
	local sgroup = _AlliedSiege_Resolve(cfg.sgroup)
	local patrol = _AlliedSiege_Resolve(cfg.patrol)
	local army_name = "allied_siege_" .. tostring(side)
	
	-- Clean up any existing army with this name
	local existing = RovingArmy_Find(army_name)
	if existing ~= nil then
		RovingArmy_Disband(existing)
	end
	
	local army = RovingArmy_Create({
		name = army_name,
		player = player5,
		sgroup = sgroup,
		targets = patrol,
		target_order = ROVING_ORDER_LOOP,
		poll_interval = 3,
		arrival_distance = 15,
		idle_time = 0,
		on_arrived = function(army_ref, target_index)
			_AlliedSiege_OnArrived(side, army_ref, target_index)
		end,
		on_death = function()
			_AlliedSiege_OnDeath(side)
		end,
	})
	RovingArmy_Start(army)
	
	_AlliedSiege_Log(string.format("[ALLIED_SIEGE] Side %d: Roving Army created — %d units, %d targets", side, SGroup_Count(sgroup), #patrol))
end

-----------------------------------------------------------
-- _AlliedSiege_OnArrived(side, army, target_index)
-- Fired when the army reaches a patrol waypoint. If the
-- waypoint is a gate marker and gates still exist, pauses
-- the army and issues Cmd_Attack on nearby gate entities.
-----------------------------------------------------------
function _AlliedSiege_OnArrived(side, army, target_index)
	
	local cfg = ALLIED_SIEGE_CONFIG[side]
	local patrol = _AlliedSiege_Resolve(cfg.patrol)
	local current_target = patrol[target_index]
	
	-- Check if current patrol waypoint matches ANY of the side's gate markers
	local matched_mkr = nil
	for _, mkr_name in ipairs(cfg.gate_markers) do
		local mkr = _G[mkr_name]
		if mkr ~= nil then
			local ok, dist = pcall(Util_GetDistance, current_target, mkr)
			if ok and dist ~= nil and dist <= 1 then
				matched_mkr = mkr
				_AlliedSiege_Log(string.format("[ALLIED_SIEGE] Side %d: arrived at gate marker %s (targetIndex=%d)", side, mkr_name, target_index))
				break
			end
		end
	end
	
	if matched_mkr == nil then
		_AlliedSiege_Log(string.format("[ALLIED_SIEGE] Side %d: arrived at targetIndex=%d (not a gate marker)", side, target_index))
		return
	end
	
	-- Skip if already attacking a gate on this side
	if _allied_siege_attacking_gate[side] == true then
		return
	end
	
	-- Dynamically find gate entities near the matched marker
	local eg_nearby = _AlliedSiege_FindGateTargets(matched_mkr)
	
	if eg_nearby == nil or EGroup_Count(eg_nearby) == 0 then
		_AlliedSiege_Log(string.format("[ALLIED_SIEGE] Side %d: gate already breached at stage marker, continuing patrol", side))
		return
	end
	
	-- Pause army and issue direct attack on gate entities
	RovingArmy_Pause(army)
	Cmd_Attack(army.sgroup, eg_nearby)
	_allied_siege_attacking_gate[side] = true
	_allied_siege_active_gate_mkr[side] = matched_mkr
	
	-- Start gate destruction monitor
	Rule_AddInterval(_AlliedSiege_GateMonitor, 5, { side = side })
	
	_AlliedSiege_Log(string.format("[ALLIED_SIEGE] Side %d: attacking %d gate entities at stage marker", side, EGroup_Count(eg_nearby)))
end

-----------------------------------------------------------
-- _AlliedSiege_GateMonitor(context, data)
-- Polls gate entity state. When all gates at the target
-- are destroyed, resumes the army. Re-issues Cmd_Attack
-- if units go idle while gates still standing.
-----------------------------------------------------------
function _AlliedSiege_GateMonitor(context, data)
	
	local side = data.side
	local cfg = ALLIED_SIEGE_CONFIG[side]
	local sgroup = _AlliedSiege_Resolve(cfg.sgroup)
	local active_mkr = _allied_siege_active_gate_mkr[side]
	local army_name = "allied_siege_" .. tostring(side)
	local army = RovingArmy_Find(army_name)
	
	-- Army died or was disbanded
	if army == nil or SGroup_Count(sgroup) <= 0 then
		_allied_siege_attacking_gate[side] = false
		_allied_siege_active_gate_mkr[side] = nil
		Rule_RemoveMe()
		return
	end
	
	-- Check remaining gates at the active stage marker
	local eg_remaining = nil
	if active_mkr ~= nil then
		eg_remaining = _AlliedSiege_FindGateTargets(active_mkr)
	end
	
	if eg_remaining == nil or EGroup_Count(eg_remaining) == 0 then
		-- Gates destroyed at this stage — resume patrol toward next waypoint
		_allied_siege_attacking_gate[side] = false
		_allied_siege_active_gate_mkr[side] = nil
		RovingArmy_Resume(army)
		_AlliedSiege_Log(string.format("[ALLIED_SIEGE] Side %d: gates destroyed at stage marker, resuming patrol", side))
		Rule_RemoveMe()
		return
	end
	
	-- Gates still standing — re-issue attack in case units went idle
	Cmd_Attack(sgroup, eg_remaining)
end

-----------------------------------------------------------
-- _AlliedSiege_OnDeath(side)
-- Called when all units in a siege army are lost.
-- Schedules a respawn after ALLIED_SIEGE_RESPAWN_TIMER.
-----------------------------------------------------------
function _AlliedSiege_OnDeath(side)
	_AlliedSiege_Log(string.format("[ALLIED_SIEGE] Side %d: army destroyed, respawn in %ds", side, ALLIED_SIEGE_RESPAWN_TIMER))
	_allied_siege_attacking_gate[side] = false
	_allied_siege_active_gate_mkr[side] = nil
	_AlliedSiege_ScheduleRespawn(side)
end

-----------------------------------------------------------
-- _AlliedSiege_ScheduleRespawn(side)
-- Sets respawn timer and ensures the respawn monitor is running.
-----------------------------------------------------------
function _AlliedSiege_ScheduleRespawn(side)
	_allied_siege_spawned[side] = false
	_allied_siege_respawn_due[side] = World_GetGameTime() + ALLIED_SIEGE_RESPAWN_TIMER
	
	if _allied_siege_respawn_monitor_active == false and Rule_Exists(AlliedSiege_RespawnMonitor) == false then
		Rule_AddInterval(AlliedSiege_RespawnMonitor, 10)
		_allied_siege_respawn_monitor_active = true
	end
end

-----------------------------------------------------------
-- AlliedSiege_RespawnMonitor()
-- 10s interval rule. Re-deploys siege armies after their
-- respawn timer expires. Self-removes when no respawns
-- are pending and game is not ending.
-----------------------------------------------------------
function AlliedSiege_RespawnMonitor()
	
	-- Don't respawn if game is ending
	if g_gameOver == true then
		_allied_siege_respawn_monitor_active = false
		Rule_RemoveMe()
		return
	end
	
	local now = World_GetGameTime()
	local any_pending = false
	
	for side = 1, ALLIED_SIEGE_SIDE_COUNT do
		if _allied_siege_respawn_due[side] > 0 and now >= _allied_siege_respawn_due[side] then
			_allied_siege_respawn_due[side] = 0
			AlliedSiege_Deploy(side)
		end
		if _allied_siege_respawn_due[side] > 0 then
			any_pending = true
		end
	end
	
	-- Keep monitor alive as long as respawns are pending
	if any_pending == false then
		_allied_siege_respawn_monitor_active = false
		Rule_RemoveMe()
	end
end

function Phase3_FinalKeep_InitObjectives()
	
	OBJ_Phase3_FinalKeep_Main = {
		Title = "$11172043",  -- "Destroy the keep" 
		Type = ObjectiveType_Primary, 
		SetupUI = Phase3_FinalKeep_UI,
		OnStart = Phase3_FinalKeep_Start, 
		OnComplete = Phase3_FinalKeep_OnComplete,
	}
	
	Objective_Register(OBJ_Phase3_FinalKeep_Main)

end

function Phase3_FinalKeep_Start()
	
	-- Enable Rule
	Rule_Add(Phase3_FinalKeep_count_rule)
	
end

function Phase3_FinalKeep_UI()
	
	Objective_SetCounter(OBJ_Phase3_FinalKeep_Main, 0, 2) --Set the counter in the UI
	
end

function Phase3_FinalKeep_count_rule()
	
	-- Counter +1
	if EGroup_Count(eg_keeps) == 1 and keep1_kia == false then
		if Objective_IsCounterSet(OBJ_Phase3_FinalKeep_Main) then
			Objective_IncreaseCounter(OBJ_Phase3_FinalKeep_Main)
			keep1_kia = true
		end
	end
	
	-- Victory
	if EGroup_Count(eg_keeps) == 0 then
		if Objective_IsComplete(OBJ_Phase3_FinalKeep_Main) == false then
			Objective_Complete(OBJ_Phase3_FinalKeep_Main, true, true)
			Rule_RemoveMe()
			
		else 
			Rule_RemoveMe()
		end
	end
	
end

function Phase3_FinalKeep_OnComplete() 
	
	--[[ Set eliminated / victorious
	Core_SetPlayerDefeated(player6, Elimination_LoserPresentation, WR_ELIMINATION)
	Core_SetPlayerVictorious(player1, Elimination_WinnerPresentation, WR_ELIMINATION)	
	Core_SetPlayerVictorious(player2, Elimination_WinnerPresentation, WR_ELIMINATION)	
	Core_SetPlayerVictorious(player3, Elimination_WinnerPresentation, WR_ELIMINATION)	
	Core_SetPlayerVictorious(player4, Elimination_WinnerPresentation, WR_ELIMINATION)	
	Core_SetPlayerVictorious(player5, Elimination_WinnerPresentation, WR_ELIMINATION)
	Elimination_CheckVictory()]]
	
	Mission_Complete()
	Rule_AddOneShot(Victory_Function, 10)
	

end 










