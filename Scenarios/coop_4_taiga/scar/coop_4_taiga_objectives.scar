	north_attacker_respawn_pending_2 = false
	north_attacker_respawn_timer_2 = 0

	if PHASE1_VILLAGE_NORTH_RESPAWN_ACTIVE == false or Objective_IsFailed(OBJ_Phase1_VillageDefence_Main) == true then
		return
	end

	if north_attacker_initial_count_2 <= 0 then
		return
	end

	if SGroup_Count(sg_village_north_attacker_2) > Phase1_VillageNorth_AttackerRespawn_GetThresholdCount(north_attacker_initial_count_2) then
		return
	end

	-- Hard cap: never exceed initial composition size
	if SGroup_Count(sg_village_north_attacker_2) >= north_attacker_initial_count_2 then
