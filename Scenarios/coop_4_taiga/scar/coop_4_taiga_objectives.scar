-------------------------------------------
-- Objective: Capture Checkpoint 
-------------------------------------------

local GARRISON_FILL_OUTPOST = 8
local GARRISON_FILL_KREMLIN = 8
local PHASE1_VILLAGE_NORTH_FALLBACK_ACTIVE = false
local PHASE1_VILLAGE_NORTH_RESPAWN_THRESHOLD = 0.3
local PHASE1_VILLAGE_NORTH_RESPAWN_ACTIVE = false

local north_attacker_initial_count_1 = 0
local north_attacker_initial_count_2 = 0
local north_attacker_initial_count_3 = 0
local north_attacker_initial_count_4 = 0

local north_attacker_respawn_pending_1 = false
local north_attacker_respawn_pending_2 = false
local north_attacker_respawn_pending_3 = false
local north_attacker_respawn_pending_4 = false

local north_attacker_respawn_timer_1 = 0
local north_attacker_respawn_timer_2 = 0
local north_attacker_respawn_timer_3 = 0
local north_attacker_respawn_timer_4 = 0

local PHASE1_PATROL_MODE_OUTPOST = 1
local PHASE1_PATROL_MODE_FLANK = 2
local PHASE1_PATROL_ASSIST_DURATION = 30
local PHASE1_PATROL_ASSIST_COOLDOWN = 20
local PHASE1_PATROL_OUTPOST_LEASH = 95
local PHASE1_PATROL_FLANK_LEASH = 180
local PHASE1_PATROL_PLAYER_SUPPORT_RANGE = 80
local PHASE1_PATROL_FORCE_RATIO = 1.5
local PHASE2_OUTPOST_GUARD_LEASH = 75

local phase1_patrol_mode = PHASE1_PATROL_MODE_OUTPOST
local phase1_patrol_side1_captures = 0
local phase1_patrol_side2_captures = 0
local phase1_patrol_side1_started = false
local phase1_patrol_side2_started = false
local phase1_patrol_side1_primary_outpost = 1
local phase1_patrol_side2_primary_outpost = 3
local phase1_patrol_side1_spawn_outpost = 1
local phase1_patrol_side2_spawn_outpost = 3
local phase1_patrol_side1_anchor_outpost = 1
local phase1_patrol_side2_anchor_outpost = 3
local phase1_patrol_side1_respawn_due = 0
local phase1_patrol_side2_respawn_due = 0
local phase1_patrol_tower_counted_1 = false
local phase1_patrol_tower_counted_2 = false
local phase1_patrol_tower_counted_3 = false
local phase1_patrol_tower_counted_4 = false
local phase1_patrol_side1_assisting = false
local phase1_patrol_side2_assisting = false
local phase1_patrol_side1_assist_until = 0
local phase1_patrol_side2_assist_until = 0
local phase1_patrol_side1_last_redirect = 0
local phase1_patrol_side2_last_redirect = 0
local phase1_patrol_monitor_active = false
local phase2_outpost_guard_monitor_active = false
local phase2_outpost_guard_started = { false, false, false, false }
local phase2_outpost_guard_respawn_due = { 0, 0, 0, 0 }

local function GarrisonCapturedEntity(entity, amount)
	if entity == nil then
		return
	end

	local eg_target = EGroup_CreateIfNotFound("eg_objective_garrison_target")
	EGroup_Clear(eg_target)
	EGroup_Add(eg_target, entity)
	Garrison_Building(None, { egroup = eg_target, amount = amount, player = player5 })
end

local function Phase1_VillageNorth_AttackerRespawn_GetThresholdCount(initial_count)
	if initial_count <= 0 then
		return 0
	end

	return math.max(1, math.ceil(initial_count * PHASE1_VILLAGE_NORTH_RESPAWN_THRESHOLD))
end

local function Phase1_VillageNorth_AttackerRespawn_UpdateInitialCounts()
	if raid_started_1 == true and north_attacker_initial_count_1 == 0 and SGroup_Count(sg_village_north_attacker_1) > 0 then
		north_attacker_initial_count_1 = SGroup_Count(sg_village_north_attacker_1)
	end

	if raid_started_2 == true and north_attacker_initial_count_2 == 0 and SGroup_Count(sg_village_north_attacker_2) > 0 then
		north_attacker_initial_count_2 = SGroup_Count(sg_village_north_attacker_2)
	end

	if raid_started_3 == true and north_attacker_initial_count_3 == 0 and SGroup_Count(sg_village_north_attacker_3) > 0 then
		north_attacker_initial_count_3 = SGroup_Count(sg_village_north_attacker_3)
	end

	if raid_started_4 == true and north_attacker_initial_count_4 == 0 and SGroup_Count(sg_village_north_attacker_4) > 0 then
		north_attacker_initial_count_4 = SGroup_Count(sg_village_north_attacker_4)
	end
end

-- Canonical hold markers per group:
-- group 1 → mkr_spawn_village_1, group 2 → mkr_village_rally_2
-- group 3 → mkr_village_rally_1, group 4 → mkr_spawn_village_4
local _respawn_hold_markers = {}
_respawn_hold_markers[1] = "mkr_spawn_village_1"
_respawn_hold_markers[2] = "mkr_village_rally_2"
_respawn_hold_markers[3] = "mkr_village_rally_1"
_respawn_hold_markers[4] = "mkr_spawn_village_4"

local function Phase1_VillageNorth_AttackerRespawn_IssueOrders(sgroup, group_index)
	local hold = Marker_FromName(_respawn_hold_markers[group_index], "")

	if Objective_IsStarted(OBJ_Phase1_VillageDefence_Main) == true and Objective_IsFailed(OBJ_Phase1_VillageDefence_Main) == false then
		Cmd_FormationAttackMove(sgroup, hold, false)
		return
	end

	if group_index <= 2 then
		Cmd_FormationAttackMove(sgroup, mkr_spawn_village_1, false)
		Cmd_FormationAttackMove(sgroup, mkr_spawn_village_2, true)
		Cmd_FormationAttackMove(sgroup, mkr_spawn_village_3, true)
		Cmd_FormationAttackMove(sgroup, mkr_spawn_village_4, true)
		Cmd_FormationAttackMove(sgroup, hold, true)
	else
		Cmd_FormationAttackMove(sgroup, mkr_spawn_village_4, false)
		Cmd_FormationAttackMove(sgroup, mkr_spawn_village_3, true)
		Cmd_FormationAttackMove(sgroup, mkr_spawn_village_2, true)
		Cmd_FormationAttackMove(sgroup, mkr_spawn_village_1, true)
		Cmd_FormationAttackMove(sgroup, hold, true)
	end
end

function Phase1_VillageNorth_AttackerRespawn_Register()
	if PHASE1_VILLAGE_NORTH_RESPAWN_ACTIVE == false then
		PHASE1_VILLAGE_NORTH_RESPAWN_ACTIVE = true
		north_attacker_respawn_pending_1 = false
		north_attacker_respawn_pending_2 = false
		north_attacker_respawn_pending_3 = false
		north_attacker_respawn_pending_4 = false
		north_attacker_respawn_timer_1 = 0
		north_attacker_respawn_timer_2 = 0
		north_attacker_respawn_timer_3 = 0
		north_attacker_respawn_timer_4 = 0
	end

	if Rule_Exists(Phase1_VillageNorth_AttackerRespawn_Monitor) == false then
		Rule_AddInterval(Phase1_VillageNorth_AttackerRespawn_Monitor, 1)
	end
end

function Phase1_VillageNorth_AttackerRespawn_Monitor()
	local respawn_delay = DC.north_attacker_respawn_timer or 180

	if PHASE1_VILLAGE_NORTH_RESPAWN_ACTIVE == false then
		Rule_RemoveMe()
		return
	end

	if Objective_IsFailed(OBJ_Phase1_VillageDefence_Main) == true then
		PHASE1_VILLAGE_NORTH_RESPAWN_ACTIVE = false
		Rule_RemoveMe()
		return
	end

	Phase1_VillageNorth_AttackerRespawn_UpdateInitialCounts()

	if north_attacker_initial_count_1 > 0 and north_attacker_respawn_pending_1 == false and SGroup_Count(sg_village_north_attacker_1) <= Phase1_VillageNorth_AttackerRespawn_GetThresholdCount(north_attacker_initial_count_1) then
		north_attacker_respawn_pending_1 = true
		north_attacker_respawn_timer_1 = respawn_delay
	end
	if north_attacker_initial_count_2 > 0 and north_attacker_respawn_pending_2 == false and SGroup_Count(sg_village_north_attacker_2) <= Phase1_VillageNorth_AttackerRespawn_GetThresholdCount(north_attacker_initial_count_2) then
		north_attacker_respawn_pending_2 = true
		north_attacker_respawn_timer_2 = respawn_delay
	end
	if north_attacker_initial_count_3 > 0 and north_attacker_respawn_pending_3 == false and SGroup_Count(sg_village_north_attacker_3) <= Phase1_VillageNorth_AttackerRespawn_GetThresholdCount(north_attacker_initial_count_3) then
		north_attacker_respawn_pending_3 = true
		north_attacker_respawn_timer_3 = respawn_delay
	end
	if north_attacker_initial_count_4 > 0 and north_attacker_respawn_pending_4 == false and SGroup_Count(sg_village_north_attacker_4) <= Phase1_VillageNorth_AttackerRespawn_GetThresholdCount(north_attacker_initial_count_4) then
		north_attacker_respawn_pending_4 = true
		north_attacker_respawn_timer_4 = respawn_delay
	end

	if north_attacker_respawn_pending_1 == true then
		north_attacker_respawn_timer_1 = north_attacker_respawn_timer_1 - 1
		if north_attacker_respawn_timer_1 <= 0 then
			Phase1_VillageNorth_AttackerRespawn_Callback_1()
		end
	end
	if north_attacker_respawn_pending_2 == true then
		north_attacker_respawn_timer_2 = north_attacker_respawn_timer_2 - 1
		if north_attacker_respawn_timer_2 <= 0 then
			Phase1_VillageNorth_AttackerRespawn_Callback_2()
		end
	end
	if north_attacker_respawn_pending_3 == true then
		north_attacker_respawn_timer_3 = north_attacker_respawn_timer_3 - 1
		if north_attacker_respawn_timer_3 <= 0 then
			Phase1_VillageNorth_AttackerRespawn_Callback_3()
		end
	end
	if north_attacker_respawn_pending_4 == true then
		north_attacker_respawn_timer_4 = north_attacker_respawn_timer_4 - 1
		if north_attacker_respawn_timer_4 <= 0 then
			Phase1_VillageNorth_AttackerRespawn_Callback_4()
		end
	end
end

function Phase1_VillageNorth_AttackerRespawn_Callback_1()
	north_attacker_respawn_pending_1 = false
	north_attacker_respawn_timer_1 = 0

	if PHASE1_VILLAGE_NORTH_RESPAWN_ACTIVE == false or Objective_IsFailed(OBJ_Phase1_VillageDefence_Main) == true then
		return
	end

	if north_attacker_initial_count_1 <= 0 then
		return
	end

	if SGroup_Count(sg_village_north_attacker_1) > Phase1_VillageNorth_AttackerRespawn_GetThresholdCount(north_attacker_initial_count_1) then
		return
	end

	-- Hard cap: never exceed initial composition size
	if SGroup_Count(sg_village_north_attacker_1) >= north_attacker_initial_count_1 then
		return
	end

	UnitEntry_DeploySquads(player5, sg_village_north_attacker_1, Unit_Types.wave_city_10m, mkr_spawn_1)
	Phase1_VillageNorth_AttackerRespawn_IssueOrders(sg_village_north_attacker_1, 1)
end

