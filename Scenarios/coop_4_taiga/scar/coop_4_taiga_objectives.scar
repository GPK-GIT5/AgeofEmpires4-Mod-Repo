		end
		
		-- Check Group #4
		if SGroup_Count(sg_outpost_guards_4) == 0 then 
			
			-- Check Outpost and change owner
			if World_OwnsEntity(cap_outpost_4) ~= true then
				-- Captured outpost
				if Entity_GetPlayerOwner(cap_outpost_4) ~= nil then
					if Entity_GetPlayerOwner(cap_outpost_4) == player6 and Entity_IsAlive(cap_outpost_4) == true then
						EGroup_SetPlayerOwner(eg_outpost_4, player5)
						-- Add Springald upgrade
						Cmd_InstantUpgrade(eg_outpost_4, UPG.RUS.UPGRADE_WOODEN_CASTLE_SPRINGALD_RUS)
						Garrison_Building(None, { egroup = eg_outpost_4, amount = GARRISON_FILL_OUTPOST, player = player5 })
						
						-- Notification: Point captured
						UI_CreateEventCueClickable(-1, 15, -1, 0, event_cue_text, "", "low_priority", "", "sfx_campaign_Hastings_horn_reinforcements_arrive", 255, 255, 255, 255, ECV_Queue, nothing)
						UI_CreateMinimapBlip(mkr_spawn_outpost_4, 10, "general")
						
						-- Remove UI
						Objective_RemoveUIElements(OBJ_Phase1_Outposts_side2, 2)
						
						-- Side Objective +1
						if Objective_IsCounterSet(OBJ_Phase1_Outposts_side2) then
							Objective_IncreaseCounter(OBJ_Phase1_Outposts_side2)
							
							if Obj_GetCounterCount(OBJ_Phase1_Outposts_side2.ID) == Obj_GetCounterMax(OBJ_Phase1_Outposts_side2.ID) then 
								Objective_Complete(OBJ_Phase1_Outposts_side2, true, true) 
								
							end
						end
						
						-- Start allied Raid #4
						Phase1_VillageNorth_Assault_raid4()
					end
					
				end
			else
				-- Destroyed outpost
				if cap_outpost_4_kia == false then
					-- Notification: Point captured
					UI_CreateEventCueClickable(-1, 15, -1, 0, event_cue_text, "", "low_priority", "", "sfx_campaign_Hastings_horn_reinforcements_arrive", 255, 255, 255, 255, ECV_Queue, nothing)
					UI_CreateMinimapBlip(mkr_spawn_outpost_4, 10, "general")
					
					-- Remove UI
					Objective_RemoveUIElements(OBJ_Phase1_Outposts_side2, 2)
					
					-- Side Objective +1
					if Objective_IsCounterSet(OBJ_Phase1_Outposts_side2) then
						Objective_IncreaseCounter(OBJ_Phase1_Outposts_side2)

						if Obj_GetCounterCount(OBJ_Phase1_Outposts_side2.ID) == Obj_GetCounterMax(OBJ_Phase1_Outposts_side2.ID) then 
							Objective_Complete(OBJ_Phase1_Outposts_side2, true, true) 
							
						end
					end
					
					-- Variable switch
					cap_outpost_4_kia = true
				end
			end
			-- Ensure raid triggers regardless of outpost entity state
			Phase1_RovingPatrol_MarkTowerCaptured(4)
			Phase1_VillageNorth_Assault_raid4()
		end
		
		-- Check both groups, complete objective
		if SGroup_Count(sg_checkpoint_group_2) == 0 then
			if Objective_IsComplete(OBJ_Phase1_Outposts_side2) == false then
				Objective_Complete(OBJ_Phase1_Outposts_side2, true, true) 
			end
			
			-- Main Objective +1
			if Objective_IsCounterSet(OBJ_Phase1_Outposts_Main) then
				
				Objective_IncreaseCounter(OBJ_Phase1_Outposts_Main)

				if Obj_GetCounterCount(OBJ_Phase1_Outposts_Main.ID) == Obj_GetCounterMax(OBJ_Phase1_Outposts_Main.ID) then 
					Objective_Complete(OBJ_Phase1_Outposts_Main, true, true) 
					
				end
			end
			Rule_RemoveMe()
		end
		
	else
		Rule_RemoveMe()
	end
	
end

function Phase1_Outposts_OnComplete()

	-- Intentionally no legacy fort archer spawn here.
	-- Friendly outposts are garrisoned at capture-time via Garrison_Building.
	 
end

-------------------------------------------
-- Objective: Capture Village (North)
-------------------------------------------

function Phase1_VillageNorth_InitObjectives()
	
	OBJ_Phase1_VillageNorth_Main = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:8" ,  -- "Prepare for the Village Assault"
		Type = ObjectiveType_Battle, 
		OnStart = Phase1_VillageNorth_Start, --when objective start call function
		OnComplete = Phase1_VillageNorth_OnComplete, -- when objective completes, call function
	}
	OBJ_Phase1_VillageNorth_side1 = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:9",  -- "Escort the Allied assault to the Western Village enterance"
		Type = ObjectiveType_Battle, 
		Parent = OBJ_Phase1_VillageNorth_Main,
		--OnComplete =Phase1_VillageNorth_side_OnComplete, -- when objective completes, call function
	}
	OBJ_Phase1_VillageNorth_side2 = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:10",  -- "Escort the Allied assault to the Eastern Village enterance"
		Type = ObjectiveType_Battle, 
		Parent = OBJ_Phase1_VillageNorth_Main,
		--OnComplete =Phase1_VillageNorth_side_OnComplete, -- when objective completes, call function
	}
	OBJ_Phase1_VillageNorth_side3 = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:11",  -- "Defeat all resistance North of the River"
		Type = ObjectiveType_Battle, 
		Parent = OBJ_Phase1_VillageNorth_Main,
	}

	
	Objective_Register(OBJ_Phase1_VillageNorth_Main)
	Objective_Register(OBJ_Phase1_VillageNorth_side1)
	Objective_Register(OBJ_Phase1_VillageNorth_side2)
	Objective_Register(OBJ_Phase1_VillageNorth_side3)
	
end

function Phase1_VillageNorth_Start()
	
	Objective_AddUIElements(OBJ_Phase1_VillageNorth_Main, mkr_spawn_village_2, true, "$11149016", true) -- "Village"
	Objective_AddUIElements(OBJ_Phase1_VillageNorth_side1, mkr_ally_raid1_3, true, "$40836", true, 4, nil, nil, "icons/objectives/capture_objective", "CaptureObjectiveTemplate") -- "Rally point"
	Objective_AddUIElements(OBJ_Phase1_VillageNorth_side2, mkr_ally_raid3_4, true, "$40836", true, 4, nil, nil, "icons/objectives/capture_objective", "CaptureObjectiveTemplate") -- "Rally point"
	Objective_AddUIElements(OBJ_Phase1_VillageNorth_side3, mkr_spawn_village_2, true, "$11149016", true) -- "Village"

	-- Merge group condition for proximity
	Rule_AddInterval(Phase1_VillageNorth_Group_side1_rule, 1)
	Rule_AddInterval(Phase1_VillageNorth_Group_side2_rule, 1)
	
	-- Escort objective condition
	Rule_EnterProximity(Phase1_VillageNorth_Assault_proximity_side1, ALL, sg_village_north_attacker_side1, mkr_ally_raid1_3, 50, false, {})
	Rule_EnterProximity(Phase1_VillageNorth_Assault_proximity_side2, ALL, sg_village_north_attacker_side2, mkr_ally_raid3_4, 50, false, {})
	
	-- Final objective condition / Outpost ownership
	Rule_Add(Phase1_VillageNorth_Rule_Counters)
	-- Assault start condition
	Rule_AddInterval(Phase1_VillageNorth_Assault_Start_rule, 1)
	-- Monitor for late-spawning escort groups
	Rule_AddInterval(Phase1_VillageNorth_Assault_Monitor, 1)
	
end

-- Allied escort #1 finished
function Phase1_VillageNorth_Assault_proximity_side1()
	if Objective_IsComplete(OBJ_Phase1_VillageNorth_Main) == true then
		Rule_RemoveMe()
		return
	end
	
	-- Win/Fail side Objective #1 
	if SGroup_Count(sg_village_north_attacker_1) + SGroup_Count(sg_village_north_attacker_2) >= 20 then
		Objective_Complete(OBJ_Phase1_VillageNorth_side1, true, true) 
		Objective_RemoveUIElements(OBJ_Phase1_VillageNorth_side1, 1)
		Rule_RemoveMe()
	else
		Objective_Fail(OBJ_Phase1_VillageNorth_side1, true, true)
		Objective_RemoveUIElements(OBJ_Phase1_VillageNorth_side1, 1)
		Rule_RemoveMe()
	end
	
	-- Check assault progress
	if Objective_IsStarted(OBJ_Phase1_VillageNorth_side3) == true then
		
		-- Play horn to signal attack
		Sound_Play2D("sfx_campaign_Hastings_horn_reinforcements_arrive")
		
		-- Attack Waypoints / Raid #1
		Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_1, false)
		Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_2, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_3, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_4, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_1, true)
		-- Attack Waypoints / Raid #2
		Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_spawn_village_1, false)
		Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_spawn_village_2, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_spawn_village_3, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_spawn_village_4, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_village_rally_2, true)
	end

end
-- Allied escort #2 finished
function Phase1_VillageNorth_Assault_proximity_side2()
	if Objective_IsComplete(OBJ_Phase1_VillageNorth_Main) == true then
		Rule_RemoveMe()
		return
	end
	
	-- Win/Fail side Objective #1 
	if SGroup_Count(sg_village_north_attacker_3) + SGroup_Count(sg_village_north_attacker_4) >= 20 then
		Objective_Complete(OBJ_Phase1_VillageNorth_side2, true, true) 
		Objective_RemoveUIElements(OBJ_Phase1_VillageNorth_side2, 1)
		Rule_RemoveMe()
	else
		Objective_Fail(OBJ_Phase1_VillageNorth_side2, true, true)
		Objective_RemoveUIElements(OBJ_Phase1_VillageNorth_side2, 1)
		Rule_RemoveMe()
	end
	
	-- Check assault progress
	if Objective_IsStarted(OBJ_Phase1_VillageNorth_side3) == true then
		
		-- Play horn to signal attack
		Sound_Play2D("sfx_campaign_Hastings_horn_reinforcements_arrive")
		
		-- Attack Waypoints / Raid #3
		Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_spawn_village_4, false)
		Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_spawn_village_3, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_spawn_village_2, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_spawn_village_1, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_village_rally_1, true)
		-- Attack Waypoints / Raid #4
		Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_4, false)
		Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_3, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_2, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_1, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_4, true)
		
		
	end
	
	

end 

-- Rule: SGroup merge #1
function Phase1_VillageNorth_Group_side1_rule()
	
	if raid_started_1 == true and raid_started_2 == true then
		-- Rules
		Rule_AddOneShot(Phase1_VillageNorth_Group_side1_delayed, 41)
		Rule_RemoveMe()
	end
		
	
end

function Phase1_VillageNorth_Group_side1_delayed()
	
	-- Merge groups
	SGroup_AddGroup(sg_village_north_attacker_side1, sg_village_north_attacker_1)
	SGroup_AddGroup(sg_village_north_attacker_side1, sg_village_north_attacker_2)
	-- Disable path UI 
	MarkerPaths_ClearIcons("wave_path_1") -- Raid #1
	MarkerPaths_ClearIcons("wave_path_2") -- Raid #1
	
end
-- Rule: SGroup merge #2
function Phase1_VillageNorth_Group_side2_rule()
	
	if raid_started_3 == true and raid_started_4 == true then
		-- Rules
		Rule_AddOneShot(Phase1_VillageNorth_Group_side2_delayed, 51)
		Rule_RemoveMe()
	end
		
	
end

function Phase1_VillageNorth_Group_side2_delayed()
	
	-- Merge groups
	SGroup_AddGroup(sg_village_north_attacker_side2, sg_village_north_attacker_3)
	SGroup_AddGroup(sg_village_north_attacker_side2, sg_village_north_attacker_4)
	-- Disable path UI 
	MarkerPaths_ClearIcons("wave_path_3") -- Raid #3
	MarkerPaths_ClearIcons("wave_path_4") -- Raid #4
	
end

-- Allied AI Assault groups position near the Village Enterance
function Phase1_VillageNorth_Assault_raid1()
	
	if raid_started_1 == false then
		
	-- Start main objective
	if Objective_IsStarted(OBJ_Phase1_VillageNorth_Main) == false then
		Objective_Start(OBJ_Phase1_VillageNorth_Main,true, false)
	end
	-- Start side objective #1
	if Objective_IsComplete(OBJ_Phase1_VillageNorth_Main) == false and Objective_IsStarted(OBJ_Phase1_VillageNorth_side1) == false then
		Objective_Start(OBJ_Phase1_VillageNorth_side1,true, false)
	end
	
	local event_cue_text_reinforcements = Loc_FormatText("$11179775")  -- "Reinforcements arriving soon"
	
	-- Enable path UI / Assault #1
	MarkerPaths_GenerateIcons("wave_path_1", AllMarkers_FromName("mkr_path_village_1", ""), "military_route_ally")
	-- Notification
	UI_CreateEventCueClickable(-1, 30, -1, 0, event_cue_text_reinforcements, "", "low_priority", "", "sfx_campaign_scripted_ui_objective_counter_update", 255, 255, 255, 255, ECV_Queue, nothing)
	UI_CreateMinimapBlip(mkr_spawn_1, 30, "general")
	
	-- Spawn enemey defenders
	UnitEntry_DeploySquads(player6, sg_village_north_defender_1, Unit_Types.units_camp, mkr_spawn_temp_reinforcements1)
	Cmd_FormationAttackMove(sg_village_north_defender_1, mkr_spawn_outpost_1)
	
	-- Spawn allied Assault #1
	Rule_AddOneShot(Units_Deploy, 30, { player = player5, sgroup = sg_village_north_attacker_1, unit_type = Unit_Types.wave_city_10m, spawn_loc = mkr_spawn_1, path = ally_assault_1 })
	SGroup_AddGroup(sg_village_north_attacker_side1, sg_village_north_attacker_1)
	
	raid_started_1 = true
end
	
end

