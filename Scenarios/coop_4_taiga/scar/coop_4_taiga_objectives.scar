-- Conditions / Allied AI assault
function Phase1_VillageNorth_Assault_Start_rule()
	
	if Objective_IsStarted(OBJ_Phase1_VillageNorth_side3) == false then
		if Objective_IsComplete(OBJ_Phase1_VillageNorth_side1) == true or Objective_IsFailed(OBJ_Phase1_VillageNorth_side1) == true then
			if Objective_IsComplete(OBJ_Phase1_VillageNorth_side2) == true or Objective_IsFailed(OBJ_Phase1_VillageNorth_side2) == true then
				
				
				-- Start side Objective #3
				if Objective_IsStarted(OBJ_Phase1_VillageNorth_side3) == false and (assault_active_1 == false or assault_active_2 == false) then
					Objective_Start(OBJ_Phase1_VillageNorth_side3,true, false)
					Phase1_VillageNorth_Assault_StallFallback_Register()
					Phase1_VillageNorth_AttackerRespawn_Register()
					-- Play horn to signal attack (3x)
					Sound_Play2D("sfx_campaign_Hastings_horn_retreat")
				end
				
				
				
				-- Spawn defenders
				if assault_active_1 == false or assault_active_2 == false then
					Spawn_Village_South_Enemey()
				end
				
				-- Start assault #1
				if assault_active_1 == false then
					-- Issue attack commands to Raid #1 (only if spawned and present)
					if raid_started_1 == true and attack_commands_issued_1 == false and SGroup_Count(sg_village_north_attacker_1) > 0 then
						Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_1, false)
						Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_2, true)
						Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_3, true)
						Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_4, true)
						Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_1, true)
						attack_commands_issued_1 = true
					end
					-- Issue attack commands to Raid #2 (only if spawned and present)
					if raid_started_2 == true and attack_commands_issued_2 == false and SGroup_Count(sg_village_north_attacker_2) > 0 then
						Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_spawn_village_1, false)
						Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_spawn_village_2, true)
						Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_spawn_village_3, true)
						Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_spawn_village_4, true)
						Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_village_rally_2, true)
						attack_commands_issued_2 = true
					end
					-- Toggle condition
					assault_active_1 = true
				end
				
				-- Start assault #2
				if assault_active_2 == false then
					-- Issue attack commands to Raid #3 (only if spawned and present)
					if raid_started_3 == true and attack_commands_issued_3 == false and SGroup_Count(sg_village_north_attacker_3) > 0 then
						Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_spawn_village_4, false)
						Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_spawn_village_3, true)
						Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_spawn_village_2, true)
						Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_spawn_village_1, true)
						Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_village_rally_1, true)
						attack_commands_issued_3 = true
					end
					-- Issue attack commands to Raid #4 (only if spawned and present)
					if raid_started_4 == true and attack_commands_issued_4 == false and SGroup_Count(sg_village_north_attacker_4) > 0 then
						Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_4, false)
						Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_3, true)
						Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_2, true)
						Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_1, true)
						Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_4, true)
						attack_commands_issued_4 = true
					end
					-- Toggle condition
					assault_active_2 = true
				end
				
				-- Finished / Remove rule (once assault phases are triggered, let monitor handle late spawns)
				if assault_active_1 == true and assault_active_2 == true then
					Rule_RemoveMe()
				end
			end
		end
	end
	
end

-- Monitor for late-spawning groups and issue attack commands if assault already active
function Phase1_VillageNorth_Assault_Monitor()
	
	-- If assault #1 is active, check if any Assault #1 groups spawned late
	if assault_active_1 == true then
		if raid_started_1 == true and attack_commands_issued_1 == false and SGroup_Count(sg_village_north_attacker_1) > 0 then
			Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_1, false)
			Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_2, true)
			Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_3, true)
			Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_4, true)
			Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_1, true)
			attack_commands_issued_1 = true
		end
		if raid_started_2 == true and attack_commands_issued_2 == false and SGroup_Count(sg_village_north_attacker_2) > 0 then
			Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_spawn_village_1, false)
			Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_spawn_village_2, true)
			Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_spawn_village_3, true)
			Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_spawn_village_4, true)
			Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_village_rally_2, true)
			attack_commands_issued_2 = true
		end
	end
	
	-- If assault #2 is active, check if any Assault #2 groups spawned late
	if assault_active_2 == true then
		if raid_started_3 == true and attack_commands_issued_3 == false and SGroup_Count(sg_village_north_attacker_3) > 0 then
			Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_spawn_village_4, false)
			Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_spawn_village_3, true)
			Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_spawn_village_2, true)
			Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_spawn_village_1, true)
			Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_village_rally_1, true)
			attack_commands_issued_3 = true
		end
		if raid_started_4 == true and attack_commands_issued_4 == false and SGroup_Count(sg_village_north_attacker_4) > 0 then
			Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_4, false)
			Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_3, true)
			Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_2, true)
			Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_1, true)
			Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_4, true)
			attack_commands_issued_4 = true
		end
	end
	
	-- Remove this monitor once all groups have received commands
	if attack_commands_issued_1 == true and attack_commands_issued_2 == true and attack_commands_issued_3 == true and attack_commands_issued_4 == true then
		Rule_RemoveMe()
	end
	
end

function Phase1_VillageNorth_Assault_StallFallback_Register()
	if PHASE1_VILLAGE_NORTH_FALLBACK_ACTIVE == false then
		Rule_AddInterval(Phase1_VillageNorth_Assault_StallFallback, 1)
		PHASE1_VILLAGE_NORTH_FALLBACK_ACTIVE = true
	end
end

function Phase1_VillageNorth_Assault_StallFallback()
	if Objective_IsComplete(OBJ_Phase1_VillageNorth_Main) == true then
		PHASE1_VILLAGE_NORTH_FALLBACK_ACTIVE = false
		Rule_RemoveMe()
		return
	end

	if Objective_IsStarted(OBJ_Phase1_VillageNorth_side3) == false then
		return
	end

	-- Side #3 is active, so both assault lanes should be considered active for late-spawn monitoring.
	assault_active_1 = true
	assault_active_2 = true

	if raid_started_1 == true and attack_commands_issued_1 == false and SGroup_Count(sg_village_north_attacker_1) > 0 then
		Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_1, false)
		Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_2, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_3, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_4, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_1, true)
		attack_commands_issued_1 = true
	end

	if raid_started_2 == true and attack_commands_issued_2 == false and SGroup_Count(sg_village_north_attacker_2) > 0 then
		Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_spawn_village_1, false)
		Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_spawn_village_2, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_spawn_village_3, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_spawn_village_4, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_village_rally_2, true)
		attack_commands_issued_2 = true
	end

	if raid_started_3 == true and attack_commands_issued_3 == false and SGroup_Count(sg_village_north_attacker_3) > 0 then
		Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_spawn_village_4, false)
		Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_spawn_village_3, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_spawn_village_2, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_spawn_village_1, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_village_rally_1, true)
		attack_commands_issued_3 = true
	end

	if raid_started_4 == true and attack_commands_issued_4 == false and SGroup_Count(sg_village_north_attacker_4) > 0 then
		Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_4, false)
		Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_3, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_2, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_1, true)
		Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_4, true)
		attack_commands_issued_4 = true
	end

	if attack_commands_issued_1 == true and attack_commands_issued_2 == true and attack_commands_issued_3 == true and attack_commands_issued_4 == true then
		PHASE1_VILLAGE_NORTH_FALLBACK_ACTIVE = false
		Rule_RemoveMe()
	end
end

-- Conditions / SGroup counts / Outpost ownership
function Phase1_VillageNorth_Rule_Counters()
	
	local event_cue_text = Loc_FormatText("$2158694") -- "Point captured"
	
	
	if Objective_IsComplete(OBJ_Phase1_VillageNorth_Main) == false then
		
		-- Check Outpost Group #1
		if SGroup_Count(sg_village_north_guards_1) == 0  then
			
			-- Check Outpost and change owner
			if World_OwnsEntity(vil_outpost_1) ~= true then
				if Entity_GetPlayerOwner(vil_outpost_1) ~= nil then
					if Entity_GetPlayerOwner(vil_outpost_1) == player6 and Entity_IsAlive(vil_outpost_1) == true then
						Entity_SetPlayerOwner(vil_outpost_1, player5)
						
						-- Add Springald upgrade
						Entity_CompleteUpgrade(vil_outpost_1, UPG.RUS.UPGRADE_WOODEN_CASTLE_SPRINGALD_RUS)
						GarrisonCapturedEntity(vil_outpost_1, GARRISON_FILL_OUTPOST)
						
						-- Notification: Point captured
						UI_CreateEventCueClickable(-1, 15, -1, 0, event_cue_text, "", "low_priority", "", "sfx_ui_event_queue_campaign_objective_start", 255, 255, 255, 255, ECV_Queue, nothing)
						UI_CreateMinimapBlip(mkr_spawn_village_1_rng, 15, "general")
					end
				end
			end
		end
		-- Check Outpost Group #2
		if SGroup_Count(sg_village_north_guards_3) == 0  then
			
			-- Check Outpost and change owner
			if World_OwnsEntity(vil_outpost_2) ~= true then
				if Entity_GetPlayerOwner(vil_outpost_2) ~= nil then
					if Entity_GetPlayerOwner(vil_outpost_2) == player6 and Entity_IsAlive(vil_outpost_2) == true then
						Entity_SetPlayerOwner(vil_outpost_2, player5)
						
						-- Add Springald upgrade
						Entity_CompleteUpgrade(vil_outpost_2, UPG.RUS.UPGRADE_WOODEN_CASTLE_SPRINGALD_RUS)
						GarrisonCapturedEntity(vil_outpost_2, GARRISON_FILL_OUTPOST)
						
						-- Notification: Point captured
						UI_CreateEventCueClickable(-1, 15, -1, 0, event_cue_text, "", "low_priority", "", "sfx_ui_event_queue_campaign_objective_start", 255, 255, 255, 255, ECV_Queue, nothing)
						UI_CreateMinimapBlip(mkr_spawn_village_3_rng, 15, "general")
					end
				end
			end
		end
		-- Check Outpost Group #3
		if SGroup_Count(sg_village_north_guards_4) == 0  then
			
			-- Check Outpost and change owner
			if World_OwnsEntity(vil_outpost_3) ~= true then
				if Entity_GetPlayerOwner(vil_outpost_3) ~= nil then
					if Entity_GetPlayerOwner(vil_outpost_3) == player6 and Entity_IsAlive(vil_outpost_3) == true then
						Entity_SetPlayerOwner(vil_outpost_3, player5)
						
						-- Add Springald upgrade
						Entity_CompleteUpgrade(vil_outpost_3, UPG.RUS.UPGRADE_WOODEN_CASTLE_SPRINGALD_RUS)
						GarrisonCapturedEntity(vil_outpost_3, GARRISON_FILL_OUTPOST)
						
						-- Notification: Point captured
						UI_CreateEventCueClickable(-1, 15, -1, 0, event_cue_text, "", "low_priority", "", "sfx_ui_event_queue_campaign_objective_start", 255, 255, 255, 255, ECV_Queue, nothing)
						UI_CreateMinimapBlip(mkr_spawn_village_4_rng, 15, "general")
					end	
				end
			end
		end
		
		-- Check Village Groups, complete objective
		if SGroup_Count(sg_village_north_group_all) == 0 then
			if Objective_IsComplete(OBJ_Phase1_VillageNorth_Main) == false then
				Objective_Complete(OBJ_Phase1_VillageNorth_Main, true, true) 
			end
		end
		
		-- Check Foward Groups incase players assault early / Start assault, side #1
		if SGroup_Count(sg_village_north_guards_1) <= 25 then
			
			-- Start main objective if players engage early
			if Objective_IsStarted(OBJ_Phase1_VillageNorth_Main) == false then
				Objective_Start(OBJ_Phase1_VillageNorth_Main, true, false)
			end
			
			-- Enable objective
			if Objective_IsStarted(OBJ_Phase1_VillageNorth_side3) == false then
				Objective_Start(OBJ_Phase1_VillageNorth_side3, true, false)
				Phase1_VillageNorth_Assault_StallFallback_Register()
				Phase1_VillageNorth_AttackerRespawn_Register()
				
				-- Legacy inline routing removed: fallback monitor now handles consistent commands for all groups.
				Spawn_Village_South_Enemey()
			end
		end
		-- Check Foward Groups incase players assault early / Start assault, side #2
		if SGroup_Count(sg_village_north_guards_4) <= 25 then
			
			-- Start main objective if players engage early
			if Objective_IsStarted(OBJ_Phase1_VillageNorth_Main) == false then
				Objective_Start(OBJ_Phase1_VillageNorth_Main, true, false)
			end
			
			-- Enable objective
			if Objective_IsStarted(OBJ_Phase1_VillageNorth_side3) == false then
				Objective_Start(OBJ_Phase1_VillageNorth_side3, true, false)
				Phase1_VillageNorth_Assault_StallFallback_Register()
				Phase1_VillageNorth_AttackerRespawn_Register()
				
				-- Legacy inline routing removed: fallback monitor now handles consistent commands for all groups.
				Spawn_Village_South_Enemey()
			end
		end
		
	else
		Rule_RemoveMe()
	end
	
end

function Phase1_VillageNorth_OnComplete()
	Objective_RemoveUIElements(OBJ_Phase1_VillageNorth_Main, 1)
	Objective_RemoveUIElements(OBJ_Phase1_VillageNorth_side1, 1)
	Objective_RemoveUIElements(OBJ_Phase1_VillageNorth_side2, 1)
	Objective_RemoveUIElements(OBJ_Phase1_VillageNorth_side3, 1)
	
	-- Set ownership buildings 
	EGroup_SetPlayerOwner(eg_village_north, player5)
	-- Add healing ability on Religious building
	EGroup_Filter(eg_village_north, EBP.RUS.BUILDING_UNIT_RELIGIOUS_CONTROL_RUS, FILTER_REMOVE, eg_religious_1)
	EGroup_AddAbility(eg_religious_1, BP_GetAbilityBlueprintByPbgID(202453))
	
	-- Enable damage for Town Center
	local TC_North = EGroup_GetClosestEntity(eg_village_north, mkr_tc_north)
	Entity_SetInvulnerable(TC_North, false, -1)
	EGroup_SetTargetingType(eg_village_north, Targeting_Automatic)
	
	-- Set positions Allied AI
	if SGroup_Count(sg_village_north_attacker_1) >= 1 then
		Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_1, false)
	end
	if SGroup_Count(sg_village_north_attacker_2) >= 1 then
		Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_village_rally_2, false)
	end
	if SGroup_Count(sg_village_north_attacker_3) >= 1 then
		Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_village_rally_1, false)
	end
	if SGroup_Count(sg_village_north_attacker_4) >= 1 then
		Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_4, false)
	end
	
	-- Start next objective
	Objective_Start(OBJ_Phase1_VillageDefence_Main,true, false)
	Objective_Start(OBJ_Phase1_VillageDefence_north,true, false)
	
	-- Add enemey upgrades
	Difficulty_Phase1_Upgrades()
	
	-- Last time / Sometimes skips during debug
	Spawn_Village_South_Enemey()
	
	-- Spawn Outer City defenders
	Spawn_CityDefenders_enemey_ex()

	-- Transition side patrols from outpost support to village flank defense.
	Phase1_RovingPatrol_TransitionToFlankGuard()
	
end

-------------------------------------------
-- Objective: Defend Village
-------------------------------------------

function Phase1_VillageDefence_InitObjectives()
	
	OBJ_Phase1_VillageDefence_Main = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:12",  -- "Defend the Village"
		Type = ObjectiveType_Primary, 
		OnStart = Phase1_VillageDefence_Start, --when objective start call function
		--OnComplete = Phase1_VillageDefence_OnComplete, -- when objective completes, call function
	}
	OBJ_Phase1_VillageDefence_north = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:13",  -- "The Northern Town Center must survive"
		Type = ObjectiveType_Primary, 
		Parent = OBJ_Phase1_VillageDefence_Main,
		--OnComplete =Phase1_VillageNorth_side_OnComplete, -- when objective completes, call function
	}
	OBJ_Phase1_VillageDefence_south = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:18",  -- "The Southern Town Center must survive"
		Type = ObjectiveType_Primary, 
		Parent = OBJ_Phase1_VillageDefence_Main,
		--OnComplete =Phase1_VillageNorth_side_OnComplete, -- when objective completes, call function
	}
	
	Objective_Register(OBJ_Phase1_VillageDefence_Main)
	Objective_Register(OBJ_Phase1_VillageDefence_north)
	Objective_Register(OBJ_Phase1_VillageDefence_south)

end

function Phase1_VillageDefence_Start()
	
	-- Filter TC
	EGroup_Filter(eg_village_north, EBP.RUS.BUILDING_TOWN_CENTER_RUS, FILTER_REMOVE, eg_tc_north)
	local tc_pos = Util_GetPosition(mkr_tc_north)
	
	EGroup_AddEGroup(eg_tc_group, eg_tc_north)
	
	-- Apply a health modifier to Town Centers (see DC.tc_health_multiplier)
	local modifier_tc = Modifier_Create(MAT_EntityType, "health_maximum_modifier", MUT_Multiplication, false, DC.tc_health_multiplier, EBP.RUS.BUILDING_TOWN_CENTER_RUS)
	Modifier_ApplyToPlayer(modifier_tc, player5, 0)
	
	-- Added UI marker minimap
	--Objective_AddPing(OBJ_Phase1_VillageDefence_north, tc_pos)
	Objective_AddUIElements(OBJ_Phase1_VillageDefence_north, tc_pos, true, "$11164881", true) -- "Town Center"
	
	-- Enable TC Rule
	Rule_AddInterval(Phase1_VillageDefence_TownCenter_rule, 1)
	Rule_AddInterval(Phase1_VillageDefence_TownCenter_ping, 1)
	
	-- Grant starting resources from difficulty config
	for _, player in ipairs(PLAYERS) do
		Player_AddResource(player.id, RT_Food, DC.starting_food)
		Player_AddResource(player.id, RT_Gold, DC.starting_gold)
		Player_AddResource(player.id, RT_Wood, DC.starting_wood)
		Player_AddResource(player.id, RT_Stone, DC.starting_stone)
	end
		
--[[	elseif AI_Difficulty >= 3 then -- low resources
		-- Player 1: Add Resources
		Player_AddResource(player1, RT_Food, 500)
		Player_AddResource(player1, RT_Gold, 350)
		Player_AddResource(player1, RT_Wood, 200)
		-- Player 2: Add Resources
		Player_AddResource(player2, RT_Food, 500)
		Player_AddResource(player2, RT_Gold, 350)
		Player_AddResource(player2, RT_Wood, 200)
		-- Player 3: Add Resources
		Player_AddResource(player3, RT_Food, 500)
		Player_AddResource(player3, RT_Gold, 350)
		Player_AddResource(player3, RT_Wood, 200)
		-- Player 4: Add Resources
		Player_AddResource(player4, RT_Food, 500)
		Player_AddResource(player4, RT_Gold, 350)
		Player_AddResource(player4, RT_Wood, 200)
		]]
	-- Spawn villagers
	Rule_AddOneShot(Spawn_Village_South_Players, 1)

	-- Enable population UI and ensure full objectives remain visible
	for _, player in ipairs(PLAYERS) do
		UI_SetPlayerDataContext(player.id, { PopulationCapOn = true, hide_condensed_objectives_override = true })
	end
	
	-- Start waves
	Main_Waves()

	-- Start moving static camp guards into the village/TC fight as soon as Defend Village is active.
	if SGroup_Count(sg_camp_guards_1) >= 1 then
		Cmd_FormationAttackMove(sg_camp_guards_1, mkr_spawn_camp_1, false, false)
		Cmd_FormationAttackMove(sg_camp_guards_1, mkr_village_rally_1, true, false)
	end
	if SGroup_Count(sg_camp_guards_2) >= 1 then
		Cmd_FormationAttackMove(sg_camp_guards_2, mkr_spawn_camp_2, false, false)
		Cmd_FormationAttackMove(sg_camp_guards_2, mkr_village_rally_2, true, false)
	end
	
	-- Sound the horn 3x
	Sound_Play2D("sfx_campaign_Hastings_horn_retreat")
	
	-- Objective/Notification timer for counter attacks
	Objective_Start(OBJ_PrepareDefences,true, false)
	
end

function Phase1_VillageDefence_TownCenter_rule()
	
	-- Main Scenario condition
	if EGroup_Count(eg_tc_group) == 0 then
		if Objective_IsComplete(OBJ_Phase1_VillageDefence_Main) == false or Objective_IsFailed(OBJ_Phase1_VillageDefence_Main) == false then
			-- Fail mission
			Objective_Fail(OBJ_Phase1_VillageDefence_Main, true, true)
			
			
			-- End mission
			Mission_Fail()
			Rule_AddOneShot(Defeat_Function, 10)
			
			--[[ Eliminate players / Disabled elimination.scar
			Core_SetPlayerDefeated(player1, Elimination_LoserPresentation, WR_ELIMINATION)
			Core_SetPlayerDefeated(player2, Elimination_LoserPresentation, WR_ELIMINATION)
			Core_SetPlayerDefeated(player3, Elimination_LoserPresentation, WR_ELIMINATION)
			Core_SetPlayerDefeated(player4, Elimination_LoserPresentation, WR_ELIMINATION)
			Elimination_CheckVictory()]]
			
			-- Remove rule
			Rule_RemoveMe()
			
		else 
			Rule_RemoveMe()
		end
	end
	
	-- Objective condition / North
	if EGroup_Count(eg_tc_north) == 0 then
		if Objective_IsComplete(OBJ_Phase1_VillageDefence_north) == false or Objective_IsFailed(OBJ_Phase1_VillageDefence_north) == false then
			Objective_Fail(OBJ_Phase1_VillageDefence_north)
			Objective_RemoveUIElements(OBJ_Phase1_VillageDefence_north, 1)
		end
	end
	-- Objective condition / South
	if EGroup_Count(eg_tc_south) == 0 then
		Phase2_OutpostGuard_CancelRespawns()
		if Objective_IsStarted(OBJ_Phase1_VillageDefence_south) == true then
			if Objective_IsComplete(OBJ_Phase1_VillageDefence_south) == false or Objective_IsFailed(OBJ_Phase1_VillageDefence_south) == false then
				Objective_Fail(OBJ_Phase1_VillageDefence_south)
				Objective_RemoveUIElements(OBJ_Phase1_VillageDefence_south, 1)
			end
		end
	end
	
end

function Phase1_VillageDefence_TownCenter_ping()
	
	-- Notification TC under attack
	local event_cue_tc = Loc_FormatText("$11159058")  -- "Capital under attack!"
	
	-- Town Center (North)
	if EGroup_IsUnderAttackByPlayer(eg_tc_north, player6, 30) == true then
		if tc_north_msg == false then
			UI_CreateEventCueClickable(-1, 30, -1, 0, event_cue_tc, "", "low_priority", "", "sfx_ui_event_queue_campaign_high_priority", 255, 255, 255, 255, ECV_Queue, nothing)
			UI_CreateMinimapBlip(mkr_tc_north, 30, "threat_group")
			tc_north_msg = true
			
			-- Attack Waypoints / Raid #1
			if SGroup_Count(sg_village_north_attacker_1) >= 1 then
				Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_tc_north, false)
				Cmd_FormationAttackMove(sg_village_north_attacker_1, mkr_spawn_village_1, true)
			end
			-- Attack Waypoints / Raid #2
			if SGroup_Count(sg_village_north_attacker_2) >= 1 then
				Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_tc_north, false)
				Cmd_FormationAttackMove(sg_village_north_attacker_2, mkr_village_rally_2, true)
			end
			-- Attack Waypoints / Raid #3
			if SGroup_Count(sg_village_north_attacker_3) >= 1 then
				Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_tc_north, false)
				Cmd_FormationAttackMove(sg_village_north_attacker_3, mkr_village_rally_1, true)
			end
			-- Attack Waypoints / Raid #4
			if SGroup_Count(sg_village_north_attacker_4) >= 1 then
				Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_tc_north, false)
				Cmd_FormationAttackMove(sg_village_north_attacker_4, mkr_spawn_village_4, true)
			end
			
		end
	else 
		tc_north_msg = false
	end
	
	-- Town Center (South)
	if EGroup_IsUnderAttackByPlayer(eg_tc_south, player6, 30) == true then
		if tc_south_msg == false then
			UI_CreateEventCueClickable(-1, 30, -1, 0, event_cue_tc, "", "low_priority", "", "sfx_ui_event_queue_campaign_high_priority", 255, 255, 255, 255, ECV_Queue, nothing)
			UI_CreateMinimapBlip(mkr_tc_south, 30, "threat_group")
			tc_south_msg = true
			
			-- Attack Waypoints / Kremlin
			if SGroup_Count(sg_village_south_allied_1) >= 1 then
				Cmd_FormationAttackMove(sg_village_south_allied_1, mkr_tc_south, false)
				Cmd_FormationAttackMove(sg_village_south_allied_1, mkr_village_ally_1, true)
			end
			
			-- Attack Waypoints / Outpost, bridge
			if SGroup_Count(sg_village_south_allied_2) >= 1 then
				Cmd_FormationAttackMove(sg_village_south_allied_2, mkr_tc_south, false)
				Cmd_FormationAttackMove(sg_village_south_allied_2, mkr_village_ally_2, true)
			end
			
			-- Attack Waypoints / Outpost, south
			if SGroup_Count(sg_village_south_allied_3) >= 1 then
				Cmd_FormationAttackMove(sg_village_south_allied_3, mkr_tc_south, false)
				Cmd_FormationAttackMove(sg_village_south_allied_3, mkr_village_ally_3, true)
			end
			
		end
	else 
		tc_south_msg = false
	end
	
end

-- Notification: Prepare for counter attacks
function PrepareDefences_InitObjectives()
	
	OBJ_PrepareDefences = {
		Title = "$11226358" ,  -- "Prepare for the enemey waves"
		Type = ObjectiveType_Information, 
		SetupUI = PrepareDefences_UI, -- seting up how objective is presented
		OnStart = PrepareDefences_Start, --when objective start call function
	}

	
	Objective_Register(OBJ_PrepareDefences)

	
end

function PrepareDefences_UI()

	Objective_StartTimer(OBJ_PrepareDefences, COUNT_DOWN, 360, 10) 
end

function PrepareDefences_Start()
	
	Rule_AddOneShot(PrepareDefences_End, 360) 
end

function PrepareDefences_End()
	
	Objective_Complete(OBJ_PrepareDefences, true, false)
	Objective_Start(OBJ_Phase2_VillageCapture_Main, true, false)
	
	-- Sound the angry horn
	Sound_Play2D("sfx_ui_shared_attack_horn_under_attack_high")
	
	-- Open interactive area beyond river
	World_SetInteractionStage(2)

end

