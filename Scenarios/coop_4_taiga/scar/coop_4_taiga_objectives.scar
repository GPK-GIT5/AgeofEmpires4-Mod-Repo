	OBJ_Phase2_VillageCapture_Main = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:16",  -- "Capture the Southern Village section"
		Type = ObjectiveType_Battle, 
		OnStart = Phase2_VillageCapture_Start, --when objective start call function
		OnComplete = Phase2_VillageCapture_OnComplete, -- when objective completes, call function
	}
	OBJ_Phase2_VillageCapture_side = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:17",  -- "Defeat all resistance in the Southern Village section"
		Type = ObjectiveType_Primary, 
		SetupUI = Phase2_VillageCapture_UI,
		Parent = OBJ_Phase2_VillageCapture_Main,
	}
	
	Objective_Register(OBJ_Phase2_VillageCapture_Main)
	Objective_Register(OBJ_Phase2_VillageCapture_side)

end

function Phase2_VillageCapture_UI()
	
	-- Main
	Objective_SetCounter(OBJ_Phase2_VillageCapture_side, 0, 4) --Set the counter in the UI
	
end

function Phase2_VillageCapture_Start()
	
	-- Added UI markers (minimap)
	Objective_AddUIElements(OBJ_Phase1_VillageDefence_south, mkr_spawn_south_1, true, "$ae948c95a8c5425d8de28e0c193e0be9:15", true) -- "Checkpoint"
	Objective_AddUIElements(OBJ_Phase1_VillageDefence_south, mkr_spawn_south_2, true, "$ae948c95a8c5425d8de28e0c193e0be9:15", true) -- "Checkpoint"
	Objective_AddUIElements(OBJ_Phase1_VillageDefence_south, mkr_spawn_south_5, true, "$ae948c95a8c5425d8de28e0c193e0be9:15", true) -- "Checkpoint"
	Objective_AddUIElements(OBJ_Phase1_VillageDefence_south, mkr_spawn_south_4, true, "$ae948c95a8c5425d8de28e0c193e0be9:15", true) -- "Checkpoint"
	
	
	-- Add rule
	Rule_Add(Phase2_VillageCapture_CountConditions)

	
end

function Phase2_VillageCapture_CountConditions()
	
	
	
	-- Capture Kremlin landmark
	if SGroup_Count(sg_village_south_defender_1) == 0 then
		
		-- Check Kremlin and change owner / Spawn enemey attack
		if World_OwnsEntity(entity_kremlin) ~= true then
			if Entity_GetPlayerOwner(entity_kremlin) ~= nil then
				if Entity_GetPlayerOwner(entity_kremlin) == player6 and Entity_IsAlive(entity_kremlin) == true then
					Entity_SetPlayerOwner(entity_kremlin, player5)
					
					-- Add Springald upgrade
					Entity_CompleteUpgrade(entity_kremlin, UPG.RUS.UPGRADE_WOODEN_CASTLE_SPRINGALD_RUS)
					-- Create egroup
					EGroup_Add(eg_kremlin, entity_kremlin)
					-- Add units
					Garrison_Building(None, { egroup = eg_kremlin, amount = GARRISON_FILL_KREMLIN, player = player5 })
					-- Enable targeting
					EGroup_SetTargetingType(eg_kremlin, Targeting_Automatic)
					
					-- Notification: Point captured
					UI_CreateEventCueClickable(-1, 15, -1, 0, event_cue_text, "", "low_priority", "", "sfx_ui_event_queue_campaign_objective_start", 255, 255, 255, 255, ECV_Queue, nothing)
					UI_CreateMinimapBlip(mkr_spawn_south_1_rng, 15, "general")
					
					-- Remove UI
					Objective_RemoveUIElements(OBJ_Phase1_VillageDefence_south, 1)
					
					-- Side Objective +1
					if Objective_IsCounterSet(OBJ_Phase2_VillageCapture_side) then
						Objective_IncreaseCounter(OBJ_Phase2_VillageCapture_side)

						if Obj_GetCounterCount(OBJ_Phase2_VillageCapture_side.ID) == Obj_GetCounterMax(OBJ_Phase2_VillageCapture_side.ID) then 
							Objective_Complete(OBJ_Phase2_VillageCapture_side, true, true) 
							
						end
					end
					
					-- Spawn enemey attack
					UnitEntry_DeploySquads(player6, sg_village_south_attacker_1, Unit_Types.wave_city_15m, mkr_spawn_wave_2)
					Cmd_FormationAttackMove(sg_village_south_attacker_1, mkr_spawn_south_1, false)
					Cmd_FormationAttackMove(sg_village_south_attacker_1, mkr_spawn_village_3, true)	
					
					-- Start local outpost guard patrol
					Phase2_OutpostGuard_Start(1)
				end
			end
		end
	end
	-- Capture Outpost / Bridge
	if SGroup_Count(sg_village_south_defender_2) == 0 then
		
		-- Check Outpost and change owner
		if World_OwnsEntity(entity_outpost_bridge) ~= true then
			if Entity_GetPlayerOwner(entity_outpost_bridge) ~= nil then
				if Entity_GetPlayerOwner(entity_outpost_bridge) == player6 and Entity_IsAlive(entity_outpost_bridge) == true then
					Entity_SetPlayerOwner(entity_outpost_bridge, player5)
					
					-- Add Springald upgrade
					Entity_CompleteUpgrade(entity_outpost_bridge, UPG.RUS.UPGRADE_WOODEN_CASTLE_SPRINGALD_RUS)
					-- Create egroup
					EGroup_Add(eg_outpost_bridge, entity_outpost_bridge)
					-- Add units
					Garrison_Building(None, { egroup = eg_outpost_bridge, amount = GARRISON_FILL_OUTPOST, player = player5 })
					-- Enable targeting
					EGroup_SetTargetingType(eg_outpost_bridge, Targeting_Automatic)
					
					-- Notification: Point captured
					UI_CreateEventCueClickable(-1, 15, -1, 0, event_cue_text, "", "low_priority", "", "sfx_ui_event_queue_campaign_objective_start", 255, 255, 255, 255, ECV_Queue, nothing)
					UI_CreateMinimapBlip(mkr_spawn_south_2_rng, 15, "general")
					
					-- Remove UI
					Objective_RemoveUIElements(OBJ_Phase1_VillageDefence_south, 2)
					
					-- Side Objective +1
					if Objective_IsCounterSet(OBJ_Phase2_VillageCapture_side) then
						Objective_IncreaseCounter(OBJ_Phase2_VillageCapture_side)

						if Obj_GetCounterCount(OBJ_Phase2_VillageCapture_side.ID) == Obj_GetCounterMax(OBJ_Phase2_VillageCapture_side.ID) then 
							Objective_Complete(OBJ_Phase2_VillageCapture_side, true, true) 
							
						end
					end
					
					-- Spawn enemey attack
					UnitEntry_DeploySquads(player6, sg_village_south_attacker_2, Unit_Types.wave_city_20m, mkr_spawn_wave_4)
					Cmd_FormationAttackMove(sg_village_south_attacker_2, mkr_spawn_south_2, false)
					Cmd_FormationAttackMove(sg_village_south_attacker_2, mkr_spawn_south_1, true)
					Cmd_FormationAttackMove(sg_village_south_attacker_2, mkr_spawn_village_3, true)
					
					-- Start local outpost guard patrol
					Phase2_OutpostGuard_Start(2)
				end
			end
		end
	end
	-- Capture Outpost / South
	if SGroup_Count(sg_village_south_defender_6) == 0 then
		
		-- Check Outpost and change owner
		if World_OwnsEntity(entity_outpost_south) ~= true then
			if Entity_GetPlayerOwner(entity_outpost_south) ~= nil then
				if Entity_GetPlayerOwner(entity_outpost_south) == player6 and Entity_IsAlive(entity_outpost_south) == true then
					Entity_SetPlayerOwner(entity_outpost_south, player5)
					
					-- Add Springald upgrade
					Entity_CompleteUpgrade(entity_outpost_south, UPG.RUS.UPGRADE_WOODEN_CASTLE_SPRINGALD_RUS)
					-- Create egroup
					EGroup_Add(eg_outpost_south, entity_outpost_south)
					-- Add units
					Garrison_Building(None, { egroup = eg_outpost_south, amount = GARRISON_FILL_OUTPOST, player = player5 })
					-- Enable targeting
					EGroup_SetTargetingType(eg_outpost_south, Targeting_Automatic)
					
					-- Notification: Point captured
					UI_CreateEventCueClickable(-1, 15, -1, 0, event_cue_text, "", "low_priority", "", "sfx_ui_event_queue_campaign_objective_start", 255, 255, 255, 255, ECV_Queue, nothing)
					UI_CreateMinimapBlip(mkr_spawn_south_5, 15, "general")
					
					-- Remove UI
					Objective_RemoveUIElements(OBJ_Phase1_VillageDefence_south, 3)
					
					-- Side Objective +1
					if Objective_IsCounterSet(OBJ_Phase2_VillageCapture_side) then
						Objective_IncreaseCounter(OBJ_Phase2_VillageCapture_side)

						if Obj_GetCounterCount(OBJ_Phase2_VillageCapture_side.ID) == Obj_GetCounterMax(OBJ_Phase2_VillageCapture_side.ID) then 
							Objective_Complete(OBJ_Phase2_VillageCapture_side, true, true) 
							
						end
					end
					
					-- Spawn enemey attack
					UnitEntry_DeploySquads(player6, sg_village_south_attacker_3, Unit_Types.wave_city_10m, mkr_spawn_wave_3)
					Cmd_FormationAttackMove(sg_village_south_attacker_3, mkr_spawn_south_5, false)
					Cmd_FormationAttackMove(sg_village_south_attacker_3, mkr_spawn_south_2, true)
					
					-- Start local outpost guard patrol
					Phase2_OutpostGuard_Start(3)
					
				end
			end
		end
	end
	
	-- Send reserve units / Side #1 / Group #5
	if SGroup_Count(sg_village_south_defender_1) <= 15 and village_south_reserves_sent_1 == false then
		Cmd_FormationAttackMove(sg_village_south_defender_6, mkr_spawn_south_5) -- Replace group #1 with #6
		Cmd_FormationAttackMove(sg_village_south_defender_5, mkr_spawn_south_1)
		if AI_Difficulty >= 2 then
			Cmd_FormationAttackMove(sg_village_south_defender_5_rng, mkr_spawn_south_1_rng)
		end
		village_south_reserves_sent_1 = true
	end
	-- Send reserve units / Side #2 / Group #3
	if SGroup_Count(sg_village_south_defender_2) <= 15 and bridge_group_eliminated_2 == false then
		Cmd_FormationAttackMove(sg_village_south_defender_3, mkr_spawn_south_2) -- Replace group #2 with #3
		if AI_Difficulty >= 2 then
			Cmd_FormationAttackMove(sg_village_south_defender_3_rng, mkr_spawn_south_2_rng)
		end
		bridge_group_eliminated_2 = true
	end
	-- Send reserve units / Side #4 / Group #5
	if SGroup_Count(sg_village_south_defender_4) <= 15 and village_south_reserves_sent_4 == false then
		Cmd_FormationAttackMove(sg_village_south_defender_6, mkr_spawn_south_5) -- Replace group #5 with #6
		Cmd_FormationAttackMove(sg_village_south_defender_5, mkr_spawn_south_4)
		if AI_Difficulty >= 2 then
			Cmd_FormationAttackMove(sg_village_south_defender_5_rng, mkr_spawn_south_4_rng)
		end
		village_south_reserves_sent_4 = true
	end
	
-- Capture Outpost / South-4
if SGroup_Count(sg_village_south_defender_4) == 0 then
if entity_outpost_4_south ~= nil and Entity_IsAlive(entity_outpost_4_south) == true then
-- Check Outpost and change owner
if World_OwnsEntity(entity_outpost_4_south) == true or Entity_GetPlayerOwner(entity_outpost_4_south) == player6 then
Entity_SetPlayerOwner(entity_outpost_4_south, player5)

-- Add Springald upgrade
Entity_CompleteUpgrade(entity_outpost_4_south, UPG.RUS.UPGRADE_WOODEN_CASTLE_SPRINGALD_RUS)
-- Refresh egroup and add the current outpost entity before garrisoning
EGroup_Clear(eg_outpost_4_south)
EGroup_Add(eg_outpost_4_south, entity_outpost_4_south)
-- Add units
Garrison_Building(None, { egroup = eg_outpost_4_south, amount = GARRISON_FILL_OUTPOST, player = player5 })
-- Enable targeting
EGroup_SetTargetingType(eg_outpost_4_south, Targeting_Automatic)

-- Notification: Point captured
UI_CreateEventCueClickable(-1, 15, -1, 0, event_cue_text, "", "low_priority", "", "sfx_ui_event_queue_campaign_objective_start", 255, 255, 255, 255, ECV_Queue, nothing)
UI_CreateMinimapBlip(mkr_spawn_south_4, 15, "general")

-- Remove UI
Objective_RemoveUIElements(OBJ_Phase1_VillageDefence_south, 4)

-- Side Objective +1
if Objective_IsCounterSet(OBJ_Phase2_VillageCapture_side) then
Objective_IncreaseCounter(OBJ_Phase2_VillageCapture_side)

if Obj_GetCounterCount(OBJ_Phase2_VillageCapture_side.ID) == Obj_GetCounterMax(OBJ_Phase2_VillageCapture_side.ID) then
Objective_Complete(OBJ_Phase2_VillageCapture_side, true, true)

end
end

-- Start local outpost guard patrol
Phase2_OutpostGuard_Start(4)
end
end
end

-- Capture Village
if SGroup_Count(sg_village_south_defender_all) <= 5 or Objective_IsComplete(OBJ_Phase2_VillageCapture_side) == true then
		if Objective_IsComplete(OBJ_Phase2_VillageCapture_Main) == false then
			
			-- Complete objective
			Objective_Complete(OBJ_Phase2_VillageCapture_Main, true, false)
			Objective_Complete(OBJ_Phase1_VillageDefence_south, false, false)
			
			-- Set Village ownership to Allied AI
			EGroup_SetPlayerOwner(eg_village_south, player5)
			
			-- Enable damage for Town Center
			local TC_South = EGroup_GetClosestEntity(eg_village_south, mkr_tc_south)
			Entity_SetInvulnerable(TC_South, false, -1)
			Entity_SetTargetingType(TC_South, Targeting_Automatic)
			
			-- Add healing ability on Religious building
			EGroup_Filter(eg_village_south, EBP.RUS.BUILDING_UNIT_RELIGIOUS_CONTROL_RUS, FILTER_REMOVE, eg_religious_2)
			EGroup_AddAbility(eg_religious_2, BP_GetAbilityBlueprintByPbgID(202453))

			-- Post-capture support updates for village defense flow
			Phase2_VillageCapture_EnablePostCaptureSupport()
			
			Rule_RemoveMe()
		end
	end
	
end

function Phase2_VillageCapture_EnablePostCaptureSupport()
	village_capture_support_enabled = true

	-- Move static camp guards between player spawns into the village fight
	Cmd_FormationAttackMove(sg_camp_guards_1, mkr_spawn_camp_1, false, false)
	Cmd_FormationAttackMove(sg_camp_guards_1, mkr_village_rally_1, true, false)
	Cmd_FormationAttackMove(sg_camp_guards_2, mkr_spawn_camp_2, false, false)
	Cmd_FormationAttackMove(sg_camp_guards_2, mkr_village_rally_2, true, false)

	-- Force startup so all four guard systems enter the monitor/respawn lifecycle
	-- even if not every outpost was individually captured before phase completion.
	Phase2_OutpostGuard_Start(1, true)
	Phase2_OutpostGuard_Start(2, true)
	Phase2_OutpostGuard_Start(3, true)
	Phase2_OutpostGuard_Start(4, true)

	-- Easy + Intermediate only support systems
	if AI_Difficulty <= 1 then
		-- Trigger once immediately so village support starts right after capture.
		Phase2_VillageCapture_EasyInter_Reinforcements()

		if Rule_Exists(Phase2_VillageCapture_EasyInter_Reinforcements) == false then
			Rule_AddInterval(Phase2_VillageCapture_EasyInter_Reinforcements, 60)
		end
	end
end

function Phase2_VillageCapture_EasyInter_Reinforcements()
	if not village_capture_support_enabled then
		return
	end

	-- Guard against stale sessions where this global may not be initialized yet.
	if sg_village_north_attacker_reinforce == nil then
		sg_village_north_attacker_reinforce = SGroup_CreateIfNotFound("sg_village_north_attacker_reinforce")
	end

	-- Persistent trigger: keep spawning this allied attacker if wiped
	if SGroup_Count(sg_village_north_attacker_reinforce) == 0 then
		UnitEntry_DeploySquads(player5, sg_village_north_attacker_reinforce, Unit_Types.wave_city_10m, mkr_spawn_1)
		Cmd_FormationAttackMove(sg_village_north_attacker_reinforce, mkr_village_rally_2, false, false)
	end
end

function Phase2_VillageCapture_EasyInter_RespawnMonitor()
	Phase2_OutpostGuard_Monitor()
end

function Phase2_VillageCapture_EasyInter_RespawnAllied1()
	village_allied_respawn_pending_1 = false
	Phase2_OutpostGuard_Start(3)
end

function Phase2_VillageCapture_EasyInter_RespawnAllied2()
	village_allied_respawn_pending_2 = false
	Phase2_OutpostGuard_Start(2)
end

function Phase2_VillageCapture_EasyInter_RespawnAllied3()
	village_allied_respawn_pending_3 = false
	Phase2_OutpostGuard_Start(1)
end

function Phase2_VillageCapture_OnComplete()
	
	-- Filter TC
	EGroup_Filter(eg_village_south, EBP.RUS.BUILDING_TOWN_CENTER_RUS, FILTER_REMOVE, eg_tc_south)
	local tc_pos = Util_GetPosition(mkr_tc_south)
	
	-- Add TC to Defend Village objective
	EGroup_AddEGroup(eg_tc_group, eg_tc_south)
	Objective_Start(OBJ_Phase1_VillageDefence_south,true, false)
	
	-- Enable targeting
	EGroup_SetTargetingType(eg_village_south, Targeting_Automatic)
	
	-- Add UI
	Objective_AddUIElements(OBJ_Phase1_VillageDefence_south, tc_pos, true, "$11164881", true) -- "Town Center"
	
	-- Start final objective
	Objective_Start(OBJ_Phase3_FinalKeep_Main,true, false)
	
	-- Start Objective: Capture Siege weapons
	Objective_Start(OBJ_Phase3_SiegeCapture_Main,true, false)
	Objective_Start(OBJ_Phase3_SiegeCapture_side,false, false)
	Objective_Start(OBJ_Phase3_SiegeCapture_info,false, false)
	-- Start Objective: Clear Reinforcements path
	Objective_Start(OBJ_Phase3_CityAssault_Main,true, false)
	
	-- Remove any markers left
	--__Objective_RemoveAssociatedUI(OBJ_Phase1_VillageDefence_south)


end

-------------------------------------------
-- Objective: Capture Siege weapons
-------------------------------------------

function Phase3_SiegeCapture_InitObjectives()
	
	OBJ_Phase3_SiegeCapture_Main = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:19",  -- "Capture the Siege Weapons"
		Type = ObjectiveType_Battle, 
		OnStart = Phase3_SiegeCapture_Start, --when objective start call function
		OnComplete = Phase3_SiegeCapture_OnComplete, -- when objective completes, call function
	}
	OBJ_Phase3_SiegeCapture_side = {
		Title ="$ae948c95a8c5425d8de28e0c193e0be9:20" ,  -- "Defeat all resistance in the Southern Village section"
		Type = ObjectiveType_Primary, 
		Parent = OBJ_Phase3_SiegeCapture_Main,
	}
	OBJ_Phase3_SiegeCapture_info = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:21",  -- "Capturing the camp unlocks the Siege Engineer upgrade"
		Type = ObjectiveType_Tip, 
		Parent = OBJ_Phase3_SiegeCapture_Main,
	}
	
	Objective_Register(OBJ_Phase3_SiegeCapture_Main)
	Objective_Register(OBJ_Phase3_SiegeCapture_side)
	Objective_Register(OBJ_Phase3_SiegeCapture_info)

end

function Phase3_SiegeCapture_Start()
	
	-- Spawn defenders
	Spawn_SiegeCamp_Enemey()
	
	-- Add objective conditions
	Rule_Add(Phase3_SiegeCapture_CountConditions)
	
	-- Add UI
	Objective_AddUIElements(OBJ_Phase3_SiegeCapture_Main, mkr_spawn_siege_4, true, "$11164271", true) -- "Siege Forces"

	
end

function Phase3_SiegeCapture_CountConditions()
	
	if Objective_IsComplete(OBJ_Phase3_SiegeCapture_Main) == false then
		-- Capture Bombards // ADD: Unlock ram upgrades
		if SGroup_Count(sg_siege_defender_all) <= 5 then
			local bombard_count = SGroup_Count(sg_siege_capture)
			if bombard_count < 8 then
				print(string.format("[OBJECTIVE] Phase3_SiegeCapture partial bombard transfer: found %d/8 in sg_siege_capture", bombard_count))
			end

			-- Safe iteration: distribute bombards evenly to 4 players, with nil protection
			local players_table = { player1, player2, player3, player4 }
			for i = 1, math.min(bombard_count, 8) do
				local squad = SGroup_GetSquadAt(sg_siege_capture, i)
				if squad ~= nil then
					local owner_index = math.ceil(i / 2)  -- 1-2→p1, 3-4→p2, 5-6→p3, 7-8→p4
					Squad_SetPlayerOwner(squad, players_table[owner_index])
				else
					print(string.format("[ERROR] Phase3_SiegeCapture: nil squad at index %d (count=%d)", i, bombard_count))
				end
			end
			
			-- Bombards remain invulnerable until OnComplete sets false,-1
			SGroup_SetInvulnerable(sg_siege_capture, true, -1)
			
			-- Notification
			local event_cue_siege = Loc_FormatText("$ae948c95a8c5425d8de28e0c193e0be9:22")  -- "Siege Engineers unlocked for infantry!"
			UI_CreateEventCueClickable(-1, 15, -1, 0, event_cue_siege, "", "low_priority", "", "sfx_ui_event_queue_campaign_high_priority", 255, 255, 255, 255, ECV_Queue, nothing)
			UI_CreateMinimapBlip(mkr_spawn_siege_5, 10, "general")
			
			-- Siege unlocks: use hardened DLC-aware helpers (nil-safe CBA_SIEGE_TABLE + IsCivFamily chain)
			for _, player in pairs(PLAYERS) do
				-- Mangonel / NestOfBees / Ribauldequin / Double siege — Intermediate -
				if AI_Difficulty <= 1 then
					_ApplySiegeRestrictions(player, ITEM_DEFAULT)
				end
				-- Siege Engineers upgrade + field constructs — Hard +
				if AI_Difficulty >= 2 then
					_ApplySiegeEngineersRestrictions(player, ITEM_DEFAULT)
				end
				-- Siege Workshop — Absurd only
				if AI_Difficulty == 6 then
					local ebp_workshop = TryGetCivilizationEntity(player.raceName, AGS_BP_WORKSHOP)
					if ebp_workshop then
						Player_SetEntityProductionAvailability(player.id, ebp_workshop, ITEM_DEFAULT)
					end
				end
			end
			
			-- Remove UI
			Objective_RemoveUIElements(OBJ_Phase3_SiegeCapture_Main, 1)
			
			-- Complete objective
			Objective_Complete(OBJ_Phase3_SiegeCapture_Main, true, false)
			
			Rule_RemoveMe()
			
		end
		
		-- Send reserves to choke point #1
		if SGroup_Count(sg_siege_defender_1) == 0 and siege_reserves_sent == false then
			Cmd_FormationAttackMove(sg_siege_defender_5, mkr_spawn_siege_1)
			siege_reserves_sent = true
		end
		-- Send reserves to choke point #2
		if SGroup_Count(sg_siege_defender_2) == 0 and siege_reserves_sent == false then
			Cmd_FormationAttackMove(sg_siege_defender_5, mkr_spawn_siege_2)
			siege_reserves_sent = true
		end
		
		-- Send choke point group to the camp
		if SGroup_Count(sg_siege_defender_3) == 0 and siege_guards_retreated == false then
			
			-- Group #1
			if SGroup_Count(sg_siege_defender_1) >= 1 then
				Cmd_FormationAttackMove(sg_siege_defender_1, mkr_spawn_siege_5, false)
				Cmd_FormationAttackMove(sg_siege_defender_1, mkr_spawn_siege_3, true)
			end
			
			-- Group #2
			if SGroup_Count(sg_siege_defender_2) >= 1 then
				Cmd_FormationAttackMove(sg_siege_defender_2, mkr_spawn_siege_5, false)
				Cmd_FormationAttackMove(sg_siege_defender_2, mkr_spawn_siege_3, true)
			end
			
			siege_guards_retreated = true
		end
		
		
		
	end		
end

function Phase3_SiegeCapture_OnComplete()
	
	-- Enable DMG for Bombards
	SGroup_SetInvulnerable(sg_siege_capture, false, -1)

	-- Unlock bombard/culverin/great bombard production after Bombard objective completion.
	for _, player in pairs(PLAYERS) do
		_ApplyBombardObjectiveRestrictions(player, ITEM_DEFAULT)
	end
	
	-- Deploy side 4 siege army after bombard objective is complete
	AlliedSiege_Deploy(4)
	
end

