local function Phase1_RovingPatrol_GetName(side)
	if side == 1 then
		return "phase1_roving_side1"
	end
	return "phase1_roving_side2"
end

local function Phase1_RovingPatrol_GetSGroup(side)
	if side == 1 then
		return sg_roving_patrol_side1
	end
	return sg_roving_patrol_side2
end

local function Phase1_RovingPatrol_GetOutpostEntity(outpost_id)
	if outpost_id == 1 then
		return cap_outpost_1
	elseif outpost_id == 2 then
		return cap_outpost_2
	elseif outpost_id == 3 then
		return cap_outpost_3
	end
	return cap_outpost_4
end

local function Phase1_RovingPatrol_GetOutpostMarker(outpost_id)
	if outpost_id == 1 then
		return mkr_spawn_outpost_1
	elseif outpost_id == 2 then
		return mkr_spawn_outpost_2
	elseif outpost_id == 3 then
		return mkr_spawn_outpost_3
	end
	return mkr_spawn_outpost_4
end

local function Phase1_RovingPatrol_GetOutpostRngMarker(outpost_id)
	if outpost_id == 1 then
		return mkr_spawn_outpost_1_rng
	elseif outpost_id == 2 then
		return mkr_spawn_outpost_2_rng
	elseif outpost_id == 3 then
		return mkr_spawn_outpost_3_rng
	end
	return mkr_spawn_outpost_4_rng
end

local function Phase1_RovingPatrol_GetSpawnMarker(outpost_id)
	if outpost_id == 1 then
		return mkr_spawn_1
	elseif outpost_id == 2 then
		return mkr_spawn_2
	elseif outpost_id == 3 then
		return mkr_spawn_3
	end
	return mkr_spawn_4
end

local function Phase1_RovingPatrol_GetAssistRoute(side)
	if side == 1 then
		return patrol_roving_side1_assist
	end
	return patrol_roving_side2_assist
end

local function Phase1_RovingPatrol_GetTowerPair(side)
	if side == 1 then
		return 1, 2
	end
	return 3, 4
end

local function Phase1_RovingPatrol_IsOutpostOwned(outpost_id)
	local entity = Phase1_RovingPatrol_GetOutpostEntity(outpost_id)
	if entity == nil then
		return false
	end
	if World_OwnsEntity(entity) == true then
		return false
	end
	if Entity_IsAlive(entity) ~= true then
		return false
	end
	return Entity_GetPlayerOwner(entity) == player5
end

local function Phase1_RovingPatrol_GetPreferredOutpost(side)
	local first_outpost, second_outpost = Phase1_RovingPatrol_GetTowerPair(side)
	local preferred_outpost = phase1_patrol_side1_spawn_outpost
	if side == 2 then
		preferred_outpost = phase1_patrol_side2_spawn_outpost
	end

	local sibling_outpost = first_outpost
	if preferred_outpost == first_outpost then
		sibling_outpost = second_outpost
	elseif preferred_outpost == second_outpost then
		sibling_outpost = first_outpost
	end

	if preferred_outpost ~= nil and Phase1_RovingPatrol_IsOutpostOwned(preferred_outpost) == true then
		return preferred_outpost
	end
	if Phase1_RovingPatrol_IsOutpostOwned(sibling_outpost) == true then
		return sibling_outpost
	end
	if Phase1_RovingPatrol_IsOutpostOwned(first_outpost) == true then
		return first_outpost
	end
	if Phase1_RovingPatrol_IsOutpostOwned(second_outpost) == true then
		return second_outpost
	end
	return nil
end

local function Phase1_RovingPatrol_GetSpawnInfo(side)
	local outpost_id = Phase1_RovingPatrol_GetPreferredOutpost(side)
	if outpost_id == nil then
		return nil, nil
	end

	if side == 1 then
		phase1_patrol_side1_spawn_outpost = outpost_id
		phase1_patrol_side1_anchor_outpost = outpost_id
	else
		phase1_patrol_side2_spawn_outpost = outpost_id
		phase1_patrol_side2_anchor_outpost = outpost_id
	end

	return outpost_id, Phase1_RovingPatrol_GetSpawnMarker(outpost_id)
end

local function Phase1_RovingPatrol_HasFullSideControl(side)
	local first_outpost, second_outpost = Phase1_RovingPatrol_GetTowerPair(side)
	return Phase1_RovingPatrol_IsOutpostOwned(first_outpost) == true and Phase1_RovingPatrol_IsOutpostOwned(second_outpost) == true
end

local function Phase1_RovingPatrol_GetBaselineRoute(side)
	if phase1_patrol_mode == PHASE1_PATROL_MODE_FLANK then
		if side == 1 then
			return patrol_roving_side1_flank_guard
		end
		return patrol_roving_side2_flank_guard
	end

	if Phase1_RovingPatrol_HasFullSideControl(side) == true then
		if side == 1 then
			return patrol_roving_side1_cycle
		end
		return patrol_roving_side2_cycle
	end

	local outpost_id = phase1_patrol_side1_anchor_outpost
	if side == 2 then
		outpost_id = phase1_patrol_side2_anchor_outpost
	end
	if outpost_id == nil or Phase1_RovingPatrol_IsOutpostOwned(outpost_id) == false then
		outpost_id = Phase1_RovingPatrol_GetPreferredOutpost(side)
	end
	if outpost_id == nil then
		local first_outpost = Phase1_RovingPatrol_GetTowerPair(side)
		outpost_id = first_outpost
	end

	return {
		Phase1_RovingPatrol_GetOutpostMarker(outpost_id),
		Phase1_RovingPatrol_GetOutpostRngMarker(outpost_id),
	}
end

local function Phase1_RovingPatrol_GetAnchorMarker(side)
	if phase1_patrol_mode == PHASE1_PATROL_MODE_FLANK then
		if side == 1 then
			return mkr_wave_1_path_flank
		end
		return mkr_wave_2_path_flank
	end

	local outpost_id = phase1_patrol_side1_anchor_outpost
	if side == 2 then
		outpost_id = phase1_patrol_side2_anchor_outpost
	end
	if outpost_id == nil or Phase1_RovingPatrol_IsOutpostOwned(outpost_id) == false then
		outpost_id = Phase1_RovingPatrol_GetPreferredOutpost(side)
	end
	if outpost_id == nil then
		return nil
	end
	return Phase1_RovingPatrol_GetOutpostMarker(outpost_id)
end

local function Phase1_RovingPatrol_GetLeashRadius()
	if phase1_patrol_mode == PHASE1_PATROL_MODE_FLANK then
		return PHASE1_PATROL_FLANK_LEASH
	end
	return PHASE1_PATROL_OUTPOST_LEASH
end

local function Phase1_RovingPatrol_SetRoute(side, route)
	if RovingArmy_Find == nil or RovingArmy_SetTargets == nil then
		return
	end

	local army = RovingArmy_Find(Phase1_RovingPatrol_GetName(side))
	if army ~= nil then
		RovingArmy_SetTargets(army, route)
	end
end

local function Phase1_RovingPatrol_ClearAssist(side)
	if side == 1 then
		phase1_patrol_side1_assisting = false
		phase1_patrol_side1_assist_until = 0
	else
		phase1_patrol_side2_assisting = false
		phase1_patrol_side2_assist_until = 0
	end
end

local function Phase1_RovingPatrol_EnsureMonitor()
	if phase1_patrol_monitor_active == false and Rule_Exists(Phase1_RovingPatrol_Monitor) == false then
		Rule_AddInterval(Phase1_RovingPatrol_Monitor, 5)
		phase1_patrol_monitor_active = true
	end
end

local function Phase1_RovingPatrol_OnDeath(side)
	local respawn_due = World_GetGameTime() + DC.north_attacker_respawn_timer
	Phase1_RovingPatrol_ClearAssist(side)

	if side == 1 then
		phase1_patrol_side1_respawn_due = respawn_due
	else
		phase1_patrol_side2_respawn_due = respawn_due
	end
end

local function Phase1_RovingPatrol_EnsureSide(side)
	if RovingArmy_Create == nil or RovingArmy_Start == nil or RovingArmy_Find == nil then
		print("[ROVING_PATROL] RovingArmy API not available; verify scar/roving_army.scar import")
		return
	end

	local _, spawn_marker = Phase1_RovingPatrol_GetSpawnInfo(side)
	if spawn_marker == nil then
		return
	end

	local name = Phase1_RovingPatrol_GetName(side)
	local sgroup = Phase1_RovingPatrol_GetSGroup(side)
	local route = Phase1_RovingPatrol_GetBaselineRoute(side)
	local army = RovingArmy_Find(name)

	if SGroup_Count(sgroup) == 0 then
		UnitEntry_DeploySquads(player5, sgroup, Unit_Types.units_allied_roving_patrol, spawn_marker)
	end

	if army == nil then
		army = RovingArmy_Create({
			name = name,
			player = player5,
			sgroup = sgroup,
			targets = route,
			target_order = ROVING_ORDER_PATROL,
			poll_interval = 2,
			arrival_distance = 20,
			idle_time = 5,
			on_death = function()
				Phase1_RovingPatrol_OnDeath(side)
			end,
		})
		RovingArmy_Start(army)
	else
		Phase1_RovingPatrol_SetRoute(side, route)
	end

	Phase1_RovingPatrol_ClearAssist(side)
	if side == 1 then
		phase1_patrol_side1_started = true
		phase1_patrol_side1_respawn_due = 0
	else
		phase1_patrol_side2_started = true
		phase1_patrol_side2_respawn_due = 0
	end

	Phase1_RovingPatrol_EnsureMonitor()
end

local function Phase1_RovingPatrol_MarkTowerCaptured(outpost_id)
	if outpost_id == 1 and phase1_patrol_tower_counted_1 == false then
		phase1_patrol_tower_counted_1 = true
		phase1_patrol_side1_captures = phase1_patrol_side1_captures + 1
		if phase1_patrol_side1_captures == 1 then
			phase1_patrol_side1_primary_outpost = 1
			phase1_patrol_side1_spawn_outpost = 1
			phase1_patrol_side1_anchor_outpost = 1
		end
		Phase1_RovingPatrol_EnsureSide(1)
		return
	end

	if outpost_id == 2 and phase1_patrol_tower_counted_2 == false then
		phase1_patrol_tower_counted_2 = true
		phase1_patrol_side1_captures = phase1_patrol_side1_captures + 1
		if phase1_patrol_side1_captures == 1 then
			phase1_patrol_side1_primary_outpost = 2
			phase1_patrol_side1_spawn_outpost = 2
			phase1_patrol_side1_anchor_outpost = 2
		end
		Phase1_RovingPatrol_EnsureSide(1)
		return
	end

	if outpost_id == 3 and phase1_patrol_tower_counted_3 == false then
		phase1_patrol_tower_counted_3 = true
		phase1_patrol_side2_captures = phase1_patrol_side2_captures + 1
		if phase1_patrol_side2_captures == 1 then
			phase1_patrol_side2_primary_outpost = 3
			phase1_patrol_side2_spawn_outpost = 3
			phase1_patrol_side2_anchor_outpost = 3
		end
		Phase1_RovingPatrol_EnsureSide(2)
		return
	end

	if outpost_id == 4 and phase1_patrol_tower_counted_4 == false then
		phase1_patrol_tower_counted_4 = true
		phase1_patrol_side2_captures = phase1_patrol_side2_captures + 1
		if phase1_patrol_side2_captures == 1 then
			phase1_patrol_side2_primary_outpost = 4
			phase1_patrol_side2_spawn_outpost = 4
			phase1_patrol_side2_anchor_outpost = 4
		end
		Phase1_RovingPatrol_EnsureSide(2)
		return
	end
end

function Phase1_RovingPatrol_Init()
	phase1_patrol_mode = PHASE1_PATROL_MODE_OUTPOST
	phase1_patrol_side1_captures = 0
	phase1_patrol_side2_captures = 0
	phase1_patrol_side1_started = false
	phase1_patrol_side2_started = false
	phase1_patrol_side1_primary_outpost = 1
	phase1_patrol_side2_primary_outpost = 3
	phase1_patrol_side1_spawn_outpost = 1
	phase1_patrol_side2_spawn_outpost = 3
	phase1_patrol_side1_anchor_outpost = 1
	phase1_patrol_side2_anchor_outpost = 3
	phase1_patrol_side1_respawn_due = 0
	phase1_patrol_side2_respawn_due = 0
	phase1_patrol_tower_counted_1 = false
	phase1_patrol_tower_counted_2 = false
	phase1_patrol_tower_counted_3 = false
	phase1_patrol_tower_counted_4 = false
	phase1_patrol_side1_assisting = false
	phase1_patrol_side2_assisting = false
	phase1_patrol_side1_assist_until = 0
	phase1_patrol_side2_assist_until = 0
	phase1_patrol_side1_last_redirect = 0
	phase1_patrol_side2_last_redirect = 0
	phase1_patrol_monitor_active = false
end

local function Phase1_RovingPatrol_HasNearbyPlayerSupport(side, marker)
	local player_groups = {}
	if side == 1 then
		player_groups = {
			sg_player1_start,
			sg_player1_unique,
			sg_player1_reinforcements,
			sg_player2_start,
			sg_player2_unique,
			sg_player2_reinforcements,
		}
	else
		player_groups = {
			sg_player3_start,
			sg_player3_unique,
			sg_player3_reinforcements,
			sg_player4_start,
			sg_player4_unique,
			sg_player4_reinforcements,
		}
	end

	for _, sgroup in pairs(player_groups) do
		if sgroup ~= nil and SGroup_Count(sgroup) > 0 then
			local distance_ok, distance = pcall(Util_GetDistance, sgroup, marker)
			if distance_ok and distance <= PHASE1_PATROL_PLAYER_SUPPORT_RANGE then
				return true
			end
		end
	end

	return false
end

local function Phase1_RovingPatrol_GetThreatCount(side)
	if side == 1 then
		return SGroup_Count(sg_waves_main_1_01b) + SGroup_Count(sg_waves_main_1_01d) + SGroup_Count(sg_waves_main_1_07) + SGroup_Count(sg_waves_main_1_08) + SGroup_Count(sg_waves_main_1_09) + SGroup_Count(sg_waves_main_1_10) + SGroup_Count(sg_waves_main_1_11)
	end
	return SGroup_Count(sg_waves_main_2_01b) + SGroup_Count(sg_waves_main_2_01d) + SGroup_Count(sg_waves_main_2_07) + SGroup_Count(sg_waves_main_2_08) + SGroup_Count(sg_waves_main_2_09) + SGroup_Count(sg_waves_main_2_10) + SGroup_Count(sg_waves_main_2_11)
end

local function Phase1_RovingPatrol_SideNeedsAssist(side)
	local threat_count = Phase1_RovingPatrol_GetThreatCount(side)
	if threat_count <= 0 then
		return false
	end

	local patrol_count = SGroup_Count(Phase1_RovingPatrol_GetSGroup(side))
	if patrol_count <= 0 then
		return false
	end

	local assist_route = Phase1_RovingPatrol_GetAssistRoute(side)
	local assist_marker = assist_route[1]
	local has_player_support = Phase1_RovingPatrol_HasNearbyPlayerSupport(side, assist_marker)
	local enemy_force_is_small = threat_count <= math.max(6, math.floor(patrol_count * PHASE1_PATROL_FORCE_RATIO))

	return has_player_support == true or enemy_force_is_small == true
end

local function Phase1_RovingPatrol_TryRespawn(side, now)
	local started = phase1_patrol_side1_started
	local respawn_due = phase1_patrol_side1_respawn_due
	if side == 2 then
		started = phase1_patrol_side2_started
		respawn_due = phase1_patrol_side2_respawn_due
	end

	if started == false or DC.patrol_respawn ~= true then
		return
	end
	if SGroup_Count(Phase1_RovingPatrol_GetSGroup(side)) > 0 then
		return
	end
	if respawn_due == 0 or now < respawn_due then
		return
	end
	if Phase1_RovingPatrol_GetSpawnInfo(side) == nil then
		return
	end

	Phase1_RovingPatrol_EnsureSide(side)
end

local function Phase1_RovingPatrol_EnforceLeash(side)
	local sgroup = Phase1_RovingPatrol_GetSGroup(side)
	if SGroup_Count(sgroup) == 0 then
		return
	end

	local anchor_marker = Phase1_RovingPatrol_GetAnchorMarker(side)
	if anchor_marker == nil then
		return
	end

	local distance_ok, distance = pcall(Util_GetDistance, sgroup, anchor_marker)
	if distance_ok and distance > Phase1_RovingPatrol_GetLeashRadius() then
		Phase1_RovingPatrol_ClearAssist(side)
		Phase1_RovingPatrol_SetRoute(side, Phase1_RovingPatrol_GetBaselineRoute(side))
	end
end

local function Phase1_RovingPatrol_UpdateSideAssist(side, now)
	local started = phase1_patrol_side1_started
	local assisting = phase1_patrol_side1_assisting
	local assist_until = phase1_patrol_side1_assist_until
	local last_redirect = phase1_patrol_side1_last_redirect

	if side == 2 then
		started = phase1_patrol_side2_started
		assisting = phase1_patrol_side2_assisting
		assist_until = phase1_patrol_side2_assist_until
		last_redirect = phase1_patrol_side2_last_redirect
	end

	if started == false then
		return
	end

	if phase1_patrol_mode == PHASE1_PATROL_MODE_OUTPOST then
		if side == 1 and Phase1_RovingPatrol_HasFullSideControl(1) == false then
			return
		end
		if side == 2 and Phase1_RovingPatrol_HasFullSideControl(2) == false then
			return
		end
	end

	local needs_assist = Phase1_RovingPatrol_SideNeedsAssist(side)

	if needs_assist == true and assisting == false and now >= (last_redirect + PHASE1_PATROL_ASSIST_COOLDOWN) then
		Phase1_RovingPatrol_SetRoute(side, Phase1_RovingPatrol_GetAssistRoute(side))
		assisting = true
		assist_until = now + PHASE1_PATROL_ASSIST_DURATION
		last_redirect = now
	elseif assisting == true and (needs_assist == false or now >= assist_until) then
		Phase1_RovingPatrol_SetRoute(side, Phase1_RovingPatrol_GetBaselineRoute(side))
		assisting = false
		assist_until = 0
	end

	if side == 1 then
		phase1_patrol_side1_assisting = assisting
		phase1_patrol_side1_assist_until = assist_until
		phase1_patrol_side1_last_redirect = last_redirect
	else
		phase1_patrol_side2_assisting = assisting
		phase1_patrol_side2_assist_until = assist_until
		phase1_patrol_side2_last_redirect = last_redirect
	end
end

function Phase1_RovingPatrol_Monitor()
	if phase1_patrol_monitor_active == false then
		Rule_RemoveMe()
		return
	end

	if OBJ_Phase1_VillageDefence_Main ~= nil and Objective_IsFailed(OBJ_Phase1_VillageDefence_Main) == true then
		phase1_patrol_monitor_active = false
		Rule_RemoveMe()
		return
	end

	local now = World_GetGameTime()
	Phase1_RovingPatrol_TryRespawn(1, now)
	Phase1_RovingPatrol_TryRespawn(2, now)
	Phase1_RovingPatrol_EnforceLeash(1)
	Phase1_RovingPatrol_EnforceLeash(2)
	Phase1_RovingPatrol_UpdateSideAssist(1, now)
	Phase1_RovingPatrol_UpdateSideAssist(2, now)
end

function Phase1_RovingPatrol_TransitionToFlankGuard()
	phase1_patrol_mode = PHASE1_PATROL_MODE_FLANK
	Phase1_RovingPatrol_ClearAssist(1)
	Phase1_RovingPatrol_ClearAssist(2)
	Phase1_RovingPatrol_EnsureSide(1)
	Phase1_RovingPatrol_EnsureSide(2)
	Phase1_RovingPatrol_SetRoute(1, Phase1_RovingPatrol_GetBaselineRoute(1))
	Phase1_RovingPatrol_SetRoute(2, Phase1_RovingPatrol_GetBaselineRoute(2))
	Phase1_RovingPatrol_EnsureMonitor()
end

local function Phase2_OutpostGuard_GetName(index)
	return "phase2_outpost_guard_" .. tostring(index)
end

local function Phase2_OutpostGuard_GetSGroup(index)
	if index == 1 then
		return sg_phase2_outpost_guard_1
	elseif index == 2 then
		return sg_phase2_outpost_guard_2
	elseif index == 3 then
		return sg_phase2_outpost_guard_3
	end
	return sg_phase2_outpost_guard_4
end

local function Phase2_OutpostGuard_HasLiveUnits(index)
	local sgroup = Phase2_OutpostGuard_GetSGroup(index)
	if sgroup == nil then
		return false
	end

	for i = 1, SGroup_Count(sgroup) do
		local squad = SGroup_GetSquadAt(sgroup, i)
		if squad ~= nil and Squad_IsAlive(squad) == true then
			return true
		end
	end

	return false
end

local function Phase2_OutpostGuard_GetSpawnMarker(index)
	if index == 1 or index == 2 then
		return mkr_spawn_2
	end
	return mkr_spawn_3
end

local function Phase2_OutpostGuard_GetRoute(index)
	if index == 1 then
		return patrol_phase2_outpost_guard_1
	elseif index == 2 then
		return patrol_phase2_outpost_guard_2
	elseif index == 3 then
		return patrol_phase2_outpost_guard_3
	end
	return patrol_phase2_outpost_guard_4
end

local function Phase2_OutpostGuard_IsAnchorValid(index)
	local entity = nil
	if index == 1 then
		entity = entity_kremlin
	elseif index == 2 then
		entity = entity_outpost_bridge
	elseif index == 3 then
		entity = entity_outpost_south
	else
		entity = entity_outpost_4_south
	end

	if entity == nil then
		return false
	end
	if World_OwnsEntity(entity) == true then
		return false
	end
	if Entity_IsAlive(entity) ~= true then
		return false
	end
	return Entity_GetPlayerOwner(entity) == player5
end

local function Phase2_OutpostGuard_EnsureMonitor()
	if phase2_outpost_guard_monitor_active == false and Rule_Exists(Phase2_OutpostGuard_Monitor) == false then
		Rule_AddInterval(Phase2_OutpostGuard_Monitor, 5)
		phase2_outpost_guard_monitor_active = true
	end
end

local function Phase2_OutpostGuard_AreRespawnsAllowed()
	if village_capture_support_enabled ~= true then
		return false
	end
	if OBJ_Phase1_VillageDefence_south == nil or Objective_IsStarted(OBJ_Phase1_VillageDefence_south) ~= true then
		return true
	end
	if eg_tc_south == nil then
		return true
	end
	return EGroup_Count(eg_tc_south) > 0
end

local function Phase2_OutpostGuard_CancelRespawns()
	for index = 1, 4 do
		phase2_outpost_guard_respawn_due[index] = 0
		if Phase2_OutpostGuard_HasLiveUnits(index) ~= true and RovingArmy_Find(Phase2_OutpostGuard_GetName(index)) == nil then
			phase2_outpost_guard_started[index] = false
		end
	end
end

local function Phase2_OutpostGuard_OnDeath(index)
	if Phase2_OutpostGuard_AreRespawnsAllowed() ~= true then
		phase2_outpost_guard_respawn_due[index] = 0
		phase2_outpost_guard_started[index] = false
		return
	end
	phase2_outpost_guard_respawn_due[index] = World_GetGameTime() + DC.north_attacker_respawn_timer
end

function Phase2_OutpostGuard_Start(index, force_start)
	if RovingArmy_Create == nil or RovingArmy_Start == nil or RovingArmy_Find == nil then
		return
	end
	if force_start ~= true and Phase2_OutpostGuard_IsAnchorValid(index) == false then
		return
	end

	local name = Phase2_OutpostGuard_GetName(index)
	local sgroup = Phase2_OutpostGuard_GetSGroup(index)
	local spawn_marker = Phase2_OutpostGuard_GetSpawnMarker(index)
	local route = Phase2_OutpostGuard_GetRoute(index)
	local army = RovingArmy_Find(name)

	if SGroup_Count(sgroup) == 0 then
		UnitEntry_DeploySquads(player5, sgroup, Unit_Types.units_allied_outpost_guard, spawn_marker)
	end

	if army == nil then
		army = RovingArmy_Create({
			name = name,
			player = player5,
			sgroup = sgroup,
			targets = route,
			target_order = ROVING_ORDER_PATROL,
			poll_interval = 2,
			arrival_distance = 18,
			idle_time = 5,
			on_death = function()
				Phase2_OutpostGuard_OnDeath(index)
			end,
		})
		RovingArmy_Start(army)
	else
		RovingArmy_SetTargets(army, route)
	end

	phase2_outpost_guard_started[index] = true
	phase2_outpost_guard_respawn_due[index] = 0
	Phase2_OutpostGuard_EnsureMonitor()
end

local function Phase2_OutpostGuard_TryRespawn(index, now)
	if phase2_outpost_guard_started[index] ~= true then
		return
	end
	if Phase2_OutpostGuard_AreRespawnsAllowed() ~= true then
		phase2_outpost_guard_respawn_due[index] = 0
		phase2_outpost_guard_started[index] = false
		return
	end
	if Phase2_OutpostGuard_HasLiveUnits(index) == true then
		return
	end
	if phase2_outpost_guard_respawn_due[index] == 0 or now < phase2_outpost_guard_respawn_due[index] then
		return
	end
	if Phase2_OutpostGuard_IsAnchorValid(index) == false then
		return
	end

	Phase2_OutpostGuard_Start(index)
end

function Phase2_OutpostGuard_Monitor()
	if phase2_outpost_guard_monitor_active == false then
		Rule_RemoveMe()
		return
	end

	local active_guards = 0
	local now = World_GetGameTime()
	for index = 1, 4 do
		if phase2_outpost_guard_started[index] == true then
			active_guards = active_guards + 1
			local army = RovingArmy_Find(Phase2_OutpostGuard_GetName(index))
			if Phase2_OutpostGuard_IsAnchorValid(index) == false then
				if army ~= nil and RovingArmy_Disband ~= nil then
					RovingArmy_Disband(army)
				end
				if Phase2_OutpostGuard_AreRespawnsAllowed() == true then
					if phase2_outpost_guard_respawn_due[index] == 0 then
						phase2_outpost_guard_respawn_due[index] = now + DC.north_attacker_respawn_timer
					end
				else
					phase2_outpost_guard_started[index] = false
					phase2_outpost_guard_respawn_due[index] = 0
				end
			elseif army ~= nil and Phase2_OutpostGuard_HasLiveUnits(index) == true then
				local distance_ok, distance = pcall(Util_GetDistance, Phase2_OutpostGuard_GetSGroup(index), Phase2_OutpostGuard_GetSpawnMarker(index))
				if distance_ok == true and distance > PHASE2_OUTPOST_GUARD_LEASH then
					RovingArmy_SetTargets(army, Phase2_OutpostGuard_GetRoute(index))
				end
			else
				Phase2_OutpostGuard_TryRespawn(index, now)
			end
		end
	end

	if active_guards == 0 and village_capture_support_enabled ~= true then
		phase2_outpost_guard_monitor_active = false
		Rule_RemoveMe()
	end
end

function Phase1_Checkpoint_InitObjectives()
	
	OBJ_Phase1_Checkpoint_main = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:6" ,  -- "Capture the Checkpoint for Reinforcements"
		Type = ObjectiveType_Battle, 
		OnStart = Phase1_Checkpoint_Start, --when objective start call function
		OnComplete = Phase1_Checkpoint_OnComplete, -- when objective completes, call function
	}
	OBJ_Phase1_Checkpoint_clear = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:7",  -- "Defeat all resistance inside the Checkpoint"
		Type = ObjectiveType_Battle, 
		Parent = OBJ_Phase1_Checkpoint_main,
	}
	OBJ_Phase1_Checkpoint_regroup = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:14",  -- "Regroup with your team, avoid losing all your units!"
		Type = ObjectiveType_Tip, 
		Parent = OBJ_Phase1_Checkpoint_main,
	}
	
	Objective_Register(OBJ_Phase1_Checkpoint_main)
	Objective_Register(OBJ_Phase1_Checkpoint_clear)
	Objective_Register(OBJ_Phase1_Checkpoint_regroup)
	
end

function Phase1_Checkpoint_Start()

	Objective_AddUIElements(OBJ_Phase1_Checkpoint_main, mkr_spawn_checkpoint_1, true, "$ae948c95a8c5425d8de28e0c193e0be9:15", true) -- "Checkpoint"
	-- Added UI marker minimap
	Objective_AddUIElements(OBJ_Phase1_Checkpoint_clear, mkr_spawn_checkpoint_1, true, "$ae948c95a8c5425d8de28e0c193e0be9:15", true) -- "Checkpoint"
	Objective_AddUIElements(OBJ_Phase1_Checkpoint_regroup, mkr_obj_regroup, true, "$40836", true, 4, nil, nil, "icons/objectives/capture_objective", "CaptureObjectiveTemplate") -- "Rally point"
	
	-- Add rules
	Rule_AddInterval(Phase1_Checkpoint_count, 1)
	Rule_AddInterval(Phase1_Checkpoint_reserves, 1)
	Rule_EnterProximity(Phase1_Checkpoint_regroup, ALL, sg_players_all_start, mkr_obj_regroup, 50, false, {})
	
end

-- Objective Main: Clear checkpoint
function Phase1_Checkpoint_count()

	if Objective_IsComplete(OBJ_Phase1_Checkpoint_main) == false then	
		if SGroup_Count(sg_checkpoint_group_all) == 0  then
			-- Outpost
			EGroup_SetPlayerOwner(eg_outpost_checkpoint, player5)
			Cmd_InstantUpgrade(eg_outpost_checkpoint, UPG.RUS.UPGRADE_WOODEN_CASTLE_SPRINGALD_RUS)
			Garrison_Building(None, { egroup = eg_outpost_checkpoint, amount = GARRISON_FILL_OUTPOST, player = player5 })
			-- Objective
			Objective_RemoveUIElements(OBJ_Phase1_Checkpoint_main, 1)
			Objective_RemoveUIElements(OBJ_Phase1_Checkpoint_clear, 1)
			Objective_Complete(OBJ_Phase1_Checkpoint_main, true, true) 
			
			-- Check 'regroup' objective / Remove UI
			if Objective_IsComplete(OBJ_Phase1_Checkpoint_regroup) == false then
				Objective_Stop(OBJ_Phase1_Checkpoint_regroup)
				Objective_RemoveUIElements(OBJ_Phase1_Checkpoint_regroup, 1)
			end
			
			
			Rule_RemoveMe()
		end	
	else
		Rule_RemoveMe()
	end
	
end
-- Objective Side: Regroup 
function Phase1_Checkpoint_regroup()
	
	if Objective_IsComplete(OBJ_Phase1_Checkpoint_regroup) == false then
		-- Complete objective, remove UI
		Objective_Complete(OBJ_Phase1_Checkpoint_regroup, true, true) 
		Objective_Stop(OBJ_Phase1_Checkpoint_regroup)
		Objective_RemoveUIElements(OBJ_Phase1_Checkpoint_regroup, 1)
		Rule_RemoveMe()
	else
		Rule_RemoveMe()
	end
	
	
end

function Phase1_Checkpoint_reserves()

	if SGroup_Count(sg_checkpoint_group_all) < 0.8 * count_checkpoint_all then
		if SGroup_Count(sg_checkpoint_units_4) >= 1 then
			Cmd_Ability(sg_checkpoint_units_4, BP_GetAbilityBlueprint("core_formation_line"))
			Cmd_FormationAttackMove(sg_checkpoint_units_4, mkr_spawn_checkpoint_1)
			Rule_RemoveMe()
		else
			Rule_RemoveMe()
		end
	end
	
end

-- Reinforcements
function Phase1_Checkpoint_Player1()
	
	local player1_civ = Player_GetRaceName(player1)
	
	-- Spawn Player 1 / Select faction
	if player1_civ == "malian" then
		UnitEntry_DeploySquads(player1, sg_player1_reinforcements, Unit_Types.start_player_melee_mal, mkr_reinforcements_checkpoint)
	elseif player1_civ == "abbasid" then
		UnitEntry_DeploySquads(player1, sg_player1_reinforcements, Unit_Types.start_player_melee_abb, mkr_reinforcements_checkpoint)
	elseif player1_civ == "rus" or player1_civ == "french" then -- Calvary
		UnitEntry_DeploySquads(player1, sg_player1_reinforcements, Unit_Types.start_player_melee_cav, mkr_reinforcements_checkpoint)
	elseif player1_civ == "english" or player1_civ == "hre" then -- Infantry
		UnitEntry_DeploySquads(player1, sg_player1_reinforcements, Unit_Types.start_player_melee_inf, mkr_reinforcements_checkpoint)
	else
		UnitEntry_DeploySquads(player1, sg_player1_reinforcements, Unit_Types.start_player_melee, mkr_reinforcements_checkpoint) -- Default
	end 
	
	-- Set Direction
	Cmd_FormationMove(sg_player1_reinforcements, mkr_reinforcements_move_1, false, false, mkr_direction_temp)
	
	SendReinforceNotification(mkr_reinforcements_checkpoint, "$11176787") -- Reinforcements have arrived!
	
end

function Phase1_Checkpoint_Player2()
	local player2_civ = Player_GetRaceName(player2)
	
	-- Spawn Player 2 / Select faction
	if player2_civ == "malian" then
		UnitEntry_DeploySquads(player2, sg_player2_reinforcements, Unit_Types.start_player_ranged_mal, mkr_reinforcements_checkpoint)
	elseif player2_civ == "chinese" then
		UnitEntry_DeploySquads(player2, sg_player2_reinforcements, Unit_Types.start_player_ranged_chi, mkr_reinforcements_checkpoint)
	elseif player2_civ == "abbasid" then
		UnitEntry_DeploySquads(player2, sg_player2_reinforcements, Unit_Types.start_player_ranged_abb, mkr_reinforcements_checkpoint)
	elseif player2_civ == "mongol" then
		UnitEntry_DeploySquads(player2, sg_player2_reinforcements, Unit_Types.start_player_ranged_mon, mkr_reinforcements_checkpoint)
	elseif player2_civ == "rus" then
		UnitEntry_DeploySquads(player2, sg_player2_reinforcements, Unit_Types.start_player_ranged_rus, mkr_reinforcements_checkpoint)
	else
		UnitEntry_DeploySquads(player2, sg_player2_reinforcements, Unit_Types.start_player_ranged, mkr_reinforcements_checkpoint) -- Default
	end
	
	-- Set Direction
	Cmd_FormationMove(sg_player2_reinforcements, mkr_reinforcements_move_2, false, false, mkr_direction_temp)
	
end

function Phase1_Checkpoint_Player3()
	local player3_civ = Player_GetRaceName(player3)
	
	-- Spawn Player 3 / Select faction
	if player3_civ == "malian" then
		UnitEntry_DeploySquads(player3, sg_player3_reinforcements, Unit_Types.start_player_melee_mal, mkr_reinforcements_checkpoint)
	elseif player3_civ == "abbasid" then
		UnitEntry_DeploySquads(player3, sg_player3_reinforcements, Unit_Types.start_player_melee_abb, mkr_reinforcements_checkpoint)
	elseif player3_civ == "rus" or player3_civ == "french" then -- Calvary
		UnitEntry_DeploySquads(player3, sg_player3_reinforcements, Unit_Types.start_player_melee_cav, mkr_reinforcements_checkpoint)
	elseif player3_civ == "english" or player3_civ == "hre" then -- Infantry
		UnitEntry_DeploySquads(player3, sg_player3_reinforcements, Unit_Types.start_player_melee_inf, mkr_reinforcements_checkpoint)
	else
		UnitEntry_DeploySquads(player3, sg_player3_reinforcements, Unit_Types.start_player_melee, mkr_reinforcements_checkpoint) -- Default
	end
	
	-- Set Direction
	Cmd_FormationMove(sg_player3_reinforcements, mkr_reinforcements_move_3, false, false, mkr_direction_temp)
	
end

function Phase1_Checkpoint_Player4()
	local player4_civ = Player_GetRaceName(player4)

	-- Spawn Player 4 / Select faction
	if player4_civ == "malian" then
		UnitEntry_DeploySquads(player4, sg_player4_reinforcements, Unit_Types.start_player_ranged_mal, mkr_reinforcements_checkpoint)
	elseif player4_civ == "chinese" then
		UnitEntry_DeploySquads(player4, sg_player4_reinforcements, Unit_Types.start_player_ranged_chi, mkr_reinforcements_checkpoint)
	elseif player4_civ == "abbasid" then
		UnitEntry_DeploySquads(player4, sg_player4_reinforcements, Unit_Types.start_player_ranged_abb, mkr_reinforcements_checkpoint)
	elseif player4_civ == "mongol" then
		UnitEntry_DeploySquads(player4, sg_player4_reinforcements, Unit_Types.start_player_ranged_mon, mkr_reinforcements_checkpoint)
	elseif player4_civ == "rus" then
		UnitEntry_DeploySquads(player4, sg_player4_reinforcements, Unit_Types.start_player_ranged_rus, mkr_reinforcements_checkpoint)
	else
		UnitEntry_DeploySquads(player4, sg_player4_reinforcements, Unit_Types.start_player_ranged, mkr_reinforcements_checkpoint) -- Default
	end
	
	-- Set Direction
	Cmd_FormationMove(sg_player4_reinforcements, mkr_reinforcements_move_4, false, false, mkr_direction_temp)

end

function Phase1_Checkpoint_OnComplete()
	
	-- Reinforcements interval
	Phase1_Checkpoint_Player1()
	Rule_AddOneShot(Phase1_Checkpoint_Player2, 6)
	Rule_AddOneShot(Phase1_Checkpoint_Player3, 12)
	Rule_AddOneShot(Phase1_Checkpoint_Player4, 18)
	
end

-------------------------------------------
-- Objective: Capture Outposts 
-------------------------------------------

function Phase1_Outposts_InitObjectives()
	
	OBJ_Phase1_Outposts_Main = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:3" ,  -- "Capture the Outposts near the Village Enterances"
		Type = ObjectiveType_Battle, 
		SetupUI = Phase1_Outposts_UI, -- seting up how objective is presented
		OnStart = Phase1_Outposts_Start, --when objective start call function
		OnComplete = Phase1_Outposts_OnComplete, -- when objective completes, call function
	}
	OBJ_Phase1_Outposts_side1 = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:5",  -- "Defeat the resistance near the Western Outposts"
		Type = ObjectiveType_Battle, 
		SetupUI = Phase1_Outposts_UI, -- seting up how objective is presented
		Parent = OBJ_Phase1_Outposts_Main,
		--OnComplete = Phase1_Outposts_side_OnComplete, -- when objective completes, call function
	}
	OBJ_Phase1_Outposts_side2 = {
		Title = "$ae948c95a8c5425d8de28e0c193e0be9:4",  -- "Defeat the resistance near the Eastern Outposts"
		Type = ObjectiveType_Battle, 
		SetupUI = Phase1_Outposts_UI, -- seting up how objective is presented
		Parent = OBJ_Phase1_Outposts_Main,
		--OnComplete = Phase1_Outposts_side_OnComplete, -- when objective completes, call function
	}
	
	Objective_Register(OBJ_Phase1_Outposts_Main)
	Objective_Register(OBJ_Phase1_Outposts_side1)
	Objective_Register(OBJ_Phase1_Outposts_side2)
	
end

function Phase1_Outposts_UI()
	
	-- Main
	Objective_SetCounter(OBJ_Phase1_Outposts_Main, 0, 2) --Set the counter in the UI
	-- Side 1 
	Objective_SetCounter(OBJ_Phase1_Outposts_side1, 0, 2) 
	-- Side 2
	Objective_SetCounter(OBJ_Phase1_Outposts_side2, 0, 2) 
	
end

function Phase1_Outposts_Start()
	
	-- Outpost garrisoning is handled only by capture-time Garrison_Building calls.
	Phase1_RovingPatrol_Init()

	-- Add rules
	Rule_Add(Phase1_Outposts_count_side1)
	Rule_Add(Phase1_Outposts_count_side2)
	-- Add UI
	Objective_AddUIElements(OBJ_Phase1_Outposts_side1, mkr_spawn_outpost_1_rng, true, "$11121046", true) -- "Outpost"
	Objective_AddUIElements(OBJ_Phase1_Outposts_side1, mkr_spawn_outpost_2_rng, true, "$11121046", true) -- "Outpost"
	Objective_AddUIElements(OBJ_Phase1_Outposts_side2, mkr_spawn_outpost_3_rng, true, "$11121046", true) -- "Outpost"
	Objective_AddUIElements(OBJ_Phase1_Outposts_side2, mkr_spawn_outpost_4_rng, true, "$11121046", true) -- "Outpost"
	
	
	
	
end
-- Outposts East 
function Phase1_Outposts_count_side1()
	
	if Objective_IsComplete(OBJ_Phase1_Outposts_Main) == false then
		
		-- Check Group #1
		if SGroup_Count(sg_outpost_guards_1) == 0  then
			
			-- Check Outpost and change owner
			if World_OwnsEntity(cap_outpost_1) ~= true then
				
				-- Captured outpost
				if Entity_GetPlayerOwner(cap_outpost_1) ~= nil then 
					if Entity_GetPlayerOwner(cap_outpost_1) == player6 and Entity_IsAlive(cap_outpost_1) == true then
						EGroup_SetPlayerOwner(eg_outpost_1, player5)
						-- Add Springald upgrade
						Cmd_InstantUpgrade(eg_outpost_1, UPG.RUS.UPGRADE_WOODEN_CASTLE_SPRINGALD_RUS)
						Garrison_Building(None, { egroup = eg_outpost_1, amount = GARRISON_FILL_OUTPOST, player = player5 })
						
						-- Notification: Point captured
						UI_CreateEventCueClickable(-1, 15, -1, 0, event_cue_text, "", "low_priority", "", "sfx_campaign_Hastings_horn_reinforcements_arrive", 255, 255, 255, 255, ECV_Queue, nothing)
						UI_CreateMinimapBlip(mkr_spawn_outpost_1, 10, "general")
						
						-- Remove UI
						Objective_RemoveUIElements(OBJ_Phase1_Outposts_side1, 1)
						
						-- Side Objective +1
						if Objective_IsCounterSet(OBJ_Phase1_Outposts_side1) then
							Objective_IncreaseCounter(OBJ_Phase1_Outposts_side1)

							if Obj_GetCounterCount(OBJ_Phase1_Outposts_side1.ID) == Obj_GetCounterMax(OBJ_Phase1_Outposts_side1.ID) then 
								Objective_Complete(OBJ_Phase1_Outposts_side1, true, true) 
								
							end
						end
						
						-- Start allied Raid #1
						Phase1_VillageNorth_Assault_raid1()
					end	
				end	
			else
				-- Destroyed outpost
				if cap_outpost_1_kia == false then
					-- Notification: Point captured
					UI_CreateEventCueClickable(-1, 15, -1, 0, event_cue_text, "", "low_priority", "", "sfx_campaign_Hastings_horn_reinforcements_arrive", 255, 255, 255, 255, ECV_Queue, nothing)
					UI_CreateMinimapBlip(mkr_spawn_outpost_1, 10, "general")
					
					-- Remove UI
					Objective_RemoveUIElements(OBJ_Phase1_Outposts_side1, 1)
					
					-- Side Objective +1
					if Objective_IsCounterSet(OBJ_Phase1_Outposts_side1) then
						Objective_IncreaseCounter(OBJ_Phase1_Outposts_side1)
						if Obj_GetCounterCount(OBJ_Phase1_Outposts_side1.ID) == Obj_GetCounterMax(OBJ_Phase1_Outposts_side1.ID) then 
							Objective_Complete(OBJ_Phase1_Outposts_side1, true, true) 
							
						end
					end
					
					-- Variable switch
					cap_outpost_1_kia = true
				end
			end
			-- Ensure raid triggers regardless of outpost entity state
			Phase1_RovingPatrol_MarkTowerCaptured(1)
			Phase1_VillageNorth_Assault_raid1()
		end
		
		-- Check Group #2
		if SGroup_Count(sg_outpost_guards_2) == 0 then
			
			-- Check Outpost and change owner
			if World_OwnsEntity(cap_outpost_2) ~= true then
				
				-- Captured outpost
				if Entity_GetPlayerOwner(cap_outpost_2) ~= nil then
					if Entity_GetPlayerOwner(cap_outpost_2) == player6 and Entity_IsAlive(cap_outpost_2) == true then
						EGroup_SetPlayerOwner(eg_outpost_2, player5)
						-- Add Springald upgrade
						Cmd_InstantUpgrade(eg_outpost_2, UPG.RUS.UPGRADE_WOODEN_CASTLE_SPRINGALD_RUS)
						Garrison_Building(None, { egroup = eg_outpost_2, amount = GARRISON_FILL_OUTPOST, player = player5 })
						
						-- Notification: Point captured
						UI_CreateEventCueClickable(-1, 15, -1, 0, event_cue_text, "", "low_priority", "", "sfx_campaign_Hastings_horn_reinforcements_arrive", 255, 255, 255, 255, ECV_Queue, nothing)
						UI_CreateMinimapBlip(mkr_spawn_outpost_2, 10, "general")
						
						-- Remove UI
						Objective_RemoveUIElements(OBJ_Phase1_Outposts_side1, 2)
						
						-- Side Objective +1
						if Objective_IsCounterSet(OBJ_Phase1_Outposts_side1) then
							Objective_IncreaseCounter(OBJ_Phase1_Outposts_side1)

							if Obj_GetCounterCount(OBJ_Phase1_Outposts_side1.ID) == Obj_GetCounterMax(OBJ_Phase1_Outposts_side1.ID) then 
								Objective_Complete(OBJ_Phase1_Outposts_side1, true, true) 
								
							end
						end
						
						-- Start allied Raid #2
						Phase1_VillageNorth_Assault_raid2()
					end
				end
			else
				-- Destroyed outpost
				if cap_outpost_2_kia == false then
					-- Notification: Point captured
					UI_CreateEventCueClickable(-1, 15, -1, 0, event_cue_text, "", "low_priority", "", "sfx_campaign_Hastings_horn_reinforcements_arrive", 255, 255, 255, 255, ECV_Queue, nothing)
					UI_CreateMinimapBlip(mkr_spawn_outpost_2, 10, "general")
					
					-- Remove UI
					Objective_RemoveUIElements(OBJ_Phase1_Outposts_side1, 2)
					
					-- Side Objective +1
					if Objective_IsCounterSet(OBJ_Phase1_Outposts_side1) then
						Objective_IncreaseCounter(OBJ_Phase1_Outposts_side1)

						if Obj_GetCounterCount(OBJ_Phase1_Outposts_side1.ID) == Obj_GetCounterMax(OBJ_Phase1_Outposts_side1.ID) then 
							Objective_Complete(OBJ_Phase1_Outposts_side1, true, true) 
							
						end
					end
					
					-- Variable switch
					cap_outpost_2_kia = true
					
				end
			end
			-- Ensure raid triggers regardless of outpost entity state
			Phase1_RovingPatrol_MarkTowerCaptured(2)
			Phase1_VillageNorth_Assault_raid2()
		end

		-- Check both groups, complete objective
		if SGroup_Count(sg_checkpoint_group_1) == 0 then
			if Objective_IsComplete(OBJ_Phase1_Outposts_side1) == false then
				Objective_Complete(OBJ_Phase1_Outposts_side1, true, true) 
			end
			
			-- Main Objective +1
			if Objective_IsCounterSet(OBJ_Phase1_Outposts_Main) then
				
				Objective_IncreaseCounter(OBJ_Phase1_Outposts_Main)

				if Obj_GetCounterCount(OBJ_Phase1_Outposts_Main.ID) == Obj_GetCounterMax(OBJ_Phase1_Outposts_Main.ID) then 
					Objective_Complete(OBJ_Phase1_Outposts_Main, true, true) 
					
				end
			end
			
			
			Rule_RemoveMe()
		end
		
	else
		Rule_RemoveMe()
	end
	
end
-- Outposts West
