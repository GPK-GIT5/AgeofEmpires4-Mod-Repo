-------------------------------------------
-- Generic Spawn Helpers
-------------------------------------------

-- Deploy starting squad using composition map lookup
function _Deploy_Starting_Squad(player, civ, sg_start, role, spawn)
	local map = (role == "melee") and CIV_MELEE_MAP or CIV_RANGED_MAP
	local default = (role == "melee") and "start_player_melee" or "start_player_ranged"
	local key = ResolveCivMapKey(map, civ, default)
	UnitEntry_DeploySquads(player, sg_start, Unit_Types[key], spawn)
end

-- Deploy unique unit (Khan, King, Jeanne, or default Monks)
function _Deploy_Unique_Unit(player, civ, sg_unique, role, spawn)
	local map = (role == "melee") and UNIQUE_UNIT_MELEE or UNIQUE_UNIT_RANGED
	local entry = ResolveUniqueUnit(map, civ)
	local deploy = {numSquads = entry.numSquads, spawn = spawn}
	if entry.type then deploy.type = entry.type end
	if entry.sbp then deploy.sbp = entry.sbp end
	UnitEntry_DeploySquads(player, sg_unique, deploy, spawn)
end

-- Deploy reinforcements using composition map lookup
function _Deploy_Reinforcements(player, civ, sg_reinforce, role, spawn)
	local map = (role == "melee") and REINFORCE_MELEE_MAP or REINFORCE_RANGED_MAP
	local default = (role == "melee") and "units_player_melee_reinforce" or "units_player_ranged_reinforce"
	local key = ResolveCivMapKey(map, civ, default)
	UnitEntry_DeploySquads(player, sg_reinforce, Unit_Types[key], spawn)
end

-------------------------------------------
-- Start
-------------------------------------------

-- Setup allied starter units / Reinforcements
function Start_Setup_Players()
	
	-- Player config: { player id, start sgroup, unique sgroup, reinforcement sgroup, spawn marker, role }
	local player_configs = {
		{ id = player1, sg_start = sg_player1_start, sg_unique = sg_player1_unique, sg_reinforce = sg_player1_reinforcements, mkr = mkr_spawn_1, role = "melee", outpost_group = sg_outpost_group_1, outpost_count = "count_checkpoint_side1" },
		{ id = player2, sg_start = sg_player2_start, sg_unique = sg_player2_unique, sg_reinforce = sg_player2_reinforcements, mkr = mkr_spawn_2, role = "ranged", outpost_group = sg_outpost_group_1, outpost_count = "count_checkpoint_side1" },
		{ id = player3, sg_start = sg_player3_start, sg_unique = sg_player3_unique, sg_reinforce = sg_player3_reinforcements, mkr = mkr_spawn_3, role = "melee", outpost_group = sg_outpost_group_2, outpost_count = "count_checkpoint_side2" },
		{ id = player4, sg_start = sg_player4_start, sg_unique = sg_player4_unique, sg_reinforce = sg_player4_reinforcements, mkr = mkr_spawn_4, role = "ranged", outpost_group = sg_outpost_group_2, outpost_count = "count_checkpoint_side2" },
	}
	
	-- Deploy starting squads + unique units for each player
	for _, p in ipairs(player_configs) do
		local civ = Player_GetRaceName(p.id)
		_Deploy_Starting_Squad(p.id, civ, p.sg_start, p.role, p.mkr)
		_Deploy_Unique_Unit(p.id, civ, p.sg_unique, p.role, p.mkr)
	end
	
	-- Setup Reinforcements_Player rules 
	if DC.reinforcement_squad_count > 0 then
		for _, p in ipairs(player_configs) do
			p.count_start = SGroup_Count(p.sg_start) + SGroup_Count(p.sg_unique)
			p.precapture_remaining = DC.reinforcement_squad_count
			p.precapture_index = 1
			p.thresholds = DC.player_reinforcement_thresholds
			Rule_AddInterval(Reinforcements_PlayerRule, 5, { player_config = p })
		end
	end
	
	-- Objective: Regroup / Merge all player units
	for _, p in ipairs(player_configs) do
		SGroup_AddGroup(sg_players_all_start, p.sg_start)
		SGroup_AddGroup(sg_players_all_start, p.sg_unique)
	end
end
-- Setup enemey starting units / Patrols
function Start_Setup_Enemies()
	
	----------------------------------
	-- Objective: Capture Checkpoint
	----------------------------------
	
	-- Spawn defenders / Ranged
	UnitEntry_DeploySquads(player6, sg_checkpoint_units_2, Unit_Types.units_ranged_light, mkr_spawn_checkpoint_2)
	UnitEntry_DeploySquads(player6, sg_checkpoint_units_3, Unit_Types.units_ranged_light, mkr_spawn_checkpoint_3)
	
	-- Spawn defenders  (Difficulty: Hard + / Improved unit groups)
	if AI_Difficulty >= 2 then 
		UnitEntry_DeploySquads(player6, sg_checkpoint_units_1, Unit_Types.units_camp_hard, mkr_spawn_checkpoint_1)
		UnitEntry_DeploySquads(player6, sg_checkpoint_units_4, Unit_Types.units_camp_hard, mkr_spawn_checkpoint_4)
	else
		UnitEntry_DeploySquads(player6, sg_checkpoint_units_1, Unit_Types.units_camp, mkr_spawn_checkpoint_1)
		UnitEntry_DeploySquads(player6, sg_checkpoint_units_4, Unit_Types.units_camp, mkr_spawn_checkpoint_4)
	end
	
	-- Set direction & formation
	Cmd_Ability(sg_checkpoint_units_1, BP_GetAbilityBlueprint("core_formation_line"))
	Cmd_FormationMove(sg_checkpoint_units_1, mkr_spawn_checkpoint_1, false, false, mkr_direction_temp)
	Cmd_FormationMove(sg_checkpoint_units_2, mkr_spawn_checkpoint_2, false, false, mkr_direction_temp)
	Cmd_FormationMove(sg_checkpoint_units_3, mkr_spawn_checkpoint_3, false, false, mkr_direction_temp)
	
	-- Objective: Capture Checkpoint  
	SGroup_AddGroup(sg_checkpoint_group_all, sg_checkpoint_units_1) 
	SGroup_AddGroup(sg_checkpoint_group_all, sg_checkpoint_units_2)
	SGroup_AddGroup(sg_checkpoint_group_all, sg_checkpoint_units_3)
	SGroup_AddGroup(sg_checkpoint_group_all, sg_checkpoint_units_4)
	
	-- Count foward groups / Objective: Tower conversion
	count_checkpoint_all = SGroup_Count(sg_checkpoint_units_1) + SGroup_Count(sg_checkpoint_units_2) + SGroup_Count(sg_checkpoint_units_3)
	-- Count reserve group / Objective: Attack Raid #2
	count_checkpoint_reserves = SGroup_Count(sg_checkpoint_units_4)
	
	----------------------------------
	-- Objective: Capture Outposts
	----------------------------------
	
	-- Spawn defenders
	UnitEntry_DeploySquads(player6, sg_outpost_guards_1, Unit_Types.units_camp, mkr_spawn_outpost_1)
	UnitEntry_DeploySquads(player6, sg_outpost_guards_2, Unit_Types.units_camp, mkr_spawn_outpost_2)
	UnitEntry_DeploySquads(player6, sg_outpost_guards_3, Unit_Types.units_camp, mkr_spawn_outpost_3)
	UnitEntry_DeploySquads(player6, sg_outpost_guards_4, Unit_Types.units_camp, mkr_spawn_outpost_4)
	-- Set direction
	Cmd_FormationMove(sg_outpost_guards_1, mkr_spawn_outpost_1, false, false, mkr_spawn_1)
	Cmd_FormationMove(sg_outpost_guards_2, mkr_spawn_outpost_2, false, false, mkr_spawn_4)
	Cmd_FormationMove(sg_outpost_guards_3, mkr_spawn_outpost_3, false, false, mkr_spawn_3)
	Cmd_FormationMove(sg_outpost_guards_4, mkr_spawn_outpost_4, false, false, mkr_spawn_4)
	
	-- Spawn defenders / Ranged (Difficulty: Hard +)
	if AI_Difficulty >= 2 then 
		-- Spawn defenders
		UnitEntry_DeploySquads(player6, sg_outpost_guards_rng_1, Unit_Types.units_ranged_light, mkr_spawn_outpost_1_rng)
		UnitEntry_DeploySquads(player6, sg_outpost_guards_rng_2, Unit_Types.units_ranged_light, mkr_spawn_outpost_2_rng)
		UnitEntry_DeploySquads(player6, sg_outpost_guards_rng_3, Unit_Types.units_ranged_light, mkr_spawn_outpost_3_rng)
		UnitEntry_DeploySquads(player6, sg_outpost_guards_rng_4, Unit_Types.units_ranged_light, mkr_spawn_outpost_4_rng)
		-- Set direction
		Cmd_FormationMove(sg_outpost_guards_rng_1, mkr_spawn_outpost_1_rng, false, false, mkr_spawn_1)
		Cmd_FormationMove(sg_outpost_guards_rng_2, mkr_spawn_outpost_2_rng, false, false, mkr_spawn_4)
		Cmd_FormationMove(sg_outpost_guards_rng_3, mkr_spawn_outpost_3_rng, false, false, mkr_spawn_3)
		Cmd_FormationMove(sg_outpost_guards_rng_4, mkr_spawn_outpost_4_rng, false, false, mkr_spawn_4)
		
		-- Merge defender groups
		SGroup_AddGroup(sg_outpost_guards_1, sg_outpost_guards_rng_1) -- Group units / Side 1
		SGroup_AddGroup(sg_outpost_guards_2, sg_outpost_guards_rng_2)
		SGroup_AddGroup(sg_outpost_guards_3, sg_outpost_guards_rng_3) -- Group units / Side 2
		SGroup_AddGroup(sg_outpost_guards_4, sg_outpost_guards_rng_4)
	end

	-- Objective: Capture Outposts  
	SGroup_AddGroup(sg_outpost_group_1, sg_outpost_guards_1) -- Group #1 units 
	SGroup_AddGroup(sg_outpost_group_1, sg_outpost_guards_2)
	SGroup_AddGroup(sg_outpost_group_2, sg_outpost_guards_3) -- Group #2 units 
	SGroup_AddGroup(sg_outpost_group_2, sg_outpost_guards_4)
	-- Merge both groups to main
	SGroup_AddGroup(sg_outpost_group_all, sg_outpost_group_1)
	SGroup_AddGroup(sg_outpost_group_all, sg_outpost_group_2)
	-- Get group counts for objective
	count_checkpoint_side1 = SGroup_Count(sg_outpost_group_1)
	count_checkpoint_side2 = SGroup_Count(sg_outpost_group_2)
	
	----------------------------------
	-- Objective: Capture Village (N)
	----------------------------------
	
	-- Spawn defenders
	UnitEntry_DeploySquads(player6, sg_village_north_guards_1, Unit_Types.units_camp, mkr_spawn_village_1)
	UnitEntry_DeploySquads(player6, sg_village_north_guards_2, Unit_Types.units_camp, mkr_spawn_village_2)
	UnitEntry_DeploySquads(player6, sg_village_north_guards_3, Unit_Types.units_camp, mkr_spawn_village_3)
	UnitEntry_DeploySquads(player6, sg_village_north_guards_4, Unit_Types.units_camp, mkr_spawn_village_4)
	
	-- Set direction
	Cmd_FormationMove(sg_village_north_guards_1, mkr_spawn_village_1, false, false, mkr_spawn_outpost_1)
	Cmd_FormationMove(sg_village_north_guards_2, mkr_spawn_village_2, false, false, mkr_spawn_village_1)
	Cmd_FormationMove(sg_village_north_guards_3, mkr_spawn_village_3, false, false, mkr_spawn_village_4)
	Cmd_FormationMove(sg_village_north_guards_4, mkr_spawn_village_4, false, false, mkr_spawn_outpost_4_rng)
	
	-- Spawn defenders / Ranged (Difficulty: Intermediate +)
	if AI_Difficulty >= 1 then 
		-- Spawn defenders
		UnitEntry_DeploySquads(player6, sg_village_north_guards_rng_1, Unit_Types.units_ranged_light, mkr_spawn_village_1_rng)
		UnitEntry_DeploySquads(player6, sg_village_north_guards_rng_2, Unit_Types.units_ranged_light, mkr_spawn_village_2_rng)
		UnitEntry_DeploySquads(player6, sg_village_north_guards_rng_3, Unit_Types.units_ranged_light, mkr_spawn_village_3_rng)
		UnitEntry_DeploySquads(player6, sg_village_north_guards_rng_4, Unit_Types.units_ranged_light, mkr_spawn_village_4_rng)
		
		-- Set direction
		Cmd_FormationMove(sg_village_north_guards_rng_1, mkr_spawn_village_1_rng, false, false, mkr_spawn_outpost_1)
		Cmd_FormationMove(sg_village_north_guards_rng_2, mkr_spawn_village_2_rng, false, false, mkr_spawn_village_2)
		Cmd_FormationMove(sg_village_north_guards_rng_3, mkr_spawn_village_3_rng, false, false, mkr_spawn_village_4_rng)
		Cmd_FormationMove(sg_village_north_guards_rng_4, mkr_spawn_village_4_rng, false, false, mkr_spawn_outpost_4_rng)
		
		-- Merge defender groups
		SGroup_AddGroup(sg_village_north_guards_1, sg_village_north_guards_rng_1) 
		SGroup_AddGroup(sg_village_north_guards_2, sg_village_north_guards_rng_2)
		SGroup_AddGroup(sg_village_north_guards_3, sg_village_north_guards_rng_3) 
		SGroup_AddGroup(sg_village_north_guards_4, sg_village_north_guards_rng_4)
		
		
	end
	
	-- Merge all Northen Village defender groups
	SGroup_AddGroup(sg_village_north_group_all, sg_village_north_guards_1) 
	SGroup_AddGroup(sg_village_north_group_all, sg_village_north_guards_2)
	SGroup_AddGroup(sg_village_north_group_all, sg_village_north_guards_3) 
	SGroup_AddGroup(sg_village_north_group_all, sg_village_north_guards_4)
	
	----------------------------------
	-- Static defenders / Patrols
	----------------------------------
	
	-- River Guards
	UnitEntry_DeploySquads(player6, sg_river_guards_1, Unit_Types.units_river_guards, mkr_spawn_river_1)
	UnitEntry_DeploySquads(player6, sg_river_guards_2, Unit_Types.units_river_guards, mkr_spawn_river_2)
	-- Set direction/formation
	Cmd_Ability(sg_river_guards_1, BP_GetAbilityBlueprint("core_formation_line"))
	Cmd_Ability(sg_river_guards_2, BP_GetAbilityBlueprint("core_formation_line"))
	Cmd_FormationMove(sg_river_guards_1, mkr_spawn_river_1, false, false, mkr_wave_1_path_flank)
	Cmd_FormationMove(sg_river_guards_2, mkr_spawn_river_2, false, false, mkr_wave_2_path_flank)
	
	-- Camp Guards
	if AI_Difficulty >= 2 then
		UnitEntry_DeploySquads(player6, sg_camp_guards_1, Unit_Types.units_camp, mkr_spawn_camp_1)
		UnitEntry_DeploySquads(player6, sg_camp_guards_2, Unit_Types.units_camp, mkr_spawn_camp_2)
	else
		UnitEntry_DeploySquads(player6, sg_camp_guards_1, Unit_Types.units_camp_easy, mkr_spawn_camp_1)
		UnitEntry_DeploySquads(player6, sg_camp_guards_2, Unit_Types.units_camp_easy, mkr_spawn_camp_2)
	end
	
	-- Patrols
	if AI_Difficulty >= 3 then
		
		-- Spawn patrol #1 / Starting area 
		UnitEntry_DeploySquads(player6, sg_middle_patrol_1, Unit_Types.units_patrol_hard, mkr_wave_2_resources_1)
		Cmd_FormationAttackMove(sg_middle_patrol_1, mkr_spawn_camp_1)
		Rule_AddInterval(Patrol_Cycle, 240, { sgroup = sg_middle_patrol_1, path = patrol_mid_1 })
		-- Spawn patrol #2 / Starting area
		UnitEntry_DeploySquads(player6, sg_middle_patrol_2, Unit_Types.units_patrol_hard, mkr_wave_1_resources_1)
		Cmd_FormationAttackMove(sg_middle_patrol_2, mkr_wave_2_resources_1)
		Rule_AddInterval(Patrol_Cycle, 240, { sgroup = sg_middle_patrol_2, path = patrol_mid_2 })
	else
		
		-- Spawn patrol #1 / Starting area 
		UnitEntry_DeploySquads(player6, sg_middle_patrol_1, Unit_Types.units_patrol, mkr_wave_2_resources_1)
		Cmd_FormationAttackMove(sg_middle_patrol_1, mkr_spawn_camp_1)
		Rule_AddInterval(Patrol_Cycle, 240, { sgroup = sg_middle_patrol_1, path = patrol_mid_1 })
		-- Spawn patrol #2 / Starting area
		UnitEntry_DeploySquads(player6, sg_middle_patrol_2, Unit_Types.units_patrol, mkr_wave_2_resources_1)
		Cmd_FormationAttackMove(sg_middle_patrol_2, mkr_wave_2_resources_1)
		Rule_AddInterval(Patrol_Cycle, 240, { sgroup = sg_middle_patrol_2, path = patrol_mid_2 })
	end
	-- Enable respawns / Difficulty: Intermediate +
	if AI_Difficulty >= 1 then
		Rule_AddInterval(Patrol_Respawn, 60)
	end
	
end

-- Generic reinforcement handler — stepped threshold budget system
-- context.player_config = { id, sg_start, sg_unique, sg_reinforce, mkr, role,
--   outpost_group, outpost_count, count_start, precapture_remaining, precapture_index, thresholds }
function Reinforcements_PlayerRule(context, data)
	local p = data.player_config

	-- Budget exhausted AND all thresholds consumed → done
	if p.precapture_remaining <= 0 and p.precapture_index > #p.thresholds then
		Rule_RemoveMe()
		return
	end

	local civ = Player_GetRaceName(p.id)
	local total_alive = SGroup_Count(p.sg_start) + SGroup_Count(p.sg_unique)
	local ratio = total_alive / p.count_start

	-- Stepped depletion check: breach current threshold → deploy
	if p.precapture_index <= #p.thresholds and ratio <= p.thresholds[p.precapture_index] then
		if p.precapture_remaining > 0 then
			_Deploy_Reinforcements(p.id, civ, p.sg_reinforce, p.role, p.mkr)
			SendReinforceNotification(p.mkr, "$11176787") -- Reinforcements have arrived!
			p.precapture_remaining = p.precapture_remaining - 1
		end
		p.precapture_index = p.precapture_index + 1
		return
	end

	-- Outpost captured (group < 10%) — spend budget if available
	local outpost_threshold = _G[p.outpost_count] or 0
	if outpost_threshold > 0 and SGroup_Count(p.outpost_group) < 0.1 * outpost_threshold then
		if p.precapture_remaining > 0 then
			_Deploy_Reinforcements(p.id, civ, p.sg_reinforce, p.role, p.mkr)
			p.precapture_remaining = p.precapture_remaining - 1
		end
		Rule_RemoveMe()
		return
	end
end

