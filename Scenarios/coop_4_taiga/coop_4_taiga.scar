-- Reset_AI and disconnect handling: see coop_4_taiga_disconnect.scar

-- Unlocks Chinese Dynasty UI
function DynastyUI_unlocked()
	
	for i, player in pairs(PLAYERS) do 

		if IsCivFamily(player.id, "chinese") then 
			-- Dynasties unlocked
			Player_CompleteUpgrade(player.id, BP_GetUpgradeBlueprint "player_dynasty1_chi")
			Player_SetStateModelBool(player.id, "dynasty_1_was_completed_chi",true) 
			Player_CompleteUpgrade(player.id, BP_GetUpgradeBlueprint "player_dynasty2_chi")
			Player_SetStateModelBool(player.id, "dynasty_2_was_completed_chi",true) 

			-- Update UI
			Player_SetStateModelFloat(player.id, "current_dynasty_chi",1)
			if Game_GetLocalPlayer() == player.id then 
				DynastyUI_Update()
			end

			Player_SetStateModelFloat(player.id, "current_dynasty_chi",2)
			if Game_GetLocalPlayer() == player.id then 
				DynastyUI_Update()
			end
		end
	end
	
end

-- Group all Player units for Proximity Marker
function SGroup_Tracker(context, data)
	
	local player = data.player 
	
	Player_GetAll(player)
	SGroup_Filter(sg_allsquads, "military", FILTER_REMOVED, sg_player_team)
	--SGroup_AddGroup(sg_player_team, sg_allsquads)
	
	
end 

-- Patrol_Cycle & Units_Deploy / Thanks to Foxplot
function Patrol_Cycle(context, data) -- Used to cycle units between waypoints
	
	local sgroup = data.sgroup 
	local path = data.path 
	
	Cmd_FormationAttackMove(sgroup, path[1])
	for index, mkr in pairs(path) do
		if index > 1 then
			Cmd_FormationAttackMove(sgroup, mkr, true)
		end
	end	
	
end

-- 'Deploy_Unit' & 'Gaurdian_Raid' combined
function Units_Deploy(context, data) -- Used to spawn units / attack groups

	local player = data.player
	local sgroup = data.sgroup
	local unit_type = data.unit_type
	local spawn_loc = data.spawn_loc
	local path = data.path 


	UnitEntry_DeploySquads(player, sgroup, unit_type, spawn_loc)
	Cmd_FormationAttackMove(sgroup, path[1])
	for index, mkr in pairs(path) do
		if index > 1 then
			Cmd_FormationAttackMove(sgroup, mkr, true)
		end
	end

end

-- Puts archers in selected building
function Garrison_Building(context, data)

	local egroup = data.egroup
	local amount = data.amount
	local player = data.player

	if egroup == nil or amount == nil or player == nil then
		print("[GARRISON] skipped: missing egroup/amount/player")
		return
	end

	local _GarrisonOne = function(gid, idx, eid)
		if eid == nil or Entity_IsAlive(eid) ~= true then
			return
		end

		local free_slots = Entity_GetHoldSlotsAvailable(eid)
		if free_slots == nil or free_slots <= 0 then
			return
		end

		local spawn_count = math.min(amount, free_slots)
		if spawn_count <= 0 then
			return
		end

		EGroup_Single(eg_single, eid)
		SGroup_Clear(sg_garrison)
		local units = {
			{type = "scar_archer", numSquads = spawn_count},
		}
		local options = {
			ignorePathfindingPos = true,
			ignoreFormation = true,
		}

		UnitEntry_DeploySquads(player, sg_garrison, units, eg_single, nil, nil, options)
		Cmd_Garrison(sg_garrison, eg_single, nil, false, true)
	end

	EGroup_ForEach(egroup, _GarrisonOne)

end

-------------------------------------------
-- Nil-safe Siege Restriction Helpers
-------------------------------------------

---_ApplySiegeRestrictions: Lock/unlock siege units using nil-safe lookups.
-- DLC civs intentionally lack some keys — nil-safe helpers skip missing entries.
function _ApplySiegeRestrictions(player, state)
	local civ = string.lower(player.raceName)
	local siege = CBA_SIEGE_TABLE[civ]
	if siege == nil then
		local resolved = ResolveCivKey(civ)
		if resolved then siege = CBA_SIEGE_TABLE[resolved] end
	end
	if siege == nil then return end
	
	-- Nil-safe helpers: skip restriction if civ lacks the blueprint
	local function _squad(key)
		if siege[key] then Player_SetSquadProductionAvailability(player.id, BP_GetSquadBlueprint(siege[key]), state) end
	end
	local function _entity(key)
		if siege[key] then Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint(siege[key]), state) end
	end
	
	-- Mangonel (all civs)
	_squad(BP_SIEGE_MANGONEL)
	
	-- Abbasid/Mongol family: field construct mangonel
	if IsCivFamilyAny(player.id, {"abbasid", "mongol"}) then
		_entity(BP_SIEGE_MANGONEL_BUILDABLE)
	end
	
	-- Chinese/Mongol/Byzantine family: nest of bees
	if IsCivFamilyAny(player.id, {"chinese", "mongol", "byzantine"}) then
		_squad(BP_SIEGE_NESTOFBEES)
		if IsCivExact(player.id, "chinese") then
			Player_SetSquadProductionAvailability(player.id, SBP.CHINESE.UNIT_NEST_OF_BEES_4_CLOCKTOWER_CHI, state)
		end
	end
	
	-- Non-Chinese: ribauldequin
	if not IsCivFamily(player.id, "chinese") then
		_squad(BP_SIEGE_RIBAULDEQUIN)
		if IsCivFamily(player.id, "french") then
			_squad(BP_SIEGE_ROYAL_RIBAULDEQUIN)
		end
	end
	
	-- Ayyubids: ram tower (exact match only)
	if IsCivExact(player.id, "abbasid_ha_01") then
		Player_SetEntityProductionAvailability(player.id, EBP.ABBASID_HA_01.UNIT_RAM_TOWER_3_ABB_HA_01, state)
	end
	
	-- Mongol family: double siege
	if IsCivFamily(player.id, "mongol") then
		_squad(BP_SIEGE_MANGONEL_DOUBLE)
		_squad(BP_SIEGE_RIBAULDEQUIN_DOUBLE)
	end
	
	-- Byzantine base only: outpost mangonel upgrade
	if IsCivExact(player.id, "byzantine") then
		Player_SetUpgradeAvailability(player.id, UPG.BYZANTINE.UPGRADE_OUTPOST_MANGONEL_BYZ, state)
	end
end

---_ApplyBombardObjectiveRestrictions: Gate bombard/culverin production until Bombard objective completion.
-- Applies to all civs and DLC by scanning CBA_SIEGE_TABLE keys.
function _ApplyBombardObjectiveRestrictions(player, state)
	local civ = string.lower(player.raceName)
	local siege = CBA_SIEGE_TABLE[civ]
	if siege == nil then
		local resolved = ResolveCivKey(civ)
		if resolved then siege = CBA_SIEGE_TABLE[resolved] end
	end
	if siege == nil then return end

	for key, attrib in pairs(siege) do
		if attrib ~= nil and (string.find(key, "bombard") ~= nil or string.find(key, "culverin") ~= nil) then
			Player_SetSquadProductionAvailability(player.id, BP_GetSquadBlueprint(attrib), state)
		end
	end
end

---_ApplySiegeEngineersRestrictions: Lock/unlock siege engineer upgrades + field constructs.
function _ApplySiegeEngineersRestrictions(player, state)
	local player_civ = string.lower(Player_GetRaceName(player.id))
	
	-- Siege Engineers (Upgrade)
	if not IsCivFamily(player.id, "sultanate") then
		Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint("upgrade_siege_engineers"), state)
	else
		Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint("upgrade_siege_engineers_sul"), state)
	end
	
	-- Mongol: improved siege engineers
	if IsCivFamily(player.id, "mongol") then
		Player_SetUpgradeAvailability(player.id, BP_GetUpgradeBlueprint("upgrade_improved_siege_engineers_mon"), ITEM_REMOVED)
	end
	
	-- Abbasid family: field construct
	if IsCivExact(player.id, "abbasid") then
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_mangonel_3_buildable_abb"), state)
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_springald_3_buildable_abb"), state)
	end
	if IsCivExact(player.id, "abbasid_ha_01") then
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_mangonel_3_buildable_abb_ha_01"), state)
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_springald_3_buildable_abb_ha_01"), state)
		Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("unit_ram_tower_3_abb_ha_01"), state)
	end
end

-- From Advanced Game Settings by Woprock 
function AGS_GetCivilizationEntity(player_civ, bp_type)
	local bp = AGS_ENTITY_TABLE[player_civ][bp_type]
	if bp == nil or bp == false then return nil end
	return BP_GetEntityBlueprint(bp)
end 

---TryGetCivilizationEntity: Safe DLC-aware blueprint lookup.
-- Returns nil instead of erroring when civ lacks the requested bp_type.
function TryGetCivilizationEntity(player_civ, bp_type)
	local raw = string.lower(player_civ)
	if DLC_CIV_OVERRIDES[raw] and DLC_CIV_OVERRIDES[raw][bp_type] ~= nil then
		if DLC_CIV_OVERRIDES[raw][bp_type] == false then return nil end
		return BP_GetEntityBlueprint(DLC_CIV_OVERRIDES[raw][bp_type])
	end
	local resolved = ResolveCivKey(raw)
	if resolved == nil then return nil end
	local entry = AGS_ENTITY_TABLE[resolved]
	if entry == nil then return nil end
	local bp = entry[bp_type]
	if bp == nil or bp == false then return nil end
	return BP_GetEntityBlueprint(bp)
end

-- From Onslaught / Copy of AGS method above
function AGS_GetSiegeEntity(player_civ, bp_type)
	return BP_GetEntityBlueprint(CBA_SIEGE_TABLE[player_civ][bp_type])
end

function AGS_GetSiegeSquad(player_civ, bp_type)
	return BP_GetSquadBlueprint(CBA_SIEGE_TABLE[player_civ][bp_type])
end

-------------------------------------------
-- DLC Civ Helpers
-------------------------------------------

---ResolveCivKey: Given a raceName, return a valid key in AGS_ENTITY_TABLE.
-- Checks AGS directly first, then walks DLC_CIV_PARENT_MAP recursively.
function ResolveCivKey(raceName, _depth)
	if raceName == nil then return nil end
	raceName = string.lower(raceName)
	_depth = _depth or 0
	if _depth > DLC_RESOLVE_MAX_DEPTH then
		error("[DLC] ResolveCivKey: parent chain exceeded depth "
			.. DLC_RESOLVE_MAX_DEPTH .. " for '" .. raceName
			.. "'. Possible circular mapping.")
	end
	if AGS_ENTITY_TABLE[raceName] then
		return raceName
	end
	local parent = DLC_CIV_PARENT_MAP[raceName]
	if parent then
		return ResolveCivKey(parent, _depth + 1)
	end
	return nil
end

---GetPlayerCiv: Resolve and cache a player's civ key.
-- Returns a valid AGS_ENTITY_TABLE key, or errors.
function GetPlayerCiv(player_id)
	if DLC_PLAYER_CIV_CACHE[player_id] then
		return DLC_PLAYER_CIV_CACHE[player_id]
	end
	local raceName = string.lower(Player_GetRaceName(player_id))
	local resolved = ResolveCivKey(raceName)
	if resolved == nil then
		error("[DLC] GetPlayerCiv: Unknown civilization '" .. raceName
			.. "' for player " .. tostring(player_id)
			.. ". Not in AGS_ENTITY_TABLE or DLC_CIV_PARENT_MAP.")
	end
	DLC_PLAYER_CIV_CACHE[player_id] = resolved
	return resolved
end

---IsCivFamily: Returns true if the player's resolved civ matches family.
function IsCivFamily(player_id, family)
	return GetPlayerCiv(player_id) == family
end

---IsCivExact: Returns true if the player's raw raceName matches exactly.
function IsCivExact(player_id, civ_name)
	return string.lower(Player_GetRaceName(player_id)) == civ_name
end

---IsCivFamilyAny: Returns true if resolved civ matches any of the listed families.
function IsCivFamilyAny(player_id, families)
	local resolved = GetPlayerCiv(player_id)
	for _, fam in ipairs(families) do
		if resolved == fam then return true end
	end
	return false
end

-------------------------------------------
-- Defeat / Victory
-------------------------------------------

g_gameOver = false

function Defeat_Function()
	if g_gameOver then return end
	g_gameOver = true
	
	Rule_RemoveGlobalEvent(Reset_AI_OnMigrated)
	Rule_RemoveGlobalEvent(Reset_AI_OnTakeOver)
	if Rule_Exists(Reset_AI) then Rule_Remove(Reset_AI) end
	Tribute_Cleanup()
	
	Core_SetTeamDefeated(TEAMS[1], Annihilation_LoserPresentation, WR_ANNIHILATION)
end

function Victory_Function()
	if g_gameOver then return end
	g_gameOver = true
	
	Rule_RemoveGlobalEvent(Reset_AI_OnMigrated)
	Rule_RemoveGlobalEvent(Reset_AI_OnTakeOver)
	if Rule_Exists(Reset_AI) then Rule_Remove(Reset_AI) end
	Tribute_Cleanup()
	
	Core_SetTeamDefeated(TEAMS[2], Annihilation_LoserPresentation, WR_ANNIHILATION)
end
