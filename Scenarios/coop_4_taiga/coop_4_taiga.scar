function Mission_SetupPlayers()
	
	-- Get player IDs for each player
	player1 = World_GetPlayerAt(1) -- Players
	player2 = World_GetPlayerAt(2) 
	player3 = World_GetPlayerAt(3) 
	player4 = World_GetPlayerAt(4) 
	
	player5 = World_GetPlayerAt(5) -- Allied AI
	player6 = World_GetPlayerAt(6) -- Enemey AI

	
	
end


function Mission_SetupVariables()	-- create any extra sgroups, egroups, and mission variables in here
	
	-- Moved into Coop_4_Taiga_data.scar
	SetupVariables_data()
	
end


function Mission_SetRestrictions()	-- set up any restrictions (i.e. locking out units, etc) in here

	-- Upgrades/Abilities setup
	for _, player in pairs(PLAYERS) do
		local player_civ = Player_GetRaceName(player.id)
		
		-- Disable Stone/Palisade walls (Issues with AI paths)
		if not IsCivFamily(player.id, "mongol") then
			local ebp_stone = TryGetCivilizationEntity(player.raceName, AGS_BP_STONEWALL)
			if ebp_stone then
				Player_SetEntityProductionAvailability(player.id, ebp_stone, ITEM_REMOVED)
			end
			local ebp_palisade = TryGetCivilizationEntity(player.raceName, AGS_BP_PALISADE)
			if ebp_palisade then
				Player_SetEntityProductionAvailability(player.id, ebp_palisade, ITEM_REMOVED)
			end
		end

		-- Disable Dock (Default)
		local ebp_dock = TryGetCivilizationEntity(player.raceName, AGS_BP_DOCK)
		if ebp_dock then
			Player_SetEntityProductionAvailability(player.id, ebp_dock, ITEM_REMOVED)
		end
		
		-- Starting upgrades (Default)
		Player_CompleteUpgrade(player.id, UPG.COMMON.UPGRADE_SCOUT_FORESTER) -- Ability: Scout / Pickup
		
		-- Starting upgrades / Difficulty: Intermediate -
		if AI_Difficulty <= 1 then 
			-- Faction shared
			Player_CompleteUpgrade(player.id, UPG.COMMON.UPGRADE_MELEE_DAMAGE_I)
			Player_CompleteUpgrade(player.id, UPG.COMMON.UPGRADE_RANGED_ARMOR_I)
			-- Faction unique
			if IsCivExact(player.id, "english") then
				Player_CompleteUpgrade(player.id, UPG.ENGLISH.UPGRADE_UNIT_MANATARMS_2_ENG)
				Player_CompleteUpgrade(player.id, UPG.ENGLISH.UPGRADE_ARMOR_CLAD_ENG)
			end
			if IsCivExact(player.id, "hre") then
				Player_CompleteUpgrade(player.id, UPG.HRE.UPGRADE_MAN_AT_ARMS_TWO_HANDED_HRE)
				Player_CompleteUpgrade(player.id, UPG.HRE.UPGRADE_INSPIRED_INFANTRY_HRE)
			end
		end

		-- Disable Ability: Conversion / Difficulty: Hard +
		if AI_Difficulty >= 2 then
			Player_SetAbilityAvailability(player.id, BP_GetAbilityBlueprint("monk_conversion"), ITEM_REMOVED)
			-- Abbasid unique 
			if IsCivFamily(player.id, "abbasid") then
				Player_SetAbilityAvailability(player.id, BP_GetAbilityBlueprint ("monk_conversion_faith_abb"), ITEM_REMOVED)
			end
		end
		
	end
	
	-- Keep Restriction  / Difficulty: Intermediate +
	if AI_Difficulty >= 1 then 
		for _, player in pairs(PLAYERS) do
			local player_civ = Player_GetRaceName(player.id)
			
			-- All factions
			local ebp_keep = TryGetCivilizationEntity(player.raceName, AGS_BP_KEEP)
			if ebp_keep then
				Player_SetEntityProductionAvailability(player.id, ebp_keep, ITEM_REMOVED)
			end
			-- Faction specific
			if player_civ == "english" then
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint ("building_landmark_age2_white_tower_eng"), ITEM_REMOVED)
			end
			if player_civ == "lancaster" then
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age2_white_tower_lan"), ITEM_REMOVED)
			end
			-- Landmarks / (Difficulty check for 'Age 4 Restriction / Difficulty: Hard +')
			if AI_Difficulty <= 1 then 
				if player_civ == "english" then
					Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint ("building_landmark_age3_windsor_castle_eng"), ITEM_REMOVED)
				end
				if player_civ == "french" then
					Player_SetEntityProductionAvailability(player.id, EBP.FRENCH.BUILDING_LANDMARK_AGE2_LA_CHATEAU_ROUGE_FRE, ITEM_REMOVED)
				end
				if player_civ == "french_ha_01" then
					Player_SetEntityProductionAvailability(player.id, EBP.FRENCH_HA_01.BUILDING_LANDMARK_AGE2_LA_CHATEAU_ROUGE_FRE_HA_01, ITEM_REMOVED)
				end
				if player_civ == "hre" then
					Player_SetEntityProductionAvailability(player.id, EBP.HRE.BUILDING_LANDMARK_AGE3_ELTZ_CASTLE_HRE, ITEM_REMOVED)
				end
				if player_civ == "hre_ha_01" then
					Player_SetEntityProductionAvailability(player.id, EBP.HRE_HA_01.BUILDING_LANDMARK_AGE3_ELTZ_CASTLE_HRE_HA_01, ITEM_REMOVED)
				end
				if player_civ == "japanese" then
					Player_SetEntityProductionAvailability(player.id, EBP.JAPANESE.BUILDING_LANDMARK_AGE3_TREASURE_JPN, ITEM_REMOVED)
				end
				if player_civ == "malian" then
					Player_SetEntityProductionAvailability(player.id, EBP.MALIAN.BUILDING_LANDMARK_AGE3_LANDMARKF_MAL, ITEM_REMOVED)
				end
				if player_civ == "ottoman" then
					Player_SetEntityProductionAvailability(player.id, EBP.OTTOMAN.BUILDING_LANDMARK_AGE3_KILITBAHIR_CASTLE_OTT, ITEM_REMOVED)
				end
				if player_civ == "rus" then
					Player_SetEntityProductionAvailability(player.id, EBP.RUS.BUILDING_LANDMARK_AGE3_SPASSAKAYA_TOWER_CONTROL_RUS, ITEM_REMOVED)
				end
				-- KoCR DLC factions
				if player_civ == "lancaster" then
					Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_berkshire_lan"), ITEM_REMOVED)
				end
				if player_civ == "japanese_ha_sen" then
					Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_crow_jpn_ha_sen"), ITEM_REMOVED)
				end
				if player_civ == "byzantine_ha_mac" then
					Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_eastern_merc_house_byz_ha_mac"), ITEM_REMOVED)
				end
				if player_civ == "sultanate_ha_tug" then
					Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_madrasa_e_firoz_sul_ha_tug"), ITEM_REMOVED)
				end
			end
		end
		
	end
	
	-- Siege Restriction  / Difficulty: Intermediate +
	if AI_Difficulty >= 1 then
		for _, player in pairs(PLAYERS) do
			_ApplySiegeRestrictions(player, ITEM_LOCKED)
		end
	end

	-- Bombard objective gate: lock bombard/culverin families for all civs until Phase3_SiegeCapture completes.
	for _, player in pairs(PLAYERS) do
		_ApplyBombardObjectiveRestrictions(player, ITEM_LOCKED)
	end

	-- Siege Engineers Restriction / Difficulty: Hard +
	if AI_Difficulty >= 2 then
		for _, player in pairs(PLAYERS) do
			_ApplySiegeEngineersRestrictions(player, ITEM_LOCKED)
		end
	end
	-- Workshop Restriction / Difficulty: Hardest +
	if AI_Difficulty >= 5 then
		for _, player in pairs(PLAYERS) do
			local ebp = TryGetCivilizationEntity(player.raceName, AGS_BP_WORKSHOP)
			if ebp then
				Player_SetEntityProductionAvailability(player.id, ebp, ITEM_LOCKED)
			end
		end
	end
	
	-- Age 4 Restriction / Difficulty: Hard +
	if AI_Difficulty >= 2 then 
		-- Restrict players max age to Castle Age
		for _, player in pairs(PLAYERS) do
			Player_SetMaximumAge(player.id, AGE_CASTLE)
		end
		
		-- Faction specific
		for _, player in pairs(PLAYERS) do
			local player_civ = Player_GetRaceName(player.id)	
			
			-- House of Wisdom / Age 4 upgrades
			if player_civ == "abbasid" then
				Player_SetUpgradeAvailability(player.id, UPG.ABBASID.UPGRADE_ADD_CULTURE_WING_CASTLE, ITEM_REMOVED)
				Player_SetUpgradeAvailability(player.id, UPG.ABBASID.UPGRADE_ADD_TRADE_WING_CASTLE, ITEM_REMOVED)
				Player_SetUpgradeAvailability(player.id, UPG.ABBASID.UPGRADE_ADD_MILITARY_WING_CASTLE, ITEM_REMOVED)
				Player_SetUpgradeAvailability(player.id, UPG.ABBASID.UPGRADE_ADD_ECONOMY_WING_CASTLE, ITEM_REMOVED)
			end
			
			-- Landmarks / Age 4
			if player_civ == "hre" then
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint ("building_landmark_age3_hohenzollern_castle_hre"), ITEM_REMOVED)
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint ("building_landmark_age3_eltz_castle_hre"), ITEM_REMOVED)
			end
			-- Landmarks / Age 4
			if player_civ == "malian" then
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_Age3_landmarke_mal"), ITEM_REMOVED)
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_Age3_landmarkf_mal"), ITEM_REMOVED)
			end
			-- Landmarks / Age 4
			if player_civ == "ottoman" then
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_istanbul_observatory_ott"), ITEM_REMOVED)
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_kilitbahir_castle_ott"), ITEM_REMOVED)
			end
			
			-- Landmarks / Age 4 / Sultan DLC
			if player_civ == "japanese" then
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_ozutsu_jpn"), ITEM_REMOVED)
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_treasure_jpn"), ITEM_REMOVED)
			end
			if player_civ == "byzantine" then
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_eastern_merc_house_byz"), ITEM_REMOVED)
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_western_merc_house_byz"), ITEM_REMOVED)
			end
			if player_civ == "chinese_ha_01" then
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_temple_of_the_sun_control_chi_ha_01"), ITEM_REMOVED)
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_library_chi_ha_01"), ITEM_REMOVED)
			end
			if player_civ == "french_ha_01" then
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_ecole_de_poudre_a_canon_fre_ha_01"), ITEM_REMOVED)
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age2_la_chateau_rouge_fre_ha_01"), ITEM_REMOVED)
			end
			if player_civ == "hre_ha_01" then
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_eltz_castle_hre_ha_01"), ITEM_REMOVED)
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_hohenzollern_castle_hre_ha_01"), ITEM_REMOVED)
			end
			-- Landmarks / Age 4 / KoCR DLC
			if player_civ == "lancaster" then
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_berkshire_lan"), ITEM_REMOVED)
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_wynguard_lan"), ITEM_REMOVED)
			end
			if player_civ == "byzantine_ha_mac" then
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_eastern_merc_house_byz_ha_mac"), ITEM_REMOVED)
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_western_merc_house_byz_ha_mac"), ITEM_REMOVED)
			end
			if player_civ == "japanese_ha_sen" then
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_crow_jpn_ha_sen"), ITEM_REMOVED)
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_statue_jpn_ha_sen"), ITEM_REMOVED)
			end
			if player_civ == "sultanate_ha_tug" then
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_madrasa_e_firoz_sul_ha_tug"), ITEM_REMOVED)
				Player_SetEntityProductionAvailability(player.id, BP_GetEntityBlueprint("building_landmark_age3_bijay_mandal_palace_control_sul_ha_tug"), ITEM_REMOVED)
			end
			-- House of Wisdom / Age 4 upgrades
			if player_civ == "abbasid_ha_01" then
				Player_SetUpgradeAvailability(player.id, UPG.ABBASID_HA_01.UPGRADE_ADD_CULTURE_WING_CASTLE_A_ABB_HA_01, ITEM_REMOVED)
				Player_SetUpgradeAvailability(player.id, UPG.ABBASID_HA_01.UPGRADE_ADD_CULTURE_WING_CASTLE_B_ABB_HA_01, ITEM_REMOVED)
				Player_SetUpgradeAvailability(player.id, UPG.ABBASID_HA_01.UPGRADE_ADD_TRADE_WING_CASTLE_A_ABB_HA_01, ITEM_REMOVED)
				Player_SetUpgradeAvailability(player.id, UPG.ABBASID_HA_01.UPGRADE_ADD_TRADE_WING_CASTLE_B_ABB_HA_01, ITEM_REMOVED)
				Player_SetUpgradeAvailability(player.id, UPG.ABBASID_HA_01.UPGRADE_ADD_ECONOMY_WING_CASTLE_A_ABB_HA_01, ITEM_REMOVED)
				Player_SetUpgradeAvailability(player.id, UPG.ABBASID_HA_01.UPGRADE_ADD_ECONOMY_WING_CASTLE_B_ABB_HA_01, ITEM_REMOVED)
				Player_SetUpgradeAvailability(player.id, UPG.ABBASID_HA_01.UPGRADE_ADD_MILITARY_WING_CASTLE_A_ABB_HA_01, ITEM_REMOVED)
				Player_SetUpgradeAvailability(player.id, UPG.ABBASID_HA_01.UPGRADE_ADD_MILITARY_WING_CASTLE_B_ABB_HA_01, ITEM_REMOVED)
			end
			
		end
	end

end

-- This function will be called before the intro cinematic
function Mission_Preset()	-- any other setup to do before the mission starts (i.e. set up rules, spawn units, etc)
	
	AI_SetPersonality(player5, "default_campaign")
	AI_SetPersonality(player6, "default_campaign")
	
	-- Add starting population +50
	local pop_mod = Modifier_Create(MAT_Player, "personnel_cap_player_modifier", MUT_Addition, false, 50, "")
	for _, player in pairs(PLAYERS) do
		Modifier_ApplyToPlayer(pop_mod, player.id, 0)
		Player_CompleteUpgrade(player.id, UPG.COMMON.UPGRADE_SCOUT_FORESTER)
		Player_SetStateModelBool(player.id, "player_can_interact_with_resource_pickups", true)
	end	

	-- Initialize path data
	Unit_Path_Data() 
	
	-- Initialize objectives
	Phase1_Checkpoint_InitObjectives() -- Phase #1
	Phase1_Outposts_InitObjectives()
	Phase1_VillageNorth_InitObjectives()
	Phase1_VillageDefence_InitObjectives()
	
	Phase2_VillageCapture_InitObjectives() -- Phase #2
	PrepareDefences_InitObjectives() -- Notification: Wave warning
	
	Phase3_SiegeCapture_InitObjectives()
	Phase3_CityAssault_InitObjectives()
	Phase3_FinalKeep_InitObjectives()
	
end

function Mission_SetPlayer6BuildingTargetingManual()
	local buildings = Player_GetEntities(player6)
	local eg_manual_targeting = EGroup_CreateIfNotFound("eg_player6_manual_targeting")
	EGroup_Clear(eg_manual_targeting)

	local _CollectEligibleBuilding = function(group_id, entity_index, entity)
		if Entity_IsAlive(entity) ~= true then
			return false
		end

		local bp_name = BP_GetName(Entity_GetBlueprint(entity))
		if string.sub(bp_name, 1, 9) ~= "building_"
    and bp_name ~= "military_tent_a_rus"
    and bp_name ~= "military_tent_b_eng"
    and bp_name ~= "york_dane_tent_eng" then
    return false
	end
		if Entity_IsOfType(entity, "outpost") then
			return false
		end
		if bp_name == "building_defense_tower_rus" or bp_name == "building_defense_keep_control_rus" then
			return false
		end

		EGroup_Add(eg_manual_targeting, entity)
		return false
	end

	EGroup_ForEach(buildings, _CollectEligibleBuilding)
	if EGroup_CountSpawned(eg_manual_targeting) > 0 then
		EGroup_SetTargetingType(eg_manual_targeting, Targeting_Manual)
	end
end

-- This function will be called after the intro cinematic, before the player takes control
function Mission_Start()	-- this is triggered after the intro, just as control is passed to the player
	
	-- Per-player Mission_Start setup (TC menu, UI overrides)
	for _, player in ipairs(PLAYERS) do
		Player_SetStateModelFloat(player.id, "has_capital", 0)
		UI_SetPlayerDataContext(player.id, { PopulationCapOn = false, hide_condensed_objectives_override = true })
	end
	
	-- Setup AI starting age 
	Player_SetCurrentAge(player5, AGE_CASTLE)
	Player_SetCurrentAge(player6, AGE_CASTLE)
	-- Set player age
--	Player_SetCurrentAge(player1, AGE_FEUDAL) 
--	Player_SetCurrentAge(player2, AGE_FEUDAL)
--	Player_SetCurrentAge(player3, AGE_FEUDAL) 
--	Player_SetCurrentAge(player4, AGE_FEUDAL)
	-- Hide population UI / Condensed objectives fix
	for _, player in pairs(PLAYERS) do
		UI_SetPlayerDataContext(player.id, { PopulationCapOn = false, hide_condensed_objectives_override = true })
	end
	
	-- Spawn Player units
	Rule_AddOneShot(Start_Setup_Players, 0) -- Delay to load models from age up
	
	-- Spawn Enemey units
	Start_Setup_Enemies()
	
	-- Starting objectives
	Objective_Start(OBJ_Phase1_Checkpoint_main,true, false)
	Objective_Start(OBJ_Phase1_Checkpoint_clear,false, false)
	Objective_Start(OBJ_Phase1_Checkpoint_regroup,true, false)
	
	Objective_Start(OBJ_Phase1_Outposts_Main,true, false)
	Objective_Start(OBJ_Phase1_Outposts_side1, false, false)
	Objective_Start(OBJ_Phase1_Outposts_side2, false, false)
	
	-- SGroup Tracker: Group all Player units for Proximity Marker
	for _, player in pairs(PLAYERS) do
		Rule_AddInterval(SGroup_Tracker, 60, { player = player.id })
	end
	
	-- Disable damage for objective related entities
	local TC_North = EGroup_GetClosestEntity(eg_village_north, mkr_tc_north)
	local TC_South = EGroup_GetClosestEntity(eg_village_south, mkr_tc_south)
	
	Entity_SetInvulnerable(TC_North, true, -1)
	Entity_SetInvulnerable(TC_South, true, -1)
	SGroup_SetInvulnerable(sg_siege_capture, true, -1) -- Bombards
	EGroup_SetInvulnerable(eg_wood_bridge, true, -1) -- Bridge
	
	-- Disable targeting of RUS Buildings
	EGroup_SetTargetingType(eg_village_north, Targeting_None)
	EGroup_SetTargetingType(eg_village_south, Targeting_None)
	Mission_SetPlayer6BuildingTargetingManual()
	
	-- Enable Training
	Training_Init()
	Training_ForceGoalsActive()  
	-- Enable Hints
	Wallingford_AddHintToRepair()
	
	-- Enable interactive zone 
	World_SetInteractionStage(1)
	
	-- Disconnect system: slots 1-4 are co-op human seats by design
	-- (Player_IsHuman() only works for local player in multiplayer)
	for i = 1, 4 do
		g_original_player_types[i] = true
	end
	
	-- AI personality enforcement + disconnect detection
	Rule_AddGlobalEvent(Reset_AI_OnMigrated, GE_AIPlayer_Migrated)
	Rule_AddGlobalEvent(Reset_AI_OnTakeOver, GE_AITakeOver)
	Rule_AddInterval(Reset_AI, 1)
	
	-- Tribute system
	Tribute_Init()
	
	-- Disable 'Annihilation' defeat condition
	Rule_RemoveGlobalEvent(Annihilation_OnEntityKilled)
	Rule_RemoveGlobalEvent(Annihilation_OnLandmarkDestroyed)
	Rule_RemoveGlobalEvent(Annihilation_OnConstructionComplete)
	
end

