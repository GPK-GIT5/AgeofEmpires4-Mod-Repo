-- ============================================================
-- DIFFICULTY FUNCTIONS
-- ============================================================

-- Thanks to AGameAnx		
function GetAIDifficulty(player)
	local AIPlayerNames = {
		[Loc_ToAnsi(1309)] = 0,     -- A.I. Easy
		[Loc_ToAnsi(1310)] = 1,     -- A.I. Intermediate
		[Loc_ToAnsi(1311)] = 2,     -- A.I. Hard
		[Loc_ToAnsi(1312)] = 3,     -- A.I. Hardest
		[Loc_ToAnsi(11250912)] = 4, -- A.I. Ridiculous
		[Loc_ToAnsi(11250913)] = 5, -- A.I. Outrageous
		[Loc_ToAnsi(11250914)] = 6, -- A.I. Absurd
	}
	-- Strip leading player slot number (e.g. "3 A.I. Intermediate" → "A.I. Intermediate")
	local player_ansi = string.gsub(Loc_ToAnsi(Player_GetDisplayName(player)), "^%d+%s+", "")
	local tier = AIPlayerNames[player_ansi]
	if tier == nil then
		print(string.format("[DIFFICULTY] WARNING: Unmapped AI name '%s', defaulting to Hard (2)", player_ansi))
		return 2
	end
	return tier
end

---Difficulty_Init: Call once after AI_Difficulty is set.
-- Sets the global DC (Difficulty Config) to the active tier.
function Difficulty_Init()
	DC = Difficulty_Config[AI_Difficulty]
	if DC == nil then
		print(string.format("[DIFFICULTY] WARNING: No config for tier %d, falling back to Hard (2)", AI_Difficulty))
		DC = Difficulty_Config[2]
	end
	print(string.format("[DIFFICULTY] Initialized: %s (tier %d)", DC.label, AI_Difficulty))
end
