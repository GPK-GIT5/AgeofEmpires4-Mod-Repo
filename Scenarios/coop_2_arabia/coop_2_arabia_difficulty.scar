--[[
	Filename: coop_2_arabia_difficulty.scar
	Description: Difficulty tiers and configuration for Arabia co-op scenario
	Last Modified: 2026-02-28
	
	HOW IT WORKS
	  1. The game reads the AI difficulty selected in lobby.
	  2. GetAIDifficulty() maps lobby name to tier number.
	  3. Difficulty_Init() picks the matching tier and stores it in DC.
	  4. All game logic reads from DC instead of raw numbers.
	
	HOW TO EDIT
	  Find the tier you want to change (Easy, Intermediate, …)
	  and adjust the values inside it. Each field has a comment
	  explaining what it does. Save the file and test in-game.
	
	TIER REFERENCE
	  0 = Easy          Beginner-friendly, extra resources, no restrictions
	  1 = Intermediate  Baseline difficulty (≈ TIER_DEFAULTS)
	  2 = Hard          Standard challenge, conversion locked
	  3 = Hardest       Extra waves, fewer resources, hard camps
]]

-- ============================================================
-- TIER_DEFAULTS — INTERMEDIATE BASELINE
--
-- This block defines INTERMEDIATE difficulty (Tier 1).
-- All tiers override only the fields that differ from this baseline.
-- Every field used in Difficulty_Config is defined here.
-- ============================================================
TIER_DEFAULTS = {

	-- ===== PLAYER UPGRADES =====
	player_upgrades_bonus			= false,	-- Free melee damage I + ranged armor I (Easy only)
	player_upgrades_extra			= true,		-- Free ranged damage I + melee armor I

	-- ===== PLAYER RESTRICTIONS =====
	restrict_keep					= true,		-- Lock keep building
	restrict_keep_landmarks			= true,		-- Lock keep-related landmarks (data-driven table)
	restrict_siege					= true,		-- Lock individual siege units (mangonel, ribauldequin, etc.)
	restrict_engineers				= false,		-- Reserved flag (engineers always available in Arabia)
	restrict_workshop				= true,		-- Lock siege workshop building (always true — captured, not built)
	restrict_age4					= false,	-- Lock Age 4 + landmarks (Hard+ only)
	disable_conversion				= false,	-- Block monk conversion ability

	-- ===== PHASE 2 PROGRESSION =====
	phase2_siege_profile			= "siege_available",	-- Profile applied on siege workshop capture
	phase2_workshop_unlock			= false,				-- Whether to also unlock workshop building

	-- ===== ENEMY CAMP STRENGTH =====
	camp_strength					= "easy",	-- "easy" | "hard" starting enemy camp composition
	city_guard_strength				= "easy",	-- "easy" | "hard" city guards after checkpoint

	-- ===== REINFORCEMENTS =====
	trader_reinforcements			= false,	-- Enable enemy QRF trader reinforcement
	reinforcement_pre_capture		= true,		-- Allow player reinforcement before village capture
	siege_reinforcements			= true,		-- Spawn siege for players after checkpoint
	reinforcement_squad_count		= 2,		-- Total reinforcement events per player (Easy=3, Int=2, Hard/Hardest=1)

	-- ===== TIMER =====
	seize_city_timer				= 4800,		-- Countdown timer (seconds): 80 min

	-- ===== RESOURCES (after mine capture) =====
	starting_food					= 2500,		-- Food given after village capture
	starting_gold					= 1500,		-- Gold given after village capture
	starting_wood					= 1000,		-- Wood given after village capture

	-- ===== ATTACK WAVES =====
	waves_5min_flank				= true,		-- Extra flank wave at 5 min
	waves_late_extra				= true,		-- Late waves (40m / 45m)
	waves_hardest_extra				= false,	-- Hardest-only extra waves (3m / 15m / 30m / 35m / 40m)
	checkpoint_wave_interval		= 480,		-- Wave respawn interval after checkpoint (seconds)

	-- ===== CHECKPOINT SPAWNS =====
	checkpoint_blockade_melee		= true,		-- Melee group defending ranged blockade
	checkpoint_upgrades_extra		= true,		-- Extra AI upgrades after checkpoint (spearman 4, etc.)

	-- ===== AI UPGRADES =====
	ai_capture_spearman_upgrade		= true,		-- Spearman II upgrade after mine capture
	-- ===== TRIBUTE =====
	tribute_tax_rate					= 0.15,		-- Tribute tax rate (0.0 = free, 0.3 = 30%)
}

-- ---------------------------------------------------------
-- _MergeTier: Shallow-copy TIER_DEFAULTS, then overlay.
-- Returns a complete tier table ready for DC consumption.
-- ---------------------------------------------------------
local function _MergeTier(overrides)
	local tier = {}
	for k, v in pairs(TIER_DEFAULTS) do
		tier[k] = v
	end
	for k, v in pairs(overrides) do
		tier[k] = v
	end
	return tier
end

