				--units = {
					--{type = "scar_spearman", numSquads = 3, spawn = mkr_mkrNameInEditor},
				--},
			--},
			
		},

		
		-- Presentation aspects for the start or end of a mission
		onStart = {
			intelEvent = "",
			expositionCamera = {},
			titleCard = {
				icon = "icons/campaign/campaign_angevin_the_conquest", --icon to use for title card on mission start
				location = LOC("Location, year"),
			},
			actions = {
			},
		},
	}

		
		
	return recipe

end
function statechange()
	Rule_AddOneShot(toDusk, 0)
	Rule_AddOneShot(toDusk2, 300)
	Rule_AddOneShot(toNight, 600)
	Rule_AddOneShot(toNight2, 900)
	Rule_AddOneShot(toDawn, 1200)
	Rule_AddOneShot(toDay, 1500)
end
function toDay()
	Game_TransitionToState("day", 300)
end
function toDusk()
	Game_TransitionToState("dusk", 300)
end
function toDusk2()
	Game_TransitionToState("dusk2", 300)
end
function toNight()
	Game_TransitionToState("night", 300)
end
function toNight2()
	Game_TransitionToState("night2", 300)
end
function toDawn()
	Game_TransitionToState("dawn", 300)
end
	


